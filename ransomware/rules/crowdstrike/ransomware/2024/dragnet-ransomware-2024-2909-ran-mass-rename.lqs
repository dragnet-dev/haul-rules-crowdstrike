// Dragnet [Ransomware]: dragnet-ransomware-2024-2909 — Mass File Rename (darkvault)
// Status: experimental | Level: high | ID: 07e3a937-2c8a-5f2b-a463-b1d8da812f64

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
