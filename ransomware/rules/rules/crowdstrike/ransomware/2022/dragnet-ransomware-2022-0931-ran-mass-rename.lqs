// Dragnet [Ransomware]: dragnet-ransomware-2022-0931 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: c1427aa8-97c1-5f81-9e1d-5b990a0e6c23

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
