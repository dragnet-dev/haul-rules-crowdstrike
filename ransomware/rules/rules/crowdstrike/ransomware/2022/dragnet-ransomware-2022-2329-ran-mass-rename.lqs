// Dragnet [Ransomware]: dragnet-ransomware-2022-2329 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 2a366b75-5a37-540f-88bd-bfe517ab4802

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
