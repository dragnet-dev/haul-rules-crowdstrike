// Dragnet [Ransomware]: dragnet-ransomware-2022-1486 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 8c3e7dd4-2992-577f-ba5b-88a3804f5f83

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
