// Dragnet [Ransomware]: dragnet-ransomware-2025-4837 — Mass File Rename (global)
// Status: deprecated | Level: high | ID: 97100987-44b7-5418-91bc-cf86d43315eb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
