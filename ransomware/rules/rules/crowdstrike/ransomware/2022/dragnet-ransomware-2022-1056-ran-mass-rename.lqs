// Dragnet [Ransomware]: dragnet-ransomware-2022-1056 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: f6820c7f-31a8-5e0a-9453-208439450e9b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
