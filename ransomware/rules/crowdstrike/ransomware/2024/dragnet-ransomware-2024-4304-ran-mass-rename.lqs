// Dragnet [Ransomware]: dragnet-ransomware-2024-4304 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: fcd05117-bbf2-5efb-88bb-20ce2e999d3c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
