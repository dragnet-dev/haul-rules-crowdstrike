// Dragnet [Ransomware]: dragnet-ransomware-2022-1987 — Mass File Rename (everest)
// Status: deprecated | Level: high | ID: 3ab81c0f-3f4a-5ff6-ae66-0176632c99dc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
