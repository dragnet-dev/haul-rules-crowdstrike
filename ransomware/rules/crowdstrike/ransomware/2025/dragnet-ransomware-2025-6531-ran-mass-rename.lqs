// Dragnet [Ransomware]: dragnet-ransomware-2025-6531 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 01d5563b-c092-5f67-9c4a-99416668aff8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
