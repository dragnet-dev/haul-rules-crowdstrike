// Dragnet [Ransomware]: dragnet-ransomware-2024-4411 — Mass File Rename (raworld)
// Status: experimental | Level: high | ID: 818170df-a1ad-5ae3-ad12-650e4308fb58

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
