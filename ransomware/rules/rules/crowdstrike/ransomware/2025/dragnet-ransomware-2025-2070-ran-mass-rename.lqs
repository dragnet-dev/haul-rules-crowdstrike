// Dragnet [Ransomware]: dragnet-ransomware-2025-2070 — Mass File Rename (worldleaks)
// Status: experimental | Level: high | ID: 25bff543-e7cb-5ec0-a943-04fcee9e6d0f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
