// Dragnet [Ransomware]: dragnet-ransomware-2021-0630 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 5953fcd9-e978-5895-a9f1-89caad10efd8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
