// Dragnet [Ransomware]: dragnet-ransomware-2022-0205 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 67ac972a-f263-5930-b87f-8437881cd012

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
