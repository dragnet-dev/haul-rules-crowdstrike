// Dragnet [Ransomware]: dragnet-ransomware-2022-0287 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 58337814-0c69-5e3a-a59c-60c9ea0ea936

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
