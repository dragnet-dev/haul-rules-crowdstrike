// Dragnet [Ransomware]: dragnet-ransomware-2025-1403 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 7910c7f7-15ed-53fa-93b5-96e7e6a6a132

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
