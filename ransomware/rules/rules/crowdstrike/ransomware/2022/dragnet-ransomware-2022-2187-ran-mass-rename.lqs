// Dragnet [Ransomware]: dragnet-ransomware-2022-2187 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 8c70ca70-46a6-5d9b-80bb-160bfd55c128

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
