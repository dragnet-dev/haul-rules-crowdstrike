// Dragnet [Ransomware]: dragnet-ransomware-2022-1472 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 03989dbc-ffa7-51d5-9eda-7e998ef061dd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
