// Dragnet [Ransomware]: dragnet-ransomware-2025-1888 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: c5dfe647-46f5-5a28-806b-6e30aa036a1f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
