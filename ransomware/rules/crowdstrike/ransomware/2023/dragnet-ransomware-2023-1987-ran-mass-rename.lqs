// Dragnet [Ransomware]: dragnet-ransomware-2023-1987 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 24f8b38a-db24-5c73-b2f5-2421a7c576b5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
