// Dragnet [Ransomware]: dragnet-ransomware-2022-2902 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 5c5076f5-307a-5039-a3cb-35e70100633f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
