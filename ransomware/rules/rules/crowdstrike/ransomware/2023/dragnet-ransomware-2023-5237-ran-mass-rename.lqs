// Dragnet [Ransomware]: dragnet-ransomware-2023-5237 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 4d26628a-202b-558a-a784-6d94dd106810

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
