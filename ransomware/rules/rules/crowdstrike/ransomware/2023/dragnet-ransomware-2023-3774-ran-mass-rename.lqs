// Dragnet [Ransomware]: dragnet-ransomware-2023-3774 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: aaee2e85-0bd5-585b-a6fa-a7fbf679a144

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
