// Dragnet [Ransomware]: dragnet-ransomware-2025-0465 — Mass File Rename (play)
// Status: experimental | Level: high | ID: eb8b0633-b068-5753-b0e4-a7e2fa6689b9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
