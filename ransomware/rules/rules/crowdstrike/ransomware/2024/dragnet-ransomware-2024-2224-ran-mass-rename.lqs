// Dragnet [Ransomware]: dragnet-ransomware-2024-2224 — Mass File Rename (hellcat)
// Status: deprecated | Level: high | ID: ff07e88a-f456-55da-838d-f72419c1053d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
