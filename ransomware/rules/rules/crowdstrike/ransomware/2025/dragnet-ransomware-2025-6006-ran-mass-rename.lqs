// Dragnet [Ransomware]: dragnet-ransomware-2025-6006 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 3daa29af-52da-5849-bb5e-828651f923a9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
