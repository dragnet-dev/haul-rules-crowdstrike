// Dragnet [Container]: dragnet-container-2024-0721 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: e629fd9f-d253-527e-be24-fcb423eda44e

#event_simpleName=*
| (ImageFileName = *azure linux:3.0* OR ImageFileName = *chainguard:* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *ubuntu:20.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
