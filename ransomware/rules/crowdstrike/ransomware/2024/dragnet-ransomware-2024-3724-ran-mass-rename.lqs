// Dragnet [Ransomware]: dragnet-ransomware-2024-3724 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 030c08de-12e2-5ec0-93c0-0748fbde9ca7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
