// Dragnet [Ransomware]: dragnet-ransomware-2025-5673 — Mass File Rename (warlock)
// Status: deprecated | Level: high | ID: 00b21193-9bd7-5d2c-b0c0-9fdf3015e774

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
