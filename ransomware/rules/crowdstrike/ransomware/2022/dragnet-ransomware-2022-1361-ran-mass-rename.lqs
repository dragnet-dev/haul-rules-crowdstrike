// Dragnet [Ransomware]: dragnet-ransomware-2022-1361 — Mass File Rename (alphv)
// Status: deprecated | Level: high | ID: e9b054f4-0631-50fa-a5d2-6caa2e4c6950

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
