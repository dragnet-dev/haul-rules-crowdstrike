// Dragnet [Ransomware]: dragnet-ransomware-2026-3306 — Mass File Rename (worldleaks)
// Status: test | Level: high | ID: 843d7063-e16a-5d8e-a4fa-11b01a8df97a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
