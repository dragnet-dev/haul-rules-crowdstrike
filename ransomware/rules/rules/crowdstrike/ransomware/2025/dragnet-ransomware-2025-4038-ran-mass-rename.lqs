// Dragnet [Ransomware]: dragnet-ransomware-2025-4038 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 42be7418-1879-5ae7-b522-12f5b8a43830

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
