// Dragnet [Ransomware]: dragnet-ransomware-2025-1016 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 4d680f1e-9191-5c34-8a47-4360aaecac03

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
