// Dragnet [Ransomware]: dragnet-ransomware-2022-2311 — Mass File Rename (lv)
// Status: deprecated | Level: high | ID: 7c8ec68c-6717-5370-b2d3-25b8d1932f9f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
