// Dragnet [Ransomware]: dragnet-ransomware-2023-0327 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 4ce5a4a9-1a38-59eb-b723-8d14ffcabe30

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
