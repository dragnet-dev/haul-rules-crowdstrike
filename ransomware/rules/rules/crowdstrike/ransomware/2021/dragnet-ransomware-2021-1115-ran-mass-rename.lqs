// Dragnet [Ransomware]: dragnet-ransomware-2021-1115 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 288f1f3c-1a5b-55e3-9e47-e9f466b478e2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
