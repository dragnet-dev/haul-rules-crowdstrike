// Dragnet [Ransomware]: dragnet-ransomware-2023-0511 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 3e59facd-8818-5aa5-815e-eeafc93fc795

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
