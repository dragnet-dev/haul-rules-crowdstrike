// Dragnet [Ransomware]: dragnet-ransomware-2025-0131 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 5f3ea2b4-fe04-57de-a330-6590a35d9229

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
