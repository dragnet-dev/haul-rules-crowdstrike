// Dragnet [Container]: dragnet-container-2025-0321 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 4a7a83c0-2daf-576e-9747-cc67bc2d304a

#event_simpleName=*
| (ImageFileName = *almalinux:8* OR ImageFileName = *amazonlinux:1* OR ImageFileName = *amazonlinux:2* OR ImageFileName = *cbl-mariner:1.0* OR ImageFileName = *cbl-mariner:2.0* OR ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:7* OR ImageFileName = *oraclelinux:8* OR ImageFileName = *photon os:1.0* OR ImageFileName = *photon os:2.0* OR ImageFileName = *photon os:3.0* OR ImageFileName = *photon os:4.0* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:16.04-ESM* OR ImageFileName = *ubuntu:18.04* OR ImageFileName = *ubuntu:18.04-ESM* OR ImageFileName = *ubuntu:20.04* OR ImageFileName = *ubuntu:20.04-ESM* OR ImageFileName = *ubuntu:21.10*)
| table([timestamp, ComputerName])
| limit(1000)
