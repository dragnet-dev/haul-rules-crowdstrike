// Dragnet [Ransomware]: dragnet-ransomware-2024-5208 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 8a57158d-78e4-5dda-bbeb-6d94eeb270d1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
