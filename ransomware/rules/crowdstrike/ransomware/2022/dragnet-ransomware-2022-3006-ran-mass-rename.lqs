// Dragnet [Ransomware]: dragnet-ransomware-2022-3006 — Mass File Rename (suncrypt)
// Status: deprecated | Level: high | ID: 94a3443b-1439-5380-9c30-ea76d375fdf9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
