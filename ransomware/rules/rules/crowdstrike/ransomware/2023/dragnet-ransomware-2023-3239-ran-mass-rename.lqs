// Dragnet [Ransomware]: dragnet-ransomware-2023-3239 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 5f1b307d-4056-524b-8945-e587d7aaa3df

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
