// Dragnet [Ransomware]: dragnet-ransomware-2022-2823 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: e1660bd0-edcf-5cc1-b708-82c4a1adb688

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
