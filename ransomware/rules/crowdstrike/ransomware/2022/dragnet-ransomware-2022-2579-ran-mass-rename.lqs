// Dragnet [Ransomware]: dragnet-ransomware-2022-2579 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 9d1f8d80-4ddc-5389-8c1c-c709408af272

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
