// Dragnet [Ransomware]: dragnet-ransomware-2021-1269 — Mass File Rename (blackmatter)
// Status: deprecated | Level: high | ID: 085eb370-b567-5c95-803f-c20773bed217

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
