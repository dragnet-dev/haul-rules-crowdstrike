// Dragnet [Ransomware]: dragnet-ransomware-2022-0769 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 70a73ba8-76ba-5de3-ae05-b1f5b0576745

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
