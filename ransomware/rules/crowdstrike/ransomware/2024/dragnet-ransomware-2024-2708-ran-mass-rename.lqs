// Dragnet [Ransomware]: dragnet-ransomware-2024-2708 — Mass File Rename (genesis)
// Status: experimental | Level: high | ID: 6eb5ebfe-f968-5823-a02e-8de9561dfea8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
