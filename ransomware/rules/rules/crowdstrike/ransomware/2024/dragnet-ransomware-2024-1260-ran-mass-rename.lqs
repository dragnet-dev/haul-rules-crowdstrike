// Dragnet [Ransomware]: dragnet-ransomware-2024-1260 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 3cfe0b34-7e1e-5b7f-9d64-0b28c6378e64

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
