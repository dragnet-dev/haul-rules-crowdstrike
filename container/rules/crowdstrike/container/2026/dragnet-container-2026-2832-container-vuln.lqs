// Dragnet [Container]: dragnet-container-2026-2832 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 8904469b-a044-5c17-b616-c2965e5f5886

#event_simpleName=*
| (ImageFileName = *chainguard:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
