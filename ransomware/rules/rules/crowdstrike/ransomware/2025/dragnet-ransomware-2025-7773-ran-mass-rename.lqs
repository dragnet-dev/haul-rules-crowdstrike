// Dragnet [Ransomware]: dragnet-ransomware-2025-7773 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 6795551d-f3d9-5bac-ad88-21707034e9bd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
