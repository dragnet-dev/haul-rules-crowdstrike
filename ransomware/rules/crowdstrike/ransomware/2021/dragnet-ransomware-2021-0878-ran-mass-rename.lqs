// Dragnet [Ransomware]: dragnet-ransomware-2021-0878 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 7cf7e17a-c6a8-510f-a15a-6755453c43e5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
