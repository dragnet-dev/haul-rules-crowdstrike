// Dragnet [Ransomware]: dragnet-ransomware-2024-3383 — Mass File Rename (blacklock)
// Status: experimental | Level: high | ID: f27b7c22-c381-5319-8835-e2b7b76a1967

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
