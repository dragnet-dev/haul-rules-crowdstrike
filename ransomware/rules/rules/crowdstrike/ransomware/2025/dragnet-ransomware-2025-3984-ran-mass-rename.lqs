// Dragnet [Ransomware]: dragnet-ransomware-2025-3984 — Mass File Rename (handala)
// Status: experimental | Level: high | ID: a7099862-904e-5d2d-8ce8-5b773797fd2c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
