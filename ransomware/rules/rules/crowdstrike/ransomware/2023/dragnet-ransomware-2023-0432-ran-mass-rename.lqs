// Dragnet [Ransomware]: dragnet-ransomware-2023-0432 — Mass File Rename (karakurt)
// Status: experimental | Level: high | ID: face1279-1e51-54d4-8a9b-751d495125dc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
