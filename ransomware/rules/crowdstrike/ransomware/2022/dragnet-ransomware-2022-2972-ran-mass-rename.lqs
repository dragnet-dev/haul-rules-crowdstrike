// Dragnet [Ransomware]: dragnet-ransomware-2022-2972 — Mass File Rename (onyx)
// Status: deprecated | Level: high | ID: 65ef168d-c172-5662-9061-356f7394375e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
