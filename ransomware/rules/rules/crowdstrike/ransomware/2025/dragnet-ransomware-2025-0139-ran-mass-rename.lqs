// Dragnet [Ransomware]: dragnet-ransomware-2025-0139 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 9f759be0-b249-5af7-9a9b-a7c861740900

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
