// Dragnet [Ransomware]: dragnet-ransomware-2024-3341 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: f5960c6d-91f6-5358-8557-3812867de726

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
