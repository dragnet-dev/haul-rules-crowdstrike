// Dragnet [Ransomware]: dragnet-ransomware-2024-0940 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: a81ac94b-c428-51c0-9b89-51d65669a06f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
