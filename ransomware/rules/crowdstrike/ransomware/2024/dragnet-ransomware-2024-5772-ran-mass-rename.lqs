// Dragnet [Ransomware]: dragnet-ransomware-2024-5772 — Mass File Rename (underground)
// Status: experimental | Level: high | ID: 10670ea9-ec11-5280-8643-7ac50272f5b2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
