// Dragnet [Ransomware]: dragnet-ransomware-2023-5344 — Mass File Rename (snatch)
// Status: experimental | Level: high | ID: c2eb2e81-c167-5275-9ad9-95cc44d5b734

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
