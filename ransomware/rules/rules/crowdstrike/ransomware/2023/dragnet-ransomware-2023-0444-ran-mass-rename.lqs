// Dragnet [Ransomware]: dragnet-ransomware-2023-0444 — Mass File Rename (ElDorado)
// Status: experimental | Level: high | ID: 2df7e4f7-b38f-5a77-a321-0e9c7fbaed2b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
