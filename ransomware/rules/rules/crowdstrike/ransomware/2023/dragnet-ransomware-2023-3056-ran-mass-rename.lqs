// Dragnet [Ransomware]: dragnet-ransomware-2023-3056 — Mass File Rename (karakurt)
// Status: deprecated | Level: high | ID: 22d9cacc-e817-5858-b8d9-c5fa8359caa9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
