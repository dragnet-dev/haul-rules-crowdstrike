// Dragnet [Ransomware]: dragnet-ransomware-2024-5428 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: eb10cd6a-68bd-5016-93de-0d89d8470dc2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
