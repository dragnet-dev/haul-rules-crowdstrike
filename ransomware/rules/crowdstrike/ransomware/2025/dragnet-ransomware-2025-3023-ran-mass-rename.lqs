// Dragnet [Ransomware]: dragnet-ransomware-2025-3023 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 15718526-6635-58b2-bf00-e281b6f9242f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
