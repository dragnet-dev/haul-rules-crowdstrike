// Dragnet [Ransomware]: dragnet-ransomware-2023-2217 — Mass File Rename (play)
// Status: experimental | Level: high | ID: f8045abb-b11c-55cb-8bac-7cd17d56e713

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
