// Dragnet [Ransomware]: dragnet-ransomware-2025-6749 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: 96865146-f09f-5f89-979e-01e721b033c4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
