// Dragnet [Ransomware]: dragnet-ransomware-2024-0650 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 22967513-8b39-5e8f-8a0a-42e8b1290455

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
