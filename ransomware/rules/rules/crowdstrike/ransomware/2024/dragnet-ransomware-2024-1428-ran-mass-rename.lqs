// Dragnet [Ransomware]: dragnet-ransomware-2024-1428 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 520494fe-33e4-5e9a-bf4f-e708beea4464

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
