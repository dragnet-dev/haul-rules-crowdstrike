// Dragnet [Ransomware]: dragnet-ransomware-2021-0019 — Mass File Rename (avaddon)
// Status: deprecated | Level: high | ID: 4ea678a4-93e3-5a0a-a6f8-176c089c3c8d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
