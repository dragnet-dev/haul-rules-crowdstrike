// Dragnet [Ransomware]: dragnet-ransomware-2025-1405 — Mass File Rename (SilentRansomGroup)
// Status: deprecated | Level: high | ID: 5eb5b4bb-f2b3-5af9-afac-68ee49fb5d1a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
