// Dragnet [Ransomware]: dragnet-ransomware-2024-0358 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 02b20e8a-4797-594d-8ba7-e8cd2d0c6354

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
