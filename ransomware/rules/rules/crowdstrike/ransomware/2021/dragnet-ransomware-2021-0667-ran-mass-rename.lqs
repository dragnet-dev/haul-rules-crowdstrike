// Dragnet [Ransomware]: dragnet-ransomware-2021-0667 — Mass File Rename (xinglocker)
// Status: deprecated | Level: high | ID: 20db1384-ed10-59e0-82bd-85ad2a5b5910

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
