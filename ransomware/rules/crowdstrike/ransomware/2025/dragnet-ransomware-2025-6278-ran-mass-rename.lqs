// Dragnet [Ransomware]: dragnet-ransomware-2025-6278 — Mass File Rename (beast)
// Status: experimental | Level: high | ID: 60419769-fcc4-59ee-aab4-617542a4d541

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
