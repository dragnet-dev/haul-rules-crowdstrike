// Dragnet [Ransomware]: dragnet-ransomware-2024-0710 — Mass File Rename (safepay)
// Status: deprecated | Level: high | ID: de72dd0d-2145-5221-9d10-001819885fd1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
