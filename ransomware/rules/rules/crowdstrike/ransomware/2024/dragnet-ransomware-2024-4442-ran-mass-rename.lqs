// Dragnet [Ransomware]: dragnet-ransomware-2024-4442 — Mass File Rename (ElDorado)
// Status: deprecated | Level: high | ID: 166d70aa-c8e9-5e73-aaec-00b355a24835

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
