// Dragnet [Ransomware]: dragnet-ransomware-2022-1136 — Mass File Rename (avoslocker)
// Status: deprecated | Level: high | ID: f6ebad48-2df4-558f-a0ef-87bb9808622c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
