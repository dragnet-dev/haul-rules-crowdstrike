// Dragnet [Ransomware]: dragnet-ransomware-2023-2670 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 98cb6011-51d0-527d-87db-c741c37cabb6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
