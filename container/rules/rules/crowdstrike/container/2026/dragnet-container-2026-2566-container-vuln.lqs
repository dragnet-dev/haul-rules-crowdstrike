// Dragnet [Container]: dragnet-container-2026-2566 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 023a4c67-39df-5dfd-8405-db347e819051

#event_simpleName=*
| (ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *photon os:4.0*)
| table([timestamp, ComputerName])
| limit(1000)
