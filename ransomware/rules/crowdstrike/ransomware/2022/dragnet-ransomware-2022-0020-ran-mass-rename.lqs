// Dragnet [Ransomware]: dragnet-ransomware-2022-0020 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 1961f982-77f6-565b-8a3a-13431df30a48

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
