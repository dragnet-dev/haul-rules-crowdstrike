// Dragnet [Ransomware]: dragnet-ransomware-2023-2931 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 36c7faf1-5e13-50f9-86e9-011733098dd3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
