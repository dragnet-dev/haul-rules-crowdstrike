// Dragnet [Ransomware]: dragnet-ransomware-2023-4772 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 78fbf8b6-1ab5-5598-83af-7e2f59f4d376

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
