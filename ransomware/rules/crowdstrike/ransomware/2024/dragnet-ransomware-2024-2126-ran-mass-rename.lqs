// Dragnet [Ransomware]: dragnet-ransomware-2024-2126 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: d59a397f-d5db-502e-a7ed-4b8974da0cb1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
