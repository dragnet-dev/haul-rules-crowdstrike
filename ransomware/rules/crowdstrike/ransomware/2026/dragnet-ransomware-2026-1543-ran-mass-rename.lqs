// Dragnet [Ransomware]: dragnet-ransomware-2026-1543 — Mass File Rename (dragonforce)
// Status: test | Level: high | ID: d8ad420e-9fbb-5fb5-9bb7-0836ae3d1c78

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
