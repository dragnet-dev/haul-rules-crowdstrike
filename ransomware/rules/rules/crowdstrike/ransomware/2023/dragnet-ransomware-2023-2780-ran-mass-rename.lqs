// Dragnet [Ransomware]: dragnet-ransomware-2023-2780 — Mass File Rename (malas)
// Status: experimental | Level: high | ID: c8fbd567-b322-5c59-8be6-1137e4f07c87

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
