// Dragnet [Ransomware]: dragnet-ransomware-2026-2081 — Mass File Rename (medusalocker)
// Status: stable | Level: high | ID: 1cb228d2-5e93-589c-ae41-9688da15279d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
