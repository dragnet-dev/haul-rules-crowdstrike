// Dragnet [Ransomware]: dragnet-ransomware-2024-3915 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 1aa5cdee-1d15-5cdd-a45f-8151e1688c7f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
