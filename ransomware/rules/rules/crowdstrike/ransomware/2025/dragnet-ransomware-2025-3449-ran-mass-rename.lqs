// Dragnet [Ransomware]: dragnet-ransomware-2025-3449 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 1c37e067-5bc7-5941-bdc7-55f1413be1a1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
