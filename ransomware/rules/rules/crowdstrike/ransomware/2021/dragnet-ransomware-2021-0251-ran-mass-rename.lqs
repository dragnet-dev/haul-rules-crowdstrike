// Dragnet [Ransomware]: dragnet-ransomware-2021-0251 — Mass File Rename (avaddon)
// Status: deprecated | Level: high | ID: 0817551d-5277-5a15-b281-0be0c4739c69

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
