// Dragnet [Ransomware]: dragnet-ransomware-2024-2479 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 191dd097-8f80-5c6b-815f-a41134e22b88

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
