// Dragnet [Ransomware]: dragnet-ransomware-2022-0889 — Mass File Rename (everest)
// Status: deprecated | Level: high | ID: d086c72e-2b12-51c6-a5bd-88042acd1903

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
