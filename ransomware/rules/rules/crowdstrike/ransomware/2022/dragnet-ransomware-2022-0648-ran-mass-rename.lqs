// Dragnet [Ransomware]: dragnet-ransomware-2022-0648 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 96ff28a1-f4c7-5fc0-8e0b-6f40af440435

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
