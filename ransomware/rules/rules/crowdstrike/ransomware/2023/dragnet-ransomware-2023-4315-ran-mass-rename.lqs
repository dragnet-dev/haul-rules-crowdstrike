// Dragnet [Ransomware]: dragnet-ransomware-2023-4315 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 6fbfd3ee-9fcf-5f5d-905a-ea1ffca391c6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
