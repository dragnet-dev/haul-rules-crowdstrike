// Dragnet [Ransomware]: dragnet-ransomware-2025-3752 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: d6f58173-8967-5f0f-8b5b-1cac284dc34f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
