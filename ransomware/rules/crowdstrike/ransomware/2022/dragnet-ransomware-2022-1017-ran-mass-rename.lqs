// Dragnet [Ransomware]: dragnet-ransomware-2022-1017 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 6827350a-c928-50e8-86f3-77c789c3fb7f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
