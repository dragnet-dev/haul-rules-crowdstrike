// Dragnet [Ransomware]: dragnet-ransomware-2025-5869 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 7e40c069-9003-5e47-a8cf-b0b900582e22

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
