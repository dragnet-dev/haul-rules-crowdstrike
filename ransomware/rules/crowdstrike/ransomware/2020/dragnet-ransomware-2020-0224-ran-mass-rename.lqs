// Dragnet [Ransomware]: dragnet-ransomware-2020-0224 — Mass File Rename (netflim)
// Status: deprecated | Level: high | ID: 7c4e601e-29e0-5ac7-83e7-b46f3d36ad51

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
