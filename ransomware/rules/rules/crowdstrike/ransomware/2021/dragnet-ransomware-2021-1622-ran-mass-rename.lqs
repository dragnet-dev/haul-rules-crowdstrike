// Dragnet [Ransomware]: dragnet-ransomware-2021-1622 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: 37830021-69b0-5566-b998-e62883c06f84

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
