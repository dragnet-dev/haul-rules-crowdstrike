// Dragnet [Ransomware]: dragnet-ransomware-2025-6019 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: fe1f349a-99c1-5953-9f39-375b4a36675c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
