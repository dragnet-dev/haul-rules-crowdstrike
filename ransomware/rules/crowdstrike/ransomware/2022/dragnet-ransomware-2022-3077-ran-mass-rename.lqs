// Dragnet [Ransomware]: dragnet-ransomware-2022-3077 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 84fe00c6-43db-5fef-ba08-0fd28b2b0fc6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
