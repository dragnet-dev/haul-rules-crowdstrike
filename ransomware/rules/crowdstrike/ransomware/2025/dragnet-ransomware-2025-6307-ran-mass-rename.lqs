// Dragnet [Ransomware]: dragnet-ransomware-2025-6307 — Mass File Rename (ransomhouse)
// Status: experimental | Level: high | ID: a2bfaf20-749c-5048-817b-d60068ad8d5d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
