// Dragnet [Ransomware]: dragnet-ransomware-2023-1998 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: dba4c60e-8286-58ed-9351-93925ebfd0e1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
