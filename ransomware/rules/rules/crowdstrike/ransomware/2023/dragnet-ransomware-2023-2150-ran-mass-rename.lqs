// Dragnet [Ransomware]: dragnet-ransomware-2023-2150 — Mass File Rename (knight)
// Status: experimental | Level: high | ID: ff5e184c-47b2-5955-a2a6-517a58d2498a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
