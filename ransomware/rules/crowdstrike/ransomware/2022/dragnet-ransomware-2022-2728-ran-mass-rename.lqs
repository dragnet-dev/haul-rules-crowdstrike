// Dragnet [Ransomware]: dragnet-ransomware-2022-2728 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 77b47a73-2b08-517d-a053-5f91076b023f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
