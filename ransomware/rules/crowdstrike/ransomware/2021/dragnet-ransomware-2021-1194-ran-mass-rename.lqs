// Dragnet [Ransomware]: dragnet-ransomware-2021-1194 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 3baf0355-bd19-5a68-8b84-848f850be2d0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
