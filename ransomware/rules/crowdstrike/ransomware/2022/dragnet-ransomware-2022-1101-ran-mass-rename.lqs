// Dragnet [Ransomware]: dragnet-ransomware-2022-1101 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: b2a5bd55-9b5c-558d-977a-dfbd7e1335e1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
