// Dragnet [Ransomware]: dragnet-ransomware-2025-4050 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 8c7e3b5b-6ac2-5bd8-a69a-4c7cab9c745b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
