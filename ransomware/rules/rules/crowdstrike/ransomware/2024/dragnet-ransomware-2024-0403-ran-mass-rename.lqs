// Dragnet [Ransomware]: dragnet-ransomware-2024-0403 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 3d1f5c48-0e04-5419-a382-fc6331591181

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
