// Dragnet [Ransomware]: dragnet-ransomware-2022-0599 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: b19f7bb2-bed7-5085-9f20-f7d4361bce19

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
