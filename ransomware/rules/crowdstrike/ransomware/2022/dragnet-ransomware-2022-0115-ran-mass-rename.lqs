// Dragnet [Ransomware]: dragnet-ransomware-2022-0115 — Mass File Rename (bianlian)
// Status: deprecated | Level: high | ID: 7b7181a7-dd1a-57f6-a12c-c1d2424e7a8f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
