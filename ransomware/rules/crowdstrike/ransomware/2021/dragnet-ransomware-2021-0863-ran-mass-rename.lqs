// Dragnet [Ransomware]: dragnet-ransomware-2021-0863 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 7ec02674-444e-5db0-add6-82d8aad4f61b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
