// Dragnet [Ransomware]: dragnet-ransomware-2025-0862 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: ce6e6c0c-7b25-5dae-8b38-607fc6e31681

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
