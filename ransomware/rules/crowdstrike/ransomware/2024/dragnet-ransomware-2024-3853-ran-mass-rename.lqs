// Dragnet [Ransomware]: dragnet-ransomware-2024-3853 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: b589646f-46b2-51b4-8dce-6831777c61d4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
