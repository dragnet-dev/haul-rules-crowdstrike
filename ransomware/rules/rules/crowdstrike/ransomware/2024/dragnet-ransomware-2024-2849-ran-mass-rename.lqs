// Dragnet [Ransomware]: dragnet-ransomware-2024-2849 — Mass File Rename (zerotolerance)
// Status: experimental | Level: high | ID: 52892199-4efc-5c9c-ad77-5b5db1a15742

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
