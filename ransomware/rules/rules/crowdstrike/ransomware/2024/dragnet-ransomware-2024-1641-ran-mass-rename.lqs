// Dragnet [Ransomware]: dragnet-ransomware-2024-1641 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 03b92bdd-687b-533b-8774-46f1516a5f15

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
