// Dragnet [Ransomware]: dragnet-ransomware-2023-2010 — Mass File Rename (knight)
// Status: experimental | Level: high | ID: f285de95-cff0-544c-8c98-0e715bb01ec4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
