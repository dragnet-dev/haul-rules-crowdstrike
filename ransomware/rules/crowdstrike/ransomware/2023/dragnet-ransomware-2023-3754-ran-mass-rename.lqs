// Dragnet [Ransomware]: dragnet-ransomware-2023-3754 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: c87bdd9c-4cce-5b9f-915f-712c9503d1e7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
