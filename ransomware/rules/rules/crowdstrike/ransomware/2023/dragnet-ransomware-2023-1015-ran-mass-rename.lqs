// Dragnet [Ransomware]: dragnet-ransomware-2023-1015 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 9d455319-fe8e-5d0b-b0df-92d3083153e5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
