// Dragnet [Ransomware]: dragnet-ransomware-2023-0075 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: b2014e88-94f4-5c7d-ace8-5f8f9bb8ae61

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
