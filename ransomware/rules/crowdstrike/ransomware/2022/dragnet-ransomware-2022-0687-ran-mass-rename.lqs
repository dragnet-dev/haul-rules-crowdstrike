// Dragnet [Ransomware]: dragnet-ransomware-2022-0687 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 2cda127c-8a48-5118-8054-e1fc7e517dc4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
