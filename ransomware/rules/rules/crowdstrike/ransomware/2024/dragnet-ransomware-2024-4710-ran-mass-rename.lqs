// Dragnet [Ransomware]: dragnet-ransomware-2024-4710 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 04e91f4f-fa2d-5425-95e9-dc31937a0f2e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
