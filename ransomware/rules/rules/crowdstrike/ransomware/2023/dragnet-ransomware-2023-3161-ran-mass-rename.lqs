// Dragnet [Ransomware]: dragnet-ransomware-2023-3161 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: f479e4c3-31a6-54c8-8ee1-7f5ce5d7f4fc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
