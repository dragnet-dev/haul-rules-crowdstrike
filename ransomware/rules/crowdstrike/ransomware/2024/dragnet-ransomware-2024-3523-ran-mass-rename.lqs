// Dragnet [Ransomware]: dragnet-ransomware-2024-3523 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: dd40fdde-4734-535b-99ed-2acec084ade9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
