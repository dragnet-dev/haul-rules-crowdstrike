// Dragnet [Ransomware]: dragnet-ransomware-2021-1062 — Mass File Rename (blackmatter)
// Status: deprecated | Level: high | ID: 3431b489-a8ee-5f3a-8b83-8cf88cd2f6e2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
