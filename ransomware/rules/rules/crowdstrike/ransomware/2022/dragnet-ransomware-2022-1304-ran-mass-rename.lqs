// Dragnet [Ransomware]: dragnet-ransomware-2022-1304 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 0c97bc0a-8ef3-5fc0-b600-4b10f0d06d46

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
