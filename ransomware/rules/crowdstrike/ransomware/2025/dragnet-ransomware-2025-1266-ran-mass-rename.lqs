// Dragnet [Ransomware]: dragnet-ransomware-2025-1266 — Mass File Rename (arcusmedia)
// Status: experimental | Level: high | ID: 2f40443c-5b9e-5e99-a1a7-1211fc59da6c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
