// Dragnet [Container]: dragnet-container-2026-1748 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 369a7648-832b-553d-9177-c1b802dfa5bb

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
