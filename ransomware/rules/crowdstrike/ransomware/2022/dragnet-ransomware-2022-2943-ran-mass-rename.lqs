// Dragnet [Ransomware]: dragnet-ransomware-2022-2943 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 03148fdc-ab58-533b-adcf-5ce0e2181591

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
