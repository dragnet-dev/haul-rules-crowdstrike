// Dragnet [Ransomware]: dragnet-ransomware-2024-5632 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 84270135-f882-5692-98e6-5bdf2a01cfd7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
