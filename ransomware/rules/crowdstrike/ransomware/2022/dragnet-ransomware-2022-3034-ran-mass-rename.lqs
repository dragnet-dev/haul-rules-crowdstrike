// Dragnet [Ransomware]: dragnet-ransomware-2022-3034 — Mass File Rename (blackbasta)
// Status: deprecated | Level: high | ID: 0bff5877-d096-5783-a282-552d3bc3aecb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
