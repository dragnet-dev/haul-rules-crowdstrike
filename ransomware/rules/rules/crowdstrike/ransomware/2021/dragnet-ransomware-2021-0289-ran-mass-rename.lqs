// Dragnet [Ransomware]: dragnet-ransomware-2021-0289 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: b16d692b-a438-5aa3-9f89-6453223e56b1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
