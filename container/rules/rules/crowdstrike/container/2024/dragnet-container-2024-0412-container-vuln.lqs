// Dragnet [Container]: dragnet-container-2024-0412 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: c5ea1176-1d20-50c0-b061-a6b21a31ecd7

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:8* OR ImageFileName = *debian:9*)
| table([timestamp, ComputerName])
| limit(1000)
