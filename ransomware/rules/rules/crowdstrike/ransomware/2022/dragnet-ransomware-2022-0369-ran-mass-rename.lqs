// Dragnet [Ransomware]: dragnet-ransomware-2022-0369 — Mass File Rename (avoslocker)
// Status: deprecated | Level: high | ID: 1240c375-bb4c-5543-a33a-1a1633c8a44f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
