// Dragnet [Ransomware]: dragnet-ransomware-2025-6607 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 814a0091-3320-51b4-aa66-f6719d0d483a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
