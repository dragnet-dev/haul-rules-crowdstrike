// Dragnet [Ransomware]: dragnet-ransomware-2024-3237 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 8d3f8ebf-30de-5a76-99be-aab507290ce0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
