// Dragnet [Ransomware]: dragnet-ransomware-2025-0216 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 099bc877-69ee-5a65-8beb-0c4392ab013e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
