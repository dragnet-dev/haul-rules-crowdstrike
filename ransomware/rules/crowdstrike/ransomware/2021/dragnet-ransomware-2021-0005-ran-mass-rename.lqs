// Dragnet [Ransomware]: dragnet-ransomware-2021-0005 — Mass File Rename (blackmatter)
// Status: deprecated | Level: high | ID: a9c22c1d-4757-5c2b-a553-bb405f179235

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
