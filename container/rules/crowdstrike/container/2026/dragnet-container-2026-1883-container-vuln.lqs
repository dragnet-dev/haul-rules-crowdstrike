// Dragnet [Container]: dragnet-container-2026-1883 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: a2676451-5657-54f9-8c06-08f7a79d9482

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:7* OR ImageFileName = *debian:8* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:14.04* OR ImageFileName = *ubuntu:14.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
