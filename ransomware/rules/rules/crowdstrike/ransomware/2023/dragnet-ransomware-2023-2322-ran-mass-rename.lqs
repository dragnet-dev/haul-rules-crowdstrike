// Dragnet [Ransomware]: dragnet-ransomware-2023-2322 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 47c35b1c-2816-5362-8308-d3fb5f8638a2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
