// Dragnet [Ransomware]: dragnet-ransomware-2025-3673 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 93d7d4dd-bbc4-5810-a467-f3d53e0f25b1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
