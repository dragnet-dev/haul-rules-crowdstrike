// Dragnet [Ransomware]: dragnet-ransomware-2024-1818 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: b4a4a58c-c966-576b-acd7-e2133df035c3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
