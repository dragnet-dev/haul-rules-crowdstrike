// Dragnet [Ransomware]: dragnet-ransomware-2025-7549 — Mass File Rename (play)
// Status: experimental | Level: high | ID: f9530c4b-7d68-55e6-9fb1-b322b2e8c579

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
