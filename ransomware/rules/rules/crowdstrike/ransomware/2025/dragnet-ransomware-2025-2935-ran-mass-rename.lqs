// Dragnet [Ransomware]: dragnet-ransomware-2025-2935 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: d9f661d0-622b-5c13-8d72-2e8a25a13a36

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
