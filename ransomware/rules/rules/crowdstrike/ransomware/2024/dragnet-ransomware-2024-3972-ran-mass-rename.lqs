// Dragnet [Ransomware]: dragnet-ransomware-2024-3972 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: d0a8f4ea-0ef7-54aa-af35-62d4c80cc953

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
