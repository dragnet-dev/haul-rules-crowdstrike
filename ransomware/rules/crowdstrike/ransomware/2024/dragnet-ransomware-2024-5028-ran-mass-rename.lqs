// Dragnet [Ransomware]: dragnet-ransomware-2024-5028 — Mass File Rename (threeam)
// Status: experimental | Level: high | ID: 3b30b4c4-2575-5f6e-afa8-ef26b9da1552

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
