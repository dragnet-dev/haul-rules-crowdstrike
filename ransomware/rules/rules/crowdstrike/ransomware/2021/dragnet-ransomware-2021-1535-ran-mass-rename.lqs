// Dragnet [Ransomware]: dragnet-ransomware-2021-1535 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: fdd8c459-5215-5461-a4b4-b60e592f8503

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
