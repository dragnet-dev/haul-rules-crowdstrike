// Dragnet [Ransomware]: dragnet-ransomware-2023-4694 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: d06526c2-e0aa-59ff-9ce1-4918d5884b66

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
