// Dragnet [Container]: dragnet-container-2026-2892 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 26b9f225-171c-5627-80fd-970e6b18b4bf

#event_simpleName=*
| (ImageFileName = *almalinux:10* OR ImageFileName = *almalinux:8* OR ImageFileName = *almalinux:9* OR ImageFileName = *amazonlinux:2* OR ImageFileName = *amazonlinux:2023* OR ImageFileName = *chainguard:* OR ImageFileName = *oraclelinux:8* OR ImageFileName = *oraclelinux:9* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:22.04* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
