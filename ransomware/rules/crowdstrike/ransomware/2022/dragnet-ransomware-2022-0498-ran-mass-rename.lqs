// Dragnet [Ransomware]: dragnet-ransomware-2022-0498 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 05887b7c-870c-5a77-a0e5-8f892a82be76

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
