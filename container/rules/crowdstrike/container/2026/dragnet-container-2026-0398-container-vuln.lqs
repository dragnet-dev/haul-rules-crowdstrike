// Dragnet [Container]: dragnet-container-2026-0398 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 654882b0-8497-5f6e-ae88-f3efd9eb1a89

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
