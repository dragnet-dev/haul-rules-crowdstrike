// Dragnet [Ransomware]: dragnet-ransomware-2024-1418 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 3887b0fe-2dfd-57e8-813e-801f82f3eb0f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
