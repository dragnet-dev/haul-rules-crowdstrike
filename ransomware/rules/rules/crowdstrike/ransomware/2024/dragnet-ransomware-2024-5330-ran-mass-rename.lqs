// Dragnet [Ransomware]: dragnet-ransomware-2024-5330 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 4dbc7f74-2418-584b-9253-d6fd0ce4e13d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
