// Dragnet [Ransomware]: dragnet-ransomware-2025-1460 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: 748272d8-b590-54c2-8cbc-37bcd449dc85

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
