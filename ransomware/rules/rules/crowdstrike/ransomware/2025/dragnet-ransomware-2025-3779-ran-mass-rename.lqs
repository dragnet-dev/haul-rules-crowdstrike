// Dragnet [Ransomware]: dragnet-ransomware-2025-3779 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 1697ee12-69fb-5828-abed-8e116e15e676

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
