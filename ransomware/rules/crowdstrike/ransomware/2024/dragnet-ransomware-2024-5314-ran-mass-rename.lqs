// Dragnet [Ransomware]: dragnet-ransomware-2024-5314 — Mass File Rename (stormous)
// Status: deprecated | Level: high | ID: 2f354d74-61ba-5e2c-8c3f-269d15b89885

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
