// Dragnet [Ransomware]: dragnet-ransomware-2021-1749 — Mass File Rename (ragnarlocker)
// Status: deprecated | Level: high | ID: 6d586318-7370-561c-8e3d-9e46304b490c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
