// Dragnet [Ransomware]: dragnet-ransomware-2025-3295 — Mass File Rename (killsec)
// Status: deprecated | Level: high | ID: 7be960c8-94cc-53b9-9618-cf6a0b6a43d2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
