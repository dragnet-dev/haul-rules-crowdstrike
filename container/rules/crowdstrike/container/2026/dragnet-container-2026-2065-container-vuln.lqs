// Dragnet [Container]: dragnet-container-2026-2065 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 7271ccfc-fe7f-5331-97ac-dd12824be2a6

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
