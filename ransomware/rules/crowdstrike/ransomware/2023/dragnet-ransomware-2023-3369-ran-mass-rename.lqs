// Dragnet [Ransomware]: dragnet-ransomware-2023-3369 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 073af0ed-ea5a-5cb1-a8e4-4ca1fefb3214

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
