// Dragnet [Ransomware]: dragnet-ransomware-2023-2355 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 50ccb58b-0771-5057-90a8-f9c5916b83b7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
