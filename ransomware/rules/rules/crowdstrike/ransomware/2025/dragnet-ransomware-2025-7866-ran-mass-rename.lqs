// Dragnet [Ransomware]: dragnet-ransomware-2025-7866 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: e6c1a2fb-996c-5c49-86be-3b33fc2b1d5a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
