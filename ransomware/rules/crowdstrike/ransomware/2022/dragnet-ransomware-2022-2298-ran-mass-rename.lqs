// Dragnet [Ransomware]: dragnet-ransomware-2022-2298 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: a53e9a4d-764e-5a77-a61e-eabd6b4c18fc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
