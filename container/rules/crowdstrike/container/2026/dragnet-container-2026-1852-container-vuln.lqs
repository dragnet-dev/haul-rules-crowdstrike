// Dragnet [Container]: dragnet-container-2026-1852 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 13b2e04f-9cb7-55f0-8f9d-152c2efb30fd

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
