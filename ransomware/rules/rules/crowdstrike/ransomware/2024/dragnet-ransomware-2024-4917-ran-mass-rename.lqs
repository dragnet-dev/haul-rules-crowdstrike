// Dragnet [Ransomware]: dragnet-ransomware-2024-4917 — Mass File Rename (stormous)
// Status: deprecated | Level: high | ID: 56e561a9-80af-5ea0-99ca-fe7cb5e847d0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
