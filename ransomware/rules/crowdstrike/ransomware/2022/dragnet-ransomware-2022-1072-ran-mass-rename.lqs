// Dragnet [Ransomware]: dragnet-ransomware-2022-1072 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 14c3c52b-3570-58ea-a552-534331170eb4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
