// Dragnet [Ransomware]: dragnet-ransomware-2025-5781 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: 707a8281-1c23-5843-86ab-7683c821362a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
