// Dragnet [Ransomware]: dragnet-ransomware-2023-1129 — Mass File Rename (royal)
// Status: experimental | Level: high | ID: 2316e14a-c245-5189-a57a-ef9ffa5a2cc2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
