// Dragnet [Ransomware]: dragnet-ransomware-2023-2647 — Mass File Rename (darkpower)
// Status: experimental | Level: high | ID: fcd4e7e0-29e6-554c-a842-3678d08fcb54

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
