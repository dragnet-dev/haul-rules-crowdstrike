// Dragnet [Ransomware]: dragnet-ransomware-2025-3564 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 16fe1bf1-426b-5a22-8e75-7bcdf5d7b1ac

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
