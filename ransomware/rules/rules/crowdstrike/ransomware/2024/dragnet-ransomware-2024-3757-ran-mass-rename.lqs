// Dragnet [Ransomware]: dragnet-ransomware-2024-3757 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: a7d482ae-86ad-56d9-b465-e54408fc8d6e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
