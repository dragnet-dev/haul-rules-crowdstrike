// Dragnet [Container]: dragnet-container-2026-0013 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 110d7349-e9fd-502c-ad52-312d9aec8acf

#event_simpleName=*
| (ImageFileName = *chainguard:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
