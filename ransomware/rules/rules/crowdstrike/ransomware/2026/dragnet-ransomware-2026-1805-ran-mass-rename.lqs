// Dragnet [Ransomware]: dragnet-ransomware-2026-1805 — Mass File Rename (payload)
// Status: stable | Level: high | ID: 64afb1fd-a16c-5b7e-a1b1-7ed7589477f2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
