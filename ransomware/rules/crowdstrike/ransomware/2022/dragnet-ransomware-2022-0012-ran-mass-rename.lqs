// Dragnet [Ransomware]: dragnet-ransomware-2022-0012 — Mass File Rename (play)
// Status: deprecated | Level: high | ID: be7e85c5-5b7e-5858-a391-5fbbfa101ce5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
