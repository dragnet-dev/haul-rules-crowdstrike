// Dragnet [Ransomware]: dragnet-ransomware-2025-3979 — Mass File Rename (VanHelsing)
// Status: experimental | Level: high | ID: c2dfc392-5a61-5115-9079-b7239bd1d380

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
