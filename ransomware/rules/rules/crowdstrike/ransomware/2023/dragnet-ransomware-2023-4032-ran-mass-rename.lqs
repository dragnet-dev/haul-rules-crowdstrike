// Dragnet [Ransomware]: dragnet-ransomware-2023-4032 — Mass File Rename (play)
// Status: experimental | Level: high | ID: b5fd57f9-e1b4-59a3-89f5-92a2768cab31

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
