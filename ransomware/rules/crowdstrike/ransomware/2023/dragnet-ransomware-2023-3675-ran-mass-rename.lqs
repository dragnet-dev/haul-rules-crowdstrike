// Dragnet [Ransomware]: dragnet-ransomware-2023-3675 — Mass File Rename (ransomhouse)
// Status: experimental | Level: high | ID: a5fcd259-bfc1-506e-bf3d-1a9bfa3cb341

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
