// Dragnet [Ransomware]: dragnet-ransomware-2023-3733 — Mass File Rename (play)
// Status: experimental | Level: high | ID: d61c5102-b509-5870-9eb1-c2946c75e133

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
