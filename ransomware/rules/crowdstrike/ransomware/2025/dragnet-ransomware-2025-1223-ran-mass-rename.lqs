// Dragnet [Ransomware]: dragnet-ransomware-2025-1223 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 5aeca2b3-ab09-5636-a510-29819d43220e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
