// Dragnet [Ransomware]: dragnet-ransomware-2023-0686 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: a7a2c146-aaeb-52a0-9bea-13c75af90f9e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
