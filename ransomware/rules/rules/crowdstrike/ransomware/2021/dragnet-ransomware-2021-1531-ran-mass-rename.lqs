// Dragnet [Ransomware]: dragnet-ransomware-2021-1531 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 57c3592b-e477-5940-ba23-67cee121969a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
