// Dragnet [Ransomware]: dragnet-ransomware-2025-1057 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: b101a41e-ed7c-534f-a92b-e27aa4d65032

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
