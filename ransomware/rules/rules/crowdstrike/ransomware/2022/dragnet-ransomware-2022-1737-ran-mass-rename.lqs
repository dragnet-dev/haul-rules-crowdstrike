// Dragnet [Ransomware]: dragnet-ransomware-2022-1737 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: ca96b16c-8162-5e83-b7a9-c18c4f0a4ea5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
