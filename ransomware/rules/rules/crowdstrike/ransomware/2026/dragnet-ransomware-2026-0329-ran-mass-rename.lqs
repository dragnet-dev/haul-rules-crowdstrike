// Dragnet [Ransomware]: dragnet-ransomware-2026-0329 — Mass File Rename (killsec)
// Status: deprecated | Level: high | ID: e72f477e-9fea-5da5-ad5c-93a74f708b7a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
