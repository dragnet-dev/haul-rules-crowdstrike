// Dragnet [Ransomware]: dragnet-ransomware-2023-2625 — Mass File Rename (stormous)
// Status: experimental | Level: high | ID: 72a6b7b3-a8d7-595e-b01e-1f395c52f0d6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
