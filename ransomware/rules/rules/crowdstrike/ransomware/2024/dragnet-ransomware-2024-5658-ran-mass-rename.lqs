// Dragnet [Ransomware]: dragnet-ransomware-2024-5658 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 4b6febba-6603-53f1-b178-0bf23113ad8d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
