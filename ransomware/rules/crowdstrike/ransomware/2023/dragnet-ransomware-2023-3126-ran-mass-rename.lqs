// Dragnet [Ransomware]: dragnet-ransomware-2023-3126 — Mass File Rename (werewolves)
// Status: deprecated | Level: high | ID: ecfbe11c-a6ce-57dc-868f-886510ddba73

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
