// Dragnet [Ransomware]: dragnet-ransomware-2024-4102 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: 613a7ad0-15aa-5dbf-ac57-02d1544f04db

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
