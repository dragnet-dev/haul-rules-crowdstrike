// Dragnet [Ransomware]: dragnet-ransomware-2024-0789 — Mass File Rename (safepay)
// Status: deprecated | Level: high | ID: 93ae04bb-d7a0-58b8-ab6d-1dd53c1ea357

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
