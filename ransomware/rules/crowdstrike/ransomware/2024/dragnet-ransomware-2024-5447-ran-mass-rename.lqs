// Dragnet [Ransomware]: dragnet-ransomware-2024-5447 — Mass File Rename (arcusmedia)
// Status: experimental | Level: high | ID: ce03ee69-9493-5834-82a0-b52225b253d4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
