// Dragnet [Ransomware]: dragnet-ransomware-2023-2948 — Mass File Rename (knight)
// Status: experimental | Level: high | ID: 6e9c8aa9-fc67-5475-b97b-20d9d3adbc33

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
