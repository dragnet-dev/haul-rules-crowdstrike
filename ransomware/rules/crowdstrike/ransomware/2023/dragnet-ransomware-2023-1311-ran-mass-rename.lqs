// Dragnet [Ransomware]: dragnet-ransomware-2023-1311 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: ff2c8434-df1e-575b-9933-c2324c251c16

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
