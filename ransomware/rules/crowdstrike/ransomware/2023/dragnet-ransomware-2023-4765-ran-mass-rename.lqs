// Dragnet [Ransomware]: dragnet-ransomware-2023-4765 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: de9ca28d-e70a-50b3-ae52-4a8a18c59f4b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
