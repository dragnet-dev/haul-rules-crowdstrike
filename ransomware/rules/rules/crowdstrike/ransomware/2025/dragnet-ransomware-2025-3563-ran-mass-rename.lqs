// Dragnet [Ransomware]: dragnet-ransomware-2025-3563 — Mass File Rename (abyss)
// Status: deprecated | Level: high | ID: 0e3363d7-2428-5077-8c73-369ed280c081

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
