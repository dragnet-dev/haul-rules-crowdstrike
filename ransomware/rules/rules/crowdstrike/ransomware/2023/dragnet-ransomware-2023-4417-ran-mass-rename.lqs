// Dragnet [Ransomware]: dragnet-ransomware-2023-4417 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 7910bb17-a8bc-54d1-945f-d40f290852fa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
