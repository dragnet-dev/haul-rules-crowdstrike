// Dragnet [Ransomware]: dragnet-ransomware-2021-0860 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 80425189-f6a9-57f3-9a22-6891531157f8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
