// Dragnet [Ransomware]: dragnet-ransomware-2025-6945 — Mass File Rename (blacknevas)
// Status: experimental | Level: high | ID: b0feabff-ac5a-5081-99d2-cb3a18a0272d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
