// Dragnet [Container]: dragnet-container-2026-2417 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: a8e3f725-4509-5531-aed1-845f66b553b1

#event_simpleName=*
| (ImageFileName = *chainguard:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
