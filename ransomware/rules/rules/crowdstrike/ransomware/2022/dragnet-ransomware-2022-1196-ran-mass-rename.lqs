// Dragnet [Ransomware]: dragnet-ransomware-2022-1196 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 6a9640c6-a518-5759-a06e-c4d51cc21347

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
