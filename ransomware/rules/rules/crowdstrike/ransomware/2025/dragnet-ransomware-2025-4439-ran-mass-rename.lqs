// Dragnet [Ransomware]: dragnet-ransomware-2025-4439 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 96aa1eed-e7e5-5a79-ad64-6fef760fc0f6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
