// Dragnet [Ransomware]: dragnet-ransomware-2022-0631 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 9f6bf31a-f3e2-5b03-a301-e738be18bb6d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
