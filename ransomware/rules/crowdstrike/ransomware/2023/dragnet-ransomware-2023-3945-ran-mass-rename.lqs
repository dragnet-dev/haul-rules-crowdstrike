// Dragnet [Ransomware]: dragnet-ransomware-2023-3945 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: b4b5f875-903d-5114-a0c0-a400cef79dff

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
