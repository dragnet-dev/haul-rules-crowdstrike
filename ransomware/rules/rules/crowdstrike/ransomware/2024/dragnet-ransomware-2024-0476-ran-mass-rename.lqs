// Dragnet [Ransomware]: dragnet-ransomware-2024-0476 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 91bcddac-7c3d-5beb-9157-5436c3431001

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
