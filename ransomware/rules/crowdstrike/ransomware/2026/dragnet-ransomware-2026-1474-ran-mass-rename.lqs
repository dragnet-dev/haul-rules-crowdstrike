// Dragnet [Ransomware]: dragnet-ransomware-2026-1474 — Mass File Rename (payload)
// Status: stable | Level: high | ID: 9fa9a5d9-afb9-5522-8fe4-022b469dc0d1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
