// Dragnet [Ransomware]: dragnet-ransomware-2024-3608 — Mass File Rename (redransomware)
// Status: deprecated | Level: high | ID: 6dfb94a2-c2ab-5477-af07-c3b2942e7574

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
