// Dragnet [Ransomware]: dragnet-ransomware-2025-6242 — Mass File Rename (play)
// Status: experimental | Level: high | ID: feea6922-73b4-5ab0-97a5-18cf37cda5b8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
