// Dragnet [Ransomware]: dragnet-ransomware-2024-2003 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: a4e11e70-b352-53eb-855e-a87597b07830

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
