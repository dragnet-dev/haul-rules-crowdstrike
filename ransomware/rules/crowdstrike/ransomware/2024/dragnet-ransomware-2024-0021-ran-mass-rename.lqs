// Dragnet [Ransomware]: dragnet-ransomware-2024-0021 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 4a8ca31a-8065-58d4-bdd6-526b06c5c56b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
