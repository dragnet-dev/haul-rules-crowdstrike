// Dragnet [Ransomware]: dragnet-ransomware-2026-1392 — Mass File Rename (nightspire)
// Status: deprecated | Level: high | ID: f435c924-bc6d-5cde-8591-1a17128a316e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
