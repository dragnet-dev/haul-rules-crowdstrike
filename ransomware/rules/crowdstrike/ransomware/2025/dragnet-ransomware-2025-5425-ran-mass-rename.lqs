// Dragnet [Ransomware]: dragnet-ransomware-2025-5425 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 3a75effd-8f34-5797-b159-472a737e98b7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
