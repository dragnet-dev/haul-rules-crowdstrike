// Dragnet [Ransomware]: dragnet-ransomware-2023-1600 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 2210c4ff-c11a-5a54-8d33-ed3be2f0ad7a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
