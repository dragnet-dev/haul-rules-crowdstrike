// Dragnet [Ransomware]: dragnet-ransomware-2025-1433 — Mass File Rename (blackshrantac)
// Status: experimental | Level: high | ID: 4ce64722-748b-5904-8568-cde182e402a6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
