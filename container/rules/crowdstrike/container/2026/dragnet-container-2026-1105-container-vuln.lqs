// Dragnet [Container]: dragnet-container-2026-1105 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 846e112f-93ca-5492-8232-063aa3935d9a

#event_simpleName=*
| (ImageFileName = *alpine:3.2* OR ImageFileName = *alpine:3.3* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:7* OR ImageFileName = *debian:8* OR ImageFileName = *redhat/ubi9:*)
| table([timestamp, ComputerName])
| limit(1000)
