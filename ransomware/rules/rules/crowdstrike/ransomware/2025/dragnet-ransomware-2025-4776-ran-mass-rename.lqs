// Dragnet [Ransomware]: dragnet-ransomware-2025-4776 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: 8b96ce52-3c61-505e-bc73-c7c3180aec0b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
