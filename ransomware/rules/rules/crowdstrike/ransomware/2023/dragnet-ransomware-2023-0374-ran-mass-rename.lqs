// Dragnet [Ransomware]: dragnet-ransomware-2023-0374 — Mass File Rename (coinbasecartel)
// Status: experimental | Level: high | ID: ac8fc284-8335-5ae3-bc11-8b18ab5d9cf6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
