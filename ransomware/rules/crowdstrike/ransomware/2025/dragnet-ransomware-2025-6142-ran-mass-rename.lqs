// Dragnet [Ransomware]: dragnet-ransomware-2025-6142 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 7ca803ed-fd69-5c49-a168-d8d4bdea5e4f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
