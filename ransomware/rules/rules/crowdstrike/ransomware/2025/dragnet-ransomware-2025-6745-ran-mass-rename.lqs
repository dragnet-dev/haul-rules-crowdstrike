// Dragnet [Ransomware]: dragnet-ransomware-2025-6745 — Mass File Rename (play)
// Status: experimental | Level: high | ID: e9695617-f53c-54fc-adde-9e97b42c1189

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
