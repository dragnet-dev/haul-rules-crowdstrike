// Dragnet [Ransomware]: dragnet-ransomware-2025-2386 — Mass File Rename (blacklock)
// Status: experimental | Level: high | ID: ac920a8a-bc7b-5990-bc6c-2ba71d105fa8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
