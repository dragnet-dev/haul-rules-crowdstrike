// Dragnet [Ransomware]: dragnet-ransomware-2025-0951 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 5063a073-6ff3-5cdf-a000-8730022bddf4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
