// Dragnet [Ransomware]: dragnet-ransomware-2026-1073 — Mass File Rename (thegentlemen)
// Status: test | Level: high | ID: 303268dd-53c2-5f3e-8535-44b0da2c0f16

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
