// Dragnet [Ransomware]: dragnet-ransomware-2024-5503 — Mass File Rename (darkvault)
// Status: experimental | Level: high | ID: 6c7d8584-7d84-5b9e-b737-55f5b787071d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
