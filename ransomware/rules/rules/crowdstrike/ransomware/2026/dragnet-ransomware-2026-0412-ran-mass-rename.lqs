// Dragnet [Ransomware]: dragnet-ransomware-2026-0412 — Mass File Rename (krybit)
// Status: stable | Level: high | ID: e97ca2a6-41ab-5644-8f59-80654693c4a8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
