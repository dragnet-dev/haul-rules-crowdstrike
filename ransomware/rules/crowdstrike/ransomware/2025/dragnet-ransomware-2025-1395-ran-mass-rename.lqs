// Dragnet [Ransomware]: dragnet-ransomware-2025-1395 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 18b3e8ea-0ef2-5c5e-b6db-0c921a9cc758

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
