// Dragnet [Ransomware]: dragnet-ransomware-2021-1810 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: b68f413d-d170-5ac0-8d83-fe16c40d6019

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
