// Dragnet [Ransomware]: dragnet-ransomware-2022-3009 — Mass File Rename (cheers)
// Status: deprecated | Level: high | ID: 7cbf6a37-f92f-542b-b57f-c09f26e888e1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
