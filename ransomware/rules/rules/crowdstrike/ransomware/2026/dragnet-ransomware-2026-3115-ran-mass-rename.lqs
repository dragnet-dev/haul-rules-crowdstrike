// Dragnet [Ransomware]: dragnet-ransomware-2026-3115 — Mass File Rename (safepay)
// Status: stable | Level: high | ID: e088a6f5-d750-56e7-84bb-e6e8b1e870ce

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
