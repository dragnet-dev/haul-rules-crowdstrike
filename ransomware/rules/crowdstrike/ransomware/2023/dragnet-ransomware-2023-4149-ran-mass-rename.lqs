// Dragnet [Ransomware]: dragnet-ransomware-2023-4149 — Mass File Rename (ElDorado)
// Status: deprecated | Level: high | ID: 73856d19-ccf6-562d-a97a-e2131937d845

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
