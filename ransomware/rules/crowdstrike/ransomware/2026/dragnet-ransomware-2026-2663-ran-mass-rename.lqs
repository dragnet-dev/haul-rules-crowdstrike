// Dragnet [Ransomware]: dragnet-ransomware-2026-2663 — Mass File Rename (payoutsking)
// Status: deprecated | Level: high | ID: 8b0eb290-717b-58f0-bdcd-0f46a37a21f8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
