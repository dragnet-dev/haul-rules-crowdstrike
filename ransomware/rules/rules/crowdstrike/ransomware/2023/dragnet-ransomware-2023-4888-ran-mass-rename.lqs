// Dragnet [Ransomware]: dragnet-ransomware-2023-4888 — Mass File Rename (monti)
// Status: experimental | Level: high | ID: 931c5ab6-cb36-5576-9886-0293cdb7783d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
