// Dragnet [Container]: dragnet-container-2026-0822 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 62988d8b-6c62-54aa-9f2c-f995216524d0

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6*)
| table([timestamp, ComputerName])
| limit(1000)
