// Dragnet [Ransomware]: dragnet-ransomware-2025-1211 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 85735094-79fc-582c-8acb-a5cbd5a831aa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
