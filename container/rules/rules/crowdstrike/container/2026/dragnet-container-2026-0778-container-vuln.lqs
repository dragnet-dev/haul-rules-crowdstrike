// Dragnet [Container]: dragnet-container-2026-0778 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 2e7f0313-4958-541e-b23a-51731eba0c7b

#event_simpleName=*
| (ImageFileName = *amazonlinux:1* OR ImageFileName = *debian:7* OR ImageFileName = *debian:8* OR ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *oraclelinux:7* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:14.04* OR ImageFileName = *ubuntu:15.04* OR ImageFileName = *ubuntu:15.10*)
| table([timestamp, ComputerName])
| limit(1000)
