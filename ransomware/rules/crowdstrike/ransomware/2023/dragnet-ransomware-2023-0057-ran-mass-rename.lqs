// Dragnet [Ransomware]: dragnet-ransomware-2023-0057 — Mass File Rename (snatch)
// Status: experimental | Level: high | ID: 0b38570e-5157-5560-9a14-79183533f3a2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
