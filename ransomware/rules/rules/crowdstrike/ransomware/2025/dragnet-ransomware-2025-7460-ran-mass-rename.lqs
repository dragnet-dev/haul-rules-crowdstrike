// Dragnet [Ransomware]: dragnet-ransomware-2025-7460 — Mass File Rename (kraken)
// Status: experimental | Level: high | ID: ad962108-a8ee-5c6d-8594-ddd478796f22

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
