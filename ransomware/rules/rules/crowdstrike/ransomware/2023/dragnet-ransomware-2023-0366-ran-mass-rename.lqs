// Dragnet [Ransomware]: dragnet-ransomware-2023-0366 — Mass File Rename (play)
// Status: deprecated | Level: high | ID: 3f700724-897c-5bd5-be14-5c21faf89bea

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
