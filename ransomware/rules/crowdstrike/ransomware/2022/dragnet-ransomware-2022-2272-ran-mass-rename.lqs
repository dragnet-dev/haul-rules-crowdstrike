// Dragnet [Ransomware]: dragnet-ransomware-2022-2272 — Mass File Rename (blackbasta)
// Status: deprecated | Level: high | ID: c889036e-842c-598b-88a8-038123b9726f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
