// Dragnet [Ransomware]: dragnet-ransomware-2024-0945 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 25bd6abb-57ba-5a51-a2c5-2df58d028527

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
