// Dragnet [Ransomware]: dragnet-ransomware-2023-2555 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: 3b2c16e6-cbf4-5fdc-9db2-a05a4f66484d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
