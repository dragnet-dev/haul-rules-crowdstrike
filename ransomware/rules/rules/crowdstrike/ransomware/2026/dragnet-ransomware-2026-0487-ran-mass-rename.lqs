// Dragnet [Ransomware]: dragnet-ransomware-2026-0487 — Mass File Rename (nightspire)
// Status: deprecated | Level: high | ID: a08c81ce-478f-5f11-9532-135665a66254

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
