// Dragnet [Ransomware]: dragnet-ransomware-2023-1394 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 17516685-661a-5ce3-9b8c-91d78a9ff9a0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
