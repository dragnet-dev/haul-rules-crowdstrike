// Dragnet [Ransomware]: dragnet-ransomware-2024-5492 — Mass File Rename (ElDorado)
// Status: deprecated | Level: high | ID: 8f33d481-6dc6-5b41-bbeb-f4720caa136d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
