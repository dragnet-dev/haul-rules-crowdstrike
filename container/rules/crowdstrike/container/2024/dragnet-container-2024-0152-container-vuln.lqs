// Dragnet [Container]: dragnet-container-2024-0152 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 933b1ebc-e6dc-551f-894a-f0318cd254a1

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *ubuntu:18.04-ESM* OR ImageFileName = *ubuntu:20.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
