// Dragnet [Ransomware]: dragnet-ransomware-2024-5907 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 4dbc1c33-4a5c-5f7a-8841-7ec5ee3252dd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
