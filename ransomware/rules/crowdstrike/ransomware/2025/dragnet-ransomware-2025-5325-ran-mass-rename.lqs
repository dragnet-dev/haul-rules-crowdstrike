// Dragnet [Ransomware]: dragnet-ransomware-2025-5325 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 556d4e8f-1af9-5c32-9bcb-f24a4bf493fd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
