// Dragnet [Ransomware]: dragnet-ransomware-2022-0969 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 2b4f0519-a7fa-5b86-9f4e-d35f8930a10e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
