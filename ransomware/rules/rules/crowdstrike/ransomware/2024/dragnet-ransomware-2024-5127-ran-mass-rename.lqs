// Dragnet [Ransomware]: dragnet-ransomware-2024-5127 — Mass File Rename (madliberator)
// Status: experimental | Level: high | ID: a5cfec5f-61c8-5c14-bda6-eeebed44911a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
