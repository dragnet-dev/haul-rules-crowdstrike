// Dragnet [Ransomware]: dragnet-ransomware-2024-3945 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: ff42c7bc-3641-584a-8a8b-a44513011193

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
