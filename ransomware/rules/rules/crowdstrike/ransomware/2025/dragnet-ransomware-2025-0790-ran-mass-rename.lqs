// Dragnet [Ransomware]: dragnet-ransomware-2025-0790 — Mass File Rename (shinyhunters)
// Status: experimental | Level: high | ID: 9bd92909-0541-5966-98ee-84224c216af5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
