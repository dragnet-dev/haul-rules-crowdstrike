// Dragnet [Ransomware]: dragnet-ransomware-2025-3412 — Mass File Rename (worldleaks)
// Status: experimental | Level: high | ID: ed3062da-cfa8-5dbe-b6e6-286503d8a8de

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
