// Dragnet [Ransomware]: dragnet-ransomware-2022-0992 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: af4e2821-77c0-56e5-bc21-27cd31b62009

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
