// Dragnet [Container]: dragnet-container-2024-1202 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: c7efbbab-ec97-5efb-9c44-16a403d6df8d

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *ubuntu:18.04-ESM* OR ImageFileName = *ubuntu:20.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
