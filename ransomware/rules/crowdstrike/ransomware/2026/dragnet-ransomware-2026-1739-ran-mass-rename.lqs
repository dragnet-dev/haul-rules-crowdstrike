// Dragnet [Ransomware]: dragnet-ransomware-2026-1739 — Mass File Rename (incransom)
// Status: stable | Level: high | ID: a7aca534-860f-5fee-8a65-7e01953a9cec

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
