// Dragnet [Ransomware]: dragnet-ransomware-2024-3609 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: 628c579d-3ecd-50c7-a531-641e4334679c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
