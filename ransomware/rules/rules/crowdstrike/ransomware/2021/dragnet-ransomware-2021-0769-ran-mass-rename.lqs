// Dragnet [Ransomware]: dragnet-ransomware-2021-0769 — Mass File Rename (payloadbin)
// Status: deprecated | Level: high | ID: c58dd45d-6c0a-5bd7-9fd6-41c1ac132f64

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
