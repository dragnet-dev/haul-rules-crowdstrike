// Dragnet [Ransomware]: dragnet-ransomware-2023-1398 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 6fd17e14-462a-5155-acc3-a53b553b9e26

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
