// Dragnet [Ransomware]: dragnet-ransomware-2024-1845 — Mass File Rename (qiulong)
// Status: experimental | Level: high | ID: 4e2d36f9-355b-512b-88bc-7fe26ff06223

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
