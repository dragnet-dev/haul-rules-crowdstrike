// Dragnet [Ransomware]: dragnet-ransomware-2023-2595 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 659ba98a-2a46-5b06-9d31-ca2c0919d1b5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
