// Dragnet [Ransomware]: dragnet-ransomware-2023-2696 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 860b4f5a-d515-5b5b-b461-87e1978900c7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
