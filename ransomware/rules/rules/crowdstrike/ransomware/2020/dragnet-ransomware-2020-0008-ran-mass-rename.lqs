// Dragnet [Ransomware]: dragnet-ransomware-2020-0008 — Mass File Rename (ragnarlocker)
// Status: deprecated | Level: high | ID: e71b2b15-7f8e-5b69-aaf5-94c1b118586a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
