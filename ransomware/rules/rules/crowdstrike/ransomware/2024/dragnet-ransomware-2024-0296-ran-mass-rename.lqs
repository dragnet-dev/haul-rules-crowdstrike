// Dragnet [Ransomware]: dragnet-ransomware-2024-0296 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: c034bb4c-669d-5c5f-ba6c-ff6b7ea9469c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
