// Dragnet [Ransomware]: dragnet-ransomware-2024-4823 — Mass File Rename (rhysida)
// Status: deprecated | Level: high | ID: c7b8ce29-0f3e-5803-869c-9399b3ded5ef

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
