// Dragnet [Ransomware]: dragnet-ransomware-2023-4890 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: f8bfb994-fe62-5b7e-9fab-aa5774248ede

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
