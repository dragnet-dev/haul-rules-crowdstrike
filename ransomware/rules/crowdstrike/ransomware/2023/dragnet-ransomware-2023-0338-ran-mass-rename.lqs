// Dragnet [Ransomware]: dragnet-ransomware-2023-0338 — Mass File Rename (play)
// Status: experimental | Level: high | ID: e1b2fa02-0f9c-5b0f-b858-8d9bff63658f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
