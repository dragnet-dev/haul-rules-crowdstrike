// Dragnet [Ransomware]: dragnet-ransomware-2023-3268 — Mass File Rename (karakurt)
// Status: deprecated | Level: high | ID: 800d73b0-49c6-58c9-b9f7-2b9679f04005

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
