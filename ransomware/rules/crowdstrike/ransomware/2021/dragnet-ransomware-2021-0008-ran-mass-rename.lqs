// Dragnet [Ransomware]: dragnet-ransomware-2021-0008 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 3f363905-5ca8-5ff7-9a24-5f739fcba83f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
