// Dragnet [Ransomware]: dragnet-ransomware-2024-3954 — Mass File Rename (play)
// Status: experimental | Level: high | ID: b203e262-cf7f-5c85-8f1c-add02707c947

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
