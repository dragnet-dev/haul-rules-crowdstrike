// Dragnet [Ransomware]: dragnet-ransomware-2025-0721 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 173cb186-c330-599e-bc33-b0e3f28cb23a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
