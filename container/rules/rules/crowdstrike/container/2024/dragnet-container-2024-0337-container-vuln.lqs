// Dragnet [Container]: dragnet-container-2024-0337 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 3b9eabaf-a4fb-5a67-ac28-45d5b03564b8

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *redhat/ubi9:*)
| table([timestamp, ComputerName])
| limit(1000)
