// Dragnet [Container]: dragnet-container-2026-0638 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 793a6400-b32f-50b8-8d90-84c9362a34b8

#event_simpleName=*
| (ImageFileName = *debian:7* OR ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10* OR ImageFileName = *ubuntu:13.10*)
| table([timestamp, ComputerName])
| limit(1000)
