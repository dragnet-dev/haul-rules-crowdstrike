// Dragnet [Ransomware]: dragnet-ransomware-2023-0307 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: d33c4ebf-3a34-5e06-927d-9303fd18feff

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
