// Dragnet [Ransomware]: dragnet-ransomware-2025-7400 — Mass File Rename (crypto24)
// Status: deprecated | Level: high | ID: 683c8af4-5a51-5886-873b-87133a2dd12a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
