// Dragnet [Container]: dragnet-container-2024-0117 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: edb9d7cc-44c5-5a70-b627-d5cb64111e74

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *ubuntu:22.04*)
| table([timestamp, ComputerName])
| limit(1000)
