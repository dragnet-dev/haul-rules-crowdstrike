// Dragnet [Ransomware]: dragnet-ransomware-2023-0649 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 07695786-9a17-598a-8c7a-ac0c6500d010

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
