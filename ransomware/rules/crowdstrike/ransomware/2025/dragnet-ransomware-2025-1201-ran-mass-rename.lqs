// Dragnet [Ransomware]: dragnet-ransomware-2025-1201 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 82ecf495-dea3-5a13-bf74-8cec6e0bd1d7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
