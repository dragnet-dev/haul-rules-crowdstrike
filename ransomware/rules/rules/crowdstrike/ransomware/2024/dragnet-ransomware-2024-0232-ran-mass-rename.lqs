// Dragnet [Ransomware]: dragnet-ransomware-2024-0232 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 505c6969-69e3-55f2-924b-bc65f3508d4a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
