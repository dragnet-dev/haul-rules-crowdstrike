// Dragnet [Ransomware]: dragnet-ransomware-2023-4851 — Mass File Rename (rhysida)
// Status: experimental | Level: high | ID: d5b90749-7f24-5f52-b1a6-7b0cac725efd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
