// Dragnet [Ransomware]: dragnet-ransomware-2023-1363 — Mass File Rename (karakurt)
// Status: experimental | Level: high | ID: 79dabd95-fe1a-5f0e-afd2-2c9eb6c4c4e1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
