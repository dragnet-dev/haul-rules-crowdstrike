// Dragnet [Ransomware]: dragnet-ransomware-2024-3713 — Mass File Rename (ransomcortex)
// Status: experimental | Level: high | ID: d5e34df7-7a55-50cb-b360-ed572e2fd129

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
