// Dragnet [Ransomware]: dragnet-ransomware-2024-3066 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 7511b8b5-f318-50bd-a525-156978b4a3f4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
