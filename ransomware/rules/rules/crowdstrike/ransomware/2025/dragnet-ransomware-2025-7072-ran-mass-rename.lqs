// Dragnet [Ransomware]: dragnet-ransomware-2025-7072 — Mass File Rename (cicada3301)
// Status: experimental | Level: high | ID: a99ff827-648c-5191-8e4b-8b61701f5477

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
