// Dragnet [Ransomware]: dragnet-ransomware-2025-2332 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 7ed84451-7172-5ff2-beca-a125590bd12b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
