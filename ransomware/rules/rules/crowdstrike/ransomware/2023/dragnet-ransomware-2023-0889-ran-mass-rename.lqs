// Dragnet [Ransomware]: dragnet-ransomware-2023-0889 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 48bbed92-a231-5881-9aa4-5a15670d6c2b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
