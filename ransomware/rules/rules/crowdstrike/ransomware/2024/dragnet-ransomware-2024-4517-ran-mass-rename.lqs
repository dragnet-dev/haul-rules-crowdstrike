// Dragnet [Ransomware]: dragnet-ransomware-2024-4517 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 449f88d7-a672-5ba7-9dd8-109292d79ab7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
