// Dragnet [Ransomware]: dragnet-ransomware-2025-2122 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 6ee4b011-2e60-50a9-8262-756e5f2ea7e1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
