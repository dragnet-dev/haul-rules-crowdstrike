// Dragnet [Ransomware]: dragnet-ransomware-2023-3624 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 5daf3d5b-d05b-5130-ab16-df5feb1abc41

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
