// Dragnet [Ransomware]: dragnet-ransomware-2024-3057 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: ca9bdbbb-c3e1-5aa4-9d18-2543bb0699f2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
