// Dragnet [Ransomware]: dragnet-ransomware-2025-7007 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 8b061ec7-7bda-5fec-abae-67103ce7b9b1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
