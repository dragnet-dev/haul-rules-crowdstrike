// Dragnet [Ransomware]: dragnet-ransomware-2023-3560 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 70fb9f94-6a64-5607-8797-e82442f2b5ad

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
