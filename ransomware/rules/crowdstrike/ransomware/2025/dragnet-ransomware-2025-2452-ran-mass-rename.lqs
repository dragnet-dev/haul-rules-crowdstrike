// Dragnet [Ransomware]: dragnet-ransomware-2025-2452 — Mass File Rename (thegentlemen)
// Status: experimental | Level: high | ID: 467167a3-e9a7-5a18-ad54-7bcfda06fd3b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
