// Dragnet [Ransomware]: dragnet-ransomware-2025-3215 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: 11d77274-3944-5fae-a72c-026414312f92

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
