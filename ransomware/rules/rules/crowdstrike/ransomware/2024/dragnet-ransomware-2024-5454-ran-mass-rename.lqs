// Dragnet [Ransomware]: dragnet-ransomware-2024-5454 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 62e7345c-9896-550b-ac39-534d4b3e120d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
