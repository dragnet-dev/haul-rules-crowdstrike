// Dragnet [Ransomware]: dragnet-ransomware-2022-0511 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 8c2d0995-ba98-5341-8025-bb60123f659b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
