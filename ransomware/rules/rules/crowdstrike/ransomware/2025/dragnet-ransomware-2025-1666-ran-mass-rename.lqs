// Dragnet [Ransomware]: dragnet-ransomware-2025-1666 — Mass File Rename (apos)
// Status: deprecated | Level: high | ID: 15e2d2e4-94ba-5cf4-94a9-47b56f187438

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
