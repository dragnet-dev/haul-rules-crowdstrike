// Dragnet [Ransomware]: dragnet-ransomware-2022-2033 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 2e20f149-5a8b-56a0-ab9a-3fd22a063ec1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
