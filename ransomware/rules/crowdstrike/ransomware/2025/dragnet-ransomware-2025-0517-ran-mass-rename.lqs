// Dragnet [Ransomware]: dragnet-ransomware-2025-0517 — Mass File Rename (payoutsking)
// Status: experimental | Level: high | ID: dd8d1b70-a936-5bcb-8919-3400c85c08d0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
