// Dragnet [Ransomware]: dragnet-ransomware-2025-5544 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 9745e0a1-12f4-535d-8ac0-cf725657934c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
