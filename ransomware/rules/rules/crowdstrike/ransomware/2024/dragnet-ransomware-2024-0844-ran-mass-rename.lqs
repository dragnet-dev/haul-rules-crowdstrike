// Dragnet [Ransomware]: dragnet-ransomware-2024-0844 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 3034284d-b175-552e-bf78-32880f74c2d6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
