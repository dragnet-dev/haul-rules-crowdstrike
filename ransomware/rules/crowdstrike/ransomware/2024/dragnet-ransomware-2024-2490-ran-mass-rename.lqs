// Dragnet [Ransomware]: dragnet-ransomware-2024-2490 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: bc360527-183e-5768-badb-babf2c3ac3a0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
