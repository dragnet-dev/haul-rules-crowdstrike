// Dragnet [Ransomware]: dragnet-ransomware-2025-6243 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 2ea1df12-f8ca-5a9c-b70d-8c4b1b519666

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
