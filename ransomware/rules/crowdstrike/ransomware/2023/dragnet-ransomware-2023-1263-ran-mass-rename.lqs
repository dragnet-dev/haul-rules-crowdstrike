// Dragnet [Ransomware]: dragnet-ransomware-2023-1263 — Mass File Rename (play)
// Status: experimental | Level: high | ID: ba4c5156-64fe-5e4b-a003-cd488ece389b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
