// Dragnet [Ransomware]: dragnet-ransomware-2025-1732 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 63735bf7-d12b-510f-a8d4-c4612e7bfe70

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
