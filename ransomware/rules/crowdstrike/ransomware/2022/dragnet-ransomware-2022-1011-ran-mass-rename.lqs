// Dragnet [Ransomware]: dragnet-ransomware-2022-1011 — Mass File Rename (quantum)
// Status: deprecated | Level: high | ID: db43e326-184f-5e10-9261-af885f7aae02

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
