// Dragnet [Ransomware]: dragnet-ransomware-2024-3321 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 930a8f3c-8e51-578a-ab5d-6b2d2118a245

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
