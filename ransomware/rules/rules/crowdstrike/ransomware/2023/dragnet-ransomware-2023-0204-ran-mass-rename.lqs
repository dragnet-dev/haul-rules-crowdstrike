// Dragnet [Ransomware]: dragnet-ransomware-2023-0204 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: 7cdc0019-456c-5644-a4e4-0b99c72d6d58

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
