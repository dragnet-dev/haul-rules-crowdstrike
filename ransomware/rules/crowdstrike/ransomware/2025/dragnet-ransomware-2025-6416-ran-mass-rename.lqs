// Dragnet [Ransomware]: dragnet-ransomware-2025-6416 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: cac026b8-4bec-59af-bfe2-1a7b2d4135d9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
