// Dragnet [Ransomware]: dragnet-ransomware-2025-0413 — Mass File Rename (sinobi)
// Status: experimental | Level: high | ID: 49229c54-b642-589a-ac71-20c68d2cc802

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
