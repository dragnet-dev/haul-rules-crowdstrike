// Dragnet [Ransomware]: dragnet-ransomware-2025-2162 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: e1443f63-e5b9-5d8a-b177-fe838998336d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
