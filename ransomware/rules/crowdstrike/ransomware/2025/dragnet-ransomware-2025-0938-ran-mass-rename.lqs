// Dragnet [Ransomware]: dragnet-ransomware-2025-0938 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 627f674f-79b5-5f0c-b40a-2091e4366604

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
