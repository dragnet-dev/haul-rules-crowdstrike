// Dragnet [Ransomware]: dragnet-ransomware-2025-0624 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: bc260230-275c-5b57-8c44-8f82dc209234

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
