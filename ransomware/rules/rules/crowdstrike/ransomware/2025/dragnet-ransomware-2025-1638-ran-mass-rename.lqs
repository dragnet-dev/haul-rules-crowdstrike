// Dragnet [Ransomware]: dragnet-ransomware-2025-1638 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: ebd490ab-f23e-534d-ad34-ccf63fad5a03

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
