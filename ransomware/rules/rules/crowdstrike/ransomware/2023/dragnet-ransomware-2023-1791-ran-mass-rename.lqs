// Dragnet [Ransomware]: dragnet-ransomware-2023-1791 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 44658922-71fb-539c-bf70-ac6704dd7beb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
