// Dragnet [Ransomware]: dragnet-ransomware-2023-1431 — Mass File Rename (snatch)
// Status: experimental | Level: high | ID: 4d50666b-093e-57c3-9eef-2d3a41c9655b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
