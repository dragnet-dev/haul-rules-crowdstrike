// Dragnet [Ransomware]: dragnet-ransomware-2023-4655 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: ff5f4077-b0d0-56c6-a43d-7daecda2e914

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
