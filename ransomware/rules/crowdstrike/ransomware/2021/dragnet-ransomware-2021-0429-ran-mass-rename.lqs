// Dragnet [Ransomware]: dragnet-ransomware-2021-0429 — Mass File Rename (spook)
// Status: deprecated | Level: high | ID: e181b1bd-1cf6-5bf5-a0ea-b3c815ef7071

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
