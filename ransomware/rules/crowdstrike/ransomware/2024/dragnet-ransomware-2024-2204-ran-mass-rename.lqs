// Dragnet [Ransomware]: dragnet-ransomware-2024-2204 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: 990e1e25-4590-5b8f-80fd-10d71587d679

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
