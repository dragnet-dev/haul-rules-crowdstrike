// Dragnet [Ransomware]: dragnet-ransomware-2023-0531 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 63de32ac-c306-5a4e-b4f5-ccd4d277b9ad

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
