// Dragnet [Ransomware]: dragnet-ransomware-2021-0342 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 9d82e187-745e-5c84-809a-9b2811dfd897

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
