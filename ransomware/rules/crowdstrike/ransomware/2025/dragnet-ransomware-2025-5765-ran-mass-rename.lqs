// Dragnet [Ransomware]: dragnet-ransomware-2025-5765 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: b852f117-b9e2-5d5b-9d76-3529adf62d09

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
