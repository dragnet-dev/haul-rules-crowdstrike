// Dragnet [Ransomware]: dragnet-ransomware-2023-0310 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 135e5a18-892d-5184-9382-733c7af180c9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
