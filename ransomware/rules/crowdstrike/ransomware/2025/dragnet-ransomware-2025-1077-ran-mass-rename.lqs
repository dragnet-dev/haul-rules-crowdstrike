// Dragnet [Ransomware]: dragnet-ransomware-2025-1077 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: f2cd052a-98aa-5553-87a6-1be0a6e26b78

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
