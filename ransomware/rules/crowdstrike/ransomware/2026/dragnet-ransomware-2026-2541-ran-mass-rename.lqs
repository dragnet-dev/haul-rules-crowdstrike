// Dragnet [Ransomware]: dragnet-ransomware-2026-2541 — Mass File Rename (lockbit5)
// Status: stable | Level: high | ID: 7ea757c3-8922-51c6-8d7b-2864c1eb1f12

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
