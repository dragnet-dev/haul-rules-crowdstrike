// Dragnet [Ransomware]: dragnet-ransomware-2020-0086 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: c0a9f738-c60d-5aa3-ad7d-9c812944d07e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
