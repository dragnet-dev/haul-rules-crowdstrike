// Dragnet [Ransomware]: dragnet-ransomware-2023-1092 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 40ac33b8-8839-5cba-a2d8-253e31a5bfc5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
