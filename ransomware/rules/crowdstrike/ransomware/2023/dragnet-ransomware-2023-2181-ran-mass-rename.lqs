// Dragnet [Ransomware]: dragnet-ransomware-2023-2181 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 3b8aeacb-6a3a-52b5-b0a5-16c1657aa538

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
