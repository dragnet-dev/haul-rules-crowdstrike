// Dragnet [Ransomware]: dragnet-ransomware-2025-5178 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: ee3fe3ea-6c2b-5782-93c6-8fc4e7eef33d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
