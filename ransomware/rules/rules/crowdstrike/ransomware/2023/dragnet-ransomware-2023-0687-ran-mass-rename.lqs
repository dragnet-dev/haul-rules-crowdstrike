// Dragnet [Ransomware]: dragnet-ransomware-2023-0687 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 8961f34c-7f50-59e1-8263-d2b77814e4c4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
