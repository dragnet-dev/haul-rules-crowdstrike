// Dragnet [Ransomware]: dragnet-ransomware-2024-3349 — Mass File Rename (meow)
// Status: experimental | Level: high | ID: 59088c2e-45bc-59d0-9b1c-2efa22769872

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
