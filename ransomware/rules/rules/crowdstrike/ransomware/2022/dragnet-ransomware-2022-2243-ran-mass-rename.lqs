// Dragnet [Ransomware]: dragnet-ransomware-2022-2243 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 796299b8-3856-5e5e-82cd-b11a8acb7271

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
