// Dragnet [Ransomware]: dragnet-ransomware-2022-3086 — Mass File Rename (lv)
// Status: deprecated | Level: high | ID: 0bd98ec5-8e8a-5286-9f95-c2def84331a9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
