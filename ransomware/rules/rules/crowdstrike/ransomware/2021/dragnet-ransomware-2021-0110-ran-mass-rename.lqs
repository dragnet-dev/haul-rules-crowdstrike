// Dragnet [Ransomware]: dragnet-ransomware-2021-0110 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 2236a4f8-6e40-58cd-8e1a-2c01023f501b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
