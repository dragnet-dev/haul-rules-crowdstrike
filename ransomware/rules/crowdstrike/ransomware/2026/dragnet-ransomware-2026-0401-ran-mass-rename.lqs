// Dragnet [Ransomware]: dragnet-ransomware-2026-0401 — Mass File Rename (lockbit5)
// Status: test | Level: high | ID: a1b7d59d-14f4-5a40-80da-0328ea216728

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
