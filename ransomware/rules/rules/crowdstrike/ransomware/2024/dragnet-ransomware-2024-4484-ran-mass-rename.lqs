// Dragnet [Ransomware]: dragnet-ransomware-2024-4484 — Mass File Rename (flocker)
// Status: experimental | Level: high | ID: ed58579c-548a-5ddb-aa88-3cf87125df9c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
