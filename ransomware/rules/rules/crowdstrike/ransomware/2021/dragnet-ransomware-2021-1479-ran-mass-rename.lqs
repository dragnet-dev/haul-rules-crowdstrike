// Dragnet [Ransomware]: dragnet-ransomware-2021-1479 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 03533ed3-a1fc-5c87-9ff7-6b640048fe51

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
