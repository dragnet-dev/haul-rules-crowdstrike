// Dragnet [Ransomware]: dragnet-ransomware-2022-2507 — Mass File Rename (icefire)
// Status: deprecated | Level: high | ID: e7914fc2-0706-58a1-8778-761b71ff6a94

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
