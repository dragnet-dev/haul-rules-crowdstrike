// Dragnet [Ransomware]: dragnet-ransomware-2026-3166 — Mass File Rename (dragonforce)
// Status: stable | Level: high | ID: e6ad70aa-9248-57bd-b7ff-559772a6103c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
