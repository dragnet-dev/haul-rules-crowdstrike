// Dragnet [Ransomware]: dragnet-ransomware-2023-0053 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 38397c83-89a4-52f3-93ae-bb159b0063f3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
