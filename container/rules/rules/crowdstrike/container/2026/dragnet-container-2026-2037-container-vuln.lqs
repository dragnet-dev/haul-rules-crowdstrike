// Dragnet [Container]: dragnet-container-2026-2037 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 30ab45be-fbea-5810-82ee-a78cb75eec59

#event_simpleName=*
| (ImageFileName = *almalinux:10* OR ImageFileName = *almalinux:8* OR ImageFileName = *almalinux:9* OR ImageFileName = *alpine:3.21* OR ImageFileName = *alpine:3.22* OR ImageFileName = *alpine:3.23* OR ImageFileName = *alpine edge:* OR ImageFileName = *amazonlinux:2023* OR ImageFileName = *azure linux:3.0* OR ImageFileName = *chainguard:* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:8* OR ImageFileName = *oraclelinux:9* OR ImageFileName = *photon os:4.0* OR ImageFileName = *photon os:5.0* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
