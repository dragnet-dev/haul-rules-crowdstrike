// Dragnet [Ransomware]: dragnet-ransomware-2024-3202 — Mass File Rename (safepay)
// Status: deprecated | Level: high | ID: 73af094a-4797-538c-9995-6b72e13dc152

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
