// Dragnet [Ransomware]: dragnet-ransomware-2024-1338 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: ca759390-d26b-5ec9-92b0-1fd01c5ab4b5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
