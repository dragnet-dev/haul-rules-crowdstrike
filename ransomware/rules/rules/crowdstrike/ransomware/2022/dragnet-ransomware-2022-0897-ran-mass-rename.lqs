// Dragnet [Ransomware]: dragnet-ransomware-2022-0897 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 3cf93d99-ad2f-5e88-8cfc-ccbd373227f3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
