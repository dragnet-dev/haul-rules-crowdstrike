// Dragnet [Ransomware]: dragnet-ransomware-2024-4421 — Mass File Rename (raworld)
// Status: experimental | Level: high | ID: abc665cf-af8a-598e-83b0-9eeb3cd2828b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
