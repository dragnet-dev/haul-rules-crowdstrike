// Dragnet [Ransomware]: dragnet-ransomware-2025-7559 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: c582b8e7-3a4c-543d-8f0b-492c75ed2e9e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
