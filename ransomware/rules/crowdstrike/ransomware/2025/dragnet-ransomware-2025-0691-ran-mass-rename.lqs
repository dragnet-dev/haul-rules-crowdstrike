// Dragnet [Ransomware]: dragnet-ransomware-2025-0691 — Mass File Rename (worldleaks)
// Status: experimental | Level: high | ID: 77e09bee-06bb-525b-bfea-e93188ec0e84

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
