// Dragnet [Ransomware]: dragnet-ransomware-2024-3370 — Mass File Rename (cicada3301)
// Status: experimental | Level: high | ID: 24d41c43-3868-506e-84b8-9e02aab38614

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
