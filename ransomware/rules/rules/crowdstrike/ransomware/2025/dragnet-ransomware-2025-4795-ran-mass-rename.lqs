// Dragnet [Ransomware]: dragnet-ransomware-2025-4795 — Mass File Rename (cicada3301)
// Status: experimental | Level: high | ID: 871aa3a0-0f68-5762-b11f-76c3bc798c59

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
