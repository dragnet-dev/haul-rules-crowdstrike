// Dragnet [Ransomware]: dragnet-ransomware-2023-1564 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: e9616ee3-676d-5a31-9034-523532a53753

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
