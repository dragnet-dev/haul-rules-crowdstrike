// Dragnet [Ransomware]: dragnet-ransomware-2025-7550 — Mass File Rename (devman)
// Status: experimental | Level: high | ID: b9c7e490-58c2-5fa1-80d4-9607ad6f27c1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
