// Dragnet [Ransomware]: dragnet-ransomware-2025-5571 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 7c8b9fda-d66b-5370-b6fa-04b7013f1de3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
