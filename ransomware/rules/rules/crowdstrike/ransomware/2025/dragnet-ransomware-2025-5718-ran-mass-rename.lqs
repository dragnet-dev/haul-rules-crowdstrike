// Dragnet [Ransomware]: dragnet-ransomware-2025-5718 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: 8b40185e-3956-59af-8182-2ec0012ddf5e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
