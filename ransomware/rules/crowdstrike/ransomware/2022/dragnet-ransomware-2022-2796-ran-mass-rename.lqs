// Dragnet [Ransomware]: dragnet-ransomware-2022-2796 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: ae70f945-58a2-5dea-b940-22367788b128

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
