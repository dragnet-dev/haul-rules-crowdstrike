// Dragnet [Ransomware]: dragnet-ransomware-2023-3879 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 7f67c715-9220-5e88-9fa5-81710d9b7645

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
