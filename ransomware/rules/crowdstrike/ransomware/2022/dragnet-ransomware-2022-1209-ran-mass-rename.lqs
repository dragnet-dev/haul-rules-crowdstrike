// Dragnet [Ransomware]: dragnet-ransomware-2022-1209 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 5939d158-d816-5aff-8d17-9edbddf63c8d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
