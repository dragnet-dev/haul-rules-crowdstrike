// Dragnet [Container]: dragnet-container-2026-2552 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: cbd9567b-5262-5f79-8b5d-3d21a0b3c233

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:8* OR ImageFileName = *ubuntu:16.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
