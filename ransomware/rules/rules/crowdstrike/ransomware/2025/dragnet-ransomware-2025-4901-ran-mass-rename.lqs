// Dragnet [Ransomware]: dragnet-ransomware-2025-4901 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: 62a3b2ad-81b3-5321-9802-5165e1c357b1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
