// Dragnet [Ransomware]: dragnet-ransomware-2024-1030 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: dc3bb654-7bf5-5a60-b9ed-4b46e5aef025

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
