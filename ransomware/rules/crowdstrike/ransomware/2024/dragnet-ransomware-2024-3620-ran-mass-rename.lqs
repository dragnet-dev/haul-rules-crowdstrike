// Dragnet [Ransomware]: dragnet-ransomware-2024-3620 — Mass File Rename (interlock)
// Status: experimental | Level: high | ID: 6ebb413c-1663-5eb5-9036-67d5fff2dde4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
