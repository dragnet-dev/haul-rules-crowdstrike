// Dragnet [Ransomware]: dragnet-ransomware-2022-0566 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 7b5153dd-d1c2-5439-b8f6-dac9591285b2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
