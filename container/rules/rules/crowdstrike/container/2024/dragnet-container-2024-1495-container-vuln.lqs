// Dragnet [Container]: dragnet-container-2024-1495 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: b440d563-5428-52d6-a558-178dfbd7cd6d

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:9*)
| table([timestamp, ComputerName])
| limit(1000)
