// Dragnet [Ransomware]: dragnet-ransomware-2025-7110 — Mass File Rename (flocker)
// Status: experimental | Level: high | ID: 3b1c5f9a-cf3e-523d-adae-628e505707a9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
