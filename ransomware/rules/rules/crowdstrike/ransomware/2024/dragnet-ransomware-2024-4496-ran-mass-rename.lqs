// Dragnet [Ransomware]: dragnet-ransomware-2024-4496 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: a2b6c5ef-bddc-58b0-92da-21ac99f4defd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
