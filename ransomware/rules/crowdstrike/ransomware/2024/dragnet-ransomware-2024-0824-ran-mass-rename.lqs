// Dragnet [Ransomware]: dragnet-ransomware-2024-0824 — Mass File Rename (arcusmedia)
// Status: experimental | Level: high | ID: 9913d6c4-b6cf-54b3-bc34-3329c642495e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
