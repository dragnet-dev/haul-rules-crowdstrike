// Dragnet [Ransomware]: dragnet-ransomware-2024-5509 — Mass File Rename (dragonransomware)
// Status: experimental | Level: high | ID: de277827-e92e-58a8-9d89-51053e50bea0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
