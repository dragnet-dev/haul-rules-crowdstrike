// Dragnet [Ransomware]: dragnet-ransomware-2026-2165 — Mass File Rename (everest)
// Status: stable | Level: high | ID: e3328c2e-dd30-598a-bfe0-4ef4c4825a35

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
