// Dragnet [Ransomware]: dragnet-ransomware-2024-5717 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 804899ec-8495-5ee9-82e2-e5502098b093

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
