// Dragnet [Ransomware]: dragnet-ransomware-2022-1105 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 40129448-cae3-51be-999a-b774d7cd9f9f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
