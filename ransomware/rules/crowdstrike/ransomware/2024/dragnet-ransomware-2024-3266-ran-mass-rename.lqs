// Dragnet [Ransomware]: dragnet-ransomware-2024-3266 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 716a0f37-9615-5b13-95be-1f03a0feb091

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
