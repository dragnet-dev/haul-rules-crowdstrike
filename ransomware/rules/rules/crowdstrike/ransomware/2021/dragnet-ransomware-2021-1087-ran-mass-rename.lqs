// Dragnet [Ransomware]: dragnet-ransomware-2021-1087 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: d857f0bb-dd70-5fc8-aa57-f8bff3e8c9d2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
