// Dragnet [Ransomware]: dragnet-ransomware-2025-3520 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 9cca04ba-b06a-5021-8e05-91ac5848ffff

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
