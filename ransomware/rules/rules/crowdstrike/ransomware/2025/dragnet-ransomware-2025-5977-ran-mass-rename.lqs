// Dragnet [Ransomware]: dragnet-ransomware-2025-5977 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: d7682469-71a7-506b-aac1-a5db2a29e0a6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
