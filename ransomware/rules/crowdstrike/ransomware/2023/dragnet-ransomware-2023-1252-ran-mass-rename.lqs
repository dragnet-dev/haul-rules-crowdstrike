// Dragnet [Ransomware]: dragnet-ransomware-2023-1252 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 3d6fc1e6-ccb8-52b6-8217-33d8b5699d24

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
