// Dragnet [Ransomware]: dragnet-ransomware-2024-3468 — Mass File Rename (dragonforce)
// Status: deprecated | Level: high | ID: 7e300620-39f4-5d3b-a00a-53eef2a26d26

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
