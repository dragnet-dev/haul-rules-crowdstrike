// Dragnet [Ransomware]: dragnet-ransomware-2024-2087 — Mass File Rename (dragonforce)
// Status: deprecated | Level: high | ID: d4bc8268-eaa8-5e4d-9c26-1cabe4b76c17

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
