// Dragnet [Ransomware]: dragnet-ransomware-2024-0778 — Mass File Rename (arcusmedia)
// Status: experimental | Level: high | ID: 2987d5ed-9216-5e48-9096-be7c73adfd73

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
