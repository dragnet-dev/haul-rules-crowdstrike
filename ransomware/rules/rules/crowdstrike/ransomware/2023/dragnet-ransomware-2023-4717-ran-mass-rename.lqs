// Dragnet [Ransomware]: dragnet-ransomware-2023-4717 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 7b703bbc-4691-5524-9cbe-6888b7fbe94c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
