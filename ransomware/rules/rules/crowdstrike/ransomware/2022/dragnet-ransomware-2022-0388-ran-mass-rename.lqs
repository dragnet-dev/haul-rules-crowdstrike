// Dragnet [Ransomware]: dragnet-ransomware-2022-0388 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: e000f7a8-2092-5511-9caa-530f26b65750

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
