// Dragnet [Ransomware]: dragnet-ransomware-2022-2794 — Mass File Rename (ragnarlocker)
// Status: experimental | Level: high | ID: 34b38c21-c4f6-5135-ba7d-c265b470830c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
