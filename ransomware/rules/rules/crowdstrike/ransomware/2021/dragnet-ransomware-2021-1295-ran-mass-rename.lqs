// Dragnet [Ransomware]: dragnet-ransomware-2021-1295 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 71b01ba4-d59b-5426-9905-7427c528df59

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
