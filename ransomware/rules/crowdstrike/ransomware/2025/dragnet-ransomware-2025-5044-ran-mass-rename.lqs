// Dragnet [Ransomware]: dragnet-ransomware-2025-5044 — Mass File Rename (medusalocker)
// Status: experimental | Level: high | ID: cbed38ef-28fc-5e6c-85c6-1a719925550a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
