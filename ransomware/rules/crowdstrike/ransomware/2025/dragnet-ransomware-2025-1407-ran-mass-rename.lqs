// Dragnet [Ransomware]: dragnet-ransomware-2025-1407 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: 5bf1f159-2465-5699-8983-1048fc0394a7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
