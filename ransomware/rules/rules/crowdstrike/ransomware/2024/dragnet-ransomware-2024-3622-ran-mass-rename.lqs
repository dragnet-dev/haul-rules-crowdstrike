// Dragnet [Ransomware]: dragnet-ransomware-2024-3622 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 5f5e0e47-fed6-56ae-a1b3-346cbcc02d88

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
