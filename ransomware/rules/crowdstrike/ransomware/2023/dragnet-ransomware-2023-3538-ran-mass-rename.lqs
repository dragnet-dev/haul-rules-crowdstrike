// Dragnet [Ransomware]: dragnet-ransomware-2023-3538 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 03e02a4f-dbba-5cab-9fb0-877a3593d763

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
