// Dragnet [Ransomware]: dragnet-ransomware-2021-0237 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 8257a8e7-d511-596c-aed7-ef766c880810

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
