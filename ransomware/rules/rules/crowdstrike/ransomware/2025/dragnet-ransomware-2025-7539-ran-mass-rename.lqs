// Dragnet [Ransomware]: dragnet-ransomware-2025-7539 — Mass File Rename (handala)
// Status: experimental | Level: high | ID: 06959797-ac93-503e-ac55-c8bd20394e8f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
