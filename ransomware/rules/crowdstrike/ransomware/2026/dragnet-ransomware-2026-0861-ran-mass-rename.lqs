// Dragnet [Ransomware]: dragnet-ransomware-2026-0861 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 8bdf52a3-0f6c-545e-8f57-88eb51d5db2e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
