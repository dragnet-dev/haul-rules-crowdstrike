// Dragnet [Ransomware]: dragnet-ransomware-2026-3141 — Mass File Rename (termite)
// Status: stable | Level: high | ID: a0a9db61-25d3-5c88-9fbc-91227e6d688f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
