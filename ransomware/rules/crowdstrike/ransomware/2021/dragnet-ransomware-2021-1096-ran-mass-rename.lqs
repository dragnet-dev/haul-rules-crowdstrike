// Dragnet [Ransomware]: dragnet-ransomware-2021-1096 — Mass File Rename (avaddon)
// Status: deprecated | Level: high | ID: 0a59b20d-c9d7-528b-be7c-4403742b33f2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
