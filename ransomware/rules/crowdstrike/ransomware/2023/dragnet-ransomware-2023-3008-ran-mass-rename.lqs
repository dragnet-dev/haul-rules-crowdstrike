// Dragnet [Ransomware]: dragnet-ransomware-2023-3008 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 10ddc3ba-2474-5034-a691-e2e422bdce69

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
