// Dragnet [Ransomware]: dragnet-ransomware-2025-5702 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: d44fd791-9163-57da-a7b9-95205503bf5e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
