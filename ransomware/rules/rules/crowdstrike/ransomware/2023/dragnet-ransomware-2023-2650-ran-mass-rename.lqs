// Dragnet [Ransomware]: dragnet-ransomware-2023-2650 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 5700d682-9d08-5119-8561-7f6b4110a13b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
