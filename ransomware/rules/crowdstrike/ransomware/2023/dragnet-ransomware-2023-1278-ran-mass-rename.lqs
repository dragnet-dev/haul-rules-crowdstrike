// Dragnet [Ransomware]: dragnet-ransomware-2023-1278 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: f7acba4a-9bd8-5ca9-9f19-9f1aab15484e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
