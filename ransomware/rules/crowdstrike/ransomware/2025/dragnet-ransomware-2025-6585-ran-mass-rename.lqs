// Dragnet [Ransomware]: dragnet-ransomware-2025-6585 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 830e9128-4b6e-5618-8d46-7e717f427a89

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
