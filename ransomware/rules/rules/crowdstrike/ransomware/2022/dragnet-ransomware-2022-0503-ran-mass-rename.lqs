// Dragnet [Ransomware]: dragnet-ransomware-2022-0503 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 74ac3b52-ae89-539e-b633-8b1fcc4e8798

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
