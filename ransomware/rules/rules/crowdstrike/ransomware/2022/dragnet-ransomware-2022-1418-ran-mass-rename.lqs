// Dragnet [Ransomware]: dragnet-ransomware-2022-1418 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 97be05b4-88fe-5793-ae61-a426dd7c02f8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
