// Dragnet [Ransomware]: dragnet-ransomware-2024-0454 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: e364d333-03f6-576e-a2a9-e169377383de

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
