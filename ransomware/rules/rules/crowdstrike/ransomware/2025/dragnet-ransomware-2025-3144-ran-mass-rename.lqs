// Dragnet [Ransomware]: dragnet-ransomware-2025-3144 — Mass File Rename (blackshrantac)
// Status: test | Level: high | ID: 57d476f2-b035-53ed-a253-37b9f63eb75d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
