// Dragnet [Ransomware]: dragnet-ransomware-2023-2057 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 87860cd6-b1c9-53d9-8ce6-f2d6f4ea78ef

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
