// Dragnet [Ransomware]: dragnet-ransomware-2024-0231 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 91306771-0700-5298-8cc2-40956872fc9d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
