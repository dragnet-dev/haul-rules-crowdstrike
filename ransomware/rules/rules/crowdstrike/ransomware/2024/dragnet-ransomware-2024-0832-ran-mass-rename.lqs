// Dragnet [Ransomware]: dragnet-ransomware-2024-0832 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 03fa6f74-b718-5fe3-b052-181fd5c32266

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
