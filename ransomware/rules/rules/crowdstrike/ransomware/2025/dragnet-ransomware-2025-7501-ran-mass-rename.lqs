// Dragnet [Ransomware]: dragnet-ransomware-2025-7501 — Mass File Rename (stormous)
// Status: deprecated | Level: high | ID: 2a01d448-6ed7-51a6-bcbf-2a6c2af64aeb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
