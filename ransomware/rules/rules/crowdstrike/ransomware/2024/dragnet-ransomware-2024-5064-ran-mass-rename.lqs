// Dragnet [Ransomware]: dragnet-ransomware-2024-5064 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 6dca808a-06f6-544f-a7c2-f843f4c8d48d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
