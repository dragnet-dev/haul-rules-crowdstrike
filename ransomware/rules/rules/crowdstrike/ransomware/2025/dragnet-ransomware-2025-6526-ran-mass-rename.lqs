// Dragnet [Ransomware]: dragnet-ransomware-2025-6526 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 8bed5181-5e9d-5d1a-b83b-25bcb5fa0f39

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
