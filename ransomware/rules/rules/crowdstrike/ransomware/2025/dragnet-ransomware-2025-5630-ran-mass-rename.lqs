// Dragnet [Ransomware]: dragnet-ransomware-2025-5630 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: a764726a-71a2-5b4e-9086-4342587cb14d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
