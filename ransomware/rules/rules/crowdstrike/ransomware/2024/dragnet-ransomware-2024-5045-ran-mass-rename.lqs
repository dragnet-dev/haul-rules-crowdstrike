// Dragnet [Ransomware]: dragnet-ransomware-2024-5045 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: 5f1f1328-1482-57be-81f7-064f7eb83ce9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
