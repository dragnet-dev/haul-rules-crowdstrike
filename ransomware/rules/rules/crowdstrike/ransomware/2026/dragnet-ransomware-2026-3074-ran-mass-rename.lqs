// Dragnet [Ransomware]: dragnet-ransomware-2026-3074 — Mass File Rename (lockbit5)
// Status: stable | Level: high | ID: feec1309-3258-532d-93ca-58ea5b02c73d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
