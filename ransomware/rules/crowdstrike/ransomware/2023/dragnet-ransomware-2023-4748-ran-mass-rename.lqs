// Dragnet [Ransomware]: dragnet-ransomware-2023-4748 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 88a06625-1f41-5556-bb7d-3f36c3ebad14

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
