// Dragnet [Container]: dragnet-container-2026-0710 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: fc0389ec-0462-5d4c-b3e4-7cf3425ed2a6

#event_simpleName=*
| (ImageFileName = *amazonlinux:2023* OR ImageFileName = *azure linux:3.0* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *redhat/ubi9:*)
| table([timestamp, ComputerName])
| limit(1000)
