// Dragnet [Container]: dragnet-container-2024-0747 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 1b78d2c3-96fd-511f-8711-0e63cecfedf1

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
