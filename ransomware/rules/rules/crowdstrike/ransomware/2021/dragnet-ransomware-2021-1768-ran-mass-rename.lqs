// Dragnet [Ransomware]: dragnet-ransomware-2021-1768 — Mass File Rename (avaddon)
// Status: deprecated | Level: high | ID: 2cd0e58b-95b3-52e2-8e06-1d9afd72f8df

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
