// Dragnet [Container]: dragnet-container-2026-0724 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: fccbb184-bf56-58b7-b100-c8c44a54eae6

#event_simpleName=*
| (ImageFileName = *amazonlinux:1* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:9* OR ImageFileName = *oraclelinux:7* OR ImageFileName = *redhat/ubi9:*)
| table([timestamp, ComputerName])
| limit(1000)
