// Dragnet [Ransomware]: dragnet-ransomware-2024-0491 — Mass File Rename (dragonforce)
// Status: deprecated | Level: high | ID: a119c9ac-ecae-50fa-8018-4eaad8d0c2d1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
