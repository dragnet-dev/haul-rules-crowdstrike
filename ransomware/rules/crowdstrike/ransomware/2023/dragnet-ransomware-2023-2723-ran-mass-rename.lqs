// Dragnet [Ransomware]: dragnet-ransomware-2023-2723 — Mass File Rename (moneymessage)
// Status: experimental | Level: high | ID: eafe9d04-e6c2-5b29-acf7-fa1a3b00fd4c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
