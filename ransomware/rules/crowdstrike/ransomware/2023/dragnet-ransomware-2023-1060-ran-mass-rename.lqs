// Dragnet [Ransomware]: dragnet-ransomware-2023-1060 — Mass File Rename (ransomed)
// Status: deprecated | Level: high | ID: 6cd70d18-a520-5d95-972d-48d00ca41693

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
