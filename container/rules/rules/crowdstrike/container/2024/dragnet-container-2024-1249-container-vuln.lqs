// Dragnet [Container]: dragnet-container-2024-1249 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: bb94f6ad-b787-5a2c-b284-2f7874fcbea3

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *ubuntu:19.04*)
| table([timestamp, ComputerName])
| limit(1000)
