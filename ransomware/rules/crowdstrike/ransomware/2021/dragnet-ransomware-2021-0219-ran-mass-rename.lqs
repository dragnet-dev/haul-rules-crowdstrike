// Dragnet [Ransomware]: dragnet-ransomware-2021-0219 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 723c9ecf-78df-5a57-9f11-9c463d4e00fa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
