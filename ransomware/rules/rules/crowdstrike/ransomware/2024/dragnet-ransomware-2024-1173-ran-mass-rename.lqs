// Dragnet [Ransomware]: dragnet-ransomware-2024-1173 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 51d1c4d4-2303-59b0-aa91-26cc97e67d24

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
