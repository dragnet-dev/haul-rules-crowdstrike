// Dragnet [Ransomware]: dragnet-ransomware-2025-0555 — Mass File Rename (direwolf)
// Status: experimental | Level: high | ID: f7d54eee-29a9-588a-93a6-5e9a3a792448

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
