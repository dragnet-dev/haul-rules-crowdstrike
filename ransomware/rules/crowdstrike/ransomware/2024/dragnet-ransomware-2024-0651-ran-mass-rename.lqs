// Dragnet [Ransomware]: dragnet-ransomware-2024-0651 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 2bcf32e8-442d-52ad-82d9-d401a7716520

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
