// Dragnet [Ransomware]: dragnet-ransomware-2025-3000 — Mass File Rename (devman)
// Status: experimental | Level: high | ID: 23434b77-d7db-5e81-8fc2-c4a86d8982ab

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
