// Dragnet [Ransomware]: dragnet-ransomware-2025-6858 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: 9f11a54f-2bef-5b8c-a6a5-b06a912f7e04

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
