// Dragnet [Ransomware]: dragnet-ransomware-2023-4821 — Mass File Rename (qilin)
// Status: deprecated | Level: high | ID: 584fd425-4a5b-55d0-8a24-d2d17991a3d1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
