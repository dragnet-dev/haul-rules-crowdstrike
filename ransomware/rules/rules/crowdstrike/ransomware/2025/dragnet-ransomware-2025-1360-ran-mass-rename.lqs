// Dragnet [Ransomware]: dragnet-ransomware-2025-1360 — Mass File Rename (spacebears)
// Status: experimental | Level: high | ID: 94140b0b-fdae-544d-89f8-51ae1b6ee749

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
