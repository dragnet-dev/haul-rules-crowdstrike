// Dragnet [Ransomware]: dragnet-ransomware-2024-3513 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 34e250f3-e14e-591c-bb52-43d64aa8bb18

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
