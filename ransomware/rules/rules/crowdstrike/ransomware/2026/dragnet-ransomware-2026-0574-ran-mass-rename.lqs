// Dragnet [Ransomware]: dragnet-ransomware-2026-0574 — Mass File Rename (BrainCipher)
// Status: stable | Level: high | ID: 345e4e06-f2c8-57b5-baec-00e4fc43d404

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
