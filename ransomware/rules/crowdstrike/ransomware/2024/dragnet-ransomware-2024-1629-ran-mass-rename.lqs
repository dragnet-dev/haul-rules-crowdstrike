// Dragnet [Ransomware]: dragnet-ransomware-2024-1629 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 3c395a53-4715-5086-99bf-3a1646703ded

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
