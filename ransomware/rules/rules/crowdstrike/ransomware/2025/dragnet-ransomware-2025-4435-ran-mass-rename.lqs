// Dragnet [Ransomware]: dragnet-ransomware-2025-4435 — Mass File Rename (devman)
// Status: experimental | Level: high | ID: 27fe969a-f86b-56ce-8d00-bb3abf599712

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
