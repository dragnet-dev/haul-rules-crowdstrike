// Dragnet [Ransomware]: dragnet-ransomware-2024-0384 — Mass File Rename (play)
// Status: experimental | Level: high | ID: c24f3e40-be60-5e07-8a95-8b5fd6550e64

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
