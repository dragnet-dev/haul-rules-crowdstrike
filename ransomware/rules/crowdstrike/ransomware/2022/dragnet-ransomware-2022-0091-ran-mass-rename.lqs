// Dragnet [Ransomware]: dragnet-ransomware-2022-0091 — Mass File Rename (blackbasta)
// Status: deprecated | Level: high | ID: c7aa8259-2609-5db0-853a-a8611b43907e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
