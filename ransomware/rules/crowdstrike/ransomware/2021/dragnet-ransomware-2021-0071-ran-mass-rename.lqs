// Dragnet [Ransomware]: dragnet-ransomware-2021-0071 — Mass File Rename (avaddon)
// Status: deprecated | Level: high | ID: 79e5a960-ad07-5d15-8345-6d2cc3c1feb8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
