// Dragnet [Ransomware]: dragnet-ransomware-2023-1518 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: ff9fa6e5-21a4-5040-a182-98998b4ae53b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
