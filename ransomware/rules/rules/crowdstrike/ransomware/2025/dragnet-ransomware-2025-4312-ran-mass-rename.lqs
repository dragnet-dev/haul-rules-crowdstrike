// Dragnet [Ransomware]: dragnet-ransomware-2025-4312 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 1803b013-f2c9-5ffb-8d99-7cef85b6c8e1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
