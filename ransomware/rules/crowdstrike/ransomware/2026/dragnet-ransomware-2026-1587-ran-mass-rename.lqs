// Dragnet [Ransomware]: dragnet-ransomware-2026-1587 — Mass File Rename (incransom)
// Status: stable | Level: high | ID: 481bb3c2-7aa8-5c6a-bf63-33b8c47392f1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
