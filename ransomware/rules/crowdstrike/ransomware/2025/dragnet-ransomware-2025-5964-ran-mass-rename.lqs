// Dragnet [Ransomware]: dragnet-ransomware-2025-5964 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: cd89aec1-1d70-58d1-8677-5cd23356ad73

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
