// Dragnet [Ransomware]: dragnet-ransomware-2023-5070 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: e933a158-58e0-5208-bf18-35fa531f3ae0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
