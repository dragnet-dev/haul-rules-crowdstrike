// Dragnet [Ransomware]: dragnet-ransomware-2025-1960 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 633e1136-3a86-599d-a9ea-eeef79c98bcc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
