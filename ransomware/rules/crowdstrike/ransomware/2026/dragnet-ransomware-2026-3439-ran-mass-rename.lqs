// Dragnet [Ransomware]: dragnet-ransomware-2026-3439 — Mass File Rename (ransomhouse)
// Status: stable | Level: high | ID: 307156ee-6b4f-5690-bddd-b2045fcb6422

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
