// Dragnet [Ransomware]: dragnet-ransomware-2024-1047 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 14d4d480-9bc8-5137-a042-6d2054ec0dbb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
