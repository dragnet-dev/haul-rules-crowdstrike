// Dragnet [Ransomware]: dragnet-ransomware-2026-2815 — Mass File Rename (blacknevas)
// Status: stable | Level: high | ID: 24a7a424-459c-57f1-83de-c6fa47ff102f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
