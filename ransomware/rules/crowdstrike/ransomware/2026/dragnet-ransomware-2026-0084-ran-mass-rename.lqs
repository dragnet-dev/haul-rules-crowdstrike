// Dragnet [Ransomware]: dragnet-ransomware-2026-0084 — Mass File Rename (incransom)
// Status: stable | Level: high | ID: 1d6fb4a6-ffcd-5aec-a286-011f44b03096

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
