// Dragnet [Ransomware]: dragnet-ransomware-2025-7920 — Mass File Rename (pear)
// Status: experimental | Level: high | ID: 67e4325d-9c4a-51ac-ba07-6e9d1023867e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
