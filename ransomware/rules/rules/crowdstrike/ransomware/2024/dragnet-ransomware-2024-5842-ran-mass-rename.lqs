// Dragnet [Ransomware]: dragnet-ransomware-2024-5842 — Mass File Rename (dragonforce)
// Status: deprecated | Level: high | ID: bfc4fdbb-ba79-5b7e-90d9-952df22aa5ce

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
