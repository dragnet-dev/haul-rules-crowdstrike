// Dragnet [Ransomware]: dragnet-ransomware-2024-3637 — Mass File Rename (handala)
// Status: experimental | Level: high | ID: 92dd7608-cf12-5743-b099-eaacfaa39ebf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
