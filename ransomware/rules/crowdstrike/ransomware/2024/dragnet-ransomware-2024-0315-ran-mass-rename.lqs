// Dragnet [Ransomware]: dragnet-ransomware-2024-0315 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: e05e1e1e-b98d-5bff-ab37-432607aa6e8e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
