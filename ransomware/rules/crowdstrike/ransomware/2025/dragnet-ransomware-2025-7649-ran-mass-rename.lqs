// Dragnet [Ransomware]: dragnet-ransomware-2025-7649 — Mass File Rename (arcusmedia)
// Status: experimental | Level: high | ID: 4fc6192d-b8d3-56a6-b981-12c1b964ec37

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
