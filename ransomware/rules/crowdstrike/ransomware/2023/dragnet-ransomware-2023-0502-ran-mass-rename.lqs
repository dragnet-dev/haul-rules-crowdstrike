// Dragnet [Ransomware]: dragnet-ransomware-2023-0502 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 44d51377-a107-55eb-92ad-ff066c139f04

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
