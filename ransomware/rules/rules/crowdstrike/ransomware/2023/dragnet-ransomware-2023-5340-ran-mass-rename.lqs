// Dragnet [Ransomware]: dragnet-ransomware-2023-5340 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 313d1e2e-f4ca-5843-8f7a-7eaef4a70afa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
