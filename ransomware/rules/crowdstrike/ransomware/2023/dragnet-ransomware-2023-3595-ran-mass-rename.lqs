// Dragnet [Ransomware]: dragnet-ransomware-2023-3595 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 71faf482-479d-5479-9a32-099943d88c27

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
