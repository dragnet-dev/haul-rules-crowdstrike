// Dragnet [Ransomware]: dragnet-ransomware-2025-6320 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: 1526f772-8a87-5110-99c4-be5cd9f4b21d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
