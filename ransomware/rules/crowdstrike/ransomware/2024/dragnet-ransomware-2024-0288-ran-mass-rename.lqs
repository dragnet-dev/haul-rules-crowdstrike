// Dragnet [Ransomware]: dragnet-ransomware-2024-0288 — Mass File Rename (donutleaks)
// Status: experimental | Level: high | ID: c4980779-439d-5d72-bdcd-d45c21af3572

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
