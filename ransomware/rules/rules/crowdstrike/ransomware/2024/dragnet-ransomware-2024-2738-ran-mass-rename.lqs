// Dragnet [Ransomware]: dragnet-ransomware-2024-2738 — Mass File Rename (shinyhunters)
// Status: experimental | Level: high | ID: 10d541d3-aaa0-57f9-9be7-dde0630ead8f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
