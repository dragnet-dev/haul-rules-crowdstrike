// Dragnet [Ransomware]: dragnet-ransomware-2025-3306 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: 288cbd88-8fb0-50cb-b639-bcb862843b7b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
