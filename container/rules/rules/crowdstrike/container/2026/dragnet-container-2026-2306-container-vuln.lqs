// Dragnet [Container]: dragnet-container-2026-2306 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 19ed3798-4a56-5ac1-9163-6256a2984594

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:7* OR ImageFileName = *debian:8*)
| table([timestamp, ComputerName])
| limit(1000)
