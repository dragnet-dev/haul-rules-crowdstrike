// Dragnet [Ransomware]: dragnet-ransomware-2025-7189 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: 768e6cef-a728-51fd-b392-2c2aacac5f8f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
