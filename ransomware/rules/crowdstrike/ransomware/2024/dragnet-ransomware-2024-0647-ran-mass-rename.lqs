// Dragnet [Ransomware]: dragnet-ransomware-2024-0647 — Mass File Rename (monti)
// Status: experimental | Level: high | ID: 3c2acf38-d75b-5115-a28c-2ff28f71fcba

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
