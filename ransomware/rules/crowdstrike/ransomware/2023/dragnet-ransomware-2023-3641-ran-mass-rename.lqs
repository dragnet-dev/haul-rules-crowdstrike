// Dragnet [Ransomware]: dragnet-ransomware-2023-3641 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 7454bfd1-1d31-50d2-b8d4-3881f9134b12

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
