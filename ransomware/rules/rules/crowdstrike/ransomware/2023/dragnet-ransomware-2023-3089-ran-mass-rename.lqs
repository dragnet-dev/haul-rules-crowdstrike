// Dragnet [Ransomware]: dragnet-ransomware-2023-3089 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: bc1e2b5b-9ab4-5a4b-af17-54e74c3ac80f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
