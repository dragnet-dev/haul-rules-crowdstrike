// Dragnet [Ransomware]: dragnet-ransomware-2023-2989 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 72688fa6-2d89-57f7-93f6-a127fb0a2289

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
