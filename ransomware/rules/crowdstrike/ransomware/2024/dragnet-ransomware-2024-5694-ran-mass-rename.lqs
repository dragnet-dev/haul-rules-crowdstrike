// Dragnet [Ransomware]: dragnet-ransomware-2024-5694 — Mass File Rename (snatch)
// Status: experimental | Level: high | ID: 6efd606e-3ae2-5513-9ee4-8ad3c0021778

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
