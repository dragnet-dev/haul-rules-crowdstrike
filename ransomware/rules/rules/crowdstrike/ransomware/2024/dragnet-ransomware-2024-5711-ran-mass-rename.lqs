// Dragnet [Ransomware]: dragnet-ransomware-2024-5711 — Mass File Rename (raworld)
// Status: experimental | Level: high | ID: 3ea4b089-a75e-5bee-b4e3-57d7daf6658c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
