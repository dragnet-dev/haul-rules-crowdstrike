// Dragnet [Ransomware]: dragnet-ransomware-2025-5721 — Mass File Rename (beast)
// Status: experimental | Level: high | ID: ce342ff9-e7d3-5a46-a9ff-75240681509d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
