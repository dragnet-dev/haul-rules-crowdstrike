// Dragnet [Ransomware]: dragnet-ransomware-2023-4760 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: f4af9dbb-f2e1-5b17-9c4c-42ceea230f83

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
