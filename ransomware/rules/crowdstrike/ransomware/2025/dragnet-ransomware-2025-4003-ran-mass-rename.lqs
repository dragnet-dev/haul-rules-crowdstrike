// Dragnet [Ransomware]: dragnet-ransomware-2025-4003 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 37e928d9-6fab-5660-9570-7208ca1a96d4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
