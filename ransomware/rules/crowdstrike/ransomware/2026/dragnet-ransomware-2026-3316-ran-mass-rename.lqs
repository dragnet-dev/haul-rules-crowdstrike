// Dragnet [Ransomware]: dragnet-ransomware-2026-3316 — Mass File Rename (dragonforce)
// Status: test | Level: high | ID: 8fd9279c-ea45-53ce-8965-78bce152c5ed

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
