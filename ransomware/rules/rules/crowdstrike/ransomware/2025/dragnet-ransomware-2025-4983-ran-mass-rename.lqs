// Dragnet [Ransomware]: dragnet-ransomware-2025-4983 — Mass File Rename (monti)
// Status: experimental | Level: high | ID: 2eb8b88f-7b88-57c5-bb8e-49c67e1c5c27

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
