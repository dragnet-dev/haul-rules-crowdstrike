// Dragnet [Ransomware]: dragnet-ransomware-2026-2693 — Mass File Rename (fulcrumsec)
// Status: stable | Level: high | ID: 6c21f32f-4f27-5476-8733-f35a9d20a74c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
