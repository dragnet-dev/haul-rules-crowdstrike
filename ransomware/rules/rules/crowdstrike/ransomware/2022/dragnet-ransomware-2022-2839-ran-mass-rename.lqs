// Dragnet [Ransomware]: dragnet-ransomware-2022-2839 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 7b653607-4a7a-5feb-8073-59f032082c17

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
