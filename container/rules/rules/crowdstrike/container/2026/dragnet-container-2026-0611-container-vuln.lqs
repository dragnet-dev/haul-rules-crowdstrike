// Dragnet [Container]: dragnet-container-2026-0611 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: b5422ef0-3c47-5fa6-8f7e-8d435e5f944f

#event_simpleName=*
| (ImageFileName = *alpine:3.23* OR ImageFileName = *alpine edge:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
