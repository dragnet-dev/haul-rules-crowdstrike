// Dragnet [Ransomware]: dragnet-ransomware-2025-4659 — Mass File Rename (spacebears)
// Status: test | Level: high | ID: 37dd5575-470f-5c97-a0ff-68b6676c1bd9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
