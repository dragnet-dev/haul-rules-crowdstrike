// Dragnet [Ransomware]: dragnet-ransomware-2025-5914 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 9803b7ec-5cd0-59fe-b747-d18694ced46d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
