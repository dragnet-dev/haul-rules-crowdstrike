// Dragnet [Ransomware]: dragnet-ransomware-2025-5736 — Mass File Rename (radar)
// Status: deprecated | Level: high | ID: 4f0d3af7-eee5-5e2a-b8e5-c8c988fe84c1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
