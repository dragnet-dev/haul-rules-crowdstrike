// Dragnet [Ransomware]: dragnet-ransomware-2021-1002 — Mass File Rename (avaddon)
// Status: deprecated | Level: high | ID: 23c78769-ae28-514c-b178-41e4666f850f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
