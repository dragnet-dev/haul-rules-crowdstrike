// Dragnet [Ransomware]: dragnet-ransomware-2024-3984 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 51b9c46e-e1d1-5b7b-a2f1-a75b0d151beb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
