// Dragnet [Ransomware]: dragnet-ransomware-2024-1002 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 10f1056a-ad81-5c3a-bbc5-a61ec71627d7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
