// Dragnet [Ransomware]: dragnet-ransomware-2023-4470 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 9b3b3055-556b-5cd1-a481-961a9a9a1259

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
