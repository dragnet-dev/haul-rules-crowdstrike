// Dragnet [Ransomware]: dragnet-ransomware-2025-1930 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: b0adce20-70a6-5851-ad53-d071275c7de9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
