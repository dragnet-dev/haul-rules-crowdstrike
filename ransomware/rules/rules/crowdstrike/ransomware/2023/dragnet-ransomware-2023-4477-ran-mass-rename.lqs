// Dragnet [Ransomware]: dragnet-ransomware-2023-4477 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 73f1d464-5390-5a61-86c4-8726d8857044

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
