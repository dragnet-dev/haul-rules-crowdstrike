// Dragnet [Container]: dragnet-container-2026-2553 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: e1beec81-380e-51ed-8630-934bfc37ed89

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:7* OR ImageFileName = *debian:8*)
| table([timestamp, ComputerName])
| limit(1000)
