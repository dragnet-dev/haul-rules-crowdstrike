// Dragnet [Ransomware]: dragnet-ransomware-2023-1066 — Mass File Rename (rhysida)
// Status: experimental | Level: high | ID: d9f3434a-3454-5fd6-9a65-d03d8bd22266

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
