// Dragnet [Ransomware]: dragnet-ransomware-2021-0994 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 5d422617-cca2-5823-acf9-0fcbf82ab1d4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
