// Dragnet [Ransomware]: dragnet-ransomware-2022-1623 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 01c99fc8-5af5-53e7-bec1-65e5013864cf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
