// Dragnet [Ransomware]: dragnet-ransomware-2024-1203 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: a654a3c4-ec6b-548e-8bd7-72ddc6805987

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
