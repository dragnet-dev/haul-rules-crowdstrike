// Dragnet [Ransomware]: dragnet-ransomware-2025-6027 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: f49f3f8e-87fb-5949-b15a-dead06cc4f2c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
