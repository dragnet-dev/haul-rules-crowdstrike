// Dragnet [Container]: dragnet-container-2025-0494 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 6061a6c2-6c2a-5e24-a32c-dcaa5003a1da

#event_simpleName=*
| (ImageFileName = *amazonlinux:2* OR ImageFileName = *azure linux:3.0* OR ImageFileName = *cbl-mariner:2.0* OR ImageFileName = *debian:8* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *oraclelinux:7* OR ImageFileName = *ubuntu:14.04-ESM* OR ImageFileName = *ubuntu:16.04* OR ImageFileName = *ubuntu:16.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
