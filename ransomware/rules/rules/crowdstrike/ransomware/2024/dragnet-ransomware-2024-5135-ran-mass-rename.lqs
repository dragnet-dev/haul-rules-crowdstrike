// Dragnet [Ransomware]: dragnet-ransomware-2024-5135 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: 57e501e5-9fda-5485-971f-e1b516973871

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
