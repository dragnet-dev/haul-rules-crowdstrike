// Dragnet [Ransomware]: dragnet-ransomware-2022-0951 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 6e9c5ce3-3deb-58dd-9eb8-1b2c199c4026

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
