// Dragnet [Ransomware]: dragnet-ransomware-2024-5281 — Mass File Rename (slug)
// Status: experimental | Level: high | ID: 57659548-37f7-59e6-b82f-4f68d6e650f9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
