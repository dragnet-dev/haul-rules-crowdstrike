// Dragnet [Ransomware]: dragnet-ransomware-2025-6417 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: f3d3ac4b-81ed-5353-8988-a7b098d4d165

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
