// Dragnet [Ransomware]: dragnet-ransomware-2026-0796 — Mass File Rename (incransom)
// Status: test | Level: high | ID: 1e126599-708a-5327-b7c0-97fb3e602ccf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
