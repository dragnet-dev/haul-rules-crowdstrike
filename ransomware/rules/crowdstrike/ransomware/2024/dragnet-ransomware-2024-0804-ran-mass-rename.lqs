// Dragnet [Ransomware]: dragnet-ransomware-2024-0804 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 5d24470b-e562-5949-980b-3dccbbce663b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
