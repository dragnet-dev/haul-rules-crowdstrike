// Dragnet [Ransomware]: dragnet-ransomware-2024-5651 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 91c44d15-dc1f-5f53-8134-2c312f857c94

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
