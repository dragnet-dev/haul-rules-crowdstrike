// Dragnet [Container]: dragnet-container-2024-1494 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: f3c158c4-535a-5ea6-9f79-9d113c877fd1

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:7* OR ImageFileName = *oraclelinux:7*)
| table([timestamp, ComputerName])
| limit(1000)
