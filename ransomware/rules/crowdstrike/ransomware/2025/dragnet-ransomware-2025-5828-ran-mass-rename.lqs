// Dragnet [Ransomware]: dragnet-ransomware-2025-5828 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 20b336a0-1b1a-59d7-9dbe-c02025a65479

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
