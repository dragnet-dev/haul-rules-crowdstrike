// Dragnet [Ransomware]: dragnet-ransomware-2023-4487 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 8942a9c5-4cc1-54af-acac-bcc8907aaad0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
