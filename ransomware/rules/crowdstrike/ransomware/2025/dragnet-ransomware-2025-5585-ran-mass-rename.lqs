// Dragnet [Ransomware]: dragnet-ransomware-2025-5585 — Mass File Rename (J)
// Status: experimental | Level: high | ID: 6d18df37-4d4a-5bc2-b26a-14b8cfc9703d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
