// Dragnet [Ransomware]: dragnet-ransomware-2024-5679 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 3ea60c0f-6e64-5d53-a601-0af43d6ea7f7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
