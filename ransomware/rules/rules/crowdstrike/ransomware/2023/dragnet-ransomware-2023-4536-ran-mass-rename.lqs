// Dragnet [Ransomware]: dragnet-ransomware-2023-4536 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 99dbc3e4-af0e-5796-9f84-ba7fdc7b09e9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
