// Dragnet [Ransomware]: dragnet-ransomware-2025-2435 — Mass File Rename (thegentlemen)
// Status: experimental | Level: high | ID: dabd0375-1f12-5909-bd84-dbc487fdb477

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
