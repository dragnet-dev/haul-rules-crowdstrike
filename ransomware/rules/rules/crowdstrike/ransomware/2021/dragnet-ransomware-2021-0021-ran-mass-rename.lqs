// Dragnet [Ransomware]: dragnet-ransomware-2021-0021 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 6cc72494-855c-5908-9386-66141352a500

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
