// Dragnet [Ransomware]: dragnet-ransomware-2022-0441 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: c52f45ef-4611-5b57-83b7-c0f61f782e24

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
