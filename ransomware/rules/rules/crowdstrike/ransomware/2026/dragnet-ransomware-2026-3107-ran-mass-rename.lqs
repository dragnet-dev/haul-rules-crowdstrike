// Dragnet [Ransomware]: dragnet-ransomware-2026-3107 — Mass File Rename (payload)
// Status: stable | Level: high | ID: 02e3bddf-4357-5419-b9b7-1a36b025bf2e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
