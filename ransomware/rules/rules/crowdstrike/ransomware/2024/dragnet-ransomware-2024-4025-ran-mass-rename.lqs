// Dragnet [Ransomware]: dragnet-ransomware-2024-4025 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 02891087-bb31-5c48-aee0-9fd4542dba4e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
