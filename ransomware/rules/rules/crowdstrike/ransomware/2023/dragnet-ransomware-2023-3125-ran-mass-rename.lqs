// Dragnet [Ransomware]: dragnet-ransomware-2023-3125 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: e2ef89de-bc98-5681-821d-8e266cda486f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
