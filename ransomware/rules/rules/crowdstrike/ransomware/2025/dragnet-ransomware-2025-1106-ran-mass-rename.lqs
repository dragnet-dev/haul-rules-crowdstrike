// Dragnet [Ransomware]: dragnet-ransomware-2025-1106 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 976d0bf4-b6ca-5cf1-9493-3f0a88e9886e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
