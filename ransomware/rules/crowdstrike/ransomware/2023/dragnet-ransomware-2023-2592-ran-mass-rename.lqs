// Dragnet [Ransomware]: dragnet-ransomware-2023-2592 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 43308f01-67a9-54b9-96a8-4341edabb63e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
