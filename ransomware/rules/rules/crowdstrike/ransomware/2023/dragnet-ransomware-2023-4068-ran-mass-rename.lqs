// Dragnet [Ransomware]: dragnet-ransomware-2023-4068 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: ac3b9dc4-3902-517e-9816-cc2b8421f4c4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
