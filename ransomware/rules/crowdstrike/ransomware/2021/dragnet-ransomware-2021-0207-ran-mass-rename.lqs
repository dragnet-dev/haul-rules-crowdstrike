// Dragnet [Ransomware]: dragnet-ransomware-2021-0207 — Mass File Rename (snatch)
// Status: deprecated | Level: high | ID: 4d7c8262-766c-5cd7-8af0-0c7e2bda9b7f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
