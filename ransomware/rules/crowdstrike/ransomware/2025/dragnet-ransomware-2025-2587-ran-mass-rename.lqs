// Dragnet [Ransomware]: dragnet-ransomware-2025-2587 — Mass File Rename (spacebears)
// Status: experimental | Level: high | ID: 92a75587-c195-5f07-9f52-66a39c1879e9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
