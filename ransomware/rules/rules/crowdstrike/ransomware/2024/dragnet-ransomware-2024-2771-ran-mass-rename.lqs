// Dragnet [Ransomware]: dragnet-ransomware-2024-2771 — Mass File Rename (bluebox)
// Status: experimental | Level: high | ID: 18b4c6b0-564e-59ae-8783-12c405f6502b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
