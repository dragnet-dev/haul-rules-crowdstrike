// Dragnet [Ransomware]: dragnet-ransomware-2023-2854 — Mass File Rename (malas)
// Status: experimental | Level: high | ID: f23a23d3-ca32-5532-8c66-6d12ff41309e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
