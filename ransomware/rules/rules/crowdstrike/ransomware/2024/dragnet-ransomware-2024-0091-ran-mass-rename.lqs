// Dragnet [Ransomware]: dragnet-ransomware-2024-0091 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 3d4a0d53-6933-5025-94ce-67c30708bdaa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
