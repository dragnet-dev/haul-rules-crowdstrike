// Dragnet [Ransomware]: dragnet-ransomware-2023-0385 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 53e5512e-26ac-5369-a8b9-e0749c8af097

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
