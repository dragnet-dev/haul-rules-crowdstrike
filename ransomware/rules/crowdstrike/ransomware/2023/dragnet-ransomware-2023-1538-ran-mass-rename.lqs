// Dragnet [Ransomware]: dragnet-ransomware-2023-1538 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 7e6905d4-0418-5c38-9a7d-60010877fe39

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
