// Dragnet [Ransomware]: dragnet-ransomware-2025-4165 — Mass File Rename (worldleaks)
// Status: experimental | Level: high | ID: 8c9c6b6f-a9cb-5237-b9c2-ed0b27b5f08b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
