// Dragnet [Ransomware]: dragnet-ransomware-2022-2653 — Mass File Rename (bianlian)
// Status: deprecated | Level: high | ID: 91e3dac1-b22d-560c-8874-fff099323649

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
