// Dragnet [Ransomware]: dragnet-ransomware-2023-2001 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: e1bf1eea-18aa-5927-a48d-9aee926ceebc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
