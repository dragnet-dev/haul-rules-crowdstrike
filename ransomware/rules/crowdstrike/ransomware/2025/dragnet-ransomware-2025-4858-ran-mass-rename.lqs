// Dragnet [Ransomware]: dragnet-ransomware-2025-4858 — Mass File Rename (IMNCrew)
// Status: experimental | Level: high | ID: 01a51762-38d6-5d24-9b7b-be724e8e5147

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
