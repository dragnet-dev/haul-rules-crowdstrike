// Dragnet [Ransomware]: dragnet-ransomware-2025-3157 — Mass File Rename (anubis)
// Status: experimental | Level: high | ID: 31faec7a-74a0-55ff-b6a4-3a2a828a6a7b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
