// Dragnet [Ransomware]: dragnet-ransomware-2022-1720 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 84cae0fb-da3c-5463-85c7-5637ee9feaee

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
