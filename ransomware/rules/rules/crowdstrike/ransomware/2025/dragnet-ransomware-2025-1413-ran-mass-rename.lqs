// Dragnet [Ransomware]: dragnet-ransomware-2025-1413 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: e7478036-cd79-51be-9b4d-f77dacf24e56

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
