// Dragnet [Ransomware]: dragnet-ransomware-2026-2962 — Mass File Rename (nightspire)
// Status: deprecated | Level: high | ID: 86308e37-7ddf-5af8-9822-d155a913853f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
