// Dragnet [Ransomware]: dragnet-ransomware-2024-0396 — Mass File Rename (snatch)
// Status: experimental | Level: high | ID: d1b6eeb1-b466-5b62-87fd-7a4fad0ba7c7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
