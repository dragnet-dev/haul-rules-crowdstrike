// Dragnet [Ransomware]: dragnet-ransomware-2024-2289 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 0bc1e904-6d8f-518b-bf56-912184987570

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
