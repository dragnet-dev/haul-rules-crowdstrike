// Dragnet [Ransomware]: dragnet-ransomware-2022-2267 — Mass File Rename (royal)
// Status: deprecated | Level: high | ID: a25743f9-a148-502f-ad75-a41b5f39cd03

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
