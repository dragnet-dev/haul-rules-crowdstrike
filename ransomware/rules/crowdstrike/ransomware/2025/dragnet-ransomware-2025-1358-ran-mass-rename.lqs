// Dragnet [Ransomware]: dragnet-ransomware-2025-1358 — Mass File Rename (trinity)
// Status: experimental | Level: high | ID: 5ef156bd-5c86-5885-9a0f-1d7d51d0881e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
