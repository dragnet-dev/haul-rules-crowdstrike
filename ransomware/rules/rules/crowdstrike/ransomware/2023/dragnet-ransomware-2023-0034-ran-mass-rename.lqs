// Dragnet [Ransomware]: dragnet-ransomware-2023-0034 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 0416bce7-10ae-58d9-a004-6bc2a71c86eb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
