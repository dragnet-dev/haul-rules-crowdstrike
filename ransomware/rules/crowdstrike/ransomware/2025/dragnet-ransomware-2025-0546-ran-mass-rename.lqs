// Dragnet [Ransomware]: dragnet-ransomware-2025-0546 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 8192b706-6a7e-5614-a6f1-86dcbcdacbfe

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
