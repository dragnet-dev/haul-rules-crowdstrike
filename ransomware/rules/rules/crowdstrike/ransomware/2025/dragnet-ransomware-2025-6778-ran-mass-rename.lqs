// Dragnet [Ransomware]: dragnet-ransomware-2025-6778 — Mass File Rename (worldleaks)
// Status: experimental | Level: high | ID: 909de1b4-03e5-5721-b276-913dec4f2f3e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
