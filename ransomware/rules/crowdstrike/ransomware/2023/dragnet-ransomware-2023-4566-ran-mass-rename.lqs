// Dragnet [Ransomware]: dragnet-ransomware-2023-4566 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 4eb2688e-189a-588b-bb9d-5b6c2366f07c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
