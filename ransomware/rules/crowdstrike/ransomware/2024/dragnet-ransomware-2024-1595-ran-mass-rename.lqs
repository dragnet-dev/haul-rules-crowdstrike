// Dragnet [Ransomware]: dragnet-ransomware-2024-1595 — Mass File Rename (threeam)
// Status: experimental | Level: high | ID: e9f201e4-088d-531b-9b49-04a107fc2cc5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
