// Dragnet [Ransomware]: dragnet-ransomware-2025-3096 — Mass File Rename (SilentRansomGroup)
// Status: deprecated | Level: high | ID: 24df11e8-ba4c-5fc5-9a5e-e47c33f8a153

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
