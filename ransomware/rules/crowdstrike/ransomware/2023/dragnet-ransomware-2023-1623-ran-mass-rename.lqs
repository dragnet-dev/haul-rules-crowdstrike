// Dragnet [Ransomware]: dragnet-ransomware-2023-1623 — Mass File Rename (thegentlemen)
// Status: experimental | Level: high | ID: 5ee0aa94-ade7-5148-acef-8c1409eaa5a7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
