// Dragnet [Ransomware]: dragnet-ransomware-2024-2908 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: 9a2edeae-be5c-5ee1-9340-a37758d62cb6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
