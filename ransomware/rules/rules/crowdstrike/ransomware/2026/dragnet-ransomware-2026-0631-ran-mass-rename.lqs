// Dragnet [Ransomware]: dragnet-ransomware-2026-0631 — Mass File Rename (AiLock)
// Status: deprecated | Level: high | ID: 8022e3dc-be14-56e7-aca7-43d04b0a757d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
