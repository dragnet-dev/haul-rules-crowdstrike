// Dragnet [Ransomware]: dragnet-ransomware-2023-1083 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 58719289-518f-5c59-b146-b650de0413f8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
