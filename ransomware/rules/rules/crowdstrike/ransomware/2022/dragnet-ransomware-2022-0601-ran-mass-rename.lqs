// Dragnet [Ransomware]: dragnet-ransomware-2022-0601 — Mass File Rename (sparta)
// Status: deprecated | Level: high | ID: 12300223-eed6-5158-84cb-7b84a90facb7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
