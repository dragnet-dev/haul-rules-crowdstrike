// Dragnet [Ransomware]: dragnet-ransomware-2023-2855 — Mass File Rename (malas)
// Status: experimental | Level: high | ID: 95573454-616f-5d96-9d2f-35e177b7fcf0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
