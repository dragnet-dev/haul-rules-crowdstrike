// Dragnet [Ransomware]: dragnet-ransomware-2024-2662 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: 56246cdb-aca3-51e8-af26-c564509e608c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
