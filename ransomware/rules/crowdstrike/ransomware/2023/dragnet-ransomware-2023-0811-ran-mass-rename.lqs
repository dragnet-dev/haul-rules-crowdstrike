// Dragnet [Ransomware]: dragnet-ransomware-2023-0811 — Mass File Rename (raworld)
// Status: experimental | Level: high | ID: 2601717e-18ec-5ea3-824f-bb7c1f7baa11

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
