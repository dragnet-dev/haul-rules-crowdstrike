// Dragnet [Ransomware]: dragnet-ransomware-2025-2811 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 72ff9dd4-a581-5597-a843-57ef430284a0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
