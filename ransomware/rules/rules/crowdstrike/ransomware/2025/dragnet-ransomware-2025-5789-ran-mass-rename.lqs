// Dragnet [Ransomware]: dragnet-ransomware-2025-5789 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: eb403856-6bcf-5ca0-83f1-f5ce3c037e35

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
