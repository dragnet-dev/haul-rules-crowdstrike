// Dragnet [Container]: dragnet-container-2026-2334 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 0352dcbb-28df-5317-9d28-f543636f636a

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:13* OR ImageFileName = *debian:7* OR ImageFileName = *debian:8*)
| table([timestamp, ComputerName])
| limit(1000)
