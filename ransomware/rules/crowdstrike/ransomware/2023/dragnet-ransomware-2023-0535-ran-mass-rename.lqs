// Dragnet [Ransomware]: dragnet-ransomware-2023-0535 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 0565df2d-5638-51e9-9b61-98e81e82a3b4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
