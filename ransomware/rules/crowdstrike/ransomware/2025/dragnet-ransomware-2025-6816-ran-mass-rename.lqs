// Dragnet [Ransomware]: dragnet-ransomware-2025-6816 — Mass File Rename (incransom)
// Status: test | Level: high | ID: 2174c040-ddc3-59b0-8bf3-c99b1020c9f0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
