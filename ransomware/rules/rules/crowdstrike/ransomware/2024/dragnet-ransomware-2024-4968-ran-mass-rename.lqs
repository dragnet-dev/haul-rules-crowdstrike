// Dragnet [Ransomware]: dragnet-ransomware-2024-4968 — Mass File Rename (dragonforce)
// Status: deprecated | Level: high | ID: a56bbd70-116b-5500-b5c2-db718811b268

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
