// Dragnet [Ransomware]: dragnet-ransomware-2024-4767 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 7a3be690-22ac-510a-b3cf-7e5a585fbc80

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
