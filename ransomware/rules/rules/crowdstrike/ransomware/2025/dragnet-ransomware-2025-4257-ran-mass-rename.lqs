// Dragnet [Ransomware]: dragnet-ransomware-2025-4257 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 91dba1cf-89ab-5c94-9626-a7c52e04f076

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
