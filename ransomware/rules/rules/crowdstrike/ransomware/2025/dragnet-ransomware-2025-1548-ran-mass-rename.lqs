// Dragnet [Ransomware]: dragnet-ransomware-2025-1548 — Mass File Rename (play)
// Status: experimental | Level: high | ID: dfafb171-d8ae-53d8-85b6-5182233fd69a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
