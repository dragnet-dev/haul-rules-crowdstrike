// Dragnet [Ransomware]: dragnet-ransomware-2022-0819 — Mass File Rename (royal)
// Status: deprecated | Level: high | ID: 7b95084d-144e-517e-a147-ca9b163eeecf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
