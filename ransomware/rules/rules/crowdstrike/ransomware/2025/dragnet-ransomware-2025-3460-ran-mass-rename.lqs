// Dragnet [Ransomware]: dragnet-ransomware-2025-3460 — Mass File Rename (apt73)
// Status: experimental | Level: high | ID: 97b5e933-0fd1-5e46-879f-e92373c46fa4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
