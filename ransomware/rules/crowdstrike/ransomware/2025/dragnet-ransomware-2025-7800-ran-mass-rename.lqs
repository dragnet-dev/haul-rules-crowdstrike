// Dragnet [Ransomware]: dragnet-ransomware-2025-7800 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: 6dd148fe-14eb-5489-9985-59153cb0c4f8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
