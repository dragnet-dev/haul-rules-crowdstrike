// Dragnet [Ransomware]: dragnet-ransomware-2025-1746 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: ead9cd44-c385-5b03-8a1b-058328322c06

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
