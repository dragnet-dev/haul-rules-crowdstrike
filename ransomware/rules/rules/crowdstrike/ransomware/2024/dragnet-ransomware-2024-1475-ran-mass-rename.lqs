// Dragnet [Ransomware]: dragnet-ransomware-2024-1475 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: adae5b4a-8eb7-5ab8-bb91-8d2a936476e5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
