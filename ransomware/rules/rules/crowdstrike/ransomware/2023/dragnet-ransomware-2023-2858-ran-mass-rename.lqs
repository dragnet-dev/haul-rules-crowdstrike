// Dragnet [Ransomware]: dragnet-ransomware-2023-2858 — Mass File Rename (malas)
// Status: experimental | Level: high | ID: 3e7da4dd-1da7-501d-91d1-e3f8f70199af

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
