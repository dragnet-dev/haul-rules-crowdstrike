// Dragnet [Ransomware]: dragnet-ransomware-2024-4079 — Mass File Rename (madliberator)
// Status: experimental | Level: high | ID: 2c3b224c-6fd3-55cf-a6c0-8c06e5e549ff

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
