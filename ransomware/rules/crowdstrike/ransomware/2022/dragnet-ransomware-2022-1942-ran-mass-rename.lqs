// Dragnet [Ransomware]: dragnet-ransomware-2022-1942 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 8a348926-34b4-566e-aca3-b6844820e8f2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
