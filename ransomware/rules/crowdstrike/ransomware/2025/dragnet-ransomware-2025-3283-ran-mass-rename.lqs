// Dragnet [Ransomware]: dragnet-ransomware-2025-3283 — Mass File Rename (incransom)
// Status: test | Level: high | ID: 78b687ec-d0ed-56f6-b1e9-863fd0f97a03

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
