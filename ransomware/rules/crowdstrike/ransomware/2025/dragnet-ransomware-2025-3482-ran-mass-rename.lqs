// Dragnet [Ransomware]: dragnet-ransomware-2025-3482 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: d0a39e97-9ab9-5403-a3ac-973def67f6c1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
