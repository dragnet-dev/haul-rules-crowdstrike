// Dragnet [Ransomware]: dragnet-ransomware-2020-0108 — Mass File Rename (maze)
// Status: deprecated | Level: high | ID: 32385a34-bdd9-5305-8fe9-1a0dbfa83038

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
