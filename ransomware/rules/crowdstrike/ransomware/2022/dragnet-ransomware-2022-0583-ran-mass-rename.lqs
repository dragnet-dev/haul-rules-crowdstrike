// Dragnet [Ransomware]: dragnet-ransomware-2022-0583 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 849f54b8-cd87-509d-8644-a9e4de049b33

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
