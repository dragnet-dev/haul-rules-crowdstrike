// Dragnet [Ransomware]: dragnet-ransomware-2023-5287 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 286ec241-ac26-5b27-bed4-f8309f17e2f7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
