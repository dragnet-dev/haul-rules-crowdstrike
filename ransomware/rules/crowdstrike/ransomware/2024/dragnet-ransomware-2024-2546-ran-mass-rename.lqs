// Dragnet [Ransomware]: dragnet-ransomware-2024-2546 — Mass File Rename (qilin)
// Status: deprecated | Level: high | ID: 7a07cbae-3cd2-5479-bbec-1c1fd0cd8962

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
