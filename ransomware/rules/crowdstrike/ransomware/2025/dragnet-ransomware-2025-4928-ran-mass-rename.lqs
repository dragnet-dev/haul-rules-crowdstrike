// Dragnet [Ransomware]: dragnet-ransomware-2025-4928 — Mass File Rename (nova)
// Status: experimental | Level: high | ID: 082ee61d-37f1-5e7d-b836-7ef48278a5aa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
