// Dragnet [Ransomware]: dragnet-ransomware-2025-6700 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: bba119cc-7add-5754-8106-54ac76e8d674

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
