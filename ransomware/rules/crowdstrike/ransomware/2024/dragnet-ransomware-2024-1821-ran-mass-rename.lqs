// Dragnet [Ransomware]: dragnet-ransomware-2024-1821 — Mass File Rename (monti)
// Status: experimental | Level: high | ID: a09a103a-71af-5630-9dc1-63b7dcb6a5f6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
