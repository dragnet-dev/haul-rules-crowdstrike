// Dragnet [Ransomware]: dragnet-ransomware-2023-1406 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 75b63cc1-f7f5-5e6c-bc01-87f62802486d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
