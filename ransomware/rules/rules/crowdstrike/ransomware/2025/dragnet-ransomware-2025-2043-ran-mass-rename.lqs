// Dragnet [Ransomware]: dragnet-ransomware-2025-2043 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: d38ee306-70b2-59a2-b1f5-7f1308c1fa84

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
