// Dragnet [Ransomware]: dragnet-ransomware-2023-3262 — Mass File Rename (dragonforce)
// Status: deprecated | Level: high | ID: 9fce6463-67c4-5c67-a84a-7eb1f5fdb3e4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
