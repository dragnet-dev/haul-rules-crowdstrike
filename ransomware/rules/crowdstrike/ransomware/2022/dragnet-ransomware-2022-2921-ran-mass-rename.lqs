// Dragnet [Ransomware]: dragnet-ransomware-2022-2921 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 71263ea3-6201-50b4-9465-4543370c46d9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
