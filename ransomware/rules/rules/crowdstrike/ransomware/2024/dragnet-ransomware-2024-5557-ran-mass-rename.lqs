// Dragnet [Ransomware]: dragnet-ransomware-2024-5557 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 3f3b27a2-dda5-51cd-86b9-3ce8dea1a01b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
