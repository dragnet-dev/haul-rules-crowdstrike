// Dragnet [Ransomware]: dragnet-ransomware-2025-4132 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 767b199a-c296-517b-9596-90303a191337

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
