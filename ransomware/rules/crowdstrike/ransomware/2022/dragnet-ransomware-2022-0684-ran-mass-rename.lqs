// Dragnet [Ransomware]: dragnet-ransomware-2022-0684 — Mass File Rename (blackbasta)
// Status: deprecated | Level: high | ID: 59ffdd51-58d1-5259-90bc-982898b227cd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
