// Dragnet [Ransomware]: dragnet-ransomware-2021-0672 — Mass File Rename (darkleakmarket)
// Status: deprecated | Level: high | ID: 0f3a148d-e8f7-5503-b439-6d94c97c1d41

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
