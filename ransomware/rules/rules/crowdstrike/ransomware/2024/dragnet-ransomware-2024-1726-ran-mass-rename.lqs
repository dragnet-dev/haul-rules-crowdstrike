// Dragnet [Ransomware]: dragnet-ransomware-2024-1726 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 643daeb7-0dc8-554b-b223-af1a54a08deb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
