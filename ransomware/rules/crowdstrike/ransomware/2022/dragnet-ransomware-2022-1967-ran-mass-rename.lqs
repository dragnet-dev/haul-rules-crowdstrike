// Dragnet [Ransomware]: dragnet-ransomware-2022-1967 — Mass File Rename (blackbasta)
// Status: deprecated | Level: high | ID: 8d5a312f-0a50-57e1-a1eb-385dbc1876c0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
