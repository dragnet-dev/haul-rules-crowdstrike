// Dragnet [Ransomware]: dragnet-ransomware-2022-0971 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 62df4023-2a33-5f1c-b82d-fd3eaa742fcb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
