// Dragnet [Ransomware]: dragnet-ransomware-2022-0021 — Mass File Rename (cheers)
// Status: deprecated | Level: high | ID: b5769b3e-19c7-5df1-818d-2134dddce0ed

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
