// Dragnet [Ransomware]: dragnet-ransomware-2026-1031 — Mass File Rename (thegentlemen)
// Status: test | Level: high | ID: 7524b086-5908-51d0-bc22-823bc474f9c2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
