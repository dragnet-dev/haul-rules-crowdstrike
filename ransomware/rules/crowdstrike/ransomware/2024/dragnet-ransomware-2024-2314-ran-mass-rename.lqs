// Dragnet [Ransomware]: dragnet-ransomware-2024-2314 — Mass File Rename (play)
// Status: experimental | Level: high | ID: a3f2b411-59ea-5af9-abcc-0144fdc55539

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
