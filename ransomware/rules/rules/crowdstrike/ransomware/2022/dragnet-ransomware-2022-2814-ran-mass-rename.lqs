// Dragnet [Ransomware]: dragnet-ransomware-2022-2814 — Mass File Rename (ragnarlocker)
// Status: deprecated | Level: high | ID: 83940060-3368-5018-a97b-b9139f69cfa2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
