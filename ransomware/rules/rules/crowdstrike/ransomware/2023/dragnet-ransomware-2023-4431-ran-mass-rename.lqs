// Dragnet [Ransomware]: dragnet-ransomware-2023-4431 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 55d4b4d2-1ece-546a-97d8-c8624fbd145f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
