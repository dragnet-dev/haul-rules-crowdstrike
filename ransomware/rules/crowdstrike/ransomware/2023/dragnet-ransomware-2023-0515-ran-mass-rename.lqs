// Dragnet [Ransomware]: dragnet-ransomware-2023-0515 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: d68b072e-9e74-5ee4-86a2-f0adfad12dbd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
