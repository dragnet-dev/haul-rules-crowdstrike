// Dragnet [Ransomware]: dragnet-ransomware-2023-1009 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 63a42108-cb6b-5634-b96d-f86bb1112937

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
