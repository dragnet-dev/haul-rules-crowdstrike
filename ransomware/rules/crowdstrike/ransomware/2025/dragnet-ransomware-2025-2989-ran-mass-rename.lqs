// Dragnet [Ransomware]: dragnet-ransomware-2025-2989 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 10c113f2-4cac-566b-9f69-88a3460bea00

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
