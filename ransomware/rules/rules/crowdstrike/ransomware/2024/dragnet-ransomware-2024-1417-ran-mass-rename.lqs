// Dragnet [Ransomware]: dragnet-ransomware-2024-1417 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: bc56f492-0d71-5d88-bd26-43c94b1f3beb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
