// Dragnet [Ransomware]: dragnet-ransomware-2024-4875 — Mass File Rename (darkvault)
// Status: experimental | Level: high | ID: 24e9580a-cae4-5adc-a55e-22bc25700744

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
