// Dragnet [Ransomware]: dragnet-ransomware-2024-3720 — Mass File Rename (meow)
// Status: experimental | Level: high | ID: d74693ce-553a-5e0e-b522-a22334a20dce

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
