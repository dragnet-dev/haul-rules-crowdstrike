// Dragnet [Ransomware]: dragnet-ransomware-2024-3162 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 4aed1b82-4bdb-5673-b7a1-8f8dd6dc04e5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
