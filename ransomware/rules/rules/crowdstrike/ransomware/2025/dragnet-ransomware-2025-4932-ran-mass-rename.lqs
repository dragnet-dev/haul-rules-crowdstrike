// Dragnet [Ransomware]: dragnet-ransomware-2025-4932 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 97de6cc7-1f47-5d26-94f7-5028c276a6a8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
