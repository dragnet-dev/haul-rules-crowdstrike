// Dragnet [Ransomware]: dragnet-ransomware-2021-1582 — Mass File Rename (everest)
// Status: deprecated | Level: high | ID: e83214f3-a174-535b-a6af-4d5443c83147

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
