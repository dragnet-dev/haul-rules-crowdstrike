// Dragnet [Ransomware]: dragnet-ransomware-2025-4792 — Mass File Rename (sinobi)
// Status: experimental | Level: high | ID: d8dad9f9-76b9-5f8a-8b30-54de6bcd31fe

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
