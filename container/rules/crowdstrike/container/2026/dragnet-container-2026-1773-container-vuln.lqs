// Dragnet [Container]: dragnet-container-2026-1773 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 83d5991f-ed98-53e4-acc1-4663e6514959

#event_simpleName=*
| (ImageFileName = *amazonlinux:1* OR ImageFileName = *chainguard:* OR ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10*)
| table([timestamp, ComputerName])
| limit(1000)
