// Dragnet [Container]: dragnet-container-2026-1005 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 6f2b0104-57ac-592d-80a5-c3d4fb7f7067

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6*)
| table([timestamp, ComputerName])
| limit(1000)
