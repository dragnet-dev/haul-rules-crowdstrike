// Dragnet [Ransomware]: dragnet-ransomware-2022-0497 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 582830e4-b70a-5366-ae84-4925b35a2b47

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
