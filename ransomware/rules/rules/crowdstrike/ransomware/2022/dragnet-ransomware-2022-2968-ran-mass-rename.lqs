// Dragnet [Ransomware]: dragnet-ransomware-2022-2968 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 6b779e50-4031-5e34-9c34-7636bc2088c1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
