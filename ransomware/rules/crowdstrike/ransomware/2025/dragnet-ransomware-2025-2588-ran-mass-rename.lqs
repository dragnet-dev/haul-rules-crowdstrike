// Dragnet [Ransomware]: dragnet-ransomware-2025-2588 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 39abb2d6-c183-589a-af31-ecb2c06c5934

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
