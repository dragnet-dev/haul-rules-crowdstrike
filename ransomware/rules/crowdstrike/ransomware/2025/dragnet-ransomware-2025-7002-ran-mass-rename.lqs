// Dragnet [Ransomware]: dragnet-ransomware-2025-7002 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 56011c93-652c-5e78-8087-870947ef9bcd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
