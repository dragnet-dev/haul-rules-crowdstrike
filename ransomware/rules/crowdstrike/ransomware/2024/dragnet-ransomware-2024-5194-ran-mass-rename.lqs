// Dragnet [Ransomware]: dragnet-ransomware-2024-5194 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 3082dded-3025-569e-a9d4-8ee4de656906

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
