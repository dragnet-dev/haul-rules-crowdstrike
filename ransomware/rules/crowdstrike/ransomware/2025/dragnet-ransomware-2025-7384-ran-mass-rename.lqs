// Dragnet [Ransomware]: dragnet-ransomware-2025-7384 — Mass File Rename (lockbit5)
// Status: test | Level: high | ID: 5cfeab0a-43ef-5feb-8b52-1a450a6b9be2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
