// Dragnet [Ransomware]: dragnet-ransomware-2021-0900 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 9220176e-5462-53a2-b09b-babd96911722

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
