// Dragnet [Ransomware]: dragnet-ransomware-2025-5666 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 1cb2a939-60ec-50b9-96d0-144f2771e3a7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
