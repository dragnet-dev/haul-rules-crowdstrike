// Dragnet [Ransomware]: dragnet-ransomware-2025-5364 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 9cd52e41-152d-5e60-b8b1-a9df6f1f08bd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
