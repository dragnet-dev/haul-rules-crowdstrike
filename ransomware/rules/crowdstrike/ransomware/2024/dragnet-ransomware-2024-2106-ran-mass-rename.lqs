// Dragnet [Ransomware]: dragnet-ransomware-2024-2106 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: 5478e4bd-d17f-5081-98eb-e6631e316eb8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
