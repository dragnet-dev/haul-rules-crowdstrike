// Dragnet [Ransomware]: dragnet-ransomware-2022-0495 — Mass File Rename (everest)
// Status: deprecated | Level: high | ID: 51c3073e-88dc-5278-a3b7-130f292f7ece

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
