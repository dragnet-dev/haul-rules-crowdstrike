// Dragnet [Ransomware]: dragnet-ransomware-2023-1752 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 31799150-ba38-5020-b79a-6b4846b59106

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
