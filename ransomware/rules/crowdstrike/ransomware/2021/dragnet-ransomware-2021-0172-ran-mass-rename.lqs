// Dragnet [Ransomware]: dragnet-ransomware-2021-0172 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: 0767f485-ede4-577d-9718-6ea163ec6292

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
