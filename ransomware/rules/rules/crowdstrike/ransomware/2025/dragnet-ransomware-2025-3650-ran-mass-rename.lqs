// Dragnet [Ransomware]: dragnet-ransomware-2025-3650 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: e8f0a090-3091-5612-bc1c-71e155d83861

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
