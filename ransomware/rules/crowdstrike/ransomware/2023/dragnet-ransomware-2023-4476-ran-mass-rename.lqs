// Dragnet [Ransomware]: dragnet-ransomware-2023-4476 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: c5528a0a-d80f-5136-a73a-ca3e3d11ec85

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
