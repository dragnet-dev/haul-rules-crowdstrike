// Dragnet [Ransomware]: dragnet-ransomware-2025-4655 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: 4eb93d65-92fb-574a-a5a4-3c12c843e4b7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
