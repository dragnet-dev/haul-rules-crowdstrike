// Dragnet [Ransomware]: dragnet-ransomware-2022-0059 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: fb03df75-a78e-5ede-9a4b-38a77388765e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
