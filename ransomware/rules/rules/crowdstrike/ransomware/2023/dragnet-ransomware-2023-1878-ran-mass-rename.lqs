// Dragnet [Ransomware]: dragnet-ransomware-2023-1878 — Mass File Rename (donutleaks)
// Status: experimental | Level: high | ID: 3d9aca32-c8d5-5af0-85ec-a7a2d7cbfec3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
