// Dragnet [Ransomware]: dragnet-ransomware-2025-2427 — Mass File Rename (thegentlemen)
// Status: experimental | Level: high | ID: 7165c5fe-123e-51b0-b862-d53580f23b30

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
