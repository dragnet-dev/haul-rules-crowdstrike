// Dragnet [Ransomware]: dragnet-ransomware-2026-1969 — Mass File Rename (lockbit5)
// Status: stable | Level: high | ID: cd0eba7a-e443-5f8c-aea4-bab9f62a52f8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
