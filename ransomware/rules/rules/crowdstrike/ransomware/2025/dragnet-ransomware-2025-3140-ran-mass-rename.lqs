// Dragnet [Ransomware]: dragnet-ransomware-2025-3140 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 860c3ca0-db4c-56b4-9fac-e37ee3f805fd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
