// Dragnet [Ransomware]: dragnet-ransomware-2025-1514 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: fa24f74f-a7f3-55b5-b754-12aef1766171

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
