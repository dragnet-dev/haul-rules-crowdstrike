// Dragnet [Ransomware]: dragnet-ransomware-2022-1745 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 2afe34f0-aac3-51cc-be85-ce40ef78f73c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
