// Dragnet [Ransomware]: dragnet-ransomware-2026-1600 — Mass File Rename (dragonforce)
// Status: test | Level: high | ID: d16a7fbd-8745-5bdc-94b4-26ed7f2f06fe

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
