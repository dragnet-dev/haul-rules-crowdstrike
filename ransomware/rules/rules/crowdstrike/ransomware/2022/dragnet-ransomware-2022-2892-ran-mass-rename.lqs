// Dragnet [Ransomware]: dragnet-ransomware-2022-2892 — Mass File Rename (snatch)
// Status: deprecated | Level: high | ID: c7d65bff-18af-5e6a-a4cd-bd6c7242c2fd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
