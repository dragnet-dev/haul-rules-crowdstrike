// Dragnet [Ransomware]: dragnet-ransomware-2025-7446 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 2269ecfa-3c46-5e59-9b3d-216e2b652cfa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
