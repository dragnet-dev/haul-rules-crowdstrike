// Dragnet [Ransomware]: dragnet-ransomware-2025-5398 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 9918cfdc-8593-5a5c-81e3-2be2c4812305

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
