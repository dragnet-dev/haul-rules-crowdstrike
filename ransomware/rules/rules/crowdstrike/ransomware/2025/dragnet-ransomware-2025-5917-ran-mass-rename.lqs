// Dragnet [Ransomware]: dragnet-ransomware-2025-5917 — Mass File Rename (worldleaks)
// Status: experimental | Level: high | ID: 7056de7d-6f5c-5e55-8653-d146928fc658

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
