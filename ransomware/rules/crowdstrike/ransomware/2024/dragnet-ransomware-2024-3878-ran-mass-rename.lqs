// Dragnet [Ransomware]: dragnet-ransomware-2024-3878 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 85510d4c-dd8b-5fab-8509-bbc71a1df86b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
