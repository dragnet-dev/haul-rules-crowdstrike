// Dragnet [Ransomware]: dragnet-ransomware-2022-0778 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 86e630f8-19c9-54e5-96c4-d40e98ae110e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
