// Dragnet [Ransomware]: dragnet-ransomware-2024-3999 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: f98cc582-08ff-5394-bb42-5e7f69f3e283

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
