// Dragnet [Ransomware]: dragnet-ransomware-2023-3366 — Mass File Rename (toufan)
// Status: deprecated | Level: high | ID: 2e555110-bdb3-5eca-805b-f5e6a6f07995

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
