// Dragnet [Container]: dragnet-container-2026-1797 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 7bcc9639-90d9-5697-a387-f9ddfefa0c58

#event_simpleName=*
| (ImageFileName = *amazonlinux:1* OR ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10*)
| table([timestamp, ComputerName])
| limit(1000)
