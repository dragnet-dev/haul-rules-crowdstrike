// Dragnet [Ransomware]: dragnet-ransomware-2024-0284 — Mass File Rename (play)
// Status: experimental | Level: high | ID: fadc3941-3533-558e-a67c-179e0cffdc31

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
