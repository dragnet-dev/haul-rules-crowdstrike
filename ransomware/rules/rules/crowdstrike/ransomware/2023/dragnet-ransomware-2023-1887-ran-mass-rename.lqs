// Dragnet [Ransomware]: dragnet-ransomware-2023-1887 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 1f1f9643-d4bb-56b7-a653-0c836f3a76a4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
