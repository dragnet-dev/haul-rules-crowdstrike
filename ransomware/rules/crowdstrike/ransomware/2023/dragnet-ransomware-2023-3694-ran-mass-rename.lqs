// Dragnet [Ransomware]: dragnet-ransomware-2023-3694 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 7870c005-d05e-51a8-80d5-f50ed45cc625

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
