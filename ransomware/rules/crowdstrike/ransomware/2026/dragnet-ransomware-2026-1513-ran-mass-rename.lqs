// Dragnet [Ransomware]: dragnet-ransomware-2026-1513 — Mass File Rename (incransom)
// Status: stable | Level: high | ID: a417a72d-8ce1-52b6-ad57-f434f752db57

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
