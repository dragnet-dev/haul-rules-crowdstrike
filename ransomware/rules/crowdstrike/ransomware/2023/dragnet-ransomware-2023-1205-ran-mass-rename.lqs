// Dragnet [Ransomware]: dragnet-ransomware-2023-1205 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 723992a4-5c71-5b05-a55d-d207c8454a99

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
