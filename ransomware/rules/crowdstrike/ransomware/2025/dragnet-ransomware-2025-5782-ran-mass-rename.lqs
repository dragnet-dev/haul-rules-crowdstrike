// Dragnet [Ransomware]: dragnet-ransomware-2025-5782 — Mass File Rename (devman)
// Status: deprecated | Level: high | ID: afc1d4ca-88f7-5c6e-8d29-590e5c6e1485

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
