// Dragnet [Ransomware]: dragnet-ransomware-2023-5167 — Mass File Rename (darkrace)
// Status: experimental | Level: high | ID: 66f99c39-e198-52b5-ad8b-0f93e763a39b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
