// Dragnet [Ransomware]: dragnet-ransomware-2022-1974 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 49dd1ae3-6988-5169-ad93-d7d4bbc03c1c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
