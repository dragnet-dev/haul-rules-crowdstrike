// Dragnet [Ransomware]: dragnet-ransomware-2023-5160 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 6bb8f3fb-7c80-5d49-a918-4a12ada4c236

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
