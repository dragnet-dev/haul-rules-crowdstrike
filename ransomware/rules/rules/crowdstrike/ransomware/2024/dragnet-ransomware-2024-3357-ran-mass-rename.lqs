// Dragnet [Ransomware]: dragnet-ransomware-2024-3357 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 9bc281b5-7ba3-5a55-96b3-83c1712015a4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
