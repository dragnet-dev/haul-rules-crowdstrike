// Dragnet [Ransomware]: dragnet-ransomware-2025-2128 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: ea2babbe-a061-51c3-915e-d1214ce6f825

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
