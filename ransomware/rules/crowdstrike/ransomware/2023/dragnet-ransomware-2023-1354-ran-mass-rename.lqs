// Dragnet [Ransomware]: dragnet-ransomware-2023-1354 — Mass File Rename (losttrust)
// Status: deprecated | Level: high | ID: 38dd35d5-e559-58df-b0d6-4d57be5d7ca1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
