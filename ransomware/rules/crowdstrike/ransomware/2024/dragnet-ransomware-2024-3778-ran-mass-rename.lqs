// Dragnet [Ransomware]: dragnet-ransomware-2024-3778 — Mass File Rename (meow)
// Status: experimental | Level: high | ID: 83a531df-2309-5ea1-8091-20b87d32baf1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
