// Dragnet [Ransomware]: dragnet-ransomware-2022-0243 — Mass File Rename (mallox)
// Status: deprecated | Level: high | ID: 187fa2dd-5ae0-571a-8a4c-602fd8722733

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
