// Dragnet [Container]: dragnet-container-2026-0604 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: b660e6dd-deee-5de2-b880-b5d3a2a64f9c

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
