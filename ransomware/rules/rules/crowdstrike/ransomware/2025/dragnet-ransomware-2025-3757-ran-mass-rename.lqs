// Dragnet [Ransomware]: dragnet-ransomware-2025-3757 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 14ba003d-4d61-50df-9d60-2dbe8926ee25

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
