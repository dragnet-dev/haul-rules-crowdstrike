// Dragnet [Ransomware]: dragnet-ransomware-2024-1633 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 3f7b48b7-6251-50f0-a311-357c5e10ecd5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
