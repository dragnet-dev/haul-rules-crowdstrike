// Dragnet [Ransomware]: dragnet-ransomware-2022-3146 — Mass File Rename (everest)
// Status: deprecated | Level: high | ID: e9b6e0f1-7f99-5ec3-b5f4-97381c611bbb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
