// Dragnet [Container]: dragnet-container-2024-1379 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: c8c42b48-d58c-55a8-997d-0d53a08d8414

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:9*)
| table([timestamp, ComputerName])
| limit(1000)
