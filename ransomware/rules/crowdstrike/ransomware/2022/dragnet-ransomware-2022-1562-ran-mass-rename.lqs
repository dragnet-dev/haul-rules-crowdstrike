// Dragnet [Ransomware]: dragnet-ransomware-2022-1562 — Mass File Rename (snatch)
// Status: deprecated | Level: high | ID: b8b1d460-8757-5b84-b387-e872a744baf7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
