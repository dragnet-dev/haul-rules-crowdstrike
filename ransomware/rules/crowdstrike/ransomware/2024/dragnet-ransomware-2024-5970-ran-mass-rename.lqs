// Dragnet [Ransomware]: dragnet-ransomware-2024-5970 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 3809b2bc-6cff-5d70-af4a-e6edb4063428

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
