// Dragnet [Ransomware]: dragnet-ransomware-2024-0245 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 74f0461f-0fd6-55ca-9932-4dd40052cf24

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
