// Dragnet [Ransomware]: dragnet-ransomware-2021-0395 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 1aca34f3-f913-584a-882a-d6f2e8462cea

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
