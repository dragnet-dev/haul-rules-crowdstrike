// Dragnet [Ransomware]: dragnet-ransomware-2025-6316 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 4ab2b95b-0e3a-58b6-8339-4292da8a0feb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
