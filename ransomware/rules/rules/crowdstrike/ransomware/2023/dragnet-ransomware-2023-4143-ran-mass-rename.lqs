// Dragnet [Ransomware]: dragnet-ransomware-2023-4143 — Mass File Rename (losttrust)
// Status: deprecated | Level: high | ID: 84d01cae-00b2-5b51-b06e-c8b148ff103c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
