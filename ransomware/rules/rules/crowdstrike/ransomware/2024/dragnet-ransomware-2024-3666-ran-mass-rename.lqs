// Dragnet [Ransomware]: dragnet-ransomware-2024-3666 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: b144fdd7-0d00-59bb-82e2-1da1b70cfaf7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
