// Dragnet [Ransomware]: dragnet-ransomware-2025-4909 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 4dbb7ab7-6db1-5133-b974-89e67a5e65b7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
