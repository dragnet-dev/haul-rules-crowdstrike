// Dragnet [Ransomware]: dragnet-ransomware-2022-2239 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 37a0c9a4-5b9b-525c-a823-807e555dd627

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
