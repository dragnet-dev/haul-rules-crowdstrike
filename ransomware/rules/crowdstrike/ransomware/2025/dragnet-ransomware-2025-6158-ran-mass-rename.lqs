// Dragnet [Ransomware]: dragnet-ransomware-2025-6158 — Mass File Rename (play)
// Status: experimental | Level: high | ID: c0748334-a636-56dd-8011-53698c1cf3ee

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
