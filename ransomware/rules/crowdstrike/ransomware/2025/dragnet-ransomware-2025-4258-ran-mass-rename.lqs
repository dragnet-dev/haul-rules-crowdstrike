// Dragnet [Ransomware]: dragnet-ransomware-2025-4258 — Mass File Rename (play)
// Status: experimental | Level: high | ID: beb62f74-4920-5c13-ad80-f3dfc74d4465

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
