// Dragnet [Ransomware]: dragnet-ransomware-2025-6844 — Mass File Rename (desolator)
// Status: experimental | Level: high | ID: a7e06166-6a96-548a-a8fe-38f6b1377dc3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
