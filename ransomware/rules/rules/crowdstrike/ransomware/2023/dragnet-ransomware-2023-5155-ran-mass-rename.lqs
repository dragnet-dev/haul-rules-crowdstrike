// Dragnet [Ransomware]: dragnet-ransomware-2023-5155 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: b5d1b2ce-03cf-5033-b829-e47aae92ab97

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
