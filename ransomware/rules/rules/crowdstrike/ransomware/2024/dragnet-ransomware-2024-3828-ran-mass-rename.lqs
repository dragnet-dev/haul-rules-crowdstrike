// Dragnet [Ransomware]: dragnet-ransomware-2024-3828 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 4d2609d8-0f88-5e28-876a-888ed9a9b59b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
