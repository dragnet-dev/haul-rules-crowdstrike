// Dragnet [Ransomware]: dragnet-ransomware-2025-5791 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 43779a1e-5aab-5c4d-a382-ed97f46b3665

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
