// Dragnet [Ransomware]: dragnet-ransomware-2024-1874 — Mass File Rename (apt73)
// Status: experimental | Level: high | ID: cbc01a02-d677-5ba9-8d62-a34e435a0971

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
