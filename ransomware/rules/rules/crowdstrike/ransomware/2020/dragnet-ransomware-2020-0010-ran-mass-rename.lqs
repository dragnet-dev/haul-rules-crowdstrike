// Dragnet [Ransomware]: dragnet-ransomware-2020-0010 — Mass File Rename (maze)
// Status: deprecated | Level: high | ID: 2c2dc270-1b72-5128-a93a-f50c4107b6cd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
