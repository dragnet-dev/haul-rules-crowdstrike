// Dragnet [Ransomware]: dragnet-ransomware-2023-2251 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: ee073643-7adc-5b23-a967-d83f4583fd4a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
