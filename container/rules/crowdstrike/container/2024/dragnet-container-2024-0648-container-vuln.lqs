// Dragnet [Container]: dragnet-container-2024-0648 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 0e8d2a53-24e1-5837-a3d0-a865baf54a3c

#event_simpleName=*
| (ImageFileName = *almalinux:9* OR ImageFileName = *amazonlinux:2023* OR ImageFileName = *azure linux:3.0* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:9* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:22.04* OR ImageFileName = *ubuntu:23.04*)
| table([timestamp, ComputerName])
| limit(1000)
