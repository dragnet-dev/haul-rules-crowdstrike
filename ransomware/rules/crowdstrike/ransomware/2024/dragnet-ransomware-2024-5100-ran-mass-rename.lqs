// Dragnet [Ransomware]: dragnet-ransomware-2024-5100 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 27cbdb5e-219e-5d78-b2cb-cde4696b0a2f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
