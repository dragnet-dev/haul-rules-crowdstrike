// Dragnet [Ransomware]: dragnet-ransomware-2023-3648 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: d6a9185c-01ea-55a0-a902-91a8b5df9dfd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
