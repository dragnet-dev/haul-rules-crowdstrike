// Dragnet [Ransomware]: dragnet-ransomware-2024-2296 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 58380aa4-26ee-566a-8259-9ded649d44d6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
