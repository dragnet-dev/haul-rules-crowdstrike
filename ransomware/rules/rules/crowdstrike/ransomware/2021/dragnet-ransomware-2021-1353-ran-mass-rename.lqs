// Dragnet [Ransomware]: dragnet-ransomware-2021-1353 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: bbe8c1c2-501c-5dff-b825-35bc0bc66df1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
