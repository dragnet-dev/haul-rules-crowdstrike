// Dragnet [Ransomware]: dragnet-ransomware-2026-0461 — Mass File Rename (nitrogen)
// Status: test | Level: high | ID: 79253e98-230f-598c-87be-2a2386b0d2e6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
