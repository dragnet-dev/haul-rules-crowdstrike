// Dragnet [Ransomware]: dragnet-ransomware-2025-0373 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 9b414003-f15c-5da1-9a73-a7a5f7aca6eb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
