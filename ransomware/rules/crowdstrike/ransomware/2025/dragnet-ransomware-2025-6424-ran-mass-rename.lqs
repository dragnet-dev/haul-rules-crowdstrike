// Dragnet [Ransomware]: dragnet-ransomware-2025-6424 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: f0877dd2-1a61-53d9-89c3-6262fc03cf16

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
