// Dragnet [Ransomware]: dragnet-ransomware-2024-2748 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: 17c12d1d-14fa-5f9b-a7ff-829b8a5e3d37

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
