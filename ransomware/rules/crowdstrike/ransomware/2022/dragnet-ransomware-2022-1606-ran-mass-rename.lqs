// Dragnet [Ransomware]: dragnet-ransomware-2022-1606 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 1860826f-6151-549f-b500-a08f505a2a63

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
