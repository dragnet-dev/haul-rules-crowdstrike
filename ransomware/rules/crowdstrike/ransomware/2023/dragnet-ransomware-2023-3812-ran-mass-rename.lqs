// Dragnet [Ransomware]: dragnet-ransomware-2023-3812 — Mass File Rename (metaencryptor)
// Status: experimental | Level: high | ID: aea5abe2-1a3d-5886-837b-8b870d72a5c9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
