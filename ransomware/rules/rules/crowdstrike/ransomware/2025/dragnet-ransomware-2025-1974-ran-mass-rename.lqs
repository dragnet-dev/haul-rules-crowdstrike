// Dragnet [Ransomware]: dragnet-ransomware-2025-1974 — Mass File Rename (worldleaks)
// Status: experimental | Level: high | ID: 12b639c1-bb05-516b-bf58-ff8695023abb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
