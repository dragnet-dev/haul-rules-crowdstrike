// Dragnet [Ransomware]: dragnet-ransomware-2024-3684 — Mass File Rename (rhysida)
// Status: experimental | Level: high | ID: 433a4188-44b6-50d5-93be-465ffff6c7f9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
