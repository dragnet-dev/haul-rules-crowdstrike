// Dragnet [Container]: dragnet-container-2026-0333 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: d1d1089e-12cf-5891-aa90-0175644d824a

#event_simpleName=*
| (ImageFileName = *chainguard:* OR ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10*)
| table([timestamp, ComputerName])
| limit(1000)
