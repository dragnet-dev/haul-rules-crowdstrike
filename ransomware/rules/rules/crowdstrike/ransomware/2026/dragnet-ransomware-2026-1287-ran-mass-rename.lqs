// Dragnet [Ransomware]: dragnet-ransomware-2026-1287 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 59a10f1e-400b-520b-bd02-605742383cff

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
