// Dragnet [Ransomware]: dragnet-ransomware-2023-3093 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 49473ff6-6b67-5be2-b89f-279c5ac05a0e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
