// Dragnet [Ransomware]: dragnet-ransomware-2023-1689 — Mass File Rename (noescape)
// Status: experimental | Level: high | ID: 67b40d26-c500-540e-856e-14539d7b998d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
