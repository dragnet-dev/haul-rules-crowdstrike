// Dragnet [Container]: dragnet-container-2024-1428 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: ee074e47-80b8-5c59-82b4-bea2ac4a3512

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:8* OR ImageFileName = *debian:9* OR ImageFileName = *ubuntu:18.04* OR ImageFileName = *ubuntu:18.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
