// Dragnet [Ransomware]: dragnet-ransomware-2021-1032 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: aa02c195-c237-577b-af1a-5f9a06114156

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
