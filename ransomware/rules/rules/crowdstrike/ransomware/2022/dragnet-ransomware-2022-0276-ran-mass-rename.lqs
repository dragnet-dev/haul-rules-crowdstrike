// Dragnet [Ransomware]: dragnet-ransomware-2022-0276 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: e04da40e-400d-54d8-b973-36794e4f10ae

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
