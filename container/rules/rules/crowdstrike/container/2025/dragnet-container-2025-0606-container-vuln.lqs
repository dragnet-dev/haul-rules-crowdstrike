// Dragnet [Container]: dragnet-container-2025-0606 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: f135b0fe-46c2-558c-9fe0-b5c8d93f59ed

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:18.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
