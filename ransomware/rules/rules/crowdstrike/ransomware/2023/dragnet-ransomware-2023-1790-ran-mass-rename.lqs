// Dragnet [Ransomware]: dragnet-ransomware-2023-1790 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 07af900a-b228-5adf-aa1e-aca369c6554c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
