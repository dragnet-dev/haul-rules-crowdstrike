// Dragnet [Ransomware]: dragnet-ransomware-2023-2469 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 81bf3677-32b2-55ba-99b5-ed16399598a6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
