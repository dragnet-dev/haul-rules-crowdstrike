// Dragnet [Ransomware]: dragnet-ransomware-2024-4476 — Mass File Rename (sarcoma)
// Status: deprecated | Level: high | ID: 6881ba8d-1737-5bc2-8b26-4fe8b4ca3c9b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
