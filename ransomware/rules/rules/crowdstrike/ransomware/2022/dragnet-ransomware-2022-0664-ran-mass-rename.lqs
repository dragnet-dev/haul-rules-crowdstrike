// Dragnet [Ransomware]: dragnet-ransomware-2022-0664 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 734b2742-9e8f-5e10-aad0-03f64a87318c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
