// Dragnet [Ransomware]: dragnet-ransomware-2024-2228 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 05b0ae33-755e-531f-a2b1-dedc56554f87

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
