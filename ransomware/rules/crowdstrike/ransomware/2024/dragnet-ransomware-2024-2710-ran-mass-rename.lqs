// Dragnet [Ransomware]: dragnet-ransomware-2024-2710 — Mass File Rename (meow)
// Status: experimental | Level: high | ID: 79a032d9-e927-5a2c-9b75-6144735fde55

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
