// Dragnet [Ransomware]: dragnet-ransomware-2025-6527 — Mass File Rename (pear)
// Status: experimental | Level: high | ID: 483f1b8a-b83c-55e9-903b-262f933371ac

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
