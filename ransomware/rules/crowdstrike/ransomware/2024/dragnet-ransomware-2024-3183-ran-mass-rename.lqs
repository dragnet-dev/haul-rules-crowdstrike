// Dragnet [Ransomware]: dragnet-ransomware-2024-3183 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: c153f669-f338-5ef1-ad05-80cfb15bd61a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
