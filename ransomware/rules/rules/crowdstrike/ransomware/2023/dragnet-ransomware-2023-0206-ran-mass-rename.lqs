// Dragnet [Ransomware]: dragnet-ransomware-2023-0206 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: f776b271-a82e-5fe2-bb63-65068db661d4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
