// Dragnet [Ransomware]: dragnet-ransomware-2024-1387 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: c56694d7-74c2-5171-91a3-e29f6798f220

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
