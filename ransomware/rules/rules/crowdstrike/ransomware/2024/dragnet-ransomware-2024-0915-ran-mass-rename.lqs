// Dragnet [Ransomware]: dragnet-ransomware-2024-0915 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: eef577f3-f98e-5ac3-a330-1c7d187bc0ea

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
