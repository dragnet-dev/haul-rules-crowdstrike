// Dragnet [Ransomware]: dragnet-ransomware-2023-0246 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: fca9f527-87b6-527e-9b92-56c302d7829d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
