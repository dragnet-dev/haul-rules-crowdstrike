// Dragnet [Ransomware]: dragnet-ransomware-2025-5164 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: 516333e5-9d1c-5fb0-b3de-81e19712261e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
