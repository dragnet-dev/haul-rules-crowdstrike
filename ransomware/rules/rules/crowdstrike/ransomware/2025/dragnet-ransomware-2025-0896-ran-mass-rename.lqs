// Dragnet [Ransomware]: dragnet-ransomware-2025-0896 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: ec2bdf71-757a-5a14-b8c4-5eebea205e2f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
