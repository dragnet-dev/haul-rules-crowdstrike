// Dragnet [Ransomware]: dragnet-ransomware-2025-0432 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 9c8b5246-4b77-5488-bf19-6fe721b45c5d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
