// Dragnet [Ransomware]: dragnet-ransomware-2025-2537 — Mass File Rename (chaos)
// Status: experimental | Level: high | ID: 5d062dd2-035a-50fc-b39b-09439d70df7c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
