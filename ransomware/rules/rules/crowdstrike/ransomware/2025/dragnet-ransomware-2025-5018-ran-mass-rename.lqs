// Dragnet [Ransomware]: dragnet-ransomware-2025-5018 — Mass File Rename (J)
// Status: experimental | Level: high | ID: aef76b1f-3785-5b98-930b-4a9a2350f77b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
