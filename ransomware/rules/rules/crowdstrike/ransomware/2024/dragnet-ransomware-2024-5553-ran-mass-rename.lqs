// Dragnet [Ransomware]: dragnet-ransomware-2024-5553 — Mass File Rename (apt73)
// Status: experimental | Level: high | ID: 0a586672-4013-5c0d-947e-39833f08f3f7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
