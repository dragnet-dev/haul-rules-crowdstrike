// Dragnet [Ransomware]: dragnet-ransomware-2023-1951 — Mass File Rename (unsafe)
// Status: deprecated | Level: high | ID: 92446ec4-2983-55fc-902d-f0ddc677210c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
