// Dragnet [Container]: dragnet-container-2026-0889 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 6bbb41ea-e4c8-57d4-94ec-2454b440fc02

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:5*)
| table([timestamp, ComputerName])
| limit(1000)
