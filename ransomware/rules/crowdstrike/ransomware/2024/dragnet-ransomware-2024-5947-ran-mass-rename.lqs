// Dragnet [Ransomware]: dragnet-ransomware-2024-5947 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 9892d76b-2cfa-5ebc-8528-aa2493a3b182

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
