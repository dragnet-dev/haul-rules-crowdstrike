// Dragnet [Ransomware]: dragnet-ransomware-2025-0138 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 44f00623-2038-5263-bb05-ba22de06f521

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
