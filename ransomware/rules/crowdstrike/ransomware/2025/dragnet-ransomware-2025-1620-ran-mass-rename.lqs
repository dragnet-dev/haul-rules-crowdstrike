// Dragnet [Ransomware]: dragnet-ransomware-2025-1620 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 1040ad96-8288-5737-9332-1e007e1ef616

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
