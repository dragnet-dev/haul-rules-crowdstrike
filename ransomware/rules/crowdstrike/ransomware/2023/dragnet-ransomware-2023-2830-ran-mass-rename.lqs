// Dragnet [Ransomware]: dragnet-ransomware-2023-2830 — Mass File Rename (malas)
// Status: experimental | Level: high | ID: 525e1bbf-a9fd-5de0-807d-c8e8462d9872

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
