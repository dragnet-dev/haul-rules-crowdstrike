// Dragnet [Ransomware]: dragnet-ransomware-2023-0177 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: e670d4d4-9bac-5ac5-b63e-0f8ecb610580

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
