// Dragnet [Ransomware]: dragnet-ransomware-2023-3067 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: abb92ccd-51fd-5059-8101-2ef3fe5bc697

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
