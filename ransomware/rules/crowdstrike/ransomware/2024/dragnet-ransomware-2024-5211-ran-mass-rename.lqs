// Dragnet [Ransomware]: dragnet-ransomware-2024-5211 — Mass File Rename (qiulong)
// Status: experimental | Level: high | ID: 867a16e5-bfb0-5858-bba4-a9320749d363

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
