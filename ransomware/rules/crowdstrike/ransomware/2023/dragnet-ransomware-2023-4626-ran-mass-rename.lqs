// Dragnet [Ransomware]: dragnet-ransomware-2023-4626 — Mass File Rename (stormous)
// Status: deprecated | Level: high | ID: 0f6ca4b7-226a-5d1b-85fc-6fa2b9126317

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
