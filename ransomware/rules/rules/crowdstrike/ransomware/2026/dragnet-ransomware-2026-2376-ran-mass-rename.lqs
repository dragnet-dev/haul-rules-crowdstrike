// Dragnet [Ransomware]: dragnet-ransomware-2026-2376 — Mass File Rename (SilentRansomGroup)
// Status: deprecated | Level: high | ID: 409eab94-170d-5540-a3e2-d48133ccdd12

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
