// Dragnet [Ransomware]: dragnet-ransomware-2025-4533 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 843c8764-cd0a-50d0-bfae-40180da216f2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
