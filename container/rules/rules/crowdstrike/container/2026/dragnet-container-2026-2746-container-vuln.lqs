// Dragnet [Container]: dragnet-container-2026-2746 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: b2114bc0-bfef-5a0b-bd1f-cc23d8865762

#event_simpleName=*
| (ImageFileName = *alpine edge:* OR ImageFileName = *chainguard:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
