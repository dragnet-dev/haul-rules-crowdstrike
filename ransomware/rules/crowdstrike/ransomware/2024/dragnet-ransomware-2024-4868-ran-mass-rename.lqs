// Dragnet [Ransomware]: dragnet-ransomware-2024-4868 — Mass File Rename (dAn0n)
// Status: experimental | Level: high | ID: 583cf1ba-e946-58c2-a849-c816bbb8bec3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
