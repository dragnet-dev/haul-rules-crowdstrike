// Dragnet [Ransomware]: dragnet-ransomware-2023-4026 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 95dc32c7-5ced-5d1a-b486-a428f1e0ff59

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
