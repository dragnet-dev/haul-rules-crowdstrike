// Dragnet [Ransomware]: dragnet-ransomware-2023-1351 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 2755ad1d-c8fb-5a8d-8c87-b913c6f356e7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
