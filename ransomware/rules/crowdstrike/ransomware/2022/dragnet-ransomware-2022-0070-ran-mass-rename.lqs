// Dragnet [Ransomware]: dragnet-ransomware-2022-0070 — Mass File Rename (vicesociety)
// Status: deprecated | Level: high | ID: 159eebce-0130-5b57-a385-ce0d81d87d13

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
