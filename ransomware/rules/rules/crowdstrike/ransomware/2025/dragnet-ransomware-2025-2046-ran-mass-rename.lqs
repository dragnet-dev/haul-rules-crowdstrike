// Dragnet [Ransomware]: dragnet-ransomware-2025-2046 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 4bb6365b-892a-54c4-9024-b71c1d55c9cb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
