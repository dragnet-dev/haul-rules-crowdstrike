// Dragnet [Ransomware]: dragnet-ransomware-2021-1156 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 975ee904-f5c6-5770-a93b-e401853937d2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
