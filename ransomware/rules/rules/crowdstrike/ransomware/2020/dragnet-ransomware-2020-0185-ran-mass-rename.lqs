// Dragnet [Ransomware]: dragnet-ransomware-2020-0185 — Mass File Rename (revil)
// Status: deprecated | Level: high | ID: 38f7cb44-39a1-54d7-80be-c512be6ba8f3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
