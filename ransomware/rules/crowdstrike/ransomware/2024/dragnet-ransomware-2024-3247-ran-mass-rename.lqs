// Dragnet [Ransomware]: dragnet-ransomware-2024-3247 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: d0cf8a05-2385-58f4-b848-01a6b488ba7d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
