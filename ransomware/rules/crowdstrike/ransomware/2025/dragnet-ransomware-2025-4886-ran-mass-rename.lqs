// Dragnet [Ransomware]: dragnet-ransomware-2025-4886 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 77e2e8ae-4d37-5295-9662-1a3511a28f8e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
