// Dragnet [Ransomware]: dragnet-ransomware-2021-0610 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 70e09783-43f8-52da-9245-9302dd73210e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
