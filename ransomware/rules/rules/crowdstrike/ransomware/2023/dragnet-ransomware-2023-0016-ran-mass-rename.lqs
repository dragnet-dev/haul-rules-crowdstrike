// Dragnet [Ransomware]: dragnet-ransomware-2023-0016 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: c3eaeb70-443f-520a-b43f-50871e3835ec

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
