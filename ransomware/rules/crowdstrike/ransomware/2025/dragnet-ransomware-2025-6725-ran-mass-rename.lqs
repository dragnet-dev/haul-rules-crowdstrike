// Dragnet [Ransomware]: dragnet-ransomware-2025-6725 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: d178b13f-dd60-5d5e-ba3e-79a1f4257d5b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
