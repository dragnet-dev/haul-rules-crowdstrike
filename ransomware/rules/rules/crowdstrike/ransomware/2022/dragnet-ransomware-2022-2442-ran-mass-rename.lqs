// Dragnet [Ransomware]: dragnet-ransomware-2022-2442 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 9e366a12-cbdd-5d2b-927e-d68792f12899

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
