// Dragnet [Ransomware]: dragnet-ransomware-2023-2814 — Mass File Rename (malas)
// Status: experimental | Level: high | ID: ea5818f4-a56d-5215-bb7e-8534daf96233

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
