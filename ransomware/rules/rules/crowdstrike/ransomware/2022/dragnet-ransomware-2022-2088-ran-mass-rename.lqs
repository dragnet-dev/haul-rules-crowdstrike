// Dragnet [Ransomware]: dragnet-ransomware-2022-2088 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 6b354231-2592-5574-b7df-d05be6fea995

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
