// Dragnet [Ransomware]: dragnet-ransomware-2025-2038 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 8b5cdc13-403b-5f6e-a014-4a75aaa0022d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
