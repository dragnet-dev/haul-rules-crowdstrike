// Dragnet [Ransomware]: dragnet-ransomware-2025-1248 — Mass File Rename (morpheus)
// Status: deprecated | Level: high | ID: 501da261-96d3-5923-af64-b995174242e1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
