// Dragnet [Ransomware]: dragnet-ransomware-2024-4373 — Mass File Rename (helldown)
// Status: experimental | Level: high | ID: 183a83ff-0ec1-5228-ab43-6e914fe08519

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
