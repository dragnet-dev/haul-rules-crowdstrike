// Dragnet [Ransomware]: dragnet-ransomware-2026-2928 — Mass File Rename (termite)
// Status: stable | Level: high | ID: cad53a21-cabd-5f44-acf7-57a5c8b9da57

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
