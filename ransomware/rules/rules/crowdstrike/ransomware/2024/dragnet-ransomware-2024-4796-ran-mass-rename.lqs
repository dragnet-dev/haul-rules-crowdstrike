// Dragnet [Ransomware]: dragnet-ransomware-2024-4796 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 649c54c0-055e-5483-97b7-18d604447b59

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
