// Dragnet [Ransomware]: dragnet-ransomware-2021-0146 — Mass File Rename (avoslocker)
// Status: deprecated | Level: high | ID: ed2c5ae9-7bfb-54ff-a43a-aa829fe20f12

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
