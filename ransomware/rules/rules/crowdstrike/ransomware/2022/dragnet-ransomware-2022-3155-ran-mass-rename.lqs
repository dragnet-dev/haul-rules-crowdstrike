// Dragnet [Ransomware]: dragnet-ransomware-2022-3155 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 163f7d89-196f-5dec-8b3f-b0482cb35826

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
