// Dragnet [Ransomware]: dragnet-ransomware-2026-0684 — Mass File Rename (nightspire)
// Status: deprecated | Level: high | ID: 5f39c18a-c300-52c6-8f5d-2ebf01d9c4e3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
