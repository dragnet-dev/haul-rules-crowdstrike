// Dragnet [Ransomware]: dragnet-ransomware-2025-5919 — Mass File Rename (sinobi)
// Status: experimental | Level: high | ID: 332a6d09-83a7-5c07-80e1-939ac4c660c8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
