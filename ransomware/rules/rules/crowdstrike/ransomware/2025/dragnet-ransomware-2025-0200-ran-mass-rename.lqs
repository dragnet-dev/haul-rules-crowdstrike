// Dragnet [Ransomware]: dragnet-ransomware-2025-0200 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: f341bc77-69c5-5a08-b7a3-f1d625712d7c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
