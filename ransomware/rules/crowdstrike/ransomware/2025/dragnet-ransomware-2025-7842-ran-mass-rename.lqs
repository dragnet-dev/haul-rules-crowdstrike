// Dragnet [Ransomware]: dragnet-ransomware-2025-7842 — Mass File Rename (apos)
// Status: experimental | Level: high | ID: 30307905-3a3f-5bee-90e1-1466be2d4546

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
