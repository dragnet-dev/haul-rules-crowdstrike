// Dragnet [Container]: dragnet-container-2026-0109 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 0fdff7a1-810e-5aee-a02c-4f65a594bbf5

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:7* OR ImageFileName = *debian:8* OR ImageFileName = *debian:9* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:16.04* OR ImageFileName = *ubuntu:16.04-ESM* OR ImageFileName = *ubuntu:18.04* OR ImageFileName = *ubuntu:18.04-ESM* OR ImageFileName = *ubuntu:18.10*)
| table([timestamp, ComputerName])
| limit(1000)
