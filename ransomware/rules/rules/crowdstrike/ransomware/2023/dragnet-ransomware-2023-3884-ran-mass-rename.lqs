// Dragnet [Ransomware]: dragnet-ransomware-2023-3884 — Mass File Rename (nokoyawa)
// Status: experimental | Level: high | ID: 7fbcb3e0-2f49-5258-b29e-79cb217d99a1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
