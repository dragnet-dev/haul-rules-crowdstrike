// Dragnet [Ransomware]: dragnet-ransomware-2023-2197 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 3c5c9f20-2eaf-5010-a81e-b1e5a45a2704

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
