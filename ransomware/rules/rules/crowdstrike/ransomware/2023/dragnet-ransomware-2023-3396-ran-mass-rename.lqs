// Dragnet [Ransomware]: dragnet-ransomware-2023-3396 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: f73899d2-b87f-554b-8107-2662a6d0d3f4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
