// Dragnet [Ransomware]: dragnet-ransomware-2026-2930 — Mass File Rename (dragonforce)
// Status: stable | Level: high | ID: d4915faf-0388-5018-93a2-193bfa39d179

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
