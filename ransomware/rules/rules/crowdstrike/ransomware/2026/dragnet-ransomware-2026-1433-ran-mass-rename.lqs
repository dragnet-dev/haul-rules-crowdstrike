// Dragnet [Ransomware]: dragnet-ransomware-2026-1433 — Mass File Rename (atomsilo)
// Status: stable | Level: high | ID: 33338684-fbf7-580c-ac09-04e28c561a34

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
