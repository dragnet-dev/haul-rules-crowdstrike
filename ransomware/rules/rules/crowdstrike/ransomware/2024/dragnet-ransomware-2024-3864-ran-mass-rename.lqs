// Dragnet [Ransomware]: dragnet-ransomware-2024-3864 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 3371bb41-8959-5a1e-bb0a-4c7e095871d1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
