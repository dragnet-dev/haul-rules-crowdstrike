// Dragnet [Ransomware]: dragnet-ransomware-2025-6182 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: c20e122f-ec55-5852-bca2-4fd7ed195ff6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
