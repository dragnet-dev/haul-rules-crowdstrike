// Dragnet [Ransomware]: dragnet-ransomware-2025-5754 — Mass File Rename (kairos)
// Status: experimental | Level: high | ID: da05adee-e3cd-53f3-a75f-932628e58fa3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
