// Dragnet [Ransomware]: dragnet-ransomware-2022-0861 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: b32fa844-b7d5-57fc-a3eb-0e70a7415841

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
