// Dragnet [Ransomware]: dragnet-ransomware-2026-0591 — Mass File Rename (shinyhunters)
// Status: deprecated | Level: high | ID: 92544132-5906-5763-848b-717d8a6cdcef

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
