// Dragnet [Ransomware]: dragnet-ransomware-2025-4885 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: 3f79b3b2-41e4-531f-a667-ac89724951dc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
