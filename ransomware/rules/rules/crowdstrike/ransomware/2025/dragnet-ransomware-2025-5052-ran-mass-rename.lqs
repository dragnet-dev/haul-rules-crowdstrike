// Dragnet [Ransomware]: dragnet-ransomware-2025-5052 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: e89fc5b9-0f6e-5f52-b64a-4da78d96b5c6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
