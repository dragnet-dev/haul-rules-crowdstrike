// Dragnet [Ransomware]: dragnet-ransomware-2022-1751 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 693ebe26-d11d-539f-ad83-22d796a180ea

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
