// Dragnet [Ransomware]: dragnet-ransomware-2023-4141 — Mass File Rename (trigona)
// Status: deprecated | Level: high | ID: c6c09f4a-0b28-503f-949a-0f428be4ef59

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
