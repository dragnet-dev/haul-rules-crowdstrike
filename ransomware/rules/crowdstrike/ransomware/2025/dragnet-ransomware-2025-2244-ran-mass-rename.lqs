// Dragnet [Ransomware]: dragnet-ransomware-2025-2244 — Mass File Rename (sinobi)
// Status: experimental | Level: high | ID: d6c5b33b-b801-55f2-a36b-59dae1c4b6cc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
