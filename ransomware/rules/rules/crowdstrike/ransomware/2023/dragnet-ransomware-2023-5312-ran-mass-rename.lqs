// Dragnet [Ransomware]: dragnet-ransomware-2023-5312 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: bb55054b-0614-5197-94f7-5c4f051d84b8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
