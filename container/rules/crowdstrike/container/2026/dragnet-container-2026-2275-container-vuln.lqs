// Status: deprecated | Level: high | ID: a8bedf74-49b2-5ee9-9d48-19007b96ba3b

#event_simpleName=*
| (ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *oraclelinux:7* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:14.04* OR ImageFileName = *ubuntu:14.10* OR ImageFileName = *ubuntu:15.04*)
| table([timestamp, ComputerName])
| limit(1000)
