// Dragnet [Ransomware]: dragnet-ransomware-2023-0849 — Mass File Rename (losttrust)
// Status: deprecated | Level: high | ID: 218c2b71-0590-5247-873d-e388c015577d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
