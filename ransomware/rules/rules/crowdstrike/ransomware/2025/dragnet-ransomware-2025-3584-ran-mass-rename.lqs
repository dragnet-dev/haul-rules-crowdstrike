// Dragnet [Ransomware]: dragnet-ransomware-2025-3584 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 10005550-bbc8-52de-bdd9-1319a56b8d9b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
