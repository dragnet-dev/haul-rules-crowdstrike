// Dragnet [Ransomware]: dragnet-ransomware-2021-0512 — Mass File Rename (spook)
// Status: deprecated | Level: high | ID: df06e03f-be73-52a5-be2d-ce2da92aeb86

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
