// Dragnet [Ransomware]: dragnet-ransomware-2025-6326 — Mass File Rename (kairos)
// Status: experimental | Level: high | ID: 91f31815-8c17-51da-ac61-b71c905e2c52

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
