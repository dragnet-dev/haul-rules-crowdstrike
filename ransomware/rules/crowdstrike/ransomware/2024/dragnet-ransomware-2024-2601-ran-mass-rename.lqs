// Dragnet [Ransomware]: dragnet-ransomware-2024-2601 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: aa618398-79ae-5418-ac36-78e51f5dca52

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
