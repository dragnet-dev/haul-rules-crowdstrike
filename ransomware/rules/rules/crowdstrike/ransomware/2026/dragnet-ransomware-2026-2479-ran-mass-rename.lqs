// Dragnet [Ransomware]: dragnet-ransomware-2026-2479 — Mass File Rename (fulcrumsec)
// Status: stable | Level: high | ID: 8afad478-db13-5755-8cf5-57ad6cb6ac3e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
