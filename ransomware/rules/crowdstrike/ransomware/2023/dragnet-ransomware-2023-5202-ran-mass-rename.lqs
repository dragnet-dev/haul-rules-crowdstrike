// Dragnet [Ransomware]: dragnet-ransomware-2023-5202 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: aac6cb2f-ac43-5fbd-83d9-0eae822e23e0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
