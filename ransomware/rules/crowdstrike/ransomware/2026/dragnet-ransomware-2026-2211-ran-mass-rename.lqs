// Dragnet [Ransomware]: dragnet-ransomware-2026-2211 — Mass File Rename (thegentlemen)
// Status: deprecated | Level: high | ID: b6774f41-f6ed-5f62-9d0d-d440e26d73a6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
