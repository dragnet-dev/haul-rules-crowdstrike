// Dragnet [Ransomware]: dragnet-ransomware-2022-1605 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 22e8f2e6-108b-5691-a061-f56f4dbd5ee6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
