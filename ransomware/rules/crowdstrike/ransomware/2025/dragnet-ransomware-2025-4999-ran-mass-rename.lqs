// Dragnet [Ransomware]: dragnet-ransomware-2025-4999 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 122195d4-3df1-5dca-9598-2a3fd36caf7a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
