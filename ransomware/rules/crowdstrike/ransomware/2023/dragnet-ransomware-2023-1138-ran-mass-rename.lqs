// Dragnet [Ransomware]: dragnet-ransomware-2023-1138 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 3c154a1e-978f-5919-93bd-2e46b333e298

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
