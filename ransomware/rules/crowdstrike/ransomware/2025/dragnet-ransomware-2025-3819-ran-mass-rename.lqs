// Dragnet [Ransomware]: dragnet-ransomware-2025-3819 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: c79374d7-0785-576a-be45-7464918e9f88

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
