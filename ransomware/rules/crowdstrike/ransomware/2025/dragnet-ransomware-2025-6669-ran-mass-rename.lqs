// Dragnet [Ransomware]: dragnet-ransomware-2025-6669 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: d6f034f7-e2dc-55a7-9531-558b627de9b3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
