// Dragnet [Ransomware]: dragnet-ransomware-2025-6455 — Mass File Rename (benzona)
// Status: deprecated | Level: high | ID: 2cbfc83c-6cc7-5ae7-911c-ba03ff22793d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
