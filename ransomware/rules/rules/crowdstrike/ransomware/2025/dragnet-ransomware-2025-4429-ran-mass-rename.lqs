// Dragnet [Ransomware]: dragnet-ransomware-2025-4429 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: e4b36a79-d535-5b41-a300-a32e65b026cd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
