// Dragnet [Ransomware]: dragnet-ransomware-2023-1460 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 86590aac-4969-551c-8bd9-54f334eaffde

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
