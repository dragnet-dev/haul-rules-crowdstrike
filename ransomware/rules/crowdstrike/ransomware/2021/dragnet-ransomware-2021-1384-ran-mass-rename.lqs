// Dragnet [Ransomware]: dragnet-ransomware-2021-1384 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 2f7a4dfa-ea73-557f-bf7a-322be5575d5e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
