// Dragnet [Ransomware]: dragnet-ransomware-2024-2536 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 6057b6bd-51df-50e4-a0ce-14c916bee99f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
