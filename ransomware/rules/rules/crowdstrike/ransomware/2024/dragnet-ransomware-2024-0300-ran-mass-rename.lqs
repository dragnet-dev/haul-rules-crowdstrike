// Dragnet [Ransomware]: dragnet-ransomware-2024-0300 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: e43fa2e1-8135-5078-9288-50ec27f9cfe7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
