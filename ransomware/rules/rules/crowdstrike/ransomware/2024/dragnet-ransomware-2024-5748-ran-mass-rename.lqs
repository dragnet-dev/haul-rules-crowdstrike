// Dragnet [Ransomware]: dragnet-ransomware-2024-5748 — Mass File Rename (dragonforce)
// Status: deprecated | Level: high | ID: a2f3cf29-14e8-5a8b-8611-744149135c18

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
