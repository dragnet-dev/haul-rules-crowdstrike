// Dragnet [Ransomware]: dragnet-ransomware-2021-0585 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 5291edab-e2a6-58db-a3f0-430191354a3d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
