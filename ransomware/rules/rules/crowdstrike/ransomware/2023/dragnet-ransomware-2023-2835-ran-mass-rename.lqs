// Dragnet [Ransomware]: dragnet-ransomware-2023-2835 — Mass File Rename (malas)
// Status: experimental | Level: high | ID: 8e9b8a8f-bf73-5c66-b995-dc4735cd1e37

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
