// Dragnet [Ransomware]: dragnet-ransomware-2023-2729 — Mass File Rename (stormous)
// Status: experimental | Level: high | ID: a33e4861-c86c-5345-bd94-a508ae2a800d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
