// Dragnet [Ransomware]: dragnet-ransomware-2021-1430 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: ffc86027-1f5f-5d53-849b-0eb1d025a335

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
