// Dragnet [Ransomware]: dragnet-ransomware-2025-2286 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 12fffe59-d919-5645-a43b-14fded8ceee9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
