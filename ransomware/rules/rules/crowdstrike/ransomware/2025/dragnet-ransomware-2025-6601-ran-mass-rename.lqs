// Dragnet [Ransomware]: dragnet-ransomware-2025-6601 — Mass File Rename (spacebears)
// Status: experimental | Level: high | ID: 7d8c5736-d5f1-5aa7-9797-d687bda1e26b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
