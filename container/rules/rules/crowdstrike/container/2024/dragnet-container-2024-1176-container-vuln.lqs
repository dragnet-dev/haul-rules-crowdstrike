// Dragnet [Container]: dragnet-container-2024-1176 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: fe58ea07-7d2b-5ee2-b498-3c5a3701d6aa

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *ubuntu:20.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
