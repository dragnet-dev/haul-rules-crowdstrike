// Dragnet [Ransomware]: dragnet-ransomware-2020-0080 — Mass File Rename (maze)
// Status: deprecated | Level: high | ID: 89f0e6f8-8be2-53cf-af53-bfb6ca8e4326

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
