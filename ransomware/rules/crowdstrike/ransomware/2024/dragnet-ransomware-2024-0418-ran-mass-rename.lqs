// Dragnet [Ransomware]: dragnet-ransomware-2024-0418 — Mass File Rename (spacebears)
// Status: experimental | Level: high | ID: 651035e9-a3cc-545f-b4e8-7b256e8ddbc1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
