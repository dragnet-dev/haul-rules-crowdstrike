// Dragnet [Ransomware]: dragnet-ransomware-2025-1581 — Mass File Rename (SilentRansomGroup)
// Status: deprecated | Level: high | ID: f44d5689-adc7-5b82-b06c-5aae71f3ffa5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
