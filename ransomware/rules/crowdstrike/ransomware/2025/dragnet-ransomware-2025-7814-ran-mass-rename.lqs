// Dragnet [Ransomware]: dragnet-ransomware-2025-7814 — Mass File Rename (sinobi)
// Status: experimental | Level: high | ID: 6988562a-3728-5f2c-840f-668e5ee14622

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
