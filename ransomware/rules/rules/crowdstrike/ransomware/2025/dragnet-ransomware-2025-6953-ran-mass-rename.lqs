// Dragnet [Ransomware]: dragnet-ransomware-2025-6953 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 1936b68c-7a6b-544b-a982-aae888511c41

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
