// Dragnet [Ransomware]: dragnet-ransomware-2025-3219 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 80dc77af-a1f7-5574-8e21-407dde1343f7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
