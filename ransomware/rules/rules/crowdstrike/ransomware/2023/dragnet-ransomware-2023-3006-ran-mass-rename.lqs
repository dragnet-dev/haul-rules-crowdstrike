// Dragnet [Ransomware]: dragnet-ransomware-2023-3006 — Mass File Rename (dunghill)
// Status: experimental | Level: high | ID: f70ceee0-3803-57a3-9ca2-9acd666e2134

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
