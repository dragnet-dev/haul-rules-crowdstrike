// Dragnet [Container]: dragnet-container-2024-0048 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 90f1388c-9e6f-588e-babb-bc54ccaec276

#event_simpleName=*
| (ImageFileName = *alpine:3.4* OR ImageFileName = *alpine:3.5* OR ImageFileName = *alpine:3.6* OR ImageFileName = *alpine:3.7* OR ImageFileName = *amazonlinux:1* OR ImageFileName = *amazonlinux:2* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:9* OR ImageFileName = *ubuntu:16.04* OR ImageFileName = *ubuntu:16.04-ESM* OR ImageFileName = *ubuntu:17.10*)
| table([timestamp, ComputerName])
| limit(1000)
