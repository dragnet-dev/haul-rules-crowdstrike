// Dragnet [Container]: dragnet-container-2025-0244 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: e8b04fd3-c9a0-5345-adc0-5826f3953576

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
