// Dragnet [Ransomware]: dragnet-ransomware-2025-7354 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: ac985af3-3042-5c5e-ae3a-1aef44759a7f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
