// Dragnet [Ransomware]: dragnet-ransomware-2023-0058 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: d83c9af7-4239-5ee3-973f-da96b91a75b7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
