// Dragnet [Ransomware]: dragnet-ransomware-2022-1901 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: c1830d90-97db-5cd4-91a2-7badf824dc9e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
