// Dragnet [Ransomware]: dragnet-ransomware-2026-3037 — Mass File Rename (lockbit5)
// Status: stable | Level: high | ID: 313b2da7-ee5d-5055-9bb0-4a4a5bb89b54

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
