// Dragnet [Ransomware]: dragnet-ransomware-2022-3063 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 53412007-51e8-54c4-8a75-27393f33dea6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
