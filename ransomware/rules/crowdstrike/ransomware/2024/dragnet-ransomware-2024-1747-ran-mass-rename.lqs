// Dragnet [Ransomware]: dragnet-ransomware-2024-1747 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: 1481dd0e-1327-572c-ae82-930ef3900686

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
