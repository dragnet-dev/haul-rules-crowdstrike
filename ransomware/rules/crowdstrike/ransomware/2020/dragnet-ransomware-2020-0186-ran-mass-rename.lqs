// Dragnet [Ransomware]: dragnet-ransomware-2020-0186 — Mass File Rename (maze)
// Status: deprecated | Level: high | ID: 7094bdb6-779a-55d9-a57f-7a71ebb48ffd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
