// Dragnet [Ransomware]: dragnet-ransomware-2025-7819 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: e73f6783-8c96-5a48-abc8-46b6a3721bc0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
