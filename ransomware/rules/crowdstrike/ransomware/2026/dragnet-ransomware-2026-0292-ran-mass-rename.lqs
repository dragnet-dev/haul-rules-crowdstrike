// Dragnet [Ransomware]: dragnet-ransomware-2026-0292 — Mass File Rename (medusalocker)
// Status: stable | Level: high | ID: 4cc403a2-72e3-5095-b639-685f469ad787

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
