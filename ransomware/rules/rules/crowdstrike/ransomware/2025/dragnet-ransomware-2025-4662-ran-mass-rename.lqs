// Dragnet [Ransomware]: dragnet-ransomware-2025-4662 — Mass File Rename (spacebears)
// Status: experimental | Level: high | ID: 017580f0-8c19-5e34-bf68-ecb8fafd9fce

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
