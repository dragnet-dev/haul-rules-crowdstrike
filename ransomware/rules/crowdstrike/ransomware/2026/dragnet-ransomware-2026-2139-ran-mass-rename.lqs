// Dragnet [Ransomware]: dragnet-ransomware-2026-2139 — Mass File Rename (dragonforce)
// Status: stable | Level: high | ID: c2423372-f9ee-5481-9fb2-91d3987e1adf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
