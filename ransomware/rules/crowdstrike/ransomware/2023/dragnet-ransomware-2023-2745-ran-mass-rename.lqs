// Dragnet [Ransomware]: dragnet-ransomware-2023-2745 — Mass File Rename (malas)
// Status: experimental | Level: high | ID: 655b7c2e-fc4d-566c-b58a-af19a5af35e8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
