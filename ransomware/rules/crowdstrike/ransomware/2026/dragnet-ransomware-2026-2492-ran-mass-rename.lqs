// Dragnet [Ransomware]: dragnet-ransomware-2026-2492 — Mass File Rename (everest)
// Status: stable | Level: high | ID: 0fdaddc0-b887-567b-93c2-b6a1337f68d3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
