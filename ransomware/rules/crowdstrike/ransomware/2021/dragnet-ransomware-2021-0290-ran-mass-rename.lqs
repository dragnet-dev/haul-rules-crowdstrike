// Dragnet [Ransomware]: dragnet-ransomware-2021-0290 — Mass File Rename (macaw)
// Status: deprecated | Level: high | ID: 82ac90d0-bb75-5f40-a64a-1ade35b339e4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
