// Dragnet [Ransomware]: dragnet-ransomware-2024-1881 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: 11e43e9a-c743-519c-bb72-29c665a7affd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
