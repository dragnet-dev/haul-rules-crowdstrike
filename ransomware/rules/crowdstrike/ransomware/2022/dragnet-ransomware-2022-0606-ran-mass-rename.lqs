// Dragnet [Ransomware]: dragnet-ransomware-2022-0606 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: eafc66fb-b3ac-5d3e-822d-6c542229d670

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
