// Dragnet [Ransomware]: dragnet-ransomware-2025-6861 — Mass File Rename (blackshrantac)
// Status: experimental | Level: high | ID: f266146e-38b4-560c-b18d-aa78fe0b06bd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
