// Dragnet [Container]: dragnet-container-2026-0990 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: dd9467d3-ef51-59c9-ad07-7184dda9353a

#event_simpleName=*
| (ImageFileName = *alpine edge:* OR ImageFileName = *chainguard:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
