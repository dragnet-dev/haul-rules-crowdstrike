// Dragnet [Ransomware]: dragnet-ransomware-2026-0780 — Mass File Rename (safepay)
// Status: stable | Level: high | ID: 00a37862-490f-5d12-9717-ed1f217330e2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
