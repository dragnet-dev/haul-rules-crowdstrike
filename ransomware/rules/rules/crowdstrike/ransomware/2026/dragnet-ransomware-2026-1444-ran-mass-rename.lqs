// Dragnet [Ransomware]: dragnet-ransomware-2026-1444 — Mass File Rename (dragonforce)
// Status: stable | Level: high | ID: 11243f1a-772f-51eb-bdb5-e1a88395328c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
