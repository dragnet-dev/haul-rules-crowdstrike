// Dragnet [Ransomware]: dragnet-ransomware-2024-2496 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 112691e4-8615-50fa-8fe8-3ee23cb87791

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
