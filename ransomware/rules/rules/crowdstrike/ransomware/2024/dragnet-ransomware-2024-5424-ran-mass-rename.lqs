// Dragnet [Ransomware]: dragnet-ransomware-2024-5424 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 43157217-03f3-51fa-8841-1f03e5414248

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
