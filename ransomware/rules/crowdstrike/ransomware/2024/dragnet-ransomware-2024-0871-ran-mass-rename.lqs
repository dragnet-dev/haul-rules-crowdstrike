// Dragnet [Ransomware]: dragnet-ransomware-2024-0871 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 768e1409-6907-5754-ab90-b8e58ed6b8b0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
