// Dragnet [Ransomware]: dragnet-ransomware-2024-3855 — Mass File Rename (frag)
// Status: deprecated | Level: high | ID: ccc69605-6274-51f2-a6e9-c2649874e6a7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
