// Dragnet [Ransomware]: dragnet-ransomware-2025-1564 — Mass File Rename (incransom)
// Status: test | Level: high | ID: 1dea3e3a-c113-58a5-98fe-26995e2b9fc5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
