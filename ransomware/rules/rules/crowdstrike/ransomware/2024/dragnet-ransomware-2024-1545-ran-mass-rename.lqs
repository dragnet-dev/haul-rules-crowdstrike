// Dragnet [Ransomware]: dragnet-ransomware-2024-1545 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: dbebc658-3772-5edf-92af-abd08f887bd8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
