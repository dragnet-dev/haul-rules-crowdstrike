// Dragnet [Ransomware]: dragnet-ransomware-2023-2990 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: eba4e9d4-a65f-56d5-86fa-7d4be3bb811d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
