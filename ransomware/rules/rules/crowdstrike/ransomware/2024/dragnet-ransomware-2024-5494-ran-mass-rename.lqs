// Dragnet [Ransomware]: dragnet-ransomware-2024-5494 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 415f3a09-e463-51e8-b28d-fbcac8d44108

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
