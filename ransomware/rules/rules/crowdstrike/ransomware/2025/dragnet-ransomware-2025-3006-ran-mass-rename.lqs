// Dragnet [Ransomware]: dragnet-ransomware-2025-3006 — Mass File Rename (payoutsking)
// Status: experimental | Level: high | ID: d18c32c5-07cd-5605-9016-ab5098ebe779

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
