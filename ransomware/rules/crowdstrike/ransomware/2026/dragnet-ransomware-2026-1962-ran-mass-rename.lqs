// Dragnet [Ransomware]: dragnet-ransomware-2026-1962 — Mass File Rename (nightspire)
// Status: deprecated | Level: high | ID: 377ae461-91a6-5b12-88d2-48847635e4ff

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
