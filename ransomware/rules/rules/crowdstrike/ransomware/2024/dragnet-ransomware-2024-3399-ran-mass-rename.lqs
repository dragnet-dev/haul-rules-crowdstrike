// Dragnet [Ransomware]: dragnet-ransomware-2024-3399 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: 30583063-a790-5987-ac97-397010dcb391

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
