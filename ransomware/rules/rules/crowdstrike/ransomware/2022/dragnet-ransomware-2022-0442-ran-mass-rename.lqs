// Dragnet [Ransomware]: dragnet-ransomware-2022-0442 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 673de9ea-17e9-585d-b8be-7b611cda1091

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
