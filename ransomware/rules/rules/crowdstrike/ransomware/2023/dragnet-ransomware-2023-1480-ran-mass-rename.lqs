// Dragnet [Ransomware]: dragnet-ransomware-2023-1480 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 8145858f-9708-505b-b049-1c79aba30200

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
