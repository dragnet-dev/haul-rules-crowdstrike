// Dragnet [Ransomware]: dragnet-ransomware-2024-4066 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 87acd94d-6d9e-5f88-b1f2-b7de1715cec9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
