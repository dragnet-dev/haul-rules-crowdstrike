// Dragnet [Ransomware]: dragnet-ransomware-2025-0051 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 6f6c30d0-2db2-56d3-9b29-b6fee0e00244

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
