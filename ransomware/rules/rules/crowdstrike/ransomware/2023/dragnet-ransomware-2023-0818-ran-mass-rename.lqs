// Dragnet [Ransomware]: dragnet-ransomware-2023-0818 — Mass File Rename (ransomhouse)
// Status: experimental | Level: high | ID: cf6a62fc-4664-5c41-9613-563910e55eab

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
