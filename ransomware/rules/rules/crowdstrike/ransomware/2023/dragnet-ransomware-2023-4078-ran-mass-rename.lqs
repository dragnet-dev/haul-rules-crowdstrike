// Dragnet [Ransomware]: dragnet-ransomware-2023-4078 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: eeb31c0c-1a42-5c74-94bc-a0c7d040e172

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
