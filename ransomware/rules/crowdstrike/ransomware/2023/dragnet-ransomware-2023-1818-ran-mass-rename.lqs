// Dragnet [Ransomware]: dragnet-ransomware-2023-1818 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 59b2c2fe-cdb0-5e9b-bac6-a2d7ea781e19

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
