// Dragnet [Ransomware]: dragnet-ransomware-2023-4808 — Mass File Rename (ransomed)
// Status: deprecated | Level: high | ID: 1fdc51f8-da0f-52cf-b50f-e79f7a1ec586

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
