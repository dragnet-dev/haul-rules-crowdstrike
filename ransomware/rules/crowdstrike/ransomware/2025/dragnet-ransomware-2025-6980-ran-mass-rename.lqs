// Dragnet [Ransomware]: dragnet-ransomware-2025-6980 — Mass File Rename (securotrop)
// Status: experimental | Level: high | ID: 780061f2-b42b-5a68-a6a4-e93a92f38a37

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
