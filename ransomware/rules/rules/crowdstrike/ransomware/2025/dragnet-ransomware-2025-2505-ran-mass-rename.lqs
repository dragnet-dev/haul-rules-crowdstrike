// Dragnet [Ransomware]: dragnet-ransomware-2025-2505 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: fbe6b75b-a3af-532e-bf99-7dfdb8116918

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
