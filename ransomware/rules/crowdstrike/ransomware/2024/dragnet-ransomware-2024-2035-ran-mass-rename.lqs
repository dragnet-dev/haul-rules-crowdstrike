// Dragnet [Ransomware]: dragnet-ransomware-2024-2035 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: a3f0bc1c-6da3-559f-b5bc-dfb317bb35df

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
