// Dragnet [Ransomware]: dragnet-ransomware-2025-3272 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 93d1eed5-8a06-5d47-94f9-afc728f567d8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
