// Dragnet [Ransomware]: dragnet-ransomware-2021-1189 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 8d57464d-2b17-557e-9b4d-885773a640a0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
