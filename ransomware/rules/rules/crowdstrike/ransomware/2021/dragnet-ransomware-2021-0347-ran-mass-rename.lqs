// Dragnet [Ransomware]: dragnet-ransomware-2021-0347 — Mass File Rename (lv)
// Status: deprecated | Level: high | ID: 0c23d746-3f2b-5ac8-9a3c-68604ad47a93

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
