// Dragnet [Ransomware]: dragnet-ransomware-2023-1386 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 9538ed58-1145-560e-a223-832b1d9e3f76

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
