// Dragnet [Ransomware]: dragnet-ransomware-2024-1089 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 9632057b-1970-5789-af9f-2741e443945a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
