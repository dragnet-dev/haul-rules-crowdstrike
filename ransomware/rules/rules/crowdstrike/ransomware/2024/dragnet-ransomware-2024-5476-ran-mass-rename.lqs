// Dragnet [Ransomware]: dragnet-ransomware-2024-5476 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 55312f32-8fff-55c8-9669-eacfd349a7eb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
