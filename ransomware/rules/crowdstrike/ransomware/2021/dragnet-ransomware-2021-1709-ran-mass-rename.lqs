// Dragnet [Ransomware]: dragnet-ransomware-2021-1709 — Mass File Rename (everest)
// Status: deprecated | Level: high | ID: 07b8d1f4-82f0-5d60-985c-d67c1852a1af

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
