// Dragnet [Ransomware]: dragnet-ransomware-2026-3047 — Mass File Rename (genesis)
// Status: stable | Level: high | ID: 3165e76f-2ae4-54bd-8cd0-f1351540e4a1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
