// Dragnet [Ransomware]: dragnet-ransomware-2025-2883 — Mass File Rename (pear)
// Status: experimental | Level: high | ID: e13975cd-788b-57e0-ac4d-71814b6c2db9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
