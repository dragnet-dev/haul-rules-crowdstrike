// Dragnet [Ransomware]: dragnet-ransomware-2024-4728 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: 7cc18fc6-1228-5288-ac96-6dbf42eec857

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
