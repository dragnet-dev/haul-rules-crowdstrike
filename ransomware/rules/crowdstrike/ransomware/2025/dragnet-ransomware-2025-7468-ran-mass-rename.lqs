// Dragnet [Ransomware]: dragnet-ransomware-2025-7468 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: 82a7f5d0-b2ad-5805-9781-9d74ffc1957f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
