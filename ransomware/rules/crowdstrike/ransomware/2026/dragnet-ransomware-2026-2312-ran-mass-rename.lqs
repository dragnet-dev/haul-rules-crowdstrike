// Dragnet [Ransomware]: dragnet-ransomware-2026-2312 — Mass File Rename (nightspire)
// Status: deprecated | Level: high | ID: 211b35fc-c43f-5b6d-9e9e-3efeb1cdef4a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
