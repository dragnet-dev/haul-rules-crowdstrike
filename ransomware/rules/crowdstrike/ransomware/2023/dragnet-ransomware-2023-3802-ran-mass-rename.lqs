// Dragnet [Ransomware]: dragnet-ransomware-2023-3802 — Mass File Rename (arvinclub)
// Status: deprecated | Level: high | ID: a71ec95f-5136-5876-b8a9-8a7b56cbbb8e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
