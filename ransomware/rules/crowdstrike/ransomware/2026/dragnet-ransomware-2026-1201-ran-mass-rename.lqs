// Dragnet [Ransomware]: dragnet-ransomware-2026-1201 — Mass File Rename (thegentlemen)
// Status: deprecated | Level: high | ID: 8945d5e8-7ec8-5e1a-8dc2-4e9624bf1102

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
