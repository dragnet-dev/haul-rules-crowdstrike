// Dragnet [Ransomware]: dragnet-ransomware-2021-0273 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 246c9a50-5d32-5ea3-bd6b-300dc5f895c1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
