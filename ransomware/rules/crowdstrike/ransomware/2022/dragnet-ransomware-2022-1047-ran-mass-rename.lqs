// Dragnet [Ransomware]: dragnet-ransomware-2022-1047 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 396b4469-6c67-56f7-8f53-04e796b67dff

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
