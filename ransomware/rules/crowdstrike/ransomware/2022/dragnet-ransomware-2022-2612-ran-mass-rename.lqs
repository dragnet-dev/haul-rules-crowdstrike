// Dragnet [Ransomware]: dragnet-ransomware-2022-2612 — Mass File Rename (royal)
// Status: deprecated | Level: high | ID: 438c1d16-bd68-53e2-a639-4123d086c6f8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
