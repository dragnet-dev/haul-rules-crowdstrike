// Dragnet [Container]: dragnet-container-2025-0035 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 1a616247-cb3f-5697-b8d7-ac6fef3df537

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *redhat/ubi9:*)
| table([timestamp, ComputerName])
| limit(1000)
