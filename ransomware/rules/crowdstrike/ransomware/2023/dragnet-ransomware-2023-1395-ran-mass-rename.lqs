// Dragnet [Ransomware]: dragnet-ransomware-2023-1395 — Mass File Rename (knight)
// Status: deprecated | Level: high | ID: 5979f6e4-5d98-523d-b37a-b867ebef01dc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
