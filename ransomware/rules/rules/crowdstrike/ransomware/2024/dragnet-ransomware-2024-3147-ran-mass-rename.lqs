// Dragnet [Ransomware]: dragnet-ransomware-2024-3147 — Mass File Rename (BrainCipher)
// Status: experimental | Level: high | ID: 6af89d0d-9b5c-5167-984a-1b5eba47b905

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
