// Dragnet [Ransomware]: dragnet-ransomware-2022-1990 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: b44e207e-2994-5a3b-a8ca-aa2cffd77cfe

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
