// Dragnet [Ransomware]: dragnet-ransomware-2021-0992 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 053e1c77-2fd5-58ce-aab0-60c4b10a6d7d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
