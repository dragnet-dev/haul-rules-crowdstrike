// Dragnet [Ransomware]: dragnet-ransomware-2022-3065 — Mass File Rename (avoslocker)
// Status: deprecated | Level: high | ID: de3b58e7-5359-51a8-9112-03860f7fd846

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
