// Dragnet [Ransomware]: dragnet-ransomware-2025-3377 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 5373433e-728c-575d-a722-94d862ad8812

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
