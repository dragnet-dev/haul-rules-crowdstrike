// Dragnet [Ransomware]: dragnet-ransomware-2025-4222 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: bac98173-20af-5ddf-a5a2-69cb64bdeaa3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
