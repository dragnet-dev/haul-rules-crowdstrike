// Dragnet [Ransomware]: dragnet-ransomware-2024-2665 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 3cca7ed1-3764-5609-aa55-8ba9b1916352

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
