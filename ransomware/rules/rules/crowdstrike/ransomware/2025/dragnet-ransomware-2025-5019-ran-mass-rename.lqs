// Dragnet [Ransomware]: dragnet-ransomware-2025-5019 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 0f7c0532-7a87-5233-b805-0d5a4e700d4a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
