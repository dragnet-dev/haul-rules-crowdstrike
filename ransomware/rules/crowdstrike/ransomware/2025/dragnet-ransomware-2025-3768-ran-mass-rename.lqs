// Dragnet [Ransomware]: dragnet-ransomware-2025-3768 — Mass File Rename (direwolf)
// Status: experimental | Level: high | ID: 5da1cac8-1e17-5d12-ba5f-022001166f31

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
