// Dragnet [Ransomware]: dragnet-ransomware-2022-3126 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: c930d13f-4aa0-5d22-acb7-d2da7b5f63c5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
