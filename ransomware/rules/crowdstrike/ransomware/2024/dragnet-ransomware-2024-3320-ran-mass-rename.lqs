// Dragnet [Ransomware]: dragnet-ransomware-2024-3320 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: efc0de18-25d1-5a97-9ba0-27cbe89faf6c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
