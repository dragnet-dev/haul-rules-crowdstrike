// Dragnet [Ransomware]: dragnet-ransomware-2022-2713 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: 174ef2ea-69d1-5ffd-8153-f72d1ca32f91

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
