// Dragnet [Ransomware]: dragnet-ransomware-2026-0844 — Mass File Rename (nightspire)
// Status: deprecated | Level: high | ID: de6f72e2-a085-5590-add4-4d428a61568e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
