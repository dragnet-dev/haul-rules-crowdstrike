// Dragnet [Ransomware]: dragnet-ransomware-2022-1551 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: bad07442-7775-53e6-83a7-58a186cb894b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
