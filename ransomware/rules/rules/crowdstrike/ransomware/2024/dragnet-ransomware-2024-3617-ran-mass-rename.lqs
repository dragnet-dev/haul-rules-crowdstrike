// Dragnet [Ransomware]: dragnet-ransomware-2024-3617 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 240e8f1b-e969-5109-a080-b6fe6d4ea68d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
