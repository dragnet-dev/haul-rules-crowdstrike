// Dragnet [Ransomware]: dragnet-ransomware-2025-0350 — Mass File Rename (skira)
// Status: experimental | Level: high | ID: 2a1446a1-4826-561b-9f96-375389d50db4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
