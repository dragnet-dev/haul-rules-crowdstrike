// Dragnet [Ransomware]: dragnet-ransomware-2024-5608 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: 38266c0f-3bee-5569-9e0d-18a2a67774a1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
