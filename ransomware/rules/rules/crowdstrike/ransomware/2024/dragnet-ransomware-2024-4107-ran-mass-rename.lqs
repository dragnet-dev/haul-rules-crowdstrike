// Dragnet [Ransomware]: dragnet-ransomware-2024-4107 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: e9423ef5-f23c-54a9-84a5-5bcfc32f6cf0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
