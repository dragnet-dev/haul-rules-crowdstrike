// Dragnet [Ransomware]: dragnet-ransomware-2026-3346 — Mass File Rename (ALP-001)
// Status: stable | Level: high | ID: 1f303679-d4d9-578a-bc51-f642404b2404

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
