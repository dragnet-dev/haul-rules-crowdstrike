// Dragnet [Ransomware]: dragnet-ransomware-2025-3617 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 44909831-dde4-5c73-a265-2296dffffd59

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
