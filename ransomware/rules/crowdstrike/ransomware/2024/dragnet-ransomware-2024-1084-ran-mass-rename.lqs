// Dragnet [Ransomware]: dragnet-ransomware-2024-1084 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 64134945-5338-5122-9daa-cdd0b9b3df9f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
