// Dragnet [Ransomware]: dragnet-ransomware-2022-0171 — Mass File Rename (ragnarlocker)
// Status: deprecated | Level: high | ID: 598f03ae-7b3f-5c36-a304-3c0a60ce000c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
