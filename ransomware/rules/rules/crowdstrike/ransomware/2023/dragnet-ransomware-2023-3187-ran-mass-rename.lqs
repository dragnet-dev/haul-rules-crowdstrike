// Dragnet [Ransomware]: dragnet-ransomware-2023-3187 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: c8ecff2c-2e64-5aab-a431-0068180de4a3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
