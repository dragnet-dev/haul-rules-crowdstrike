// Dragnet [Ransomware]: dragnet-ransomware-2025-0508 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: de852118-b7b3-59de-8e94-5e9030a51b6c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
