// Dragnet [Ransomware]: dragnet-ransomware-2023-1196 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 6597f237-8dd1-5f95-8c27-02241226cb08

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
