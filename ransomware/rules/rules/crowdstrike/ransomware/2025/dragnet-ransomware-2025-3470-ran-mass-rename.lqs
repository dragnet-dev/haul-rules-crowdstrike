// Dragnet [Ransomware]: dragnet-ransomware-2025-3470 — Mass File Rename (crypto24)
// Status: deprecated | Level: high | ID: b8670f70-935f-5f1f-b791-c9cf3fdec2b9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
