// Dragnet [Ransomware]: dragnet-ransomware-2024-4642 — Mass File Rename (sarcoma)
// Status: experimental | Level: high | ID: 62f95392-3bd0-5c48-9c3f-2b2079041265

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
