// Dragnet [Ransomware]: dragnet-ransomware-2025-6603 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: 70774c96-82c5-527c-b04c-994568ce5ba8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
