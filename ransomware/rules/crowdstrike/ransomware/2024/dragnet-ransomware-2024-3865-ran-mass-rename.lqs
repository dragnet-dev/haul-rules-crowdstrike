// Dragnet [Ransomware]: dragnet-ransomware-2024-3865 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: 96e3fa91-246b-51e2-b6be-51a7edee398e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
