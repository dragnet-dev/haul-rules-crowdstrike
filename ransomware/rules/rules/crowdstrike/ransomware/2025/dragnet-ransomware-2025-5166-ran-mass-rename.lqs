// Dragnet [Ransomware]: dragnet-ransomware-2025-5166 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: ef451efa-1647-5196-a42d-f11b1c323a9a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
