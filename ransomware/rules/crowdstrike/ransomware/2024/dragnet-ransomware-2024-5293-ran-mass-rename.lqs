// Dragnet [Ransomware]: dragnet-ransomware-2024-5293 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 56ac3ac2-66f0-51ea-9d29-88bd09c2969f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
