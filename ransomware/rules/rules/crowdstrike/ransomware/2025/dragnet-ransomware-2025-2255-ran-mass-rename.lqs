// Dragnet [Ransomware]: dragnet-ransomware-2025-2255 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: b2e18568-0540-5f83-8fcc-8b2f20934749

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
