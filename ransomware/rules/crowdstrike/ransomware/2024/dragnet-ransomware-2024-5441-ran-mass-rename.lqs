// Dragnet [Ransomware]: dragnet-ransomware-2024-5441 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 95460281-d174-504a-8f02-dcadabe463bd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
