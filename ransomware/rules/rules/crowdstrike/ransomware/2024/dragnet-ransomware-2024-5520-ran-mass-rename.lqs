// Dragnet [Ransomware]: dragnet-ransomware-2024-5520 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 7b19e488-f69f-5bbe-8efd-152e7679e114

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
