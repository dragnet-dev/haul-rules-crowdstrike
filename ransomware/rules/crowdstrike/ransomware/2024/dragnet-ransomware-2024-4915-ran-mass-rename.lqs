// Dragnet [Ransomware]: dragnet-ransomware-2024-4915 — Mass File Rename (ElDorado)
// Status: deprecated | Level: high | ID: 92ec0163-ce17-5b8d-ba4c-55dd293e3cd5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
