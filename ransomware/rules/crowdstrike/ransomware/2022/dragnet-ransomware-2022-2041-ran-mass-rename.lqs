// Dragnet [Ransomware]: dragnet-ransomware-2022-2041 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 16456d09-aeb8-54e1-92dd-6479c51bc210

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
