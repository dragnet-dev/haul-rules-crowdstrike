// Dragnet [Ransomware]: dragnet-ransomware-2023-2153 — Mass File Rename (play)
// Status: experimental | Level: high | ID: bab30362-4f02-55b1-8d56-682da666d3dd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
