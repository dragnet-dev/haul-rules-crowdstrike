// Dragnet [Ransomware]: dragnet-ransomware-2022-1320 — Mass File Rename (freecivilian)
// Status: deprecated | Level: high | ID: d5111e6e-8e6a-5597-9a65-04200fa4d3a1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
