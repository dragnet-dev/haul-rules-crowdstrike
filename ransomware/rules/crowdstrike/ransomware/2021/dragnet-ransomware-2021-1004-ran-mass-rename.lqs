// Dragnet [Ransomware]: dragnet-ransomware-2021-1004 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 34168e0c-a373-5456-a7a7-38ca86faf511

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
