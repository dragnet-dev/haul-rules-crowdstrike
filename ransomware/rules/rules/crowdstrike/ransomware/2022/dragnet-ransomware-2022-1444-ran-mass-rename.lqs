// Dragnet [Ransomware]: dragnet-ransomware-2022-1444 — Mass File Rename (cuba)
// Status: deprecated | Level: high | ID: 2da549d8-5fc5-5d8a-92f7-bff1a3aada7c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
