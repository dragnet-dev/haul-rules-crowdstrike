// Dragnet [Ransomware]: dragnet-ransomware-2022-2118 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: df598ea8-4737-5a39-a153-37266d5cbc80

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
