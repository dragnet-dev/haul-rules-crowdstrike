// Dragnet [Ransomware]: dragnet-ransomware-2025-5556 — Mass File Rename (coinbasecartel)
// Status: experimental | Level: high | ID: 02a51708-3bf7-5606-8467-eb94a7491edb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
