// Dragnet [Ransomware]: dragnet-ransomware-2024-0490 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 1affd5a5-5a8f-5ced-a70c-ec9798fb99f2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
