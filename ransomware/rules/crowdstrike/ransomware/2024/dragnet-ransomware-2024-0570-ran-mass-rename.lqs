// Dragnet [Ransomware]: dragnet-ransomware-2024-0570 — Mass File Rename (safepay)
// Status: deprecated | Level: high | ID: 7cf10796-ea77-5fbe-89a2-07d0d8cf9e52

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
