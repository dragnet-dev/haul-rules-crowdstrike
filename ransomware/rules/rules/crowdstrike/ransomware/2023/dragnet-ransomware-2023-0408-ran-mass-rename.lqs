// Dragnet [Ransomware]: dragnet-ransomware-2023-0408 — Mass File Rename (cuba)
// Status: deprecated | Level: high | ID: feb8d913-2466-5ad2-8368-d35cc8d5c9e6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
