// Dragnet [Ransomware]: dragnet-ransomware-2025-5006 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: edae8e89-0290-5fe4-ae6a-5a44e887eacb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
