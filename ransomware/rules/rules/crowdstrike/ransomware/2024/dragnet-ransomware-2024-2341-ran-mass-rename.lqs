// Dragnet [Ransomware]: dragnet-ransomware-2024-2341 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 9283b0e4-a48b-5784-b56e-9b3cbe549af8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
