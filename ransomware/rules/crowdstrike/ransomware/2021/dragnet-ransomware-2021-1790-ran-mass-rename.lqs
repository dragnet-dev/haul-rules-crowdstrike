// Dragnet [Ransomware]: dragnet-ransomware-2021-1790 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 0853395f-96ce-50e9-b43e-4081d670f14d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
