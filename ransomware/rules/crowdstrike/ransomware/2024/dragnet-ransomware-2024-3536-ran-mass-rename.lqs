// Dragnet [Ransomware]: dragnet-ransomware-2024-3536 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: d3364f35-2688-5115-a7a3-65d9e35f41e4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
