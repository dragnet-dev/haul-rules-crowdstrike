// Dragnet [Ransomware]: dragnet-ransomware-2021-1134 — Mass File Rename (avaddon)
// Status: deprecated | Level: high | ID: 5609e8fd-5635-5ca9-a8bb-32bd654326e7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
