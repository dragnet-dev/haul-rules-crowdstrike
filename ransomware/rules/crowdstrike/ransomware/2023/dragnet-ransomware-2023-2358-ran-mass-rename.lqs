// Dragnet [Ransomware]: dragnet-ransomware-2023-2358 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: c1d1b33c-e515-57da-b543-ed0fdfab4b77

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
