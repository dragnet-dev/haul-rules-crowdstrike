// Dragnet [Ransomware]: dragnet-ransomware-2022-1155 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 304c2d6f-8530-5b46-a640-300c5b30fb0d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
