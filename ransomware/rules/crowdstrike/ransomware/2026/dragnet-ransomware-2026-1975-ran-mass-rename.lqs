// Dragnet [Ransomware]: dragnet-ransomware-2026-1975 — Mass File Rename (incransom)
// Status: test | Level: high | ID: 3cecc02d-ba1f-58de-b1fc-4e9affb6fce8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
