// Dragnet [Ransomware]: dragnet-ransomware-2026-1232 — Mass File Rename (incransom)
// Status: stable | Level: high | ID: 7a6fe8b2-fa17-51f0-b82a-ef1543ddb2f6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
