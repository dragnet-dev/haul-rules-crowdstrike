// Dragnet [Ransomware]: dragnet-ransomware-2023-2228 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: bddbc462-d7f4-52ed-9518-0a0bfd8f9e22

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
