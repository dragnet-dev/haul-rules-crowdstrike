// Dragnet [Ransomware]: dragnet-ransomware-2023-2083 — Mass File Rename (karakurt)
// Status: experimental | Level: high | ID: 8ca8c2fd-ea4d-5e7e-9088-d85864ea8de2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
