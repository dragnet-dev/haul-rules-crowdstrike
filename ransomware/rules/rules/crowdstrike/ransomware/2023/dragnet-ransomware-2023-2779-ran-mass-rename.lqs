// Dragnet [Ransomware]: dragnet-ransomware-2023-2779 — Mass File Rename (malas)
// Status: experimental | Level: high | ID: cc1483b3-17e7-537f-bfd5-7a5b22a70684

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
