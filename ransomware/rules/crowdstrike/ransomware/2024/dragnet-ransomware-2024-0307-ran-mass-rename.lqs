// Dragnet [Ransomware]: dragnet-ransomware-2024-0307 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 93fe2a76-1360-557b-ba47-497d31e728db

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
