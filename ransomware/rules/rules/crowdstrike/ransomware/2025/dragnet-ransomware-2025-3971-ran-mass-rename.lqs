// Dragnet [Ransomware]: dragnet-ransomware-2025-3971 — Mass File Rename (sinobi)
// Status: experimental | Level: high | ID: bbe35053-d91e-58eb-8db0-d7afe30feeda

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
