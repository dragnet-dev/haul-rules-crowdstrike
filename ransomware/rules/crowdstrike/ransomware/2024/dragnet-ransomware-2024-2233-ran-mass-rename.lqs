// Dragnet [Ransomware]: dragnet-ransomware-2024-2233 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 5778c735-b21e-5b83-86bb-e6642bebbeda

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
