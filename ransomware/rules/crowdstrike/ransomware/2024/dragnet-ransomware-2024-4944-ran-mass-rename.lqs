// Dragnet [Ransomware]: dragnet-ransomware-2024-4944 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: 12929ea3-00a7-502f-b745-de5aaee85f30

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
