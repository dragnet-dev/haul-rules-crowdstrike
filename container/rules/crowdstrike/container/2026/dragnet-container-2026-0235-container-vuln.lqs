// Dragnet [Container]: dragnet-container-2026-0235 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 6fee0740-759e-58b5-a3c5-cff6425fc4f1

#event_simpleName=*
| (ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10* OR ImageFileName = *ubuntu:13.04* OR ImageFileName = *ubuntu:13.10*)
| table([timestamp, ComputerName])
| limit(1000)
