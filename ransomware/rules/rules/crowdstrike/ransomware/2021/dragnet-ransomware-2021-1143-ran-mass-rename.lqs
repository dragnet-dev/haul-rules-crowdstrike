// Dragnet [Ransomware]: dragnet-ransomware-2021-1143 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: ade6d6de-65c5-54ea-810f-cae4952da4aa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
