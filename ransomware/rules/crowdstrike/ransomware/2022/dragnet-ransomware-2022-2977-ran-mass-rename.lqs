// Dragnet [Ransomware]: dragnet-ransomware-2022-2977 — Mass File Rename (royal)
// Status: deprecated | Level: high | ID: b69eef86-9acf-5c9e-aa70-d9abcc0f9159

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
