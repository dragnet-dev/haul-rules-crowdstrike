// Dragnet [Container]: dragnet-container-2024-1387 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 7c33d32f-4150-5e72-84f0-a77aebef2f64

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
