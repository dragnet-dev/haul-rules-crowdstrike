// Dragnet [Ransomware]: dragnet-ransomware-2024-5312 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 4b52e5ea-5b2d-52bd-be91-20af0dd09682

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
