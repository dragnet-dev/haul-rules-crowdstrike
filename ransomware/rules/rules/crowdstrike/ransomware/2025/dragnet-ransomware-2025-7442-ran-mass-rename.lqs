// Dragnet [Ransomware]: dragnet-ransomware-2025-7442 — Mass File Rename (incransom)
// Status: test | Level: high | ID: db682cb0-8156-5bf1-b1d8-6e875a6371ff

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
