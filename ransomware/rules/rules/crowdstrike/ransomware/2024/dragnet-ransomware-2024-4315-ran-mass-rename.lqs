// Dragnet [Ransomware]: dragnet-ransomware-2024-4315 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 86381a4c-dff0-558e-a4d6-15b575ffba0b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
