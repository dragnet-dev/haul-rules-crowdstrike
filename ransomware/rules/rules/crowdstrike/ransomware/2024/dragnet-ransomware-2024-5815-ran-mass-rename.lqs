// Dragnet [Ransomware]: dragnet-ransomware-2024-5815 — Mass File Rename (redransomware)
// Status: deprecated | Level: high | ID: 7888bde7-5220-5274-a1b5-08867db68812

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
