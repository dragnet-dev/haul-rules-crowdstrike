// Dragnet [Ransomware]: dragnet-ransomware-2024-5246 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 7d84fc9d-44b6-5ae3-9565-da2407ba9ac4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
