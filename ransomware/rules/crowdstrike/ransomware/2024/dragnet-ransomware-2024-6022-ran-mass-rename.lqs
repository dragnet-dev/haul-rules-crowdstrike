// Dragnet [Ransomware]: dragnet-ransomware-2024-6022 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 080fef99-4d5f-5e14-8085-030f7fde4b30

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
