// Dragnet [Container]: dragnet-container-2025-0722 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: ffa6e549-e6c5-594a-ae1e-f8a08e1ff152

#event_simpleName=*
| (ImageFileName = *oraclelinux:7* OR ImageFileName = *ubuntu:14.04* OR ImageFileName = *ubuntu:16.04* OR ImageFileName = *ubuntu:16.10* OR ImageFileName = *ubuntu:17.04*)
| table([timestamp, ComputerName])
| limit(1000)
