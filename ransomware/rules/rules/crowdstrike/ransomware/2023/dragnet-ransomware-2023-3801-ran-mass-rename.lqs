// Dragnet [Ransomware]: dragnet-ransomware-2023-3801 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 31078ae4-9d35-5d5c-aa4a-7c1e607e8a73

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
