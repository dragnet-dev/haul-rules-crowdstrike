// Dragnet [Ransomware]: dragnet-ransomware-2024-4772 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: 5132e6b8-2922-5c6f-a7e0-cd5098f44464

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
