// Dragnet [Ransomware]: dragnet-ransomware-2025-7493 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: d6c3b3b3-7d12-5aae-aa23-55fb65bf160b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
