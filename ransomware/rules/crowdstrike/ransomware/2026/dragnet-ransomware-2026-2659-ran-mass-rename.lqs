// Dragnet [Ransomware]: dragnet-ransomware-2026-2659 — Mass File Rename (kairos)
// Status: deprecated | Level: high | ID: 5256fa55-454e-56ab-a34a-f1844f2ec229

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
