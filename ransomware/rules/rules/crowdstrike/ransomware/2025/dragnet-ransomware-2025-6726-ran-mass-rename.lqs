// Dragnet [Ransomware]: dragnet-ransomware-2025-6726 — Mass File Rename (worldleaks)
// Status: experimental | Level: high | ID: 4fbb0d02-2336-558f-8566-07804e52ad85

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
