// Dragnet [Ransomware]: dragnet-ransomware-2023-1399 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 040ac57f-b790-5d72-9f16-b635ad9300d7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
