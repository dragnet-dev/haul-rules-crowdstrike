// Dragnet [Ransomware]: dragnet-ransomware-2023-3030 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: f1a99b3d-18cb-5243-b462-53a3124e4747

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
