// Dragnet [Ransomware]: dragnet-ransomware-2024-5026 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 19cfa087-4503-558c-8517-2ed2151c58d5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
