// Dragnet [Ransomware]: dragnet-ransomware-2023-2227 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 2d57f580-ffb4-5783-97ef-7c54dd0ff29d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
