// Dragnet [Ransomware]: dragnet-ransomware-2025-0167 — Mass File Rename (play)
// Status: experimental | Level: high | ID: d7af3599-ab11-5334-b5a8-0caa9d00173a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
