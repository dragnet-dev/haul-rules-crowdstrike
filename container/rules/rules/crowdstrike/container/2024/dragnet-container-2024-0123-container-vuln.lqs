// Dragnet [Container]: dragnet-container-2024-0123 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 3d4507f2-a17b-5bd7-b12e-8865f52c9782

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12*)
| table([timestamp, ComputerName])
| limit(1000)
