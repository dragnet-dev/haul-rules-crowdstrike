// Dragnet [Ransomware]: dragnet-ransomware-2025-3576 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: 1280665b-5ff4-5d4b-b563-fae7334dcdcf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
