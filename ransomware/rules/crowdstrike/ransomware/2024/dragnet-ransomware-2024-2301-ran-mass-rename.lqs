// Dragnet [Ransomware]: dragnet-ransomware-2024-2301 — Mass File Rename (handala)
// Status: experimental | Level: high | ID: 6fd121c9-265c-53fc-9cf8-0ece34b89eed

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
