// Dragnet [Ransomware]: dragnet-ransomware-2026-0299 — Mass File Rename (everest)
// Status: stable | Level: high | ID: 8df97f21-acc4-5968-9551-ac26e1d7c07f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
