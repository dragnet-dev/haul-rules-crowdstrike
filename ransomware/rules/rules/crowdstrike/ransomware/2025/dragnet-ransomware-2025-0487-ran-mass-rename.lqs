// Dragnet [Ransomware]: dragnet-ransomware-2025-0487 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: b38ea8bc-c62d-5850-a4ee-f119def87321

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
