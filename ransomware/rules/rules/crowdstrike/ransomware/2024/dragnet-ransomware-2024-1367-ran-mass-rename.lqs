// Dragnet [Ransomware]: dragnet-ransomware-2024-1367 — Mass File Rename (meow)
// Status: experimental | Level: high | ID: 371ed69f-95ce-5bc4-b5ed-977115467cc9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
