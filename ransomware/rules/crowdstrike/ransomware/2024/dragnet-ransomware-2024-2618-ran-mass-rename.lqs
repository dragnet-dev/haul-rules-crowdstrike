// Dragnet [Ransomware]: dragnet-ransomware-2024-2618 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 9f4e05ea-2518-5d06-a591-63aa2c0b8a1b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
