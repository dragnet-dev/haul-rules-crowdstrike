// Dragnet [Ransomware]: dragnet-ransomware-2026-0238 — Mass File Rename (insomnia)
// Status: stable | Level: high | ID: f10736ce-a21d-56ec-af6b-431efe795696

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
