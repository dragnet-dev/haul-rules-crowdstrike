// Dragnet [Ransomware]: dragnet-ransomware-2025-2370 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: befa0bec-ca22-5397-8e1b-7d8fc6df1c00

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
