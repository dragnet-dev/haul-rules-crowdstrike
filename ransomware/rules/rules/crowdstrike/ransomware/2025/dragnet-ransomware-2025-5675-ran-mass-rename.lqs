// Dragnet [Ransomware]: dragnet-ransomware-2025-5675 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: 096ae8e5-dae3-55a8-afb5-2d4ca5ed4cda

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
