// Dragnet [Ransomware]: dragnet-ransomware-2022-2519 — Mass File Rename (cuba)
// Status: deprecated | Level: high | ID: 1c2a3500-2898-54f5-ac3d-e1db08440b8d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
