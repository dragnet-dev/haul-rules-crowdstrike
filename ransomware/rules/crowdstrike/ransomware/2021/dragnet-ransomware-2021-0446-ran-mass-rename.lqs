// Dragnet [Ransomware]: dragnet-ransomware-2021-0446 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 442b5767-92d5-58f9-9f2d-885d48d27f39

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
