// Dragnet [Ransomware]: dragnet-ransomware-2025-5475 — Mass File Rename (rhysida)
// Status: deprecated | Level: high | ID: d0492275-6981-5b9d-aee2-2a8a1fba8db1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
