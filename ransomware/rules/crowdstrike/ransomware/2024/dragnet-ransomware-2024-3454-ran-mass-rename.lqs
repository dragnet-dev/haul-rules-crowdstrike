// Dragnet [Ransomware]: dragnet-ransomware-2024-3454 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 2172b578-f7a4-50ed-aaa3-75cfaa21396e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
