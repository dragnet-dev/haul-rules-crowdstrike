// Dragnet [Ransomware]: dragnet-ransomware-2026-3422 — Mass File Rename (spacebears)
// Status: test | Level: high | ID: a6661864-ebbe-5e17-b7d7-5290300a45f2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
