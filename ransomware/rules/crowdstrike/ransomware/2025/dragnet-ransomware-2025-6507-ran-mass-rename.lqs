// Dragnet [Ransomware]: dragnet-ransomware-2025-6507 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: 401e136a-3484-5ac2-9ed2-6f9d8377190c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
