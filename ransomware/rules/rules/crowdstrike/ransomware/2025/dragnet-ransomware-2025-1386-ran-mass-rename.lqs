// Dragnet [Ransomware]: dragnet-ransomware-2025-1386 — Mass File Rename (threeam)
// Status: experimental | Level: high | ID: 8a36a1cd-7ff0-5b12-b580-6bb9eefb4fcd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
