// Dragnet [Ransomware]: dragnet-ransomware-2025-0725 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: 3431be32-3472-5d89-908f-2ed40ad3a55a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
