// Dragnet [Ransomware]: dragnet-ransomware-2024-5998 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: d3627647-d989-53eb-9a67-b6bb5e5baabf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
