// Dragnet [Ransomware]: dragnet-ransomware-2024-1733 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: 04ccf930-5523-5ae3-9742-02a7c697fe63

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
