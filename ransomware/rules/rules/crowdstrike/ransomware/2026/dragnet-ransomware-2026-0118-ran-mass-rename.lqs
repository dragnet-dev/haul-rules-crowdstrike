// Dragnet [Ransomware]: dragnet-ransomware-2026-0118 — Mass File Rename (termite)
// Status: stable | Level: high | ID: d43ba5ff-c92f-55fc-80e8-be115dc49cae

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
