// Dragnet [Ransomware]: dragnet-ransomware-2025-0629 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: b0b9ea30-491d-5216-87fa-0a168f06fb8d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
