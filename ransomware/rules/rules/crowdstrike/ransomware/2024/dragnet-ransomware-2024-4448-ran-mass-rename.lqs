// Dragnet [Ransomware]: dragnet-ransomware-2024-4448 — Mass File Rename (donutleaks)
// Status: experimental | Level: high | ID: 34e665bc-a644-5caa-9dab-995055b149be

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
