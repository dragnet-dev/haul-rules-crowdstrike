// Dragnet [Ransomware]: dragnet-ransomware-2025-4228 — Mass File Rename (genesis)
// Status: experimental | Level: high | ID: 7e3e5bd4-592f-5a0b-93ac-2a82d948e8ca

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
