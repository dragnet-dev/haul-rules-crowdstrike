// Dragnet [Ransomware]: dragnet-ransomware-2025-0316 — Mass File Rename (handala)
// Status: experimental | Level: high | ID: d74c4ff8-9361-5027-9344-f916eb7f637f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
