// Dragnet [Ransomware]: dragnet-ransomware-2025-7246 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: aaa4905d-7a3e-5f9a-a93c-eea370704b57

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
