// Dragnet [Ransomware]: dragnet-ransomware-2023-1740 — Mass File Rename (mallox)
// Status: deprecated | Level: high | ID: 855d3550-497c-585a-9efe-cb434d723efa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
