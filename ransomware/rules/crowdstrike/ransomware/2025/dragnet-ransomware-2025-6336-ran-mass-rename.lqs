// Dragnet [Ransomware]: dragnet-ransomware-2025-6336 — Mass File Rename (global)
// Status: deprecated | Level: high | ID: 91489ab3-aa5e-500e-8b13-63f736431c44

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
