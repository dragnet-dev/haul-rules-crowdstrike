// Dragnet [Ransomware]: dragnet-ransomware-2025-2882 — Mass File Rename (nova)
// Status: experimental | Level: high | ID: f0bbd9e9-87cd-5a8a-8dea-e4814c08ab51

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
