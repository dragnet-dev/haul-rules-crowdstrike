// Dragnet [Ransomware]: dragnet-ransomware-2024-2124 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: 1ba402f1-1d01-5252-a9ee-8cf887675c49

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
