// Dragnet [Ransomware]: dragnet-ransomware-2022-1490 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 379f089b-d1b7-5ab9-84ed-d8243b0aabfc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
