// Dragnet [Ransomware]: dragnet-ransomware-2022-3085 — Mass File Rename (mindware)
// Status: deprecated | Level: high | ID: 099b6c9c-a30a-5d61-ac32-adf22f907736

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
