// Dragnet [Ransomware]: dragnet-ransomware-2025-7188 — Mass File Rename (securotrop)
// Status: experimental | Level: high | ID: e0f6668f-67c3-5aa1-b34d-8b3ad694e485

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
