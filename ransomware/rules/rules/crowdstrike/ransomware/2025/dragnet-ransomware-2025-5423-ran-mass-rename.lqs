// Dragnet [Ransomware]: dragnet-ransomware-2025-5423 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 2c7737d3-a1a9-5ad1-9592-08ab8cb120a5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
