// Dragnet [Ransomware]: dragnet-ransomware-2023-3634 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: 0b613a68-eebe-5206-b762-ce53a347a447

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
