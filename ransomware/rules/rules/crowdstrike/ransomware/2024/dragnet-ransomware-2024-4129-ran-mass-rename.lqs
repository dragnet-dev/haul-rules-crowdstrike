// Dragnet [Ransomware]: dragnet-ransomware-2024-4129 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 524bec00-febf-5621-8520-e90301409e85

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
