// Dragnet [Ransomware]: dragnet-ransomware-2025-7745 — Mass File Rename (alphalocker)
// Status: experimental | Level: high | ID: 21a597e1-330d-5217-b19d-d211def09c4d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
