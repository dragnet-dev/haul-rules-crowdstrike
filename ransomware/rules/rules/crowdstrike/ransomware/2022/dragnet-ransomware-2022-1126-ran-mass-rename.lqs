// Dragnet [Ransomware]: dragnet-ransomware-2022-1126 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: f2bab11a-fd35-5b7e-b60d-ed04302813ba

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
