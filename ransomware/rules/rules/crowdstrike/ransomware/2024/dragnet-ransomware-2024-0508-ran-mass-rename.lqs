// Dragnet [Ransomware]: dragnet-ransomware-2024-0508 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 427d6f57-cc9f-5bc0-8dfb-3f68afd2013b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
