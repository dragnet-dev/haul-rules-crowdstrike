// Dragnet [Ransomware]: dragnet-ransomware-2023-3373 — Mass File Rename (royal)
// Status: experimental | Level: high | ID: af99b921-3dd4-5a73-bacd-96e9bd8eb50b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
