// Dragnet [Ransomware]: dragnet-ransomware-2025-6617 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 4b6bea9f-170b-5621-a3a4-af0e49f607c4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
