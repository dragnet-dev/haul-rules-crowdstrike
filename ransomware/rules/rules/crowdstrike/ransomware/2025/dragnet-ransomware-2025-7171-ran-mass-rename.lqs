// Dragnet [Ransomware]: dragnet-ransomware-2025-7171 — Mass File Rename (kairos)
// Status: deprecated | Level: high | ID: 6976a63a-803b-5aaa-92fa-ad9ae57a476b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
