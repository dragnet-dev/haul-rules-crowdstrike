// Dragnet [Ransomware]: dragnet-ransomware-2025-3932 — Mass File Rename (radar)
// Status: deprecated | Level: high | ID: 614456d8-b8e7-5239-8a6d-141149b11acb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
