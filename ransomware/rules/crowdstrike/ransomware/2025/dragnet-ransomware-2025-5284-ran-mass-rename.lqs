// Dragnet [Ransomware]: dragnet-ransomware-2025-5284 — Mass File Rename (incransom)
// Status: test | Level: high | ID: 1428a1a6-341e-556a-bae2-21637885cae6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
