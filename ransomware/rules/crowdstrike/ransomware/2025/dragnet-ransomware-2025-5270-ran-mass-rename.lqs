// Dragnet [Ransomware]: dragnet-ransomware-2025-5270 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 6d6d3d36-890a-5944-85da-c236a5d14be2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
