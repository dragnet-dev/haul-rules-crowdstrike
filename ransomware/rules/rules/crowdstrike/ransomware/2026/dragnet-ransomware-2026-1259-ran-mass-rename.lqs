// Dragnet [Ransomware]: dragnet-ransomware-2026-1259 — Mass File Rename (incransom)
// Status: stable | Level: high | ID: 484bbe65-bf3a-54e0-946e-8f72a3545071

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
