// Dragnet [Ransomware]: dragnet-ransomware-2025-3160 — Mass File Rename (spacebears)
// Status: experimental | Level: high | ID: 8c622940-18a8-5a11-8a2f-c053e5b85e5f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
