// Dragnet [Ransomware]: dragnet-ransomware-2022-3042 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: cde51ccf-e3ec-5f94-a6e9-2eaf1999d6b7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
