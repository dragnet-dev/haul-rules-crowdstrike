// Dragnet [Ransomware]: dragnet-ransomware-2024-5995 — Mass File Rename (meow)
// Status: experimental | Level: high | ID: a15514b2-b019-5056-8712-5b28946b60df

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
