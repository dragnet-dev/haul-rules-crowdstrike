// Dragnet [Ransomware]: dragnet-ransomware-2025-7311 — Mass File Rename (coinbasecartel)
// Status: experimental | Level: high | ID: 2fb8e4e6-5726-5244-b02e-a4387ad6d72e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
