// Dragnet [Ransomware]: dragnet-ransomware-2024-3235 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: f47dc6c4-879d-57f7-984d-e56a41b75563

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
