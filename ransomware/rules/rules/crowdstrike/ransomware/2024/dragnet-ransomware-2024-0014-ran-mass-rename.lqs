// Dragnet [Ransomware]: dragnet-ransomware-2024-0014 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: ed6ae240-cfc3-5455-9520-604717d3d5a3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
