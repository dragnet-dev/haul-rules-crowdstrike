// Dragnet [Ransomware]: dragnet-ransomware-2025-5222 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 2b3c23aa-7d44-52bb-9f07-afcc4a484d10

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
