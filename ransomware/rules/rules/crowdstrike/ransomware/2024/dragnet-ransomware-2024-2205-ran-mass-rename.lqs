// Dragnet [Ransomware]: dragnet-ransomware-2024-2205 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: b9bd5bc4-6cf4-5bf5-ac28-dc1d6bae43d1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
