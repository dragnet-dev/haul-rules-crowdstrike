// Dragnet [Ransomware]: dragnet-ransomware-2026-1848 — Mass File Rename (payoutsking)
// Status: test | Level: high | ID: 290ce622-2a88-5eaf-bbbb-a54bbde56d18

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
