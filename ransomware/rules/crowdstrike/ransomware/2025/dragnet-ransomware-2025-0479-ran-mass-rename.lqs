// Dragnet [Ransomware]: dragnet-ransomware-2025-0479 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: f6cc0625-1855-56a4-a09d-36eee22d4743

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
