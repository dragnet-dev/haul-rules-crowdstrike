// Dragnet [Container]: dragnet-container-2026-1281 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 21c5bbbd-8daa-5f07-98d2-b753805492aa

#event_simpleName=*
| (ImageFileName = *amazonlinux:1* OR ImageFileName = *debian:7* OR ImageFileName = *debian:8* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:14.04* OR ImageFileName = *ubuntu:14.04-ESM* OR ImageFileName = *ubuntu:16.04* OR ImageFileName = *ubuntu:16.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
