// Dragnet [Ransomware]: dragnet-ransomware-2023-1415 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: c177f576-cec7-5886-8aba-bb4757ac205f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
