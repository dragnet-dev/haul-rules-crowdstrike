// Dragnet [Ransomware]: dragnet-ransomware-2023-0830 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: efc050f1-5bbe-5437-b41d-3667d252ec19

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
