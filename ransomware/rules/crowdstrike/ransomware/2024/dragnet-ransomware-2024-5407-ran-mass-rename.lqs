// Dragnet [Ransomware]: dragnet-ransomware-2024-5407 — Mass File Rename (meow)
// Status: experimental | Level: high | ID: 5c34ecb5-9778-5760-9b79-155932146dd9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
