// Dragnet [Ransomware]: dragnet-ransomware-2025-3091 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: f24ab7c6-a62e-5e06-9f50-a8c24474a9f9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
