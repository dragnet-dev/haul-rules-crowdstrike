// Dragnet [Ransomware]: dragnet-ransomware-2024-0928 — Mass File Rename (play)
// Status: experimental | Level: high | ID: c31a3efc-6ed1-5ccf-8af0-885e48975f26

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
