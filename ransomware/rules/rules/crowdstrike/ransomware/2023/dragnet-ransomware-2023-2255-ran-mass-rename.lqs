// Dragnet [Ransomware]: dragnet-ransomware-2023-2255 — Mass File Rename (trigona)
// Status: deprecated | Level: high | ID: 02fb5b4e-598e-5778-bcd7-225c7519ca8f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
