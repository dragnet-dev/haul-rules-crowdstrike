// Dragnet [Ransomware]: dragnet-ransomware-2023-2496 — Mass File Rename (werewolves)
// Status: experimental | Level: high | ID: 5d34176d-8fe8-5633-9ffa-9c0957b77b13

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
