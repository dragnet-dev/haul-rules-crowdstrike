// Dragnet [Ransomware]: dragnet-ransomware-2025-6413 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 288470ad-cd2c-50ff-82df-67c15e721c74

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
