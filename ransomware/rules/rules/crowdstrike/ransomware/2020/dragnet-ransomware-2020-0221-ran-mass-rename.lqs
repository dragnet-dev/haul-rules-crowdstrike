// Dragnet [Ransomware]: dragnet-ransomware-2020-0221 — Mass File Rename (revil)
// Status: deprecated | Level: high | ID: be175f55-31b2-53d0-b620-731d6532e277

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
