// Dragnet [Ransomware]: dragnet-ransomware-2022-0178 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 5ec587ba-1f7c-579f-a644-0c3b1af5cc67

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
