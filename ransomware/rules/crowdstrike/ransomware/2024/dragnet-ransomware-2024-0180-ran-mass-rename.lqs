// Dragnet [Ransomware]: dragnet-ransomware-2024-0180 — Mass File Rename (alphalocker)
// Status: experimental | Level: high | ID: 078d9180-3dbb-539d-b067-d57959a2078e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
