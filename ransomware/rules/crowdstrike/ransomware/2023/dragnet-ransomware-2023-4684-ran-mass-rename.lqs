// Dragnet [Ransomware]: dragnet-ransomware-2023-4684 — Mass File Rename (play)
// Status: experimental | Level: high | ID: fb881e46-6ad0-51d0-9218-9452879d5db5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
