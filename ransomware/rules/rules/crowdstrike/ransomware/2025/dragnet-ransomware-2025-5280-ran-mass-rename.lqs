// Dragnet [Ransomware]: dragnet-ransomware-2025-5280 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: ebf68f8b-ba65-50b0-84c7-96ba7ff74318

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
