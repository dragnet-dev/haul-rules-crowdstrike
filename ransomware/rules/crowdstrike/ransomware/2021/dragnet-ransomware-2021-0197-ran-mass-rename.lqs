// Dragnet [Ransomware]: dragnet-ransomware-2021-0197 — Mass File Rename (snatch)
// Status: deprecated | Level: high | ID: 27853ddf-8f8a-5bfd-af5f-364fa637221e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
