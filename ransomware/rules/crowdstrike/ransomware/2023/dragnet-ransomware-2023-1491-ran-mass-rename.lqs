// Dragnet [Ransomware]: dragnet-ransomware-2023-1491 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 1c912cd1-43bf-5785-a639-fb1fdc710ebb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
