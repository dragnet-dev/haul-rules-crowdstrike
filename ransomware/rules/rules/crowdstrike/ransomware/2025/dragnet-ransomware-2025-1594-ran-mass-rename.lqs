// Dragnet [Ransomware]: dragnet-ransomware-2025-1594 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 932a4fe7-389a-5a32-a1e8-b233dea2f340

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
