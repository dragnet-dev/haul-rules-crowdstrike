// Dragnet [Ransomware]: dragnet-ransomware-2025-2551 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 59c0eb96-f46d-569f-8cbe-8f18262b25e5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
