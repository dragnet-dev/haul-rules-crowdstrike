// Dragnet [Ransomware]: dragnet-ransomware-2024-3964 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 8bbee3bd-9ca6-5905-b8bd-7cf18411aace

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
