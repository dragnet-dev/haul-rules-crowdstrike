// Dragnet [Ransomware]: dragnet-ransomware-2023-1954 — Mass File Rename (play)
// Status: experimental | Level: high | ID: ded4daec-feed-5fa3-871e-be4a08676634

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
