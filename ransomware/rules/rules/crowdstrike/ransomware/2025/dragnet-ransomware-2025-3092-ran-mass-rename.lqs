// Dragnet [Ransomware]: dragnet-ransomware-2025-3092 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 95d3057e-5125-5c4c-82d0-2ccdda94257e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
