// Dragnet [Ransomware]: dragnet-ransomware-2022-0428 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 9ea9a6d6-3c0f-5603-9935-94ef7010254e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
