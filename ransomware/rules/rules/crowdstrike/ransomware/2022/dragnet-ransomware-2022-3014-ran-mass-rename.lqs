// Dragnet [Ransomware]: dragnet-ransomware-2022-3014 — Mass File Rename (vicesociety)
// Status: deprecated | Level: high | ID: ad47f855-31ee-5152-8368-02ba7f3ed2b8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
