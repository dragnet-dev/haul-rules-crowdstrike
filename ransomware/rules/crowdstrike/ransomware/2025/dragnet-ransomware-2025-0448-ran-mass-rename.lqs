// Dragnet [Ransomware]: dragnet-ransomware-2025-0448 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: c96569c2-a750-503f-98de-17f99ba3399b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
