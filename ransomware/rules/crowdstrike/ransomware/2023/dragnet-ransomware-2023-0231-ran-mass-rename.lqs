// Dragnet [Ransomware]: dragnet-ransomware-2023-0231 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 9927e535-25fc-5248-b9ee-db7deec2485a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
