// Dragnet [Ransomware]: dragnet-ransomware-2025-7546 — Mass File Rename (rhysida)
// Status: experimental | Level: high | ID: b26793fb-be04-5403-8ce9-648358de5eee

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
