// Dragnet [Ransomware]: dragnet-ransomware-2022-1741 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 54c75963-0fde-5874-b01e-ff2682f4c813

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
