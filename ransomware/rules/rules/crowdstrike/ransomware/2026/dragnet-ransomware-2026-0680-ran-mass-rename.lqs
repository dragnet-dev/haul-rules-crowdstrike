// Dragnet [Ransomware]: dragnet-ransomware-2026-0680 — Mass File Rename (safepay)
// Status: stable | Level: high | ID: 75cbdfa1-2814-57e5-a030-d9f0d366f00d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
