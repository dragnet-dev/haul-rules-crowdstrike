// Dragnet [Ransomware]: dragnet-ransomware-2023-3010 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 05a04d5d-f290-569f-a16d-9fafea958aa3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
