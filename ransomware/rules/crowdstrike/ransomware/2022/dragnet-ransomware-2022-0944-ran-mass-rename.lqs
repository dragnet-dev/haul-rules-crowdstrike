// Dragnet [Ransomware]: dragnet-ransomware-2022-0944 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 3114c918-7248-5151-9b0f-74d93cb9cdc9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
