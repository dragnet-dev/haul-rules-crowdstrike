// Dragnet [Ransomware]: dragnet-ransomware-2025-0602 — Mass File Rename (silent)
// Status: experimental | Level: high | ID: 41c190e5-bfcf-5bf1-9f90-a70f5ef7de00

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
