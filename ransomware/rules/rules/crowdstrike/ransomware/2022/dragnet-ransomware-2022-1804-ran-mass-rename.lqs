// Dragnet [Ransomware]: dragnet-ransomware-2022-1804 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: b7139cf7-78b7-5870-9191-e5fff8dde2ed

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
