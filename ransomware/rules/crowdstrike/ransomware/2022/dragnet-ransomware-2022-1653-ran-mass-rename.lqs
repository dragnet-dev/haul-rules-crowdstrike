// Dragnet [Ransomware]: dragnet-ransomware-2022-1653 — Mass File Rename (blackbasta)
// Status: deprecated | Level: high | ID: 7952a706-a9a4-5cd3-86f6-f852f88eb210

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
