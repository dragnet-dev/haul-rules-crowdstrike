// Dragnet [Ransomware]: dragnet-ransomware-2024-0809 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 44c9f254-7dc5-50cc-a7a5-47bc5fba06df

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
