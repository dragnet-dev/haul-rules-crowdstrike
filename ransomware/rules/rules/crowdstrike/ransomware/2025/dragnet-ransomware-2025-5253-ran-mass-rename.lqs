// Dragnet [Ransomware]: dragnet-ransomware-2025-5253 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: e9e6287e-c9eb-5f58-a9bd-d76a5482702c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
