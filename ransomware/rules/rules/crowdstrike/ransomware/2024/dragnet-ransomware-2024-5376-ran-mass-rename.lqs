// Dragnet [Ransomware]: dragnet-ransomware-2024-5376 — Mass File Rename (meow)
// Status: experimental | Level: high | ID: dbff89da-a874-5db6-9d62-64a622d5efc8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
