// Dragnet [Ransomware]: dragnet-ransomware-2025-6636 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: bb8893d4-768e-5f81-8dcb-963b5ad6ec17

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
