// Dragnet [Ransomware]: dragnet-ransomware-2023-1462 — Mass File Rename (nokoyawa)
// Status: experimental | Level: high | ID: c76f669e-f270-551b-92ec-cbdd43e103d5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
