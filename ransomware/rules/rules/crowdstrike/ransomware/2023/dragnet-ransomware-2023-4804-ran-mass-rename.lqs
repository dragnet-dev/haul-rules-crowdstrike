// Dragnet [Ransomware]: dragnet-ransomware-2023-4804 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 510b0269-a130-5e3a-9fc3-11bc3931d207

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
