// Dragnet [Ransomware]: dragnet-ransomware-2022-2171 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: dfbeb7c1-59a7-5b04-9e62-52d8b52b813e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
