// Dragnet [Ransomware]: dragnet-ransomware-2023-5012 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: bf5d932e-4870-567c-927d-d162e14a638f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
