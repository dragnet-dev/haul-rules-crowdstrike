// Dragnet [Ransomware]: dragnet-ransomware-2020-0053 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 5778cffd-8411-5255-9f3f-cf305ccbbaab

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
