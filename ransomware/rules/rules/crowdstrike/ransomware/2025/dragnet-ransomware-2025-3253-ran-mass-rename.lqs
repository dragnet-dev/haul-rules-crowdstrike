// Dragnet [Ransomware]: dragnet-ransomware-2025-3253 — Mass File Rename (nightspire)
// Status: deprecated | Level: high | ID: 4605fcd9-b650-584d-99ef-adcc4c031507

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
