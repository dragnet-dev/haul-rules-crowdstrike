// Dragnet [Ransomware]: dragnet-ransomware-2025-0013 — Mass File Rename (warlock)
// Status: deprecated | Level: high | ID: 360cc1e5-498f-5b82-9997-191a72464e94

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
