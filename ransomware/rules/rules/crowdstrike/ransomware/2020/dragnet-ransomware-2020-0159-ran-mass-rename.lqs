// Dragnet [Ransomware]: dragnet-ransomware-2020-0159 — Mass File Rename (snake)
// Status: deprecated | Level: high | ID: 1d577797-fa0b-5483-9ee3-1d624ce4467f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
