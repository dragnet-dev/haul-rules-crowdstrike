// Dragnet [Ransomware]: dragnet-ransomware-2025-0442 — Mass File Rename (sarcoma)
// Status: deprecated | Level: high | ID: 7e32a248-791d-5ade-8588-f8015b7afbf9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
