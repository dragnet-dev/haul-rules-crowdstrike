// Dragnet [Ransomware]: dragnet-ransomware-2025-5139 — Mass File Rename (coinbasecartel)
// Status: experimental | Level: high | ID: 55f8fff6-32e1-5031-9db8-b85ea3e7d54a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
