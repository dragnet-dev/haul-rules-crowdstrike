// Dragnet [Ransomware]: dragnet-ransomware-2024-2791 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 168e080a-9c69-51f8-8d87-8ae516b0795d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
