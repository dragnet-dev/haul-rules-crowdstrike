// Dragnet [Ransomware]: dragnet-ransomware-2021-1098 — Mass File Rename (ragnarlocker)
// Status: deprecated | Level: high | ID: f3ca8c1b-0abe-5bc7-add2-8a4da5237fc5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
