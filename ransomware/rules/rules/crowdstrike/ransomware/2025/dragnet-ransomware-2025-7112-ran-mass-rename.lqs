// Dragnet [Ransomware]: dragnet-ransomware-2025-7112 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 4e19b71b-c2e4-529b-bbc8-cbe434fd1af6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
