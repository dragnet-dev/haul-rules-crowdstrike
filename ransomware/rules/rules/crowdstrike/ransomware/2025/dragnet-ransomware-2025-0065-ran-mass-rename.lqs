// Dragnet [Ransomware]: dragnet-ransomware-2025-0065 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: ff78668f-b2e2-55f7-819b-36d25c583130

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
