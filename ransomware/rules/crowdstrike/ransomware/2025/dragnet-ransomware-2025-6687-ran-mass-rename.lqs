// Dragnet [Ransomware]: dragnet-ransomware-2025-6687 — Mass File Rename (monti)
// Status: experimental | Level: high | ID: 1497fbf1-e23f-5d61-8fd9-94b0a675c0f6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
