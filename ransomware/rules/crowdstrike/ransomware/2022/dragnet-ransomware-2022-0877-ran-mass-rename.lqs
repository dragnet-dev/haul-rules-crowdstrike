// Dragnet [Ransomware]: dragnet-ransomware-2022-0877 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 7466e238-7ca7-581d-9583-096ef518ace7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
