// Dragnet [Ransomware]: dragnet-ransomware-2025-4138 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 100e3106-7c77-5ed8-ba5a-adca40308417

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
