// Dragnet [Ransomware]: dragnet-ransomware-2025-3612 — Mass File Rename (handala)
// Status: experimental | Level: high | ID: 53323cd3-9d40-5484-bbcd-4371fa2e6ecd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
