// Dragnet [Ransomware]: dragnet-ransomware-2023-0735 — Mass File Rename (malas)
// Status: experimental | Level: high | ID: 852fc381-8009-54f2-8cd2-e495dde3b42d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
