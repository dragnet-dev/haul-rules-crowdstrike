// Dragnet [Ransomware]: dragnet-ransomware-2022-1396 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 932cfea0-bb88-541f-a9ab-fb3d9134686a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
