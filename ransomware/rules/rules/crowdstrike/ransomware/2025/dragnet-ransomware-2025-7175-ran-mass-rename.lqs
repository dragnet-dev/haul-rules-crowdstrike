// Dragnet [Ransomware]: dragnet-ransomware-2025-7175 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: c91dba34-633c-5bac-b426-f6a45e8c49fe

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
