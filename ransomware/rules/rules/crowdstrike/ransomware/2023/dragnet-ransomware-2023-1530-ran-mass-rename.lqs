// Dragnet [Ransomware]: dragnet-ransomware-2023-1530 — Mass File Rename (play)
// Status: experimental | Level: high | ID: a7850eb4-0a5c-5791-9b10-099dd72e0986

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
