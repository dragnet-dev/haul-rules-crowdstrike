// Dragnet [Ransomware]: dragnet-ransomware-2024-4937 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 45123bda-3126-5734-a8c3-d3b83c3b9d0d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
