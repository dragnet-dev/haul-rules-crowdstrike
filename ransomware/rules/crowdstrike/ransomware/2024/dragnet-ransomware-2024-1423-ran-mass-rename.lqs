// Dragnet [Ransomware]: dragnet-ransomware-2024-1423 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 396d4170-b28a-5a30-ad13-30bda6a890f1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
