// Dragnet [Ransomware]: dragnet-ransomware-2023-3306 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: f72a9ff4-2717-5b43-b8ea-1b346a93270a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
