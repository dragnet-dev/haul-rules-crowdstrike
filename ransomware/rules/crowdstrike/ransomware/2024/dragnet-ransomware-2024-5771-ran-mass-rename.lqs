// Dragnet [Ransomware]: dragnet-ransomware-2024-5771 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 9ad3dcf7-e365-5f51-ba7a-7923683de5e6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
