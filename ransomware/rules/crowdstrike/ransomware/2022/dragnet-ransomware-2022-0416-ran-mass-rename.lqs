// Dragnet [Ransomware]: dragnet-ransomware-2022-0416 — Mass File Rename (royal)
// Status: deprecated | Level: high | ID: 8b005b65-2ed4-58f8-b007-e73b1a171891

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
