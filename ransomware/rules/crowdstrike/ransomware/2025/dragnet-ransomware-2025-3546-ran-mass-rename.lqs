// Dragnet [Ransomware]: dragnet-ransomware-2025-3546 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: 01456797-13d2-504c-86a2-89a780fc3654

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
