// Dragnet [Ransomware]: dragnet-ransomware-2025-0307 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: fc40c6f7-1394-5fe9-bfe6-cf221dbb9730

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
