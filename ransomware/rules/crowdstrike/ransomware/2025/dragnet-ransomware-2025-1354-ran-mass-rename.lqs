// Dragnet [Ransomware]: dragnet-ransomware-2025-1354 — Mass File Rename (handala)
// Status: experimental | Level: high | ID: 15144120-2820-592f-b36a-0c93930331d4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
