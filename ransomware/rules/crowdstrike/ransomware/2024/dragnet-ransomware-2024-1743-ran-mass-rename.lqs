// Dragnet [Ransomware]: dragnet-ransomware-2024-1743 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 0c7dc50c-0157-5758-b7a4-734c7a28f6d5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
