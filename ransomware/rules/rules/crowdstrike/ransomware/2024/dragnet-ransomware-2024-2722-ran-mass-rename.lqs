// Dragnet [Ransomware]: dragnet-ransomware-2024-2722 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: cb39bc03-d497-5771-bc77-3213c08f3d64

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
