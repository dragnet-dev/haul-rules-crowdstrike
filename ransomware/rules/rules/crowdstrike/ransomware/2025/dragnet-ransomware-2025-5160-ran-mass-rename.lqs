// Dragnet [Ransomware]: dragnet-ransomware-2025-5160 — Mass File Rename (apt73)
// Status: experimental | Level: high | ID: 33471dea-f5d4-5428-affc-9f9913e880b1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
