// Dragnet [Ransomware]: dragnet-ransomware-2025-2775 — Mass File Rename (devman)
// Status: experimental | Level: high | ID: bba3d482-0d03-5c82-af3e-38e8560a9342

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
