// Dragnet [Ransomware]: dragnet-ransomware-2023-3871 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: 4863ba37-c07c-5d31-b7a1-ab250afd6400

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
