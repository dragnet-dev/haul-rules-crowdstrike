// Dragnet [Ransomware]: dragnet-ransomware-2025-1063 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 4a5fd7c6-6a79-57a7-85d1-7b729702d453

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
