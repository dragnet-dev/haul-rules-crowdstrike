// Dragnet [Ransomware]: dragnet-ransomware-2025-2566 — Mass File Rename (cloak)
// Status: deprecated | Level: high | ID: 7dac64a3-083b-5e3f-ac3c-6cdc40d35c9e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
