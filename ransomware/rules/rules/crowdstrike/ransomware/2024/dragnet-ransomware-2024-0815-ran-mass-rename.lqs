// Dragnet [Ransomware]: dragnet-ransomware-2024-0815 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: be362ad2-013f-5435-9749-02d36baab166

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
