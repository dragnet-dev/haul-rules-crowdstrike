// Dragnet [Ransomware]: dragnet-ransomware-2022-0090 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 0c983dee-b84a-5bc5-af33-0288be223734

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
