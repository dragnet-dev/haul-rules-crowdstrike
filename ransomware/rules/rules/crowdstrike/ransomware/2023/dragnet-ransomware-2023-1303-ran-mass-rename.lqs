// Dragnet [Ransomware]: dragnet-ransomware-2023-1303 — Mass File Rename (cloak)
// Status: deprecated | Level: high | ID: effdd79b-9e6e-51b4-8bb2-55d107e9614d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
