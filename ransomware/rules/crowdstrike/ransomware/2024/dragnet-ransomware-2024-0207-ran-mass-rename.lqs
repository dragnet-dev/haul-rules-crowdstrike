// Dragnet [Ransomware]: dragnet-ransomware-2024-0207 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: b4bb280a-6daf-5510-ad30-348f7c6c6478

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
