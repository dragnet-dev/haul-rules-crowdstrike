// Dragnet [Ransomware]: dragnet-ransomware-2025-0763 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 82b8ad13-4fbf-59e1-b626-44ec090ccec1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
