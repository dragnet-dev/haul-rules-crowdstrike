// Dragnet [Ransomware]: dragnet-ransomware-2025-7548 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: f116a182-b105-558d-a210-45fada1f0927

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
