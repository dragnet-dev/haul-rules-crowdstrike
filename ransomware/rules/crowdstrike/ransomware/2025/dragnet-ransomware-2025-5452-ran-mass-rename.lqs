// Dragnet [Ransomware]: dragnet-ransomware-2025-5452 — Mass File Rename (interlock)
// Status: experimental | Level: high | ID: c5c30a9a-9c9f-55fb-8cdd-b8b5d30e5f7e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
