// Dragnet [Ransomware]: dragnet-ransomware-2023-4117 — Mass File Rename (play)
// Status: experimental | Level: high | ID: b3f10e78-b187-50ec-b1e2-3ec739370e35

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
