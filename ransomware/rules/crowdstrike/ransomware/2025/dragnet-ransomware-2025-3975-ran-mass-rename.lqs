// Dragnet [Ransomware]: dragnet-ransomware-2025-3975 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: c384ac59-de24-5772-a0ec-1e8f65e95389

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
