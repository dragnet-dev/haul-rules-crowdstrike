// Dragnet [Ransomware]: dragnet-ransomware-2024-1514 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: e8b53a0d-8414-51bd-8470-479a9e4bc046

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
