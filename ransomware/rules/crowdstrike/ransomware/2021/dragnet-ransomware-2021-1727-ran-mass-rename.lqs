// Dragnet [Ransomware]: dragnet-ransomware-2021-1727 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 32f64b7f-bdd9-5288-83a7-0d9dc862aaf1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
