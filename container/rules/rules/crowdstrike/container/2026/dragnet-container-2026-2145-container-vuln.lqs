// Dragnet [Container]: dragnet-container-2026-2145 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 783a183d-e076-55fe-8025-61ead0fc2c3b

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:8* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:14.04* OR ImageFileName = *ubuntu:16.04* OR ImageFileName = *ubuntu:16.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
