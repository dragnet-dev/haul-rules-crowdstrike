// Dragnet [Ransomware]: dragnet-ransomware-2025-0572 — Mass File Rename (devman)
// Status: experimental | Level: high | ID: 6b364267-bedf-544d-929d-5e33c2810dca

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
