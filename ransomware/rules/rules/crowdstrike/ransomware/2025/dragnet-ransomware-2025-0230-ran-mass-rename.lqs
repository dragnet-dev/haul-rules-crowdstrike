// Dragnet [Ransomware]: dragnet-ransomware-2025-0230 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: b268c625-1047-5f5d-85d0-7b4da4ff4df3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
