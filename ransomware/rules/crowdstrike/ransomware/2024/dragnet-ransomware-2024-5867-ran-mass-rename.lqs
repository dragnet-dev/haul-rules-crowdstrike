// Dragnet [Ransomware]: dragnet-ransomware-2024-5867 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 27faab95-649f-53bc-ae87-6010a65809a3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
