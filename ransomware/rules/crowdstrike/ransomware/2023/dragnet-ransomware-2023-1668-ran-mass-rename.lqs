// Dragnet [Ransomware]: dragnet-ransomware-2023-1668 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 81957dde-1691-59a7-a11c-248918f9eb84

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
