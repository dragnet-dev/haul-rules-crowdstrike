// Dragnet [Ransomware]: dragnet-ransomware-2025-3619 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: bac1870d-96a4-5393-9e0a-a8e1e2c19f8a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
