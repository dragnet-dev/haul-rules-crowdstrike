// Dragnet [Ransomware]: dragnet-ransomware-2025-4266 — Mass File Rename (beast)
// Status: experimental | Level: high | ID: 48aa0c31-71a6-57a4-bcad-23211f76b2b6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
