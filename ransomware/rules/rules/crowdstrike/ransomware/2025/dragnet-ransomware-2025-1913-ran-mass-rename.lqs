// Dragnet [Ransomware]: dragnet-ransomware-2025-1913 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: 1f12f951-676a-5f61-b01b-41a817465df6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
