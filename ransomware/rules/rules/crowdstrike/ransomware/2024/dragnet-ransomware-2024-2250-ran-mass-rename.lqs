// Dragnet [Ransomware]: dragnet-ransomware-2024-2250 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: f559b816-57e9-5976-9fda-ff583a1c7e69

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
