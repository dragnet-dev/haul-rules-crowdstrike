// Dragnet [Ransomware]: dragnet-ransomware-2023-2381 — Mass File Rename (cloak)
// Status: deprecated | Level: high | ID: e6cddcd0-7062-5770-a551-e63a90cd66c6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
