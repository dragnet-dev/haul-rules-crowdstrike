// Dragnet [Container]: dragnet-container-2024-0292 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 8c83fc80-bcc6-527f-ac6b-ac72299346d9

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:8* OR ImageFileName = *debian:9*)
| table([timestamp, ComputerName])
| limit(1000)
