// Dragnet [Ransomware]: dragnet-ransomware-2023-3433 — Mass File Rename (snatch)
// Status: experimental | Level: high | ID: 143716ac-9c54-59eb-bd72-1bcd3ed5bced

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
