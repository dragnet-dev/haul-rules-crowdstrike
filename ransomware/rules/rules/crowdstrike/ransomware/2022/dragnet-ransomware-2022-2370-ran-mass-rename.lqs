// Dragnet [Ransomware]: dragnet-ransomware-2022-2370 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: e52c847e-52d6-5d08-9726-9dcfad8684f1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
