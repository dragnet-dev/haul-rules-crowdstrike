// Dragnet [Ransomware]: dragnet-ransomware-2025-2538 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 3d454309-20aa-5aa6-815c-9838b7b2d97e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
