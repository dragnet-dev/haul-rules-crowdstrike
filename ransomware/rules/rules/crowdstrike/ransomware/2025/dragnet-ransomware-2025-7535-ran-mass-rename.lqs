// Dragnet [Ransomware]: dragnet-ransomware-2025-7535 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: b742952e-deb0-56f1-a7ab-fc8dc7d542b8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
