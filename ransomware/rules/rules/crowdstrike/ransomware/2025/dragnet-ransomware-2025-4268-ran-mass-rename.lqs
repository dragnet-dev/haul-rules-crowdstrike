// Dragnet [Ransomware]: dragnet-ransomware-2025-4268 — Mass File Rename (cephalus)
// Status: deprecated | Level: high | ID: ce95c5a9-3d1d-51c8-84f7-de46f64f8307

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
