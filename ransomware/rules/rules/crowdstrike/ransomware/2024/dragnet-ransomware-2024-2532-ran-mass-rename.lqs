// Dragnet [Ransomware]: dragnet-ransomware-2024-2532 — Mass File Rename (darkvault)
// Status: experimental | Level: high | ID: 47c6b0dd-6b36-54c8-9971-8626e8403771

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
