// Dragnet [Ransomware]: dragnet-ransomware-2024-2342 — Mass File Rename (SilentRansomGroup)
// Status: deprecated | Level: high | ID: 37089618-34c4-5dbd-87a9-ac9f72d42fab

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
