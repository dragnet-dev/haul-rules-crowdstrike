// Dragnet [Ransomware]: dragnet-ransomware-2024-0633 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: 7efb3cc4-0e2d-5696-81df-9438e4d8335b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
