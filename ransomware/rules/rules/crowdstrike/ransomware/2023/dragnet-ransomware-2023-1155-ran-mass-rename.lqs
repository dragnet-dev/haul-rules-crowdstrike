// Dragnet [Ransomware]: dragnet-ransomware-2023-1155 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: fa1cc332-f23f-57b6-a5db-5fd8a701fb1d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
