// Dragnet [Ransomware]: dragnet-ransomware-2024-3832 — Mass File Rename (meow)
// Status: experimental | Level: high | ID: 634d2bee-67e7-5b19-8d9d-06ffa2ad3164

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
