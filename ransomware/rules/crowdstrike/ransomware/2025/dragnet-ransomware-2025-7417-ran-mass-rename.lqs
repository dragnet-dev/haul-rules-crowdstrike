// Dragnet [Ransomware]: dragnet-ransomware-2025-7417 — Mass File Rename (stormous)
// Status: deprecated | Level: high | ID: 5b5441cc-3332-5359-ae2b-d35c4d4ad554

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
