// Dragnet [Container]: dragnet-container-2026-0323 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 5e917419-543c-5f28-a891-c1a212482445

#event_simpleName=*
| (ImageFileName = *chainguard:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
