// Dragnet [Ransomware]: dragnet-ransomware-2023-2922 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: a7e56e68-49a0-5e57-830f-3560b81f2909

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
