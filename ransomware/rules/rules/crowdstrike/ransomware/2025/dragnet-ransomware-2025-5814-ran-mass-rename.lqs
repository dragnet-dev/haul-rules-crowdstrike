// Dragnet [Ransomware]: dragnet-ransomware-2025-5814 — Mass File Rename (shinyhunters)
// Status: experimental | Level: high | ID: 11a60df8-146e-5612-b1e1-36afe212475f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
