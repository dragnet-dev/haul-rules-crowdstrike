// Dragnet [Ransomware]: dragnet-ransomware-2022-1882 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: e5e630d4-14fd-5360-968f-43faddbd2c2c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
