// Dragnet [Container]: dragnet-container-2026-2150 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: e632aaa5-55c6-5cd7-8c42-c879ab1ad4b6

#event_simpleName=*
| (ImageFileName = *alpine:3.2* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:7* OR ImageFileName = *debian:8*)
| table([timestamp, ComputerName])
| limit(1000)
