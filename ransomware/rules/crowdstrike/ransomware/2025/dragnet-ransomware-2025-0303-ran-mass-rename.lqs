// Dragnet [Ransomware]: dragnet-ransomware-2025-0303 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: 184bccca-9649-5247-b755-cb803805eaab

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
