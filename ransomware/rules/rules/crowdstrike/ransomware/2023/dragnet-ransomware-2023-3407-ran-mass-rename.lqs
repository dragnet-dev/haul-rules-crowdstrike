// Dragnet [Ransomware]: dragnet-ransomware-2023-3407 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 358a7187-a2ac-5dd1-ba78-730ebe778ef6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
