// Dragnet [Ransomware]: dragnet-ransomware-2025-5880 — Mass File Rename (nightspire)
// Status: deprecated | Level: high | ID: 02cf07c1-0189-58ce-bba2-f32fcb86fd43

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
