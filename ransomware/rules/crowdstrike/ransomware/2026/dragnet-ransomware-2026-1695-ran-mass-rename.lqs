// Dragnet [Ransomware]: dragnet-ransomware-2026-1695 — Mass File Rename (everest)
// Status: stable | Level: high | ID: 65249994-ce8d-58a6-86d0-9c53b9ccd3f5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
