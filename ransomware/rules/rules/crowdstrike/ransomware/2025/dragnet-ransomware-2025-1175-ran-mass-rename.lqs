// Dragnet [Ransomware]: dragnet-ransomware-2025-1175 — Mass File Rename (SilentRansomGroup)
// Status: deprecated | Level: high | ID: a545bbd6-4e87-5f18-a17d-7643118e3b44

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
