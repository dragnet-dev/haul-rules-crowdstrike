// Dragnet [Ransomware]: dragnet-ransomware-2025-7127 — Mass File Rename (lockbit5)
// Status: test | Level: high | ID: a1a03f0f-1d7c-5b77-854c-6aa3e1442fff

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
