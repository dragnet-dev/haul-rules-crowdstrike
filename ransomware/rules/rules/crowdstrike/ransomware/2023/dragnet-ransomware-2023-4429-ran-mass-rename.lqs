// Dragnet [Ransomware]: dragnet-ransomware-2023-4429 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: f3a5177c-fc11-5ce8-be34-96ef85fe0aaf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
