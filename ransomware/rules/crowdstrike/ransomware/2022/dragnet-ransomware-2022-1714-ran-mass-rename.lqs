// Dragnet [Ransomware]: dragnet-ransomware-2022-1714 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 93df08a1-3ded-5675-843d-ac2af064a91d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
