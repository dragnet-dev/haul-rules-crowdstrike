// Dragnet [Ransomware]: dragnet-ransomware-2022-0572 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 7fb497d3-4384-511b-8848-ff0e0b25a741

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
