// Dragnet [Ransomware]: dragnet-ransomware-2023-2191 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: da5bc76e-8330-5cb1-8d18-fc0aaabc3271

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
