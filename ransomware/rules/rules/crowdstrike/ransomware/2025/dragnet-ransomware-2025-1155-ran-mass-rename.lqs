// Dragnet [Ransomware]: dragnet-ransomware-2025-1155 — Mass File Rename (play)
// Status: experimental | Level: high | ID: b44d4a6c-e516-55cb-8a1e-dcadc147f2f8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
