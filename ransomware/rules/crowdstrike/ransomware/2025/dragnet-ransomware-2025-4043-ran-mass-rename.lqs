// Dragnet [Ransomware]: dragnet-ransomware-2025-4043 — Mass File Rename (radiant)
// Status: experimental | Level: high | ID: 59debe6c-ecbf-524d-993c-c19a691d1120

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
