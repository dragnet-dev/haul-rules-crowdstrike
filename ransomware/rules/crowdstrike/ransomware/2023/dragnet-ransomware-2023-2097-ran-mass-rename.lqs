// Dragnet [Ransomware]: dragnet-ransomware-2023-2097 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 98603ad5-66e2-50db-a050-0a5b91a7afe2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
