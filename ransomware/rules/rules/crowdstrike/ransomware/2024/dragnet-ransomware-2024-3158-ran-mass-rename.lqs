// Dragnet [Ransomware]: dragnet-ransomware-2024-3158 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 902ccc3c-2a6a-5520-b812-b0920b65f035

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
