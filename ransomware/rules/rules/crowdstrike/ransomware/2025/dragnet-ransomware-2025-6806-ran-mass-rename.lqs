// Dragnet [Ransomware]: dragnet-ransomware-2025-6806 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 6ae3d71a-0000-540a-8d72-c5055d63c470

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
