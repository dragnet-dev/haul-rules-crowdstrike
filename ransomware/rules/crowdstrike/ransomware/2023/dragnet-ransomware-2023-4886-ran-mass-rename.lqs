// Dragnet [Ransomware]: dragnet-ransomware-2023-4886 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 7e07be6c-9fbc-52a3-b9c1-ec797c90bd0e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
