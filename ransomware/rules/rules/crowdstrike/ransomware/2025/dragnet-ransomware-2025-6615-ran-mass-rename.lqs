// Dragnet [Ransomware]: dragnet-ransomware-2025-6615 — Mass File Rename (termite)
// Status: experimental | Level: high | ID: 7fbdcf07-a12f-5ca1-8d72-37d8e528b555

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
