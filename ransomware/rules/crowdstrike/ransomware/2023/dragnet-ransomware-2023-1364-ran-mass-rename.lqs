// Dragnet [Ransomware]: dragnet-ransomware-2023-1364 — Mass File Rename (raworld)
// Status: experimental | Level: high | ID: 3c365b25-3b3d-5fbd-8024-e0f11a1d5e1b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
