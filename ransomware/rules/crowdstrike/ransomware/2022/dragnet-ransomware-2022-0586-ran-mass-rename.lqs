// Dragnet [Ransomware]: dragnet-ransomware-2022-0586 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 14fdc10f-aa79-5a1e-b3bd-79dc95d3efb6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
