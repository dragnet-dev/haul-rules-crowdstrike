// Dragnet [Ransomware]: dragnet-ransomware-2024-5255 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 3abb7160-424d-58c0-aed6-5294052b9b7e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
