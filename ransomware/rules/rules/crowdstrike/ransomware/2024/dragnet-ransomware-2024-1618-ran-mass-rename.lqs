// Dragnet [Ransomware]: dragnet-ransomware-2024-1618 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: c0a00e5a-d311-5b46-9cc6-70156a480891

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
