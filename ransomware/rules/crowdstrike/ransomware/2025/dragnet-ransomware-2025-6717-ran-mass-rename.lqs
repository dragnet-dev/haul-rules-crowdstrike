// Dragnet [Ransomware]: dragnet-ransomware-2025-6717 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 988cfd39-bb73-5d7b-ad47-78858773a38b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
