// Dragnet [Ransomware]: dragnet-ransomware-2023-1630 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: c55e3930-8126-5f00-8c4b-9a138215154d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
