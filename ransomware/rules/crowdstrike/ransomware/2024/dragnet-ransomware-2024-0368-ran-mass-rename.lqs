// Dragnet [Ransomware]: dragnet-ransomware-2024-0368 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 874a1f62-11e7-5b11-bd45-a6018b9ac462

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
