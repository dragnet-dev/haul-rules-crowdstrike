// Dragnet [Ransomware]: dragnet-ransomware-2023-4967 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 4f873ebe-a638-568b-b366-c4f925154622

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
