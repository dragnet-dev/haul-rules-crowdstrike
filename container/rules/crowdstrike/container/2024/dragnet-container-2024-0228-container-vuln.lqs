// Dragnet [Container]: dragnet-container-2024-0228 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 5e28e5f4-a2e4-56db-a68f-7889dcaf55e2

#event_simpleName=*
| (ImageFileName = *chainguard:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
