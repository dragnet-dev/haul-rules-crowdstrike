// Dragnet [Ransomware]: dragnet-ransomware-2025-4789 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 3d1ff339-7d0d-55e9-a5bb-d54e3f0d7e93

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
