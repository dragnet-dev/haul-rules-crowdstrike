// Dragnet [Ransomware]: dragnet-ransomware-2023-3113 — Mass File Rename (royal)
// Status: experimental | Level: high | ID: 17ceeacd-fbfa-5c81-9f80-d57ab57c7093

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
