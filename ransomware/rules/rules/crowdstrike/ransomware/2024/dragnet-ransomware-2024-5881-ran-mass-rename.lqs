// Dragnet [Ransomware]: dragnet-ransomware-2024-5881 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 6ea96e66-eee6-5865-a906-dbc90660cc55

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
