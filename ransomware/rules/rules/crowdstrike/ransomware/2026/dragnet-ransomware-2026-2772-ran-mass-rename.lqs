// Dragnet [Ransomware]: dragnet-ransomware-2026-2772 — Mass File Rename (lockbit5)
// Status: stable | Level: high | ID: bcbaf3e6-3a06-56bc-8264-412ceb706dc2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
