// Dragnet [Ransomware]: dragnet-ransomware-2025-2621 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: ad76cc2c-9024-5cd7-837a-3dc014ebb89f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
