// Dragnet [Ransomware]: dragnet-ransomware-2025-4970 — Mass File Rename (stormous)
// Status: experimental | Level: high | ID: 14942d83-c3f6-5bd2-9185-910f871d24ed

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
