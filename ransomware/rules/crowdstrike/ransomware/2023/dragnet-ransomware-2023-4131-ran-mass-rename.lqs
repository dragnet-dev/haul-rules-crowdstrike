// Dragnet [Ransomware]: dragnet-ransomware-2023-4131 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 37a33535-c75c-5415-8194-ed85882a85a2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
