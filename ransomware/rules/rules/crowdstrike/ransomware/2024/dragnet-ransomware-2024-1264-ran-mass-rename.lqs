// Dragnet [Ransomware]: dragnet-ransomware-2024-1264 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 457b386e-519b-5a3a-835e-cc209818adf1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
