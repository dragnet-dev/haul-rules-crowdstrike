// Dragnet [Ransomware]: dragnet-ransomware-2024-0256 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 26d4f075-7771-5265-980b-79aea7773701

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
