// Dragnet [Ransomware]: dragnet-ransomware-2025-5761 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: c2edc86a-f6bd-51ec-b046-21e923594535

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
