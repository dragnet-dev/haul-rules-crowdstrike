// Dragnet [Ransomware]: dragnet-ransomware-2026-0033 — Mass File Rename (lamashtu)
// Status: stable | Level: high | ID: 17415165-04b4-533e-b8fb-212363329164

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
