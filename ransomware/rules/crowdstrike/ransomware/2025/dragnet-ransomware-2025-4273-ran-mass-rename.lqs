// Dragnet [Ransomware]: dragnet-ransomware-2025-4273 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 7ace2729-6620-5c77-9d56-fc4b90529446

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
