// Dragnet [Ransomware]: dragnet-ransomware-2025-4140 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: bd6613ef-4ee9-5f64-9ec8-009d97da1512

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
