// Dragnet [Ransomware]: dragnet-ransomware-2025-5755 — Mass File Rename (lockbit5)
// Status: experimental | Level: high | ID: b8d41f2d-b2e5-5a08-9b60-43c15fd85f07

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
