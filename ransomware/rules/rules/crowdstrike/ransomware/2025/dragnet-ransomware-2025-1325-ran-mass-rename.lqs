// Dragnet [Ransomware]: dragnet-ransomware-2025-1325 — Mass File Rename (nova)
// Status: experimental | Level: high | ID: 5ded9473-cd33-5eff-9139-fcaca994be32

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
