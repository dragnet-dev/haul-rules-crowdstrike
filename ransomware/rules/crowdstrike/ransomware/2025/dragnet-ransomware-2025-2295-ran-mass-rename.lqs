// Dragnet [Ransomware]: dragnet-ransomware-2025-2295 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 64aa5611-4cef-59c2-b1f3-2457e2ce1b77

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
