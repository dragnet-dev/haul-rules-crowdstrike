// Dragnet [Ransomware]: dragnet-ransomware-2022-3090 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 1a0280a6-7dfe-5c7e-8ebd-30bc72954ec1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
