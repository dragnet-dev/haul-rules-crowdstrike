// Dragnet [Ransomware]: dragnet-ransomware-2025-7193 — Mass File Rename (devman)
// Status: experimental | Level: high | ID: f6532fe7-df4b-5527-8ae6-a0862c608c66

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
