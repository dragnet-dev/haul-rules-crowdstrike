// Dragnet [Ransomware]: dragnet-ransomware-2023-2888 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 707d566e-0716-5aad-af6f-3d32be626f4a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
