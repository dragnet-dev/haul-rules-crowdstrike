// Dragnet [Ransomware]: dragnet-ransomware-2025-6054 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 420bc9a8-bc25-50c9-914b-ba8ff75bd473

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
