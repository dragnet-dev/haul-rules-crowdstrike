// Dragnet [Ransomware]: dragnet-ransomware-2024-0612 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 5a650c41-a4fd-5d43-98d0-1a82d9a67f16

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
