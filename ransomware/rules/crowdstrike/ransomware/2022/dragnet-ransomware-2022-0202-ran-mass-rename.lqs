// Dragnet [Ransomware]: dragnet-ransomware-2022-0202 — Mass File Rename (donutleaks)
// Status: deprecated | Level: high | ID: cd2677e7-8015-5819-b374-67e97f216424

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
