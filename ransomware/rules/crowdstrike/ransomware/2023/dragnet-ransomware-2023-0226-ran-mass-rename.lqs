// Dragnet [Ransomware]: dragnet-ransomware-2023-0226 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 496d4a7b-c11a-5150-9d0b-da0ae4f80ce0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
