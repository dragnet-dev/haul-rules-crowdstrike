// Dragnet [Ransomware]: dragnet-ransomware-2025-3073 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 0a704f65-77db-5047-a431-0635587c039e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
