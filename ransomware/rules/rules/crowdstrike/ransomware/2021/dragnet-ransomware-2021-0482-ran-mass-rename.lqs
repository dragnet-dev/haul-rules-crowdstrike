// Dragnet [Ransomware]: dragnet-ransomware-2021-0482 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: a86fa97f-89a3-5853-bb7b-e4fa653b28a8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
