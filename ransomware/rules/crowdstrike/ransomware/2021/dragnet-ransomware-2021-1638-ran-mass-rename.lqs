// Dragnet [Ransomware]: dragnet-ransomware-2021-1638 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 474fec9a-46b2-5b99-be4b-5814dae5d033

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
