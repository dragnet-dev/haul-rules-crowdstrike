// Dragnet [Ransomware]: dragnet-ransomware-2023-5309 — Mass File Rename (play)
// Status: deprecated | Level: high | ID: 11fda1ed-183d-5ccf-952a-07e6d92fd103

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
