// Dragnet [Ransomware]: dragnet-ransomware-2025-6773 — Mass File Rename (anubis)
// Status: experimental | Level: high | ID: 4fde1538-86fb-59e3-810b-013fd9eaaa48

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
