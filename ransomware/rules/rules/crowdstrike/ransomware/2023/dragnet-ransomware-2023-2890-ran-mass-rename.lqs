// Dragnet [Ransomware]: dragnet-ransomware-2023-2890 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 474c48a3-10f7-5f44-b18a-13544827769d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
