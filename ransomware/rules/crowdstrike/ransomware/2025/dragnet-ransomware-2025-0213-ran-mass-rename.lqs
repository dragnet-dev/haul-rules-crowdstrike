// Dragnet [Ransomware]: dragnet-ransomware-2025-0213 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 41e2de3d-7c05-5bd2-b318-8e28474033a2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
