// Dragnet [Ransomware]: dragnet-ransomware-2024-0544 — Mass File Rename (rhysida)
// Status: deprecated | Level: high | ID: 8b2105e2-f45d-5ad3-b7b7-b6bf93c99218

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
