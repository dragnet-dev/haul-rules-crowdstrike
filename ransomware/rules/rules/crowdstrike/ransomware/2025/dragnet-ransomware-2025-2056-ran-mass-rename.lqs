// Dragnet [Ransomware]: dragnet-ransomware-2025-2056 — Mass File Rename (play)
// Status: experimental | Level: high | ID: c9678730-a9b2-5bd5-b295-920855bb8cf0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
