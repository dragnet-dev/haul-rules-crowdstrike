// Dragnet [Ransomware]: dragnet-ransomware-2024-2881 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 46994e32-347d-5df9-81eb-51f94c0008bb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
