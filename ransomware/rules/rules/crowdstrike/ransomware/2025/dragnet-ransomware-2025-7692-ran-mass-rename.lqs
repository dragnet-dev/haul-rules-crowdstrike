// Dragnet [Ransomware]: dragnet-ransomware-2025-7692 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 72562f48-ef14-562e-8a44-1b8702053ec3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
