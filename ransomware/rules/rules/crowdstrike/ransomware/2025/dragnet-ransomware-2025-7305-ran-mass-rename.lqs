// Dragnet [Ransomware]: dragnet-ransomware-2025-7305 — Mass File Rename (play)
// Status: experimental | Level: high | ID: dfe4a8f2-59e8-5068-bd61-ad3acc5c69b9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
