// Dragnet [Ransomware]: dragnet-ransomware-2025-4919 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 9036aa17-7eb5-5bf1-896c-9f0428ccc885

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
