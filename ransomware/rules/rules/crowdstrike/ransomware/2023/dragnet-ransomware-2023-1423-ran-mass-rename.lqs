// Dragnet [Ransomware]: dragnet-ransomware-2023-1423 — Mass File Rename (play)
// Status: experimental | Level: high | ID: d7dedb91-b5a9-5ce0-ba15-a5ae01da5f1c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
