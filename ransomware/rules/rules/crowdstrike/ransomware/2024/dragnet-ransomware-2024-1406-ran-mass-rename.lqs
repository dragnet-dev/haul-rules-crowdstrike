// Dragnet [Ransomware]: dragnet-ransomware-2024-1406 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 4501994d-f8c3-5527-92c2-da7f30807f7c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
