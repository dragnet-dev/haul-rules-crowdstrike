// Dragnet [Ransomware]: dragnet-ransomware-2025-0297 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: ef305c57-8c38-5a64-9c0e-86898a6555b7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
