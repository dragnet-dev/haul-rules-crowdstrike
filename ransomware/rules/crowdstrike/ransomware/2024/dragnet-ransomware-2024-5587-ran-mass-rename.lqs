// Dragnet [Ransomware]: dragnet-ransomware-2024-5587 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 59a43152-a00b-54bf-8de3-27512abea09e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
