// Dragnet [Ransomware]: dragnet-ransomware-2021-1435 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 731d2ac1-f004-55fc-86c8-fe3b14022757

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
