// Dragnet [Ransomware]: dragnet-ransomware-2023-3092 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 6b900871-44aa-5ca1-8e97-0fd30d2e8a85

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
