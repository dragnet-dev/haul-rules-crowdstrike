// Dragnet [Ransomware]: dragnet-ransomware-2022-1195 — Mass File Rename (everest)
// Status: deprecated | Level: high | ID: ac99bbfd-515c-517c-bc89-ebf858b93a95

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
