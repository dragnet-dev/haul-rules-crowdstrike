// Dragnet [Ransomware]: dragnet-ransomware-2025-2330 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: 1ade659e-c671-58a4-a133-2379072322a7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
