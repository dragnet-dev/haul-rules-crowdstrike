// Dragnet [Ransomware]: dragnet-ransomware-2024-4473 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 45744725-51bc-54c9-8300-9fb82accd390

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
