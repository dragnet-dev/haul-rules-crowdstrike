// Dragnet [Ransomware]: dragnet-ransomware-2026-3111 — Mass File Rename (killsec)
// Status: deprecated | Level: high | ID: cb2bdb26-5c7a-537b-8384-c05448cd0e48

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
