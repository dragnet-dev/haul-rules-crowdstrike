// Dragnet [Container]: dragnet-container-2024-0325 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 4b23d4d7-829d-5407-ae19-9f059146174c

#event_simpleName=*
| (ImageFileName = *amazonlinux:2* OR ImageFileName = *amazonlinux:2023* OR ImageFileName = *azure linux:3.0* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
