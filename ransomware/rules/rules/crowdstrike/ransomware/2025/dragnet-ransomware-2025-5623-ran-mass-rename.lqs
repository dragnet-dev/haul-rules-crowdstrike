// Dragnet [Ransomware]: dragnet-ransomware-2025-5623 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 79fbd7e4-6a34-5d50-bb71-5c5a9d635489

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
