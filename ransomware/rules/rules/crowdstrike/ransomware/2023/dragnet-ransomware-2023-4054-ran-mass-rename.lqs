// Dragnet [Ransomware]: dragnet-ransomware-2023-4054 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: ca8fa8d1-250f-57e2-b24c-a7b95733d8b6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
