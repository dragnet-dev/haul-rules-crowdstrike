// Dragnet [Ransomware]: dragnet-ransomware-2024-3798 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: 7658ff4e-e286-5278-b3d3-8177c9a089f2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
