// Dragnet [Ransomware]: dragnet-ransomware-2025-1239 — Mass File Rename (sinobi)
// Status: experimental | Level: high | ID: 42e12912-766c-5895-9449-62cd776cb45f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
