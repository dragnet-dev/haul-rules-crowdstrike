// Dragnet [Ransomware]: dragnet-ransomware-2024-1543 — Mass File Rename (meow)
// Status: experimental | Level: high | ID: 3376e5d7-5edd-5880-bc06-53f172027a1e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
