// Dragnet [Ransomware]: dragnet-ransomware-2024-2948 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: ac96295f-05e8-5a32-b032-bf5b0d476b49

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
