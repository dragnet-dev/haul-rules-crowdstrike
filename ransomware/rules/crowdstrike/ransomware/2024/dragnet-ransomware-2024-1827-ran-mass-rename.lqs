// Dragnet [Ransomware]: dragnet-ransomware-2024-1827 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 4c7100a3-31f9-5c14-89be-de653eb0bf5a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
