// Dragnet [Container]: dragnet-container-2026-1829 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 74284658-4028-5d55-8ab6-c8e6982c9ef1

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:7* OR ImageFileName = *debian:8* OR ImageFileName = *ubuntu:12.04*)
| table([timestamp, ComputerName])
| limit(1000)
