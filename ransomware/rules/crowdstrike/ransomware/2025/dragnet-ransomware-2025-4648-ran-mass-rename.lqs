// Dragnet [Ransomware]: dragnet-ransomware-2025-4648 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 2982e852-5606-5c82-848d-64022ad775fa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
