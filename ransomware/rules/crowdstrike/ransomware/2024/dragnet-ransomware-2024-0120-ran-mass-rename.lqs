// Dragnet [Ransomware]: dragnet-ransomware-2024-0120 — Mass File Rename (donex)
// Status: experimental | Level: high | ID: a7dbfe04-91e5-5503-8a36-ebefc3619f70

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
