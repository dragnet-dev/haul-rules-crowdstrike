// Dragnet [Ransomware]: dragnet-ransomware-2025-4285 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: e9af3419-3683-5707-ab7b-e473ce062c9d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
