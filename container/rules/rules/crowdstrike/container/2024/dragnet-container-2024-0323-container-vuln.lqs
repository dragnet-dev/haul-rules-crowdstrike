// Dragnet [Container]: dragnet-container-2024-0323 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: c9b4d461-a892-5cd4-83e8-e63bae5f8713

#event_simpleName=*
| (ImageFileName = *cbl-mariner:1.0* OR ImageFileName = *cbl-mariner:2.0* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *photon os:5.0* OR ImageFileName = *ubuntu:20.04* OR ImageFileName = *ubuntu:20.04-ESM* OR ImageFileName = *ubuntu:22.04* OR ImageFileName = *ubuntu:23.04*)
| table([timestamp, ComputerName])
| limit(1000)
