// Dragnet [Ransomware]: dragnet-ransomware-2025-2259 — Mass File Rename (worldleaks)
// Status: experimental | Level: high | ID: 7938a035-0c8c-5506-8633-f88c47a4dd05

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
