// Dragnet [Ransomware]: dragnet-ransomware-2025-4924 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 7bdf6dc6-e88e-5bbc-99fd-07261613f6ed

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
