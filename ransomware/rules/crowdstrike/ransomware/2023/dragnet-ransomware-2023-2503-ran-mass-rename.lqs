// Dragnet [Ransomware]: dragnet-ransomware-2023-2503 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: d8c1b811-828c-5f1e-8c5a-eab1e8e159e0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
