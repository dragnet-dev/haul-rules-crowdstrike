// Dragnet [Ransomware]: dragnet-ransomware-2024-2273 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: 18a29e7f-b539-5a72-a8e5-15eba0d94665

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
