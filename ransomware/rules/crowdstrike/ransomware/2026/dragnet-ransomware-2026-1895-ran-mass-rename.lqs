// Dragnet [Ransomware]: dragnet-ransomware-2026-1895 — Mass File Rename (incransom)
// Status: stable | Level: high | ID: f06a2bd2-bf0f-5e2d-84f5-d9093f541492

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
