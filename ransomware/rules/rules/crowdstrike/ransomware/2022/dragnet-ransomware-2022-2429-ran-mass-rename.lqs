// Dragnet [Ransomware]: dragnet-ransomware-2022-2429 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 15730b4d-e359-50b3-a5c4-554965d4539c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
