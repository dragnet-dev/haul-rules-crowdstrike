// Dragnet [Ransomware]: dragnet-ransomware-2022-2689 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 807495b2-4a17-5d58-a55f-a76d08342e9c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
