// Dragnet [Ransomware]: dragnet-ransomware-2023-2978 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: ca0ea5cb-d70b-5471-b058-0a940c03a6c0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
