// Dragnet [Ransomware]: dragnet-ransomware-2024-1932 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 3e9b4c34-9f0c-5cc0-b4f0-dbe5ca302486

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
