// Dragnet [Ransomware]: dragnet-ransomware-2024-1599 — Mass File Rename (unsafe)
// Status: deprecated | Level: high | ID: 579d64e0-06a8-53ac-9a86-086462e266cb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
