// Dragnet [Ransomware]: dragnet-ransomware-2023-3025 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: a37aff07-01bb-5247-9f5b-fcd450fd8cda

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
