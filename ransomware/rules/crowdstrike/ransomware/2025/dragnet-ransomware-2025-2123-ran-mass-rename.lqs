// Dragnet [Ransomware]: dragnet-ransomware-2025-2123 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 5da5c6d9-5d97-5f1f-abe6-7635c02d9cd1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
