// Dragnet [Container]: dragnet-container-2026-0811 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: ba2e1948-8121-5ce1-90d1-149fc1dfdfd6

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:5*)
| table([timestamp, ComputerName])
| limit(1000)
