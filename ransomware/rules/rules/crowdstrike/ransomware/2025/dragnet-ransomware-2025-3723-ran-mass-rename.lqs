// Dragnet [Ransomware]: dragnet-ransomware-2025-3723 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 7996426c-bd7e-5834-9868-d8a74015fba0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
