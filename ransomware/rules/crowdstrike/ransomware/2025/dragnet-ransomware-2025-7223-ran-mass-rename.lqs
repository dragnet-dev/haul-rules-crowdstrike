// Dragnet [Ransomware]: dragnet-ransomware-2025-7223 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 97247e0e-41f2-5ecb-9255-5ae1a634e41d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
