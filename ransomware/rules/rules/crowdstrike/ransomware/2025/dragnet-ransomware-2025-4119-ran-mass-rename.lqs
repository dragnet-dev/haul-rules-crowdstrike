// Dragnet [Ransomware]: dragnet-ransomware-2025-4119 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 59f5036e-ea1b-5987-83f5-8dc44764434d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
