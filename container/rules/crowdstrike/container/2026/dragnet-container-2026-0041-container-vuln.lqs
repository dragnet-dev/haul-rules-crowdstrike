// Dragnet [Container]: dragnet-container-2026-0041 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 5cbfaabb-d264-505c-9f53-4da69d3143f6

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *redhat/ubi9:*)
| table([timestamp, ComputerName])
| limit(1000)
