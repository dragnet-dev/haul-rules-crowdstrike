// Dragnet [Ransomware]: dragnet-ransomware-2023-2426 — Mass File Rename (qilin)
// Status: deprecated | Level: high | ID: 0e15ed96-8fd0-54ce-bc66-3cd6729e350f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
