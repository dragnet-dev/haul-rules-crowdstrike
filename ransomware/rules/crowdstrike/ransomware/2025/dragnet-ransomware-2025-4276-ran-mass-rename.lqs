// Dragnet [Ransomware]: dragnet-ransomware-2025-4276 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 2e15f11a-abcc-5e04-a420-e19ccabef122

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
