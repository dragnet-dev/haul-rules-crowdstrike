// Dragnet [Ransomware]: dragnet-ransomware-2023-4975 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: 04426009-a0ab-5a76-a380-f9ad40367159

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
