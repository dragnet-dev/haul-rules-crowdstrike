// Dragnet [Ransomware]: dragnet-ransomware-2021-1383 — Mass File Rename (avaddon)
// Status: deprecated | Level: high | ID: e53ef4eb-5f9c-5a6c-bd40-0a9271bdec56

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
