// Dragnet [Ransomware]: dragnet-ransomware-2024-3449 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 0f8abb69-90f1-53f6-8c44-3868bc50fc24

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
