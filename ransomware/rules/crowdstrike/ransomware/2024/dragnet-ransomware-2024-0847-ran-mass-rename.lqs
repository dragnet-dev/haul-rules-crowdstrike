// Dragnet [Ransomware]: dragnet-ransomware-2024-0847 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 8510fd40-a3ce-59bb-b6d8-3268f251e1ba

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
