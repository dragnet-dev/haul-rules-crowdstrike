// Dragnet [Ransomware]: dragnet-ransomware-2023-4439 — Mass File Rename (royal)
// Status: experimental | Level: high | ID: b2b39a02-205e-5557-9065-fa2ae3d1ae52

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
