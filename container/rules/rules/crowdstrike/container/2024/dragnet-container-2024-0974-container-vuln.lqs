// Dragnet [Container]: dragnet-container-2024-0974 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 268595dd-e152-5fc7-83c3-0ec15cc3bacb

#event_simpleName=*
| (ImageFileName = *almalinux:8* OR ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:9* OR ImageFileName = *oraclelinux:7* OR ImageFileName = *oraclelinux:8* OR ImageFileName = *ubuntu:16.04* OR ImageFileName = *ubuntu:16.04-ESM* OR ImageFileName = *ubuntu:18.04* OR ImageFileName = *ubuntu:18.04-ESM* OR ImageFileName = *ubuntu:19.10* OR ImageFileName = *ubuntu:20.04* OR ImageFileName = *ubuntu:20.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
