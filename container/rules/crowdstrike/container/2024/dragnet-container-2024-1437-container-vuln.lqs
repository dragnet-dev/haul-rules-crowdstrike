// Dragnet [Container]: dragnet-container-2024-1437 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 945dfd29-434a-5b27-be7e-f606c8162e24

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
