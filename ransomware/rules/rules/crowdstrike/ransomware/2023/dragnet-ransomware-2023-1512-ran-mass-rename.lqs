// Dragnet [Ransomware]: dragnet-ransomware-2023-1512 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 09878dfe-39d7-53ed-a35a-3fb367d30923

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
