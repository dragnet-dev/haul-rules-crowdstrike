// Dragnet [Ransomware]: dragnet-ransomware-2026-0931 — Mass File Rename (incransom)
// Status: test | Level: high | ID: 90d03e8a-97f2-5696-be97-94be04b0c264

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
