// Dragnet [Ransomware]: dragnet-ransomware-2025-7486 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 0b976816-a44f-5d22-a062-262e896580df

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
