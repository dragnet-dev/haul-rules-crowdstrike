// Dragnet [Ransomware]: dragnet-ransomware-2024-5356 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: df30ce12-4978-5cf9-a8e9-77f1c41d2661

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
