// Dragnet [Ransomware]: dragnet-ransomware-2023-5240 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 4aebb39c-6ca5-5ec1-8792-e5eb2fb5b12e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
