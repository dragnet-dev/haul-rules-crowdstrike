// Dragnet [Ransomware]: dragnet-ransomware-2025-4907 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: ca3d57cc-6a9f-50f0-8688-a6d4a628508e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
