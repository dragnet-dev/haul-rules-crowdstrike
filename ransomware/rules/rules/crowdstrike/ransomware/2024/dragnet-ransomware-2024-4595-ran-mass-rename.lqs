// Dragnet [Ransomware]: dragnet-ransomware-2024-4595 — Mass File Rename (meow)
// Status: experimental | Level: high | ID: 9d5905e9-5067-53e7-b331-7f748ae4e243

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
