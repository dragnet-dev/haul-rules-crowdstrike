// Dragnet [Ransomware]: dragnet-ransomware-2023-1953 — Mass File Rename (royal)
// Status: deprecated | Level: high | ID: 93b0e8b0-c504-54d5-8f18-e376219dc059

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
