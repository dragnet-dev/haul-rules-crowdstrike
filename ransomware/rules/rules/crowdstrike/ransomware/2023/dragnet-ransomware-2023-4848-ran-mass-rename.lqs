// Dragnet [Ransomware]: dragnet-ransomware-2023-4848 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 9b8495b1-a7e0-5987-b3fb-f307fb1dbeac

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
