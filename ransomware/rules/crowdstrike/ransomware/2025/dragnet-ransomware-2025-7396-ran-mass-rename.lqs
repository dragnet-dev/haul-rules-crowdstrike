// Dragnet [Ransomware]: dragnet-ransomware-2025-7396 — Mass File Rename (blackshrantac)
// Status: experimental | Level: high | ID: 62139990-d73c-54ba-b443-f51d9bd9585f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
