// Dragnet [Ransomware]: dragnet-ransomware-2024-1685 — Mass File Rename (play)
// Status: experimental | Level: high | ID: f0fc1417-6b94-595f-b9ec-5b91ac90c22b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
