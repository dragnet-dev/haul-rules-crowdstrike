// Dragnet [Ransomware]: dragnet-ransomware-2023-1832 — Mass File Rename (losttrust)
// Status: deprecated | Level: high | ID: c406a69f-3101-5fc5-99bc-6cdc1335b634

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
