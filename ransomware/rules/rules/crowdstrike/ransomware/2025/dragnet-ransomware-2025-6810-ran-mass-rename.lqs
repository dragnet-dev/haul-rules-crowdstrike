// Dragnet [Ransomware]: dragnet-ransomware-2025-6810 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 99870195-dca8-5b5e-8764-0aacd2af0a41

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
