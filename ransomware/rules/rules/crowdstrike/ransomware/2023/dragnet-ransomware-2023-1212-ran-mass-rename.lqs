// Dragnet [Ransomware]: dragnet-ransomware-2023-1212 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 7ac147e4-84fc-553d-a94f-f0749bdbba44

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
