// Dragnet [Ransomware]: dragnet-ransomware-2023-0317 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 785c5dfe-08ea-59ab-96b4-07a318baa12d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
