// Dragnet [Ransomware]: dragnet-ransomware-2022-2833 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 11e17598-6365-56c9-81a7-441b1a0bd99c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
