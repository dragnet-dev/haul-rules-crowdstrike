// Dragnet [Ransomware]: dragnet-ransomware-2024-1600 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: a78b348a-bb11-5cf0-8d37-071db4f8c1dc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
