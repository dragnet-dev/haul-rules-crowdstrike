// Dragnet [Ransomware]: dragnet-ransomware-2025-7925 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: b93a2523-f190-5039-aaf7-baefe7948b6e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
