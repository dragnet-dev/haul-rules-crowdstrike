// Dragnet [Ransomware]: dragnet-ransomware-2025-0796 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 7c08069f-3353-5ce4-8914-bb51b83cefb0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
