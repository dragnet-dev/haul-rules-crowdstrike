// Dragnet [Ransomware]: dragnet-ransomware-2025-4738 — Mass File Rename (J)
// Status: experimental | Level: high | ID: e00dbff3-c659-5eb8-b877-d62740e77204

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
