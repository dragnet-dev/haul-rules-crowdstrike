// Dragnet [Ransomware]: dragnet-ransomware-2025-6324 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 5a400608-2937-5d1f-a3dd-b851da46c2c9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
