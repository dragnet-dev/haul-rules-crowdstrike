// Dragnet [Ransomware]: dragnet-ransomware-2022-0862 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 35790fe5-4c49-564d-b835-e208b9c95e9d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
