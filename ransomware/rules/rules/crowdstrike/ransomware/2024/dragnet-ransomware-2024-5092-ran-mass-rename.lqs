// Dragnet [Ransomware]: dragnet-ransomware-2024-5092 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 474b0f63-c6f5-5fd8-94f3-46c1a39943c1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
