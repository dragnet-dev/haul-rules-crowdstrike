// Dragnet [Ransomware]: dragnet-ransomware-2025-4486 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: 9a9dced9-613c-56f2-b11b-b73fb28f2947

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
