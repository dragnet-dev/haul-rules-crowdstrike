// Dragnet [Ransomware]: dragnet-ransomware-2023-1619 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 876bb992-e97c-5d64-9a26-555b20489a74

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
