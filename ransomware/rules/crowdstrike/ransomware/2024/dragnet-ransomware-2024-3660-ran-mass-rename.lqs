// Dragnet [Ransomware]: dragnet-ransomware-2024-3660 — Mass File Rename (stormous)
// Status: deprecated | Level: high | ID: 67feab5b-0a82-56e3-bab7-24187e52be2b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
