// Dragnet [Ransomware]: dragnet-ransomware-2024-1068 — Mass File Rename (knight)
// Status: experimental | Level: high | ID: 45605f74-5b53-56da-91f2-86cf99f96d3a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
