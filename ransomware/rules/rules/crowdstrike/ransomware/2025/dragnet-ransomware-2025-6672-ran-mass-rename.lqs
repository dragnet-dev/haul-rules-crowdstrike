// Dragnet [Ransomware]: dragnet-ransomware-2025-6672 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: ce18c812-d118-5a3a-84eb-e7ae77e2aebd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
