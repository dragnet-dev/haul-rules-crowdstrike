// Dragnet [Ransomware]: dragnet-ransomware-2024-3453 — Mass File Rename (arcusmedia)
// Status: experimental | Level: high | ID: 4c3db26a-0222-5b18-a6c2-74de84f64ffd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
