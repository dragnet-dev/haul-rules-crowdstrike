// Dragnet [Ransomware]: dragnet-ransomware-2025-3497 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: 71ad1c7a-e30f-5136-ab72-aa90488f7f50

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
