// Dragnet [Ransomware]: dragnet-ransomware-2025-1603 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 85a1551e-2195-50a3-82c2-59dfd9c76643

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
