// Dragnet [Ransomware]: dragnet-ransomware-2022-2452 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: 351320ba-2da7-5da3-a563-7ab2b990a9ce

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
