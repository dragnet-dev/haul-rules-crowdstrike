// Dragnet [Ransomware]: dragnet-ransomware-2022-2785 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 144ab583-e3cc-5608-8d90-c8a811801582

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
