// Dragnet [Container]: dragnet-container-2024-1100 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: e0c12e1f-5528-553d-8070-c584b143140d

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
