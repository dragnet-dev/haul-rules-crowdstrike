// Dragnet [Ransomware]: dragnet-ransomware-2025-2253 — Mass File Rename (pear)
// Status: experimental | Level: high | ID: 76997a8e-47b6-53e9-a9f3-e8fceacb859b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
