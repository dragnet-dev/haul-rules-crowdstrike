// Dragnet [Ransomware]: dragnet-ransomware-2024-1871 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: cc38982f-ea86-5958-ae49-ef5110ece57d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
