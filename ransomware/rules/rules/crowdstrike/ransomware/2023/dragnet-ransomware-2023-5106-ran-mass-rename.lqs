// Dragnet [Ransomware]: dragnet-ransomware-2023-5106 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 35066cd2-3956-55a5-856e-dca7ce8707f8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
