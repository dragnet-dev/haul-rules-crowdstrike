// Dragnet [Ransomware]: dragnet-ransomware-2023-0678 — Mass File Rename (cryptbb)
// Status: experimental | Level: high | ID: f62aac25-d3ff-54de-91f9-1b9dcfa99d84

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
