// Dragnet [Ransomware]: dragnet-ransomware-2025-1308 — Mass File Rename (payoutsking)
// Status: deprecated | Level: high | ID: 5eb28c2b-a46e-5a69-b96d-8549d3d7a04c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
