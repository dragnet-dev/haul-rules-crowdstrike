// Dragnet [Ransomware]: dragnet-ransomware-2021-0089 — Mass File Rename (avaddon)
// Status: deprecated | Level: high | ID: e59fdd98-2f28-5b11-886f-fdbe69f1a759

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
