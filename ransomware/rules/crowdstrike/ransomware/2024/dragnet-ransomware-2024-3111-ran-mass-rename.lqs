// Dragnet [Ransomware]: dragnet-ransomware-2024-3111 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: e8cbcb54-9898-5565-8df4-1ee81bfdec1e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
