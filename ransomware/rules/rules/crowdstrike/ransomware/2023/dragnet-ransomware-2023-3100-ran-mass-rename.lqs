// Dragnet [Ransomware]: dragnet-ransomware-2023-3100 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: c861049f-e6d3-5f98-846c-715b8a619dd8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
