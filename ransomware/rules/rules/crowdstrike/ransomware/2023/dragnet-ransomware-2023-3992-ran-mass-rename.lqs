// Dragnet [Ransomware]: dragnet-ransomware-2023-3992 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 5035cfde-7aa3-5666-9dac-b65e5d9fa6f2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
