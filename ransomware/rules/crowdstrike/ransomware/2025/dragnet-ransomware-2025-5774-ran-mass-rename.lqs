// Dragnet [Ransomware]: dragnet-ransomware-2025-5774 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 3d073aa1-b5e6-508a-aef4-fec05e4c2c86

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
