// Dragnet [Ransomware]: dragnet-ransomware-2024-2970 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: d8a95e12-f0cc-5298-8d0e-e1f83212bb6b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
