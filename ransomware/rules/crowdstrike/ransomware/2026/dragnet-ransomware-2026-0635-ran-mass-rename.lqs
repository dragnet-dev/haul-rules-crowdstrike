// Dragnet [Ransomware]: dragnet-ransomware-2026-0635 — Mass File Rename (embargo)
// Status: stable | Level: high | ID: b63fea7b-41f3-5cee-b3ec-a425d9c63ca9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
