// Dragnet [Ransomware]: dragnet-ransomware-2024-4456 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: d5b5ed12-4a62-58cd-bd6b-b2c1f04aaf5e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
