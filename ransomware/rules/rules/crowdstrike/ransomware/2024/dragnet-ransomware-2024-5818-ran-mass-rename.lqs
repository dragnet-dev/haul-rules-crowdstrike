// Dragnet [Ransomware]: dragnet-ransomware-2024-5818 — Mass File Rename (mogilevich)
// Status: deprecated | Level: high | ID: 31f92f3d-3794-50ee-835f-d442e1e17745

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
