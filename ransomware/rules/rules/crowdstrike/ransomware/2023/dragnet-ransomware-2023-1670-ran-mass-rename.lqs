// Dragnet [Ransomware]: dragnet-ransomware-2023-1670 — Mass File Rename (losttrust)
// Status: deprecated | Level: high | ID: 5f791a69-d967-5d69-adae-808e2e0b3f7e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
