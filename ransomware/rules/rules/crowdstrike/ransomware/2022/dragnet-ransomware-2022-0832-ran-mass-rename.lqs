// Dragnet [Ransomware]: dragnet-ransomware-2022-0832 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 80637fcd-7a52-5091-a3fc-9d86c3c4be69

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
