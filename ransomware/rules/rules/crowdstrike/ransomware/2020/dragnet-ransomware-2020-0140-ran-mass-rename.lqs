// Dragnet [Ransomware]: dragnet-ransomware-2020-0140 — Mass File Rename (maze)
// Status: deprecated | Level: high | ID: 44ea38d7-4dc3-5330-bdad-bceeef3d7a18

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
