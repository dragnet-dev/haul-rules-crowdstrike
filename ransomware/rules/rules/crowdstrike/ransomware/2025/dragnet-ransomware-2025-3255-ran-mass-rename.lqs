// Dragnet [Ransomware]: dragnet-ransomware-2025-3255 — Mass File Rename (handala)
// Status: experimental | Level: high | ID: a72e6149-0639-5602-864f-1d1688fef6de

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
