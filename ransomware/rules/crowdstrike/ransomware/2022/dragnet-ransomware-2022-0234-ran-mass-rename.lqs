// Dragnet [Ransomware]: dragnet-ransomware-2022-0234 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: f80a7fd2-8793-5bb4-b0fb-43b538a5c7d2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
