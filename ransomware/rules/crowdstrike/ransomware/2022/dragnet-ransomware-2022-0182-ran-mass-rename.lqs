// Dragnet [Ransomware]: dragnet-ransomware-2022-0182 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 8c2f9ae7-5f2c-57b3-ac5f-0ee2dade54ef

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
