// Dragnet [Ransomware]: dragnet-ransomware-2022-1059 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: cadb0c70-15dc-583d-8118-b37f250736be

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
