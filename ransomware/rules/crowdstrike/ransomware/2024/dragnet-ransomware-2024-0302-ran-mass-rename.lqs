// Dragnet [Ransomware]: dragnet-ransomware-2024-0302 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: e384ec01-17ad-5e6d-90fd-92666f2c10f0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
