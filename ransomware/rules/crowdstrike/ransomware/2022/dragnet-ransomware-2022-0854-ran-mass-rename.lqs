// Dragnet [Ransomware]: dragnet-ransomware-2022-0854 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: a7ac0154-95ec-53b4-aa58-3410c1a26e55

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
