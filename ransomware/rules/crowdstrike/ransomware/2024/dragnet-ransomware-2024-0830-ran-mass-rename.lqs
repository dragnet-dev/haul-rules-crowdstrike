// Dragnet [Ransomware]: dragnet-ransomware-2024-0830 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: b6b73342-c03d-51ab-b95e-d114474049de

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
