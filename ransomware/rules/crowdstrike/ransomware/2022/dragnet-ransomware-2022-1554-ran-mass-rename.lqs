// Dragnet [Ransomware]: dragnet-ransomware-2022-1554 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 4c220340-d05c-5f40-80d2-512115000b1b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
