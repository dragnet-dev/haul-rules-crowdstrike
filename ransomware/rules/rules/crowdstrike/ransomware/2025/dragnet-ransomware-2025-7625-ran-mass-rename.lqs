// Dragnet [Ransomware]: dragnet-ransomware-2025-7625 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: 0dabdc4c-aca3-5a34-9c4f-51fa6273fefd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
