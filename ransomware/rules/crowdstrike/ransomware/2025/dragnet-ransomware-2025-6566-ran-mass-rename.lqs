// Dragnet [Ransomware]: dragnet-ransomware-2025-6566 — Mass File Rename (lockbit5)
// Status: test | Level: high | ID: b5f3ea56-cf11-5029-8852-f37b53a88644

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
