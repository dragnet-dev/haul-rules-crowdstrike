// Dragnet [Ransomware]: dragnet-ransomware-2024-5483 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 7d04975b-34f9-5398-a97a-ccefb073b2b9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
