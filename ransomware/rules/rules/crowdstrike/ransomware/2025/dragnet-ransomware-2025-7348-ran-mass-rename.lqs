// Dragnet [Ransomware]: dragnet-ransomware-2025-7348 — Mass File Rename (worldleaks)
// Status: experimental | Level: high | ID: e9542d74-6a05-523f-9461-9a8ccb469c94

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
