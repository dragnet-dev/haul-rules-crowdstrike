// Dragnet [Ransomware]: dragnet-ransomware-2025-2031 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: a5508ab3-9910-501d-b2c2-19777365f2c7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
