// Dragnet [Ransomware]: dragnet-ransomware-2022-2607 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 40bc0699-cccd-5fcf-a200-762a7c710fff

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
