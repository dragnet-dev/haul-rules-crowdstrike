// Dragnet [Ransomware]: dragnet-ransomware-2025-6472 — Mass File Rename (ralord)
// Status: experimental | Level: high | ID: 3c44639a-eca6-51a9-9f50-4fda6bd8200f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
