// Dragnet [Ransomware]: dragnet-ransomware-2025-2595 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 0679c07b-02bc-5f8b-b1b8-d4ecf2fb2370

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
