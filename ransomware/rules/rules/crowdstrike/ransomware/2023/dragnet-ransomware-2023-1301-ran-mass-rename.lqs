// Dragnet [Ransomware]: dragnet-ransomware-2023-1301 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: e3960695-7508-5c03-9f7a-8238a88fdc90

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
