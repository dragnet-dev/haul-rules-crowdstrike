// Dragnet [Ransomware]: dragnet-ransomware-2022-0121 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 6bd8245c-0493-5002-bea1-377eb3607772

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
