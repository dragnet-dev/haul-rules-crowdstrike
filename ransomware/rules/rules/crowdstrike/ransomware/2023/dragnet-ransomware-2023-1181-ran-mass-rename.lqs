// Dragnet [Ransomware]: dragnet-ransomware-2023-1181 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 0ca91214-28ab-5b6a-8d1c-9bac21a03776

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
