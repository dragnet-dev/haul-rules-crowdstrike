// Dragnet [Ransomware]: dragnet-ransomware-2023-0335 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 20c945a8-3d7b-5d08-b4a1-73b615dc9a28

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
