// Dragnet [Ransomware]: dragnet-ransomware-2025-5900 — Mass File Rename (sinobi)
// Status: experimental | Level: high | ID: c7754388-99fa-5040-8feb-fe6dd7f34e78

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
