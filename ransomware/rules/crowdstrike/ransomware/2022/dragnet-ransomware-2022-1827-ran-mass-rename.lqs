// Dragnet [Ransomware]: dragnet-ransomware-2022-1827 — Mass File Rename (blackbasta)
// Status: deprecated | Level: high | ID: c270e1af-2d3b-5373-ab81-aae7740ca2f0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
