// Dragnet [Ransomware]: dragnet-ransomware-2024-1632 — Mass File Rename (play)
// Status: experimental | Level: high | ID: a7c2c75f-c551-5f0e-9907-ba139c863994

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
