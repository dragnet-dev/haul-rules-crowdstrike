// Dragnet [Ransomware]: dragnet-ransomware-2025-1653 — Mass File Rename (stormous)
// Status: experimental | Level: high | ID: 1a24b9bf-bb40-5b8d-86ad-a3cae9fd78f0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
