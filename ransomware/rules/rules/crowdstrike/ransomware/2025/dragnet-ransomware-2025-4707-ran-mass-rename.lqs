// Dragnet [Ransomware]: dragnet-ransomware-2025-4707 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 8c762cd3-6c9a-5b74-8a3d-6af6128fd9ed

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
