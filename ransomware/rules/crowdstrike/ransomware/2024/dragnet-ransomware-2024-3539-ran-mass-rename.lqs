// Dragnet [Ransomware]: dragnet-ransomware-2024-3539 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 98892b74-4cef-56a4-b175-df685967c8dc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
