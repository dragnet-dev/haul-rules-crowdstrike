// Dragnet [Ransomware]: dragnet-ransomware-2024-5318 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 75913128-6632-5f08-ba71-0823a4130445

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
