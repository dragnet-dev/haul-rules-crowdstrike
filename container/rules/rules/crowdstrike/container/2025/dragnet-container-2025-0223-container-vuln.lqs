// Dragnet [Container]: dragnet-container-2025-0223 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 82a7581b-f89e-57ee-833e-2e3500cc37a4

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
