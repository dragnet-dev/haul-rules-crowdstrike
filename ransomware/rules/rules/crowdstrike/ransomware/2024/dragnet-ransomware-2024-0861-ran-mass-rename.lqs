// Dragnet [Ransomware]: dragnet-ransomware-2024-0861 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: bafd9c39-e08e-5e3a-accd-cd720eab308d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
