// Dragnet [Ransomware]: dragnet-ransomware-2022-0097 — Mass File Rename (quantum)
// Status: deprecated | Level: high | ID: 96143a37-1ca1-50ee-8d42-919db8c1aa3d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
