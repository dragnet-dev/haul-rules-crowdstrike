// Dragnet [Ransomware]: dragnet-ransomware-2025-4054 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 12d1f8e3-f264-5a03-a694-17db1ed833ee

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
