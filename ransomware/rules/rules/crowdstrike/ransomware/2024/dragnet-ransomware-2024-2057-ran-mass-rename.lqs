// Dragnet [Ransomware]: dragnet-ransomware-2024-2057 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: a59f8b01-54fb-58c4-a6ab-fea34114cf2a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
