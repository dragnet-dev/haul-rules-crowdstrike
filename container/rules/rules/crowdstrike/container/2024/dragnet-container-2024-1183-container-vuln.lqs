// Dragnet [Container]: dragnet-container-2024-1183 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 4b2fa554-de22-5230-8b1b-899eda1023d2

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:9* OR ImageFileName = *ubuntu:16.04* OR ImageFileName = *ubuntu:16.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
