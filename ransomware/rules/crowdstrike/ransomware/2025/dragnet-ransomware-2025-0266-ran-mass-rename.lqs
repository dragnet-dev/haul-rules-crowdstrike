// Dragnet [Ransomware]: dragnet-ransomware-2025-0266 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: fb761e9f-4b48-5b5f-baea-1c8a7dbb093b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
