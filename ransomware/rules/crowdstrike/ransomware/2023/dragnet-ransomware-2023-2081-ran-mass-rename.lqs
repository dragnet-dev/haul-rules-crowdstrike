// Dragnet [Ransomware]: dragnet-ransomware-2023-2081 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 23ed64e8-f60e-56d2-928c-607336f77d68

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
