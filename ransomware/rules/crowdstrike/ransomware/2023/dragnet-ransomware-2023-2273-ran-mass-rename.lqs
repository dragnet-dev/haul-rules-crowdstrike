// Dragnet [Ransomware]: dragnet-ransomware-2023-2273 — Mass File Rename (rhysida)
// Status: deprecated | Level: high | ID: 796f1fd0-a9c5-5c08-87a4-739f25f8f884

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
