// Dragnet [Container]: dragnet-container-2025-0597 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 5c88b1b0-9900-5257-ba72-d0fb3fb7d72d

#event_simpleName=*
| (ImageFileName = *almalinux:8* OR ImageFileName = *cbl-mariner:2.0* OR ImageFileName = *chainguard:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:8* OR ImageFileName = *photon os:4.0* OR ImageFileName = *photon os:5.0* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:22.04* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
