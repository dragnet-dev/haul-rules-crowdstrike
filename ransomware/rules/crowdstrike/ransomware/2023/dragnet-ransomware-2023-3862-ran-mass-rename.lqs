// Dragnet [Ransomware]: dragnet-ransomware-2023-3862 — Mass File Rename (donutleaks)
// Status: experimental | Level: high | ID: c968bd1d-cc74-5dc3-a939-e882d7d8c7fd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
