// Dragnet [Ransomware]: dragnet-ransomware-2021-0612 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 5474bd61-314b-533e-95c8-fae12cc40ad1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
