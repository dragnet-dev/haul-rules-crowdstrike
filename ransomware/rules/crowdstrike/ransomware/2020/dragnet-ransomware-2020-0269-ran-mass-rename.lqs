// Dragnet [Ransomware]: dragnet-ransomware-2020-0269 — Mass File Rename (revil)
// Status: deprecated | Level: high | ID: 4433bb0c-c688-5ad3-8ba5-a70723f60740

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
