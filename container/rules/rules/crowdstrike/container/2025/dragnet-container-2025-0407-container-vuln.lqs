// Dragnet [Container]: dragnet-container-2025-0407 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 06306147-07df-5c11-bd4c-d845dbfae390

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:8* OR ImageFileName = *debian:9* OR ImageFileName = *ubuntu:16.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
