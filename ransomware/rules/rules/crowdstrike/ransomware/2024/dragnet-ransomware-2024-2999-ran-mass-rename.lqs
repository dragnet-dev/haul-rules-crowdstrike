// Dragnet [Ransomware]: dragnet-ransomware-2024-2999 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 4fd5a6cd-2794-5817-9e2b-aa0e80f9a97b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
