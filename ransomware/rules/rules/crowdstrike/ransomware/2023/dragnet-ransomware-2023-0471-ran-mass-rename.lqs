// Dragnet [Ransomware]: dragnet-ransomware-2023-0471 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: dcb192e0-93d7-514b-b299-8406859d614f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
