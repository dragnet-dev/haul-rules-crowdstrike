// Dragnet [Ransomware]: dragnet-ransomware-2024-1486 — Mass File Rename (apt73)
// Status: experimental | Level: high | ID: e654c419-dbce-5ed6-939f-ab00dc7089ef

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
