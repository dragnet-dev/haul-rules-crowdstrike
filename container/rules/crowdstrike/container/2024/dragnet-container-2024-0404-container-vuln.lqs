// Dragnet [Container]: dragnet-container-2024-0404 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 69c0a454-3092-563f-879a-399a1e6f027f

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:9* OR ImageFileName = *ubuntu:18.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
