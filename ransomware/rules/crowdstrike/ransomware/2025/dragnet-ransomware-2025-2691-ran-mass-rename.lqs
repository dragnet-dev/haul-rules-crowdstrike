// Dragnet [Ransomware]: dragnet-ransomware-2025-2691 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 52e37e57-6bdc-506c-85df-970c44d5563c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
