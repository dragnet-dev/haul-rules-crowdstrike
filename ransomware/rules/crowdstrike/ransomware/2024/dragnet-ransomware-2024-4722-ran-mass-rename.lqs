// Dragnet [Ransomware]: dragnet-ransomware-2024-4722 — Mass File Rename (darkvault)
// Status: experimental | Level: high | ID: b4b1f7c7-fa05-5ac2-95d6-368ec1a4b4fa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
