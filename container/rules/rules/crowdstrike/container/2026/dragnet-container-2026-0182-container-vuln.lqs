// Dragnet [Container]: dragnet-container-2026-0182 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 317ccf0d-b6cc-5f00-901a-61a8995fd857

#event_simpleName=*
| (ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *redhat/ubi9:*)
| table([timestamp, ComputerName])
| limit(1000)
