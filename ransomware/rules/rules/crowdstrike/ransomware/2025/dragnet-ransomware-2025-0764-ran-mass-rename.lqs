// Dragnet [Ransomware]: dragnet-ransomware-2025-0764 — Mass File Rename (kraken)
// Status: experimental | Level: high | ID: 3b7ce071-bca3-5d24-b767-5b163b76489f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
