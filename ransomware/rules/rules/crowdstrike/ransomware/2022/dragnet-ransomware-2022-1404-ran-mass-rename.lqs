// Dragnet [Ransomware]: dragnet-ransomware-2022-1404 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 4bd2e949-297b-53d4-b20b-0025e19037b5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
