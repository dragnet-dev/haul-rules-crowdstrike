// Dragnet [Ransomware]: dragnet-ransomware-2025-1384 — Mass File Rename (payoutsking)
// Status: test | Level: high | ID: 6893a11f-3f64-5789-9a0e-17366a16cc15

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
