// Dragnet [Ransomware]: dragnet-ransomware-2023-3968 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 94e2d302-944a-573e-86ef-582c07611af3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
