// Dragnet [Ransomware]: dragnet-ransomware-2023-5206 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 495ed649-05b4-5e52-8f95-a312d707dca3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
