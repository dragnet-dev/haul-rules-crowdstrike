// Dragnet [Ransomware]: dragnet-ransomware-2023-2942 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 397b735a-c821-528d-a216-73277ba792ea

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
