// Dragnet [Ransomware]: dragnet-ransomware-2022-1582 — Mass File Rename (snatch)
// Status: experimental | Level: high | ID: bbd35ebe-ff86-5aa9-ae31-e895aec55f28

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
