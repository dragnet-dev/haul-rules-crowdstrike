// Dragnet [Ransomware]: dragnet-ransomware-2025-0040 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: f4527ff8-7cb0-56cd-b12f-0861ba335c99

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
