// Dragnet [Ransomware]: dragnet-ransomware-2026-1937 — Mass File Rename (spacebears)
// Status: stable | Level: high | ID: 63e0c2c8-9301-5a45-8d6b-91755a802322

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
