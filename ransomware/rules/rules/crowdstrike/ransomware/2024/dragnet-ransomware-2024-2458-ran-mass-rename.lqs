// Dragnet [Ransomware]: dragnet-ransomware-2024-2458 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: d3b00234-702c-5234-ac18-7f418cb0347e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
