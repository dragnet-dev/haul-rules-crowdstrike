// Dragnet [Ransomware]: dragnet-ransomware-2025-7690 — Mass File Rename (blacknevas)
// Status: experimental | Level: high | ID: 00723533-4611-5f71-8ce3-ce9f4be9f4a4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
