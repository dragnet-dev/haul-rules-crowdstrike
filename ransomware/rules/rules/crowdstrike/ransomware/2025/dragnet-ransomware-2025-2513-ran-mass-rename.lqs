// Dragnet [Ransomware]: dragnet-ransomware-2025-2513 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: efedac6b-d0f8-5a5a-a07d-e6df8f38d417

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
