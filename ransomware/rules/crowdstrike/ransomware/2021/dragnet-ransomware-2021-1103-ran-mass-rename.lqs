// Dragnet [Ransomware]: dragnet-ransomware-2021-1103 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: d6c86313-6646-5044-8abe-080fd5f637b7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
