// Dragnet [Ransomware]: dragnet-ransomware-2025-7591 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: c7b5a238-f845-57dd-bcdc-00d584f994be

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
