// Dragnet [Ransomware]: dragnet-ransomware-2023-2849 — Mass File Rename (malas)
// Status: experimental | Level: high | ID: 58eec869-731e-5193-ba67-9ed61bf4c7b9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
