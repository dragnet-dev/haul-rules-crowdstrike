// Dragnet [Ransomware]: dragnet-ransomware-2025-7326 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 3f3ca265-341e-5554-81ff-862f9582790b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
