// Dragnet [Container]: dragnet-container-2026-1081 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: efd72b11-36d3-5701-95bc-5baabe679ef5

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:7*)
| table([timestamp, ComputerName])
| limit(1000)
