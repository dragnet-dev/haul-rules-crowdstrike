// Dragnet [Ransomware]: dragnet-ransomware-2025-2801 — Mass File Rename (nightspire)
// Status: deprecated | Level: high | ID: 5ccd2286-5aef-567a-93b1-5473538290a7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
