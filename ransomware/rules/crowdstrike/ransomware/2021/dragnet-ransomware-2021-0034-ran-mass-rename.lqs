// Dragnet [Ransomware]: dragnet-ransomware-2021-0034 — Mass File Rename (spook)
// Status: deprecated | Level: high | ID: ee2a1846-befa-5faa-b1e5-e890c7fdfac4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
