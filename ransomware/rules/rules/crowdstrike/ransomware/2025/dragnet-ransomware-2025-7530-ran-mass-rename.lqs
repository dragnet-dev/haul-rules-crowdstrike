// Dragnet [Ransomware]: dragnet-ransomware-2025-7530 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 4679f8d3-dfe4-55bf-ab22-e345b0560756

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
