// Dragnet [Ransomware]: dragnet-ransomware-2025-4769 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: d40f5875-5d1b-5ece-9e6f-a5e6880fa461

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
