// Dragnet [Ransomware]: dragnet-ransomware-2024-5207 — Mass File Rename (cloak)
// Status: deprecated | Level: high | ID: 26859a87-e7e0-590f-ae67-bde79bc49f0f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
