// Dragnet [Ransomware]: dragnet-ransomware-2021-0244 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: c1287bc5-e2d7-5595-9053-1446d539b7d1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
