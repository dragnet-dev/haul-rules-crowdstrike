// Dragnet [Ransomware]: dragnet-ransomware-2022-2501 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: f9338eff-127c-5a80-a302-ff6669181ca9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
