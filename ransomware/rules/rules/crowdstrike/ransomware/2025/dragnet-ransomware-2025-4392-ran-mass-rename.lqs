// Dragnet [Ransomware]: dragnet-ransomware-2025-4392 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 62a2267d-9dfd-5e59-80b6-61d44ae4d4e5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
