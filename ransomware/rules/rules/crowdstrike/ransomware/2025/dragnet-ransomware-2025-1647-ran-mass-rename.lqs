// Dragnet [Ransomware]: dragnet-ransomware-2025-1647 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: f9a8e554-2e2b-51ca-b8c1-66a3ce9fb07d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
