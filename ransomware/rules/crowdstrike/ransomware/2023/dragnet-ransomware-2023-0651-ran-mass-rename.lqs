// Dragnet [Ransomware]: dragnet-ransomware-2023-0651 — Mass File Rename (noescape)
// Status: experimental | Level: high | ID: 392f5325-32a4-5b22-9c85-486eba66b730

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
