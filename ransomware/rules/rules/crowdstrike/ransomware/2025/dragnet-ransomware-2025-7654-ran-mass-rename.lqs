// Dragnet [Ransomware]: dragnet-ransomware-2025-7654 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 2fc20dab-801d-51b5-975b-570066a3ad37

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
