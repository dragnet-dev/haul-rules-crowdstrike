// Dragnet [Ransomware]: dragnet-ransomware-2026-1152 — Mass File Rename (thegentlemen)
// Status: stable | Level: high | ID: 2d684a3e-e3d8-5657-b7ff-16222ab08917

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
