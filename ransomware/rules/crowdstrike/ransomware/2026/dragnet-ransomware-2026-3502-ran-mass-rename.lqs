// Dragnet [Ransomware]: dragnet-ransomware-2026-3502 — Mass File Rename (interlock)
// Status: stable | Level: high | ID: 71dc1007-1db0-5bd8-9629-0c2da7986cf0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
