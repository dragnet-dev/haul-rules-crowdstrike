// Dragnet [Ransomware]: dragnet-ransomware-2022-0466 — Mass File Rename (avoslocker)
// Status: deprecated | Level: high | ID: d5a38de2-d537-5477-a5b1-576758c7a9fe

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
