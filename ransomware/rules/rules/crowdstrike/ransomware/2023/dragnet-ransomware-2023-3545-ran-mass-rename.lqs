// Dragnet [Ransomware]: dragnet-ransomware-2023-3545 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 29f7915f-ccb2-50c3-bd00-19aec0cbf8a4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
