// Dragnet [Ransomware]: dragnet-ransomware-2026-3268 — Mass File Rename (dragonforce)
// Status: stable | Level: high | ID: 985fcb49-da36-5f24-98c3-7330d5a9cb6b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
