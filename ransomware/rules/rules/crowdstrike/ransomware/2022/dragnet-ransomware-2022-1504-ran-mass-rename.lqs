// Dragnet [Ransomware]: dragnet-ransomware-2022-1504 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: 880d07bf-98d7-526d-bfe3-23024dc60a64

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
