// Dragnet [Ransomware]: dragnet-ransomware-2022-2542 — Mass File Rename (everest)
// Status: deprecated | Level: high | ID: 34529a96-d3be-5a1a-9f68-a6f6e833c578

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
