// Dragnet [Ransomware]: dragnet-ransomware-2023-3177 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 91786a53-bdea-5318-a0f6-199655fdf59a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
