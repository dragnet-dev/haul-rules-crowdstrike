// Dragnet [Ransomware]: dragnet-ransomware-2025-1612 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 4630f402-68c5-5cf6-871e-dba39b61373f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
