// Dragnet [Ransomware]: dragnet-ransomware-2026-2496 — Mass File Rename (nightspire)
// Status: deprecated | Level: high | ID: 8b6781ab-d13e-54f6-afb6-48e12e2d129f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
