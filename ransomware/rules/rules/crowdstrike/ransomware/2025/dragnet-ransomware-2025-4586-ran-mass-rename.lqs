// Dragnet [Ransomware]: dragnet-ransomware-2025-4586 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: 0f69f16d-c0b7-58dd-879c-a74f6454134b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
