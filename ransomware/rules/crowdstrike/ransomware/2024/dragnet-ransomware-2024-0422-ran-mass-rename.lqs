// Dragnet [Ransomware]: dragnet-ransomware-2024-0422 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: a984ac03-1376-5e25-8e51-771094ddbe6f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
