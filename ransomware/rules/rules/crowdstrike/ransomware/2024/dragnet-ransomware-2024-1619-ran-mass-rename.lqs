// Dragnet [Ransomware]: dragnet-ransomware-2024-1619 — Mass File Rename (blacklock)
// Status: experimental | Level: high | ID: f5f68c71-3a1c-5f7b-9b65-3b0b4147f120

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
