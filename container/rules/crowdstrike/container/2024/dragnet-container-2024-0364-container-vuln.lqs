// Dragnet [Container]: dragnet-container-2024-0364 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 163066c1-6402-59f5-8eea-75ef1182f9ec

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:8* OR ImageFileName = *debian:9* OR ImageFileName = *ubuntu:18.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
