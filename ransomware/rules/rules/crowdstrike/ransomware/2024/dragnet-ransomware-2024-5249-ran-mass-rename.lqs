// Dragnet [Ransomware]: dragnet-ransomware-2024-5249 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 29306f2f-bba3-5965-b2d9-2b2b0d6be6a4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
