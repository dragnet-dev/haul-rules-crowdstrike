// Dragnet [Ransomware]: dragnet-ransomware-2022-1482 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 6fb46616-286e-5c60-8862-f3d031608022

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
