// Dragnet [Ransomware]: dragnet-ransomware-2025-5622 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 138d8012-d5bf-54b6-a455-7e08c87a6a7d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
