// Dragnet [Ransomware]: dragnet-ransomware-2023-2816 — Mass File Rename (malas)
// Status: experimental | Level: high | ID: b78ec862-2261-5a47-97e6-94cd92d8535c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
