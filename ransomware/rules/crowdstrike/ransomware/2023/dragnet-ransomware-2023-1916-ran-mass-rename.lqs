// Dragnet [Ransomware]: dragnet-ransomware-2023-1916 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: c2aae2e7-800f-5c2e-8baa-9012814c73c2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
