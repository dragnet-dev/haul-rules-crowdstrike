// Dragnet [Ransomware]: dragnet-ransomware-2026-1828 — Mass File Rename (krybit)
// Status: stable | Level: high | ID: dea2513f-02d9-5f3a-b28c-a99ef5f051c7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
