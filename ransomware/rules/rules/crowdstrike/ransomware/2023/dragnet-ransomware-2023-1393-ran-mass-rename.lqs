// Dragnet [Ransomware]: dragnet-ransomware-2023-1393 — Mass File Rename (mallox)
// Status: deprecated | Level: high | ID: fa9f7d15-aa33-55c7-9637-b6eea40d3478

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
