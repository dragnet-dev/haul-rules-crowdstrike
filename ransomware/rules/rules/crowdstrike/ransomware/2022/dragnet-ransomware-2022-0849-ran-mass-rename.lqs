// Dragnet [Ransomware]: dragnet-ransomware-2022-0849 — Mass File Rename (cuba)
// Status: deprecated | Level: high | ID: 3b63936f-4c7e-5484-b1ed-c061dce06544

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
