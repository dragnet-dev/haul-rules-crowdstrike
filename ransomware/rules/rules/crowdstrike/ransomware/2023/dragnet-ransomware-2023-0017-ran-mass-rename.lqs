// Dragnet [Ransomware]: dragnet-ransomware-2023-0017 — Mass File Rename (threeam)
// Status: experimental | Level: high | ID: 1a1b0dba-d424-5653-9958-3cf787b1058f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
