// Dragnet [Container]: dragnet-container-2026-1246 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 2386316b-ce4e-5345-8da1-7e141c58f8a6

#event_simpleName=*
| (ImageFileName = *debian:7* OR ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10* OR ImageFileName = *ubuntu:13.04*)
| table([timestamp, ComputerName])
| limit(1000)
