// Dragnet [Ransomware]: dragnet-ransomware-2022-2477 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 4e2a6913-24e8-5910-a0ed-4c2d29cc7dbc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
