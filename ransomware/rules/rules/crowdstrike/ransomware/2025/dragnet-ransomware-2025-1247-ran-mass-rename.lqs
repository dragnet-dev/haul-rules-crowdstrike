// Dragnet [Ransomware]: dragnet-ransomware-2025-1247 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 730b0061-aa33-5214-b343-b612e44b70b2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
