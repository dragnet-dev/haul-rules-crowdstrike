// Dragnet [Ransomware]: dragnet-ransomware-2025-2306 — Mass File Rename (nova)
// Status: experimental | Level: high | ID: 0938be6b-01b8-5dcc-8377-d0112d271141

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
