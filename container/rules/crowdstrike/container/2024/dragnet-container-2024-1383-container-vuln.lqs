// Dragnet [Container]: dragnet-container-2024-1383 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 69dfa28a-8edf-5172-a13a-b48424043920

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:9*)
| table([timestamp, ComputerName])
| limit(1000)
