// Dragnet [Ransomware]: dragnet-ransomware-2022-2524 — Mass File Rename (shaoleaks)
// Status: deprecated | Level: high | ID: fc96c9fc-7e1a-5753-8ff7-39183c7ad87c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
