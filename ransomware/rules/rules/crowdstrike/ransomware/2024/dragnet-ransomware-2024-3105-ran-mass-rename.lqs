// Dragnet [Ransomware]: dragnet-ransomware-2024-3105 — Mass File Rename (helldown)
// Status: experimental | Level: high | ID: 966f56ce-c487-5f21-a313-7f1a8c3d5c50

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
