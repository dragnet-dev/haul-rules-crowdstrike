// Dragnet [Ransomware]: dragnet-ransomware-2024-3186 — Mass File Rename (arcusmedia)
// Status: experimental | Level: high | ID: 2fb05ab3-7c1a-508a-abe6-46cdc5a89da6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
