// Dragnet [Ransomware]: dragnet-ransomware-2023-0534 — Mass File Rename (play)
// Status: experimental | Level: high | ID: bf2c9414-015f-57c9-ad1d-fb58545f69ab

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
