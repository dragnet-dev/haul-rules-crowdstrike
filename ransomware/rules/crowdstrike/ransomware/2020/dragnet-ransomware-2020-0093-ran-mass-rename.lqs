// Dragnet [Ransomware]: dragnet-ransomware-2020-0093 — Mass File Rename (ragnarlocker)
// Status: deprecated | Level: high | ID: 78cfaad6-357d-5ace-81b6-7fe01f937c5f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
