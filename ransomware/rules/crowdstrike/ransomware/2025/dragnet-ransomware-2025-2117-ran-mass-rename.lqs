// Dragnet [Ransomware]: dragnet-ransomware-2025-2117 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: e637e5ae-b28a-5d87-8b39-1a8837577f8b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
