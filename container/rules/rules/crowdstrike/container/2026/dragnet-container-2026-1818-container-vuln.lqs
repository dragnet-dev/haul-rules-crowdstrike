// Dragnet [Container]: dragnet-container-2026-1818 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 38cf47ca-e0e5-5637-8217-3646409462af

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
