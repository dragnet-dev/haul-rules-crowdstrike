// Dragnet [Ransomware]: dragnet-ransomware-2022-0689 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 8f07289d-caa6-55b3-bfde-c37833b7a4db

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
