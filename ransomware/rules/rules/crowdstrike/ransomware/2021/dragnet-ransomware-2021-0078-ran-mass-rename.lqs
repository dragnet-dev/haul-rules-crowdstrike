// Dragnet [Ransomware]: dragnet-ransomware-2021-0078 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: ea764430-7888-55e7-be2b-05381abedf47

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
