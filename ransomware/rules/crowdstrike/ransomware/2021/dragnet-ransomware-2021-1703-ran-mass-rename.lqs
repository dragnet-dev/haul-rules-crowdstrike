// Dragnet [Ransomware]: dragnet-ransomware-2021-1703 — Mass File Rename (mountlocker)
// Status: deprecated | Level: high | ID: 9c24955e-e683-5473-9c79-b3a590b1e9a1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
