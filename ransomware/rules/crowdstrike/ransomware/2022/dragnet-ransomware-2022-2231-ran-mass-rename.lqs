// Dragnet [Ransomware]: dragnet-ransomware-2022-2231 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 2c8c2d9d-4263-5533-b00f-721fade53938

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
