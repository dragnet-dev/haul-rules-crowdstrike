// Dragnet [Ransomware]: dragnet-ransomware-2025-4245 — Mass File Rename (play)
// Status: experimental | Level: high | ID: d3a13e70-a8d5-553d-86c3-a471aec889e8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
