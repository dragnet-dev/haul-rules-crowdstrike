// Dragnet [Ransomware]: dragnet-ransomware-2021-0596 — Mass File Rename (spook)
// Status: deprecated | Level: high | ID: 3ee0c8c8-0a7e-5441-be72-46863f3e9a1a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
