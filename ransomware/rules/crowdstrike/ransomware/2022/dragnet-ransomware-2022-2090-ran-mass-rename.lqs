// Dragnet [Ransomware]: dragnet-ransomware-2022-2090 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: ec515241-5bc2-560a-bb21-5463e143bfb4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
