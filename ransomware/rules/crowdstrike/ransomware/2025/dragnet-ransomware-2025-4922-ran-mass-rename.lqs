// Dragnet [Ransomware]: dragnet-ransomware-2025-4922 — Mass File Rename (payoutsking)
// Status: deprecated | Level: high | ID: 9ba14695-a590-5b50-a5dc-2aa20beefcfe

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
