// Dragnet [Ransomware]: dragnet-ransomware-2026-2375 — Mass File Rename (kairos)
// Status: deprecated | Level: high | ID: c46f4f3f-f109-546d-a8f8-1bfa0f9b7426

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
