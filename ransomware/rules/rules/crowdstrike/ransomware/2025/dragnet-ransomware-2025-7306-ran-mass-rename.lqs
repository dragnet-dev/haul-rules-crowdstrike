// Dragnet [Ransomware]: dragnet-ransomware-2025-7306 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: 6cbc6ce4-4262-562a-8fc5-725090841fb7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
