// Dragnet [Ransomware]: dragnet-ransomware-2022-1681 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 1e709ddf-fadb-550f-b669-8ee760f7d232

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
