// Status: deprecated | Level: critical | ID: 5b5d15ac-abac-5757-9717-54fea7002221

#event_simpleName=*
| (ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:14.04* OR ImageFileName = *ubuntu:14.10*)
| table([timestamp, ComputerName])
| limit(1000)
