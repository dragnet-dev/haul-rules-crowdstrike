// Dragnet [Ransomware]: dragnet-ransomware-2025-7720 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 659538de-f1c0-56f9-9ea2-9bd2b558cfdf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
