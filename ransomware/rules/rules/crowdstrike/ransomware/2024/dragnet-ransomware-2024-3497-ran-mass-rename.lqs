// Dragnet [Ransomware]: dragnet-ransomware-2024-3497 — Mass File Rename (bluebox)
// Status: experimental | Level: high | ID: a4b4ba24-27cb-51c1-b89c-3f066c052b99

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
