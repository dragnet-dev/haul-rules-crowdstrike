// Dragnet [Ransomware]: dragnet-ransomware-2025-7560 — Mass File Rename (lockbit5)
// Status: experimental | Level: high | ID: 239b4667-6a4e-5b50-8240-0492a85aea64

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
