// Dragnet [Ransomware]: dragnet-ransomware-2024-2989 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 3e8a6107-a8c9-5bab-8f4d-0e7979e81fdc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
