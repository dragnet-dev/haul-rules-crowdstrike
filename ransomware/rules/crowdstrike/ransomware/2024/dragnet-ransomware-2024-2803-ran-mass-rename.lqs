// Dragnet [Ransomware]: dragnet-ransomware-2024-2803 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 3490b7ea-d075-55f7-a4be-a9ead182fe2f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
