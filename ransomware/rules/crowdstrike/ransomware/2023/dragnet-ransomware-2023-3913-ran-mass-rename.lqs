// Dragnet [Ransomware]: dragnet-ransomware-2023-3913 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 7f7d44d0-3d7f-55d6-9d5e-d3a9bbc2b272

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
