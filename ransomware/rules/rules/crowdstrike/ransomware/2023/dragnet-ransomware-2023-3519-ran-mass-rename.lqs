// Dragnet [Ransomware]: dragnet-ransomware-2023-3519 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 61cfbd44-2537-5585-b839-b319987f86a1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
