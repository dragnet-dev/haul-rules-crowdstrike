// Dragnet [Ransomware]: dragnet-ransomware-2024-5794 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 6d312028-d985-5d67-9722-f6bb144e1690

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
