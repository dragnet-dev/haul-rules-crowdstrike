// Dragnet [Ransomware]: dragnet-ransomware-2024-0165 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: 180f3e94-cb42-5407-af8d-2d7e1e437225

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
