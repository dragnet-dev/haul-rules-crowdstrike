// Dragnet [Ransomware]: dragnet-ransomware-2022-0564 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: b1c8a22c-0b39-55f5-955a-ea17887c5622

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
