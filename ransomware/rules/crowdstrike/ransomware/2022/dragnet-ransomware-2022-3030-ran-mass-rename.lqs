// Dragnet [Ransomware]: dragnet-ransomware-2022-3030 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 75598913-85b1-582f-b25f-98e0d33f3e4b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
