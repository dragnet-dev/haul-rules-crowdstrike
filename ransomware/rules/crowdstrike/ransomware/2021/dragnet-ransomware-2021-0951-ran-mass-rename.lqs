// Dragnet [Ransomware]: dragnet-ransomware-2021-0951 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 245ebd6e-9b9c-5755-8536-d8c1e40793e8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
