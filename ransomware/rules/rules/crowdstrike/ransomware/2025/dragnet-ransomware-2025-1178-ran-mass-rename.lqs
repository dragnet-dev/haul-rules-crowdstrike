// Dragnet [Ransomware]: dragnet-ransomware-2025-1178 — Mass File Rename (pear)
// Status: experimental | Level: high | ID: b8f43640-3bff-5042-85b1-fa92397a3f7b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
