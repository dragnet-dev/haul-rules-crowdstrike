// Dragnet [Ransomware]: dragnet-ransomware-2025-4426 — Mass File Rename (direwolf)
// Status: experimental | Level: high | ID: 09cdaca6-6edf-5152-ab4e-e0e0a3b4f977

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
