// Dragnet [Ransomware]: dragnet-ransomware-2024-4374 — Mass File Rename (helldown)
// Status: experimental | Level: high | ID: 5bf65ec9-06ce-550b-b1ca-d904caa7006b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
