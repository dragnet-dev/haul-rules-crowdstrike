// Dragnet [Ransomware]: dragnet-ransomware-2021-0765 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 703df785-6d58-52c2-8038-c48b26770fb6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
