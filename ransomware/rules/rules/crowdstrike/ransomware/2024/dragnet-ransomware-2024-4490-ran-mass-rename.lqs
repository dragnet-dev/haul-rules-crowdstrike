// Dragnet [Ransomware]: dragnet-ransomware-2024-4490 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: d18c4442-cded-5dd6-b1b6-a38487c4e79f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
