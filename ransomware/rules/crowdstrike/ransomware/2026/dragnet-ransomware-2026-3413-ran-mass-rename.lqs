// Dragnet [Ransomware]: dragnet-ransomware-2026-3413 — Mass File Rename (dragonforce)
// Status: stable | Level: high | ID: 5642f33b-a0ce-516b-a7ee-3e919b4a71a1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
