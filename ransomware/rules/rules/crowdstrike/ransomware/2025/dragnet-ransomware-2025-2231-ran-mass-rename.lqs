// Dragnet [Ransomware]: dragnet-ransomware-2025-2231 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: d610433d-61e2-536c-88c5-ea7e78f612d0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
