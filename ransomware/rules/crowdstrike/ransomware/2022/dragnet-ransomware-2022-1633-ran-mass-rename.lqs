// Dragnet [Ransomware]: dragnet-ransomware-2022-1633 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: eae1ad16-96fe-5a38-887c-5200c27885f8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
