// Dragnet [Container]: dragnet-container-2024-1425 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 3d602a8c-7e05-5be6-84db-a2c2520aef09

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:9* OR ImageFileName = *redhat/ubi9:*)
| table([timestamp, ComputerName])
| limit(1000)
