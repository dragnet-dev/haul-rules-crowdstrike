// Dragnet [Ransomware]: dragnet-ransomware-2025-3683 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: ca8f19f8-852f-512a-8474-2263904940c3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
