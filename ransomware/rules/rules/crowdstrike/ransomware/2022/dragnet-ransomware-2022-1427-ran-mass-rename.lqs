// Dragnet [Ransomware]: dragnet-ransomware-2022-1427 — Mass File Rename (play)
// Status: deprecated | Level: high | ID: c193e0c2-d247-57ec-9d71-b7a25d90047a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
