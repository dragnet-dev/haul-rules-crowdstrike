// Dragnet [Container]: dragnet-container-2026-2021 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 173354c1-5139-5c74-823e-808009b9a04c

#event_simpleName=*
| (ImageFileName = *amazonlinux:1* OR ImageFileName = *debian:7* OR ImageFileName = *debian:8* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:14.04* OR ImageFileName = *ubuntu:14.04-ESM* OR ImageFileName = *ubuntu:16.04* OR ImageFileName = *ubuntu:16.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
