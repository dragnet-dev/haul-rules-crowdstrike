// Dragnet [Ransomware]: dragnet-ransomware-2021-1187 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 833b55a6-ff39-5b19-bd39-aa06ccf6a8b4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
