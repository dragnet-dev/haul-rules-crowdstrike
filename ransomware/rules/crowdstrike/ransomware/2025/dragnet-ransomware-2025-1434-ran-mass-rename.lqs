// Dragnet [Ransomware]: dragnet-ransomware-2025-1434 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: fa8bea3b-db9f-5482-9509-0ba792a27503

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
