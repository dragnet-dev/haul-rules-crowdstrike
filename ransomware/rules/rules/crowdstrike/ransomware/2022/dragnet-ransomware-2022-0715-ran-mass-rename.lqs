// Dragnet [Ransomware]: dragnet-ransomware-2022-0715 — Mass File Rename (alphv)
// Status: deprecated | Level: high | ID: a8cf6503-39c6-5317-92ec-b06136aa08dc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
