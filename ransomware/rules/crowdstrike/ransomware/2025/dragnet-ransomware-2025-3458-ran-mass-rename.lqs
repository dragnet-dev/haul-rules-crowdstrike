// Dragnet [Ransomware]: dragnet-ransomware-2025-3458 — Mass File Rename (flocker)
// Status: experimental | Level: high | ID: d5d4e820-8ec0-5772-b5df-0f4e1fcba276

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
