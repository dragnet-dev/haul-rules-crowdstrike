// Dragnet [Ransomware]: dragnet-ransomware-2024-4311 — Mass File Rename (safepay)
// Status: deprecated | Level: high | ID: a2903c0f-d075-52fb-b2d4-5129a159aa0d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
