// Dragnet [Ransomware]: dragnet-ransomware-2024-0182 — Mass File Rename (play)
// Status: experimental | Level: high | ID: ba81b08a-9684-536a-bd5c-a8c13f26341d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
