// Dragnet [Ransomware]: dragnet-ransomware-2025-1045 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 8fb192cd-bcc0-5442-b3b7-c1b6ea4f942c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
