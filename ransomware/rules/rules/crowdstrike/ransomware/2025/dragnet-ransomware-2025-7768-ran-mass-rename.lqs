// Dragnet [Ransomware]: dragnet-ransomware-2025-7768 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: d79893b2-e838-50ba-b573-bbad6ad220cd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
