// Dragnet [Ransomware]: dragnet-ransomware-2025-5015 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: ad7e7cfa-899a-5fb7-a0c2-70515231008d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
