// Dragnet [Ransomware]: dragnet-ransomware-2023-5232 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 2bbcd607-00fd-50f3-bcb6-74a610ce0346

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
