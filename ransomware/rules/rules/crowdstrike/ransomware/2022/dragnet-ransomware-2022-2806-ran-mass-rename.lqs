// Dragnet [Ransomware]: dragnet-ransomware-2022-2806 — Mass File Rename (lv)
// Status: deprecated | Level: high | ID: 2a413966-691f-5a60-ae2b-fda81fd42fbb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
