// Dragnet [Ransomware]: dragnet-ransomware-2026-1093 — Mass File Rename (thegentlemen)
// Status: test | Level: high | ID: ecf14a7e-1c0a-5f47-8eb0-2d588fd2d61b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
