// Dragnet [Ransomware]: dragnet-ransomware-2025-3634 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: 4ff172ac-c8a1-5fcf-a4d5-1cc22c902425

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
