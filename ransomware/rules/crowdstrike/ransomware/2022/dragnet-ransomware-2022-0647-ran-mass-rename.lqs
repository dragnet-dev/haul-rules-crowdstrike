// Dragnet [Ransomware]: dragnet-ransomware-2022-0647 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 34647568-1ae3-543b-96f9-4ceb8814c418

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
