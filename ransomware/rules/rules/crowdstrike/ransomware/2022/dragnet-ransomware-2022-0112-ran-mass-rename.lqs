// Dragnet [Ransomware]: dragnet-ransomware-2022-0112 — Mass File Rename (karakurt)
// Status: experimental | Level: high | ID: 16023d91-f059-55cc-89f9-6aff5ffb617e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
