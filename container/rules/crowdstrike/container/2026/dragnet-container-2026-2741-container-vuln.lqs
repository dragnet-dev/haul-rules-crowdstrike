// Dragnet [Container]: dragnet-container-2026-2741 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 6e30dae6-e15a-5d77-8828-68eb8811730c

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6*)
| table([timestamp, ComputerName])
| limit(1000)
