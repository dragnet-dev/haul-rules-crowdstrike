// Dragnet [Ransomware]: dragnet-ransomware-2023-0739 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: dff89a46-33e3-5448-9ba3-1644a85417a5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
