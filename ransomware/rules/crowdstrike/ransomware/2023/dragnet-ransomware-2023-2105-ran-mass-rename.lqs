// Dragnet [Ransomware]: dragnet-ransomware-2023-2105 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: aab79782-931e-5c92-81c6-65c3aadc2289

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
