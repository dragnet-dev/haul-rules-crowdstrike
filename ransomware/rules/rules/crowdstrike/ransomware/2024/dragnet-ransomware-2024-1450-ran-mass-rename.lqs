// Dragnet [Ransomware]: dragnet-ransomware-2024-1450 — Mass File Rename (cuba)
// Status: experimental | Level: high | ID: 151a761f-5104-5472-af5d-cfc3c5ad6325

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
