// Dragnet [Ransomware]: dragnet-ransomware-2025-2044 — Mass File Rename (global)
// Status: deprecated | Level: high | ID: 53e4b7fa-4cdf-53b8-812d-45b9bb4c2743

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
