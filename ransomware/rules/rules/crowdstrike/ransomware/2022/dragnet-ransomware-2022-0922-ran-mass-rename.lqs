// Dragnet [Ransomware]: dragnet-ransomware-2022-0922 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 3e564669-fcd3-5794-bd09-e4525df7dc2f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
