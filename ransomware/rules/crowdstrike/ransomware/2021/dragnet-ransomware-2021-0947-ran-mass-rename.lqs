// Dragnet [Ransomware]: dragnet-ransomware-2021-0947 — Mass File Rename (avaddon)
// Status: deprecated | Level: high | ID: 681b6dcd-9332-52ed-afa3-3c9f5ec858c1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
