// Dragnet [Ransomware]: dragnet-ransomware-2023-4774 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: f2cc00d4-0717-54db-91ec-61f484e74bef

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
