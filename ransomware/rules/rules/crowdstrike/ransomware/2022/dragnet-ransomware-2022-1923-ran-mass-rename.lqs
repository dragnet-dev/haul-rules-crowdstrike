// Dragnet [Ransomware]: dragnet-ransomware-2022-1923 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 49afaab5-503a-5350-8a4e-d148c489169d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
