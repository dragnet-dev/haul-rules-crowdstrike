// Dragnet [Ransomware]: dragnet-ransomware-2022-2004 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 66f75ddb-270f-582e-b907-8621a180fa50

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
