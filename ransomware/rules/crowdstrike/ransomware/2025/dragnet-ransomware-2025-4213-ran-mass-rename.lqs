// Dragnet [Ransomware]: dragnet-ransomware-2025-4213 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 481399a7-045b-5cca-b662-3e3522fd4d1f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
