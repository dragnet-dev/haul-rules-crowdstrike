// Dragnet [Ransomware]: dragnet-ransomware-2024-0481 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: a67eb41d-6106-5841-a985-709043fbd349

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
