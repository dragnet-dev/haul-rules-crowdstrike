// Dragnet [Ransomware]: dragnet-ransomware-2023-5247 — Mass File Rename (royal)
// Status: experimental | Level: high | ID: 7ae07569-0058-5e32-a9bc-9ed5716063bb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
