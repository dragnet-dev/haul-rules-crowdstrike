// Dragnet [Ransomware]: dragnet-ransomware-2024-0589 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: 7d4cd3bf-1ae1-5291-97e0-85db11977521

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
