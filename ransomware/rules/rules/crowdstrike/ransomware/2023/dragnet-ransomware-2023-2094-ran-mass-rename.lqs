// Dragnet [Ransomware]: dragnet-ransomware-2023-2094 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: a0c1ccaf-55fa-5769-8845-1d0e2ffa4ca4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
