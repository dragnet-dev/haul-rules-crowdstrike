// Dragnet [Ransomware]: dragnet-ransomware-2023-2857 — Mass File Rename (malas)
// Status: experimental | Level: high | ID: c7045324-e133-57e9-b829-34c5cc4aaeb3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
