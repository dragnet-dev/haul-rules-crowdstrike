// Dragnet [Ransomware]: dragnet-ransomware-2024-1244 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: e7405de5-682f-507e-8cc3-6e70941098bb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
