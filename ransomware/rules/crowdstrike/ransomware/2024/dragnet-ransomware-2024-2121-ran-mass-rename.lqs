// Dragnet [Ransomware]: dragnet-ransomware-2024-2121 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 84333184-7beb-546f-97c5-06fa2eb16c2c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
