// Dragnet [Ransomware]: dragnet-ransomware-2022-0183 — Mass File Rename (blackbasta)
// Status: deprecated | Level: high | ID: 06d6c512-6a4c-5856-a06c-e5cd4444a6e4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
