// Dragnet [Ransomware]: dragnet-ransomware-2025-6567 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: ae187391-c69f-5696-983c-2d93cee1f76d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
