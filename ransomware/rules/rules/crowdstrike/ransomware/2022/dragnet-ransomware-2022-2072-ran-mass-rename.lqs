// Dragnet [Ransomware]: dragnet-ransomware-2022-2072 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 61531b29-c28f-5ac3-87d6-de428464bd8b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
