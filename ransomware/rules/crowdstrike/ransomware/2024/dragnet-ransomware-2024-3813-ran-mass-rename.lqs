// Dragnet [Ransomware]: dragnet-ransomware-2024-3813 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: 3fd92474-7f4f-5dd9-85fb-255082d55076

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
