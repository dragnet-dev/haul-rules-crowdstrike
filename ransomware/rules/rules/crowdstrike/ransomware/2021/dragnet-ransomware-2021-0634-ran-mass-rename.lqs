// Dragnet [Ransomware]: dragnet-ransomware-2021-0634 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: f63c1006-b2cb-5268-affd-285cee59a31c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
