// Dragnet [Ransomware]: dragnet-ransomware-2021-0007 — Mass File Rename (payloadbin)
// Status: deprecated | Level: high | ID: af780b14-4bfe-580f-84c4-1bc7eae6c863

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
