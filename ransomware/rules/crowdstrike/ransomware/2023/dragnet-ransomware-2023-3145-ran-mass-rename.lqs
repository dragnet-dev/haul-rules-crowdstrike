// Dragnet [Ransomware]: dragnet-ransomware-2023-3145 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: b3d2d775-21a1-52aa-ab62-25f2de472c17

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
