// Dragnet [Ransomware]: dragnet-ransomware-2025-0707 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 19df8980-09b0-5f94-a284-7c873a8cb8f4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
