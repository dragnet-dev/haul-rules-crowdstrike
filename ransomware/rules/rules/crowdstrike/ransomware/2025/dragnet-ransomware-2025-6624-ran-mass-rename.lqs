// Dragnet [Ransomware]: dragnet-ransomware-2025-6624 — Mass File Rename (warlock)
// Status: deprecated | Level: high | ID: 5cdb921c-2d19-5de2-b79d-69070c5635e9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
