// Dragnet [Ransomware]: dragnet-ransomware-2024-5310 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 22cfb385-ce46-520d-8695-c68b11caeece

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
