// Dragnet [Ransomware]: dragnet-ransomware-2022-1183 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 5bad92c6-6777-56bc-9755-76a0a9c7242d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
