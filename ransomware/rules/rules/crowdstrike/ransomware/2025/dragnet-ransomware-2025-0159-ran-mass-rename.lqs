// Dragnet [Ransomware]: dragnet-ransomware-2025-0159 — Mass File Rename (spacebears)
// Status: experimental | Level: high | ID: bf5efc07-dd21-590a-9f33-5235434f748a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
