// Dragnet [Ransomware]: dragnet-ransomware-2023-1189 — Mass File Rename (noescape)
// Status: experimental | Level: high | ID: e2da0c34-4c04-5116-95af-4e0fb5f740f9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
