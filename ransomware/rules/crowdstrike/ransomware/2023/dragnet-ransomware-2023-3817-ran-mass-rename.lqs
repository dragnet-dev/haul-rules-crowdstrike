// Dragnet [Ransomware]: dragnet-ransomware-2023-3817 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 6cb0128e-1c76-59e7-a3a2-e6a22b491c05

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
