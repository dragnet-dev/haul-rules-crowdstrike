// Dragnet [Ransomware]: dragnet-ransomware-2023-2433 — Mass File Rename (play)
// Status: experimental | Level: high | ID: cf1240d8-4bad-5374-b8a0-d9581a768d0c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
