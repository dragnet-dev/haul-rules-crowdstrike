// Dragnet [Ransomware]: dragnet-ransomware-2022-0856 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: c9f1ce30-b4b5-5e6d-a21f-837dec31de2b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
