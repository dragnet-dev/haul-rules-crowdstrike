// Dragnet [Container]: dragnet-container-2026-2717 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 0c37575b-4222-52f7-b7ca-ebdc74b961a0

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:5*)
| table([timestamp, ComputerName])
| limit(1000)
