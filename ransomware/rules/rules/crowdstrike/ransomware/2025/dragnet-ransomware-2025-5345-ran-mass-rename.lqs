// Dragnet [Ransomware]: dragnet-ransomware-2025-5345 — Mass File Rename (play)
// Status: experimental | Level: high | ID: ffb5d139-ea37-51c4-a254-40f5a0121341

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
