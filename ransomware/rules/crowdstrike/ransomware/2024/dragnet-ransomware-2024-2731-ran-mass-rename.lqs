// Dragnet [Ransomware]: dragnet-ransomware-2024-2731 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: bad5ec20-8816-512c-aa1e-046e5d7909f1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
