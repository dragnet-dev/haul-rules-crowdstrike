// Dragnet [Ransomware]: dragnet-ransomware-2025-4263 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: dfa29413-3e3b-5e57-9f75-1b359affa06d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
