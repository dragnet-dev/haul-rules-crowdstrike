// Dragnet [Ransomware]: dragnet-ransomware-2025-7564 — Mass File Rename (nova)
// Status: experimental | Level: high | ID: 7ff55cc6-ff93-5f8c-9633-1fb17add5872

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
