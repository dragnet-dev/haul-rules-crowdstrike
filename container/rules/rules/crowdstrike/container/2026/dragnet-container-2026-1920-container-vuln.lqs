// Dragnet [Container]: dragnet-container-2026-1920 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: ca744d65-198f-5f27-b331-13f0aa49fa41

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:7* OR ImageFileName = *debian:8* OR ImageFileName = *debian:9*)
| table([timestamp, ComputerName])
| limit(1000)
