// Dragnet [Ransomware]: dragnet-ransomware-2023-1021 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 1f578752-3371-5bf5-99b8-0cfbbd962fe3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
