// Dragnet [Ransomware]: dragnet-ransomware-2022-2770 — Mass File Rename (0mega)
// Status: deprecated | Level: high | ID: 7556f04e-23c4-50df-b6e2-2d5b42d5b46e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
