// Dragnet [Ransomware]: dragnet-ransomware-2023-3267 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 4af6be77-5ae9-51af-9689-6d5ee6891471

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
