// Dragnet [Ransomware]: dragnet-ransomware-2023-2054 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 7f19d47f-5abb-540a-b477-8bfdb58c6b25

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
