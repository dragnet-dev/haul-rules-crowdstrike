// Dragnet [Ransomware]: dragnet-ransomware-2025-2637 — Mass File Rename (J)
// Status: experimental | Level: high | ID: ffd72a5a-726a-5f76-984a-79b7f8905fdd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
