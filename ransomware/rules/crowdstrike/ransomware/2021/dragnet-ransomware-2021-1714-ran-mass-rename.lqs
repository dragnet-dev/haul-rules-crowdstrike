// Dragnet [Ransomware]: dragnet-ransomware-2021-1714 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 15a24b64-7f21-5cfb-8746-f8defe29d7a7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
