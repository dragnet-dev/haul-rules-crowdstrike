// Dragnet [Ransomware]: dragnet-ransomware-2022-1712 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 505c7cca-ec2c-5b9d-942b-9b85a9d33c26

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
