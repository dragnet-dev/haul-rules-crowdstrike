// Dragnet [Ransomware]: dragnet-ransomware-2023-2259 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 4dfddd10-4566-5872-8fdb-83dcaa319474

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
