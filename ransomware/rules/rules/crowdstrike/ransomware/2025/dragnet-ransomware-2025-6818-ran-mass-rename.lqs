// Dragnet [Ransomware]: dragnet-ransomware-2025-6818 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: b3e8e7d0-df7e-5b63-8905-8112e9d66eb5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
