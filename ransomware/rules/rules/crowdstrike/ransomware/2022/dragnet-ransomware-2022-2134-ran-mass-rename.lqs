// Dragnet [Ransomware]: dragnet-ransomware-2022-2134 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 74f716da-a684-5c18-a4f6-50b8e39da3a3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
