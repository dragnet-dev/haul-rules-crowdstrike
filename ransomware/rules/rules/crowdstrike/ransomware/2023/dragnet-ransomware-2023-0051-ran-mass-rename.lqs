// Dragnet [Ransomware]: dragnet-ransomware-2023-0051 — Mass File Rename (noescape)
// Status: experimental | Level: high | ID: cff5b45d-14ed-5648-9387-6396543d61ca

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
