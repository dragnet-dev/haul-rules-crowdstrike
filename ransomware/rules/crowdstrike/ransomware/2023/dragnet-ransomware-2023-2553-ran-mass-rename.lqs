// Dragnet [Ransomware]: dragnet-ransomware-2023-2553 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 4ea0528d-d814-575c-b22c-322cbec96292

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
