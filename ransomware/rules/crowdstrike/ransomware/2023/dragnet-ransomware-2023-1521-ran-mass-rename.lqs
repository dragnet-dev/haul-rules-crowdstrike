// Dragnet [Ransomware]: dragnet-ransomware-2023-1521 — Mass File Rename (trigona)
// Status: experimental | Level: high | ID: ab863275-1b8c-5cad-aa78-27663de172f9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
