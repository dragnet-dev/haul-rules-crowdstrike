// Dragnet [Ransomware]: dragnet-ransomware-2024-2261 — Mass File Rename (dAn0n)
// Status: experimental | Level: high | ID: 49ab0ae6-ffd2-55bd-baa9-6859757479ca

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
