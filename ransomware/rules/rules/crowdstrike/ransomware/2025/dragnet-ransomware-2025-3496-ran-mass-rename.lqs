// Dragnet [Ransomware]: dragnet-ransomware-2025-3496 — Mass File Rename (payoutsking)
// Status: experimental | Level: high | ID: 7d3351cb-ad4e-58f0-9180-234f1a01e28b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
