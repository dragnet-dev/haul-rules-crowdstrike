// Dragnet [Ransomware]: dragnet-ransomware-2023-3087 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 1d119c54-f536-532d-b7c3-c6bd8d625eff

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
