// Dragnet [Ransomware]: dragnet-ransomware-2024-4078 — Mass File Rename (madliberator)
// Status: experimental | Level: high | ID: 8ea245f3-b9ba-54e0-8a2c-4e3065676b86

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
