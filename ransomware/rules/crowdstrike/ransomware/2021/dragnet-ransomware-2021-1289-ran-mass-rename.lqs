// Dragnet [Ransomware]: dragnet-ransomware-2021-1289 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 91c4461c-17c3-51ee-8e0e-7447cabbbec6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
