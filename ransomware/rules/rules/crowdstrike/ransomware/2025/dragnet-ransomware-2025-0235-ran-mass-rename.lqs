// Dragnet [Ransomware]: dragnet-ransomware-2025-0235 — Mass File Rename (warlock)
// Status: deprecated | Level: high | ID: d0f19807-67bc-5d66-9f18-00dde5b81910

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
