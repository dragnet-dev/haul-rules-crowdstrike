// Dragnet [Ransomware]: dragnet-ransomware-2023-4527 — Mass File Rename (ransomed)
// Status: experimental | Level: high | ID: 83596b2c-7add-5bab-9f3d-09c72bab8e73

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
