// Dragnet [Ransomware]: dragnet-ransomware-2023-4349 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 4375c5ff-3a12-5429-932d-e50b2ca8c296

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
