// Dragnet [Ransomware]: dragnet-ransomware-2024-0552 — Mass File Rename (argonauts)
// Status: experimental | Level: high | ID: 7f80864d-391f-5b24-9943-22e2bdac33e9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
