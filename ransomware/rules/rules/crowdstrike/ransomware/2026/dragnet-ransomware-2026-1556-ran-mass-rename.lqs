// Dragnet [Ransomware]: dragnet-ransomware-2026-1556 — Mass File Rename (insomnia)
// Status: stable | Level: high | ID: f69f862e-a7a1-5738-b467-f6278088417d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
