// Dragnet [Ransomware]: dragnet-ransomware-2024-5444 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: fb694595-039c-5b5c-b8c9-77d371113325

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
