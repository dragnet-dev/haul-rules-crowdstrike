// Dragnet [Ransomware]: dragnet-ransomware-2021-1611 — Mass File Rename (blacktor)
// Status: deprecated | Level: high | ID: a0fe88a7-874a-5dbf-90d0-2bec838332ed

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
