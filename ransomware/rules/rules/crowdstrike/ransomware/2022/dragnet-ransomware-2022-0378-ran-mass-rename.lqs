// Dragnet [Ransomware]: dragnet-ransomware-2022-0378 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 4e4d7791-6ec1-57f2-8cdc-64175310a301

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
