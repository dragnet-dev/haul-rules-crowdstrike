// Dragnet [Ransomware]: dragnet-ransomware-2024-5985 — Mass File Rename (rhysida)
// Status: experimental | Level: high | ID: 945b6b84-925e-5840-98d7-7f464fd5a545

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
