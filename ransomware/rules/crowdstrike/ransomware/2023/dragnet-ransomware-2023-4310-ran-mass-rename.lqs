// Dragnet [Ransomware]: dragnet-ransomware-2023-4310 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 5358c688-0ce3-5a6c-bca8-5b5bdbe88cbf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
