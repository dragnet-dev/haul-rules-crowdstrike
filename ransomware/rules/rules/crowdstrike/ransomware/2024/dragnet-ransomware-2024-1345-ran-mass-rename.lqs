// Dragnet [Ransomware]: dragnet-ransomware-2024-1345 — Mass File Rename (hellcat)
// Status: deprecated | Level: high | ID: cd94cbc8-61c9-5a79-8397-99cc374e89b9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
