// Dragnet [Ransomware]: dragnet-ransomware-2025-7371 — Mass File Rename (direwolf)
// Status: experimental | Level: high | ID: 06419aaf-66f2-53eb-b407-02af7b537a2d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
