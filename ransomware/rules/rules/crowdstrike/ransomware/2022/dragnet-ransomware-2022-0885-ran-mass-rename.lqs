// Dragnet [Ransomware]: dragnet-ransomware-2022-0885 — Mass File Rename (vicesociety)
// Status: deprecated | Level: high | ID: 91f5442b-2046-58f3-9a38-4de5ea8e29d1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
