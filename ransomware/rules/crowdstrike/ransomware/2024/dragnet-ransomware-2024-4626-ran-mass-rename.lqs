// Dragnet [Ransomware]: dragnet-ransomware-2024-4626 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 52eb1c35-3b53-5608-9c92-0b54b2eb7dd2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
