// Dragnet [Ransomware]: dragnet-ransomware-2021-1467 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 79c14fe4-cfac-5569-9a24-b3362f04793a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
