// Dragnet [Ransomware]: dragnet-ransomware-2025-7391 — Mass File Rename (direwolf)
// Status: experimental | Level: high | ID: dff23feb-d7ee-5408-9990-b64092d114ca

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
