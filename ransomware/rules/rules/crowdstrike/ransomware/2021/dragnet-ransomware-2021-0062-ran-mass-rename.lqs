// Dragnet [Ransomware]: dragnet-ransomware-2021-0062 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: ea706b50-147e-5eb2-8372-cc9582b3eeda

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
