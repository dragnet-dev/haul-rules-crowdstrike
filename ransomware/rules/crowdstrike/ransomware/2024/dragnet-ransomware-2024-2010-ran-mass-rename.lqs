// Dragnet [Ransomware]: dragnet-ransomware-2024-2010 — Mass File Rename (raworld)
// Status: experimental | Level: high | ID: f5181312-2130-551d-aefb-8d715148e0c0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
