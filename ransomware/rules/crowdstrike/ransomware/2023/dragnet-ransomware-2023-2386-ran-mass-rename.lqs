// Dragnet [Ransomware]: dragnet-ransomware-2023-2386 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 86f31c93-1405-5289-9439-fbc39eda1823

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
