// Dragnet [Ransomware]: dragnet-ransomware-2025-3484 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: bed3f5e4-59e9-5dc6-836d-4b1b7ac27ea5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
