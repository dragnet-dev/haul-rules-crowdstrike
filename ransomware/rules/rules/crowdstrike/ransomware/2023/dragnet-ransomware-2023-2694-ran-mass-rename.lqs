// Dragnet [Ransomware]: dragnet-ransomware-2023-2694 — Mass File Rename (ransomhouse)
// Status: experimental | Level: high | ID: 2691a387-c1cc-5627-993a-d071dd528c5f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
