// Dragnet [Ransomware]: dragnet-ransomware-2025-1519 — Mass File Rename (flocker)
// Status: experimental | Level: high | ID: 50891041-dae1-55bc-a1e7-8732e21ff284

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
