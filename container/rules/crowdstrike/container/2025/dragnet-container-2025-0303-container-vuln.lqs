// Dragnet [Container]: dragnet-container-2025-0303 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: eaf7a4ed-06ad-5129-98a6-d1769c3636a5

#event_simpleName=*
| (ImageFileName = *alpine:3.19* OR ImageFileName = *alpine:3.20* OR ImageFileName = *alpine:3.21* OR ImageFileName = *alpine:3.22* OR ImageFileName = *alpine:3.23* OR ImageFileName = *alpine edge:* OR ImageFileName = *amazonlinux:2* OR ImageFileName = *chainguard:* OR ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *oraclelinux:9* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:20.04* OR ImageFileName = *ubuntu:20.04-ESM* OR ImageFileName = *ubuntu:22.04* OR ImageFileName = *ubuntu:23.10* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
