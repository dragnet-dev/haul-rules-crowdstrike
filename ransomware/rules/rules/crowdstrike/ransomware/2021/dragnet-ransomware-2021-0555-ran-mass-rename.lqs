// Dragnet [Ransomware]: dragnet-ransomware-2021-0555 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: b81e2298-5c05-52c8-9472-5bb09e635a5d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
