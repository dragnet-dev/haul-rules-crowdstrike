// Dragnet [Ransomware]: dragnet-ransomware-2025-2723 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: fd26bb65-bc39-5125-b36e-635f60f56adc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
