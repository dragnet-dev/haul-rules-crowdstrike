// Dragnet [Ransomware]: dragnet-ransomware-2024-4035 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: 24495155-5358-5bf6-b596-e3159686d3be

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
