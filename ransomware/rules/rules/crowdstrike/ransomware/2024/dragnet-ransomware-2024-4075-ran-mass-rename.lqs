// Dragnet [Ransomware]: dragnet-ransomware-2024-4075 — Mass File Rename (madliberator)
// Status: experimental | Level: high | ID: e8eb18b3-a680-5e85-98db-d2507194ed2f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
