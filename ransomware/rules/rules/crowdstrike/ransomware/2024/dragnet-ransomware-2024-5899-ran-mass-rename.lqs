// Dragnet [Ransomware]: dragnet-ransomware-2024-5899 — Mass File Rename (play)
// Status: experimental | Level: high | ID: a1cbc3fc-fb65-5996-9a70-399aa3610ee5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
