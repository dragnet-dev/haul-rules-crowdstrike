// Dragnet [Ransomware]: dragnet-ransomware-2022-2786 — Mass File Rename (kelvinsecurity)
// Status: deprecated | Level: high | ID: 09b1d977-bd17-5457-b2ce-d645700caa93

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
