// Dragnet [Ransomware]: dragnet-ransomware-2023-0237 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: c6cb0890-555d-5d27-b460-edc350de54fd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
