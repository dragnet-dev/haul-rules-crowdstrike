// Dragnet [Ransomware]: dragnet-ransomware-2024-5506 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 7b8548d6-da0b-55ed-a936-e84cb5e3e10b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
