// Dragnet [Ransomware]: dragnet-ransomware-2023-0491 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 8466100e-665a-5b3a-82a4-5236bfe6ac03

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
