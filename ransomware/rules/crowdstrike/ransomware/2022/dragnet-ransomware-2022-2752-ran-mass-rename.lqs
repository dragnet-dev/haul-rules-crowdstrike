// Dragnet [Ransomware]: dragnet-ransomware-2022-2752 — Mass File Rename (projectrelic)
// Status: deprecated | Level: high | ID: 8f147d3c-9a2d-51a2-8c9c-96b7def1924c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
