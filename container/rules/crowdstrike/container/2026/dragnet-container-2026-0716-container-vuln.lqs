// Dragnet [Container]: dragnet-container-2026-0716 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 531760be-61b2-5ac2-bec8-3c3b633af048

#event_simpleName=*
| (ImageFileName = *amazonlinux:1* OR ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10* OR ImageFileName = *ubuntu:13.04* OR ImageFileName = *ubuntu:13.10*)
| table([timestamp, ComputerName])
| limit(1000)
