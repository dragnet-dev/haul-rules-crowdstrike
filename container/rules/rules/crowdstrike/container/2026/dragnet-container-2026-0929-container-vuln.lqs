// Dragnet [Container]: dragnet-container-2026-0929 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: bbae86e2-852a-5954-83ae-27bfcff7a01b

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:7* OR ImageFileName = *debian:8* OR ImageFileName = *debian:9* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:18.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
