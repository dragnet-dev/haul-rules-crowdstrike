// Dragnet [Ransomware]: dragnet-ransomware-2024-0510 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: b95b63d9-1155-5316-b2c9-9385c868c9fc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
