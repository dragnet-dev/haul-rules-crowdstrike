// Dragnet [Ransomware]: dragnet-ransomware-2025-2711 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 1ec8f226-5e26-55ae-a863-004354801b4f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
