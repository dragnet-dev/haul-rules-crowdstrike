// Dragnet [Ransomware]: dragnet-ransomware-2023-2506 — Mass File Rename (losttrust)
// Status: deprecated | Level: high | ID: 242065f1-d887-5841-8353-f396366f1755

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
