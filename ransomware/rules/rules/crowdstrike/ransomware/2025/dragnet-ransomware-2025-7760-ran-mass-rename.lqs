// Dragnet [Ransomware]: dragnet-ransomware-2025-7760 — Mass File Rename (shinyhunters)
// Status: experimental | Level: high | ID: ae77bf91-7c5c-5a19-bb92-55c75f43820e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
