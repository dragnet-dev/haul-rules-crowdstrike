// Dragnet [Ransomware]: dragnet-ransomware-2025-0426 — Mass File Rename (incransom)
// Status: test | Level: high | ID: 7dc714a8-9cbe-5a3c-9122-29a34b9918c8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
