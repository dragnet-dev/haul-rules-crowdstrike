// Dragnet [Ransomware]: dragnet-ransomware-2022-0932 — Mass File Rename (royal)
// Status: deprecated | Level: high | ID: 49935345-5b08-501a-b0d6-4a71723e1ce0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
