// Dragnet [Ransomware]: dragnet-ransomware-2022-1986 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: b95063e5-cd10-57c7-ae6e-52a71dcbe6c5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
