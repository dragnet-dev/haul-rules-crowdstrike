// Dragnet [Ransomware]: dragnet-ransomware-2025-5644 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 0a030d25-e782-50e8-916f-d7f3223d82bc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
