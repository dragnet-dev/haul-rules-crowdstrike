// Dragnet [Ransomware]: dragnet-ransomware-2023-4384 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 14d392ee-29b8-5940-abd8-8d62d4e94c3c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
