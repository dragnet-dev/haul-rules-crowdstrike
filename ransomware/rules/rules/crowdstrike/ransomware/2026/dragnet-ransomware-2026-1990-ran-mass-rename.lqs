// Dragnet [Ransomware]: dragnet-ransomware-2026-1990 — Mass File Rename (dragonforce)
// Status: test | Level: high | ID: 214f31f8-6d7f-5e71-a7eb-12cea3a04f7b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
