// Dragnet [Ransomware]: dragnet-ransomware-2025-5333 — Mass File Rename (sinobi)
// Status: experimental | Level: high | ID: 0987c16f-23bb-5168-8e10-18f74e722c78

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
