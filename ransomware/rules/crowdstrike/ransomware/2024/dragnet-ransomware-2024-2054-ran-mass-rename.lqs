// Dragnet [Ransomware]: dragnet-ransomware-2024-2054 — Mass File Rename (helldown)
// Status: experimental | Level: high | ID: 7170e490-1084-51a9-b3cd-27362f429e64

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
