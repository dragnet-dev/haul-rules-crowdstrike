// Dragnet [Ransomware]: dragnet-ransomware-2024-0609 — Mass File Rename (safepay)
// Status: deprecated | Level: high | ID: f99db9c4-b275-520a-89cd-7ddc3c9ccd4e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
