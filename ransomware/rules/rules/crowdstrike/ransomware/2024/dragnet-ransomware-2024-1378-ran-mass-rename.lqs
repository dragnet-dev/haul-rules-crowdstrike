// Dragnet [Ransomware]: dragnet-ransomware-2024-1378 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 8de4a3f4-9c5b-5d6a-8feb-ce6ce37488b3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
