// Dragnet [Ransomware]: dragnet-ransomware-2023-3140 — Mass File Rename (underground)
// Status: experimental | Level: high | ID: 4c1cc94a-3f32-559c-8cb8-5b760bb9d0cb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
