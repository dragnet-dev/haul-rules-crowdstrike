// Dragnet [Ransomware]: dragnet-ransomware-2025-5641 — Mass File Rename (flocker)
// Status: experimental | Level: high | ID: df34c8a8-4356-5837-b610-2ebbd658485d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
