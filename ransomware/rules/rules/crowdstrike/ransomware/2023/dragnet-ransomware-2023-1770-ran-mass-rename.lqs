// Dragnet [Ransomware]: dragnet-ransomware-2023-1770 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 0491034d-728c-50a3-a12f-83414927af59

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
