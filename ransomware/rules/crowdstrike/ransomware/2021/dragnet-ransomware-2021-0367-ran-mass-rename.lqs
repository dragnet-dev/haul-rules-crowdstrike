// Dragnet [Ransomware]: dragnet-ransomware-2021-0367 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: 5090d24c-6ff8-5451-b4f7-f06d0741fbfd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
