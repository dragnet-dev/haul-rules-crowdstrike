// Dragnet [Ransomware]: dragnet-ransomware-2022-3106 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: c866c717-81d9-5dfa-a2a0-ee51db73aa27

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
