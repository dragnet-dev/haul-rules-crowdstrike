// Dragnet [Ransomware]: dragnet-ransomware-2024-4502 — Mass File Rename (ransomhouse)
// Status: experimental | Level: high | ID: 7219d019-35c0-5c87-bfa6-c43151166c06

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
