// Dragnet [Ransomware]: dragnet-ransomware-2023-4554 — Mass File Rename (trigona)
// Status: experimental | Level: high | ID: e9d93794-17c4-593a-b873-7de90c851e00

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
