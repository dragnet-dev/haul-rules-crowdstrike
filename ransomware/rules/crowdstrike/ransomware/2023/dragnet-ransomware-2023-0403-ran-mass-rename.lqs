// Dragnet [Ransomware]: dragnet-ransomware-2023-0403 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 3eb37d61-d45e-500d-889f-844fa4588bc4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
