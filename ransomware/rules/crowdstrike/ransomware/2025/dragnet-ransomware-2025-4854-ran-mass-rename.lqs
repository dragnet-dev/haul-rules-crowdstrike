// Dragnet [Ransomware]: dragnet-ransomware-2025-4854 — Mass File Rename (IMNCrew)
// Status: experimental | Level: high | ID: 42a3bf37-24ed-5652-834d-f5bf959ed1ff

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
