// Dragnet [Ransomware]: dragnet-ransomware-2023-4494 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 00f06a11-8ab2-52b9-b772-a7e7bffd0f88

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
