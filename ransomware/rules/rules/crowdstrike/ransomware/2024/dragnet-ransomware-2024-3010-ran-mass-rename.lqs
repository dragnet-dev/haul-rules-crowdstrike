// Dragnet [Ransomware]: dragnet-ransomware-2024-3010 — Mass File Rename (dragonforce)
// Status: deprecated | Level: high | ID: eea875b8-420d-59e8-9cc1-ad3d5c60cdc7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
