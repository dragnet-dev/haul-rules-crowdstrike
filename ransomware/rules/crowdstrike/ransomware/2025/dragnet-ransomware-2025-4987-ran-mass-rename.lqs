// Dragnet [Ransomware]: dragnet-ransomware-2025-4987 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 0d10fbb2-3f6f-5520-a7e5-c78b04ab8016

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
