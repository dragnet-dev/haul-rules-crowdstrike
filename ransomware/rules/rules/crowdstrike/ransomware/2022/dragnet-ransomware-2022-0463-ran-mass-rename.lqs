// Dragnet [Ransomware]: dragnet-ransomware-2022-0463 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 7665502b-511d-5459-a1eb-e1407ca61d56

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
