// Dragnet [Container]: dragnet-container-2025-0289 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: c7378b38-5784-51e1-a92d-5f7885d249e9

#event_simpleName=*
| (ImageFileName = *cbl-mariner:2.0* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *redhat/ubi9:*)
| table([timestamp, ComputerName])
| limit(1000)
