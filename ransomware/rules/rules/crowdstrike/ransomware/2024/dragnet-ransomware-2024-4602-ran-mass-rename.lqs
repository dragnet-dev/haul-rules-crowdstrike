// Dragnet [Ransomware]: dragnet-ransomware-2024-4602 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: f45c6612-fb3e-5f0a-b018-024c79ce2a7a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
