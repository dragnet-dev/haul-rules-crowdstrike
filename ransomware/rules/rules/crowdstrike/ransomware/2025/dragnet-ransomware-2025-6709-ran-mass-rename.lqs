// Dragnet [Ransomware]: dragnet-ransomware-2025-6709 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: d338699a-d41a-5476-ae12-3fe3e52fce47

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
