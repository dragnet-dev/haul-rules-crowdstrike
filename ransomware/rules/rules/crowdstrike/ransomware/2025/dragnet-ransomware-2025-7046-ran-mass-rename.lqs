// Dragnet [Ransomware]: dragnet-ransomware-2025-7046 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: fa7caf6a-c690-5695-ba64-34e847bbb18f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
