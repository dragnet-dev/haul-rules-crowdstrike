// Dragnet [Container]: dragnet-container-2024-1446 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 4defc6d1-fb9e-5899-ad79-7dcbd62cefd8

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *redhat/ubi9:*)
| table([timestamp, ComputerName])
| limit(1000)
