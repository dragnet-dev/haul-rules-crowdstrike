// Dragnet [Ransomware]: dragnet-ransomware-2022-1477 — Mass File Rename (cheers)
// Status: deprecated | Level: high | ID: 4e0f54de-bf63-59a0-9f3e-e5b0478ca61c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
