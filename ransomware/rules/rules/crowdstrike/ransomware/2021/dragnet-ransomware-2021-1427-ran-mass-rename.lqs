// Dragnet [Ransomware]: dragnet-ransomware-2021-1427 — Mass File Rename (babuk)
// Status: experimental | Level: high | ID: 5d8d21b8-2394-51ae-8053-f5f38b9e0881

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
