// Dragnet [Ransomware]: dragnet-ransomware-2022-2788 — Mass File Rename (karakurt)
// Status: deprecated | Level: high | ID: b19ef213-2c3e-5e95-93b4-9fea1fd3ff66

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
