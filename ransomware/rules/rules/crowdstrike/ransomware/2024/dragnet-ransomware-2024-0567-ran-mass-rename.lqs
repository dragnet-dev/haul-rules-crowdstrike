// Dragnet [Ransomware]: dragnet-ransomware-2024-0567 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: bac2b8d4-3d81-5330-bee5-bee0d596fa03

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
