// Dragnet [Ransomware]: dragnet-ransomware-2020-0255 — Mass File Rename (snake)
// Status: deprecated | Level: high | ID: 440f05ab-7e78-5e8b-9850-d3d64c34ca5f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
