// Dragnet [Ransomware]: dragnet-ransomware-2026-0647 — Mass File Rename (incransom)
// Status: stable | Level: high | ID: e923e6f7-2cfb-56bb-a6b6-8cf9ac0625f9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
