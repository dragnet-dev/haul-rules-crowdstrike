// Dragnet [Ransomware]: dragnet-ransomware-2023-4842 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 052602ca-60eb-5e18-acd0-8ca967746f9d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
