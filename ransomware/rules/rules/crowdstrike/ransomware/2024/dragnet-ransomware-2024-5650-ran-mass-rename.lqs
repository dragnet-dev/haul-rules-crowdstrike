// Dragnet [Ransomware]: dragnet-ransomware-2024-5650 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 90bb8e68-7df5-59b0-886d-1a7e408f4c10

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
