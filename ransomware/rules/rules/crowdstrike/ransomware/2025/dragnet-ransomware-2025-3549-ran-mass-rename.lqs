// Dragnet [Ransomware]: dragnet-ransomware-2025-3549 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 96329896-abb6-586a-bc3b-e15cf7d61fa1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
