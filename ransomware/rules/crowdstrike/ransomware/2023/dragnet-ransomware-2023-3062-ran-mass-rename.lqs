// Dragnet [Ransomware]: dragnet-ransomware-2023-3062 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 240fd136-d322-533b-9fa0-ef45b5300584

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
