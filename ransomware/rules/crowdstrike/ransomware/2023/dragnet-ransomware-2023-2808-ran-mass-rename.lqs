// Dragnet [Ransomware]: dragnet-ransomware-2023-2808 — Mass File Rename (malas)
// Status: experimental | Level: high | ID: 1c08ca9b-4ac9-5adf-b04a-29a520e9d704

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
