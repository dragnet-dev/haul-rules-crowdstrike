// Dragnet [Ransomware]: dragnet-ransomware-2023-0219 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: a499f689-a648-5992-8a90-aacd02fe30b2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
