// Dragnet [Ransomware]: dragnet-ransomware-2022-1078 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 5dc814b5-7048-5208-b94d-d0a2a9e0182b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
