// Dragnet [Ransomware]: dragnet-ransomware-2023-5259 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: d639c98a-4551-5287-b46f-f190e3d658a2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
