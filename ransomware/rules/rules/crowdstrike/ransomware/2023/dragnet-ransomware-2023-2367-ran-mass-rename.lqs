// Dragnet [Ransomware]: dragnet-ransomware-2023-2367 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 49ccf55a-8c67-5627-8bee-247ab7ffec14

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
