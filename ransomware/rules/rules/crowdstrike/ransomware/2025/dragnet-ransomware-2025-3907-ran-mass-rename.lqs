// Dragnet [Ransomware]: dragnet-ransomware-2025-3907 — Mass File Rename (warlock)
// Status: deprecated | Level: high | ID: ddbf0fe1-3dba-509c-a97f-66f9decb2f3a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
