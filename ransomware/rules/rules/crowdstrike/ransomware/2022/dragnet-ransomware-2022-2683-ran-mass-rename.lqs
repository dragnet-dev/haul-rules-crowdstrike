// Dragnet [Ransomware]: dragnet-ransomware-2022-2683 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 27a5a575-da18-5256-9cc6-c4eafee6962e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
