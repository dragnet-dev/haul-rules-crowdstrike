// Dragnet [Ransomware]: dragnet-ransomware-2024-2422 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 98c1d87b-7499-5ca0-9bf0-d68f087878cb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
