// Dragnet [Ransomware]: dragnet-ransomware-2025-5723 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: fc605be5-1718-5087-8306-da79a7b0cd9b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
