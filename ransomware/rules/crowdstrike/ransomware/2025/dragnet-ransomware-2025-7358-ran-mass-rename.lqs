// Dragnet [Ransomware]: dragnet-ransomware-2025-7358 — Mass File Rename (stormous)
// Status: deprecated | Level: high | ID: 9fe5062e-0680-554d-b4f2-283d20c2644c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
