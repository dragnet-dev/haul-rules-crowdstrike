// Dragnet [Ransomware]: dragnet-ransomware-2022-1703 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: e4e3dafe-de3a-5cc3-8bbc-2bdae5a88799

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
