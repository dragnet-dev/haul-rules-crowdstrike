// Dragnet [Ransomware]: dragnet-ransomware-2024-3850 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: e3db93fa-9c5f-5677-a327-ff6f5cd92aca

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
