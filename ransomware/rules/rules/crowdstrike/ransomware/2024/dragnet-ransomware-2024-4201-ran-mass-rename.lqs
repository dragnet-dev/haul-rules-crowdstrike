// Dragnet [Ransomware]: dragnet-ransomware-2024-4201 — Mass File Rename (donutleaks)
// Status: experimental | Level: high | ID: 62a144ff-0243-5730-baa9-f4f8ed5042d0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
