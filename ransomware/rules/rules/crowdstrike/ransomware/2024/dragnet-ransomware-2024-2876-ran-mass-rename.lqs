// Dragnet [Ransomware]: dragnet-ransomware-2024-2876 — Mass File Rename (dragonforce)
// Status: deprecated | Level: high | ID: df2c786a-6aa6-5d2e-81ec-d7a2f02666fe

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
