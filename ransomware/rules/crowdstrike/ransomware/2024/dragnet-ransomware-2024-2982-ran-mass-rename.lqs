// Dragnet [Ransomware]: dragnet-ransomware-2024-2982 — Mass File Rename (darkvault)
// Status: experimental | Level: high | ID: 52b6488e-9c3c-55f7-a8ac-fa9218a01273

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
