// Dragnet [Ransomware]: dragnet-ransomware-2023-1113 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 19731714-fc8b-51f4-a4f4-ee0532d90500

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
