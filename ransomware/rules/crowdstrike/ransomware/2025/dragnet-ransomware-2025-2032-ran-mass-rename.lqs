// Dragnet [Ransomware]: dragnet-ransomware-2025-2032 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: d48e6e2f-aa40-5309-a884-9e23a47c469d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
