// Dragnet [Ransomware]: dragnet-ransomware-2020-0171 — Mass File Rename (revil)
// Status: deprecated | Level: high | ID: 2cd005b2-d68b-59b7-b4e0-3247f59af07e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
