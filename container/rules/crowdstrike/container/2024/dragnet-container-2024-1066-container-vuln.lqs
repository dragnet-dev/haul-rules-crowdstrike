// Dragnet [Container]: dragnet-container-2024-1066 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 9f6342b2-e2cd-5eb6-b240-4226cbdad09d

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:7* OR ImageFileName = *debian:8*)
| table([timestamp, ComputerName])
| limit(1000)
