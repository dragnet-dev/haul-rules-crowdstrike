// Dragnet [Container]: dragnet-container-2024-1184 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 77d58192-0ea5-5482-9745-37e2b9d9557e

#event_simpleName=*
| (ImageFileName = *amazonlinux:2* OR ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:8* OR ImageFileName = *debian:9* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *oraclelinux:7* OR ImageFileName = *oraclelinux:8* OR ImageFileName = *ubuntu:16.04* OR ImageFileName = *ubuntu:16.04-ESM* OR ImageFileName = *ubuntu:18.04* OR ImageFileName = *ubuntu:18.04-ESM* OR ImageFileName = *ubuntu:19.10*)
| table([timestamp, ComputerName])
| limit(1000)
