// Dragnet [Ransomware]: dragnet-ransomware-2025-1430 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: d74bf38f-6157-5e53-905a-6615b4d3e990

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
