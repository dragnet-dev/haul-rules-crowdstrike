// Dragnet [Ransomware]: dragnet-ransomware-2026-3155 — Mass File Rename (handala)
// Status: stable | Level: high | ID: b857afd7-5ef0-51a0-b94e-a273016906a1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
