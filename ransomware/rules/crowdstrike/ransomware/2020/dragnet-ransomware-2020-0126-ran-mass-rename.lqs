// Dragnet [Ransomware]: dragnet-ransomware-2020-0126 — Mass File Rename (maze)
// Status: deprecated | Level: high | ID: 2ee355df-a972-5cd5-956a-c2db8762f3dd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
