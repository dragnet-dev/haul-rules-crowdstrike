// Dragnet [Ransomware]: dragnet-ransomware-2022-0361 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: d8aae456-06b2-59da-a2ff-931bc241d739

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
