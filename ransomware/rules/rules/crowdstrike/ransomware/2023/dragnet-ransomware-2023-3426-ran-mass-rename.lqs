// Dragnet [Ransomware]: dragnet-ransomware-2023-3426 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 9ac983f1-185f-54b5-998e-6872aa19ce89

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
