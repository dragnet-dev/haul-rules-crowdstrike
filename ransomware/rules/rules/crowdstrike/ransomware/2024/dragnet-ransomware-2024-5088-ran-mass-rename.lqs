// Dragnet [Ransomware]: dragnet-ransomware-2024-5088 — Mass File Rename (abyss)
// Status: deprecated | Level: high | ID: 1f080708-2839-5449-8fff-c2186bf828a6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
