// Dragnet [Ransomware]: dragnet-ransomware-2024-4676 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: 98c10a38-8af9-52c8-aa78-b324768a1302

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
