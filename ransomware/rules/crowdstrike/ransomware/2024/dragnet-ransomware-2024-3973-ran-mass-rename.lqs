// Dragnet [Ransomware]: dragnet-ransomware-2024-3973 — Mass File Rename (play)
// Status: experimental | Level: high | ID: a10e86a5-dc1b-599f-8d32-7b55628548cb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
