// Dragnet [Ransomware]: dragnet-ransomware-2023-4269 — Mass File Rename (raworld)
// Status: experimental | Level: high | ID: 3bf627c6-5b27-559c-96aa-d31fb83e7bfe

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
