// Dragnet [Ransomware]: dragnet-ransomware-2023-2869 — Mass File Rename (malas)
// Status: experimental | Level: high | ID: f1f8ce9c-fb67-57fd-ba4c-c3da361e47d4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
