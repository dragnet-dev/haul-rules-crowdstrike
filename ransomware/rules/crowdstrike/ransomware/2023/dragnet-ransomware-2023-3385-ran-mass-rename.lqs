// Dragnet [Ransomware]: dragnet-ransomware-2023-3385 — Mass File Rename (toufan)
// Status: deprecated | Level: high | ID: b6e2aeea-014d-5b06-9d3d-d78129ed7d28

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
