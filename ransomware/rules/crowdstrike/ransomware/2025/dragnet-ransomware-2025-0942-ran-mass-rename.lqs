// Dragnet [Ransomware]: dragnet-ransomware-2025-0942 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: a1042dfc-1c00-5708-8e67-5dad337d3e54

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
