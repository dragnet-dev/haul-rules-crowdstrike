// Dragnet [Ransomware]: dragnet-ransomware-2025-7475 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: b62c6cbf-37d3-5df7-babc-036c4ee382d8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
