// Dragnet [Ransomware]: dragnet-ransomware-2023-0923 — Mass File Rename (rhysida)
// Status: experimental | Level: high | ID: e5b58a03-acef-534b-bf6d-97c0718453a9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
