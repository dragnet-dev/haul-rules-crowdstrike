// Dragnet [Ransomware]: dragnet-ransomware-2022-2227 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 02cf012b-3a60-5ca7-a455-5742d045566a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
