// Dragnet [Ransomware]: dragnet-ransomware-2022-0111 — Mass File Rename (karakurt)
// Status: deprecated | Level: high | ID: f9e2a41d-081c-5e94-879c-1be526841a2e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
