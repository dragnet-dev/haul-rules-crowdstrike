// Dragnet [Ransomware]: dragnet-ransomware-2024-1011 — Mass File Rename (play)
// Status: experimental | Level: high | ID: fee44766-fe65-5681-9008-211cc34e68ef

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
