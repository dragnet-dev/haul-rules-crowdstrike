// Dragnet [Ransomware]: dragnet-ransomware-2023-4409 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 0519d310-323c-5b84-ab55-059f0cddde17

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
