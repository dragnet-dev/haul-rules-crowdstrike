// Dragnet [Ransomware]: dragnet-ransomware-2026-0537 — Mass File Rename (incransom)
// Status: test | Level: high | ID: 18bfb80a-1f99-5b9a-abf8-d0ceaa8387a2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
