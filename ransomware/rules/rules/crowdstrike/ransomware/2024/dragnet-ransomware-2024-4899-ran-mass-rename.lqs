// Dragnet [Ransomware]: dragnet-ransomware-2024-4899 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: a35431df-6f62-50e9-a723-88e6b8fc5e55

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
