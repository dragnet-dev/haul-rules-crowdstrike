// Dragnet [Ransomware]: dragnet-ransomware-2026-3222 — Mass File Rename (kairos)
// Status: deprecated | Level: high | ID: 249bd1a3-08b3-5039-8639-a9dd9857ebc7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
