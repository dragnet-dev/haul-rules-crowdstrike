// Dragnet [Ransomware]: dragnet-ransomware-2021-1271 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 4dd83d62-f000-5bba-9f75-6bf27aed2628

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
