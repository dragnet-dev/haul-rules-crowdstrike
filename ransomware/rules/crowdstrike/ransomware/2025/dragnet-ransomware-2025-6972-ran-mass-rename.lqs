// Dragnet [Ransomware]: dragnet-ransomware-2025-6972 — Mass File Rename (securotrop)
// Status: experimental | Level: high | ID: 92cc191f-45f3-5627-9279-18147531dfad

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
