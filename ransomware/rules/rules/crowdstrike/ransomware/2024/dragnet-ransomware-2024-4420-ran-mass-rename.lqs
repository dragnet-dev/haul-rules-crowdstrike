// Dragnet [Ransomware]: dragnet-ransomware-2024-4420 — Mass File Rename (raworld)
// Status: experimental | Level: high | ID: 2bf13134-4043-5c9f-8dad-9656c0fe3c65

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
