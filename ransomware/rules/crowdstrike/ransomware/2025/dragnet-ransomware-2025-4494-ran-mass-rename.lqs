// Dragnet [Ransomware]: dragnet-ransomware-2025-4494 — Mass File Rename (cloak)
// Status: deprecated | Level: high | ID: f4307cc7-bb9e-5042-9faa-d4ce60220d00

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
