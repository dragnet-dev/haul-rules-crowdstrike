// Dragnet [Ransomware]: dragnet-ransomware-2023-0044 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 05234308-2d00-594f-9efb-d11a85afa4a9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
