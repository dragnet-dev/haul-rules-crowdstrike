// Dragnet [Ransomware]: dragnet-ransomware-2024-0045 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 854b91b0-18cc-5fd5-86df-1fb33847b158

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
