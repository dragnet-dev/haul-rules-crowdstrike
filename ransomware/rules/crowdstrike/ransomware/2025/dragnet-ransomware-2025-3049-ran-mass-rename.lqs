// Dragnet [Ransomware]: dragnet-ransomware-2025-3049 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 31ec296c-09b1-5393-847f-85a98d0fc015

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
