// Dragnet [Ransomware]: dragnet-ransomware-2025-3463 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 37d8b9f5-c876-5c30-b8e5-60cb31c0e922

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
