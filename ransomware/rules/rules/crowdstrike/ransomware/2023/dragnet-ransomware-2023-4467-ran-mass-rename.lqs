// Dragnet [Ransomware]: dragnet-ransomware-2023-4467 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: ac07ac7b-686b-5a2b-bba6-cf9dac00d47f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
