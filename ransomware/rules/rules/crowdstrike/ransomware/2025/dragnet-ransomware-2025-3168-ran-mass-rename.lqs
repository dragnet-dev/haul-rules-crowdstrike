// Dragnet [Ransomware]: dragnet-ransomware-2025-3168 — Mass File Rename (stormous)
// Status: experimental | Level: high | ID: 85391878-ea8b-595d-9e27-d7c29ae17d73

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
