// Dragnet [Ransomware]: dragnet-ransomware-2023-2636 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: f8d1c014-db6c-57c0-bc13-33a0689f02a3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
