// Dragnet [Ransomware]: dragnet-ransomware-2022-1431 — Mass File Rename (ragnarlocker)
// Status: deprecated | Level: high | ID: b46c379a-a47f-5320-8323-476f87d4ae5d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
