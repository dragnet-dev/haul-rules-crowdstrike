// Dragnet [Ransomware]: dragnet-ransomware-2024-5967 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 6a5b3f49-9d88-5af3-ae9f-73b60599ca49

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
