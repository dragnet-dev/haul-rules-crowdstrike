// Dragnet [Ransomware]: dragnet-ransomware-2024-0495 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: 802d0549-6fe7-532e-ba09-64f77d0c0464

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
