// Dragnet [Ransomware]: dragnet-ransomware-2025-0973 — Mass File Rename (play)
// Status: experimental | Level: high | ID: a8dc6c56-b945-5257-9234-8efa065af162

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
