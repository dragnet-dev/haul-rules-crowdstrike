// Dragnet [Ransomware]: dragnet-ransomware-2023-0396 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 5889bcc4-b146-50a9-b38a-da4d815fc4c7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
