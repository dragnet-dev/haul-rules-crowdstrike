// Dragnet [Container]: dragnet-container-2024-0315 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 5d601282-2cbe-5041-94d7-aa5399c3de16

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:8* OR ImageFileName = *debian:9*)
| table([timestamp, ComputerName])
| limit(1000)
