// Dragnet [Ransomware]: dragnet-ransomware-2025-2963 — Mass File Rename (SilentRansomGroup)
// Status: deprecated | Level: high | ID: 00e11ec7-60c5-5026-b354-9d4fad9dd9ac

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
