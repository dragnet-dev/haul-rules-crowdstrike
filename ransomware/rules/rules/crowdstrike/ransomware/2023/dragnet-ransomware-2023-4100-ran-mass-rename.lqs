// Dragnet [Ransomware]: dragnet-ransomware-2023-4100 — Mass File Rename (nokoyawa)
// Status: experimental | Level: high | ID: 2d5743de-c10e-5269-b0ac-b91d9280d8b0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
