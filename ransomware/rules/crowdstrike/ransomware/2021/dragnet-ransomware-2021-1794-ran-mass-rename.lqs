// Dragnet [Ransomware]: dragnet-ransomware-2021-1794 — Mass File Rename (babuk)
// Status: experimental | Level: high | ID: 00bfc92a-ee7a-5e7a-94fe-d99adbfccfaf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
