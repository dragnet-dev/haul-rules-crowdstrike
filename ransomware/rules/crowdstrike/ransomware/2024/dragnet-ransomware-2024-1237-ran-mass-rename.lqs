// Dragnet [Ransomware]: dragnet-ransomware-2024-1237 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 8fe53423-8557-5310-a0cb-7b3cf07d9b41

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
