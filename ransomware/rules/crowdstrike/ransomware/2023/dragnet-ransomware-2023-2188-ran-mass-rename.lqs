// Dragnet [Ransomware]: dragnet-ransomware-2023-2188 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 4ed4cedc-28c9-5668-9b0a-3fe3541e0184

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
