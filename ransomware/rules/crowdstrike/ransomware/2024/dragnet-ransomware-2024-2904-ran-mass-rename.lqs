// Dragnet [Ransomware]: dragnet-ransomware-2024-2904 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: ba96a1a8-b09d-52e3-bdbf-142d20cf2344

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
