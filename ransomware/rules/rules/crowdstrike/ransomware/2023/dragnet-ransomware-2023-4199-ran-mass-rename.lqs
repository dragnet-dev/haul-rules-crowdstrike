// Dragnet [Ransomware]: dragnet-ransomware-2023-4199 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 85c9324a-3059-5e82-a510-12c8d154d6b4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
