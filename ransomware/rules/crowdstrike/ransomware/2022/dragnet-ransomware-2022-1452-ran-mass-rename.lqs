// Dragnet [Ransomware]: dragnet-ransomware-2022-1452 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 9d6d3aea-4825-5fd6-9b42-450d3b6eb0c5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
