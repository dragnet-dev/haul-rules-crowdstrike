// Dragnet [Ransomware]: dragnet-ransomware-2023-3227 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: a9f93bde-4a13-5f0f-ac09-97721b52d733

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
