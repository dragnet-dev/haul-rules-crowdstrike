// Dragnet [Ransomware]: dragnet-ransomware-2023-4981 — Mass File Rename (werewolves)
// Status: experimental | Level: high | ID: 10f88ac9-ed45-521e-9e7a-c7bbf17683b1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
