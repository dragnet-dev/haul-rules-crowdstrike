// Dragnet [Ransomware]: dragnet-ransomware-2025-1207 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 36c40875-af1f-513b-8dc0-be04c71017dd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
