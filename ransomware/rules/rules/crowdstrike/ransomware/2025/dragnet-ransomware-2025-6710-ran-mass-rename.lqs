// Dragnet [Ransomware]: dragnet-ransomware-2025-6710 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: adde6b24-dbb1-5845-93c1-056760a57fa3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
