// Dragnet [Ransomware]: dragnet-ransomware-2022-2885 — Mass File Rename (vicesociety)
// Status: deprecated | Level: high | ID: b36d124e-347e-5b1b-8f4b-d2aea787c7ea

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
