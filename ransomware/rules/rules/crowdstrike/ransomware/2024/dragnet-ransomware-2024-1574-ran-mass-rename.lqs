// Dragnet [Ransomware]: dragnet-ransomware-2024-1574 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: a7570e61-9435-5cdc-886c-3639929b444d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
