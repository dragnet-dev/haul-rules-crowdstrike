// Dragnet [Ransomware]: dragnet-ransomware-2022-3010 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 878fc53a-ffaa-53d7-90ba-acb6150cedf6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
