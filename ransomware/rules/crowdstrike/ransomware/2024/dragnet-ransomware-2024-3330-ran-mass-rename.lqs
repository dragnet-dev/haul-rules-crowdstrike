// Dragnet [Ransomware]: dragnet-ransomware-2024-3330 — Mass File Rename (cloak)
// Status: deprecated | Level: high | ID: de1ca3e0-89f8-5d04-958d-833c23107c1b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
