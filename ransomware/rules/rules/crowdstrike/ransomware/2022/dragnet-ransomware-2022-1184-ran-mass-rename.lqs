// Dragnet [Ransomware]: dragnet-ransomware-2022-1184 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 22e21f8e-000c-55f4-a659-7a3ac17a9b1b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
