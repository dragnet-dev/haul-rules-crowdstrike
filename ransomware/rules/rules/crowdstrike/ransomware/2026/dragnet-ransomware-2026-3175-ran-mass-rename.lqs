// Dragnet [Ransomware]: dragnet-ransomware-2026-3175 — Mass File Rename (fulcrumsec)
// Status: stable | Level: high | ID: e485a0a5-40c4-54b2-ba42-dc7cd53d7b49

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
