// Dragnet [Ransomware]: dragnet-ransomware-2024-4659 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: ae3d7a84-cca5-5cb6-824f-9f2ee5a3fbee

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
