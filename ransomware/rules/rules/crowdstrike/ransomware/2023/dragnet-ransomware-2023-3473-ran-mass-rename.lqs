// Dragnet [Ransomware]: dragnet-ransomware-2023-3473 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: a29b6241-8041-59fd-a7f4-332e902c0904

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
