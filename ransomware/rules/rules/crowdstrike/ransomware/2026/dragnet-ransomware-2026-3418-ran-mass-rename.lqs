// Dragnet [Ransomware]: dragnet-ransomware-2026-3418 — Mass File Rename (nightspire)
// Status: deprecated | Level: high | ID: 413fe3ce-477c-510c-912b-246154559613

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
