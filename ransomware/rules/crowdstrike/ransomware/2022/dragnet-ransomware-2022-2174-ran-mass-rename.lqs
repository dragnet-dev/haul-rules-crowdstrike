// Dragnet [Ransomware]: dragnet-ransomware-2022-2174 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: f71896ad-dc97-5567-b0ae-5d035f806f78

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
