// Dragnet [Container]: dragnet-container-2024-1377 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 240cc60a-183c-540f-8cf0-ab5af7cc9f64

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:9* OR ImageFileName = *redhat/ubi9:*)
| table([timestamp, ComputerName])
| limit(1000)
