// Dragnet [Ransomware]: dragnet-ransomware-2022-2314 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: a3fdeb98-7a52-5c41-a520-164b402332e7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
