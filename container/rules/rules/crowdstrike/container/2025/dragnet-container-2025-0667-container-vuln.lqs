// Dragnet [Container]: dragnet-container-2025-0667 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 89aac73b-a29a-5c69-b2a6-0ff46acae232

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:7* OR ImageFileName = *debian:8* OR ImageFileName = *debian:9*)
| table([timestamp, ComputerName])
| limit(1000)
