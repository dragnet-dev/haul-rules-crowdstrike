// Dragnet [Container]: dragnet-container-2024-0452 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: b2cda453-a921-5a96-82be-3bc020406b6a

#event_simpleName=*
| (ImageFileName = *almalinux:8* OR ImageFileName = *almalinux:9* OR ImageFileName = *alpine:3.15* OR ImageFileName = *alpine:3.16* OR ImageFileName = *alpine:3.17* OR ImageFileName = *alpine:3.18* OR ImageFileName = *alpine:3.19* OR ImageFileName = *alpine:3.20* OR ImageFileName = *alpine:3.21* OR ImageFileName = *alpine:3.22* OR ImageFileName = *alpine:3.23* OR ImageFileName = *alpine edge:* OR ImageFileName = *oraclelinux:8* OR ImageFileName = *oraclelinux:9* OR ImageFileName = *ubuntu:22.04*)
| table([timestamp, ComputerName])
| limit(1000)
