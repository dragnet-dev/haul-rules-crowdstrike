// Dragnet [Ransomware]: dragnet-ransomware-2024-5502 — Mass File Rename (BrainCipher)
// Status: experimental | Level: high | ID: 2923d2e3-2350-5e5f-b605-90a2e422dbfa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
