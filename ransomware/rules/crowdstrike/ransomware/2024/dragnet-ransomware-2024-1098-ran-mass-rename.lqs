// Dragnet [Ransomware]: dragnet-ransomware-2024-1098 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 593f3ba5-ce17-594f-aecc-7c9a1471bd24

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
