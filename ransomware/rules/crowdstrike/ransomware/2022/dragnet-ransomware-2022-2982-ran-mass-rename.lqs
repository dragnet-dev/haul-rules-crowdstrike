// Dragnet [Ransomware]: dragnet-ransomware-2022-2982 — Mass File Rename (everest)
// Status: deprecated | Level: high | ID: 160ff3a2-e240-5310-a17f-727c5c9e19f6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
