// Dragnet [Ransomware]: dragnet-ransomware-2025-5821 — Mass File Rename (frag)
// Status: deprecated | Level: high | ID: bf85cbfd-a0ed-5a21-9d8e-e32189207f92

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
