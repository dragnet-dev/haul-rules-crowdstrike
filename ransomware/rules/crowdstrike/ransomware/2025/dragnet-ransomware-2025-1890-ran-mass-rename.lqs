// Dragnet [Ransomware]: dragnet-ransomware-2025-1890 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: b9445b35-b19c-5e53-a9db-e9de9b9639f3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
