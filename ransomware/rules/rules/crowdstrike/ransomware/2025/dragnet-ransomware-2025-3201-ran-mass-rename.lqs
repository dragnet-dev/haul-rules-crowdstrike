// Dragnet [Ransomware]: dragnet-ransomware-2025-3201 — Mass File Rename (blacknevas)
// Status: experimental | Level: high | ID: 15ec18e3-20a3-5ed1-b3ad-38822a75e855

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
