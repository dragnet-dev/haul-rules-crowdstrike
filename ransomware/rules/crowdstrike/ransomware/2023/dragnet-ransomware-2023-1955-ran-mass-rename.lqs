// Dragnet [Ransomware]: dragnet-ransomware-2023-1955 — Mass File Rename (ragnarlocker)
// Status: experimental | Level: high | ID: 082b8b8d-dee5-50dc-95be-25fff694737b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
