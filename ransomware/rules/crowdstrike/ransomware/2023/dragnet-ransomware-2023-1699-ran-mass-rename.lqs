// Dragnet [Ransomware]: dragnet-ransomware-2023-1699 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 1ac2cc14-f738-58f1-9099-e078a2aff583

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
