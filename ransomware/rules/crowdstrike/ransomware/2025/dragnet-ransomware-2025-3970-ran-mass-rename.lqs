// Dragnet [Ransomware]: dragnet-ransomware-2025-3970 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: 116759c1-875f-57bd-89d4-67046aab2ae5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
