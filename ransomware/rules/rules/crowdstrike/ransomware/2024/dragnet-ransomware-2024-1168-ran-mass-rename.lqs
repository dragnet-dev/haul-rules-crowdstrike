// Dragnet [Ransomware]: dragnet-ransomware-2024-1168 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: b5f9cee0-65bf-5369-9c30-2cf25f7eeab5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
