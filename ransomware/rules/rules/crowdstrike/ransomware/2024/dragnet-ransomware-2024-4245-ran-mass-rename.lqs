// Dragnet [Ransomware]: dragnet-ransomware-2024-4245 — Mass File Rename (BrainCipher)
// Status: experimental | Level: high | ID: 7a8fde39-f9ea-50fa-beb3-d6a14469517c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
