// Dragnet [Ransomware]: dragnet-ransomware-2022-2624 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 240b01a3-9d00-57e1-96dd-fdfb382507eb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
