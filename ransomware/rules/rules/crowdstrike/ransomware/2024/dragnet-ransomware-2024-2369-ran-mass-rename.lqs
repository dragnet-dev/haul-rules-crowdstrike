// Dragnet [Ransomware]: dragnet-ransomware-2024-2369 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 7ae032eb-1dc4-5d26-b6e8-00bb54493e57

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
