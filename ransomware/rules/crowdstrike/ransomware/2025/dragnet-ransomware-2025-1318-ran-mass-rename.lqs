// Dragnet [Ransomware]: dragnet-ransomware-2025-1318 — Mass File Rename (play)
// Status: experimental | Level: high | ID: d26c82b9-535a-5163-8132-0b22662a578c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
