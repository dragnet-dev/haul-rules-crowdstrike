// Dragnet [Ransomware]: dragnet-ransomware-2025-0046 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: 9d8bf874-e402-52fa-87bb-654603640c33

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
