// Dragnet [Ransomware]: dragnet-ransomware-2020-0043 — Mass File Rename (ragnarlocker)
// Status: deprecated | Level: high | ID: ab2a807e-ba5e-56aa-b84c-34c07ad13b46

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
