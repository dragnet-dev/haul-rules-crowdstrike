// Dragnet [Ransomware]: dragnet-ransomware-2022-2334 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 83609e8c-7711-523a-aa47-665f54c2e21a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
