// Dragnet [Ransomware]: dragnet-ransomware-2024-1297 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: f393e777-a8e4-5c6e-8569-22793732f784

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
