// Dragnet [Ransomware]: dragnet-ransomware-2024-2430 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 99dd4fe2-5281-595f-ae2c-297705373833

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
