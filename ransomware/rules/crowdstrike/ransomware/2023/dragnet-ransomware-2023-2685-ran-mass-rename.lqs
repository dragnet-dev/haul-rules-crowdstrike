// Dragnet [Ransomware]: dragnet-ransomware-2023-2685 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: fa6792ab-5302-51fb-b9e4-e4248565380f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
