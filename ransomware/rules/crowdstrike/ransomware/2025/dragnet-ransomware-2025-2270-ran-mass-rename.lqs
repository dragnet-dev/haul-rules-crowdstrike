// Dragnet [Ransomware]: dragnet-ransomware-2025-2270 — Mass File Rename (kairos)
// Status: experimental | Level: high | ID: 4864cbc5-9d7b-556d-909e-e543b73a36a4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
