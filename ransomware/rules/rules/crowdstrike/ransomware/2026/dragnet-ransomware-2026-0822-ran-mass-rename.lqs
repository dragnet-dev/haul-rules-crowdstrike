// Dragnet [Ransomware]: dragnet-ransomware-2026-0822 — Mass File Rename (lockbit5)
// Status: stable | Level: high | ID: 975bbcfa-26ed-5b61-8303-cc3f8a9e9ac1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
