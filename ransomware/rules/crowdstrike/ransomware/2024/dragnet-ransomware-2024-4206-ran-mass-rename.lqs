// Dragnet [Ransomware]: dragnet-ransomware-2024-4206 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 9f8a0ae0-5107-5e31-9db5-dbc6d03ff213

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
