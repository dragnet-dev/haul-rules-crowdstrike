// Dragnet [Ransomware]: dragnet-ransomware-2024-4966 — Mass File Rename (SilentRansomGroup)
// Status: deprecated | Level: high | ID: aabe6bff-efa5-5b86-8546-c9a4ffefd56b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
