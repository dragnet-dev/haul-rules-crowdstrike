// Dragnet [Ransomware]: dragnet-ransomware-2025-6905 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: ae754c3c-d003-5083-afaf-c590092c652e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
