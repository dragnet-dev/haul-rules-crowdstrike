// Dragnet [Container]: dragnet-container-2026-2398 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 9582d93c-ed8e-5865-81f1-a80843876c36

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
