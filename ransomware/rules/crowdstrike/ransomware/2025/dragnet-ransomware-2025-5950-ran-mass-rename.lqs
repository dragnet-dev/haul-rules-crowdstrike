// Dragnet [Ransomware]: dragnet-ransomware-2025-5950 — Mass File Rename (pear)
// Status: experimental | Level: high | ID: 422f43e8-87d7-5dd5-9388-871fe887fcb2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
