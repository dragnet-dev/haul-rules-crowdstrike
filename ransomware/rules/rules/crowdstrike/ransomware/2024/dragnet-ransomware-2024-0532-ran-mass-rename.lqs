// Dragnet [Ransomware]: dragnet-ransomware-2024-0532 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 2e431c10-69d7-5a16-a9b5-7c8f51f2b3e8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
