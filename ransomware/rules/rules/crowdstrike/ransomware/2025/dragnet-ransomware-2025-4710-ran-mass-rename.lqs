// Dragnet [Ransomware]: dragnet-ransomware-2025-4710 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: 5156aa9e-d7d5-5b6c-b0c9-d042535a377d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
