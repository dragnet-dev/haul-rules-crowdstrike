// Dragnet [Ransomware]: dragnet-ransomware-2025-5208 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 190f14fb-c7dd-5860-aa41-e80a386efc88

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
