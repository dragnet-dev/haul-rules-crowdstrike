// Dragnet [Ransomware]: dragnet-ransomware-2024-3667 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 05ecf5e5-8d7a-538c-941c-9796892eb874

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
