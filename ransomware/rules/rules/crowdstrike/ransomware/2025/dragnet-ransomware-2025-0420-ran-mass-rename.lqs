// Dragnet [Ransomware]: dragnet-ransomware-2025-0420 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 7f1e37e8-4d61-5537-9795-2b9dca728dcd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
