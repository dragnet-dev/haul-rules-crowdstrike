// Dragnet [Ransomware]: dragnet-ransomware-2023-0384 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 2802b7ff-873a-5233-89d5-53c723c53915

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
