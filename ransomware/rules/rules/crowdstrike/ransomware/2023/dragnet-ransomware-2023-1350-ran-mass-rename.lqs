// Dragnet [Ransomware]: dragnet-ransomware-2023-1350 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: c22a8d43-abb1-525f-a56e-ba665307f665

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
