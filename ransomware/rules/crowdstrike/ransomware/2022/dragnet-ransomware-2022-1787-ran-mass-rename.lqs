// Dragnet [Ransomware]: dragnet-ransomware-2022-1787 — Mass File Rename (alphv)
// Status: deprecated | Level: high | ID: 159c0444-2c60-5b00-bf81-fd8fd09d4452

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
