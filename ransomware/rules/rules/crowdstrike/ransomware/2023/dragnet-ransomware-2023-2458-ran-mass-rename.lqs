// Dragnet [Ransomware]: dragnet-ransomware-2023-2458 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 61d5e77b-b4f4-5fc6-9664-31bd10246d95

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
