// Dragnet [Ransomware]: dragnet-ransomware-2025-4934 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: f83ef381-b222-52fb-9022-7fbfaad79a11

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
