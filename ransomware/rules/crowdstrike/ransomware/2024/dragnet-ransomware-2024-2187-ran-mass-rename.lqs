// Dragnet [Ransomware]: dragnet-ransomware-2024-2187 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 51d21b1c-0f23-513f-8106-d28245594c55

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
