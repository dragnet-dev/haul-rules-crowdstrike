// Dragnet [Ransomware]: dragnet-ransomware-2022-0034 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 0ab3535e-17f3-5bab-a196-67f08de5354d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
