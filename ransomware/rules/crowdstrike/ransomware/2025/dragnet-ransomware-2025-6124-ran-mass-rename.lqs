// Dragnet [Ransomware]: dragnet-ransomware-2025-6124 — Mass File Rename (warlock)
// Status: deprecated | Level: high | ID: 2adba8f6-659c-56f5-916e-86ba978f41ec

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
