// Dragnet [Ransomware]: dragnet-ransomware-2024-1615 — Mass File Rename (ElDorado)
// Status: experimental | Level: high | ID: e8215fa0-3c3c-5cdf-833a-3276d7b3e137

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
