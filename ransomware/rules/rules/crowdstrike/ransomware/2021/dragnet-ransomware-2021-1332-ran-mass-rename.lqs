// Dragnet [Ransomware]: dragnet-ransomware-2021-1332 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 34cd57a6-9b5c-5f00-b8e9-10d5dada7ccc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
