// Dragnet [Ransomware]: dragnet-ransomware-2024-1132 — Mass File Rename (play)
// Status: experimental | Level: high | ID: c12e1f85-398a-5ac7-b354-0372f22b5a14

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
