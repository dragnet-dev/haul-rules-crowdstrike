// Dragnet [Ransomware]: dragnet-ransomware-2024-2436 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: 3d85cf16-0196-538c-aa69-7bc749e91536

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
