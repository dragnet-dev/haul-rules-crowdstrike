// Dragnet [Container]: dragnet-container-2025-0006 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 3603d79f-7eeb-500e-90f2-807e848d2a3e

#event_simpleName=*
| (ImageFileName = *chainguard:* OR ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *ubuntu:18.04-ESM* OR ImageFileName = *ubuntu:20.04* OR ImageFileName = *ubuntu:20.04-ESM* OR ImageFileName = *ubuntu:22.04* OR ImageFileName = *ubuntu:23.04* OR ImageFileName = *ubuntu:23.10* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
