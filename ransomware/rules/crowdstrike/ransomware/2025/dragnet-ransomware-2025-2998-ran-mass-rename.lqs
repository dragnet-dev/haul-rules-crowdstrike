// Dragnet [Ransomware]: dragnet-ransomware-2025-2998 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: fb820d80-484a-5e7a-831d-6eefc9acef6b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
