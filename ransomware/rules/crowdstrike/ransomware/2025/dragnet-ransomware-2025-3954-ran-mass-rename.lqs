// Dragnet [Ransomware]: dragnet-ransomware-2025-3954 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 4e7c2aa2-8ad8-5424-9b81-bf44558c37a5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
