// Dragnet [Ransomware]: dragnet-ransomware-2020-0246 — Mass File Rename (netwalker)
// Status: deprecated | Level: high | ID: 3942b2ef-4b0a-5309-949b-bf23a2fc730a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
