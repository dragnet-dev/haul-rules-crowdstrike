// Dragnet [Ransomware]: dragnet-ransomware-2023-2356 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 06ef0b7d-fe38-5e86-ad32-e72780b5f969

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
