// Dragnet [Container]: dragnet-container-2026-0553 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 6e081905-2580-553c-8b17-651d12abd07a

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:7* OR ImageFileName = *ubuntu:16.04* OR ImageFileName = *ubuntu:16.04-ESM* OR ImageFileName = *ubuntu:17.04*)
| table([timestamp, ComputerName])
| limit(1000)
