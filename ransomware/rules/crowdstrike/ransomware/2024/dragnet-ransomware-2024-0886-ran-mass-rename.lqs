// Dragnet [Ransomware]: dragnet-ransomware-2024-0886 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 73ee4834-bc2d-5978-85ac-86702467bbe3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
