// Dragnet [Ransomware]: dragnet-ransomware-2025-0767 — Mass File Rename (chaos)
// Status: experimental | Level: high | ID: fb061cee-fa10-55bc-9bf3-31a2713704f7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
