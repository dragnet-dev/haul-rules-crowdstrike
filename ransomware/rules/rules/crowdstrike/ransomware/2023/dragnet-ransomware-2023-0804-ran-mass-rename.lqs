// Dragnet [Ransomware]: dragnet-ransomware-2023-0804 — Mass File Rename (knight)
// Status: experimental | Level: high | ID: 4417562c-d08d-5f16-914c-b247c63bbb18

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
