// Dragnet [Ransomware]: dragnet-ransomware-2025-5415 — Mass File Rename (flocker)
// Status: experimental | Level: high | ID: 095b6cd0-1d10-57f6-a5c0-266bdae1950d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
