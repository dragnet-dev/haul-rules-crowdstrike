// Dragnet [Ransomware]: dragnet-ransomware-2020-0200 — Mass File Rename (ryuk)
// Status: deprecated | Level: high | ID: 3a3b0b34-d2e3-5b10-86b7-cb8a4e574fda

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
