// Dragnet [Container]: dragnet-container-2025-0170 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: b1eaa06f-2ed9-5554-b128-dcb7d38e0593

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
