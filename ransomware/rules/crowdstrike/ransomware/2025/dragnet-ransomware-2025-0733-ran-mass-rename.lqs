// Dragnet [Ransomware]: dragnet-ransomware-2025-0733 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 72fca8cf-10d0-5044-bd55-e90a69f0c741

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
