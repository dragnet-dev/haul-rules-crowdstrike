// Dragnet [Ransomware]: dragnet-ransomware-2025-2624 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 653a5a10-0bd2-5bd8-885e-e438f1e4de35

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
