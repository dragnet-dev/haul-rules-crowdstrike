// Dragnet [Ransomware]: dragnet-ransomware-2022-2861 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 409ab9dc-ab86-56f5-b73e-521adc70e86b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
