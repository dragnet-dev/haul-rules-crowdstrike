// Dragnet [Ransomware]: dragnet-ransomware-2025-4474 — Mass File Rename (fog)
// Status: deprecated | Level: high | ID: d752bcaf-0e81-5244-b45c-877e3a8e5d37

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
