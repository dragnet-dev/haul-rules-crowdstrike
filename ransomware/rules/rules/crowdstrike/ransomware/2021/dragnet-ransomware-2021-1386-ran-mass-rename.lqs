// Dragnet [Ransomware]: dragnet-ransomware-2021-1386 — Mass File Rename (avaddon)
// Status: deprecated | Level: high | ID: ca23ffb1-b839-5373-9005-f4e100f9f27e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
