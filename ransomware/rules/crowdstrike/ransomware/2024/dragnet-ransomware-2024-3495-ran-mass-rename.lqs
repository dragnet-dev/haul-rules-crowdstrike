// Dragnet [Ransomware]: dragnet-ransomware-2024-3495 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 9a8ab020-e9c0-5a74-aa84-f5f93e29f382

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
