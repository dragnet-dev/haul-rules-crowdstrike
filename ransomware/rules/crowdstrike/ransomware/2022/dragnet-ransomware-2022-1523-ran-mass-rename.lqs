// Dragnet [Ransomware]: dragnet-ransomware-2022-1523 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: b397d748-e82e-5cdb-9fc4-d219380ce592

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
