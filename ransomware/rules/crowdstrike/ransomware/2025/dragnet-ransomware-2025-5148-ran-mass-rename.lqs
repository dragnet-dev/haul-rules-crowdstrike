// Dragnet [Ransomware]: dragnet-ransomware-2025-5148 — Mass File Rename (worldleaks)
// Status: test | Level: high | ID: 1d0ba5be-7193-5d3e-aab7-2159926763ae

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
