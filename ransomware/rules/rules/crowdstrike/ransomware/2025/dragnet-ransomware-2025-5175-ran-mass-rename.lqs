// Dragnet [Ransomware]: dragnet-ransomware-2025-5175 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: a5d29e2a-2fa4-54ad-b3a6-020841472eb8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
