// Dragnet [Ransomware]: dragnet-ransomware-2025-4095 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: bbc5befa-6044-5bae-8f25-8ae4b40e65a5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
