// Dragnet [Ransomware]: dragnet-ransomware-2024-0678 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: d9d862ef-b029-53e8-9985-1be674d55d47

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
