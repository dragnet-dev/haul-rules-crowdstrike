// Dragnet [Ransomware]: dragnet-ransomware-2023-0557 — Mass File Rename (cloak)
// Status: deprecated | Level: high | ID: 1ec65519-31c2-5dea-b60d-16e3ccb6e856

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
