// Dragnet [Ransomware]: dragnet-ransomware-2024-4618 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: b65ad176-61f5-57ed-ae5e-8797ea9a4552

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
