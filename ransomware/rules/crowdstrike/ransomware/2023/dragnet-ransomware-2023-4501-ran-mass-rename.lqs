// Dragnet [Ransomware]: dragnet-ransomware-2023-4501 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: c4e61dd1-f659-5a12-b4d7-d00ca0d543c6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
