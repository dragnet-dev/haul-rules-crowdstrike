// Dragnet [Ransomware]: dragnet-ransomware-2021-0328 — Mass File Rename (spook)
// Status: deprecated | Level: high | ID: 1d51a98d-7e93-5faa-9f11-f09e1ccd7235

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
