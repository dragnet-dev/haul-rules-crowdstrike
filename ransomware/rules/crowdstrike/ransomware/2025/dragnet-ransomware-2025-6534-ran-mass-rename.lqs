// Dragnet [Ransomware]: dragnet-ransomware-2025-6534 — Mass File Rename (crypto24)
// Status: deprecated | Level: high | ID: fafe955b-f503-54c7-9ff7-1e01c0d8f64c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
