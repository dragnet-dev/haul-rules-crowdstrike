// Dragnet [Ransomware]: dragnet-ransomware-2024-2461 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: eba59359-c476-5df2-83d5-673b22472534

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
