// Dragnet [Ransomware]: dragnet-ransomware-2023-4482 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 0f524bef-e282-52c7-90ed-b2b5d3256364

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
