// Dragnet [Container]: dragnet-container-2025-0706 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 1d27b27e-653c-55bf-90f1-5cd08cf030a0

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *ubuntu:18.04*)
| table([timestamp, ComputerName])
| limit(1000)
