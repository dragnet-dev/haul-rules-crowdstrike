// Dragnet [Container]: dragnet-container-2026-2358 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 87be0274-2cc6-56c5-a873-fc2b861475c1

#event_simpleName=*
| (ImageFileName = *amazonlinux:2023* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
