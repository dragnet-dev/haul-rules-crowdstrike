// Dragnet [Ransomware]: dragnet-ransomware-2025-2859 — Mass File Rename (kairos)
// Status: deprecated | Level: high | ID: 49f5089e-44a1-5c60-845a-8e07f2ecea3c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
