// Dragnet [Ransomware]: dragnet-ransomware-2025-6227 — Mass File Rename (play)
// Status: experimental | Level: high | ID: de47240b-9cdf-56d3-9c62-d399f7704097

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
