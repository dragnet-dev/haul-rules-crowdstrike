// Dragnet [Ransomware]: dragnet-ransomware-2024-3574 — Mass File Rename (ransomhouse)
// Status: experimental | Level: high | ID: 9d445a8c-b7e7-56d5-b605-2d26b34733be

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
