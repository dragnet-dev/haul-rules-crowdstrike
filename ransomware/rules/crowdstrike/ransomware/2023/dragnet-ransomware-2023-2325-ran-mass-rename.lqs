// Dragnet [Ransomware]: dragnet-ransomware-2023-2325 — Mass File Rename (royal)
// Status: experimental | Level: high | ID: d0472527-1819-5555-8b52-4f0330cc6e29

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
