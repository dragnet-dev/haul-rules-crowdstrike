// Dragnet [Container]: dragnet-container-2026-2573 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: db0e9241-69f9-5291-9b3f-cf38b0482eba

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:5*)
| table([timestamp, ComputerName])
| limit(1000)
