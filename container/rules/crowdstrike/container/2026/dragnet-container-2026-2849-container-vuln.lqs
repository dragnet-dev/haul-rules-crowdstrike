// Dragnet [Container]: dragnet-container-2026-2849 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 6e7a28c5-5699-5c36-a0ba-a1205d119531

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:7* OR ImageFileName = *debian:8* OR ImageFileName = *debian:9* OR ImageFileName = *ubuntu:17.04*)
| table([timestamp, ComputerName])
| limit(1000)
