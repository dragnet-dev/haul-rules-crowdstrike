// Dragnet [Ransomware]: dragnet-ransomware-2024-2733 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 1885df72-8c7b-52e7-be3b-f9e9387ad026

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
