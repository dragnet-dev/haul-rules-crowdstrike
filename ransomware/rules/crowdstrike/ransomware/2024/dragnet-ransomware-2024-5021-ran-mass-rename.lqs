// Dragnet [Ransomware]: dragnet-ransomware-2024-5021 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 43eeea73-dc98-5a50-ae3a-bf24c0b4a72f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
