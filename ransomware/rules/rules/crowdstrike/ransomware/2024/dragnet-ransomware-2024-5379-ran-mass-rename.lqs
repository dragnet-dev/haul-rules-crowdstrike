// Dragnet [Ransomware]: dragnet-ransomware-2024-5379 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 5249bcfa-cc2f-56a8-8cf3-9e12b2853600

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
