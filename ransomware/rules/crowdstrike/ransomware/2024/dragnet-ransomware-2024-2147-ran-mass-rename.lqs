// Dragnet [Ransomware]: dragnet-ransomware-2024-2147 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 5a973d0f-ba48-5d11-a763-e9b9044a623c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
