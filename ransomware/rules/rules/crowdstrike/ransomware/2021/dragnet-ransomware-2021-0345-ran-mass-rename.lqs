// Dragnet [Ransomware]: dragnet-ransomware-2021-0345 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 3c558d3e-2f69-5566-8188-852551f97002

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
