// Dragnet [Ransomware]: dragnet-ransomware-2025-5863 — Mass File Rename (devman)
// Status: experimental | Level: high | ID: 774d0209-2619-566e-ba8d-fc475e43bcaa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
