// Dragnet [Ransomware]: dragnet-ransomware-2024-1650 — Mass File Rename (rhysida)
// Status: deprecated | Level: high | ID: 0dd625a0-4522-58de-9607-3527273b3ee8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
