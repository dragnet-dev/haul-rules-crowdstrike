// Dragnet [Ransomware]: dragnet-ransomware-2023-3507 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: c720d948-0027-5175-b0f3-16630e79cf0a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
