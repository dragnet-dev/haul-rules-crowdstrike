// Dragnet [Ransomware]: dragnet-ransomware-2025-6554 — Mass File Rename (hellcat)
// Status: deprecated | Level: high | ID: cb518bd9-2119-59f8-af21-5d0d7ec98b5d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
