// Dragnet [Ransomware]: dragnet-ransomware-2025-6688 — Mass File Rename (devman)
// Status: experimental | Level: high | ID: 7b28458e-a9bb-5d07-b23d-32a8a14cb508

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
