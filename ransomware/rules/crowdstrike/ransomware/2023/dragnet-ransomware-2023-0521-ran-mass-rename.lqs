// Dragnet [Ransomware]: dragnet-ransomware-2023-0521 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: a91ab5d6-bd9d-50bb-a2ea-3e961ec8fd06

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
