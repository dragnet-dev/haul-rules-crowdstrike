// Dragnet [Ransomware]: dragnet-ransomware-2022-1570 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: e20e8f0a-ce8c-5bd5-87e6-7d4ace898aa1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
