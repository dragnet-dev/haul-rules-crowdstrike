// Dragnet [Ransomware]: dragnet-ransomware-2024-2480 — Mass File Rename (embargo)
// Status: experimental | Level: high | ID: 572cfe92-a148-5f33-ad60-9441683ce5ea

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
