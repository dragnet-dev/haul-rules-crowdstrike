// Dragnet [Container]: dragnet-container-2024-0171 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 36dcf67d-033a-5fc1-b6a2-386245cc9500

#event_simpleName=*
| (ImageFileName = *amazonlinux:2022* OR ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:9* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:20.04-ESM* OR ImageFileName = *ubuntu:22.04*)
| table([timestamp, ComputerName])
| limit(1000)
