// Dragnet [Ransomware]: dragnet-ransomware-2024-2200 — Mass File Rename (cloak)
// Status: deprecated | Level: high | ID: 31b21c66-82ef-5b16-a538-e1aaa365aa19

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
