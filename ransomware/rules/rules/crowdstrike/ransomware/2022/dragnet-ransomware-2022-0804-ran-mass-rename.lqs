// Dragnet [Ransomware]: dragnet-ransomware-2022-0804 — Mass File Rename (unsafe)
// Status: deprecated | Level: high | ID: 8aed5d3d-c11a-5b3a-ad14-ff4ae13e2115

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
