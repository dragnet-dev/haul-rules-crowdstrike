// Dragnet [Ransomware]: dragnet-ransomware-2024-5644 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 2314cbf1-8cd6-5eb3-be30-a4956bb6dcf5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
