// Dragnet [Ransomware]: dragnet-ransomware-2023-0279 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: b07c24b4-b9c5-5f04-a989-e6ff9c990b93

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
