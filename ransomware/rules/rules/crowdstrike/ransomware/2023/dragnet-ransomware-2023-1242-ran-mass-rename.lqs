// Dragnet [Ransomware]: dragnet-ransomware-2023-1242 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 29cb75cb-eb8a-5c9c-af23-966e37e4a034

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
