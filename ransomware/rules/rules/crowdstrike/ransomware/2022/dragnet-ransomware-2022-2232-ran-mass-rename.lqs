// Dragnet [Ransomware]: dragnet-ransomware-2022-2232 — Mass File Rename (alphv)
// Status: deprecated | Level: high | ID: a0100b1a-33b9-541c-9cd7-49d4153eac95

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
