// Dragnet [Ransomware]: dragnet-ransomware-2024-2197 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 24f45a22-0e82-578b-9e21-48af3d5ea10a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
