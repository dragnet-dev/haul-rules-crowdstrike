// Dragnet [Ransomware]: dragnet-ransomware-2025-2705 — Mass File Rename (flocker)
// Status: experimental | Level: high | ID: 89405073-7f68-5cdb-a6fc-f74bdc2628fe

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
