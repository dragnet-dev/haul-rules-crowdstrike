// Dragnet [Ransomware]: dragnet-ransomware-2024-4815 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 1aa11126-2377-5d95-adf8-2dbad5c8d79f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
