// Dragnet [Ransomware]: dragnet-ransomware-2025-1942 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 59e386e3-ef42-5d8a-a1be-40ffa4d58549

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
