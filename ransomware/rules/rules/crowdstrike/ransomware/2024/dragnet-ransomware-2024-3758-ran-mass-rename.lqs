// Dragnet [Ransomware]: dragnet-ransomware-2024-3758 — Mass File Rename (blacklock)
// Status: experimental | Level: high | ID: 61e8e640-9657-5e2f-9f68-e91750493e42

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
