// Dragnet [Ransomware]: dragnet-ransomware-2023-1489 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 7452294a-01fa-57a7-b833-f4403a19dea8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
