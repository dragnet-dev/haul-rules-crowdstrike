// Dragnet [Ransomware]: dragnet-ransomware-2024-4822 — Mass File Rename (apt73)
// Status: experimental | Level: high | ID: 6bffc429-9b74-535d-a6a3-23d63fbbabf7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
