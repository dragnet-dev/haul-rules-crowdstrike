// Dragnet [Ransomware]: dragnet-ransomware-2025-7752 — Mass File Rename (direwolf)
// Status: experimental | Level: high | ID: 4e7ad85e-c858-5573-92d3-6911760a5bcc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
