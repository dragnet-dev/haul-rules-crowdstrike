// Dragnet [Ransomware]: dragnet-ransomware-2026-2595 — Mass File Rename (threeam)
// Status: stable | Level: high | ID: 081ad57f-bf32-5866-9353-70d6816d07e6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
