// Dragnet [Ransomware]: dragnet-ransomware-2025-6698 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 2fe64c2c-9fd3-52d9-934f-fe0f84b5869e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
