// Dragnet [Ransomware]: dragnet-ransomware-2026-2858 — Mass File Rename (dragonforce)
// Status: stable | Level: high | ID: 9aed5ad9-7d93-58c1-9137-ebc308b2b985

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
