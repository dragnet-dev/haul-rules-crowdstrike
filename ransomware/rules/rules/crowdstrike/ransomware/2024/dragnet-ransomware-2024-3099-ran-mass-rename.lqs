// Dragnet [Ransomware]: dragnet-ransomware-2024-3099 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 3e4d51a2-0b98-512a-9fae-6c2e20faa1c5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
