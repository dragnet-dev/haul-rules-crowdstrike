// Dragnet [Ransomware]: dragnet-ransomware-2025-7724 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 73bd43ce-41a0-559a-a5e8-7b89f4ae6f1f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
