// Dragnet [Ransomware]: dragnet-ransomware-2023-2204 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 73c771b1-63c4-570a-9601-2253db68b80a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
