// Dragnet [Ransomware]: dragnet-ransomware-2025-3712 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: b3eaf4c1-d036-51a2-b264-b3584cf97c79

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
