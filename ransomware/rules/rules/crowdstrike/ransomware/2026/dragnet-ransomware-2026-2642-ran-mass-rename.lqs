// Dragnet [Ransomware]: dragnet-ransomware-2026-2642 — Mass File Rename (lockbit5)
// Status: stable | Level: high | ID: c0bdc874-7585-578c-866b-57714a684063

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
