// Dragnet [Ransomware]: dragnet-ransomware-2023-4095 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 5a197168-3627-547e-a5ec-4c8ce98e8cf4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
