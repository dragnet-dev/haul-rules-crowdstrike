// Dragnet [Ransomware]: dragnet-ransomware-2023-3544 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: d9f57185-7e03-56ab-885f-c7498773f3be

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
