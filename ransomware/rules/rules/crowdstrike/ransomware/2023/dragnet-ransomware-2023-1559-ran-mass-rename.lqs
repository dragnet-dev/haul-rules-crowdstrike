// Dragnet [Ransomware]: dragnet-ransomware-2023-1559 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: 51fdf8db-888c-58a3-b433-0296b570a1d6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
