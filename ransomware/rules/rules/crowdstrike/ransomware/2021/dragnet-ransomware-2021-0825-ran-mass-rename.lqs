// Dragnet [Ransomware]: dragnet-ransomware-2021-0825 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 5be7167c-bcc5-5178-a843-cdd572cd14f6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
