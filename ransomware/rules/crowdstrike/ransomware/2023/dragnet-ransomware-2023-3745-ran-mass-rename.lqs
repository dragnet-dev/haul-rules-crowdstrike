// Dragnet [Ransomware]: dragnet-ransomware-2023-3745 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: e7bc995b-fcbe-52da-835b-f337754cc814

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
