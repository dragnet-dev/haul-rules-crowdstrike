// Dragnet [Ransomware]: dragnet-ransomware-2025-2413 — Mass File Rename (thegentlemen)
// Status: experimental | Level: high | ID: 9374cd21-982e-5049-881f-fe45d19095f9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
