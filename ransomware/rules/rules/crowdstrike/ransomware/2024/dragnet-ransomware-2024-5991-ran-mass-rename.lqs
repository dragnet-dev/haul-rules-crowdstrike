// Dragnet [Ransomware]: dragnet-ransomware-2024-5991 — Mass File Rename (play)
// Status: experimental | Level: high | ID: ed30fee8-d9fa-5fd9-8211-a60dbea2b3e2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
