// Dragnet [Ransomware]: dragnet-ransomware-2025-4532 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 527cc98f-3e12-5822-851d-97f3344ebc07

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
