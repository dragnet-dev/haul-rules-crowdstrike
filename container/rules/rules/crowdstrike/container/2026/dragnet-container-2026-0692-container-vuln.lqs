// Dragnet [Container]: dragnet-container-2026-0692 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: f369aa70-faaf-5ec2-8606-fca77667ad29

#event_simpleName=*
| (ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *redhat/ubi9:*)
| table([timestamp, ComputerName])
| limit(1000)
