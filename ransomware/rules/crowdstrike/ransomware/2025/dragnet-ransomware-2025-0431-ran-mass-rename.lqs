// Dragnet [Ransomware]: dragnet-ransomware-2025-0431 — Mass File Rename (anubis)
// Status: experimental | Level: high | ID: 6e9f25ec-3b1c-5266-ba26-b7a95ebc2600

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
