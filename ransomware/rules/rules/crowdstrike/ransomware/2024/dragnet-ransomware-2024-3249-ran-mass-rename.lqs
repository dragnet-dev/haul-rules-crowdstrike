// Dragnet [Ransomware]: dragnet-ransomware-2024-3249 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: c5b4ad88-48bf-5030-a82a-920630306fed

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
