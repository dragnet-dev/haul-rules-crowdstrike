// Dragnet [Ransomware]: dragnet-ransomware-2026-1149 — Mass File Rename (thegentlemen)
// Status: stable | Level: high | ID: 5d6aace3-f07e-5318-b153-1918edb08b7b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
