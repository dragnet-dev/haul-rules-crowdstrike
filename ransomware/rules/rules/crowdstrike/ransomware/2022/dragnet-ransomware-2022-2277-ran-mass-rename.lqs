// Dragnet [Ransomware]: dragnet-ransomware-2022-2277 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 1000208d-eeb5-5c59-ab25-e67d08e9f0d6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
