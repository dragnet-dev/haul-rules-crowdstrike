// Dragnet [Ransomware]: dragnet-ransomware-2025-2402 — Mass File Rename (thegentlemen)
// Status: experimental | Level: high | ID: c0274f62-3c19-5167-93f3-bc076af9dba2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
