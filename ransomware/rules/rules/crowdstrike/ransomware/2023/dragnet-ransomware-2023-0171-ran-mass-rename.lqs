// Dragnet [Ransomware]: dragnet-ransomware-2023-0171 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: c38b4af0-4876-534c-96c5-feec7a6f9f2b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
