// Dragnet [Ransomware]: dragnet-ransomware-2024-4211 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 5f1f5294-dbd8-5efd-9ca9-274ba74541ae

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
