// Dragnet [Ransomware]: dragnet-ransomware-2025-4731 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: cf89f4fb-1f76-5e3e-babb-938acbb3686a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
