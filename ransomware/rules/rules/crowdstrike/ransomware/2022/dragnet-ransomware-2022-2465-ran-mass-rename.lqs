// Dragnet [Ransomware]: dragnet-ransomware-2022-2465 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 6c6f0b8d-30e3-5c6f-8c8f-cae1bc68ed6e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
