// Dragnet [Ransomware]: dragnet-ransomware-2023-4163 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: dff60480-2d07-5e32-95f2-d95246225a1d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
