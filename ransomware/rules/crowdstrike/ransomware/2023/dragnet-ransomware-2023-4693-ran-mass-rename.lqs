// Dragnet [Ransomware]: dragnet-ransomware-2023-4693 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 31a11d24-7d3d-5ea9-a7eb-d0785a0691e3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
