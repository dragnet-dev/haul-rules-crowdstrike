// Dragnet [Ransomware]: dragnet-ransomware-2023-3034 — Mass File Rename (stormous)
// Status: experimental | Level: high | ID: a25f9e4c-18dd-5df0-adcf-bc6f15993dca

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
