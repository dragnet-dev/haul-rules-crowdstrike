// Dragnet [Ransomware]: dragnet-ransomware-2025-0533 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: ebdda70e-7d8d-5e11-8ff4-71e4e72afa72

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
