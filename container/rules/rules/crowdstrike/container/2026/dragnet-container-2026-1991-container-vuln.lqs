// Dragnet [Container]: dragnet-container-2026-1991 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 7e35da0a-a8f8-5f74-880d-05a24b6184e3

#event_simpleName=*
| (ImageFileName = *alpine edge:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
