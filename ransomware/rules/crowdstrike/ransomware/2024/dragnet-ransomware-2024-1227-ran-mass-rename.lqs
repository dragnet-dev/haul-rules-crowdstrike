// Dragnet [Ransomware]: dragnet-ransomware-2024-1227 — Mass File Rename (SilentRansomGroup)
// Status: deprecated | Level: high | ID: f5941d21-484d-57a9-9f22-f575ccdaf749

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
