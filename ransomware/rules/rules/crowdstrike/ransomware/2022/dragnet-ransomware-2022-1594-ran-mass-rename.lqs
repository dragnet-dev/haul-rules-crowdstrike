// Dragnet [Ransomware]: dragnet-ransomware-2022-1594 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 820a142b-9c7c-5e7f-a560-81c688af441e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
