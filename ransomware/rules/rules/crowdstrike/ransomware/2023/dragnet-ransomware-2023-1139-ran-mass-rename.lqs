// Dragnet [Ransomware]: dragnet-ransomware-2023-1139 — Mass File Rename (play)
// Status: experimental | Level: high | ID: bf553435-8219-5245-941b-b0869a7e78e4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
