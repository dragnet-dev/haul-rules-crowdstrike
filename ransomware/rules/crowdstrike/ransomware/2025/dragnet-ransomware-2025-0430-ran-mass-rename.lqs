// Dragnet [Ransomware]: dragnet-ransomware-2025-0430 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: bf479faa-7a9c-5ff8-9fed-3d44153fd857

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
