// Dragnet [Ransomware]: dragnet-ransomware-2024-2328 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: 80079352-0033-5ca9-b4bc-cc84af34add0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
