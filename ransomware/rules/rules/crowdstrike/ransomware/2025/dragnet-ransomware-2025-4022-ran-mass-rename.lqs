// Dragnet [Ransomware]: dragnet-ransomware-2025-4022 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: c2b99b14-a06e-59b8-884b-ba00f6b45781

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
