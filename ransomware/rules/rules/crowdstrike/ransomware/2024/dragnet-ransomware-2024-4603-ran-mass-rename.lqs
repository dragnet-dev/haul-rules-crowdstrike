// Dragnet [Ransomware]: dragnet-ransomware-2024-4603 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 2152b35b-db7f-5a01-a6b6-be9562087c36

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
