// Dragnet [Ransomware]: dragnet-ransomware-2024-5031 — Mass File Rename (blacklock)
// Status: experimental | Level: high | ID: 36641638-ab20-5228-8c97-7ff611814fce

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
