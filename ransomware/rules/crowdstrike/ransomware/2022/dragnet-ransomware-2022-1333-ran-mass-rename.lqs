// Dragnet [Ransomware]: dragnet-ransomware-2022-1333 — Mass File Rename (royal)
// Status: deprecated | Level: high | ID: 7d01df6e-2495-5e34-8112-20a6ac57310f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
