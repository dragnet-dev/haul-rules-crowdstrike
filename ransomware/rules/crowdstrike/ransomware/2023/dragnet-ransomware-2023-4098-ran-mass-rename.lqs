// Dragnet [Ransomware]: dragnet-ransomware-2023-4098 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: c455b414-2051-5b56-a485-0cba1c83fe47

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
