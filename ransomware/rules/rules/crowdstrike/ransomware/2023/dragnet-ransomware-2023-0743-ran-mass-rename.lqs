// Dragnet [Ransomware]: dragnet-ransomware-2023-0743 — Mass File Rename (noescape)
// Status: experimental | Level: high | ID: eae8eca7-5738-507b-bfed-3f02c3480d4a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
