// Dragnet [Ransomware]: dragnet-ransomware-2023-1088 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 7d982d76-e18a-5e86-ad2e-76cfc08f0b23

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
