// Dragnet [Ransomware]: dragnet-ransomware-2023-2721 — Mass File Rename (moneymessage)
// Status: experimental | Level: high | ID: 1cb53eb8-f84b-501d-a5f8-971406164b70

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
