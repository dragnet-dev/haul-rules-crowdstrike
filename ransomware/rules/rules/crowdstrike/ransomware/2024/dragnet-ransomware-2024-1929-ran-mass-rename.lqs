// Dragnet [Ransomware]: dragnet-ransomware-2024-1929 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: b09a7de3-2262-5450-b45d-a8d0b560d23f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
