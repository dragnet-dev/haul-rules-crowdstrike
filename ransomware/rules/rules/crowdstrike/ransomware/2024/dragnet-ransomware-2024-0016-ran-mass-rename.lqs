// Dragnet [Ransomware]: dragnet-ransomware-2024-0016 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 231389c6-9eb9-5f17-82fb-c45f8f99d820

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
