// Dragnet [Ransomware]: dragnet-ransomware-2024-2448 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: a57a6356-d762-519e-b8f8-a3fd5d72f9f9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
