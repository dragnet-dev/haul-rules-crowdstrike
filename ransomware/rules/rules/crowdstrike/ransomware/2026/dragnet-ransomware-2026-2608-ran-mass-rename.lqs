// Dragnet [Ransomware]: dragnet-ransomware-2026-2608 — Mass File Rename (safepay)
// Status: stable | Level: high | ID: 9f96f959-9b38-5e60-a3f3-5d21f242dfdb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
