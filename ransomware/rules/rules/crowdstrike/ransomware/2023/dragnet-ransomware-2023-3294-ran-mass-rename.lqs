// Dragnet [Ransomware]: dragnet-ransomware-2023-3294 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: d9000fa2-af66-5640-abfe-f37e3d0ec877

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
