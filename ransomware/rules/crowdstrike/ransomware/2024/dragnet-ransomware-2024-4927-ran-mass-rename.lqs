// Dragnet [Ransomware]: dragnet-ransomware-2024-4927 — Mass File Rename (malekteam)
// Status: experimental | Level: high | ID: d20a1679-0a5e-572d-b60a-ef17102cb6de

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
