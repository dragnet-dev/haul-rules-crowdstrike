// Dragnet [Ransomware]: dragnet-ransomware-2023-0706 — Mass File Rename (ransomhouse)
// Status: deprecated | Level: high | ID: 2ec210bb-79c6-5529-aa79-3992290e1427

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
