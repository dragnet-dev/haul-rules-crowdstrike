// Dragnet [Ransomware]: dragnet-ransomware-2025-5760 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: d99fb758-9e80-5e19-aad4-12ba44e23dcb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
