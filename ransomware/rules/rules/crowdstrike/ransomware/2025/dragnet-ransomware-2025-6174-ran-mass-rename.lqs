// Dragnet [Ransomware]: dragnet-ransomware-2025-6174 — Mass File Rename (SilentRansomGroup)
// Status: deprecated | Level: high | ID: 1ac1f00b-7a17-572d-9fa8-09bef46219ab

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
