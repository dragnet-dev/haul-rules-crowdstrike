// Dragnet [Ransomware]: dragnet-ransomware-2024-4153 — Mass File Rename (raworld)
// Status: experimental | Level: high | ID: 345be840-bde9-5375-bff0-99e00a5f8a42

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
