// Dragnet [Ransomware]: dragnet-ransomware-2025-1545 — Mass File Rename (incransom)
// Status: test | Level: high | ID: 29ecb6b0-831e-5459-8202-18811751c05a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
