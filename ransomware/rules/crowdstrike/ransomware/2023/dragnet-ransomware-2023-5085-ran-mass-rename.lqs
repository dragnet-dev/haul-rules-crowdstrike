// Dragnet [Ransomware]: dragnet-ransomware-2023-5085 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: deb89258-0667-55bf-b067-1e774de07442

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
