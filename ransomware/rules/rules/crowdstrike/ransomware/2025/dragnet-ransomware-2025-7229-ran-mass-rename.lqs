// Dragnet [Ransomware]: dragnet-ransomware-2025-7229 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 890349bb-72c2-5260-bfad-2134fb723fab

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
