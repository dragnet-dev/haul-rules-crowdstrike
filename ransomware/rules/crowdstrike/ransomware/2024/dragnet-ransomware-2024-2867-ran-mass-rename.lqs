// Dragnet [Ransomware]: dragnet-ransomware-2024-2867 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: fec741d3-f96e-503e-8b3c-9035f2a95a02

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
