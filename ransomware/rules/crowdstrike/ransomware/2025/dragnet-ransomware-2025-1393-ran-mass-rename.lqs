// Dragnet [Ransomware]: dragnet-ransomware-2025-1393 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: cf33a4c5-5131-534a-a81f-cf04d8ee187c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
