// Dragnet [Ransomware]: dragnet-ransomware-2021-1056 — Mass File Rename (lv)
// Status: deprecated | Level: high | ID: 805111b6-7a5c-5664-a1fc-237f3f1a37e0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
