// Dragnet [Container]: dragnet-container-2026-1655 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 59b28d0f-d156-538f-a642-c03741c36a6a

#event_simpleName=*
| (ImageFileName = *alpine:3.16* OR ImageFileName = *alpine:3.17* OR ImageFileName = *cbl-mariner:1.0* OR ImageFileName = *cbl-mariner:2.0* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *photon os:4.0* OR ImageFileName = *photon os:5.0* OR ImageFileName = *ubuntu:22.04* OR ImageFileName = *ubuntu:23.04*)
| table([timestamp, ComputerName])
| limit(1000)
