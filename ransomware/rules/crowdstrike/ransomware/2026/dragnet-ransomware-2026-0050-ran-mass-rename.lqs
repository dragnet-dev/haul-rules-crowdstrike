// Dragnet [Ransomware]: dragnet-ransomware-2026-0050 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: d2281b6a-df0c-5074-b5f1-43a64ddcf547

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
