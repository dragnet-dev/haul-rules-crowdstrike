// Dragnet [Ransomware]: dragnet-ransomware-2020-0012 — Mass File Rename (maze)
// Status: deprecated | Level: high | ID: 14fa9005-76c0-5910-8160-a9abeff2f694

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
