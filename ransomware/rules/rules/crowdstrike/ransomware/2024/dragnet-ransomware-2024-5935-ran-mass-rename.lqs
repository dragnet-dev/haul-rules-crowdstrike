// Dragnet [Ransomware]: dragnet-ransomware-2024-5935 — Mass File Rename (embargo)
// Status: experimental | Level: high | ID: 3c4c168d-bb7a-5803-8b67-29a4050991fb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
