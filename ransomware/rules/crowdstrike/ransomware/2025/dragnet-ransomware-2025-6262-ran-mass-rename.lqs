// Dragnet [Ransomware]: dragnet-ransomware-2025-6262 — Mass File Rename (play)
// Status: experimental | Level: high | ID: a5e3cd2d-0c83-579c-b6ca-c67010862450

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
