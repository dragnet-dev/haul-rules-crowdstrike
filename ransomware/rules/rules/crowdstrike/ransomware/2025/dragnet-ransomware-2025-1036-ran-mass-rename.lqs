// Dragnet [Ransomware]: dragnet-ransomware-2025-1036 — Mass File Rename (ralord)
// Status: experimental | Level: high | ID: fe69754f-5849-5ebb-b978-524b49489694

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
