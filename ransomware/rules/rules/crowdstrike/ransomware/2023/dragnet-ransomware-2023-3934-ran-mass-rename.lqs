// Dragnet [Ransomware]: dragnet-ransomware-2023-3934 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: fc0ece9a-a944-5db0-8e0a-f8dbdc976890

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
