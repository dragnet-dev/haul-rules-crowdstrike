// Dragnet [Ransomware]: dragnet-ransomware-2022-1173 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 161bf6ba-bcf1-510c-a99e-1def694f6ac3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
