// Dragnet [Ransomware]: dragnet-ransomware-2025-6415 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 8d491508-64bb-5cdc-8afe-6a06b9a78aed

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
