// Dragnet [Ransomware]: dragnet-ransomware-2024-2040 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 41b4e97c-3af3-5b3a-b066-d42031ebc349

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
