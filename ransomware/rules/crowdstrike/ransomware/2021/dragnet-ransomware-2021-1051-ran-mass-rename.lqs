// Dragnet [Ransomware]: dragnet-ransomware-2021-1051 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: c04159d3-c3cf-566a-aa2c-7da020d47aed

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
