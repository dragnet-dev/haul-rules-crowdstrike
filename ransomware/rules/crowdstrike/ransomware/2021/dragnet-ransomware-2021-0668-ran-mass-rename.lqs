// Dragnet [Ransomware]: dragnet-ransomware-2021-0668 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: ef278e31-08bd-57a3-a7fe-eb06e2132d80

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
