// Dragnet [Ransomware]: dragnet-ransomware-2023-3643 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 87bd7467-3c7e-5c89-af68-25c5801b6be2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
