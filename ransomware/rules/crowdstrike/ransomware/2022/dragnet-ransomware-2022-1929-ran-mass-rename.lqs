// Dragnet [Ransomware]: dragnet-ransomware-2022-1929 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 582e4910-9eaa-5038-a5d4-150e84891df2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
