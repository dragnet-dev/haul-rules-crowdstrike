// Dragnet [Ransomware]: dragnet-ransomware-2023-0995 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: af3f819d-85f2-59ca-a137-efd73526024f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
