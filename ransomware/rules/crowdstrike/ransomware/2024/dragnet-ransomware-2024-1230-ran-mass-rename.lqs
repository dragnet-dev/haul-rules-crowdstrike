// Dragnet [Ransomware]: dragnet-ransomware-2024-1230 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: b09ff665-3532-5568-bd80-5290a2630ee9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
