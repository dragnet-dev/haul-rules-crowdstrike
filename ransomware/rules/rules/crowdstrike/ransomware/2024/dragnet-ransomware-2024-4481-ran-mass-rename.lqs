// Dragnet [Ransomware]: dragnet-ransomware-2024-4481 — Mass File Rename (handala)
// Status: experimental | Level: high | ID: 23290dfd-6e5d-549c-9293-e2e1729891b8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
