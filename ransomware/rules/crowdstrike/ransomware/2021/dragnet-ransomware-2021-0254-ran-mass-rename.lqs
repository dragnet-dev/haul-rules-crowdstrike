// Dragnet [Ransomware]: dragnet-ransomware-2021-0254 — Mass File Rename (groove)
// Status: deprecated | Level: high | ID: f53a7590-b738-55bf-bb58-f8068b4f5506

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
