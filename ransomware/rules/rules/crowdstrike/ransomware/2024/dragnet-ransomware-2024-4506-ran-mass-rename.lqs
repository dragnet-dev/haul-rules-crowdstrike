// Dragnet [Ransomware]: dragnet-ransomware-2024-4506 — Mass File Rename (trigona)
// Status: experimental | Level: high | ID: d13eb3ff-6ac6-5a8b-b3dc-42e7ac65f95e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
