// Dragnet [Ransomware]: dragnet-ransomware-2025-7317 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 733ce391-6f90-5f00-9626-a6caf40631c1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
