// Dragnet [Ransomware]: dragnet-ransomware-2024-0287 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 41f5a2d6-9c90-570e-9c12-092dcc5e030f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
