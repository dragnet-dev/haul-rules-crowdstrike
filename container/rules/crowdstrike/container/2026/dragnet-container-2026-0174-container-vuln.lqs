// Dragnet [Container]: dragnet-container-2026-0174 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: bacff186-8146-5a7b-a6d0-d2c7f36c714d

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:5*)
| table([timestamp, ComputerName])
| limit(1000)
