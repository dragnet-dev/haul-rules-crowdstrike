// Dragnet [Ransomware]: dragnet-ransomware-2025-2165 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: c7c082ae-efad-5fcd-bdb9-c9389a1b192d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
