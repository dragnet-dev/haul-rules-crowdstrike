// Dragnet [Ransomware]: dragnet-ransomware-2024-5959 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: d7654a6a-00c4-511d-a366-60ee79c527e5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
