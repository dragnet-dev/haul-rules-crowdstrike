// Dragnet [Ransomware]: dragnet-ransomware-2025-2796 — Mass File Rename (devman)
// Status: experimental | Level: high | ID: 7c2d70ca-f84a-530f-ba63-6b74c3ca39fb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
