// Dragnet [Ransomware]: dragnet-ransomware-2025-6641 — Mass File Rename (J)
// Status: experimental | Level: high | ID: 23d8cb03-19cd-51a5-b9bf-44a5c272d8d7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
