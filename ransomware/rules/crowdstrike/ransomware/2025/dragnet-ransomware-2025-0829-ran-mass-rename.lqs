// Dragnet [Ransomware]: dragnet-ransomware-2025-0829 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 325952ca-9520-5c12-bc91-7ba721b5389a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
