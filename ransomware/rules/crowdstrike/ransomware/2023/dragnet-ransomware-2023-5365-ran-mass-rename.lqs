// Dragnet [Ransomware]: dragnet-ransomware-2023-5365 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 4f4656f1-1ec7-5fa4-86f3-ad68ae42f564

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
