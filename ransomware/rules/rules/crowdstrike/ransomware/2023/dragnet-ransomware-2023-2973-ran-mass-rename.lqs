// Dragnet [Ransomware]: dragnet-ransomware-2023-2973 — Mass File Rename (moneymessage)
// Status: experimental | Level: high | ID: 142d986c-e73e-5370-a31e-e1ce5da49bd9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
