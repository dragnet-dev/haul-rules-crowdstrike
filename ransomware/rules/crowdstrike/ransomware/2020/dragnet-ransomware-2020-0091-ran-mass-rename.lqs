// Dragnet [Ransomware]: dragnet-ransomware-2020-0091 — Mass File Rename (snake)
// Status: deprecated | Level: high | ID: 775ad930-f0f6-5ad1-a1eb-c5c26fa4fb60

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
