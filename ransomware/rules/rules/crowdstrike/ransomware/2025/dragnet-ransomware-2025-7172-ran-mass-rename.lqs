// Dragnet [Ransomware]: dragnet-ransomware-2025-7172 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: 65def575-59a3-57f8-8eef-3a850f44e9aa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
