// Dragnet [Ransomware]: dragnet-ransomware-2024-5569 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 2cf83c8b-dcc7-5c66-b165-4fb6a8f0efcf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
