// Dragnet [Ransomware]: dragnet-ransomware-2024-1950 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 8dd978ba-58d2-573c-bedb-a96445c67865

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
