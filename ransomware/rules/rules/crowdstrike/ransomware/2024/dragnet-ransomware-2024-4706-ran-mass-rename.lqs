// Dragnet [Ransomware]: dragnet-ransomware-2024-4706 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: cf0ca07e-d859-5854-860d-238984b97451

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
