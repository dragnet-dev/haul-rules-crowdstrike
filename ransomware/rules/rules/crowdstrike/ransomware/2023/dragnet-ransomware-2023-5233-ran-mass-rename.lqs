// Dragnet [Ransomware]: dragnet-ransomware-2023-5233 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: bee25b61-1f92-5538-9572-ca7859e13a8e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
