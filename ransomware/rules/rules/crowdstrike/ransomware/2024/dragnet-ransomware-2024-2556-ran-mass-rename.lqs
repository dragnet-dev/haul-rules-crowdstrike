// Dragnet [Ransomware]: dragnet-ransomware-2024-2556 — Mass File Rename (dragonforce)
// Status: deprecated | Level: high | ID: 4be5c5a7-4bf0-5c81-8e06-679890358f4b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
