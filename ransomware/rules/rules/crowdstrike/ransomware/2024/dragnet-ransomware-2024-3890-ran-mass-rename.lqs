// Dragnet [Ransomware]: dragnet-ransomware-2024-3890 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: f79171dc-7990-5405-ade5-a2698cb77744

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
