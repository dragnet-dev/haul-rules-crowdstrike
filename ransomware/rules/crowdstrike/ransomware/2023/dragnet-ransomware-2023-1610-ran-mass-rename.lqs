// Dragnet [Ransomware]: dragnet-ransomware-2023-1610 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 41495f4a-60dd-54bc-b822-1e0a34b73648

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
