// Dragnet [Ransomware]: dragnet-ransomware-2023-2288 — Mass File Rename (losttrust)
// Status: deprecated | Level: high | ID: 66b2290e-e2bf-5db2-a9af-55edaaaa39f3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
