// Dragnet [Ransomware]: dragnet-ransomware-2020-0161 — Mass File Rename (revil)
// Status: deprecated | Level: high | ID: d066efbd-38a9-5411-a702-eef793cf85c2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
