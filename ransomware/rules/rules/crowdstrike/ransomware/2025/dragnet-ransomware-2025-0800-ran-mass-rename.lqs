// Dragnet [Ransomware]: dragnet-ransomware-2025-0800 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: 840c4cd9-5d54-510c-818c-853cf3912327

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
