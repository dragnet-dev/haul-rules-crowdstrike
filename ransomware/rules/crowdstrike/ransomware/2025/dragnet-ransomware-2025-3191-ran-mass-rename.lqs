// Dragnet [Ransomware]: dragnet-ransomware-2025-3191 — Mass File Rename (chaos)
// Status: experimental | Level: high | ID: cfa79179-df02-5592-b36f-be1f07be49ed

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
