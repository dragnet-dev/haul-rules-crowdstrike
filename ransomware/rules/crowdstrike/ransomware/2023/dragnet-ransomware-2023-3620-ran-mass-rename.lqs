// Dragnet [Ransomware]: dragnet-ransomware-2023-3620 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: ff43580c-cd7d-51b1-81ed-adb903054d63

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
