// Dragnet [Container]: dragnet-container-2024-0159 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 643ee48e-8212-50f0-a744-d674faa2a6c5

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:9*)
| table([timestamp, ComputerName])
| limit(1000)
