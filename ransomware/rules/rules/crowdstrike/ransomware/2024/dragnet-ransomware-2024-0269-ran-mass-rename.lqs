// Dragnet [Ransomware]: dragnet-ransomware-2024-0269 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 80ab7bd7-9d5b-54a0-b118-f915f56dab5a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
