// Dragnet [Ransomware]: dragnet-ransomware-2022-2206 — Mass File Rename (midas)
// Status: deprecated | Level: high | ID: c81f73e2-7ae0-5759-920e-0ed9fd27730f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
