// Dragnet [Container]: dragnet-container-2026-1235 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 921dd5e1-b8fb-5320-8213-889984dcc046

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:8*)
| table([timestamp, ComputerName])
| limit(1000)
