// Dragnet [Ransomware]: dragnet-ransomware-2023-0087 — Mass File Rename (play)
// Status: experimental | Level: high | ID: fc6ec423-3120-53a4-8a23-e3bf2493dcd3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
