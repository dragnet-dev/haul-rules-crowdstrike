// Dragnet [Ransomware]: dragnet-ransomware-2025-0258 — Mass File Rename (arcusmedia)
// Status: experimental | Level: high | ID: 8e2f5ed3-f642-53c7-bc2a-49906afcb326

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
