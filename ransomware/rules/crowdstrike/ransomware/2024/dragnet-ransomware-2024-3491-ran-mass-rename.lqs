// Dragnet [Ransomware]: dragnet-ransomware-2024-3491 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: ea4461b8-f21e-55c2-a49e-52462722b380

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
