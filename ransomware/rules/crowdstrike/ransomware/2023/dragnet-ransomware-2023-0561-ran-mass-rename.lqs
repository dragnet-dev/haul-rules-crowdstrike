// Dragnet [Ransomware]: dragnet-ransomware-2023-0561 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 0bfdd308-0c85-5700-a6ad-989aebfc5998

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
