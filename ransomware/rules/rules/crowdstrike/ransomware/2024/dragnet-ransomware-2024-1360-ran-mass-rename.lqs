// Dragnet [Ransomware]: dragnet-ransomware-2024-1360 — Mass File Rename (safepay)
// Status: deprecated | Level: high | ID: 0ce3bfda-bc42-5d3f-a30a-ecab341ed629

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
