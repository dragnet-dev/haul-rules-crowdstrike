// Dragnet [Ransomware]: dragnet-ransomware-2025-5366 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: da1ef219-0dbc-53f2-8357-20e0e9efa751

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
