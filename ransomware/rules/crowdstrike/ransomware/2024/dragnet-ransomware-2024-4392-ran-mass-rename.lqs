// Dragnet [Ransomware]: dragnet-ransomware-2024-4392 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: efa64f9b-a40f-5d13-bbb2-22850a91edb6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
