// Dragnet [Ransomware]: dragnet-ransomware-2025-7216 — Mass File Rename (skira)
// Status: experimental | Level: high | ID: 25d4ba9c-fb98-521d-9163-8caaea9bfb25

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
