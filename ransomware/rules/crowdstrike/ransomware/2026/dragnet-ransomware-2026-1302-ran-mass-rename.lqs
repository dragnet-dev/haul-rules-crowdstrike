// Dragnet [Ransomware]: dragnet-ransomware-2026-1302 — Mass File Rename (dragonforce)
// Status: stable | Level: high | ID: 6669d6d9-1867-5b04-bd25-37fb5dcebe9f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
