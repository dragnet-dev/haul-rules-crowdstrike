// Dragnet [Ransomware]: dragnet-ransomware-2023-1131 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 251065b9-5002-5ba1-802c-7559f9c172d4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
