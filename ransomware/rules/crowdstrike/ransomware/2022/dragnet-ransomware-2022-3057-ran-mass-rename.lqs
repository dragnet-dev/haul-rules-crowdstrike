// Dragnet [Ransomware]: dragnet-ransomware-2022-3057 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: e0f6529a-e066-5c23-ace1-03e0582829d0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
