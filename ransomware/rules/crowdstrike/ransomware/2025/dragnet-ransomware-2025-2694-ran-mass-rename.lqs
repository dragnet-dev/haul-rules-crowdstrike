// Dragnet [Ransomware]: dragnet-ransomware-2025-2694 — Mass File Rename (killsec)
// Status: deprecated | Level: high | ID: cc49455c-1b92-5d7c-b4e1-a7ac04456c13

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
