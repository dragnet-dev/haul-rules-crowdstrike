// Dragnet [Ransomware]: dragnet-ransomware-2021-1067 — Mass File Rename (payloadbin)
// Status: deprecated | Level: high | ID: 3a0b22be-7a0d-52af-b15c-f4047d09a9c8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
