// Dragnet [Ransomware]: dragnet-ransomware-2025-2557 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: fb2066aa-7c3a-5cd5-8cfd-0716f97b2a19

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
