// Dragnet [Ransomware]: dragnet-ransomware-2023-2554 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 216e85c1-57bb-5142-bace-57470df2b849

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
