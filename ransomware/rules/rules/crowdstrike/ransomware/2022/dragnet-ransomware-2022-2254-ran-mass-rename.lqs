// Dragnet [Ransomware]: dragnet-ransomware-2022-2254 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 29621932-27b5-5f50-8a34-0e1589589b56

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
