// Dragnet [Ransomware]: dragnet-ransomware-2024-2990 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 636c40c3-738e-5d60-bb01-b57cf8fdd47d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
