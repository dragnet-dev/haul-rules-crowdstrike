// Dragnet [Ransomware]: dragnet-ransomware-2026-3541 — Mass File Rename (payload)
// Status: stable | Level: high | ID: 8317d949-700d-5479-b7c6-a4cd70f74bf2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
