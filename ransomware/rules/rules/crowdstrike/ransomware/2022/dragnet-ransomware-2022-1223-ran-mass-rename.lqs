// Dragnet [Ransomware]: dragnet-ransomware-2022-1223 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 3ed5ca32-a3b6-55b2-8cba-102a39d53bdb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
