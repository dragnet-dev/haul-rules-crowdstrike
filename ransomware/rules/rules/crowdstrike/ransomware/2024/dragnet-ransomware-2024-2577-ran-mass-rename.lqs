// Dragnet [Ransomware]: dragnet-ransomware-2024-2577 — Mass File Rename (play)
// Status: experimental | Level: high | ID: ab630fae-4965-51ea-881b-440fe89b4a1f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
