// Dragnet [Ransomware]: dragnet-ransomware-2023-3172 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 9d9a1068-9dcc-5d74-8f52-ffa68e91ec6b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
