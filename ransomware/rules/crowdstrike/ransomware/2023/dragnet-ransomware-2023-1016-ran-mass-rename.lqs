// Dragnet [Ransomware]: dragnet-ransomware-2023-1016 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 3bb0c657-f7a0-5df8-9ccd-a12c92f13a39

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
