// Dragnet [Ransomware]: dragnet-ransomware-2023-2913 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 3bf014bc-b71b-58c1-82f3-fac73f0a5f7b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
