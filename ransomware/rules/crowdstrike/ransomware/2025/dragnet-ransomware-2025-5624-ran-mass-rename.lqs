// Dragnet [Ransomware]: dragnet-ransomware-2025-5624 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 16cbecd6-e989-55f6-8438-88a24303640c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
