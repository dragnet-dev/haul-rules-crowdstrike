// Dragnet [Ransomware]: dragnet-ransomware-2025-1113 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: d261c12e-f1d9-5da2-b26a-31a1b8a28e30

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
