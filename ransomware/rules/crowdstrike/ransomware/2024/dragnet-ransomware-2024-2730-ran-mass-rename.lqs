// Dragnet [Ransomware]: dragnet-ransomware-2024-2730 — Mass File Rename (meow)
// Status: experimental | Level: high | ID: 36a0b838-d545-5394-bba6-d09bb1bf73df

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
