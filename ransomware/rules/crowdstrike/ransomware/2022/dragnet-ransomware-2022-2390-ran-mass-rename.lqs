// Dragnet [Ransomware]: dragnet-ransomware-2022-2390 — Mass File Rename (royal)
// Status: deprecated | Level: high | ID: 89fed1ea-120c-50f3-b823-330cf46d69c2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
