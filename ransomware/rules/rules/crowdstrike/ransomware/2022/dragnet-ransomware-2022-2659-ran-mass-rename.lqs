// Dragnet [Ransomware]: dragnet-ransomware-2022-2659 — Mass File Rename (royal)
// Status: deprecated | Level: high | ID: b65bf5e5-12dd-5ee3-abd4-8290c762f590

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
