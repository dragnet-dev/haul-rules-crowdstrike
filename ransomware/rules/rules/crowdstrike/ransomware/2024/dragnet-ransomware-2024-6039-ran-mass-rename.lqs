// Dragnet [Ransomware]: dragnet-ransomware-2024-6039 — Mass File Rename (ransomcortex)
// Status: experimental | Level: high | ID: 637b15f4-345e-57c9-a058-a9af3f571b9b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
