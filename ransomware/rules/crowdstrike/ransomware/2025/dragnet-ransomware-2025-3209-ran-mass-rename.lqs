// Dragnet [Ransomware]: dragnet-ransomware-2025-3209 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: 91ded938-a3c0-5eed-9a37-c1a8e9f0747c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
