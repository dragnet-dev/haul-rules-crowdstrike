// Dragnet [Ransomware]: dragnet-ransomware-2023-0729 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 37be1726-91fb-5d55-8804-290e75e57b02

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
