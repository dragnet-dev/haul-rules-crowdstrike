// Dragnet [Ransomware]: dragnet-ransomware-2024-5839 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: 163af2db-fcf1-5016-bb0a-071e863ca5f2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
