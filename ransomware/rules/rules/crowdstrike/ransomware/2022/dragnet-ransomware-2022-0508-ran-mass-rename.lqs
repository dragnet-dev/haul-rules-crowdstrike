// Dragnet [Ransomware]: dragnet-ransomware-2022-0508 — Mass File Rename (cuba)
// Status: deprecated | Level: high | ID: 23ca2054-ed67-5de4-9bd8-160803d6f63e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
