// Dragnet [Ransomware]: dragnet-ransomware-2023-1939 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: 08dde5de-f538-5364-8310-632310bd28b2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
