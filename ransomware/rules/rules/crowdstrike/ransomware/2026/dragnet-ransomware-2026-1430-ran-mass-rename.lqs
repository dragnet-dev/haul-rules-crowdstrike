// Dragnet [Ransomware]: dragnet-ransomware-2026-1430 — Mass File Rename (cmdorganization)
// Status: deprecated | Level: high | ID: b53c41b3-bfa1-53e1-b73e-4d7101b9b825

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
