// Dragnet [Ransomware]: dragnet-ransomware-2025-1546 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 9fb7deea-05b5-5d36-80ff-b21d8bb20f65

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
