// Dragnet [Ransomware]: dragnet-ransomware-2023-0558 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 8a9df0d6-ab68-58e5-bed9-f9ab9a537b7d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
