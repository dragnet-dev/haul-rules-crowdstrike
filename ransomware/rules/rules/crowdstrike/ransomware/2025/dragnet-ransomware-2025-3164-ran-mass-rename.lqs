// Dragnet [Ransomware]: dragnet-ransomware-2025-3164 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 497a3a9b-fc9e-5898-bd2e-0ad4d7643d43

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
