// Dragnet [Ransomware]: dragnet-ransomware-2021-1610 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 44d0d971-a8cd-55e0-afa6-608a732cfa33

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
