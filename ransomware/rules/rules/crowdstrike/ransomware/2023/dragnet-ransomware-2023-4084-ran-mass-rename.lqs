// Dragnet [Ransomware]: dragnet-ransomware-2023-4084 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 67713c3a-5766-58f6-8e1d-dd5a3bd7274f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
