// Dragnet [Ransomware]: dragnet-ransomware-2025-3423 — Mass File Rename (play)
// Status: experimental | Level: high | ID: fb1a4df2-fee6-52a1-8add-d210c2e1aa52

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
