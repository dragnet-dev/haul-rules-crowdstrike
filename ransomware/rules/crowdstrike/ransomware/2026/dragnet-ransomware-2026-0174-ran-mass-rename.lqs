// Dragnet [Ransomware]: dragnet-ransomware-2026-0174 — Mass File Rename (thegentlemen)
// Status: deprecated | Level: high | ID: fd4e65b6-c2d0-57f8-b83f-b8a7e5113461

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
