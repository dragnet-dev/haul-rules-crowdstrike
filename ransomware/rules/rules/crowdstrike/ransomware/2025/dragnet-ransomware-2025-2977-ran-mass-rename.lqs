// Dragnet [Ransomware]: dragnet-ransomware-2025-2977 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: a2d0946f-8e4c-5791-acf2-d32a8814ef1d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
