// Dragnet [Ransomware]: dragnet-ransomware-2025-3552 — Mass File Rename (sinobi)
// Status: experimental | Level: high | ID: 138400a3-8d96-5b4c-948d-b7dfb3bbde87

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
