// Dragnet [Ransomware]: dragnet-ransomware-2025-3833 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 4ed8b93d-064e-558e-83f2-38aea6782202

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
