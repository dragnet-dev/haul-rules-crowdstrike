// Dragnet [Ransomware]: dragnet-ransomware-2023-4555 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 0eff5aef-b880-5214-a856-7dc90ebbe600

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
