// Dragnet [Ransomware]: dragnet-ransomware-2025-1996 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: e949d519-d668-5d7d-8051-ebe55a3bb175

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
