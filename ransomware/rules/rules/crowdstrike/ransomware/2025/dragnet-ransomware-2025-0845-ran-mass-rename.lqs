// Dragnet [Ransomware]: dragnet-ransomware-2025-0845 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 623ca289-f9a4-5932-b07e-70dba12a11dc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
