// Dragnet [Ransomware]: dragnet-ransomware-2023-4459 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 8260888c-7f5c-5701-b004-250eafe742d2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
