// Dragnet [Ransomware]: dragnet-ransomware-2023-2352 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: c8abfb47-043f-5073-96f6-e511b56c5c60

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
