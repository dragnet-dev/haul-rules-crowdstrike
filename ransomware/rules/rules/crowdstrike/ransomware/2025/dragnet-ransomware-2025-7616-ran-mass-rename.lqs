// Dragnet [Ransomware]: dragnet-ransomware-2025-7616 — Mass File Rename (play)
// Status: experimental | Level: high | ID: db8df73c-1cc8-5709-b984-694c786c225c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
