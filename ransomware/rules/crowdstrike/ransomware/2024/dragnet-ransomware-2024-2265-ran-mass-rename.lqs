// Dragnet [Ransomware]: dragnet-ransomware-2024-2265 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 9755fe78-f443-5cc2-8c8b-3d34bed4a78a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
