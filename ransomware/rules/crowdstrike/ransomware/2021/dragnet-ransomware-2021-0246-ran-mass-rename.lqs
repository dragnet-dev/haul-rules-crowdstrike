// Dragnet [Ransomware]: dragnet-ransomware-2021-0246 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: ebc35499-b9c4-5a1b-805b-63278b25eb30

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
