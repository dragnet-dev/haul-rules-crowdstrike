// Dragnet [Container]: dragnet-container-2026-0308 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 33477b0c-74f3-5da4-8001-f4e70e400b4d

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
