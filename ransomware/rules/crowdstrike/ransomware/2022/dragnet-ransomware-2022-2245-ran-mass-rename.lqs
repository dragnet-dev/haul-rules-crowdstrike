// Dragnet [Ransomware]: dragnet-ransomware-2022-2245 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: fb9dd450-e2af-5440-8106-9cbe9a8a0f40

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
