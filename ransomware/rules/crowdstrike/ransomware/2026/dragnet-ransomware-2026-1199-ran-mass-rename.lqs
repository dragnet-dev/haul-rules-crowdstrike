// Dragnet [Ransomware]: dragnet-ransomware-2026-1199 — Mass File Rename (sinobi)
// Status: stable | Level: high | ID: 230bf163-9da5-5a3a-add6-c0c2d94bf92e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
