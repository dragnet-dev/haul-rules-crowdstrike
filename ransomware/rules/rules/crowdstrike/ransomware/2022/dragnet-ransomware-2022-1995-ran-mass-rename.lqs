// Dragnet [Ransomware]: dragnet-ransomware-2022-1995 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 16f944e1-f863-50a1-9b70-fbc886afc666

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
