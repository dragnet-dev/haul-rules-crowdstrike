// Dragnet [Ransomware]: dragnet-ransomware-2024-3252 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 129c2870-e3de-547d-b9b6-b6d81c0c8621

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
