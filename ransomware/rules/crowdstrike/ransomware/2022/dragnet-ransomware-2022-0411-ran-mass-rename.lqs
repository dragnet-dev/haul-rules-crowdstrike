// Dragnet [Ransomware]: dragnet-ransomware-2022-0411 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 160e371f-45c1-5f61-b03d-0a16a967a6ee

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
