// Dragnet [Ransomware]: dragnet-ransomware-2025-1648 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: 3d1482fd-e074-5b3f-8087-75e281274c4e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
