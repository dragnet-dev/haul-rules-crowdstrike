// Dragnet [Container]: dragnet-container-2026-1766 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 74a17d2f-1460-5ff1-949f-24d87e3ade3a

#event_simpleName=*
| (ImageFileName = *debian:7* OR ImageFileName = *debian:8* OR ImageFileName = *ubuntu:14.04* OR ImageFileName = *ubuntu:15.10*)
| table([timestamp, ComputerName])
| limit(1000)
