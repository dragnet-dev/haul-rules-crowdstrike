// Dragnet [Ransomware]: dragnet-ransomware-2024-5743 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: bc6085d7-be31-5c62-908a-5b328a0f9d86

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
