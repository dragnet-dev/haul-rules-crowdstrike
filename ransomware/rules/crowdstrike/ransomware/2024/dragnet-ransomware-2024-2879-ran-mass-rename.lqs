// Dragnet [Ransomware]: dragnet-ransomware-2024-2879 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: 8aa7a327-68ac-5fd7-8d1f-4cd3e3f1d64f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
