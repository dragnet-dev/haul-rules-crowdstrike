// Dragnet [Ransomware]: dragnet-ransomware-2025-4420 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 8cd84653-feda-520c-ba27-c39050b52eb5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
