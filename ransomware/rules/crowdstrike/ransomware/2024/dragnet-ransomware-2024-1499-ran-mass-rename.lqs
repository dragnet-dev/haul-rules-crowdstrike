// Dragnet [Ransomware]: dragnet-ransomware-2024-1499 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: f8473e7d-d6da-5d19-af6a-e4e6276fdd55

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
