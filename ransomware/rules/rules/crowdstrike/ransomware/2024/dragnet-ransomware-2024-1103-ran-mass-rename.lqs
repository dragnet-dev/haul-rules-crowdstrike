// Dragnet [Ransomware]: dragnet-ransomware-2024-1103 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 651784da-95e8-5143-9ee7-8999ba05f62c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
