// Dragnet [Ransomware]: dragnet-ransomware-2023-1901 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 3a563d15-4ec2-5133-8e4d-4438f627357d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
