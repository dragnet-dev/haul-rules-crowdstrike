// Dragnet [Ransomware]: dragnet-ransomware-2025-3424 — Mass File Rename (play)
// Status: experimental | Level: high | ID: ff071c52-afcb-5c61-820e-defd78385bd6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
