// Dragnet [Ransomware]: dragnet-ransomware-2025-2007 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 4024efd3-fa9e-5148-b23f-e3ad20e7709e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
