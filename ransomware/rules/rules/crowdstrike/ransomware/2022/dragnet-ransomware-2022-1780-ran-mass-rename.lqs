// Dragnet [Ransomware]: dragnet-ransomware-2022-1780 — Mass File Rename (ragnarlocker)
// Status: deprecated | Level: high | ID: 9a375df9-118b-5ef3-931b-cb9fc6fbb6c7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
