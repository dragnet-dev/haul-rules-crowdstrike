// Dragnet [Ransomware]: dragnet-ransomware-2025-7717 — Mass File Rename (lockbit5)
// Status: test | Level: high | ID: 12dac43e-ea72-54f0-b5e9-e21145413182

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
