// Dragnet [Ransomware]: dragnet-ransomware-2024-3760 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 96226bee-f639-58f6-8aed-3314f37a46c6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
