// Dragnet [Ransomware]: dragnet-ransomware-2023-4258 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: e02dd45b-f851-50bd-894f-d2c75bff4476

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
