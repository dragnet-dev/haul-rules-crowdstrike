// Dragnet [Ransomware]: dragnet-ransomware-2025-2959 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 2447a1ac-f52b-5840-a471-dad5162f8f02

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
