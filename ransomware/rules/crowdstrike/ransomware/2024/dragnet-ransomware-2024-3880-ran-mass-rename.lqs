// Dragnet [Ransomware]: dragnet-ransomware-2024-3880 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 2680aa0d-c9e0-5979-96ce-859f8a1d2e66

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
