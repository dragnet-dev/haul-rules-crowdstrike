// Dragnet [Ransomware]: dragnet-ransomware-2023-1011 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: fef35bd2-71dd-5864-b1d5-98683e39d4c0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
