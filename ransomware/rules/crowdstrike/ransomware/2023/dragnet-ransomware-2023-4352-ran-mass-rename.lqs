// Dragnet [Ransomware]: dragnet-ransomware-2023-4352 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 0ba98a80-0abd-5954-bf6f-a57acf0cd253

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
