// Dragnet [Ransomware]: dragnet-ransomware-2023-3875 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: d0d82cdf-6112-5603-94d2-c2027eb28d60

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
