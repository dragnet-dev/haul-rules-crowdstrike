// Dragnet [Ransomware]: dragnet-ransomware-2025-2143 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 6f0c43d4-8213-5892-9ee2-fea63cce4e44

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
