// Dragnet [Ransomware]: dragnet-ransomware-2024-3689 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 771f99fb-b1aa-5806-884d-cacf51654604

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
