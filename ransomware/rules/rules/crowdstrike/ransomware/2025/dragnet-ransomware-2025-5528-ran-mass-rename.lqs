// Dragnet [Ransomware]: dragnet-ransomware-2025-5528 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 98787894-0663-5fd1-adfb-b8421402bb41

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
