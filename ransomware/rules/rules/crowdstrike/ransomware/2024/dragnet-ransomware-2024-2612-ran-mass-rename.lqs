// Dragnet [Ransomware]: dragnet-ransomware-2024-2612 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: c763cc58-02e1-5694-b2af-396424273091

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
