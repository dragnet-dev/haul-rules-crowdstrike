// Dragnet [Ransomware]: dragnet-ransomware-2021-0664 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 1bb08300-ae7f-5240-b705-4cf5e98a3e7b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
