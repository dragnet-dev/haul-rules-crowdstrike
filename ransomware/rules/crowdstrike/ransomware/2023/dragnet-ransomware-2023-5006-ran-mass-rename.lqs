// Dragnet [Ransomware]: dragnet-ransomware-2023-5006 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 5cca9c4c-ec45-5dde-9302-bb79458b5ca4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
