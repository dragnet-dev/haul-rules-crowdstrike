// Dragnet [Ransomware]: dragnet-ransomware-2025-5402 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 58fa8e0a-1a9e-50d6-afc8-380ef17377ed

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
