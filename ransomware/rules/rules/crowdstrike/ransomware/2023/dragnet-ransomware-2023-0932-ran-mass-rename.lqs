// Dragnet [Ransomware]: dragnet-ransomware-2023-0932 — Mass File Rename (stormous)
// Status: experimental | Level: high | ID: 8396fca4-3294-5171-8102-112a64ce9d1e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
