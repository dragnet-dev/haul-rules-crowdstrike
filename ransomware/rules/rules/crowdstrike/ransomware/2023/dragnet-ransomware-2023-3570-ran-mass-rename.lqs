// Dragnet [Ransomware]: dragnet-ransomware-2023-3570 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 9f213add-3723-5809-8790-166033c98e75

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
