// Dragnet [Ransomware]: dragnet-ransomware-2025-1667 — Mass File Rename (devman)
// Status: experimental | Level: high | ID: 2c09b169-b2d6-5cc8-91c0-f6c8b1efb265

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
