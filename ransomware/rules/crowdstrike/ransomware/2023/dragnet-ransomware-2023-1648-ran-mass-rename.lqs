// Dragnet [Ransomware]: dragnet-ransomware-2023-1648 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 1fde65b6-e209-55b4-b97f-2de59fa88abf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
