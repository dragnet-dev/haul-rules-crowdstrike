// Dragnet [Ransomware]: dragnet-ransomware-2024-5090 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 6db74733-2c41-5809-8f1d-ba2534873d12

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
