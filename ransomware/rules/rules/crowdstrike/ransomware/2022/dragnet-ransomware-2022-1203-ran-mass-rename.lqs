// Dragnet [Ransomware]: dragnet-ransomware-2022-1203 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: e670485e-8063-5e93-9478-593927ec9062

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
