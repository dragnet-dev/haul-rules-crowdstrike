// Dragnet [Ransomware]: dragnet-ransomware-2025-6708 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: cfe125ce-f249-530e-ada0-236b3b09b63a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
