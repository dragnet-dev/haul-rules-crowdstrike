// Dragnet [Ransomware]: dragnet-ransomware-2024-2004 — Mass File Rename (handala)
// Status: experimental | Level: high | ID: 2157bf47-c92c-50c0-a595-616505123a32

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
