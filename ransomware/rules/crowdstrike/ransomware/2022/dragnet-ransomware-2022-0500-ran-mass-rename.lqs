// Dragnet [Ransomware]: dragnet-ransomware-2022-0500 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 9f01a4e3-153d-5093-8af6-4411cc9df5c6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
