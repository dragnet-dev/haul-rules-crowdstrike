// Dragnet [Ransomware]: dragnet-ransomware-2024-1508 — Mass File Rename (rhysida)
// Status: deprecated | Level: high | ID: 20438a10-a69f-52b9-9bb6-76f50e7a77a3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
