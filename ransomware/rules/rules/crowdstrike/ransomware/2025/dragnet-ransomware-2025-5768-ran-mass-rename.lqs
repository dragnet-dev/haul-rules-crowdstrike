// Dragnet [Ransomware]: dragnet-ransomware-2025-5768 — Mass File Rename (dragonforce)
// Status: test | Level: high | ID: a3723295-0e73-5ddd-b5bc-20c040a3d5d6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
