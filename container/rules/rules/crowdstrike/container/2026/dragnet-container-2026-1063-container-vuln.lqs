// Dragnet [Container]: dragnet-container-2026-1063 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 29e13fa4-ea07-52af-b7ff-e02d27db3025

#event_simpleName=*
| (ImageFileName = *almalinux:10* OR ImageFileName = *alpine:3.23* OR ImageFileName = *alpine edge:* OR ImageFileName = *amazonlinux:2* OR ImageFileName = *amazonlinux:2023* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:24.04* OR ImageFileName = *ubuntu:25.10*)
| table([timestamp, ComputerName])
| limit(1000)
