// Dragnet [Ransomware]: dragnet-ransomware-2024-3524 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 374bdfd9-4b7b-5e55-8d69-1238fe72659d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
