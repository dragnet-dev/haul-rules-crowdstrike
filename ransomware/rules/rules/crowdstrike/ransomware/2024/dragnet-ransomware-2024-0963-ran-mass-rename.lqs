// Dragnet [Ransomware]: dragnet-ransomware-2024-0963 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 21650ff0-8c9e-5095-a3ae-51a5eeb39c89

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
