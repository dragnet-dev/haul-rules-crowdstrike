// Dragnet [Ransomware]: dragnet-ransomware-2025-6487 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 881f27a1-b4dc-5055-af8b-11773649e2f6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
