// Dragnet [Ransomware]: dragnet-ransomware-2025-7604 — Mass File Rename (sinobi)
// Status: experimental | Level: high | ID: 90f3065c-9d54-5741-9cb8-b3d1043cc907

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
