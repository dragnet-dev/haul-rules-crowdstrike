// Dragnet [Container]: dragnet-container-2025-0227 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: e51bb789-675f-5d69-b99b-eaeebc058371

#event_simpleName=*
| (ImageFileName = *chainguard:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
