// Dragnet [Ransomware]: dragnet-ransomware-2022-0222 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: c53c4e21-77e0-5f68-8098-81c4db8c7023

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
