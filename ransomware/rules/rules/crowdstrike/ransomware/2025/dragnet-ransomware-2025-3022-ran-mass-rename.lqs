// Dragnet [Ransomware]: dragnet-ransomware-2025-3022 — Mass File Rename (blackshrantac)
// Status: experimental | Level: high | ID: f5465636-d450-5617-ac4c-a99798cd4ea4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
