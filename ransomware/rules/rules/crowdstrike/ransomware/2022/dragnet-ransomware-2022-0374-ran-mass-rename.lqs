// Dragnet [Ransomware]: dragnet-ransomware-2022-0374 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: bae61641-6655-5203-92b5-70b1e72ca2c6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
