// Dragnet [Container]: dragnet-container-2025-0351 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 06d90be1-f97b-50ad-b14a-eae030bdcd32

#event_simpleName=*
| (ImageFileName = *alpine:3.21* OR ImageFileName = *alpine:3.22* OR ImageFileName = *alpine:3.23* OR ImageFileName = *alpine edge:* OR ImageFileName = *chainguard:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
