// Dragnet [Ransomware]: dragnet-ransomware-2025-2281 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 65202e66-b7a4-51d9-909c-151594320cd4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
