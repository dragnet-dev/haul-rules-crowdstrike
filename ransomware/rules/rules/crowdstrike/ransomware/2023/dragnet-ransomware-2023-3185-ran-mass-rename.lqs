// Dragnet [Ransomware]: dragnet-ransomware-2023-3185 — Mass File Rename (ragnarlocker)
// Status: experimental | Level: high | ID: 12566e62-f3d7-5610-befd-fec44547b8fb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
