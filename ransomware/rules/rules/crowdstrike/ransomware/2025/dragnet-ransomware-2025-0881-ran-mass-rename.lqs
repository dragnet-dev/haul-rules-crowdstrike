// Dragnet [Ransomware]: dragnet-ransomware-2025-0881 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 1a7a293b-9889-5434-830d-ce1f24954bf2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
