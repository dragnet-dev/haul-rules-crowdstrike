// Dragnet [Ransomware]: dragnet-ransomware-2022-2034 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 4007cd56-bb5a-5209-80c7-69a1de788c46

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
