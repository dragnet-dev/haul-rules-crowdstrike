// Dragnet [Ransomware]: dragnet-ransomware-2026-0396 — Mass File Rename (lockbit5)
// Status: test | Level: high | ID: 4b760f74-7b7e-5a2e-9431-19758ffb3f86

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
