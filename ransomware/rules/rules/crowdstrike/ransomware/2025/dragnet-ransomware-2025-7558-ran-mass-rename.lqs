// Dragnet [Ransomware]: dragnet-ransomware-2025-7558 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: f19f686b-d370-5f74-a2fb-1b3c032c5e8d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
