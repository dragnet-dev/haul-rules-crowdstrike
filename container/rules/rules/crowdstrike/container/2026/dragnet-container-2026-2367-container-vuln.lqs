// Dragnet [Container]: dragnet-container-2026-2367 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 7840d59e-1e15-5d05-a1bf-8f66229d3f54

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13*)
| table([timestamp, ComputerName])
| limit(1000)
