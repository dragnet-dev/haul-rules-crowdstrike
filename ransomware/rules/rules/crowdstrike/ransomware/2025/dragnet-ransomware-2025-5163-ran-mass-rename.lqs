// Dragnet [Ransomware]: dragnet-ransomware-2025-5163 — Mass File Rename (play)
// Status: experimental | Level: high | ID: c53faa62-009c-5417-92ca-b5673d84b23f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
