// Dragnet [Ransomware]: dragnet-ransomware-2023-1434 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 439b32f5-1fb3-5543-9d0d-c923dc1a54ef

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
