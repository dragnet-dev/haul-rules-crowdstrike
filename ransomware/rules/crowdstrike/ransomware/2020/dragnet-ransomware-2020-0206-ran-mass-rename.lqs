// Dragnet [Ransomware]: dragnet-ransomware-2020-0206 — Mass File Rename (revil)
// Status: deprecated | Level: high | ID: b60d8999-e902-5735-bd96-2fde6ee44a84

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
