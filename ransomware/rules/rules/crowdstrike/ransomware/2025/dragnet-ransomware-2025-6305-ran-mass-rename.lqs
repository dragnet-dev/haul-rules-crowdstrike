// Dragnet [Ransomware]: dragnet-ransomware-2025-6305 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 7583a59e-1788-5d6a-9bb6-f6bb80f84ae6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
