// Dragnet [Ransomware]: dragnet-ransomware-2023-1542 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 79397d50-7d14-5865-83e0-5cee6fbf52c8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
