// Dragnet [Ransomware]: dragnet-ransomware-2024-0071 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: 4a313516-096b-5bd0-9b7f-84c302427c53

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
