// Dragnet [Ransomware]: dragnet-ransomware-2023-2208 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 14ebd617-fe17-5223-859f-8748025d2266

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
