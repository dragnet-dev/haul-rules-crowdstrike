// Dragnet [Ransomware]: dragnet-ransomware-2023-4920 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 30f3af8d-2e3f-523c-8488-79b665b72eb3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
