// Dragnet [Ransomware]: dragnet-ransomware-2021-0973 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: da8c99a6-d9ca-5fe5-8411-76a45d71df0c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
