// Dragnet [Ransomware]: dragnet-ransomware-2023-0828 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 22feb9e1-ca66-5fab-87a7-1ddf94c080cf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
