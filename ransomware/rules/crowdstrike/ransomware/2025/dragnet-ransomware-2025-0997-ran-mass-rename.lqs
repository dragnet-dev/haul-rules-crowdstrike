// Dragnet [Ransomware]: dragnet-ransomware-2025-0997 — Mass File Rename (stormous)
// Status: deprecated | Level: high | ID: 84d7f6f4-66ae-5b76-b57d-c522e4c410e3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
