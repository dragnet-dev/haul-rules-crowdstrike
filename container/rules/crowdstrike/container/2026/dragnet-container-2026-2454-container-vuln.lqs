// Dragnet [Container]: dragnet-container-2026-2454 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: e4f4f026-e32c-5cfa-aa5b-e0b2daed5c30

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:5*)
| table([timestamp, ComputerName])
| limit(1000)
