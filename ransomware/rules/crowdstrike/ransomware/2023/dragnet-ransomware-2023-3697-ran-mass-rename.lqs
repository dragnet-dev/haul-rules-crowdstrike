// Dragnet [Ransomware]: dragnet-ransomware-2023-3697 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: 711a7d01-8549-5890-8d33-b3f0a53cb7b2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
