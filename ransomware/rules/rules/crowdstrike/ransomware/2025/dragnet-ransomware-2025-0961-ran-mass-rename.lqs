// Dragnet [Ransomware]: dragnet-ransomware-2025-0961 — Mass File Rename (lockbit5)
// Status: test | Level: high | ID: 71a83793-e58a-5c79-9777-b3a86f2aa333

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
