// Dragnet [Ransomware]: dragnet-ransomware-2023-5175 — Mass File Rename (mallox)
// Status: experimental | Level: high | ID: c72895c1-b98a-5236-8f27-0ea4bd7a8529

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
