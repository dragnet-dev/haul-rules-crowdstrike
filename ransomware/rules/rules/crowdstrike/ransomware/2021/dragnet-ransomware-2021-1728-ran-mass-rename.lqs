// Dragnet [Ransomware]: dragnet-ransomware-2021-1728 — Mass File Rename (suncrypt)
// Status: deprecated | Level: high | ID: 03ddd0f4-c865-5ccf-86a7-a2bd01e430aa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
