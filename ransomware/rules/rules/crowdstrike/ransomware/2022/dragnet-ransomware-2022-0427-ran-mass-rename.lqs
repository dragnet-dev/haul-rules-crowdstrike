// Dragnet [Ransomware]: dragnet-ransomware-2022-0427 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 3aa36645-5cdb-5ee1-b750-fcb07aa2521f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
