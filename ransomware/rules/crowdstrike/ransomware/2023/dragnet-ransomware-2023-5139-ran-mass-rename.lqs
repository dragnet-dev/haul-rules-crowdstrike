// Dragnet [Ransomware]: dragnet-ransomware-2023-5139 — Mass File Rename (ragnarlocker)
// Status: experimental | Level: high | ID: 6f584e57-f797-53b0-bc81-46e5d7a48323

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
