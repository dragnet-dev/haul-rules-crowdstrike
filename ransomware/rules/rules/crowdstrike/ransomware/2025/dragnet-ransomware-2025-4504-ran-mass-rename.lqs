// Dragnet [Ransomware]: dragnet-ransomware-2025-4504 — Mass File Rename (payoutsking)
// Status: experimental | Level: high | ID: 2eaec944-0ad8-5845-9974-2a179ead7605

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
