// Dragnet [Ransomware]: dragnet-ransomware-2024-5317 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: 5922b665-427c-5c7e-bfd6-4b847847c59a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
