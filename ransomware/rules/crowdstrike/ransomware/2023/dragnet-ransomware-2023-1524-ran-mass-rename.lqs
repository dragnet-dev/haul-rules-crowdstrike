// Dragnet [Ransomware]: dragnet-ransomware-2023-1524 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 69ecd887-a890-5bb8-a257-511a3d23592e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
