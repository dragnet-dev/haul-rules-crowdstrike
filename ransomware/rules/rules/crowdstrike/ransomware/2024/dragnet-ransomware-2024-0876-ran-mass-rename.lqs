// Dragnet [Ransomware]: dragnet-ransomware-2024-0876 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 88619943-025f-59c0-a4cc-d9942433f7ce

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
