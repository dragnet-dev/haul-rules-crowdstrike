// Dragnet [Ransomware]: dragnet-ransomware-2025-4817 — Mass File Rename (rhysida)
// Status: deprecated | Level: high | ID: 96b97dec-91f2-5c2d-8e66-3f5467a2fd36

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
