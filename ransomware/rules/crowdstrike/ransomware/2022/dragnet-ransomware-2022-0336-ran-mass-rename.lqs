// Dragnet [Ransomware]: dragnet-ransomware-2022-0336 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 65598746-379e-563c-9852-d9710a9f0371

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
