// Dragnet [Ransomware]: dragnet-ransomware-2022-0344 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: c784e018-7881-5833-bb00-8137b36bbc90

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
