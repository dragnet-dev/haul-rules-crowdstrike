// Dragnet [Container]: dragnet-container-2026-1558 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 27d72dcf-32ff-5f9a-b12b-d43e5e0c226b

#event_simpleName=*
| (ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10*)
| table([timestamp, ComputerName])
| limit(1000)
