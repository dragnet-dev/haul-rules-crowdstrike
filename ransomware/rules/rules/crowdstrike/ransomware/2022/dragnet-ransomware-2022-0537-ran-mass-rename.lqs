// Dragnet [Ransomware]: dragnet-ransomware-2022-0537 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 33c1014d-1b6e-557e-831f-41bc2c268369

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
