// Dragnet [Ransomware]: dragnet-ransomware-2025-1374 — Mass File Rename (play)
// Status: experimental | Level: high | ID: feef773b-25cf-5b15-a069-963275573886

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
