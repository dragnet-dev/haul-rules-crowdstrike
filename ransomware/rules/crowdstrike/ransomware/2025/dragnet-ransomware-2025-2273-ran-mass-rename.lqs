// Dragnet [Ransomware]: dragnet-ransomware-2025-2273 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: b8cc6e16-3e6e-52bf-a1b1-9e37b77c2635

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
