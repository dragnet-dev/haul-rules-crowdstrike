// Dragnet [Ransomware]: dragnet-ransomware-2025-0053 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 7931bf8c-3c0c-530d-8b80-c98abeff3017

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
