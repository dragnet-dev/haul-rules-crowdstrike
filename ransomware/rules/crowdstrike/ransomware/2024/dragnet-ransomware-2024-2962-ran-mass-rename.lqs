// Dragnet [Ransomware]: dragnet-ransomware-2024-2962 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 580fe5d8-83c1-5b3a-8b4c-15a3f7a4f9bf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
