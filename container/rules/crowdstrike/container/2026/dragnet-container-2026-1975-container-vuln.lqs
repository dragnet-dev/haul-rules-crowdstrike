// Dragnet [Container]: dragnet-container-2026-1975 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: f350496f-4c7b-57a7-8edc-3ac3ff188b8d

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
