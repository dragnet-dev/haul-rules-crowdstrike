// Dragnet [Ransomware]: dragnet-ransomware-2022-1819 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 165207a4-406f-5cd8-9ff1-94100f02ff14

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
