// Dragnet [Ransomware]: dragnet-ransomware-2022-0007 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: ecfbaa38-7acf-5be9-907b-17c30d451f53

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
