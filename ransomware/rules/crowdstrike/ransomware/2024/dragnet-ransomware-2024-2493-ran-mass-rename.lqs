// Dragnet [Ransomware]: dragnet-ransomware-2024-2493 — Mass File Rename (redransomware)
// Status: deprecated | Level: high | ID: 6fa61887-093d-5faf-86be-e60917fde179

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
