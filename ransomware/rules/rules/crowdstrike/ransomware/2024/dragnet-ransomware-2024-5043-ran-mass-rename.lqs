// Dragnet [Ransomware]: dragnet-ransomware-2024-5043 — Mass File Rename (cicada3301)
// Status: experimental | Level: high | ID: 46526b61-1166-57ef-910b-91aa66c1aa19

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
