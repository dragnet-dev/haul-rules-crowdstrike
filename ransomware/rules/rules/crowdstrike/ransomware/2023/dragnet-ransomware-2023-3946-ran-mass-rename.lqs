// Dragnet [Ransomware]: dragnet-ransomware-2023-3946 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: aeb8b223-d65f-55b8-b5e6-1f6a09afec38

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
