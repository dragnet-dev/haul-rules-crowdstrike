// Dragnet [Ransomware]: dragnet-ransomware-2022-3008 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: fb8c6943-da42-52f5-bf1f-b6d899c73b96

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
