// Dragnet [Ransomware]: dragnet-ransomware-2023-5067 — Mass File Rename (metaencryptor)
// Status: experimental | Level: high | ID: 8de794ee-c12e-5931-901e-2f544e175463

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
