// Dragnet [Ransomware]: dragnet-ransomware-2023-3515 — Mass File Rename (play)
// Status: deprecated | Level: high | ID: 28331624-a0d0-5e5d-b1a8-da79097ccc1c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
