// Dragnet [Ransomware]: dragnet-ransomware-2025-1120 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: e4d88c27-f1b5-5359-9684-21760e50c45f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
