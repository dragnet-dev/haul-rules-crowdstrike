// Dragnet [Ransomware]: dragnet-ransomware-2022-0095 — Mass File Rename (cuba)
// Status: deprecated | Level: high | ID: 63767097-0975-5ffc-841c-0d71a0e2e21e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
