// Dragnet [Container]: dragnet-container-2025-0542 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 79cf25e7-54a4-5e76-84c7-d93aafdc83b3

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *ubuntu:24.04* OR ImageFileName = *ubuntu:24.10* OR ImageFileName = *ubuntu:25.04* OR ImageFileName = *ubuntu:25.10* OR ImageFileName = *ubuntu:26.04*)
| table([timestamp, ComputerName])
| limit(1000)
