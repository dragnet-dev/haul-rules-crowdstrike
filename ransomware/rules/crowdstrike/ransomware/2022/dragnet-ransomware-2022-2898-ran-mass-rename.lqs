// Dragnet [Ransomware]: dragnet-ransomware-2022-2898 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: c09ca74e-774a-5ddc-b50c-77d31167e80b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
