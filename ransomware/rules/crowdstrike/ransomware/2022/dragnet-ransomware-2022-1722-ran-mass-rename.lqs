// Dragnet [Ransomware]: dragnet-ransomware-2022-1722 — Mass File Rename (royal)
// Status: deprecated | Level: high | ID: 3a83d903-b379-53ac-ad6f-5b687ee258eb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
