// Dragnet [Ransomware]: dragnet-ransomware-2025-2567 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 029e09c6-ada3-5b23-b40e-22fa02a1d874

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
