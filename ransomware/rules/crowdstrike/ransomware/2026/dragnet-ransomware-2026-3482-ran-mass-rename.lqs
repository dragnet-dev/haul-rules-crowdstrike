// Dragnet [Ransomware]: dragnet-ransomware-2026-3482 — Mass File Rename (incransom)
// Status: stable | Level: high | ID: d9c5baec-5657-538d-8478-69a8c8ef3be4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
