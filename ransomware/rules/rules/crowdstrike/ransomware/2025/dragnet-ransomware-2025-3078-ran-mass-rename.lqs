// Dragnet [Ransomware]: dragnet-ransomware-2025-3078 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: 5e7aaa95-6cb1-50dc-9306-d70fb8a5e8ff

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
