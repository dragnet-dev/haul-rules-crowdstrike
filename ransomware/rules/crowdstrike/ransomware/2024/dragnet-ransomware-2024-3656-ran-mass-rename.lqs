// Dragnet [Ransomware]: dragnet-ransomware-2024-3656 — Mass File Rename (handala)
// Status: experimental | Level: high | ID: 37c11980-058b-556b-b95d-6d00ab807e96

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
