// Dragnet [Container]: dragnet-container-2026-2282 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 442bbe51-dffe-540d-938c-ea8c322ac6f8

#event_simpleName=*
| (ImageFileName = *amazonlinux:1* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:7* OR ImageFileName = *debian:8* OR ImageFileName = *debian:9* OR ImageFileName = *ubuntu:16.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
