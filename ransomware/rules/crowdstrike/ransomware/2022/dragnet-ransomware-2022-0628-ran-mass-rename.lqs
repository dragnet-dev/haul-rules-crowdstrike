// Dragnet [Ransomware]: dragnet-ransomware-2022-0628 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 05f28ea7-11b1-544a-9b0a-cb7ce425a74f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
