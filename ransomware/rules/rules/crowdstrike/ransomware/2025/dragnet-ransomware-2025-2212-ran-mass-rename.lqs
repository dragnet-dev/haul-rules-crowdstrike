// Dragnet [Ransomware]: dragnet-ransomware-2025-2212 — Mass File Rename (play)
// Status: experimental | Level: high | ID: d9bbb49a-af39-5650-b066-4f69a3a40667

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
