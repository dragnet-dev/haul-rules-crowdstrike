// Dragnet [Ransomware]: dragnet-ransomware-2022-1742 — Mass File Rename (royal)
// Status: deprecated | Level: high | ID: bd1b691f-44af-5b0f-b525-1716166fe2a4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
