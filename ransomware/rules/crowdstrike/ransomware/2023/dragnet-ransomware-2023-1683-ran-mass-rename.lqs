// Dragnet [Ransomware]: dragnet-ransomware-2023-1683 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 0e10dd44-9ae7-59e4-9f58-4507fc9d4eaf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
