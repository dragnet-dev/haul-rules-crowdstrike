// Dragnet [Ransomware]: dragnet-ransomware-2025-7381 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 001150b8-3e22-539a-80b1-06c5cf4107b9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
