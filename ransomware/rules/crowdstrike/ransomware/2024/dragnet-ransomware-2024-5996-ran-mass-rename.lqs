// Dragnet [Ransomware]: dragnet-ransomware-2024-5996 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: cd897929-a4cb-5d3c-99db-f5dba9fd42fc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
