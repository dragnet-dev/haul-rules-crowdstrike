// Dragnet [Ransomware]: dragnet-ransomware-2024-5425 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: fd36d1ea-8a66-5947-aa68-eea6ce4c6671

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
