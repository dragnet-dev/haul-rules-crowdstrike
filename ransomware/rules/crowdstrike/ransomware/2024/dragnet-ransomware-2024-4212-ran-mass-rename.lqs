// Dragnet [Ransomware]: dragnet-ransomware-2024-4212 — Mass File Rename (play)
// Status: experimental | Level: high | ID: a75b7857-1add-535f-8487-f2dbb82c8772

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
