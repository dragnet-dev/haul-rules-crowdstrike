// Dragnet [Ransomware]: dragnet-ransomware-2024-5348 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: fee83f37-6659-56db-a47b-ab59af7c8357

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
