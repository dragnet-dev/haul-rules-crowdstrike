// Dragnet [Ransomware]: dragnet-ransomware-2022-3017 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: bddfa5f5-3c0a-504a-9b00-b86afff05f33

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
