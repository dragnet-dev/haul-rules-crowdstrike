// Dragnet [Ransomware]: dragnet-ransomware-2023-3111 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: 4452add9-ae23-5cc2-9657-947a8e81edc1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
