// Dragnet [Ransomware]: dragnet-ransomware-2022-1363 — Mass File Rename (icefire)
// Status: deprecated | Level: high | ID: 38c908a9-99b3-5f53-a2b8-6dab7489a505

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
