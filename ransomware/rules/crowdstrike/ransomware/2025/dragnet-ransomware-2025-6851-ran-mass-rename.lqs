// Dragnet [Ransomware]: dragnet-ransomware-2025-6851 — Mass File Rename (devman)
// Status: experimental | Level: high | ID: 123821e5-fcbe-5f03-9916-b4e20e305a4a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
