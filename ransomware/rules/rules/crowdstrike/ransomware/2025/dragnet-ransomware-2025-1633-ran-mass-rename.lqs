// Dragnet [Ransomware]: dragnet-ransomware-2025-1633 — Mass File Rename (BrainCipher)
// Status: experimental | Level: high | ID: 371015e1-6aad-5609-b3f0-7801622c0429

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
