// Dragnet [Ransomware]: dragnet-ransomware-2025-6444 — Mass File Rename (interlock)
// Status: experimental | Level: high | ID: 958a5d55-968a-51b2-b0a7-de7ed1a44ea0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
