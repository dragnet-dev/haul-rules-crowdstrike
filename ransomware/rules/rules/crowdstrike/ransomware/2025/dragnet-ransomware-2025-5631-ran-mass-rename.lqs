// Dragnet [Ransomware]: dragnet-ransomware-2025-5631 — Mass File Rename (worldleaks)
// Status: experimental | Level: high | ID: 44ba1201-1aa2-50df-886f-743ab36a2c65

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
