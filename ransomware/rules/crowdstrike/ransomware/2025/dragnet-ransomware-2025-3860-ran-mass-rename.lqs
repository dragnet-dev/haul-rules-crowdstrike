// Dragnet [Ransomware]: dragnet-ransomware-2025-3860 — Mass File Rename (nova)
// Status: experimental | Level: high | ID: 6db5d097-da15-5ad1-b34a-5d1baa13e15e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
