// Dragnet [Ransomware]: dragnet-ransomware-2026-1368 — Mass File Rename (krybit)
// Status: stable | Level: high | ID: 49df1461-2286-5293-929e-f7e9a80704ea

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
