// Dragnet [Ransomware]: dragnet-ransomware-2024-5580 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 31852541-ad70-5fb6-a3f5-6b71579275ca

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
