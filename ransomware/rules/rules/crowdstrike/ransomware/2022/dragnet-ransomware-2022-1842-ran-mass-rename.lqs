// Dragnet [Ransomware]: dragnet-ransomware-2022-1842 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 81e79409-15bb-5ac2-a71c-6d1f3197a57c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
