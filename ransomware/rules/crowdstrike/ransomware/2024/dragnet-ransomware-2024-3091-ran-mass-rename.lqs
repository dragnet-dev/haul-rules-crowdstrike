// Dragnet [Ransomware]: dragnet-ransomware-2024-3091 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 28169e1a-e493-56b7-abce-9f2800798d09

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
