// Dragnet [Ransomware]: dragnet-ransomware-2022-1075 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: f81c9142-1ff8-541e-9aec-7976dcc1c8b4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
