// Dragnet [Ransomware]: dragnet-ransomware-2024-4826 — Mass File Rename (monti)
// Status: experimental | Level: high | ID: 3452e281-2af3-564c-847a-a06d474e3108

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
