// Dragnet [Ransomware]: dragnet-ransomware-2025-6023 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: f156cc5f-fa0c-5297-aa22-bda98878b500

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
