// Dragnet [Ransomware]: dragnet-ransomware-2021-1745 — Mass File Rename (avoslocker)
// Status: deprecated | Level: high | ID: 6f9864d5-db26-5d01-9722-79b229d21034

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
