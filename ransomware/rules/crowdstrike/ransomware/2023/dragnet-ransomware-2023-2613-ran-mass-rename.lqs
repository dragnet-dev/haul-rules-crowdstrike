// Dragnet [Ransomware]: dragnet-ransomware-2023-2613 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: 7d5f50f4-07b6-53dc-b540-1eff3f1b87a3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
