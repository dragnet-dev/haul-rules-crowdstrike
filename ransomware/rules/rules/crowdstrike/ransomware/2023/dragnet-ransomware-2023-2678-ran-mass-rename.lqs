// Dragnet [Ransomware]: dragnet-ransomware-2023-2678 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: d63482b2-5e1f-5446-b31f-8e87b0effaca

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
