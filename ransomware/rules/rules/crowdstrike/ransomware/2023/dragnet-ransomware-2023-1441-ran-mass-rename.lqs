// Dragnet [Ransomware]: dragnet-ransomware-2023-1441 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: c8f85d20-6b58-5a7c-992f-6407921d6c9a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
