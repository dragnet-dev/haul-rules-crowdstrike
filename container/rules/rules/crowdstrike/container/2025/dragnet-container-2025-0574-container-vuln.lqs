// Dragnet [Container]: dragnet-container-2025-0574 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 38afa861-9757-5c0d-946a-b0d35580e6f6

#event_simpleName=*
| (ImageFileName = *chainguard:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *photon os:4.0* OR ImageFileName = *photon os:5.0* OR ImageFileName = *ubuntu:18.04-ESM* OR ImageFileName = *ubuntu:20.04-ESM* OR ImageFileName = *ubuntu:22.04* OR ImageFileName = *ubuntu:24.04* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
