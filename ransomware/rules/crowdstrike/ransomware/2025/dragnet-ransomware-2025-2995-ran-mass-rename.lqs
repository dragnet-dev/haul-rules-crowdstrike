// Dragnet [Ransomware]: dragnet-ransomware-2025-2995 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: cbcf6178-65e0-5490-ba09-3b7415416066

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
