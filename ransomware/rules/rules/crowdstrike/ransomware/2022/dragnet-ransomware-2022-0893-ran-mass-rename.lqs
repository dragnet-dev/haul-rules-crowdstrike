// Dragnet [Ransomware]: dragnet-ransomware-2022-0893 — Mass File Rename (medusalocker)
// Status: deprecated | Level: high | ID: c4b8ac2d-5a4f-512c-a994-7dbfa6d86494

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
