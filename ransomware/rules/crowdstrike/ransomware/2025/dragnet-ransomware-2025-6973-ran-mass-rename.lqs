// Dragnet [Ransomware]: dragnet-ransomware-2025-6973 — Mass File Rename (securotrop)
// Status: experimental | Level: high | ID: 106e7371-64cf-572b-aee9-21382f8d38d8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
