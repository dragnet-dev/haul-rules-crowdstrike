// Dragnet [Ransomware]: dragnet-ransomware-2023-2028 — Mass File Rename (stormous)
// Status: experimental | Level: high | ID: 23bf6b8b-be3c-5add-861f-7cb733d7add5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
