// Dragnet [Ransomware]: dragnet-ransomware-2025-4799 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: 9cd60924-56da-5809-9781-5b4bfa85885e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
