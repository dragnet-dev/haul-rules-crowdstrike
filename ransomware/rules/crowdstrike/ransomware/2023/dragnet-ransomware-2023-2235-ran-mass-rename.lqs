// Dragnet [Ransomware]: dragnet-ransomware-2023-2235 — Mass File Rename (hunters)
// Status: deprecated | Level: high | ID: 6e0314e3-0c11-57f0-ac78-581e1857581e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
