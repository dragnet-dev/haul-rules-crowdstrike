// Dragnet [Ransomware]: dragnet-ransomware-2022-0191 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: b2fd0212-e5c9-5bee-b0a2-4af0a010919f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
