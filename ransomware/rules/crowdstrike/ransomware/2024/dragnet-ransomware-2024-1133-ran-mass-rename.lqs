// Dragnet [Ransomware]: dragnet-ransomware-2024-1133 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 6ca5726e-a3ae-5879-b922-b36ed3008375

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
