// Dragnet [Ransomware]: dragnet-ransomware-2025-4389 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: be22986b-0bea-50e5-8610-1ad38ed16062

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
