// Dragnet [Ransomware]: dragnet-ransomware-2025-2838 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: a44e5b6c-e067-517e-b032-8b3189b0fa3d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
