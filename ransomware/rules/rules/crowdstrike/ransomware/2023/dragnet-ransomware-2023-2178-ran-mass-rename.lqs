// Dragnet [Ransomware]: dragnet-ransomware-2023-2178 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 70f2b50b-1807-57b9-b39d-93b6a62cb437

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
