// Dragnet [Ransomware]: dragnet-ransomware-2023-0980 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 36a83edc-5f97-5a2d-a8da-5b9dcbbfe240

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
