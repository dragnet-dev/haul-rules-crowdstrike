// Dragnet [Container]: dragnet-container-2026-2259 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: bc9d2e8f-03ab-5804-9ceb-8b82f2c41ac2

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:5*)
| table([timestamp, ComputerName])
| limit(1000)
