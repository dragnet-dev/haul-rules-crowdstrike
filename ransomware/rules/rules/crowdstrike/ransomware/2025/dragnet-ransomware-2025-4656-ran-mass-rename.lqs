// Dragnet [Ransomware]: dragnet-ransomware-2025-4656 — Mass File Rename (global)
// Status: deprecated | Level: high | ID: bab510af-ffa0-5fdd-9d8c-7f3c793bda2f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
