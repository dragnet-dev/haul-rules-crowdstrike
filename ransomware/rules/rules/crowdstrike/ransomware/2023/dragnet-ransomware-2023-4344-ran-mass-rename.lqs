// Dragnet [Ransomware]: dragnet-ransomware-2023-4344 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 37750923-a3bf-5642-beea-ef834c3c859f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
