// Dragnet [Ransomware]: dragnet-ransomware-2023-4343 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: b7c817f0-3698-5e07-8c61-d9d74f1a9de6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
