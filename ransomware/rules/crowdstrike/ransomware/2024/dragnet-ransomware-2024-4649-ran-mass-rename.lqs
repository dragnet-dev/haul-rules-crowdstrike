// Dragnet [Ransomware]: dragnet-ransomware-2024-4649 — Mass File Rename (ValenciaLeaks)
// Status: experimental | Level: high | ID: 9f530711-4be4-5f52-a7c6-417c79a8f492

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
