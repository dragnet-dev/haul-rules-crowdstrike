// Dragnet [Ransomware]: dragnet-ransomware-2026-2958 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 1a2a7829-8eac-510d-8586-9f7afc35cd60

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
