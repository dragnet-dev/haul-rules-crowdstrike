// Dragnet [Ransomware]: dragnet-ransomware-2021-0592 — Mass File Rename (blackshadow)
// Status: deprecated | Level: high | ID: 6d0840b6-e12b-5d1d-8d19-cfadc8f79006

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
