// Dragnet [Ransomware]: dragnet-ransomware-2022-0072 — Mass File Rename (vicesociety)
// Status: deprecated | Level: high | ID: 0a7e2bf4-38a3-510a-99cf-835d5b4cd4fe

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
