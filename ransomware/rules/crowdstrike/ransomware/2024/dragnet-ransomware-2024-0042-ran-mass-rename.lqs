// Dragnet [Ransomware]: dragnet-ransomware-2024-0042 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: 2fef44a8-468a-5024-9d4b-e0a2e6e01a10

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
