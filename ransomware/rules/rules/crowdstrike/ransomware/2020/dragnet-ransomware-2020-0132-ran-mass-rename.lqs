// Dragnet [Ransomware]: dragnet-ransomware-2020-0132 — Mass File Rename (netwalker)
// Status: deprecated | Level: high | ID: 9b558339-c1ca-5552-b5c1-4ecde6453161

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
