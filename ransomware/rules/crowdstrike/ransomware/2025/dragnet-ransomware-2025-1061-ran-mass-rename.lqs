// Dragnet [Ransomware]: dragnet-ransomware-2025-1061 — Mass File Rename (J)
// Status: experimental | Level: high | ID: b4a308c5-e73a-5597-9b8f-2ee4bcf9fbdc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
