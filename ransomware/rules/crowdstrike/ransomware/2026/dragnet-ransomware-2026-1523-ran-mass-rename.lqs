// Dragnet [Ransomware]: dragnet-ransomware-2026-1523 — Mass File Rename (threeam)
// Status: stable | Level: high | ID: 33296c2d-2873-5393-8e9e-392a19104966

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
