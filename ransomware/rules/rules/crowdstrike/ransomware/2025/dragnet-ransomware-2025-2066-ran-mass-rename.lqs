// Dragnet [Ransomware]: dragnet-ransomware-2025-2066 — Mass File Rename (dragonforce)
// Status: test | Level: high | ID: 611776ce-dc84-5afa-be3a-ec6a92ee810c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
