// Dragnet [Ransomware]: dragnet-ransomware-2025-2578 — Mass File Rename (interlock)
// Status: experimental | Level: high | ID: 404feb9d-fd2d-5701-afec-cf6614796644

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
