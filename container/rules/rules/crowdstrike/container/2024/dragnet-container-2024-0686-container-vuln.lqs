// Dragnet [Container]: dragnet-container-2024-0686 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 25e24210-66ec-56ec-a863-d51e224d46b4

#event_simpleName=*
| (ImageFileName = *amazonlinux:2* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:8* OR ImageFileName = *oraclelinux:7* OR ImageFileName = *oraclelinux:8* OR ImageFileName = *ubuntu:18.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
