// Dragnet [Ransomware]: dragnet-ransomware-2024-5378 — Mass File Rename (ElDorado)
// Status: deprecated | Level: high | ID: 0785442c-27a4-5e53-81b2-65deb4384ff1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
