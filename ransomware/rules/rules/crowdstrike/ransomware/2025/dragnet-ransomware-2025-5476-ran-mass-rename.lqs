// Dragnet [Ransomware]: dragnet-ransomware-2025-5476 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 9c322ff4-9626-59de-a181-b6913bf8a1cf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
