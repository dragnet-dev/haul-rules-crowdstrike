// Dragnet [Ransomware]: dragnet-ransomware-2025-2030 — Mass File Rename (shinyhunters)
// Status: experimental | Level: high | ID: 68d3b3ab-40e1-50e7-b1a3-0dc96d8a3abe

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
