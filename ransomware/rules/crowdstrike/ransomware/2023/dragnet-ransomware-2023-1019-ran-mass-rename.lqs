// Dragnet [Ransomware]: dragnet-ransomware-2023-1019 — Mass File Rename (rhysida)
// Status: experimental | Level: high | ID: 8647588f-e986-5c47-b39d-30fd1484468e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
