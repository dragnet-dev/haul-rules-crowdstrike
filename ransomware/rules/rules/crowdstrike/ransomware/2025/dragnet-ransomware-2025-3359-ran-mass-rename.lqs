// Dragnet [Ransomware]: dragnet-ransomware-2025-3359 — Mass File Rename (devman)
// Status: deprecated | Level: high | ID: 0e2b9ef0-0500-509e-a017-b60152af8998

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
