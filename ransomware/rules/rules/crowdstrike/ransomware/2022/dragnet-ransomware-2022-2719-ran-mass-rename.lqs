// Dragnet [Ransomware]: dragnet-ransomware-2022-2719 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 9a6424d5-09bb-5dbb-811a-dd3fc0bbc489

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
