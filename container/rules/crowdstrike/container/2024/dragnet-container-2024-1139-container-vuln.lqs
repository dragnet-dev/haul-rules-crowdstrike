// Dragnet [Container]: dragnet-container-2024-1139 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: c8c68412-90d7-5a46-9285-0b7e4b179a49

#event_simpleName=*
| (ImageFileName = *amazonlinux:2* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:7* OR ImageFileName = *ubuntu:18.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
