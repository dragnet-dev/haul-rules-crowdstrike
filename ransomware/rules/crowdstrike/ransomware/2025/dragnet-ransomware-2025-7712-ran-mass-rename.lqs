// Dragnet [Ransomware]: dragnet-ransomware-2025-7712 — Mass File Rename (threeam)
// Status: experimental | Level: high | ID: 36b90ab1-96d9-5d8f-8200-52da9369e8c2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
