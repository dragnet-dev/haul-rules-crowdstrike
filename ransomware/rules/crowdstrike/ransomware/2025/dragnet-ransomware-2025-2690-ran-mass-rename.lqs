// Dragnet [Ransomware]: dragnet-ransomware-2025-2690 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: fa553b23-a446-57a7-8e0c-0316e1bac172

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
