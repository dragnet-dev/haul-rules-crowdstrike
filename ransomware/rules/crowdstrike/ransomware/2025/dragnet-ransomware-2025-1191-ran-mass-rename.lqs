// Dragnet [Ransomware]: dragnet-ransomware-2025-1191 — Mass File Rename (play)
// Status: experimental | Level: high | ID: adc5ad3e-3e35-5dad-ba63-4e425158dd18

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
