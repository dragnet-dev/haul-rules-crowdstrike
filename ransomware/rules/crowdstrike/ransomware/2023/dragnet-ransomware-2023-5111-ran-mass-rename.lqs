// Dragnet [Ransomware]: dragnet-ransomware-2023-5111 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: fcaa77d0-40f2-5630-9943-17aad903e2c8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
