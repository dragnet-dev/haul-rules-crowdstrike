// Dragnet [Ransomware]: dragnet-ransomware-2025-0745 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 613f7a5a-0404-5b51-a003-94a4b0d0c3de

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
