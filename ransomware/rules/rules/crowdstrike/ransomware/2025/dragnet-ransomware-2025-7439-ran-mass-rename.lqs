// Dragnet [Ransomware]: dragnet-ransomware-2025-7439 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 46a0d799-1eba-5e58-b54b-6a94058dd3f0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
