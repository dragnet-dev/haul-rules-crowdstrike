// Dragnet [Ransomware]: dragnet-ransomware-2022-0962 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 729e066d-5606-53f0-bd36-85495760c2ac

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
