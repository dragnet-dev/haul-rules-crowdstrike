// Dragnet [Container]: dragnet-container-2024-1254 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 5a79a076-0c7b-58a8-b585-3decff0a540d

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *redhat/ubi9:*)
| table([timestamp, ComputerName])
| limit(1000)
