// Dragnet [Ransomware]: dragnet-ransomware-2023-0581 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: e0a7df29-168c-5258-8f4d-3ac2f4d61944

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
