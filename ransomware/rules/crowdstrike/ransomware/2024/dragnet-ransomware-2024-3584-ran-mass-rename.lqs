// Dragnet [Ransomware]: dragnet-ransomware-2024-3584 — Mass File Rename (blacklock)
// Status: experimental | Level: high | ID: 15994e18-25e5-5737-987d-e4919a997a58

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
