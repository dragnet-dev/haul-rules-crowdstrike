// Dragnet [Ransomware]: dragnet-ransomware-2024-3835 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: fe04579b-3a19-50d2-937c-aa8f877f42bf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
