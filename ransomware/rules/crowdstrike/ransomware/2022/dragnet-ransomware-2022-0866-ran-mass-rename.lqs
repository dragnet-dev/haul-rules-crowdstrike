// Dragnet [Ransomware]: dragnet-ransomware-2022-0866 — Mass File Rename (vicesociety)
// Status: deprecated | Level: high | ID: 5b0856ae-0214-5e53-bcdb-ca3f0a5c148c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
