// Dragnet [Container]: dragnet-container-2026-1408 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 586760cb-a3b4-5d59-9bd9-e45364586d0e

#event_simpleName=*
| (ImageFileName = *alpine edge:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
