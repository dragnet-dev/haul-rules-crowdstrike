// Dragnet [Ransomware]: dragnet-ransomware-2024-1532 — Mass File Rename (abyss)
// Status: deprecated | Level: high | ID: 75825718-251e-59b8-b5c8-a7c0b0d080ac

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
