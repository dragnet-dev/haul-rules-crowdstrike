// Dragnet [Ransomware]: dragnet-ransomware-2023-5189 — Mass File Rename (snatch)
// Status: experimental | Level: high | ID: aa54aaf0-4247-5864-8b26-73076bfebfc1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
