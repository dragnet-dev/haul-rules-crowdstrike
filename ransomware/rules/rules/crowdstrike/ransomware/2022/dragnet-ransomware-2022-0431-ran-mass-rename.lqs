// Dragnet [Ransomware]: dragnet-ransomware-2022-0431 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 5a713821-5b1c-5ef6-83db-e5cc8033fd68

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
