// Dragnet [Ransomware]: dragnet-ransomware-2023-3408 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 7e6b3849-ad3f-5844-9e39-0dce549cbea8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
