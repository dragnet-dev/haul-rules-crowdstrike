// Dragnet [Container]: dragnet-container-2026-2228 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 8a192260-2a6c-5460-93c8-f65e024221ef

#event_simpleName=*
| (ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10*)
| table([timestamp, ComputerName])
| limit(1000)
