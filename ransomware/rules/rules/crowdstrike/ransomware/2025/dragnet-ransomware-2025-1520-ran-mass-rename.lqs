// Dragnet [Ransomware]: dragnet-ransomware-2025-1520 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 172d83d1-6bff-584c-b0f7-52c96d22cb3f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
