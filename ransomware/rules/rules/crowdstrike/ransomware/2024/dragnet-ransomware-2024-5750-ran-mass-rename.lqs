// Dragnet [Ransomware]: dragnet-ransomware-2024-5750 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 666b33f6-f200-5a0f-aeb2-01bc20a8e78a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
