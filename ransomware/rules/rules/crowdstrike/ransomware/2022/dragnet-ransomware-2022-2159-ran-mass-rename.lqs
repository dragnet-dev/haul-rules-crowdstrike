// Dragnet [Ransomware]: dragnet-ransomware-2022-2159 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 172f6f1e-0c09-5bff-b09f-3525053f9646

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
