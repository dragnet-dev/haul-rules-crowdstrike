// Dragnet [Ransomware]: dragnet-ransomware-2024-2938 — Mass File Rename (metaencryptor)
// Status: experimental | Level: high | ID: 7a9ad234-78c3-524d-8f7f-a2e6b537d988

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
