// Dragnet [Ransomware]: dragnet-ransomware-2022-1211 — Mass File Rename (ragnarlocker)
// Status: deprecated | Level: high | ID: 8eeeee91-1c0b-5f38-bbc5-e7572c021c9d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
