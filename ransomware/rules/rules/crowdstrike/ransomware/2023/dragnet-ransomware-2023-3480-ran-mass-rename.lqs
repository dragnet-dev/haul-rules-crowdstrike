// Dragnet [Ransomware]: dragnet-ransomware-2023-3480 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 822266ba-f722-5b47-8c4f-d2d23125fbe8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
