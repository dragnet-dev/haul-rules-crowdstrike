// Dragnet [Ransomware]: dragnet-ransomware-2025-2773 — Mass File Rename (cephalus)
// Status: experimental | Level: high | ID: 934437be-0111-54ad-b6ba-72e0efdf9dc8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
