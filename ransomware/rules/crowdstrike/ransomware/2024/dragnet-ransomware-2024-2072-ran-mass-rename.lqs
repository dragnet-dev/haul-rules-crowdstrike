// Dragnet [Ransomware]: dragnet-ransomware-2024-2072 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 238c3825-a996-5de4-b732-09aabefc51e0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
