// Dragnet [Ransomware]: dragnet-ransomware-2023-1884 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: ee7a7c07-62bf-5ad6-8a9b-dd5db8d62c78

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
