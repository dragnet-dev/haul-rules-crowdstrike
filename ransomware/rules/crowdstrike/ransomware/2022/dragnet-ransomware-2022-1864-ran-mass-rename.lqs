// Dragnet [Ransomware]: dragnet-ransomware-2022-1864 — Mass File Rename (everest)
// Status: deprecated | Level: high | ID: d1221cd5-a358-5635-853a-dffbc1fb26f9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
