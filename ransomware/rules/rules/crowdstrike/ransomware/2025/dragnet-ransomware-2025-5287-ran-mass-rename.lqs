// Dragnet [Ransomware]: dragnet-ransomware-2025-5287 — Mass File Rename (crypto24)
// Status: deprecated | Level: high | ID: 15983f67-3f33-5a11-b282-b5a79bafb9fd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
