// Dragnet [Ransomware]: dragnet-ransomware-2020-0118 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 7bf88aea-418a-558f-b543-ba0438a73db6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
