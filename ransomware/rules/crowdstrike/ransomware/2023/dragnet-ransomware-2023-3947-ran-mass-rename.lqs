// Dragnet [Ransomware]: dragnet-ransomware-2023-3947 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: f46ba9c6-c285-5d10-b48b-88fa3341be7e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
