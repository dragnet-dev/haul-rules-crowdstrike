// Dragnet [Ransomware]: dragnet-ransomware-2024-1923 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: c69443f5-8a7b-51de-8a11-729e88e0ac7b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
