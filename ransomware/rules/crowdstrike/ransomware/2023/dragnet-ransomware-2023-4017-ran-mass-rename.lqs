// Dragnet [Ransomware]: dragnet-ransomware-2023-4017 — Mass File Rename (underground)
// Status: experimental | Level: high | ID: 84a8dbe0-977b-5471-b80a-8d41f7d129f2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
