// Dragnet [Ransomware]: dragnet-ransomware-2025-0642 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: f9d9db9b-bed7-5628-af0b-f355fe3ed4d5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
