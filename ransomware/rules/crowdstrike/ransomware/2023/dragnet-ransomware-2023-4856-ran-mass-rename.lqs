// Dragnet [Ransomware]: dragnet-ransomware-2023-4856 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: c4b0e737-dbce-5ea5-a66a-13fb56a86cf2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
