// Dragnet [Ransomware]: dragnet-ransomware-2024-3712 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 9807ab75-259d-50fb-bedd-bff3a5718fe3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
