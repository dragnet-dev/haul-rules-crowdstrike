// Dragnet [Ransomware]: dragnet-ransomware-2024-2713 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: d12d216e-3120-58a7-a1cd-572cd1064e54

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
