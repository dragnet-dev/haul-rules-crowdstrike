// Dragnet [Container]: dragnet-container-2024-0166 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 77271401-c422-5dcc-bb10-facff9864015

#event_simpleName=*
| (ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
