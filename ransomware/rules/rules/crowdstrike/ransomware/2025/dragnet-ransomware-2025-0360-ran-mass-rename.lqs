// Dragnet [Ransomware]: dragnet-ransomware-2025-0360 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 751318ff-e309-5319-a776-3090f4cedc51

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
