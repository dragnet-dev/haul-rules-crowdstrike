// Dragnet [Ransomware]: dragnet-ransomware-2024-0326 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: cc18d479-1223-5230-b36e-037efe3176fd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
