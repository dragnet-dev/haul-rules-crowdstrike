// Dragnet [Ransomware]: dragnet-ransomware-2024-1005 — Mass File Rename (arcusmedia)
// Status: experimental | Level: high | ID: 1d4711f7-ef7f-5e59-a560-16051bf56c20

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
