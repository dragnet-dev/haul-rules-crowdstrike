// Dragnet [Ransomware]: dragnet-ransomware-2025-5671 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 8162472a-1376-5fa9-bca3-ebda334c77ca

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
