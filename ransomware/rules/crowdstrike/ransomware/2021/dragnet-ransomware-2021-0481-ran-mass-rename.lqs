// Dragnet [Ransomware]: dragnet-ransomware-2021-0481 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: ec799142-fd94-5c2e-bf3b-c986219c92dd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
