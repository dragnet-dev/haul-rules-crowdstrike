// Dragnet [Ransomware]: dragnet-ransomware-2021-1663 — Mass File Rename (lv)
// Status: deprecated | Level: high | ID: 57f8324a-427f-5afb-99be-f0040dbaca0c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
