// Dragnet [Ransomware]: dragnet-ransomware-2025-4651 — Mass File Rename (stormous)
// Status: deprecated | Level: high | ID: b138b048-22c5-5767-8e70-8d13fdea3df3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
