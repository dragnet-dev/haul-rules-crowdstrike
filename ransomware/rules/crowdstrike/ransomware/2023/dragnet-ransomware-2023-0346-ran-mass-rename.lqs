// Dragnet [Ransomware]: dragnet-ransomware-2023-0346 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 60bc2868-63f0-5f8d-8e2c-e9ea435b54ab

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
