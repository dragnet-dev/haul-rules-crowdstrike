// Dragnet [Ransomware]: dragnet-ransomware-2023-1064 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 0bccf927-d5e1-5d7d-ac08-4ddca75c88a2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
