// Dragnet [Ransomware]: dragnet-ransomware-2025-5399 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 81d7c802-1740-536a-8aa3-91027c8752a3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
