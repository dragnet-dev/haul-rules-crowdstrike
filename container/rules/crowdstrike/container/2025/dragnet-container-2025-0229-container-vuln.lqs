// Dragnet [Container]: dragnet-container-2025-0229 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: ef5f95b4-4437-5d65-a081-36953a8b8a2f

#event_simpleName=*
| (ImageFileName = *almalinux:8* OR ImageFileName = *almalinux:9* OR ImageFileName = *amazonlinux:2023* OR ImageFileName = *azure linux:3.0* OR ImageFileName = *oraclelinux:8* OR ImageFileName = *oraclelinux:9* OR ImageFileName = *photon os:5.0*)
| table([timestamp, ComputerName])
| limit(1000)
