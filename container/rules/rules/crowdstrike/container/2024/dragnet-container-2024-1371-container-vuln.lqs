// Dragnet [Container]: dragnet-container-2024-1371 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: d9f37c17-b9c2-5252-b0c9-2cf5b52c6af6

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:17.10*)
| table([timestamp, ComputerName])
| limit(1000)
