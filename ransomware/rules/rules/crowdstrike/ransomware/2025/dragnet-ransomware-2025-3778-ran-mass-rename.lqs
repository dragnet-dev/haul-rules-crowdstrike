// Dragnet [Ransomware]: dragnet-ransomware-2025-3778 — Mass File Rename (d4rk4rmy)
// Status: experimental | Level: high | ID: 1ce0b804-486b-5766-b21f-f577a7b89c64

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
