// Dragnet [Ransomware]: dragnet-ransomware-2023-0926 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 9843aefc-39e2-5a83-b939-7ffd3d14fa3f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
