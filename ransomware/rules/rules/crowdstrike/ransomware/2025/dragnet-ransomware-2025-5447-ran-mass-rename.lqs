// Dragnet [Ransomware]: dragnet-ransomware-2025-5447 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 70145c15-2e21-5f61-86e5-231419d0657c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
