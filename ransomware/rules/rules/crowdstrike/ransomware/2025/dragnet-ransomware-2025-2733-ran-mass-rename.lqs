// Dragnet [Ransomware]: dragnet-ransomware-2025-2733 — Mass File Rename (sarcoma)
// Status: deprecated | Level: high | ID: 03e052b0-6ae8-5dc4-8d47-e7d1e2d04777

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
