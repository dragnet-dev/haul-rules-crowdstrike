// Dragnet [Ransomware]: dragnet-ransomware-2025-6131 — Mass File Rename (dunghill)
// Status: experimental | Level: high | ID: 64db88ac-02a1-5f47-be74-f1d89e35c553

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
