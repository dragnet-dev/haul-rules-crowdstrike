// Dragnet [Ransomware]: dragnet-ransomware-2023-3182 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: d10bcdef-09aa-5696-b8ce-692bbc81d672

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
