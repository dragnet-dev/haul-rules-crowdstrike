// Dragnet [Ransomware]: dragnet-ransomware-2022-1152 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: f4eebabf-c8a3-509c-a4d8-5f26184c9556

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
