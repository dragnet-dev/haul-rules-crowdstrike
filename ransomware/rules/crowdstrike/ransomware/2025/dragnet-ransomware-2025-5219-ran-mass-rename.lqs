// Dragnet [Ransomware]: dragnet-ransomware-2025-5219 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 6cd5bcdf-af2f-55cc-ad2c-92f60704518b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
