// Dragnet [Ransomware]: dragnet-ransomware-2023-0367 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 121c8d63-90c0-5feb-b5db-8534de0761be

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
