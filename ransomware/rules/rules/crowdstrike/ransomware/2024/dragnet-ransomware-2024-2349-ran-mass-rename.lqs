// Dragnet [Ransomware]: dragnet-ransomware-2024-2349 — Mass File Rename (hellogookie)
// Status: experimental | Level: high | ID: 1d2f2f94-d42f-5719-b768-909ae039d8ad

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
