// Dragnet [Ransomware]: dragnet-ransomware-2022-0892 — Mass File Rename (royal)
// Status: deprecated | Level: high | ID: 3cc0d74a-486d-5681-94e2-d2dbfea863d0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
