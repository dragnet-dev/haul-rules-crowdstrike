// Dragnet [Container]: dragnet-container-2024-1518 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: c49f7c90-6a6c-571a-ada9-eebb73e895f4

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:9* OR ImageFileName = *ubuntu:18.04*)
| table([timestamp, ComputerName])
| limit(1000)
