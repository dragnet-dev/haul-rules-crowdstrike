// Dragnet [Ransomware]: dragnet-ransomware-2025-0161 — Mass File Rename (obscura)
// Status: deprecated | Level: high | ID: 1ce70e5b-f444-5a47-be9f-4fcd39fc60b4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
