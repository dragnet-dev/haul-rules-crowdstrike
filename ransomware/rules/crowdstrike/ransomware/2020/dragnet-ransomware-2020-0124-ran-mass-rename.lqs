// Dragnet [Ransomware]: dragnet-ransomware-2020-0124 — Mass File Rename (maze)
// Status: deprecated | Level: high | ID: 70a02f6b-b08e-5d61-b46a-eadbd89f2fa0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
