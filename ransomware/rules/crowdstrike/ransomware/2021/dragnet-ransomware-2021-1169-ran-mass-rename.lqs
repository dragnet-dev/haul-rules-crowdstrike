// Dragnet [Ransomware]: dragnet-ransomware-2021-1169 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 934d5043-b26a-5c31-a3b9-160b4c7d6473

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
