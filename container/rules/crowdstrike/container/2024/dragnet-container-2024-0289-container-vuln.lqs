// Dragnet [Container]: dragnet-container-2024-0289 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: b7b002d8-d64c-5bbe-9ea2-c4ca6a15b5d4

#event_simpleName=*
| (ImageFileName = *almalinux:8* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:8* OR ImageFileName = *debian:9* OR ImageFileName = *oraclelinux:8* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:18.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
