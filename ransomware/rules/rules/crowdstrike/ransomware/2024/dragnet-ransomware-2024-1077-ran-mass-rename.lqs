// Dragnet [Ransomware]: dragnet-ransomware-2024-1077 — Mass File Rename (dragonforce)
// Status: deprecated | Level: high | ID: 55703880-d9d2-5fa5-adcd-fca79b4d3107

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
