// Dragnet [Ransomware]: dragnet-ransomware-2025-3193 — Mass File Rename (kraken)
// Status: experimental | Level: high | ID: 6427170e-29b3-5056-a55e-1b5c0bd1f596

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
