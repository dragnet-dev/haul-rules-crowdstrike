// Dragnet [Ransomware]: dragnet-ransomware-2024-5248 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: df06ff92-4683-5a34-a4b9-2ee68f792a92

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
