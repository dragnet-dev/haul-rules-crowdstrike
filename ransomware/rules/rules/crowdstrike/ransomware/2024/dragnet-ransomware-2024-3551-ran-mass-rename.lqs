// Dragnet [Ransomware]: dragnet-ransomware-2024-3551 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 5ed758b4-ec25-5d87-b0ed-4d571ed3843a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
