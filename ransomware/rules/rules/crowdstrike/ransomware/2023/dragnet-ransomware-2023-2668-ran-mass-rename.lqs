// Dragnet [Ransomware]: dragnet-ransomware-2023-2668 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: ee37daea-7cf6-5781-90f8-a0d14f595989

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
