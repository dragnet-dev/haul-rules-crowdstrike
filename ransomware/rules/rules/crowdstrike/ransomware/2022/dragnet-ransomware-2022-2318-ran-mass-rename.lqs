// Dragnet [Ransomware]: dragnet-ransomware-2022-2318 — Mass File Rename (royal)
// Status: deprecated | Level: high | ID: 42ce0c08-4f78-51e3-9faa-637fee993435

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
