// Dragnet [Ransomware]: dragnet-ransomware-2024-1311 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 6530cff1-6380-5c09-8c6f-12d547b1e46a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
