// Dragnet [Ransomware]: dragnet-ransomware-2023-4622 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 1921b9fe-a8ac-5d4d-80db-ca2e4303f1f4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
