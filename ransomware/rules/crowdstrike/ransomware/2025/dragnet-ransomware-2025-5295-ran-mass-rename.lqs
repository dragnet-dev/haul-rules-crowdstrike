// Dragnet [Ransomware]: dragnet-ransomware-2025-5295 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 9420455e-b4cf-5147-bca5-92e4398b0635

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
