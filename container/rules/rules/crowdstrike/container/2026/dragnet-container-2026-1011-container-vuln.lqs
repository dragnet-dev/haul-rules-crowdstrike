// Dragnet [Container]: dragnet-container-2026-1011 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: af4ace09-5831-5a8f-8b01-d13240814e2f

#event_simpleName=*
| (ImageFileName = *amazonlinux:1* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:7* OR ImageFileName = *redhat/ubi9:*)
| table([timestamp, ComputerName])
| limit(1000)
