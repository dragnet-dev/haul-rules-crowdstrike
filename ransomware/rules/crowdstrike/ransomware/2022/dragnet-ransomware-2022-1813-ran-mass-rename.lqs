// Dragnet [Ransomware]: dragnet-ransomware-2022-1813 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: f7c6a79c-2dcc-5af5-a683-e268755df739

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
