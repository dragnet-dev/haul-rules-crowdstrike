// Dragnet [Ransomware]: dragnet-ransomware-2024-2215 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 41a76976-3f8c-5b92-9e36-d079fa2206f3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
