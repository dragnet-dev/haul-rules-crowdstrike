// Dragnet [Ransomware]: dragnet-ransomware-2024-4696 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 6fdc0bd4-6714-5ff3-8a5c-3ca6f6a6f1ba

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
