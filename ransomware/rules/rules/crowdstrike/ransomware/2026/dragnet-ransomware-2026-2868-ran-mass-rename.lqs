// Dragnet [Ransomware]: dragnet-ransomware-2026-2868 — Mass File Rename (dragonforce)
// Status: stable | Level: high | ID: 1222f873-abbe-569b-847c-28450b99a855

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
