// Dragnet [Ransomware]: dragnet-ransomware-2025-1651 — Mass File Rename (IMNCrew)
// Status: experimental | Level: high | ID: 43e4f693-0b2f-5ec5-8b96-45e85d337997

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
