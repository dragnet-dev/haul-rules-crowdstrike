// Dragnet [Ransomware]: dragnet-ransomware-2023-3263 — Mass File Rename (play)
// Status: deprecated | Level: high | ID: 6a8bd524-4651-5c69-85e4-44dc8c80f556

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
