// Dragnet [Container]: dragnet-container-2026-1756 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 5f384e03-bad3-53da-8421-c4ed02db3262

#event_simpleName=*
| (ImageFileName = *alpine:3.23* OR ImageFileName = *alpine edge:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
