// Dragnet [Ransomware]: dragnet-ransomware-2024-5302 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 8977bef0-0ac6-5d4a-b093-f8440611c282

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
