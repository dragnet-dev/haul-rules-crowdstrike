// Dragnet [Ransomware]: dragnet-ransomware-2025-4145 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 2da89397-36a5-5d2a-9eb0-996928ca86f5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
