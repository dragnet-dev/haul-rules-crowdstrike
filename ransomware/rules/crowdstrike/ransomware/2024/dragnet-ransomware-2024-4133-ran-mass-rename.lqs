// Dragnet [Ransomware]: dragnet-ransomware-2024-4133 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 3278bf69-33df-5ad7-87da-b6edaff0e3fb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
