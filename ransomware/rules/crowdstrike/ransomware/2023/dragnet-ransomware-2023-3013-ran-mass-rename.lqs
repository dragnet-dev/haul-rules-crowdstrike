// Dragnet [Ransomware]: dragnet-ransomware-2023-3013 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 0cd02ae8-03cf-5177-b861-c7a2ba33202e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
