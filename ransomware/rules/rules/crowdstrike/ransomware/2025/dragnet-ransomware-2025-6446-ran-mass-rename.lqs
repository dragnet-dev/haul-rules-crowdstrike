// Dragnet [Ransomware]: dragnet-ransomware-2025-6446 — Mass File Rename (kairos)
// Status: experimental | Level: high | ID: a0dd2583-3854-5d18-ab9a-7f998c34e6e3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
