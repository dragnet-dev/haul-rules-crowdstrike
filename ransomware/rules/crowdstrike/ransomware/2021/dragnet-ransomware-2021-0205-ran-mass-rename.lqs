// Dragnet [Ransomware]: dragnet-ransomware-2021-0205 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: 735b7cb0-0a93-57b3-95a5-60b3b920a3ab

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
