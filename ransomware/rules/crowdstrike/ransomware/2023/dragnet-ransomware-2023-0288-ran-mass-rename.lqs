// Dragnet [Ransomware]: dragnet-ransomware-2023-0288 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: fdbc0bba-72a4-50f1-b0f8-04d2ce49453c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
