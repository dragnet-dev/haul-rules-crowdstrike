// Dragnet [Ransomware]: dragnet-ransomware-2024-3006 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 925481b5-da3e-577d-b604-cd3e79bbb7bb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
