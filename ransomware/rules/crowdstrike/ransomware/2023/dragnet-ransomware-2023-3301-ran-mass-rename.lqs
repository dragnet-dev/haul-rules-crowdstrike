// Dragnet [Ransomware]: dragnet-ransomware-2023-3301 — Mass File Rename (play)
// Status: experimental | Level: high | ID: b2f87834-fca8-58b6-9df6-5b016adc2542

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
