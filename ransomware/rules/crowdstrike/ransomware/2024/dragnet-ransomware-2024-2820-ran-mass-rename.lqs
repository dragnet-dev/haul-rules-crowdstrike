// Dragnet [Ransomware]: dragnet-ransomware-2024-2820 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: e02f662e-becd-5845-86ea-08a1ad1af717

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
