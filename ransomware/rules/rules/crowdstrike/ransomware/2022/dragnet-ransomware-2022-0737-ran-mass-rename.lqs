// Dragnet [Ransomware]: dragnet-ransomware-2022-0737 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: aa826ced-b4f6-5682-9769-9a4d055bb067

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
