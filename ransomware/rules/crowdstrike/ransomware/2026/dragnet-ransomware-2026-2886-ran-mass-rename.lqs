// Dragnet [Ransomware]: dragnet-ransomware-2026-2886 — Mass File Rename (anubis)
// Status: stable | Level: high | ID: 9c87365f-9da2-5038-a4e9-5c9fa9a853bb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
