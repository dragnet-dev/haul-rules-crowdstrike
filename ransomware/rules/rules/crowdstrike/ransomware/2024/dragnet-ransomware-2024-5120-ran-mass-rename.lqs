// Dragnet [Ransomware]: dragnet-ransomware-2024-5120 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 9936ed55-102d-5f90-96f9-a471d96be1aa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
