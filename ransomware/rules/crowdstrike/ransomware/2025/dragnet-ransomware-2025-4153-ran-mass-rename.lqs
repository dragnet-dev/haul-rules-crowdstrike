// Dragnet [Ransomware]: dragnet-ransomware-2025-4153 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: b15a2e42-2e74-593a-aa57-67b0fdb051da

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
