// Dragnet [Ransomware]: dragnet-ransomware-2023-2654 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 96fa38e1-b780-50fa-9ae3-3192f90f4139

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
