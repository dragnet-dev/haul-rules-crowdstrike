// Dragnet [Ransomware]: dragnet-ransomware-2022-2427 — Mass File Rename (everest)
// Status: deprecated | Level: high | ID: 19fbfedb-ad10-57e9-a399-093fe6d22884

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
