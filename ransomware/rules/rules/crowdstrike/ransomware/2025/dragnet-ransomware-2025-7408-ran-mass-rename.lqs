// Dragnet [Ransomware]: dragnet-ransomware-2025-7408 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: e985155d-ae86-5602-a655-979740a0e103

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
