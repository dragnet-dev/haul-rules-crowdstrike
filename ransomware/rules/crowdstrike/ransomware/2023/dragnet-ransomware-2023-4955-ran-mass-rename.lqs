// Dragnet [Ransomware]: dragnet-ransomware-2023-4955 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: b3e8f1e6-a4d6-5949-a712-6b4ad3973fea

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
