// Dragnet [Ransomware]: dragnet-ransomware-2023-0467 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: b1f513af-150f-51fa-ac76-4dcdaf5d7b6f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
