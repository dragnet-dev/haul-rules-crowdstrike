// Dragnet [Container]: dragnet-container-2024-0106 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 3da178b1-f1a2-5734-89f8-c341a84158e6

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
