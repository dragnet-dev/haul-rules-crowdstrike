// Dragnet [Container]: dragnet-container-2026-0259 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 1f87c496-ef20-523f-979e-1e0f9c474e71

#event_simpleName=*
| (ImageFileName = *chainguard:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
