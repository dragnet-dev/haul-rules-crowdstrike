// Dragnet [Ransomware]: dragnet-ransomware-2025-5742 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: a4c54a34-1394-5261-ac9e-3264f43a8226

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
