// Dragnet [Ransomware]: dragnet-ransomware-2023-3090 — Mass File Rename (monti)
// Status: experimental | Level: high | ID: 0e5ddd72-17d6-5f95-8a07-5dc20770c6af

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
