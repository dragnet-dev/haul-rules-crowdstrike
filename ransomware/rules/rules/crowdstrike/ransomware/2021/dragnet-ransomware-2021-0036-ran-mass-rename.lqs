// Dragnet [Ransomware]: dragnet-ransomware-2021-0036 — Mass File Rename (everest)
// Status: deprecated | Level: high | ID: 1a471237-dd04-5eb1-bdee-2983d67bd7aa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
