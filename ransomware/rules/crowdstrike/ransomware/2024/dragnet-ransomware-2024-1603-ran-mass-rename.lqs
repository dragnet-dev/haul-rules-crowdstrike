// Dragnet [Ransomware]: dragnet-ransomware-2024-1603 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: f4161a87-4bc5-5f4b-8ac4-08aeb3951193

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
