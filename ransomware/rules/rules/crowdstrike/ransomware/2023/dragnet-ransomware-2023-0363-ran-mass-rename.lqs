// Dragnet [Ransomware]: dragnet-ransomware-2023-0363 — Mass File Rename (noescape)
// Status: experimental | Level: high | ID: cfb14b3e-125c-5c75-8b0b-874da91d3f41

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
