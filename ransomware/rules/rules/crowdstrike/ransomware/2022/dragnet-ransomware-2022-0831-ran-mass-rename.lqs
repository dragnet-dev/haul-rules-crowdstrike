// Dragnet [Ransomware]: dragnet-ransomware-2022-0831 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: c291a9d8-14b6-5915-9115-10510ab347f5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
