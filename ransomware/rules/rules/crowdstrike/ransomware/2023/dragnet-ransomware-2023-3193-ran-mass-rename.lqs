// Dragnet [Ransomware]: dragnet-ransomware-2023-3193 — Mass File Rename (losttrust)
// Status: deprecated | Level: high | ID: dcd94612-ac25-5007-90dc-307e385f9dd8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
