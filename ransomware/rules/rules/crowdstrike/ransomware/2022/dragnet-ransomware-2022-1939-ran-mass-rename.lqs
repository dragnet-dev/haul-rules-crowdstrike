// Dragnet [Ransomware]: dragnet-ransomware-2022-1939 — Mass File Rename (blackbasta)
// Status: deprecated | Level: high | ID: 809ed509-3ec9-5f3e-a9ca-ab5caa5fda22

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
