// Dragnet [Ransomware]: dragnet-ransomware-2023-3490 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 09d83aac-0633-5fe3-81b3-28267650bfc4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
