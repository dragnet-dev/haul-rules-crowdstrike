// Dragnet [Ransomware]: dragnet-ransomware-2025-0140 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 65407d6b-d5ac-51a1-8b56-fa2e0531abab

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
