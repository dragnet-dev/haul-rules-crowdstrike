// Dragnet [Ransomware]: dragnet-ransomware-2023-0548 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 265d39ef-2fed-5787-9551-d1526ac4e020

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
