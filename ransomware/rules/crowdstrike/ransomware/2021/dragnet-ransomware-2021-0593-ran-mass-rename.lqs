// Dragnet [Ransomware]: dragnet-ransomware-2021-0593 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: b4b6d305-592d-59d7-ade1-ca2ef9760839

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
