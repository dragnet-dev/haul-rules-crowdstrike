// Dragnet [Ransomware]: dragnet-ransomware-2025-6771 — Mass File Rename (beast)
// Status: experimental | Level: high | ID: ba5ba6ca-9158-5539-9a6f-a940176cc2ba

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
