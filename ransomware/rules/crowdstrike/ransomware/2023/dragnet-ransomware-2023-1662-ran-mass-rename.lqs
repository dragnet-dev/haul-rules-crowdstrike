// Dragnet [Ransomware]: dragnet-ransomware-2023-1662 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: c11eda2f-152e-5156-a6d8-be932465f846

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
