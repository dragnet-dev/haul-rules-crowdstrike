// Dragnet [Ransomware]: dragnet-ransomware-2022-0542 — Mass File Rename (monti)
// Status: deprecated | Level: high | ID: 1759f896-bfcd-5187-a2ea-e61783731952

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
