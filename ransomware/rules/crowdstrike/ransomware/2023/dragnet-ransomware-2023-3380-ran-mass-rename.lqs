// Dragnet [Ransomware]: dragnet-ransomware-2023-3380 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 5bd28a8e-322d-514f-8d31-cf79f090779a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
