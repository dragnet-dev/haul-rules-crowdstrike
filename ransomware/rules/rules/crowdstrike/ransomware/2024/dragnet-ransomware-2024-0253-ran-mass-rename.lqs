// Dragnet [Ransomware]: dragnet-ransomware-2024-0253 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 496eba05-53e3-586b-a080-5ecd6f15f4d3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
