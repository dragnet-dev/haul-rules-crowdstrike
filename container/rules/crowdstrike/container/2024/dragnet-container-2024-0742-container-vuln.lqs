// Dragnet [Container]: dragnet-container-2024-0742 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: f575e614-b3e8-5a31-a26f-8a8e1d502477

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:8* OR ImageFileName = *debian:9* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *oraclelinux:7* OR ImageFileName = *photon os:2.0* OR ImageFileName = *photon os:3.0* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:14.04-ESM* OR ImageFileName = *ubuntu:16.04* OR ImageFileName = *ubuntu:16.04-ESM* OR ImageFileName = *ubuntu:18.04* OR ImageFileName = *ubuntu:18.04-ESM* OR ImageFileName = *ubuntu:19.04* OR ImageFileName = *ubuntu:19.10*)
| table([timestamp, ComputerName])
| limit(1000)
