// Dragnet [Ransomware]: dragnet-ransomware-2021-1756 — Mass File Rename (karma)
// Status: deprecated | Level: high | ID: 9fb59a9d-8afd-5b53-92b4-931e008cdce6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
