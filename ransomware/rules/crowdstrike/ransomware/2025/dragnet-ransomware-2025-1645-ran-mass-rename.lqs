// Dragnet [Ransomware]: dragnet-ransomware-2025-1645 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 4b43f1c2-03e9-53d1-b4f2-a88899ab3a0b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
