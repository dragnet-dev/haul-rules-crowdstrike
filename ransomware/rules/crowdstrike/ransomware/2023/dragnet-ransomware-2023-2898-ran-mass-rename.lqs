// Dragnet [Ransomware]: dragnet-ransomware-2023-2898 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 910d8c04-1f5d-5c33-92f6-37366570a8b4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
