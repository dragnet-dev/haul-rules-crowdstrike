// Dragnet [Ransomware]: dragnet-ransomware-2023-0589 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: ae534d20-4c59-508c-b256-e7fe481c636b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
