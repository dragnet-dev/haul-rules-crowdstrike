// Dragnet [Ransomware]: dragnet-ransomware-2025-4088 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 10c94ce5-44b6-5981-9882-8fd4359ab7d6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
