// Dragnet [Ransomware]: dragnet-ransomware-2025-2720 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 56ede9a9-63ac-56d3-8fde-7690d94b50b3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
