// Dragnet [Ransomware]: dragnet-ransomware-2023-5087 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 9a94e59b-837e-5fa3-bbfe-665c119d0266

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
