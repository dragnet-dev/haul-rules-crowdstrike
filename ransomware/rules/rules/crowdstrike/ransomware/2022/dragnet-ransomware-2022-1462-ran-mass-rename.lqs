// Dragnet [Ransomware]: dragnet-ransomware-2022-1462 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 013577db-4598-5721-8093-e2ec3701c5a1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
