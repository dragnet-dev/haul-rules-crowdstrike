// Dragnet [Ransomware]: dragnet-ransomware-2022-0697 — Mass File Rename (freecivilian)
// Status: deprecated | Level: high | ID: 325df04d-6dac-509d-934f-a47c43bf0443

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
