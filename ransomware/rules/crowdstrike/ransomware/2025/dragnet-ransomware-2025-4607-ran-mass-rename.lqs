// Dragnet [Ransomware]: dragnet-ransomware-2025-4607 — Mass File Rename (nova)
// Status: experimental | Level: high | ID: f555b858-fbb7-5a0a-8cf7-3d858b0c1558

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
