// Dragnet [Ransomware]: dragnet-ransomware-2023-3539 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: ed891312-14a1-5719-859f-0cb0dc908303

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
