// Dragnet [Ransomware]: dragnet-ransomware-2024-4951 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 1f00bf1d-f249-5938-bdb1-5232b03492a7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
