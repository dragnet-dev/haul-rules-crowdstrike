// Dragnet [Ransomware]: dragnet-ransomware-2021-1451 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: da181c90-daf4-5fe8-8933-d0161e3d49e6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
