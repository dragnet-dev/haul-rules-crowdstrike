// Dragnet [Ransomware]: dragnet-ransomware-2023-0419 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: a73ef589-cabf-5787-a4bd-867bcfe01a79

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
