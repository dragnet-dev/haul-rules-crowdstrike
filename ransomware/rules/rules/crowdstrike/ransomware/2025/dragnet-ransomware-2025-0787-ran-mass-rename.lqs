// Dragnet [Ransomware]: dragnet-ransomware-2025-0787 — Mass File Rename (cloak)
// Status: deprecated | Level: high | ID: 329a9a73-80b7-572c-a75d-85ec2924966c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
