// Dragnet [Ransomware]: dragnet-ransomware-2023-2908 — Mass File Rename (rhysida)
// Status: deprecated | Level: high | ID: e0f41e74-e08b-5d7a-81f8-2d1b3ef66048

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
