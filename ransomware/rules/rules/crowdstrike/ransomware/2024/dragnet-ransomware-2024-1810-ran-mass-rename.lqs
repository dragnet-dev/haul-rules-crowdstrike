// Dragnet [Ransomware]: dragnet-ransomware-2024-1810 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 04b46fea-1ba2-5d55-8ec5-d0946483abd4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
