// Dragnet [Ransomware]: dragnet-ransomware-2024-3334 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 14ffc2b8-5913-5a08-88d0-7f4894c694b5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
