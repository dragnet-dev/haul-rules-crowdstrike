// Dragnet [Ransomware]: dragnet-ransomware-2025-2001 — Mass File Rename (VanHelsing)
// Status: experimental | Level: high | ID: 3ae2ad1d-600b-5214-b10e-e4cb1155875b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
