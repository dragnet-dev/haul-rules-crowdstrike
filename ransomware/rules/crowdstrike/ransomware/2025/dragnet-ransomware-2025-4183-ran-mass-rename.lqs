// Dragnet [Ransomware]: dragnet-ransomware-2025-4183 — Mass File Rename (nightspire)
// Status: deprecated | Level: high | ID: 8f1179f0-e3e9-53c1-9cce-ead4438d1852

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
