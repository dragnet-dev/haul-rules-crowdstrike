// Dragnet [Ransomware]: dragnet-ransomware-2025-6517 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 8a806b56-11e7-5ba1-9d0a-d72d14604788

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
