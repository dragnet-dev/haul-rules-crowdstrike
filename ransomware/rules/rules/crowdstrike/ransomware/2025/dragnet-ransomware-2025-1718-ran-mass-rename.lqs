// Dragnet [Ransomware]: dragnet-ransomware-2025-1718 — Mass File Rename (bert)
// Status: experimental | Level: high | ID: 5ff392fd-27c7-5341-b14f-9267f575b00d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
