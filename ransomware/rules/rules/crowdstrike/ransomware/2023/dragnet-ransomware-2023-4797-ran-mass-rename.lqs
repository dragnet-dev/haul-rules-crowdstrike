// Dragnet [Ransomware]: dragnet-ransomware-2023-4797 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: d9256ec2-18a7-58c4-b2e6-cd9b3ab15cfe

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
