// Dragnet [Ransomware]: dragnet-ransomware-2025-4189 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: aa383c3e-0b33-5172-98be-9213e06131e1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
