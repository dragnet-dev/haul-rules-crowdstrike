// Dragnet [Ransomware]: dragnet-ransomware-2024-4283 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: f297ba70-db5c-592f-963a-bf5cf0a762b5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
