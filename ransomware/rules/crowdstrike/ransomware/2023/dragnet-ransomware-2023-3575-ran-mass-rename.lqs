// Dragnet [Ransomware]: dragnet-ransomware-2023-3575 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 1251ebe9-911c-5fcd-8603-d5a6323931a0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
