// Dragnet [Ransomware]: dragnet-ransomware-2025-6114 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: 0f700b6d-d10e-5412-a4ba-bf25ab85fc17

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
