// Dragnet [Ransomware]: dragnet-ransomware-2025-0893 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 9a9e936b-62eb-55b2-aaf2-9f40cf8ea965

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
