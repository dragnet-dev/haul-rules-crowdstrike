// Dragnet [Container]: dragnet-container-2024-0075 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 061564a5-4d25-5706-88b7-a56f25e89809

#event_simpleName=*
| (ImageFileName = *almalinux:8* OR ImageFileName = *chainguard:* OR ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:8* OR ImageFileName = *debian:9* OR ImageFileName = *oraclelinux:8* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:16.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
