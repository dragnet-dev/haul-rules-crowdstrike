// Dragnet [Ransomware]: dragnet-ransomware-2023-3791 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 0bf7e1e2-fe49-5a7f-95b5-eed1504a19f8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
