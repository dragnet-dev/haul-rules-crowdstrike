// Dragnet [Ransomware]: dragnet-ransomware-2024-0385 — Mass File Rename (apt73)
// Status: experimental | Level: high | ID: 6e507b16-d6ef-50b0-8d77-abc0bc43c82c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
