// Dragnet [Ransomware]: dragnet-ransomware-2025-3213 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 541cbd3f-d78b-5b10-830f-de983f0583a8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
