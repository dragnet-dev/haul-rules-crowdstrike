// Dragnet [Ransomware]: dragnet-ransomware-2024-5059 — Mass File Rename (rhysida)
// Status: deprecated | Level: high | ID: 3a61917d-04e0-5059-9f4d-24e8bb193afd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
