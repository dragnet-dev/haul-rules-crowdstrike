// Dragnet [Ransomware]: dragnet-ransomware-2025-5365 — Mass File Rename (direwolf)
// Status: experimental | Level: high | ID: 78aa5471-e20e-5f6e-8188-b0b4a7facbd1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
