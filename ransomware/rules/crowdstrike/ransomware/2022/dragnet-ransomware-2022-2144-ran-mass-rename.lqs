// Dragnet [Ransomware]: dragnet-ransomware-2022-2144 — Mass File Rename (ransomexx)
// Status: experimental | Level: high | ID: a96eec65-c2ed-5785-908c-1bd530f6d9db

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
