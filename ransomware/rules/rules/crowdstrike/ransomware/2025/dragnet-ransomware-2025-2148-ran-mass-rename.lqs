// Dragnet [Ransomware]: dragnet-ransomware-2025-2148 — Mass File Rename (J)
// Status: experimental | Level: high | ID: 951d5ec1-494c-53cb-8469-f601af738ae0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
