// Dragnet [Ransomware]: dragnet-ransomware-2024-2030 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 8b1af3b2-088b-5e57-bb31-ed5ca7d69508

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
