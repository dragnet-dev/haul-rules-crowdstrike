// Dragnet [Ransomware]: dragnet-ransomware-2024-4180 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: 7a0e5c81-de2d-5809-b389-94286e2918de

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
