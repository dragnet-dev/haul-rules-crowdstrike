// Dragnet [Ransomware]: dragnet-ransomware-2021-1532 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: dfeea4ba-12e4-562a-bba2-d21d0e2857a0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
