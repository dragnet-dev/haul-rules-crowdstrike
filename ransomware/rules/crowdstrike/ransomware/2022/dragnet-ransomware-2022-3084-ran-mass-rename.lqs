// Dragnet [Ransomware]: dragnet-ransomware-2022-3084 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: c1d3632f-4f71-5cdb-be14-71e1e309008d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
