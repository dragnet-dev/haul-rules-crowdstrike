// Dragnet [Ransomware]: dragnet-ransomware-2026-0916 — Mass File Rename (lockbit5)
// Status: stable | Level: high | ID: 34d6b9c1-1101-5620-bc03-328333b30567

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
