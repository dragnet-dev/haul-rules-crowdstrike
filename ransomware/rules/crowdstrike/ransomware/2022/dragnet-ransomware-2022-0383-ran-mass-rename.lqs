// Dragnet [Ransomware]: dragnet-ransomware-2022-0383 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: ed96ee61-187f-5b31-9826-d3bc0124b2d2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
