// Dragnet [Ransomware]: dragnet-ransomware-2025-5699 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 1eb25951-9178-52cf-a490-db0000488203

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
