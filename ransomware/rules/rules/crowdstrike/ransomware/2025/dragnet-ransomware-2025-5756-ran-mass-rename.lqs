// Dragnet [Ransomware]: dragnet-ransomware-2025-5756 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: b6f95ff4-6c7d-5bab-8fb8-1dc9df9070e2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
