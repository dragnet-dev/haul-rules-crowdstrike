// Dragnet [Ransomware]: dragnet-ransomware-2022-0863 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 06c103b3-efd0-5910-b089-9cefafccc31a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
