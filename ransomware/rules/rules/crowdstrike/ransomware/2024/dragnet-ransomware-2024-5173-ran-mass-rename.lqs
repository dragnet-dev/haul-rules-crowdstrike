// Dragnet [Ransomware]: dragnet-ransomware-2024-5173 — Mass File Rename (frag)
// Status: deprecated | Level: high | ID: 7757dbc2-36fb-50ca-b260-4d4b06ed86a2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
