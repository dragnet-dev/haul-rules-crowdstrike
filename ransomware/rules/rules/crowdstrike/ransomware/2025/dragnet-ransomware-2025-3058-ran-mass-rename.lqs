// Dragnet [Ransomware]: dragnet-ransomware-2025-3058 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 62a0c2ba-fca8-5349-934e-12715f2907b3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
