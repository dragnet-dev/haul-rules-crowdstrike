// Dragnet [Ransomware]: dragnet-ransomware-2022-2241 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 46e76a8f-b945-513b-8ff7-eae16d611791

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
