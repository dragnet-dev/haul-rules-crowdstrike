// Dragnet [Ransomware]: dragnet-ransomware-2024-2096 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 3ee076f1-3097-562b-b880-0b1b719398c4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
