// Dragnet [Ransomware]: dragnet-ransomware-2023-2434 — Mass File Rename (ransomed)
// Status: experimental | Level: high | ID: e8f914be-0f13-50da-a148-0b7800947dc7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
