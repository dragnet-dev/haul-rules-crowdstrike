// Dragnet [Ransomware]: dragnet-ransomware-2026-0492 — Mass File Rename (incransom)
// Status: test | Level: high | ID: 6d2b2d5e-24d8-56e3-945c-4ffa057b63a1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
