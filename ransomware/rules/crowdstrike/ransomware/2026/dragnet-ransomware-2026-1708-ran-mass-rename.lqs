// Dragnet [Ransomware]: dragnet-ransomware-2026-1708 — Mass File Rename (incransom)
// Status: stable | Level: high | ID: 15f47f46-2bc1-5a82-a5df-cd50ca514080

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
