// Dragnet [Container]: dragnet-container-2024-0303 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: cf1f85f5-5aaa-5376-bf7d-7f40230552c2

#event_simpleName=*
| (ImageFileName = *almalinux:8* OR ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:8* OR ImageFileName = *debian:9* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:16.04-ESM* OR ImageFileName = *ubuntu:18.04-ESM* OR ImageFileName = *ubuntu:20.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
