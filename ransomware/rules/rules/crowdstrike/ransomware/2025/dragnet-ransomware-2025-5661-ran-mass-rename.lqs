// Dragnet [Ransomware]: dragnet-ransomware-2025-5661 — Mass File Rename (abyss)
// Status: deprecated | Level: high | ID: f75855c2-8ab1-59c4-bb2e-b7a6baa3626d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
