// Dragnet [Ransomware]: dragnet-ransomware-2021-1157 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 7709279a-3bfb-515d-ba2f-49d080ce88f7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
