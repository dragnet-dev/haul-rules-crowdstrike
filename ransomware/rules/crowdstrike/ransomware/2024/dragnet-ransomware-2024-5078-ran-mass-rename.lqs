// Dragnet [Ransomware]: dragnet-ransomware-2024-5078 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 2085ec37-a251-5d13-8b23-216a72e7f9d3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
