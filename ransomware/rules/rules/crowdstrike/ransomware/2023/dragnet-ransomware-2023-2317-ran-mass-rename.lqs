// Dragnet [Ransomware]: dragnet-ransomware-2023-2317 — Mass File Rename (noescape)
// Status: experimental | Level: high | ID: 9c0c0f3e-f775-5156-8567-ed70a5d18080

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
