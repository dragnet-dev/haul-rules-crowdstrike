// Dragnet [Ransomware]: dragnet-ransomware-2025-1912 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 504447d0-239c-543f-827b-602fd0d0a3b2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
