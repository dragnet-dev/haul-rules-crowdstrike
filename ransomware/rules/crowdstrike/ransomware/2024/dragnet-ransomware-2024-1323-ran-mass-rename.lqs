// Dragnet [Ransomware]: dragnet-ransomware-2024-1323 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 2c4c1dba-dc30-5d34-a3ea-52b9aefc5ce3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
