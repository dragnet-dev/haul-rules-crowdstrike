// Dragnet [Ransomware]: dragnet-ransomware-2024-0956 — Mass File Rename (blacklock)
// Status: experimental | Level: high | ID: df01f0f4-575b-53ba-a7f1-6709edccd9b3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
