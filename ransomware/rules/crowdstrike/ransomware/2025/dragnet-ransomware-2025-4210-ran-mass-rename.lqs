// Dragnet [Ransomware]: dragnet-ransomware-2025-4210 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: da68052b-6d1d-5226-b2c4-e550b2b4a52c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
