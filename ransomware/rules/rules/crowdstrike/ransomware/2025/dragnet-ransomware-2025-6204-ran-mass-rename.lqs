// Dragnet [Ransomware]: dragnet-ransomware-2025-6204 — Mass File Rename (global)
// Status: deprecated | Level: high | ID: 50c9fdca-e5ff-5469-98d4-bc7957cfe556

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
