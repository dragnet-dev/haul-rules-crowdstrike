// Dragnet [Container]: dragnet-container-2024-1248 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: ac0d8c44-5743-587c-98a6-30a2ca988431

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:8* OR ImageFileName = *debian:9*)
| table([timestamp, ComputerName])
| limit(1000)
