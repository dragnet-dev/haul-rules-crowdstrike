// Dragnet [Ransomware]: dragnet-ransomware-2023-0897 — Mass File Rename (play)
// Status: experimental | Level: high | ID: cd8c8d2d-d476-586c-ab9a-f9762b74a239

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
