// Dragnet [Ransomware]: dragnet-ransomware-2022-1574 — Mass File Rename (blackbasta)
// Status: deprecated | Level: high | ID: 34af1cc3-b606-582d-8d83-772358a4aae9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
