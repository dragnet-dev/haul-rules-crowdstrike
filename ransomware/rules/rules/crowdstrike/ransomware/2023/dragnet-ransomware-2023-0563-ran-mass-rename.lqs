// Dragnet [Ransomware]: dragnet-ransomware-2023-0563 — Mass File Rename (play)
// Status: deprecated | Level: high | ID: 6695bc60-d13e-566c-82f5-8aa141bb6055

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
