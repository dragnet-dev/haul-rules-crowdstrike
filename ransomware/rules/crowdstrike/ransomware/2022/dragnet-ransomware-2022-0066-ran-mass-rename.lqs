// Dragnet [Ransomware]: dragnet-ransomware-2022-0066 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 5a6e5e0d-f293-5497-867b-e9184035d56a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
