// Dragnet [Ransomware]: dragnet-ransomware-2024-2754 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: b3b48d0b-4561-5bfc-99d6-61795e8a300f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
