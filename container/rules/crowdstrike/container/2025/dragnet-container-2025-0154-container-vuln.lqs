// Dragnet [Container]: dragnet-container-2025-0154 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: ef1f893a-ac34-5dd5-9327-f07374e01026

#event_simpleName=*
| (ImageFileName = *almalinux:8* OR ImageFileName = *almalinux:9* OR ImageFileName = *amazonlinux:2* OR ImageFileName = *azure linux:3.0* OR ImageFileName = *cbl-mariner:2.0* OR ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:8* OR ImageFileName = *oraclelinux:9* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:18.04-ESM* OR ImageFileName = *ubuntu:20.04-ESM* OR ImageFileName = *ubuntu:22.04*)
| table([timestamp, ComputerName])
| limit(1000)
