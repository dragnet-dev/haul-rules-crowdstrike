// Dragnet [Container]: dragnet-container-2026-1815 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: eaafd266-4358-5951-bc6b-dbf45b24b8d6

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:7* OR ImageFileName = *debian:8*)
| table([timestamp, ComputerName])
| limit(1000)
