// Dragnet [Ransomware]: dragnet-ransomware-2025-3876 — Mass File Rename (ransomhouse)
// Status: experimental | Level: high | ID: a2afcf6f-0873-5e14-8372-abf57da3adb1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
