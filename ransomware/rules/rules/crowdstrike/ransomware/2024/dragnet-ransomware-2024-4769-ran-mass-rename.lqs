// Dragnet [Ransomware]: dragnet-ransomware-2024-4769 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 7c538400-041b-55fd-af59-26701d8b4d14

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
