// Dragnet [Ransomware]: dragnet-ransomware-2025-5381 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: a0d5cbbb-1c29-5e4b-a395-be2dd46da2f9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
