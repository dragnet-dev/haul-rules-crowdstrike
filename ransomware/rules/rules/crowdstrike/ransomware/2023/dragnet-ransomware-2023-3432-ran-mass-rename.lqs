// Dragnet [Ransomware]: dragnet-ransomware-2023-3432 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: 3e460b79-5c00-5b20-a0ed-2e3e5ae3e25c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
