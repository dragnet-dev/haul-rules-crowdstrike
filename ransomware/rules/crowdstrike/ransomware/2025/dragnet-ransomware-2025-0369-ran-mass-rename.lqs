// Dragnet [Ransomware]: dragnet-ransomware-2025-0369 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 814a5400-c5e0-5c05-844e-c1313d8d1df3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
