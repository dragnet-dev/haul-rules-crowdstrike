// Dragnet [Ransomware]: dragnet-ransomware-2025-1260 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 3341da05-299b-5abf-a0be-1fc0ee2d2100

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
