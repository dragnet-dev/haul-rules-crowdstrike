// Dragnet [Ransomware]: dragnet-ransomware-2025-2301 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 22e8bd7f-281e-5742-b342-455199918f24

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
