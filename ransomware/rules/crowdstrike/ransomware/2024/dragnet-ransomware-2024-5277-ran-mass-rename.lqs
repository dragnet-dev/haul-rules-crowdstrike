// Dragnet [Ransomware]: dragnet-ransomware-2024-5277 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: a2329cf9-7e9e-55cc-ad2a-7db6ad0e49f1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
