// Dragnet [Ransomware]: dragnet-ransomware-2024-5309 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 2a83a0a8-d943-5897-8775-fe63de2d0cc4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
