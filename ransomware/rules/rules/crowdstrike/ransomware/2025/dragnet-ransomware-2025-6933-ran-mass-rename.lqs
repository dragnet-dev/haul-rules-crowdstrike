// Dragnet [Ransomware]: dragnet-ransomware-2025-6933 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 7aa135b1-6cdf-5167-8c8d-bcce7c5fbba4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
