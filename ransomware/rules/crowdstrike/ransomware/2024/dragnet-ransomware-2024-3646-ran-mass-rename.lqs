// Dragnet [Ransomware]: dragnet-ransomware-2024-3646 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 06e37b8b-e115-59b6-9ad6-29bd10505636

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
