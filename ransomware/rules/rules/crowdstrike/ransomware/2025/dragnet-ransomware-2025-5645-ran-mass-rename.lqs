// Dragnet [Ransomware]: dragnet-ransomware-2025-5645 — Mass File Rename (shinyhunters)
// Status: experimental | Level: high | ID: ff0e4de0-e3fd-5282-bdda-c4fe0e39141e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
