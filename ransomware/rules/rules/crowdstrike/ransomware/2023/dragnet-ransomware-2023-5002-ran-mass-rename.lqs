// Dragnet [Ransomware]: dragnet-ransomware-2023-5002 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 7fe995d9-ebe1-5d4c-9140-c6810e14af58

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
