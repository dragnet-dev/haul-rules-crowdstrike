// Dragnet [Ransomware]: dragnet-ransomware-2025-6699 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 07912d12-941d-581b-84da-951d8ddb5328

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
