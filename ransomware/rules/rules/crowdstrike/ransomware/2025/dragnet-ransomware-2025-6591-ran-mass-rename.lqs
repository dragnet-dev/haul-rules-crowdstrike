// Dragnet [Ransomware]: dragnet-ransomware-2025-6591 — Mass File Rename (cicada3301)
// Status: experimental | Level: high | ID: bf0e23d9-ebb3-51bd-8876-66ef0c26647f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
