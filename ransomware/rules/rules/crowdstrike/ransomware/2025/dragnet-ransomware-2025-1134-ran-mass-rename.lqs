// Dragnet [Ransomware]: dragnet-ransomware-2025-1134 — Mass File Rename (anubis)
// Status: experimental | Level: high | ID: 1541ce49-826b-5760-9f0a-eac0377a3a8d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
