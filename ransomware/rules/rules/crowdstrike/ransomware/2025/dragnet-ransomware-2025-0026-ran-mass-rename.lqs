// Dragnet [Ransomware]: dragnet-ransomware-2025-0026 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 0c51413c-25bf-56e7-bd18-647434be4eb7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
