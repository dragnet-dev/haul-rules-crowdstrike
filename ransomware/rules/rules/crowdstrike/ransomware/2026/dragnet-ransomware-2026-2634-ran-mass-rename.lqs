// Dragnet [Ransomware]: dragnet-ransomware-2026-2634 — Mass File Rename (fulcrumsec)
// Status: stable | Level: high | ID: 7c69c563-80fa-5b77-8b68-f549d700297a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
