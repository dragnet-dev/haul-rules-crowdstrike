// Dragnet [Ransomware]: dragnet-ransomware-2024-2796 — Mass File Rename (flocker)
// Status: experimental | Level: high | ID: 9854d3b6-f432-5f2e-8a55-e1843e0e2a39

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
