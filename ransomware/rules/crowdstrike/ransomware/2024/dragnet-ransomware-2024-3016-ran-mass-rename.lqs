// Dragnet [Ransomware]: dragnet-ransomware-2024-3016 — Mass File Rename (flocker)
// Status: experimental | Level: high | ID: b883c997-b6d2-5145-bdbe-3bef7ac3c7bc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
