// Dragnet [Ransomware]: dragnet-ransomware-2024-3772 — Mass File Rename (ransomexx)
// Status: experimental | Level: high | ID: 47df0a80-3f3e-5c32-bb4b-31a04e1b0b62

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
