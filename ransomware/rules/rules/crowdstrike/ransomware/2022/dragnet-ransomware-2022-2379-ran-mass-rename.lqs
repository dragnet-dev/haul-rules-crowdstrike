// Dragnet [Ransomware]: dragnet-ransomware-2022-2379 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: b524ee8f-ab5e-5964-b6aa-27e65f9f5e7a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
