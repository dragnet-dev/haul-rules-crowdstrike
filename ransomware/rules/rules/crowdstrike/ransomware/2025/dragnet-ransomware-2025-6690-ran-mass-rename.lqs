// Dragnet [Ransomware]: dragnet-ransomware-2025-6690 — Mass File Rename (lockbit5)
// Status: test | Level: high | ID: 07074e51-0efa-58f5-896d-12413daa36b3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
