// Dragnet [Ransomware]: dragnet-ransomware-2024-3776 — Mass File Rename (SilentRansomGroup)
// Status: deprecated | Level: high | ID: 6ddad68f-2162-5d15-af7c-a6a7deae3c41

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
