// Dragnet [Ransomware]: dragnet-ransomware-2025-3939 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 022f559e-f06e-5dca-9849-57b892571104

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
