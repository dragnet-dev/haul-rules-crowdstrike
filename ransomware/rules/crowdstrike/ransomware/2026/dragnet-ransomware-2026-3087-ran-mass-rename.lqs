// Dragnet [Ransomware]: dragnet-ransomware-2026-3087 — Mass File Rename (worldleaks)
// Status: stable | Level: high | ID: 5fa5ff3a-79bb-52cf-bfee-43d031611c46

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
