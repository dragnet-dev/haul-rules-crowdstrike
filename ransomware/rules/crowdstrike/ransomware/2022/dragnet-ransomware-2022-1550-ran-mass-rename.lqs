// Dragnet [Ransomware]: dragnet-ransomware-2022-1550 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: d67da581-5e92-52b8-86b9-add3435e7682

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
