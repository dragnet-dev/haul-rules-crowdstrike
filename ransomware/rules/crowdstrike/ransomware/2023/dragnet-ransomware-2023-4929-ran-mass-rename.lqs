// Dragnet [Ransomware]: dragnet-ransomware-2023-4929 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: f227c1ff-faaa-5371-9845-221d95de489a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
