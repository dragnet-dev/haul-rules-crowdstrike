// Dragnet [Ransomware]: dragnet-ransomware-2026-0086 — Mass File Rename (rhysida)
// Status: deprecated | Level: high | ID: 3aa448f2-3fee-5d05-8354-b262468e58ef

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
