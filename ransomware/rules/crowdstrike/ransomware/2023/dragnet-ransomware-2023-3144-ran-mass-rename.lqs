// Dragnet [Ransomware]: dragnet-ransomware-2023-3144 — Mass File Rename (threeam)
// Status: experimental | Level: high | ID: 68c24966-ab28-5b1c-abc2-31367473b022

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
