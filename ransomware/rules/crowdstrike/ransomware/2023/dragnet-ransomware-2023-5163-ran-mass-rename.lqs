// Dragnet [Ransomware]: dragnet-ransomware-2023-5163 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 7eb1eb45-64fb-52e3-82ef-152f407a5a69

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
