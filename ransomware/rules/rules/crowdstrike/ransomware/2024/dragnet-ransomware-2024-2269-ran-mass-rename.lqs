// Dragnet [Ransomware]: dragnet-ransomware-2024-2269 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 9355c15f-4d1e-5202-9cf2-b9829e72bf22

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
