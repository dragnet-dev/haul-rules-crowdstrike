// Dragnet [Ransomware]: dragnet-ransomware-2025-1496 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: 4ca8d8c4-d724-55e5-84c1-397d2b3a107c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
