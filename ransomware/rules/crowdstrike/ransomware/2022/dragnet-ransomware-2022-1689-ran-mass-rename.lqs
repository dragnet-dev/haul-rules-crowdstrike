// Dragnet [Ransomware]: dragnet-ransomware-2022-1689 — Mass File Rename (everest)
// Status: deprecated | Level: high | ID: 8fc3ec19-4304-590d-8ec3-a1a1d71835c3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
