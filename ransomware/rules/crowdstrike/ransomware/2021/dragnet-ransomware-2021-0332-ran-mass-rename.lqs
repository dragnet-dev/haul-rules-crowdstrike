// Dragnet [Ransomware]: dragnet-ransomware-2021-0332 — Mass File Rename (cuba)
// Status: deprecated | Level: high | ID: a43de360-809d-5ca3-ad87-15f084021099

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
