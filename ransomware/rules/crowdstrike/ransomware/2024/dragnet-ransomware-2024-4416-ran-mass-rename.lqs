// Dragnet [Ransomware]: dragnet-ransomware-2024-4416 — Mass File Rename (raworld)
// Status: experimental | Level: high | ID: 42465ce1-0366-518c-ac67-7a6097c98915

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
