// Dragnet [Ransomware]: dragnet-ransomware-2025-5546 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 4eecb10a-bdd8-52a4-a374-252fece16569

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
