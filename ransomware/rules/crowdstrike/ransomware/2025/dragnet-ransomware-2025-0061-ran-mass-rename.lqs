// Dragnet [Ransomware]: dragnet-ransomware-2025-0061 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 50556ce0-1bfb-5b59-9cc1-72c15925f9a0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
