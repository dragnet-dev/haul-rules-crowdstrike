// Dragnet [Ransomware]: dragnet-ransomware-2024-5939 — Mass File Rename (stormous)
// Status: deprecated | Level: high | ID: 6615dd42-634b-5cf7-bc26-ad6207f71a93

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
