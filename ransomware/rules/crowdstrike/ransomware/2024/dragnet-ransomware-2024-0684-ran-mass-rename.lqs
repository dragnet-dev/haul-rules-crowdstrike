// Dragnet [Ransomware]: dragnet-ransomware-2024-0684 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 8b9e3059-53b4-57ca-ab3e-7d4639f507d7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
