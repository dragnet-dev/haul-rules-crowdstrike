// Dragnet [Ransomware]: dragnet-ransomware-2022-3083 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 7837b724-7a1c-5836-978f-9b5bd22b30cd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
