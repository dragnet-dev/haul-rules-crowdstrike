// Dragnet [Ransomware]: dragnet-ransomware-2022-1378 — Mass File Rename (play)
// Status: deprecated | Level: high | ID: 87e91a71-8f3b-5d83-a1fe-4e2ca39ce6fa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
