// Dragnet [Ransomware]: dragnet-ransomware-2020-0266 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 4f24eb70-5fc5-5561-99d4-8f2b0ffbc3ee

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
