// Dragnet [Ransomware]: dragnet-ransomware-2025-6410 — Mass File Rename (lockbit5)
// Status: experimental | Level: high | ID: ba0857a3-d865-57df-ac5c-39a249dcdf3d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
