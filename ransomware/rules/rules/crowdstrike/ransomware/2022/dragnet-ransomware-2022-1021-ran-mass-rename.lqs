// Dragnet [Ransomware]: dragnet-ransomware-2022-1021 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 8e63c843-42e8-5170-8193-4412ff143acf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
