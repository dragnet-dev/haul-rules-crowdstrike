// Dragnet [Ransomware]: dragnet-ransomware-2025-3217 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: b6a7cdfa-d2a1-513e-937d-976a21b75275

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
