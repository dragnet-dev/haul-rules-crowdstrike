// Dragnet [Ransomware]: dragnet-ransomware-2025-3888 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 397a81a8-78f8-5565-8639-91360aa09b73

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
