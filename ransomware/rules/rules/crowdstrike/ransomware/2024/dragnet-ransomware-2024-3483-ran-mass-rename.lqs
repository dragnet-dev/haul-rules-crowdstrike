// Dragnet [Ransomware]: dragnet-ransomware-2024-3483 — Mass File Rename (ransomhouse)
// Status: experimental | Level: high | ID: 5fa5b356-8a25-5bb1-bb4b-869827579a6e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
