// Dragnet [Ransomware]: dragnet-ransomware-2024-1860 — Mass File Rename (embargo)
// Status: experimental | Level: high | ID: 33aea5f8-c18d-582c-91e9-6e1e01c2ce2c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
