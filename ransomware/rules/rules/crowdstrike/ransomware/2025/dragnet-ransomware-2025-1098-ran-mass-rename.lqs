// Dragnet [Ransomware]: dragnet-ransomware-2025-1098 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 9d195956-b3f3-569e-95ef-7b2e5fad358c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
