// Dragnet [Ransomware]: dragnet-ransomware-2025-3572 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 7eac00a4-0e3b-5064-a57d-75b8759566dc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
