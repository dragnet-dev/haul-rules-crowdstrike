// Dragnet [Ransomware]: dragnet-ransomware-2025-6705 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 405a374b-5aea-5431-8ee2-4c16c91f256e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
