// Dragnet [Container]: dragnet-container-2026-0888 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 39e1d17b-709d-5b19-a18d-b1de17099c6a

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:7*)
| table([timestamp, ComputerName])
| limit(1000)
