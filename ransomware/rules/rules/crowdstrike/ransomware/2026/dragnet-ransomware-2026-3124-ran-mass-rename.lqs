// Dragnet [Ransomware]: dragnet-ransomware-2026-3124 — Mass File Rename (handala)
// Status: stable | Level: high | ID: cdf192d6-7d6e-5039-b2ff-17b6fe61a4e1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
