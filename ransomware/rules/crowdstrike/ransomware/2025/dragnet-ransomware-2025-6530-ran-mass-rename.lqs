// Dragnet [Ransomware]: dragnet-ransomware-2025-6530 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: ce4db6a5-6d4e-5492-8922-098f0388f7f0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
