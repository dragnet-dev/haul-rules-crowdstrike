// Dragnet [Ransomware]: dragnet-ransomware-2024-1069 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 9e657de8-89f0-5682-9ab6-6648f3c88051

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
