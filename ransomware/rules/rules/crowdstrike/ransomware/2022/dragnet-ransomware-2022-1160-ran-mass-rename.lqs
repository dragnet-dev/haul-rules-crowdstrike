// Dragnet [Ransomware]: dragnet-ransomware-2022-1160 — Mass File Rename (suncrypt)
// Status: deprecated | Level: high | ID: 4d164e57-fd2b-5925-8cfe-2d4131d8371f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
