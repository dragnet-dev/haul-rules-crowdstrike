// Dragnet [Ransomware]: dragnet-ransomware-2026-0123 — Mass File Rename (payload)
// Status: stable | Level: high | ID: f5619a7d-6c26-5417-899a-fcde085450f0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
