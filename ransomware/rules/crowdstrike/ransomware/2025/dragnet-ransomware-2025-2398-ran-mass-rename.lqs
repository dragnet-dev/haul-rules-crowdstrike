// Dragnet [Ransomware]: dragnet-ransomware-2025-2398 — Mass File Rename (thegentlemen)
// Status: experimental | Level: high | ID: 1d8ac47c-f7ce-5307-ae84-b7b57b9abfa9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
