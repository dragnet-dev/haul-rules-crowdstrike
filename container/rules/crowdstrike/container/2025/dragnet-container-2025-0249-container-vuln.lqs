// Dragnet [Container]: dragnet-container-2025-0249 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 3cb2e02f-f513-53fd-90cb-cc3fc9622341

#event_simpleName=*
| (ImageFileName = *oraclelinux:7* OR ImageFileName = *ubuntu:14.04* OR ImageFileName = *ubuntu:16.04* OR ImageFileName = *ubuntu:16.10* OR ImageFileName = *ubuntu:17.04*)
| table([timestamp, ComputerName])
| limit(1000)
