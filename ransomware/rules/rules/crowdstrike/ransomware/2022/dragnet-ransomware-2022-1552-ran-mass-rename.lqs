// Dragnet [Ransomware]: dragnet-ransomware-2022-1552 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: eaa1fd83-ccb9-5d2b-a313-a050c65116f5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
