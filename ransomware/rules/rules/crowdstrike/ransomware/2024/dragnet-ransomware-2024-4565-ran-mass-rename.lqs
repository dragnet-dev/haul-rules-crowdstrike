// Dragnet [Ransomware]: dragnet-ransomware-2024-4565 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 75f346fc-2fee-5ae1-b143-e45821b1bb1c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
