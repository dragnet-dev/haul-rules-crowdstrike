// Dragnet [Ransomware]: dragnet-ransomware-2025-2763 — Mass File Rename (VanHelsing)
// Status: experimental | Level: high | ID: 2992cabd-0b65-5f14-9163-b7135509e680

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
