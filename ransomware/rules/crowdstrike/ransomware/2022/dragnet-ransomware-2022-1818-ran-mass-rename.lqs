// Dragnet [Ransomware]: dragnet-ransomware-2022-1818 — Mass File Rename (pandora)
// Status: deprecated | Level: high | ID: 819c6a3f-ed5a-5f13-8775-6d78195c3036

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
