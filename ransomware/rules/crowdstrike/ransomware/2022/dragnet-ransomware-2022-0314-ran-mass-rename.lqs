// Dragnet [Ransomware]: dragnet-ransomware-2022-0314 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 9e010632-1d11-5a38-b891-e98336d2bb99

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
