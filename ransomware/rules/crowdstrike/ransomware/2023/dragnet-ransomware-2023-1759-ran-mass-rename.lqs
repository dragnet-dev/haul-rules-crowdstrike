// Dragnet [Ransomware]: dragnet-ransomware-2023-1759 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 3dd601b3-2b86-53bf-bdb7-de1f38cb9d46

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
