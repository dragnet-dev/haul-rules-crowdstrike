// Dragnet [Ransomware]: dragnet-ransomware-2024-5068 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 4a1b1b8d-9b0c-5c36-b21a-546046528fd3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
