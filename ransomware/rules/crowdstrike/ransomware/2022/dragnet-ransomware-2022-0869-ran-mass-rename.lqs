// Dragnet [Ransomware]: dragnet-ransomware-2022-0869 — Mass File Rename (roadsweep)
// Status: deprecated | Level: high | ID: 9a404464-761b-5c36-aa4a-5b4a3311284d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
