// Dragnet [Ransomware]: dragnet-ransomware-2024-4063 — Mass File Rename (play)
// Status: experimental | Level: high | ID: d312b164-acac-544d-8dbc-093d62038986

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
