// Dragnet [Ransomware]: dragnet-ransomware-2023-2575 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 4bd43f97-2719-5bb5-82ab-34c1db7ecb6d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
