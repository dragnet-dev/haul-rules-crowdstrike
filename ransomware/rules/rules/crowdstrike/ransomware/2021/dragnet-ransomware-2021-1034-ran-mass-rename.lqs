// Dragnet [Ransomware]: dragnet-ransomware-2021-1034 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: ce2bdaed-845e-551f-b968-1d00c040f208

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
