// Dragnet [Ransomware]: dragnet-ransomware-2023-0292 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: 7fe8d8ed-77a8-5086-bb2e-cf00e97b4cd2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
