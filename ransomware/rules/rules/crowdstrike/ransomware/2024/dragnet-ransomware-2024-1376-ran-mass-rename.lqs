// Dragnet [Ransomware]: dragnet-ransomware-2024-1376 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 88e17b73-53b9-5197-acb9-0c8ae9e6c5ad

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
