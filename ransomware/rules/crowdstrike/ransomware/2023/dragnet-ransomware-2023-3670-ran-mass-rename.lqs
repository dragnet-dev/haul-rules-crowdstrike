// Dragnet [Ransomware]: dragnet-ransomware-2023-3670 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: d74f0338-81b3-5a4e-839f-e5066de13dd9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
