// Dragnet [Ransomware]: dragnet-ransomware-2024-3532 — Mass File Rename (play)
// Status: experimental | Level: high | ID: a081f791-445e-5ad4-b0f0-e884f546c333

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
