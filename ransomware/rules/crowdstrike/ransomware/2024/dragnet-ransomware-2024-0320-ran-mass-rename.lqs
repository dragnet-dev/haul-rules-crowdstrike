// Dragnet [Ransomware]: dragnet-ransomware-2024-0320 — Mass File Rename (orca)
// Status: experimental | Level: high | ID: 205eddfd-9db9-5cd5-8f6e-41f3136255c7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
