// Dragnet [Ransomware]: dragnet-ransomware-2025-5206 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 2f96039d-75bf-52d4-acfa-15f4fa1f0007

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
