// Dragnet [Ransomware]: dragnet-ransomware-2022-0634 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: f078fb10-2e3b-5378-a848-603340570352

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
