// Dragnet [Ransomware]: dragnet-ransomware-2021-0141 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 0dd9ab78-6905-551c-af7a-2b2d998f1a80

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
