// Dragnet [Ransomware]: dragnet-ransomware-2025-0706 — Mass File Rename (worldleaks)
// Status: experimental | Level: high | ID: 062493d1-2d4a-5146-983a-62e9e23f15cc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
