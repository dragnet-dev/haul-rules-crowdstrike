// Dragnet [Ransomware]: dragnet-ransomware-2026-1514 — Mass File Rename (incransom)
// Status: stable | Level: high | ID: 4a8a5c7d-d23e-5947-8bdc-d8858de85514

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
