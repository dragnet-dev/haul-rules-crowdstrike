// Dragnet [Ransomware]: dragnet-ransomware-2023-0719 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: e1b2b243-2679-5034-916a-ea7fd246d8d5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
