// Dragnet [Container]: dragnet-container-2026-0824 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: b871a9a1-a0e4-5bd4-a6a6-9f600c691612

#event_simpleName=*
| (ImageFileName = *amazonlinux:1* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:7* OR ImageFileName = *redhat/ubi9:*)
| table([timestamp, ComputerName])
| limit(1000)
