// Dragnet [Ransomware]: dragnet-ransomware-2025-3292 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: aebbd594-66af-5d47-a5f0-abf3918ad0d4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
