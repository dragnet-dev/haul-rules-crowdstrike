// Dragnet [Ransomware]: dragnet-ransomware-2023-0959 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 90e9d7e7-f169-5aac-a6bc-c6a39a4c8dd8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
