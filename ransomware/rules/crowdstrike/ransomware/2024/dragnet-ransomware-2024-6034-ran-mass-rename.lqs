// Dragnet [Ransomware]: dragnet-ransomware-2024-6034 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: a7778806-637a-5508-9ec5-3508364e915b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
