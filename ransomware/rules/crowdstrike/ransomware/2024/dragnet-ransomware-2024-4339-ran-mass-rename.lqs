// Dragnet [Ransomware]: dragnet-ransomware-2024-4339 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 28f3b746-a3d9-5b3e-850a-b192bdba5ebd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
