// Dragnet [Ransomware]: dragnet-ransomware-2022-1928 — Mass File Rename (ransomexx)
// Status: experimental | Level: high | ID: 5d13e601-a57f-522e-8bbc-744e391b71cd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
