// Dragnet [Ransomware]: dragnet-ransomware-2023-1761 — Mass File Rename (nitrogen)
// Status: experimental | Level: high | ID: ec75170f-57fc-59be-8724-67136a41a263

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
