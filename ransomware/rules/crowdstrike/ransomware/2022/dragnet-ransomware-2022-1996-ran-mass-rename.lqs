// Dragnet [Ransomware]: dragnet-ransomware-2022-1996 — Mass File Rename (royal)
// Status: deprecated | Level: high | ID: a58fedda-8041-5b40-b197-dbfdb0030950

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
