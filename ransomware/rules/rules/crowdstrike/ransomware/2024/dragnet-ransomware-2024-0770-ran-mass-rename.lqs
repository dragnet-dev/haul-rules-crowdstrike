// Dragnet [Ransomware]: dragnet-ransomware-2024-0770 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: d4ed561a-0249-56b8-a62e-8eee14d0b66c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
