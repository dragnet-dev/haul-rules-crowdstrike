// Dragnet [Ransomware]: dragnet-ransomware-2023-2383 — Mass File Rename (losttrust)
// Status: deprecated | Level: high | ID: 952988ea-a63b-521a-b61b-1c08466c733c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
