// Dragnet [Ransomware]: dragnet-ransomware-2023-4870 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 50c2da74-4f25-51fb-a44c-e33ce157c727

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
