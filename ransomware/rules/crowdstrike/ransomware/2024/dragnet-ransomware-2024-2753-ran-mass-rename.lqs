// Dragnet [Ransomware]: dragnet-ransomware-2024-2753 — Mass File Rename (play)
// Status: experimental | Level: high | ID: b64d27dd-d595-5fcb-bdcb-0475701cf534

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
