// Dragnet [Ransomware]: dragnet-ransomware-2025-2950 — Mass File Rename (handala)
// Status: experimental | Level: high | ID: d70bd6b6-a525-556d-b7fe-7e45cecc7392

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
