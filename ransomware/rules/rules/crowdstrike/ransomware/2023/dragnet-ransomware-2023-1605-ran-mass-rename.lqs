// Dragnet [Ransomware]: dragnet-ransomware-2023-1605 — Mass File Rename (losttrust)
// Status: deprecated | Level: high | ID: fe70d127-f49d-5ac4-9e28-b70e74cb2586

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
