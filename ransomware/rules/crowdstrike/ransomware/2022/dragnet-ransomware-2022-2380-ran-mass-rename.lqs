// Dragnet [Ransomware]: dragnet-ransomware-2022-2380 — Mass File Rename (blackbasta)
// Status: deprecated | Level: high | ID: 502b7a89-8b71-5ac7-82e0-444599d2ad8e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
