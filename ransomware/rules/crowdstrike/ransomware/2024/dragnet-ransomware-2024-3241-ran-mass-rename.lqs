// Dragnet [Ransomware]: dragnet-ransomware-2024-3241 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 8b102e91-558b-55e7-8f06-10b6ab65b00c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
