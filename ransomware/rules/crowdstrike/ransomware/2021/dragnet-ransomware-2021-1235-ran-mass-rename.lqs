// Dragnet [Ransomware]: dragnet-ransomware-2021-1235 — Mass File Rename (midas)
// Status: deprecated | Level: high | ID: 0bd5d41b-7738-5908-b080-4b89826f2002

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
