// Dragnet [Ransomware]: dragnet-ransomware-2026-0813 — Mass File Rename (dragonforce)
// Status: stable | Level: high | ID: 118c41fe-aa5c-58d2-862e-78d8731ee9ea

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
