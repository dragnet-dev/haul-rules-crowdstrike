// Dragnet [Ransomware]: dragnet-ransomware-2025-5348 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: e12014cb-7488-5637-ac0f-52045e499b18

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
