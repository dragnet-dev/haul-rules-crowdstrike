// Dragnet [Ransomware]: dragnet-ransomware-2025-6359 — Mass File Rename (arcusmedia)
// Status: experimental | Level: high | ID: 9b6f115c-5491-5258-bfc6-b56044295932

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
