// Dragnet [Ransomware]: dragnet-ransomware-2024-0745 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 4ba648fb-60f2-50f8-aa8c-095ca1698858

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
