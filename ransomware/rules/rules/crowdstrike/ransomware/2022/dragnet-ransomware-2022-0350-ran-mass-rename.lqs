// Dragnet [Ransomware]: dragnet-ransomware-2022-0350 — Mass File Rename (rook)
// Status: deprecated | Level: high | ID: b7a7b788-c651-57b6-a9fc-a350153f842c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
