// Dragnet [Ransomware]: dragnet-ransomware-2024-5144 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: 61fdfb00-b1e3-5414-9dc4-810790238ccb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
