// Dragnet [Ransomware]: dragnet-ransomware-2026-0770 — Mass File Rename (dragonforce)
// Status: stable | Level: high | ID: d9d22181-2b2f-5074-b709-b585afbcf3b4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
