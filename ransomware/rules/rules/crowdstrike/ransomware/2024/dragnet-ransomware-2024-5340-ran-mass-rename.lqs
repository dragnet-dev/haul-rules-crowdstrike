// Dragnet [Ransomware]: dragnet-ransomware-2024-5340 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 9fa6f198-4484-5fa0-b6d9-19a46ba0d2a7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
