// Dragnet [Ransomware]: dragnet-ransomware-2024-5590 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 0eaa5802-8a8e-57bb-9b15-5b0c3680f0a1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
