// Dragnet [Ransomware]: dragnet-ransomware-2024-2067 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 63662dd5-32b7-542f-9f90-b217ff1a3154

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
