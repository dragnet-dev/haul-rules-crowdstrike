// Dragnet [Ransomware]: dragnet-ransomware-2026-1987 — Mass File Rename (lockbit5)
// Status: stable | Level: high | ID: 38e72227-9b9d-5655-bbb2-dbdc97fb3cb5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
