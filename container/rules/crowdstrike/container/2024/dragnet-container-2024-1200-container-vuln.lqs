// Dragnet [Container]: dragnet-container-2024-1200 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: adcd555c-8512-5a43-b9ec-c4ebb86afc6a

#event_simpleName=*
| (ImageFileName = *almalinux:9* OR ImageFileName = *chainguard:* OR ImageFileName = *oraclelinux:9* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:24.10* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
