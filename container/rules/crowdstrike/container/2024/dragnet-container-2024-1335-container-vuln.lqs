// Dragnet [Container]: dragnet-container-2024-1335 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: e93e7f46-fdd6-57d5-910a-4d780fccd734

#event_simpleName=*
| (ImageFileName = *amazonlinux:2* OR ImageFileName = *cbl-mariner:1.0* OR ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:9* OR ImageFileName = *oraclelinux:7* OR ImageFileName = *oraclelinux:8* OR ImageFileName = *photon os:2.0* OR ImageFileName = *photon os:3.0* OR ImageFileName = *ubuntu:14.04-ESM* OR ImageFileName = *ubuntu:16.04-ESM* OR ImageFileName = *ubuntu:18.04* OR ImageFileName = *ubuntu:18.04-ESM* OR ImageFileName = *ubuntu:20.04* OR ImageFileName = *ubuntu:20.04-ESM* OR ImageFileName = *ubuntu:20.10* OR ImageFileName = *ubuntu:21.04* OR ImageFileName = *ubuntu:21.10* OR ImageFileName = *ubuntu:22.04*)
| table([timestamp, ComputerName])
| limit(1000)
