// Dragnet [Ransomware]: dragnet-ransomware-2023-1847 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 99b8f5fe-e413-52b0-af98-5b490f414f24

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
