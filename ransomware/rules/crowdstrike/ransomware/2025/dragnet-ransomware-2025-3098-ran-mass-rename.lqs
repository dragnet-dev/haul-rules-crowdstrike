// Dragnet [Ransomware]: dragnet-ransomware-2025-3098 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 5bfd0101-8cc0-52de-aa4e-49f7ef7b3d8b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
