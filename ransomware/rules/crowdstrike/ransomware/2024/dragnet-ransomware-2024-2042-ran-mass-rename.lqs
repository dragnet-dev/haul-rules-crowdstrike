// Dragnet [Ransomware]: dragnet-ransomware-2024-2042 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: 4c61dfea-58d5-56fa-a2a3-467679a965da

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
