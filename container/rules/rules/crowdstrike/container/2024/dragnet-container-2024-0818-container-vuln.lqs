// Dragnet [Container]: dragnet-container-2024-0818 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 768ac4c9-062e-5685-a483-eec95eec68bc

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:20.04-ESM* OR ImageFileName = *ubuntu:22.04*)
| table([timestamp, ComputerName])
| limit(1000)
