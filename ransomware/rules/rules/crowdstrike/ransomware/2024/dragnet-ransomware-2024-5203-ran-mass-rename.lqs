// Dragnet [Ransomware]: dragnet-ransomware-2024-5203 — Mass File Rename (dAn0n)
// Status: experimental | Level: high | ID: b11f2659-ae00-56f4-9dfb-47661c74d17c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
