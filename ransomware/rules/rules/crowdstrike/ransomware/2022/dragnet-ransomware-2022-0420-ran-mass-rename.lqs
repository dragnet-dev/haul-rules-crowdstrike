// Dragnet [Ransomware]: dragnet-ransomware-2022-0420 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: b971c086-8046-5381-9e1b-cca0b063e0f1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
