// Dragnet [Ransomware]: dragnet-ransomware-2025-1609 — Mass File Rename (chaos)
// Status: experimental | Level: high | ID: dc929b12-6c80-546d-b269-d621b95b7352

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
