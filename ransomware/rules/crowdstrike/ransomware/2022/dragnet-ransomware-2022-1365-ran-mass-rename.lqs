// Dragnet [Ransomware]: dragnet-ransomware-2022-1365 — Mass File Rename (dataleak)
// Status: deprecated | Level: high | ID: 1745be5d-34a3-589f-9420-21e8959b166a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
