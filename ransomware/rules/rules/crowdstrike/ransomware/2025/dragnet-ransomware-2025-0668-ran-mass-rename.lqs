// Dragnet [Ransomware]: dragnet-ransomware-2025-0668 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: b647d909-cf69-5ab5-9ca7-05d344f05e96

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
