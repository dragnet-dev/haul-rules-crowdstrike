// Dragnet [Ransomware]: dragnet-ransomware-2024-2181 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: b3398fd9-0edc-529e-9d55-931ea054e8b5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
