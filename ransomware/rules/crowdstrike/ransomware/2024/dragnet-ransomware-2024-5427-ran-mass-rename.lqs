// Dragnet [Ransomware]: dragnet-ransomware-2024-5427 — Mass File Rename (handala)
// Status: experimental | Level: high | ID: 6c36d83e-e15c-5ba8-8e0f-195b6668e732

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
