// Dragnet [Ransomware]: dragnet-ransomware-2022-2323 — Mass File Rename (bianlian)
// Status: deprecated | Level: high | ID: c967ec4a-da8e-506f-9d53-9cc2bd5d6e30

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
