// Dragnet [Container]: dragnet-container-2026-2998 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 695e6cac-039e-53bc-b6b1-ceeda9e5f8d2

#event_simpleName=*
| (ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *ubuntu:12.04*)
| table([timestamp, ComputerName])
| limit(1000)
