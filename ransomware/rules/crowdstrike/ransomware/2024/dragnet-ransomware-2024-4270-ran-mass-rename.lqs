// Dragnet [Ransomware]: dragnet-ransomware-2024-4270 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: c98e8608-7f04-56c0-ab6d-e31c19e5b61d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
