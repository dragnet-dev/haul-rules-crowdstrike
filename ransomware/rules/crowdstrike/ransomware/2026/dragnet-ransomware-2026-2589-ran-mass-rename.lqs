// Dragnet [Ransomware]: dragnet-ransomware-2026-2589 — Mass File Rename (nightspire)
// Status: deprecated | Level: high | ID: e68608df-8731-51c9-b36b-cf21ed2dde1e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
