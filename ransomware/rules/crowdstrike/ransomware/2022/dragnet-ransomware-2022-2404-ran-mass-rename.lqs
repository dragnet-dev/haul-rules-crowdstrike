// Dragnet [Ransomware]: dragnet-ransomware-2022-2404 — Mass File Rename (cuba)
// Status: deprecated | Level: high | ID: b00aaebf-cde6-5bc7-a745-c2e4e7aff08e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
