// Dragnet [Container]: dragnet-container-2026-0528 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: b79f1415-13ef-5412-94dd-81f8ef1829fc

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *ubuntu:12.04*)
| table([timestamp, ComputerName])
| limit(1000)
