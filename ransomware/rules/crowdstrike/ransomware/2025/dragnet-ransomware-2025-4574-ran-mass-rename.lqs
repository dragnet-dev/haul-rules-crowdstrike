// Dragnet [Ransomware]: dragnet-ransomware-2025-4574 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: d63df274-0228-50d4-9815-83e025244b68

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
