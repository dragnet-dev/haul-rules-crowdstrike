// Dragnet [Ransomware]: dragnet-ransomware-2025-6772 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 42df8d3c-a53a-5f34-be6e-5b3e742cd447

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
