// Dragnet [Ransomware]: dragnet-ransomware-2024-1642 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 0aa322b4-7d18-5364-b501-b1365154e8c9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
