// Dragnet [Ransomware]: dragnet-ransomware-2023-2788 — Mass File Rename (malas)
// Status: experimental | Level: high | ID: 21c2b813-368d-5d14-94fc-e422ba42bceb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
