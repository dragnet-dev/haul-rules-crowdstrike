// Dragnet [Ransomware]: dragnet-ransomware-2025-3656 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 42d71700-2cb7-570b-ade8-11972b70aad7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
