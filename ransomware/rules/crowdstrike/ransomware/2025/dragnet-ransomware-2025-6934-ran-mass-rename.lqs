// Dragnet [Ransomware]: dragnet-ransomware-2025-6934 — Mass File Rename (play)
// Status: experimental | Level: high | ID: c1033bf1-4c53-5c4c-93b7-da5b88db429c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
