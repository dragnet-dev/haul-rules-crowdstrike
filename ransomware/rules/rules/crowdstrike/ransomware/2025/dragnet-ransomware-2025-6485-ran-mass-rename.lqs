// Dragnet [Ransomware]: dragnet-ransomware-2025-6485 — Mass File Rename (nightspire)
// Status: deprecated | Level: high | ID: eee93925-9d80-5733-afd7-9e9045d82ab0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
