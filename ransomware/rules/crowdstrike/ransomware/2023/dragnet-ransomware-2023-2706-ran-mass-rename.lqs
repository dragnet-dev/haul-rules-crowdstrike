// Dragnet [Ransomware]: dragnet-ransomware-2023-2706 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 25df6d3b-d2fe-5c75-a26d-8d61ae82b587

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
