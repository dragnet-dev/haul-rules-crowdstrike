// Dragnet [Ransomware]: dragnet-ransomware-2026-0824 — Mass File Rename (spacebears)
// Status: stable | Level: high | ID: 3f5eea6c-8e4c-519f-856c-0a045babc28d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
