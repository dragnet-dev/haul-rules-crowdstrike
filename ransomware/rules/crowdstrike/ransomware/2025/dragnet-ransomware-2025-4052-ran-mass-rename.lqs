// Dragnet [Ransomware]: dragnet-ransomware-2025-4052 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 78247e10-a4ac-5837-a612-98166d58d61f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
