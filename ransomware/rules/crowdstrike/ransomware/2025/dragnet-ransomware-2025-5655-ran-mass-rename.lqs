// Dragnet [Ransomware]: dragnet-ransomware-2025-5655 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: e73af077-582d-5b28-9a42-071aa1e79fba

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
