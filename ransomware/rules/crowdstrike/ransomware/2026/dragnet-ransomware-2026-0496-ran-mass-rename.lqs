// Dragnet [Ransomware]: dragnet-ransomware-2026-0496 — Mass File Rename (lockbit5)
// Status: stable | Level: high | ID: 5343525a-c8e5-5192-b5b2-170eafa5f530

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
