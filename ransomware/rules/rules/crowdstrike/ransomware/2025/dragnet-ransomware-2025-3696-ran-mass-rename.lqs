// Dragnet [Ransomware]: dragnet-ransomware-2025-3696 — Mass File Rename (coinbasecartel)
// Status: experimental | Level: high | ID: 637e6a29-4a88-5b9f-92bd-b18e5eddb9db

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
