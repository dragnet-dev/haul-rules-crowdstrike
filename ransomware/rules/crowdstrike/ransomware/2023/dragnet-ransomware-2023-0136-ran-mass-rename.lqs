// Dragnet [Ransomware]: dragnet-ransomware-2023-0136 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 05b16f1f-5928-5011-82fa-a12c44b664bb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
