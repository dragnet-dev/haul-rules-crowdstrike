// Dragnet [Ransomware]: dragnet-ransomware-2024-3875 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: abb27b2a-b627-5a29-9efa-b0327b233436

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
