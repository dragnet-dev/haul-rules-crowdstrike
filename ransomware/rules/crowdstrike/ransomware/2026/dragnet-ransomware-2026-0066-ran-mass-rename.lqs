// Dragnet [Ransomware]: dragnet-ransomware-2026-0066 — Mass File Rename (shinyhunters)
// Status: deprecated | Level: high | ID: ca37b79a-ae55-5481-a625-b87bbaece724

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
