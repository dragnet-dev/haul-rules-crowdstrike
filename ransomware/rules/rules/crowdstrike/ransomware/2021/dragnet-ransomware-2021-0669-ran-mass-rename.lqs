// Dragnet [Ransomware]: dragnet-ransomware-2021-0669 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 354e0d97-f201-5bbc-86ce-1a5b8af6a3e2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
