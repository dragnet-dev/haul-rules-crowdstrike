// Dragnet [Ransomware]: dragnet-ransomware-2025-4173 — Mass File Rename (kraken)
// Status: experimental | Level: high | ID: 20df2ed2-59e9-550f-bb1e-07601318975c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
