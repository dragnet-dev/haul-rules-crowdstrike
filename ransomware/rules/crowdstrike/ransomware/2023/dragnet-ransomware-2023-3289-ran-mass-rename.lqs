// Dragnet [Ransomware]: dragnet-ransomware-2023-3289 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: f1ab4e0b-1a51-5e09-95c0-328c258c9de4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
