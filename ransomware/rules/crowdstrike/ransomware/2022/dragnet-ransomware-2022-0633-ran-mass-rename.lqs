// Dragnet [Ransomware]: dragnet-ransomware-2022-0633 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 6e590812-8c6a-5f87-852f-bef1c3d527b8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
