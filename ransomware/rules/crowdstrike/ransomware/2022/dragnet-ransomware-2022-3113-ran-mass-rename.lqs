// Dragnet [Ransomware]: dragnet-ransomware-2022-3113 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 00d5f69f-9933-5dbd-a9ef-4d965ce67319

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
