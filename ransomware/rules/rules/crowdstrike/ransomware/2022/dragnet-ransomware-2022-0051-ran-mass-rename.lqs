// Dragnet [Ransomware]: dragnet-ransomware-2022-0051 — Mass File Rename (everest)
// Status: deprecated | Level: high | ID: 66892f03-667d-50ff-8077-5e28e3909ace

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
