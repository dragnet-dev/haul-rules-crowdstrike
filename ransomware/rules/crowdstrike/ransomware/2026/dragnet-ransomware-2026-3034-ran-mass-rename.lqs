// Dragnet [Ransomware]: dragnet-ransomware-2026-3034 — Mass File Rename (safepay)
// Status: stable | Level: high | ID: bbf93b36-3a5a-5beb-bfb9-b0a1c903731a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
