// Dragnet [Ransomware]: dragnet-ransomware-2024-1851 — Mass File Rename (knight)
// Status: experimental | Level: high | ID: 3a168b8c-2b44-5d75-8b0f-0ef122f11542

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
