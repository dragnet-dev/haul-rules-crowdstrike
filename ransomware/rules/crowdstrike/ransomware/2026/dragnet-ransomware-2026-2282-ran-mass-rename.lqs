// Dragnet [Ransomware]: dragnet-ransomware-2026-2282 — Mass File Rename (krybit)
// Status: stable | Level: high | ID: 225039de-9381-5164-952f-fe975db1f5ba

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
