// Dragnet [Ransomware]: dragnet-ransomware-2023-2079 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: b3fa0c44-ea6d-5c8f-ae61-d77e5def53f0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
