// Dragnet [Ransomware]: dragnet-ransomware-2024-1309 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 4c742de7-f182-55ed-bd50-10bc07fff31c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
