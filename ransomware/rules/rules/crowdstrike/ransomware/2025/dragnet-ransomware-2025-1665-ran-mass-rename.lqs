// Dragnet [Ransomware]: dragnet-ransomware-2025-1665 — Mass File Rename (kryptos)
// Status: deprecated | Level: high | ID: 322458f1-d16a-593f-8088-60a416f843e4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
