// Dragnet [Ransomware]: dragnet-ransomware-2026-2582 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: c1d91443-abd3-545a-8d2b-5701d1a74168

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
