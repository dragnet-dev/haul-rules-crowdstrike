// Dragnet [Ransomware]: dragnet-ransomware-2024-2697 — Mass File Rename (chort)
// Status: deprecated | Level: high | ID: f532db03-7ab4-5242-9d5c-5fa0b62b76e8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
