// Dragnet [Ransomware]: dragnet-ransomware-2025-0488 — Mass File Rename (pear)
// Status: experimental | Level: high | ID: 21c6f48b-021b-55af-81de-9574b281ebfc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
