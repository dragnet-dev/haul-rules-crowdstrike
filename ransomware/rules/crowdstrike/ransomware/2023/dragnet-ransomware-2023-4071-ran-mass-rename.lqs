// Dragnet [Ransomware]: dragnet-ransomware-2023-4071 — Mass File Rename (rancoz)
// Status: experimental | Level: high | ID: 0e3c8d6a-6fb4-53e5-945c-eab38f0d7915

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
