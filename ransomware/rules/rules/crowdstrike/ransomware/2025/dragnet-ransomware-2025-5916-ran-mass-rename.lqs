// Dragnet [Ransomware]: dragnet-ransomware-2025-5916 — Mass File Rename (coinbasecartel)
// Status: experimental | Level: high | ID: f90fc1c6-45c6-567c-97cd-c273e730c076

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
