// Dragnet [Ransomware]: dragnet-ransomware-2025-3993 — Mass File Rename (play)
// Status: experimental | Level: high | ID: e45204ce-cf34-52c4-9772-5f9a0d4eaff1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
