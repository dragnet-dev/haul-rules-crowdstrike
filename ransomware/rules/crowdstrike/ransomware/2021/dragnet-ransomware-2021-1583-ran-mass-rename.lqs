// Dragnet [Ransomware]: dragnet-ransomware-2021-1583 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 0a45ef3a-25e1-567e-a096-4cf55a402c11

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
