// Dragnet [Ransomware]: dragnet-ransomware-2024-6038 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 9a7607f9-1480-5764-921a-dd33eadee801

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
