// Dragnet [Ransomware]: dragnet-ransomware-2023-0442 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 4d11135d-a705-5826-90f1-83ba2751f6a4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
