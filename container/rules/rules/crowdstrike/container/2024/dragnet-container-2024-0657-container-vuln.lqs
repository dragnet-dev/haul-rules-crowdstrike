// Dragnet [Container]: dragnet-container-2024-0657 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: e2dbe357-2aae-5fe5-9bec-44d0744fd8f7

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:9*)
| table([timestamp, ComputerName])
| limit(1000)
