// Dragnet [Ransomware]: dragnet-ransomware-2023-2655 — Mass File Rename (snatch)
// Status: experimental | Level: high | ID: 65751c48-ff85-57cb-bb1a-b4aacabd93c8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
