// Dragnet [Ransomware]: dragnet-ransomware-2020-0227 — Mass File Rename (ragnarlocker)
// Status: deprecated | Level: high | ID: 48bd9e25-4cab-596c-811d-fac01bb14d40

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
