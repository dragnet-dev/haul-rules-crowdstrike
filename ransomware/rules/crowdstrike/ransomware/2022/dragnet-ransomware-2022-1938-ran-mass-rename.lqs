// Dragnet [Ransomware]: dragnet-ransomware-2022-1938 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 0fa86b5c-8d63-5c0e-9196-e78c179ed706

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
