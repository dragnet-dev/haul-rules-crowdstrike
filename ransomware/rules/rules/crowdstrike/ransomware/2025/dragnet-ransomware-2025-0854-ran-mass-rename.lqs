// Dragnet [Ransomware]: dragnet-ransomware-2025-0854 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: b2d62ad5-1098-5b5c-a776-c3527f263b56

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
