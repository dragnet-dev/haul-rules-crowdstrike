// Dragnet [Ransomware]: dragnet-ransomware-2023-1858 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 5e34c43a-3abb-5b51-b6d6-e95bb077d400

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
