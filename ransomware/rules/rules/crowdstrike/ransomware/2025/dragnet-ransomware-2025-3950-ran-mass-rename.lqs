// Dragnet [Ransomware]: dragnet-ransomware-2025-3950 — Mass File Rename (nova)
// Status: experimental | Level: high | ID: a9ed7e0a-8a1c-539e-8131-c5a0c10bd6d0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
