// Dragnet [Ransomware]: dragnet-ransomware-2025-1717 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 6aaae52a-47ae-54e9-99be-8fd69f7a4d0d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
