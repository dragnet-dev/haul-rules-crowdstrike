// Dragnet [Ransomware]: dragnet-ransomware-2025-4569 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: f30800de-4c1e-5194-9c1b-d1b19e447b49

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
