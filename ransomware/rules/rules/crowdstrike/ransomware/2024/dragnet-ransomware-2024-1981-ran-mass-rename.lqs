// Dragnet [Ransomware]: dragnet-ransomware-2024-1981 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: adbfebb7-e744-5a1f-9b10-753b1664a702

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
