// Dragnet [Ransomware]: dragnet-ransomware-2024-2059 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: eca5a849-14c1-54d0-8597-8629bd0dda73

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
