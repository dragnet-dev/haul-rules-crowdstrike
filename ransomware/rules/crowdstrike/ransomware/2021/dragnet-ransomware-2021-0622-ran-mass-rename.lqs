// Dragnet [Ransomware]: dragnet-ransomware-2021-0622 — Mass File Rename (blackmatter)
// Status: deprecated | Level: high | ID: da53f6ee-dc12-589e-96ef-e39146930bfb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
