// Dragnet [Ransomware]: dragnet-ransomware-2026-1735 — Mass File Rename (payload)
// Status: stable | Level: high | ID: 83beb722-b8e1-5141-959f-3657bcd12819

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
