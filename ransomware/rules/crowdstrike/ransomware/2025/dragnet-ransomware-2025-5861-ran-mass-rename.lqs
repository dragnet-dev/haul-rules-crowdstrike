// Dragnet [Ransomware]: dragnet-ransomware-2025-5861 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 4fe478b1-3c8a-531e-a3ad-39bd6b9d368d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
