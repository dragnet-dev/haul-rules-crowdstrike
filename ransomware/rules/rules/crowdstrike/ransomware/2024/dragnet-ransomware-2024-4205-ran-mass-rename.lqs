// Dragnet [Ransomware]: dragnet-ransomware-2024-4205 — Mass File Rename (sarcoma)
// Status: deprecated | Level: high | ID: 0039622a-b1a9-5fff-a93d-5be82861d6ce

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
