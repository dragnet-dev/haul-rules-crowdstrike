// Dragnet [Ransomware]: dragnet-ransomware-2023-2786 — Mass File Rename (malas)
// Status: experimental | Level: high | ID: 3c3bf8b8-3bc8-5e88-bdd8-7a21e0f7e0e7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
