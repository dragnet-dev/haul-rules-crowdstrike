// Dragnet [Ransomware]: dragnet-ransomware-2025-3275 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 925f5012-064e-54e5-ad3f-dba9030aa836

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
