// Dragnet [Ransomware]: dragnet-ransomware-2021-0068 — Mass File Rename (ransomexx)
// Status: deprecated | Level: high | ID: d545a305-e5f7-528d-8213-406cf63f6f5d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
