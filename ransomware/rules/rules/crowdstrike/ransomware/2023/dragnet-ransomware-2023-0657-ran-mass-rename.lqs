// Dragnet [Ransomware]: dragnet-ransomware-2023-0657 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 3a9a9372-fdd8-5bd4-b604-844a66ae226e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
