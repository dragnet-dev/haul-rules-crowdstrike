// Dragnet [Ransomware]: dragnet-ransomware-2024-3597 — Mass File Rename (arcusmedia)
// Status: experimental | Level: high | ID: da2d3ef3-45fc-5fd8-ace7-7a9a1127c7a3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
