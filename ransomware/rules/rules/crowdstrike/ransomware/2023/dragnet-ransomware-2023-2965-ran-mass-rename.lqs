// Dragnet [Ransomware]: dragnet-ransomware-2023-2965 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 153d83c1-17fe-5ac3-b50f-af3f89ed14ca

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
