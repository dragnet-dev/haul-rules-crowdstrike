// Dragnet [Ransomware]: dragnet-ransomware-2023-1550 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 109b6db7-aa70-5624-b766-4af2aa79aab7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
