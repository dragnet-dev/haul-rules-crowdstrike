// Dragnet [Ransomware]: dragnet-ransomware-2025-6807 — Mass File Rename (play)
// Status: experimental | Level: high | ID: c1f7b44d-d9fb-5f90-92de-63441ce558c3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
