// Dragnet [Ransomware]: dragnet-ransomware-2023-3619 — Mass File Rename (donutleaks)
// Status: experimental | Level: high | ID: 87a18572-1de9-5afa-8607-34c2df3c767d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
