// Dragnet [Ransomware]: dragnet-ransomware-2021-1290 — Mass File Rename (midas)
// Status: deprecated | Level: high | ID: 0a3abf1c-ca2e-5896-96d9-65f835049081

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
