// Dragnet [Ransomware]: dragnet-ransomware-2022-0047 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 3af753d0-ea24-5564-b756-7ca2ef1a7348

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
