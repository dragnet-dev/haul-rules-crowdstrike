// Dragnet [Container]: dragnet-container-2026-2109 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: e8d37f9f-7b3d-5571-8384-b2cf0ff6b2ea

#event_simpleName=*
| (ImageFileName = *amazonlinux:1* OR ImageFileName = *chainguard:* OR ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10*)
| table([timestamp, ComputerName])
| limit(1000)
