// Dragnet [Ransomware]: dragnet-ransomware-2025-6086 — Mass File Rename (lockbit5)
// Status: test | Level: high | ID: 801ccd5b-a59b-5b4d-bfbd-0246762d22f8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
