// Dragnet [Ransomware]: dragnet-ransomware-2023-3049 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 3c271e5f-f0cf-5baa-90a2-8a0ab0e59446

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
