// Dragnet [Ransomware]: dragnet-ransomware-2022-2877 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: e9ddae18-5e7d-5c92-b533-b8d415e8ba28

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
