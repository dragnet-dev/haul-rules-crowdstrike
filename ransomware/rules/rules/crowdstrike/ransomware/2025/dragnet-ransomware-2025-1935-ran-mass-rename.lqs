// Dragnet [Ransomware]: dragnet-ransomware-2025-1935 — Mass File Rename (ralord)
// Status: experimental | Level: high | ID: 33ac28d8-cdd9-579f-97c7-191fda346e24

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
