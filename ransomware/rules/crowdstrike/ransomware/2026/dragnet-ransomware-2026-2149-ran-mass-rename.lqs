// Dragnet [Ransomware]: dragnet-ransomware-2026-2149 — Mass File Rename (payload)
// Status: stable | Level: high | ID: e9d99727-f63b-53fb-9d17-65a31447853c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
