// Dragnet [Ransomware]: dragnet-ransomware-2024-5740 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: 7d2de82c-86cf-5b8d-ad48-ce2eec6b23e5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
