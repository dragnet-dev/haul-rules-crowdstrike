// Dragnet [Ransomware]: dragnet-ransomware-2024-2516 — Mass File Rename (helldown)
// Status: experimental | Level: high | ID: a075800d-8a05-562d-8cd9-d1186c271a03

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
