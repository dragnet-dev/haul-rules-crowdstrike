// Dragnet [Ransomware]: dragnet-ransomware-2020-0195 — Mass File Rename (ragnarlocker)
// Status: deprecated | Level: high | ID: 8b0db3d9-6013-5ffe-a1b3-8b9807b41205

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
