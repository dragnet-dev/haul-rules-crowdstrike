// Dragnet [Ransomware]: dragnet-ransomware-2025-7655 — Mass File Rename (nightspire)
// Status: deprecated | Level: high | ID: 8a78468c-9b97-520d-873b-7a1999909df2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
