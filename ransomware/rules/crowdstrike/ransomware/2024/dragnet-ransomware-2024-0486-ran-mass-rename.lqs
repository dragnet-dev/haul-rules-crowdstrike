// Dragnet [Ransomware]: dragnet-ransomware-2024-0486 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 83133668-749e-5267-a58a-d2cefee1a1a8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
