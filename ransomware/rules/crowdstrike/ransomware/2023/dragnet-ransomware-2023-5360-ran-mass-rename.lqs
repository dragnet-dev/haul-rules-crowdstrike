// Dragnet [Ransomware]: dragnet-ransomware-2023-5360 — Mass File Rename (play)
// Status: experimental | Level: high | ID: a8a3f39e-9376-5aed-b7da-b562d19cea23

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
