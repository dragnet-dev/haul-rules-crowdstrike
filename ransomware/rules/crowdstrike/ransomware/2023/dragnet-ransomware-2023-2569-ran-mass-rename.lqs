// Dragnet [Ransomware]: dragnet-ransomware-2023-2569 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: d2d8b16a-de60-59e3-9063-b3bd473dfea1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
