// Dragnet [Ransomware]: dragnet-ransomware-2024-3020 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 5457f333-56a7-5eb3-bd35-b59278897667

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
