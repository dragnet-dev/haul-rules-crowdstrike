// Dragnet [Ransomware]: dragnet-ransomware-2023-4099 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 9e3ac7a6-c5e7-550d-9370-c8f70b4370ce

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
