// Dragnet [Ransomware]: dragnet-ransomware-2024-0591 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: eb20a2d9-381d-5367-8125-b9cf4b6780da

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
