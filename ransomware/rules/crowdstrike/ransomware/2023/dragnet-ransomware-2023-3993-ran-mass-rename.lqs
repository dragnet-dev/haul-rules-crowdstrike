// Dragnet [Ransomware]: dragnet-ransomware-2023-3993 — Mass File Rename (dunghill)
// Status: experimental | Level: high | ID: 578600e2-8539-55af-9474-92d5244578e0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
