// Dragnet [Ransomware]: dragnet-ransomware-2024-3810 — Mass File Rename (monti)
// Status: experimental | Level: high | ID: e70d787e-4e75-5caa-8cd2-dfc9514225b4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
