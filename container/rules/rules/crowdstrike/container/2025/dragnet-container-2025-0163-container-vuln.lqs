// Dragnet [Container]: dragnet-container-2025-0163 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 8ba32771-d29b-5ac2-8cd9-d79668b4b19f

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
