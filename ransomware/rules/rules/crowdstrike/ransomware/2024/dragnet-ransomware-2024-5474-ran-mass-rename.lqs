// Dragnet [Ransomware]: dragnet-ransomware-2024-5474 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 65114dad-4c6e-5c1f-a618-d10990c63468

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
