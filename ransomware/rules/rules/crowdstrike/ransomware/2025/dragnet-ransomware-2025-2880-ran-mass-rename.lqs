// Dragnet [Ransomware]: dragnet-ransomware-2025-2880 — Mass File Rename (cicada3301)
// Status: experimental | Level: high | ID: 36591aef-ec32-5627-968d-2e6f7e8f0cf6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
