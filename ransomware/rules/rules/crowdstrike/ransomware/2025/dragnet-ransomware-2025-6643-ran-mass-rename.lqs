// Dragnet [Ransomware]: dragnet-ransomware-2025-6643 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: b6069e63-9186-5fc0-9738-949748a675fc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
