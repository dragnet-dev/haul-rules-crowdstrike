// Dragnet [Ransomware]: dragnet-ransomware-2024-1012 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 235930fc-a521-51df-999d-2da14858689b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
