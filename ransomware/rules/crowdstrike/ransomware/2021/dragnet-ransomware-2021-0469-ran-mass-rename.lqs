// Dragnet [Ransomware]: dragnet-ransomware-2021-0469 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: bf6b9372-de66-5444-959f-8730df16fe1c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
