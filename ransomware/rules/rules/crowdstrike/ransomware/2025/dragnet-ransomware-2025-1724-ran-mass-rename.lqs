// Dragnet [Ransomware]: dragnet-ransomware-2025-1724 — Mass File Rename (termite)
// Status: experimental | Level: high | ID: 51278556-150e-507c-be02-5fab62bd1c58

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
