// Dragnet [Ransomware]: dragnet-ransomware-2025-3855 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 410a9a5b-d1bf-5fdf-b55c-184acae726c7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
