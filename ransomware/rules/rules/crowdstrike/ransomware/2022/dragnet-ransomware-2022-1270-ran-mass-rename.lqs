// Dragnet [Ransomware]: dragnet-ransomware-2022-1270 — Mass File Rename (donutleaks)
// Status: experimental | Level: high | ID: 3ace3861-ea94-5423-b624-d0b9b0fbfc30

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
