// Dragnet [Ransomware]: dragnet-ransomware-2021-0457 — Mass File Rename (avaddon)
// Status: deprecated | Level: high | ID: 6b38fec2-1023-5781-8ba7-a61e174c6f22

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
