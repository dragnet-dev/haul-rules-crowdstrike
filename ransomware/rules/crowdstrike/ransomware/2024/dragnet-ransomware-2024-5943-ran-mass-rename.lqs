// Dragnet [Ransomware]: dragnet-ransomware-2024-5943 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: eac9cfe3-421f-5e4b-a968-1e9d10033fe7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
