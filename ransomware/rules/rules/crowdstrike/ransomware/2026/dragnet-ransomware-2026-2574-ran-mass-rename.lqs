// Dragnet [Ransomware]: dragnet-ransomware-2026-2574 — Mass File Rename (nightspire)
// Status: deprecated | Level: high | ID: 0ea4b089-842e-51a2-b3be-bf33f7543b45

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
