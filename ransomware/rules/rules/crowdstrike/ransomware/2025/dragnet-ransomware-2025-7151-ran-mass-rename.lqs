// Dragnet [Ransomware]: dragnet-ransomware-2025-7151 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 0c6ae897-7639-5ab8-b17c-d4c203bd5487

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
