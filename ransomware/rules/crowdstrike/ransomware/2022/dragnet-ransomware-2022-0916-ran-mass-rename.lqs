// Dragnet [Ransomware]: dragnet-ransomware-2022-0916 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 71767caa-964f-535f-a562-d8bd7e94ce9b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
