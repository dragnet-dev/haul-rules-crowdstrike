// Dragnet [Ransomware]: dragnet-ransomware-2024-5834 — Mass File Rename (argonauts)
// Status: experimental | Level: high | ID: 8a6a9865-6298-563e-85c5-873ad946725f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
