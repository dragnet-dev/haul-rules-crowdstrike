// Dragnet [Ransomware]: dragnet-ransomware-2021-0016 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: f2a65976-7030-51da-b889-01e30e7d1048

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
