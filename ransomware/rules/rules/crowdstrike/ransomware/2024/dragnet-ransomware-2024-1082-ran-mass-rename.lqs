// Dragnet [Ransomware]: dragnet-ransomware-2024-1082 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: 2f37a2d4-fe30-5826-903d-6d8acc5ba3d1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
