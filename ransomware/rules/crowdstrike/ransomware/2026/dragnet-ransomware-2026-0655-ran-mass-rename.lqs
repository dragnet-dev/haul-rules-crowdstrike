// Dragnet [Ransomware]: dragnet-ransomware-2026-0655 — Mass File Rename (lockbit5)
// Status: stable | Level: high | ID: 21f7f7a5-e97c-52df-ae79-3ccba82f7673

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
