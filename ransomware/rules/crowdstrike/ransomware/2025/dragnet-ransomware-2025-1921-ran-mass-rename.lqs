// Dragnet [Ransomware]: dragnet-ransomware-2025-1921 — Mass File Rename (lockbit5)
// Status: test | Level: high | ID: e2cf6c4b-0e03-572e-9469-402c50401e52

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
