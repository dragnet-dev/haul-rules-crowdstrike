// Dragnet [Ransomware]: dragnet-ransomware-2024-3282 — Mass File Rename (trinity)
// Status: experimental | Level: high | ID: a83eac2c-7cfc-51f1-838b-e6db25bc7250

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
