// Dragnet [Ransomware]: dragnet-ransomware-2024-5634 — Mass File Rename (apos)
// Status: experimental | Level: high | ID: 3f15cf65-9000-5f6b-9dc1-ecb467623fc8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
