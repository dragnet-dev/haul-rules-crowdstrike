// Dragnet [Ransomware]: dragnet-ransomware-2026-0873 — Mass File Rename (lockbit5)
// Status: stable | Level: high | ID: 59f66d31-e74c-5e2b-ab97-4af7dc81df2b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
