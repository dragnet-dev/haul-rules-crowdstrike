// Dragnet [Container]: dragnet-container-2026-0982 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 0a1480d1-5060-52ab-833c-a47dc40a4e55

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:5*)
| table([timestamp, ComputerName])
| limit(1000)
