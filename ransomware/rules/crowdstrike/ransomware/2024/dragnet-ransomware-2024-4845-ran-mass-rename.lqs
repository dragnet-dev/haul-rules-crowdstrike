// Dragnet [Ransomware]: dragnet-ransomware-2024-4845 — Mass File Rename (nitrogen)
// Status: experimental | Level: high | ID: 286d20c5-fba9-50c7-9846-3c9a6cfdf85b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
