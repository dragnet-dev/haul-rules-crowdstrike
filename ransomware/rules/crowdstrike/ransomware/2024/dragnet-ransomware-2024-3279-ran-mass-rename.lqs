// Dragnet [Ransomware]: dragnet-ransomware-2024-3279 — Mass File Rename (dragonforce)
// Status: deprecated | Level: high | ID: dc7d6b18-fc81-509b-8a6b-c5c123a95b7e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
