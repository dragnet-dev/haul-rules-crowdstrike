// Dragnet [Ransomware]: dragnet-ransomware-2024-4950 — Mass File Rename (rhysida)
// Status: deprecated | Level: high | ID: bf956fdc-7c4c-5135-80a2-2b1df0d927f9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
