// Dragnet [Ransomware]: dragnet-ransomware-2022-1148 — Mass File Rename (blackbasta)
// Status: deprecated | Level: high | ID: a3842c40-da9d-51f2-a002-5d8564a4dc2d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
