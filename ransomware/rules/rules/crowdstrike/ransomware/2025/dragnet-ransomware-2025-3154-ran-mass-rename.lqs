// Dragnet [Ransomware]: dragnet-ransomware-2025-3154 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: 5ed87d0a-4bd3-5afd-9544-ae218d896428

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
