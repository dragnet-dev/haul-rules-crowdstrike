// Dragnet [Ransomware]: dragnet-ransomware-2024-0504 — Mass File Rename (apt73)
// Status: experimental | Level: high | ID: 714c3322-80a0-5a8c-a1ef-17d1747f5134

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
