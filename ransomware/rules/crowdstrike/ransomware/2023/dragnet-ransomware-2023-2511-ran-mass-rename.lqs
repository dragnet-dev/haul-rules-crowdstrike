// Dragnet [Ransomware]: dragnet-ransomware-2023-2511 — Mass File Rename (play)
// Status: experimental | Level: high | ID: f4ed2d91-d591-5d65-930b-2488ad443e06

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
