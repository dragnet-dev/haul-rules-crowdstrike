// Dragnet [Ransomware]: dragnet-ransomware-2023-2455 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: ab9fcca1-72a1-589f-b6a3-b124d2b5c2b8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
