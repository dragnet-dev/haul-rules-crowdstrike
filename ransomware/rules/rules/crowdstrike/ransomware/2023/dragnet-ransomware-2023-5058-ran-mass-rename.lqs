// Dragnet [Ransomware]: dragnet-ransomware-2023-5058 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 6152ba8c-0a40-5cec-b4f2-248b2d729334

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
