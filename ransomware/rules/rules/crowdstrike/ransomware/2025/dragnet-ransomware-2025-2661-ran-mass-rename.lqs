// Dragnet [Ransomware]: dragnet-ransomware-2025-2661 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: b063babe-d59f-579b-981d-fa8e825cb364

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
