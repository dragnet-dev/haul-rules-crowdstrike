// Dragnet [Ransomware]: dragnet-ransomware-2025-3680 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 30ac09e3-02b1-52df-8ae8-5fcd26e42d8a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
