// Dragnet [Ransomware]: dragnet-ransomware-2022-1408 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 2f12cae1-a067-5696-8606-b4f833a4e94b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
