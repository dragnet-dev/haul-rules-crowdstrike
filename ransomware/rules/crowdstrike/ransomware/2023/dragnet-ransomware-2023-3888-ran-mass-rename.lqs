// Dragnet [Ransomware]: dragnet-ransomware-2023-3888 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 970faf3c-b8fc-547c-ba54-4c8992b8ec7f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
