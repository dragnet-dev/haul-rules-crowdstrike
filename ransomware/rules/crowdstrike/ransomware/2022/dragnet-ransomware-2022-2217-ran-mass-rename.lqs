// Dragnet [Ransomware]: dragnet-ransomware-2022-2217 — Mass File Rename (royal)
// Status: deprecated | Level: high | ID: 0cef73d5-039b-5a85-8b86-4431f947d6e5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
