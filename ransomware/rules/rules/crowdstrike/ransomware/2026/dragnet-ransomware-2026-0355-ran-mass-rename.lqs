// Dragnet [Ransomware]: dragnet-ransomware-2026-0355 — Mass File Rename (direwolf)
// Status: test | Level: high | ID: fbc99446-214c-5dd4-a287-3ce6f439dd59

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
