// Dragnet [Ransomware]: dragnet-ransomware-2025-6583 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: ea16901b-879d-59a8-b3bb-422fd46fbc1e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
