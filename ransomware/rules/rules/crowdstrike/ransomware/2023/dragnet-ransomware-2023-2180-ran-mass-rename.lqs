// Dragnet [Ransomware]: dragnet-ransomware-2023-2180 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 4f86c18b-0690-5c0a-88d3-75d2ddbb796e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
