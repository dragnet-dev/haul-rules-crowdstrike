// Dragnet [Ransomware]: dragnet-ransomware-2024-5006 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: a054a58b-7f0b-5af8-aaa2-a2d48de20809

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
