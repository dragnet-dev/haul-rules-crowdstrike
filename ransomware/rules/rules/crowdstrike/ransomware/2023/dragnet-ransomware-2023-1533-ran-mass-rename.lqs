// Dragnet [Ransomware]: dragnet-ransomware-2023-1533 — Mass File Rename (nokoyawa)
// Status: experimental | Level: high | ID: 6c872e88-6023-5d2a-a2f9-061d14ff8f18

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
