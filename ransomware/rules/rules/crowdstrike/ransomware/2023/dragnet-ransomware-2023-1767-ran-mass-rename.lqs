// Dragnet [Ransomware]: dragnet-ransomware-2023-1767 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: a4d758f7-d3db-55a7-80e5-fa4113bfcbc1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
