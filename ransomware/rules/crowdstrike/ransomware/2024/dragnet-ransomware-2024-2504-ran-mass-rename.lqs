// Dragnet [Ransomware]: dragnet-ransomware-2024-2504 — Mass File Rename (play)
// Status: experimental | Level: high | ID: d410d8a6-f45f-5d9a-a745-ad722cdbdc0f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
