// Dragnet [Ransomware]: dragnet-ransomware-2021-0583 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 34aec07b-77dd-58d3-b752-da1aa7303b1f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
