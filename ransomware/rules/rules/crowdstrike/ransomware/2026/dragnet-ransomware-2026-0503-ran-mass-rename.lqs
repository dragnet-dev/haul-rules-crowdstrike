// Dragnet [Ransomware]: dragnet-ransomware-2026-0503 — Mass File Rename (worldleaks)
// Status: stable | Level: high | ID: 8dc90615-1c0c-5044-8ca4-0b9be9059bb1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
