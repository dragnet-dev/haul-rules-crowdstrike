// Dragnet [Ransomware]: dragnet-ransomware-2023-1817 — Mass File Rename (rhysida)
// Status: experimental | Level: high | ID: a0ea01bd-7194-59d3-b6d0-a9c978afc854

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
