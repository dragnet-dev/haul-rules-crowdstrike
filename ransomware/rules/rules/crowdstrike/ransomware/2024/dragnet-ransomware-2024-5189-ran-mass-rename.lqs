// Dragnet [Ransomware]: dragnet-ransomware-2024-5189 — Mass File Rename (underground)
// Status: experimental | Level: high | ID: d2b0246b-9291-5b51-b455-f0f2c73aa5f1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
