// Dragnet [Ransomware]: dragnet-ransomware-2021-1057 — Mass File Rename (avaddon)
// Status: deprecated | Level: high | ID: e233afae-92b6-5c0d-921e-8bc636848f5a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
