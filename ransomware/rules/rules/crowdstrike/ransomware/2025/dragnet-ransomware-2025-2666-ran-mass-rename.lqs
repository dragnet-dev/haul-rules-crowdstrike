// Dragnet [Ransomware]: dragnet-ransomware-2025-2666 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 50d22d58-a63d-576b-8bde-6fbd0d896f0d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
