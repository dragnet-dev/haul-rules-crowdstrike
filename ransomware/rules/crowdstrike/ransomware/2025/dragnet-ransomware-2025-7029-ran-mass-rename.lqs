// Dragnet [Ransomware]: dragnet-ransomware-2025-7029 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: e75f3cb6-9dd9-5b75-960d-773aa76f8011

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
