// Dragnet [Ransomware]: dragnet-ransomware-2024-3040 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 7a0222d1-ce4f-5b2a-be02-2a8bec0df496

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
