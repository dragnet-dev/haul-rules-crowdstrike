// Dragnet [Ransomware]: dragnet-ransomware-2022-0300 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: e23a0e3c-47b9-5483-b054-f24078b9f94a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
