// Dragnet [Ransomware]: dragnet-ransomware-2024-5355 — Mass File Rename (mallox)
// Status: deprecated | Level: high | ID: 0f37aab4-10b1-5101-90e2-f0b51b3accb9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
