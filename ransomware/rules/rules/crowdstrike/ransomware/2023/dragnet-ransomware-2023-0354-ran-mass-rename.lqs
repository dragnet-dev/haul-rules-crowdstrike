// Dragnet [Ransomware]: dragnet-ransomware-2023-0354 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 67296f61-c145-5da4-a1d8-61a7b7e836fb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
