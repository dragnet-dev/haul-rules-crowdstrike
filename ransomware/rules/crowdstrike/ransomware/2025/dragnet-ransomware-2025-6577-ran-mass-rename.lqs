// Dragnet [Ransomware]: dragnet-ransomware-2025-6577 — Mass File Rename (securotrop)
// Status: experimental | Level: high | ID: 0520019a-f44f-5f37-89b2-6d5c8a1c0b99

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
