// Dragnet [Ransomware]: dragnet-ransomware-2022-2172 — Mass File Rename (midas)
// Status: deprecated | Level: high | ID: 1727e656-8a7b-500c-83cd-7deb2ed2b640

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
