// Dragnet [Ransomware]: dragnet-ransomware-2024-2308 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: b07d1f41-9654-5a92-ba03-deb46e5501c0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
