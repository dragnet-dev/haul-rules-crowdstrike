// Dragnet [Ransomware]: dragnet-ransomware-2025-6660 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: c44baaa3-327f-5208-b772-915b19d19d17

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
