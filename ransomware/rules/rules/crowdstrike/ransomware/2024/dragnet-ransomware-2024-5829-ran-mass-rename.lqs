// Dragnet [Ransomware]: dragnet-ransomware-2024-5829 — Mass File Rename (darkvault)
// Status: experimental | Level: high | ID: f4719363-8fbf-5594-b944-8b613425e8f7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
