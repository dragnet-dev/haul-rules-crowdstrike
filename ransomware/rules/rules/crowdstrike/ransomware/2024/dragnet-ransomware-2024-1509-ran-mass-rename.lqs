// Dragnet [Ransomware]: dragnet-ransomware-2024-1509 — Mass File Rename (alphalocker)
// Status: experimental | Level: high | ID: f43b1138-7f30-5164-8aa1-d1409e4ef5a4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
