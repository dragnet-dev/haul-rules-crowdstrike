// Dragnet [Ransomware]: dragnet-ransomware-2024-2830 — Mass File Rename (arcusmedia)
// Status: experimental | Level: high | ID: 9802cda1-c075-57f1-a552-a3e65e13d369

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
