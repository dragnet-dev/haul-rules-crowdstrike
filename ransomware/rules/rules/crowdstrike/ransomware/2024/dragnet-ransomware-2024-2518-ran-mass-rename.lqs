// Dragnet [Ransomware]: dragnet-ransomware-2024-2518 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 6c26aadc-6d70-5df8-9cad-4cf94c3c4927

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
