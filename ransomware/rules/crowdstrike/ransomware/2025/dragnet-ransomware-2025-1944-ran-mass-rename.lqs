// Dragnet [Ransomware]: dragnet-ransomware-2025-1944 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 2219951d-93eb-5151-ad69-d3835bcb9efd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
