// Dragnet [Ransomware]: dragnet-ransomware-2022-3149 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: c01c7a08-b2fc-56dc-b588-e8338e057755

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
