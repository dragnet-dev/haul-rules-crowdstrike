// Dragnet [Ransomware]: dragnet-ransomware-2024-2802 — Mass File Rename (blackout)
// Status: experimental | Level: high | ID: 22e8e5fe-b3fb-59ca-80d3-9acbdb6d5fcc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
