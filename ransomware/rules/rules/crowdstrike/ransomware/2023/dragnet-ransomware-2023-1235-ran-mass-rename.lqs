// Dragnet [Ransomware]: dragnet-ransomware-2023-1235 — Mass File Rename (knight)
// Status: experimental | Level: high | ID: e8a97043-7427-554e-89a1-9937396569fc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
