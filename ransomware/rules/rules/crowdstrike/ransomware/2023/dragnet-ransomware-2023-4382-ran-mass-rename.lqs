// Dragnet [Ransomware]: dragnet-ransomware-2023-4382 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 649aa847-e904-516e-9336-831e3fff41b0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
