// Dragnet [Ransomware]: dragnet-ransomware-2025-2511 — Mass File Rename (play)
// Status: experimental | Level: high | ID: b66aec14-2e71-50fc-a0d4-8f3213231464

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
