// Dragnet [Ransomware]: dragnet-ransomware-2023-2561 — Mass File Rename (noescape)
// Status: experimental | Level: high | ID: c6150d90-e6e1-57eb-98d9-e67a6dad339a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
