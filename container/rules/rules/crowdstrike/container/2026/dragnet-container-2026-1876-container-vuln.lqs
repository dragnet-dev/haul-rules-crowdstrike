// Dragnet [Container]: dragnet-container-2026-1876 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: f58009b8-42f1-5325-a7ff-37e6c7f03e50

#event_simpleName=*
| (ImageFileName = *chainguard:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
