// Dragnet [Ransomware]: dragnet-ransomware-2025-7331 — Mass File Rename (payoutsking)
// Status: deprecated | Level: high | ID: 869f26ac-32fa-5c29-b335-14f2b1f2f855

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
