// Dragnet [Ransomware]: dragnet-ransomware-2023-4714 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 7bc50f55-014d-52a7-a2cb-42cc1cb82c2d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
