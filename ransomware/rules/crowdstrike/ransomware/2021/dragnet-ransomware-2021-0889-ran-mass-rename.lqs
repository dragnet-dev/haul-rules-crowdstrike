// Dragnet [Ransomware]: dragnet-ransomware-2021-0889 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: ff181c16-1bc4-5a2c-9b95-5263fdddfd97

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
