// Dragnet [Ransomware]: dragnet-ransomware-2025-3602 — Mass File Rename (flocker)
// Status: experimental | Level: high | ID: c30d5ef4-7013-5fbb-b873-28ed868210e9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
