// Dragnet [Ransomware]: dragnet-ransomware-2024-5603 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 559d12da-f865-56e2-aa49-1428524b938a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
