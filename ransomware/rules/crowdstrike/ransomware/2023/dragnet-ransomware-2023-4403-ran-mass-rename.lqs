// Dragnet [Ransomware]: dragnet-ransomware-2023-4403 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 5ce40ad9-a3af-507c-bf3a-1976a5e438b2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
