// Dragnet [Container]: dragnet-container-2026-2914 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 3a493979-1515-58cc-82bf-b940e0ec1754

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:5*)
| table([timestamp, ComputerName])
| limit(1000)
