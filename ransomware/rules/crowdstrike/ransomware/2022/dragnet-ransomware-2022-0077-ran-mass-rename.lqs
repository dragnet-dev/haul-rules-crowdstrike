// Dragnet [Ransomware]: dragnet-ransomware-2022-0077 — Mass File Rename (onyx)
// Status: deprecated | Level: high | ID: 4c06c51e-4fbc-528e-b19f-632dcebf955a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
