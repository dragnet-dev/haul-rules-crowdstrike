// Dragnet [Ransomware]: dragnet-ransomware-2025-5780 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 45983422-d0e5-5f53-bc9b-eab9a6d85862

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
