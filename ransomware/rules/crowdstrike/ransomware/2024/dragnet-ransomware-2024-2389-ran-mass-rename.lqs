// Dragnet [Ransomware]: dragnet-ransomware-2024-2389 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 5e7cb6b0-cdfe-5251-ada2-5648bcae46d7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
