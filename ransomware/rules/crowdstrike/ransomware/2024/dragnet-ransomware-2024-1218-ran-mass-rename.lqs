// Dragnet [Ransomware]: dragnet-ransomware-2024-1218 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: cb14b996-e861-5cdf-a974-3b1cbd40532d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
