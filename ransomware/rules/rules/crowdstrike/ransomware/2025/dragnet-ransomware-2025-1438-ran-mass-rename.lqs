// Dragnet [Ransomware]: dragnet-ransomware-2025-1438 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 22ee2a8f-4e03-551a-9aea-fe20a03fc99f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
