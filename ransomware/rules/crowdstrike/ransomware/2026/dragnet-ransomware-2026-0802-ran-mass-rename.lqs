// Dragnet [Ransomware]: dragnet-ransomware-2026-0802 — Mass File Rename (SilentRansomGroup)
// Status: deprecated | Level: high | ID: 7f9b5f53-239d-5f17-9b38-684cc3e4f498

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
