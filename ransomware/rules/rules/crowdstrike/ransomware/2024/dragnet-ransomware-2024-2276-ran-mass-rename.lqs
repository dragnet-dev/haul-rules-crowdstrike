// Dragnet [Ransomware]: dragnet-ransomware-2024-2276 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 86a31889-7d7c-5a1b-ae6b-ed7a776d07e3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
