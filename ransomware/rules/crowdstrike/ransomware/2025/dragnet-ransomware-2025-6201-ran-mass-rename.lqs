// Dragnet [Ransomware]: dragnet-ransomware-2025-6201 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: 1db45628-7164-50ff-8a7f-1e2e05533e40

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
