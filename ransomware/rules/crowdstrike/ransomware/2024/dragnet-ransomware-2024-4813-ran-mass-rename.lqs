// Dragnet [Ransomware]: dragnet-ransomware-2024-4813 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: f439e1d7-efa2-5749-b41b-2f9ebaef8978

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
