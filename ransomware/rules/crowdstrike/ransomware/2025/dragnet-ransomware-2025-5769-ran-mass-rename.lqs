// Dragnet [Ransomware]: dragnet-ransomware-2025-5769 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 69aa0afc-dfe2-5d56-83ec-965d5d3521eb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
