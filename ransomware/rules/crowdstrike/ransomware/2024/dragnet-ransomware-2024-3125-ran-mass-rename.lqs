// Dragnet [Ransomware]: dragnet-ransomware-2024-3125 — Mass File Rename (lockbit5)
// Status: experimental | Level: high | ID: 2ab221ae-3edb-5878-8dd0-fb578546b190

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
