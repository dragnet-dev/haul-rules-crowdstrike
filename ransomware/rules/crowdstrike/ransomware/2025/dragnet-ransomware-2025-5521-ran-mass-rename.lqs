// Dragnet [Ransomware]: dragnet-ransomware-2025-5521 — Mass File Rename (beast)
// Status: experimental | Level: high | ID: ee8f12a1-f791-5e68-abf7-d0bb2a81e5aa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
