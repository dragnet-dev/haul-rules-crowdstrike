// Dragnet [Ransomware]: dragnet-ransomware-2026-2749 — Mass File Rename (lockbit5)
// Status: stable | Level: high | ID: 421dab1b-64d1-50f3-becf-43ba2e64920b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
