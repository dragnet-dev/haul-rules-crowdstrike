// Dragnet [Ransomware]: dragnet-ransomware-2024-5042 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: d9bc7eca-2ac1-52d4-8b87-28b3a9cb0a61

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
