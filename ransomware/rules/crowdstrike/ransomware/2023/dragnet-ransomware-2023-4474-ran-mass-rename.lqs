// Dragnet [Ransomware]: dragnet-ransomware-2023-4474 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 906501b8-a451-588f-bc7e-1f6e3d36ea63

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
