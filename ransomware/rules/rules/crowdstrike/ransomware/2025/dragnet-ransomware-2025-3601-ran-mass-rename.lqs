// Dragnet [Ransomware]: dragnet-ransomware-2025-3601 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: 257bce3c-6aa4-5ac5-a8a7-d691ff24c1d7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
