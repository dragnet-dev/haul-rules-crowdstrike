// Dragnet [Ransomware]: dragnet-ransomware-2023-3057 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 47d3c45f-e332-55b6-a3ce-2d83b7614101

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
