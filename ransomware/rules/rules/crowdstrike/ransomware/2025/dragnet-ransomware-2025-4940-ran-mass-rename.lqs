// Dragnet [Ransomware]: dragnet-ransomware-2025-4940 — Mass File Rename (genesis)
// Status: experimental | Level: high | ID: 61117e84-28c0-51c7-9310-a8ed169bbda9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
