// Dragnet [Ransomware]: dragnet-ransomware-2025-5725 — Mass File Rename (pear)
// Status: experimental | Level: high | ID: 148f3b55-0bd4-515e-867a-c0106a29c5ee

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
