// Dragnet [Ransomware]: dragnet-ransomware-2023-1128 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: 5f9b5a79-8660-5812-9088-b6d059cd8a59

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
