// Dragnet [Ransomware]: dragnet-ransomware-2025-2111 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 80aed66b-91cb-58a4-b88e-ea2f73dbb984

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
