// Dragnet [Ransomware]: dragnet-ransomware-2024-4604 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 84c0b4dd-8837-5b0c-86aa-090d7cbfbe5b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
