// Dragnet [Ransomware]: dragnet-ransomware-2024-3854 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: d1a57cef-c254-5a72-ad68-38269ff9dd75

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
