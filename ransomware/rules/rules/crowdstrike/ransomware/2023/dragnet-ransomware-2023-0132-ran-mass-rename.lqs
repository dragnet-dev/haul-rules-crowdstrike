// Dragnet [Ransomware]: dragnet-ransomware-2023-0132 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 2990abea-72ee-5981-a610-01642adca96c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
