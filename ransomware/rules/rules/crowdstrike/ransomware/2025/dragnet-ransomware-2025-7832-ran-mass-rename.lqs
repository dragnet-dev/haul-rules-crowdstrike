// Dragnet [Ransomware]: dragnet-ransomware-2025-7832 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: b5782b46-6a5b-50fb-89af-62921b5c0e70

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
