// Dragnet [Ransomware]: dragnet-ransomware-2026-2128 — Mass File Rename (payoutsking)
// Status: test | Level: high | ID: c1dce897-a2a7-5d1a-902a-c5bd59614b60

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
