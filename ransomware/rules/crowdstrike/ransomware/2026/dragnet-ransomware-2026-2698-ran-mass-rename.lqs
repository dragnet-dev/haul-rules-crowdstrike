// Dragnet [Ransomware]: dragnet-ransomware-2026-2698 — Mass File Rename (incransom)
// Status: stable | Level: high | ID: 6b168b44-f2a2-5bf6-9d3f-f2ed69f25c3a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
