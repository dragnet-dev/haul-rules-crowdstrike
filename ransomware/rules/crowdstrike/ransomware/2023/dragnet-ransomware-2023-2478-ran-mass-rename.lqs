// Dragnet [Ransomware]: dragnet-ransomware-2023-2478 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: caf91662-c682-5967-a74b-799ebd7f5403

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
