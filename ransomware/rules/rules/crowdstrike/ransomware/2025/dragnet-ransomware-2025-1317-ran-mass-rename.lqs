// Dragnet [Ransomware]: dragnet-ransomware-2025-1317 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 2bcfd86e-dff7-5b8c-a061-3ebe8fbe7488

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
