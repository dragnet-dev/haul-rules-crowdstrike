// Dragnet [Ransomware]: dragnet-ransomware-2022-1918 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 01607c45-d697-596a-aa4e-8cb8d45f978c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
