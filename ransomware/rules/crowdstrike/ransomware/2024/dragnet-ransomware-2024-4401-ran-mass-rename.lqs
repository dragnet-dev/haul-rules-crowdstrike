// Dragnet [Ransomware]: dragnet-ransomware-2024-4401 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 91c9e19d-946f-57d2-bcda-ca0e5b39e90a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
