// Dragnet [Ransomware]: dragnet-ransomware-2024-5146 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 01820e9b-40b8-5383-9533-f45eef39c786

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
