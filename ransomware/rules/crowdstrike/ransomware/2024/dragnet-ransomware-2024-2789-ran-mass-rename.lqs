// Dragnet [Ransomware]: dragnet-ransomware-2024-2789 — Mass File Rename (ElDorado)
// Status: experimental | Level: high | ID: caa66184-012a-5ecf-97f9-9ace7fcff82a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
