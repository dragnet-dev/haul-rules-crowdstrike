// Dragnet [Ransomware]: dragnet-ransomware-2024-1343 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 0eb6a6fd-d9b2-51ba-82d9-836c6fc76ad1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
