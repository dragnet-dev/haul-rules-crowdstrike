// Dragnet [Ransomware]: dragnet-ransomware-2021-0350 — Mass File Rename (avaddon)
// Status: deprecated | Level: high | ID: cb040ccd-3f5c-5bca-a5d2-a1ef6e7b4c54

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
