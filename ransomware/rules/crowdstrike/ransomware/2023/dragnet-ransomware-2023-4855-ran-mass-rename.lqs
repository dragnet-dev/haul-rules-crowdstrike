// Dragnet [Ransomware]: dragnet-ransomware-2023-4855 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 68ac6fed-4d80-59f9-ac30-c0d88e0e19f4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
