// Dragnet [Ransomware]: dragnet-ransomware-2023-0931 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: fb96ad39-1068-58a8-a406-c83a4e19174e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
