// Dragnet [Ransomware]: dragnet-ransomware-2025-5605 — Mass File Rename (kairos)
// Status: experimental | Level: high | ID: 276a1ddc-2b03-5773-a8c6-bf3be6300258

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
