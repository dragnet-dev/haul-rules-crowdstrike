// Dragnet [Ransomware]: dragnet-ransomware-2024-5151 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: d71a3332-ae1f-572d-85ed-ff8c394f5542

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
