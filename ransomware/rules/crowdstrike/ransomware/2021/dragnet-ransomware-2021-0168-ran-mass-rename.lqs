// Dragnet [Ransomware]: dragnet-ransomware-2021-0168 — Mass File Rename (babuk)
// Status: experimental | Level: high | ID: ee40c2a0-53f4-5193-a422-f6392c3a02c6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
