// Dragnet [Ransomware]: dragnet-ransomware-2025-0367 — Mass File Rename (nova)
// Status: experimental | Level: high | ID: ecfe8702-a5b9-5d71-ab78-ea0ae886f70a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
