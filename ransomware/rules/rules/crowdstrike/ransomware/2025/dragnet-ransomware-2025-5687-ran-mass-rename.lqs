// Dragnet [Ransomware]: dragnet-ransomware-2025-5687 — Mass File Rename (AiLock)
// Status: deprecated | Level: high | ID: 6037dcde-a8f6-5d71-be64-40a0f2c10f17

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
