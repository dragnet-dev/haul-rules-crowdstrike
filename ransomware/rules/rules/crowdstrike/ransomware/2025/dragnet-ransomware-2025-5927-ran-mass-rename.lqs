// Dragnet [Ransomware]: dragnet-ransomware-2025-5927 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: ef00d5d2-acb5-588b-bbb9-1ee3f86a944b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
