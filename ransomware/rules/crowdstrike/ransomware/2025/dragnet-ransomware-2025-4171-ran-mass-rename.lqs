// Dragnet [Ransomware]: dragnet-ransomware-2025-4171 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 71992268-e3cc-58c1-884f-ee9e5c339566

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
