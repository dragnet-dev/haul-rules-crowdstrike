// Dragnet [Ransomware]: dragnet-ransomware-2025-1040 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 558f1f09-afcf-5cdf-a1d4-f42c0d42be7f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
