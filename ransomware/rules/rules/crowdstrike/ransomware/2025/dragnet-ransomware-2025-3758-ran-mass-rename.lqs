// Dragnet [Ransomware]: dragnet-ransomware-2025-3758 — Mass File Rename (weyhro)
// Status: experimental | Level: high | ID: b1231265-ddbc-5eac-adb2-21bf05e965b0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
