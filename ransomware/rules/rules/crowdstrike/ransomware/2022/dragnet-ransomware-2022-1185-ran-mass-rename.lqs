// Dragnet [Ransomware]: dragnet-ransomware-2022-1185 — Mass File Rename (royal)
// Status: deprecated | Level: high | ID: 536d0559-46fe-533e-8a3e-f583ad1dac09

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
