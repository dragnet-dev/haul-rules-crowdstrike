// Dragnet [Ransomware]: dragnet-ransomware-2025-3259 — Mass File Rename (sinobi)
// Status: experimental | Level: high | ID: 39c980d5-1d28-52bd-b069-ed4d3c5850e0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
