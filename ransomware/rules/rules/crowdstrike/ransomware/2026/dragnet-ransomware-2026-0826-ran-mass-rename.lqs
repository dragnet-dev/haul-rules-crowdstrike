// Dragnet [Ransomware]: dragnet-ransomware-2026-0826 — Mass File Rename (termite)
// Status: stable | Level: high | ID: afc6ff80-83a1-5c73-afe8-d7bd4eb6fed0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
