// Dragnet [Ransomware]: dragnet-ransomware-2025-7012 — Mass File Rename (SilentRansomGroup)
// Status: deprecated | Level: high | ID: 9a44b470-49eb-5067-babf-4c4493fcd351

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
