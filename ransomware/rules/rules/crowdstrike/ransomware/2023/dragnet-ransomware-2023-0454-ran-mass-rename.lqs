// Dragnet [Ransomware]: dragnet-ransomware-2023-0454 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 2a035e30-4c40-5a47-bb25-2c3db675c11d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
