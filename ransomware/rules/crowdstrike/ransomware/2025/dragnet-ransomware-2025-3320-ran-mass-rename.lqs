// Dragnet [Ransomware]: dragnet-ransomware-2025-3320 — Mass File Rename (ransomhouse)
// Status: experimental | Level: high | ID: 7ef1b9a9-a9d4-5828-a839-6a6a916ec239

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
