// Dragnet [Ransomware]: dragnet-ransomware-2025-3792 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 45807b3f-175c-56d0-a6ae-e2466349db88

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
