// Dragnet [Ransomware]: dragnet-ransomware-2022-1131 — Mass File Rename (everest)
// Status: deprecated | Level: high | ID: 6d20fd65-b36f-59d5-850b-a09b9c7122b5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
