// Dragnet [Ransomware]: dragnet-ransomware-2025-1171 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 492b1a2b-6dc6-58d5-8338-c429e2311623

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
