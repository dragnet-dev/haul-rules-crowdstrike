// Dragnet [Ransomware]: dragnet-ransomware-2025-1598 — Mass File Rename (bert)
// Status: experimental | Level: high | ID: a40acc50-a11b-53c1-80ef-3ce46f1a29e4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
