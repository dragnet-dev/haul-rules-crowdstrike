// Dragnet [Ransomware]: dragnet-ransomware-2024-0625 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 72dc6aeb-3abf-5dac-a09e-3a1679cc4bba

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
