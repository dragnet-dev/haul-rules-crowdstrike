// Dragnet [Ransomware]: dragnet-ransomware-2025-6512 — Mass File Rename (pear)
// Status: experimental | Level: high | ID: 2cf3dc4c-e86a-5111-99ac-124a6dfdf38b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
