// Dragnet [Ransomware]: dragnet-ransomware-2023-2021 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: a8166385-cc67-5c57-a074-b18c2ac15ed8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
