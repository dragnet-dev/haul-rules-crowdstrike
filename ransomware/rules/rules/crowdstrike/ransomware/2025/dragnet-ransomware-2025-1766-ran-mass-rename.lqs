// Dragnet [Ransomware]: dragnet-ransomware-2025-1766 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 2defe639-d7be-5dc9-bfc1-dbf10b24870e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
