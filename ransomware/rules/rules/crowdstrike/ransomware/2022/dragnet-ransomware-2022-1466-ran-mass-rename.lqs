// Dragnet [Ransomware]: dragnet-ransomware-2022-1466 — Mass File Rename (karakurt)
// Status: experimental | Level: high | ID: e346720d-44bd-556f-acc9-aea38864a1e0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
