// Dragnet [Ransomware]: dragnet-ransomware-2021-0806 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 653d2b0c-592a-54f9-a1ca-72a4677d8d25

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
