// Dragnet [Ransomware]: dragnet-ransomware-2024-2997 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 62991d17-f757-5ddd-a99b-7c36880835a9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
