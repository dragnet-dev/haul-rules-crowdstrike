// Dragnet [Ransomware]: dragnet-ransomware-2021-0144 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: d4111b1f-4e7d-56e1-b8c0-bde797183815

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
