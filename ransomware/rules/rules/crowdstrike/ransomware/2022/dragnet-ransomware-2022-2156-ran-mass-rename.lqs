// Dragnet [Ransomware]: dragnet-ransomware-2022-2156 — Mass File Rename (cuba)
// Status: deprecated | Level: high | ID: 0a0a4646-69dc-51ce-83dc-86612d477ffd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
