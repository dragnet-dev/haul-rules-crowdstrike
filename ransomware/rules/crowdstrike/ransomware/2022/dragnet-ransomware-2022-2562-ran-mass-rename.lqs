// Dragnet [Ransomware]: dragnet-ransomware-2022-2562 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: c31677bb-5915-5d7d-835e-59dfa60e3d54

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
