// Dragnet [Ransomware]: dragnet-ransomware-2022-1927 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 42411fe9-1997-5191-9589-96b25ff19354

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
