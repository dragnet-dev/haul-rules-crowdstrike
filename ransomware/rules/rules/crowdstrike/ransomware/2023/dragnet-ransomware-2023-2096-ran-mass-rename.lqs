// Dragnet [Ransomware]: dragnet-ransomware-2023-2096 — Mass File Rename (monti)
// Status: experimental | Level: high | ID: 1510465c-ff21-5d58-8247-4dcf0940c8aa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
