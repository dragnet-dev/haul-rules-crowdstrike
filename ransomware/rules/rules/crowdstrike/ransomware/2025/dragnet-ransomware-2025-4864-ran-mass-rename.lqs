// Dragnet [Ransomware]: dragnet-ransomware-2025-4864 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: d2818b60-aac0-53d4-a197-05b7b6055bf4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
