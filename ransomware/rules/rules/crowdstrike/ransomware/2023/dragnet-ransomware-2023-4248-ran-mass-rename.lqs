// Dragnet [Ransomware]: dragnet-ransomware-2023-4248 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 77bcceb7-261e-553e-aafc-846cca66274e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
