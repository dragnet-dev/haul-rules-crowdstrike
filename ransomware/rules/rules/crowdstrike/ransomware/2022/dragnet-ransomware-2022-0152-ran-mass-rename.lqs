// Dragnet [Ransomware]: dragnet-ransomware-2022-0152 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: d6d9fdf7-b257-53ab-a5e4-a388ce800e2c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
