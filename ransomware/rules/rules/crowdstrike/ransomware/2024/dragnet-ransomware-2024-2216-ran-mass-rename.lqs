// Dragnet [Ransomware]: dragnet-ransomware-2024-2216 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: ccc12aee-1b4a-56e5-ac0e-ad54cb9f9a6d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
