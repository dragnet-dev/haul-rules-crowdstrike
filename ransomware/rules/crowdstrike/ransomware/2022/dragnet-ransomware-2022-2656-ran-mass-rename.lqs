// Dragnet [Ransomware]: dragnet-ransomware-2022-2656 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: b643825e-8dba-5002-bc77-c0933e35eed2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
