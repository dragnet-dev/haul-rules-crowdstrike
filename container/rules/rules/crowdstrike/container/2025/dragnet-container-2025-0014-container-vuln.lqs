// Dragnet [Container]: dragnet-container-2025-0014 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 930e994e-5363-5958-a643-6147527b3ca4

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:9* OR ImageFileName = *ubuntu:14.04-ESM* OR ImageFileName = *ubuntu:16.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
