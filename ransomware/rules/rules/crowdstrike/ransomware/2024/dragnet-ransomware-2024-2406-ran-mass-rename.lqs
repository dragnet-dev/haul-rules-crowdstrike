// Dragnet [Ransomware]: dragnet-ransomware-2024-2406 — Mass File Rename (raworld)
// Status: experimental | Level: high | ID: 9c1ec098-ab14-5435-9df5-1ef88badb681

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
