// Dragnet [Ransomware]: dragnet-ransomware-2025-5079 — Mass File Rename (worldleaks)
// Status: experimental | Level: high | ID: 6de630f7-e835-5b42-8167-d2290d562e6f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
