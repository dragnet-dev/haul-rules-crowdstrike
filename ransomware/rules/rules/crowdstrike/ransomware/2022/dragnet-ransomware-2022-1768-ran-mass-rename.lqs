// Dragnet [Ransomware]: dragnet-ransomware-2022-1768 — Mass File Rename (vicesociety)
// Status: deprecated | Level: high | ID: 13912838-4574-5f71-807c-f877b722544e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
