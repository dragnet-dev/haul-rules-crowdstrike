// Dragnet [Ransomware]: dragnet-ransomware-2025-7511 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 6a9af353-e8c4-5114-8826-64e22e224bd5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
