// Dragnet [Ransomware]: dragnet-ransomware-2022-0725 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 16da1d34-097a-550b-b3e3-c866c0152023

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
