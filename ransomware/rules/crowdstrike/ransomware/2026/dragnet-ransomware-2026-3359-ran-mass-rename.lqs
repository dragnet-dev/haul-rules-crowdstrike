// Dragnet [Ransomware]: dragnet-ransomware-2026-3359 — Mass File Rename (ALP-001)
// Status: stable | Level: high | ID: b9de430b-923d-5174-adeb-1071f8144ea1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
