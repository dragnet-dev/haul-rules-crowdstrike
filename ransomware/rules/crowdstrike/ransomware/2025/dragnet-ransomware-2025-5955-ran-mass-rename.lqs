// Dragnet [Ransomware]: dragnet-ransomware-2025-5955 — Mass File Rename (beast)
// Status: experimental | Level: high | ID: f430dce4-c6dc-5d4f-9416-675abcd03043

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
