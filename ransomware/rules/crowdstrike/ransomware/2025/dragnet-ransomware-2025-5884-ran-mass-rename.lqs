// Dragnet [Ransomware]: dragnet-ransomware-2025-5884 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: c656b37e-58dd-5925-a376-b74eb421d947

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
