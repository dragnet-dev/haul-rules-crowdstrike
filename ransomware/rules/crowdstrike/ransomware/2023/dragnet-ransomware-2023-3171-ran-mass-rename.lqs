// Dragnet [Ransomware]: dragnet-ransomware-2023-3171 — Mass File Rename (monti)
// Status: experimental | Level: high | ID: 140c0455-8cd2-5a5c-9561-255327bca98c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
