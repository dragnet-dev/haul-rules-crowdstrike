// Dragnet [Ransomware]: dragnet-ransomware-2026-2004 — Mass File Rename (spacebears)
// Status: stable | Level: high | ID: fb014c8d-03c0-5430-9f5d-847bdb7f4ba3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
