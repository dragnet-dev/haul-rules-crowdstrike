// Dragnet [Ransomware]: dragnet-ransomware-2021-1732 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 7b8b8bfa-36cc-5d9e-89da-3efcc079a911

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
