// Dragnet [Ransomware]: dragnet-ransomware-2025-5599 — Mass File Rename (kairos)
// Status: deprecated | Level: high | ID: f3f2e1e8-8ac5-509c-b7f2-536baa61a7e8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
