// Dragnet [Ransomware]: dragnet-ransomware-2022-1866 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 948a331d-5e8a-5d63-ab5f-727bd6902bb3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
