// Dragnet [Ransomware]: dragnet-ransomware-2025-1755 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 4179d315-42b1-5a6a-9bbb-2e05a150a621

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
