// Dragnet [Ransomware]: dragnet-ransomware-2026-1101 — Mass File Rename (thegentlemen)
// Status: test | Level: high | ID: e3c0296e-9124-5611-9dce-15321f865eac

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
