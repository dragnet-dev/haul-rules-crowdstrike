// Dragnet [Ransomware]: dragnet-ransomware-2022-1328 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 8796aa04-9488-5a28-bc64-97bad54029fc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
