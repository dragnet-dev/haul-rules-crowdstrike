// Dragnet [Ransomware]: dragnet-ransomware-2023-2906 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 7da924e2-c63d-51bf-b031-8e62963348ca

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
