// Dragnet [Ransomware]: dragnet-ransomware-2024-5539 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: c2a5f1fc-7b75-591a-bb33-bd670072f19a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
