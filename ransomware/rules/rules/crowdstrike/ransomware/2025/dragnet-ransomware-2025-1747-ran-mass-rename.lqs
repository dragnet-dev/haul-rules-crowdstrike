// Dragnet [Ransomware]: dragnet-ransomware-2025-1747 — Mass File Rename (devman)
// Status: deprecated | Level: high | ID: 1d6fc960-9440-5cdc-bd02-fef165b97b39

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
