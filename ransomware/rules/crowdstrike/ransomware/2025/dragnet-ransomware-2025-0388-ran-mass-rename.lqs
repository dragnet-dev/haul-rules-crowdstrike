// Dragnet [Ransomware]: dragnet-ransomware-2025-0388 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: d4e34514-1bbe-57e0-8943-8a75fce6bee5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
