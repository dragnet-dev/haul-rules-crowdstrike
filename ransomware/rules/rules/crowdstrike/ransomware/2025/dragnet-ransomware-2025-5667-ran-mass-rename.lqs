// Dragnet [Ransomware]: dragnet-ransomware-2025-5667 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: a97daae2-2b01-5a0c-a671-41c4be0ea6bd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
