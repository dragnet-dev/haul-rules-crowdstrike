// Dragnet [Ransomware]: dragnet-ransomware-2025-0815 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: 8a72dcc9-d33e-5ba2-9e31-501e47c1f312

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
