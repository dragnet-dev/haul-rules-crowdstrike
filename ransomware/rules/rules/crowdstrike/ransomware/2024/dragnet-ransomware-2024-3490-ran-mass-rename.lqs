// Dragnet [Ransomware]: dragnet-ransomware-2024-3490 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: 61bf5ee9-d84c-5d24-8921-3020b57537a6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
