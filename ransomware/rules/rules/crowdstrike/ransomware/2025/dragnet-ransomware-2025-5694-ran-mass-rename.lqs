// Dragnet [Ransomware]: dragnet-ransomware-2025-5694 — Mass File Rename (blacklock)
// Status: experimental | Level: high | ID: 01db9897-af8e-5a21-a210-bbc91f4356db

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
