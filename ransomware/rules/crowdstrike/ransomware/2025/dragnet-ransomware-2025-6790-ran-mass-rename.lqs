// Dragnet [Ransomware]: dragnet-ransomware-2025-6790 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: fdd43485-94a1-542f-89ef-34b7ebbc8da1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
