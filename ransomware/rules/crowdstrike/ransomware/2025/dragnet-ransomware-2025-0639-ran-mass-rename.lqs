// Dragnet [Ransomware]: dragnet-ransomware-2025-0639 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 6ae66bb7-9f01-5dba-bd8f-b63e039931de

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
