// Dragnet [Ransomware]: dragnet-ransomware-2025-7668 — Mass File Rename (weyhro)
// Status: experimental | Level: high | ID: 2dc5c8d3-b876-5ec8-93b3-c3c030abd8cf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
