// Dragnet [Ransomware]: dragnet-ransomware-2023-4634 — Mass File Rename (siegedsec)
// Status: deprecated | Level: high | ID: fa18b8ea-ba40-5142-adf1-2a05340d5fe9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
