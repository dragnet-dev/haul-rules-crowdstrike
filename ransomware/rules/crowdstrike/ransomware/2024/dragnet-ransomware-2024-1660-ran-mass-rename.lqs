// Dragnet [Ransomware]: dragnet-ransomware-2024-1660 — Mass File Rename (meow)
// Status: experimental | Level: high | ID: fd630bec-92cd-5b68-b1d4-e5ced929dd07

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
