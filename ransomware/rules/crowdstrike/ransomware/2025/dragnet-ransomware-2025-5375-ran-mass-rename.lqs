// Dragnet [Ransomware]: dragnet-ransomware-2025-5375 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: 925fba23-3420-56ca-87d5-d91db61cbaec

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
