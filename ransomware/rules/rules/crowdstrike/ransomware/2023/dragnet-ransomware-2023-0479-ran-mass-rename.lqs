// Dragnet [Ransomware]: dragnet-ransomware-2023-0479 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 7aa6a9b4-51fd-555b-b311-95908a2a5e8f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
