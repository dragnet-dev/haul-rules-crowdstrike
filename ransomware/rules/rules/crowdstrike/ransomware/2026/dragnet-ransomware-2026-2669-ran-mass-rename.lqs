// Dragnet [Ransomware]: dragnet-ransomware-2026-2669 — Mass File Rename (payload)
// Status: stable | Level: high | ID: b7759fac-815e-5a60-b8c3-dc07124821a9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
