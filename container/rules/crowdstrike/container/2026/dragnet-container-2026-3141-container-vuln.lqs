// Dragnet [Container]: dragnet-container-2026-3141 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 55a6776a-e843-548d-9ba8-6cab718b26c6

#event_simpleName=*
| (ImageFileName = *amazonlinux:1* OR ImageFileName = *debian:8* OR ImageFileName = *ubuntu:14.04* OR ImageFileName = *ubuntu:14.04-ESM* OR ImageFileName = *ubuntu:15.10*)
| table([timestamp, ComputerName])
| limit(1000)
