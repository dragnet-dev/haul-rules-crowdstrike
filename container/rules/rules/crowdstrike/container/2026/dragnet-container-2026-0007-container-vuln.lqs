// Dragnet [Container]: dragnet-container-2026-0007 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: a42ab8ce-0f8d-5aaf-8757-ae823ff9544e

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *photon os:4.0*)
| table([timestamp, ComputerName])
| limit(1000)
