// Dragnet [Ransomware]: dragnet-ransomware-2024-1880 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: b3e1fd3b-d84f-5417-8c27-cacc0d5585a5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
