// Dragnet [Container]: dragnet-container-2026-2406 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: e1b8b9c1-6d21-5f5c-9fd1-8d2cef3ce362

#event_simpleName=*
| (ImageFileName = *amazonlinux:1* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:7* OR ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *oraclelinux:7* OR ImageFileName = *ubuntu:12.04*)
| table([timestamp, ComputerName])
| limit(1000)
