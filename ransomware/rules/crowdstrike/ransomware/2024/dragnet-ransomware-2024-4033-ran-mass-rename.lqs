// Dragnet [Ransomware]: dragnet-ransomware-2024-4033 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: e160eeec-52d2-5e35-a6a0-826dd977be71

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
