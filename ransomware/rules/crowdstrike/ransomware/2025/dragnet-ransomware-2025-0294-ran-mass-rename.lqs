// Dragnet [Ransomware]: dragnet-ransomware-2025-0294 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: ac735b8d-c959-56f2-9a6b-7921a367e564

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
