// Dragnet [Ransomware]: dragnet-ransomware-2022-1838 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: f5363f54-d040-59b2-9d8f-f8e9ee70e3e6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
