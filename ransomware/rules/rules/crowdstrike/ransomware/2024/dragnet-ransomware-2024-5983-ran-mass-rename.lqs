// Dragnet [Ransomware]: dragnet-ransomware-2024-5983 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: 6b5e8fb9-8d0b-5371-90fa-1f644cca8a4f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
