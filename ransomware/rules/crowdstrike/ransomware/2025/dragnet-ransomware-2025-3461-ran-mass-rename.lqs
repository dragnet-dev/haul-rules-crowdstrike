// Dragnet [Ransomware]: dragnet-ransomware-2025-3461 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 1b8d1dd3-7112-578d-8001-8725b4dbd116

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
