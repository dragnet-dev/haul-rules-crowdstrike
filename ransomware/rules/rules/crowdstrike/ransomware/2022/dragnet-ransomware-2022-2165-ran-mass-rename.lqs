// Dragnet [Ransomware]: dragnet-ransomware-2022-2165 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 36e500bb-628c-5509-857b-31094916408e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
