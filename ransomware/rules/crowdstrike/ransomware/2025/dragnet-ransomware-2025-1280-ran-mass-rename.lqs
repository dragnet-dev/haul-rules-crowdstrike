// Dragnet [Ransomware]: dragnet-ransomware-2025-1280 — Mass File Rename (interlock)
// Status: experimental | Level: high | ID: afd0d5aa-1f5c-57c7-a988-284ce36ddb3e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
