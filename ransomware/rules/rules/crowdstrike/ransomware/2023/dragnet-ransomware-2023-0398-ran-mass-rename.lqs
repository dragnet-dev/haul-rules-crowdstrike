// Dragnet [Ransomware]: dragnet-ransomware-2023-0398 — Mass File Rename (ransomhouse)
// Status: experimental | Level: high | ID: 350cb90e-f3c2-5221-8d8c-08dca005cf33

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
