// Dragnet [Ransomware]: dragnet-ransomware-2023-3889 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 90f49c77-0406-5ec8-86c0-64486d951b53

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
