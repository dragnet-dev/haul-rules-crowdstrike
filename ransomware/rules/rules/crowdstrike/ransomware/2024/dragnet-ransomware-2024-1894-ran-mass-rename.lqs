// Dragnet [Ransomware]: dragnet-ransomware-2024-1894 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: b9e26e05-c90c-5edc-8a09-2ce84a0bf7c1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
