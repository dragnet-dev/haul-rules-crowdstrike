// Dragnet [Container]: dragnet-container-2025-0478 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 242b6c04-a5c2-5fcd-8438-2ef2fe7bf1b8

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *redhat/ubi9:*)
| table([timestamp, ComputerName])
| limit(1000)
