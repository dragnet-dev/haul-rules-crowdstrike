// Dragnet [Ransomware]: dragnet-ransomware-2024-0978 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 17667d7b-6b7b-5a9a-82da-e321f7558e43

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
