// Dragnet [Ransomware]: dragnet-ransomware-2024-4459 — Mass File Rename (rhysida)
// Status: deprecated | Level: high | ID: c15783e2-2e38-5577-b058-014be4d7bca7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
