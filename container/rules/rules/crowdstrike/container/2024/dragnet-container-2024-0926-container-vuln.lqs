// Dragnet [Container]: dragnet-container-2024-0926 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 4b2f2fac-17a2-5077-b896-893dab30f411

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:8* OR ImageFileName = *debian:9* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *oraclelinux:7* OR ImageFileName = *ubuntu:14.04* OR ImageFileName = *ubuntu:16.04* OR ImageFileName = *ubuntu:17.10*)
| table([timestamp, ComputerName])
| limit(1000)
