// Dragnet [Ransomware]: dragnet-ransomware-2022-2290 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 21a08c50-808c-5f8a-a23c-95e482d80960

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
