// Dragnet [Ransomware]: dragnet-ransomware-2025-6724 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 3fb99278-fb1f-5758-985e-087ed1bb1aac

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
