// Dragnet [Ransomware]: dragnet-ransomware-2022-1307 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: cebbcbe9-1743-5c71-9c87-cea50d635c65

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
