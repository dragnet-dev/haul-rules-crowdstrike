// Dragnet [Ransomware]: dragnet-ransomware-2025-4786 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 1f297d01-4456-528f-846c-d39be2ded6bf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
