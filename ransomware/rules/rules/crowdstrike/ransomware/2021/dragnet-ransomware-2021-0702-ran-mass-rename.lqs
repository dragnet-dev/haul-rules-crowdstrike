// Dragnet [Ransomware]: dragnet-ransomware-2021-0702 — Mass File Rename (suncrypt)
// Status: deprecated | Level: high | ID: 9d25035a-46ca-5be3-aae9-18a5242f753f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
