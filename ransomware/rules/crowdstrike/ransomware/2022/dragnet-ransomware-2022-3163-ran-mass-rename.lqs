// Dragnet [Ransomware]: dragnet-ransomware-2022-3163 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 5fb0a662-e329-5c42-97e9-939df0ad5c4b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
