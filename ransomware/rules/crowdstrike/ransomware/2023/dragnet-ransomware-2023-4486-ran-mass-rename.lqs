// Dragnet [Ransomware]: dragnet-ransomware-2023-4486 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: ea30e0bc-a83b-5426-aaa2-e0b3951a4702

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
