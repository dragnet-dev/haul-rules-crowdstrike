// Dragnet [Ransomware]: dragnet-ransomware-2022-0248 — Mass File Rename (blackbasta)
// Status: deprecated | Level: high | ID: 37e3a590-29f6-5d25-b80d-f4e61d66289d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
