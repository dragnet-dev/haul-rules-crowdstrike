// Dragnet [Ransomware]: dragnet-ransomware-2025-1471 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: a52d619d-942f-5600-a9c9-b134f3aae135

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
