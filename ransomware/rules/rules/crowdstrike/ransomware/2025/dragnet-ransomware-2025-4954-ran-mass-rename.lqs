// Dragnet [Ransomware]: dragnet-ransomware-2025-4954 — Mass File Rename (play)
// Status: experimental | Level: high | ID: e18c3647-e686-5f8e-b258-f1903803123b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
