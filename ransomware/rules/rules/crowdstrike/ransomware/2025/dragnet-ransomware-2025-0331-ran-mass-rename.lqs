// Dragnet [Ransomware]: dragnet-ransomware-2025-0331 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 7592615c-e01a-5f91-b19a-69e66502f77e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
