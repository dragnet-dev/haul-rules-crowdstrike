// Dragnet [Ransomware]: dragnet-ransomware-2024-4197 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 773fcf0a-138b-510e-9a6c-79a4436fe4f5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
