// Dragnet [Ransomware]: dragnet-ransomware-2021-0231 — Mass File Rename (azroteam)
// Status: deprecated | Level: high | ID: 08529e16-5bc3-5e1c-b18a-c1445996353b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
