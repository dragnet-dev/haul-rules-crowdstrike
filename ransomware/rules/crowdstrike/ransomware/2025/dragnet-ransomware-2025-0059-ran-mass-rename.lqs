// Dragnet [Ransomware]: dragnet-ransomware-2025-0059 — Mass File Rename (devman)
// Status: experimental | Level: high | ID: 9c1dbdaf-6476-5f1e-b252-1d5934fc7190

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
