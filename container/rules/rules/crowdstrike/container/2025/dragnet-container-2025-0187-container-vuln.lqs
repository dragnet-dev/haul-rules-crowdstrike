// Dragnet [Container]: dragnet-container-2025-0187 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: ad55a37b-42aa-5abe-b824-de3481ab0ad8

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
