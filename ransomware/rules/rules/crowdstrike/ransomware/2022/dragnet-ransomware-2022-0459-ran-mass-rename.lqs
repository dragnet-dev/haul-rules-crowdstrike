// Dragnet [Ransomware]: dragnet-ransomware-2022-0459 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 36e2f40f-5d9b-59aa-86c5-342e33c69061

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
