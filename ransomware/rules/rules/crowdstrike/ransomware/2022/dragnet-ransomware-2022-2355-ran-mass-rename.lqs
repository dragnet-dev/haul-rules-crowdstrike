// Dragnet [Ransomware]: dragnet-ransomware-2022-2355 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 4032cd9b-254d-542f-a3b8-2e042de21da4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
