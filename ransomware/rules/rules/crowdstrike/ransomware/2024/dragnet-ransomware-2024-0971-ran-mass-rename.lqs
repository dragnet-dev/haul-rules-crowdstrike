// Dragnet [Ransomware]: dragnet-ransomware-2024-0971 — Mass File Rename (blacklock)
// Status: experimental | Level: high | ID: d7b911dd-2012-54e5-b878-13c0216a3302

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
