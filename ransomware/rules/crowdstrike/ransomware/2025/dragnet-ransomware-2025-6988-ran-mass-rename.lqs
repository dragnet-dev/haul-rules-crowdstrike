// Dragnet [Ransomware]: dragnet-ransomware-2025-6988 — Mass File Rename (spacebears)
// Status: experimental | Level: high | ID: b047a3da-f1b3-5a82-b5eb-f920b9db8879

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
