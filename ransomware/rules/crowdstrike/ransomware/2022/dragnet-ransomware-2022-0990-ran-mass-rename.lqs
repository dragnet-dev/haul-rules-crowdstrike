// Dragnet [Ransomware]: dragnet-ransomware-2022-0990 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 38db14bf-cb30-5550-b98e-4e4e32f43aec

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
