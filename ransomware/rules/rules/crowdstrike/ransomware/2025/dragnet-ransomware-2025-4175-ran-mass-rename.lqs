// Dragnet [Ransomware]: dragnet-ransomware-2025-4175 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 7b6c31f9-8f7e-5449-9542-f2dae1f083ea

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
