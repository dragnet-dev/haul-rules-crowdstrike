// Dragnet [Ransomware]: dragnet-ransomware-2025-4195 — Mass File Rename (hellcat)
// Status: deprecated | Level: high | ID: 4091ac60-46ee-5fa2-8508-6cc1e9beb0ec

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
