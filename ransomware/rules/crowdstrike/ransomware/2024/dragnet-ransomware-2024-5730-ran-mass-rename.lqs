// Dragnet [Ransomware]: dragnet-ransomware-2024-5730 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: 0b7e23f7-186e-5f9c-a150-9ba648f4fdd1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
