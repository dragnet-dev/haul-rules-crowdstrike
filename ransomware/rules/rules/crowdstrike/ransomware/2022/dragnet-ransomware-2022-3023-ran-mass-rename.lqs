// Dragnet [Ransomware]: dragnet-ransomware-2022-3023 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 2d6f103f-cab0-57b6-b183-152a7df416d5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
