// Dragnet [Ransomware]: dragnet-ransomware-2024-3143 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: e90ce9cc-0aed-5960-897b-9c52301f7620

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
