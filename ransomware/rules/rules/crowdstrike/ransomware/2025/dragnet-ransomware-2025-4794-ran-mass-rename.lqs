// Dragnet [Ransomware]: dragnet-ransomware-2025-4794 — Mass File Rename (apt73)
// Status: experimental | Level: high | ID: 1dc09908-f740-543b-b8f3-a0e126fb670a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
