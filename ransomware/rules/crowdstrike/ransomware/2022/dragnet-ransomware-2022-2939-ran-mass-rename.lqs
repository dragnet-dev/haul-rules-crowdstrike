// Dragnet [Ransomware]: dragnet-ransomware-2022-2939 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 2c5b827d-1a40-54b9-a4b6-aee00b069795

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
