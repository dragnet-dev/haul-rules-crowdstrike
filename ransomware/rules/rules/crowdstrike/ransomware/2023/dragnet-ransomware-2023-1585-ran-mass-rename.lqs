// Dragnet [Ransomware]: dragnet-ransomware-2023-1585 — Mass File Rename (royal)
// Status: experimental | Level: high | ID: 13023a67-2918-59bb-9504-11483199e637

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
