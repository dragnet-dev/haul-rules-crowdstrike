// Dragnet [Ransomware]: dragnet-ransomware-2025-4841 — Mass File Rename (arcusmedia)
// Status: experimental | Level: high | ID: a797e878-d4d1-5c70-b027-c30dd9f31269

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
