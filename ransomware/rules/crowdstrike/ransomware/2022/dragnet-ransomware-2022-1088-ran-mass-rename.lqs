// Dragnet [Ransomware]: dragnet-ransomware-2022-1088 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: b6d41f37-73dc-5ce6-a6d1-bc6d9f91cb75

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
