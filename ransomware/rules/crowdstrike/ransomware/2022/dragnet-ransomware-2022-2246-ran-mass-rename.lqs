// Dragnet [Ransomware]: dragnet-ransomware-2022-2246 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 1e28f8d0-0989-5cb7-9352-11706195d775

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
