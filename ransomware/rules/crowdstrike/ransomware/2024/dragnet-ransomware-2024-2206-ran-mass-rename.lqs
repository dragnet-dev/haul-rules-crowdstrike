// Dragnet [Ransomware]: dragnet-ransomware-2024-2206 — Mass File Rename (meow)
// Status: experimental | Level: high | ID: c7f0e0fe-eeb7-5a73-862b-6e4e7cdfbd92

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
