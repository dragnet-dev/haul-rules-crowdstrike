// Dragnet [Ransomware]: dragnet-ransomware-2024-4289 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: 34567f57-28ad-599d-8c83-c65f32043788

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
