// Dragnet [Ransomware]: dragnet-ransomware-2023-2851 — Mass File Rename (malas)
// Status: experimental | Level: high | ID: 356081fa-6807-5e67-b6fa-8c9366339cf3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
