// Dragnet [Ransomware]: dragnet-ransomware-2025-5685 — Mass File Rename (pear)
// Status: experimental | Level: high | ID: 7cf9a654-6a52-5b7b-a5e8-02563dd93856

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
