// Dragnet [Ransomware]: dragnet-ransomware-2023-0623 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 0c3e003b-5cbf-5163-89bb-d2e1521d0be9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
