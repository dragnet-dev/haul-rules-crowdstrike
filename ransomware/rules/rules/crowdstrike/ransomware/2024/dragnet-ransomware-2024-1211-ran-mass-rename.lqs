// Dragnet [Ransomware]: dragnet-ransomware-2024-1211 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: d6a72c33-66ac-5409-8372-2fe3c9172c22

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
