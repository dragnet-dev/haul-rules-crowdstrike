// Dragnet [Ransomware]: dragnet-ransomware-2025-1432 — Mass File Rename (sarcoma)
// Status: deprecated | Level: high | ID: 71c0d58f-c83c-5575-af08-6f5b48ff66c7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
