// Dragnet [Ransomware]: dragnet-ransomware-2023-1045 — Mass File Rename (monti)
// Status: deprecated | Level: high | ID: 6b99fcfe-6acf-5c5e-9fde-f9ffb34fe725

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
