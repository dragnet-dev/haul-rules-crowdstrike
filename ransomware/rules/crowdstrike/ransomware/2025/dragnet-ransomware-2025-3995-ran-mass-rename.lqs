// Dragnet [Ransomware]: dragnet-ransomware-2025-3995 — Mass File Rename (kraken)
// Status: experimental | Level: high | ID: dd5a7ca3-1b9f-51c5-a6ed-b1349aa6ea41

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
