// Dragnet [Ransomware]: dragnet-ransomware-2021-0159 — Mass File Rename (ransomexx)
// Status: deprecated | Level: high | ID: 8d7d1e3f-91b6-5216-855f-193b6fa28ac2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
