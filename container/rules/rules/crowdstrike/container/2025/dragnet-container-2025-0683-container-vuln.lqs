// Dragnet [Container]: dragnet-container-2025-0683 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 4d5df555-8310-5a38-ba27-df639a6bbdf3

#event_simpleName=*
| (ImageFileName = *amazonlinux:2* OR ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:9* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:18.04* OR ImageFileName = *ubuntu:20.04*)
| table([timestamp, ComputerName])
| limit(1000)
