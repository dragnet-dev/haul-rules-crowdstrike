// Dragnet [Ransomware]: dragnet-ransomware-2025-3236 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 901cd981-99d4-585e-8eb5-501c52352dbe

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
