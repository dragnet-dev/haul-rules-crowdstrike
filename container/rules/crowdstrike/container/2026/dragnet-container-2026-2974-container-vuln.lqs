// Dragnet [Container]: dragnet-container-2026-2974 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 506688b7-2f3f-5582-9d86-974acfaf9647

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:5*)
| table([timestamp, ComputerName])
| limit(1000)
