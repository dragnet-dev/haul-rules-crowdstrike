// Dragnet [Ransomware]: dragnet-ransomware-2024-0739 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: b96bc7e7-2a07-5b49-8c48-6b116ae4c200

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
