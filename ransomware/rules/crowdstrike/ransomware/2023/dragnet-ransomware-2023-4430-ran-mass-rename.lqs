// Dragnet [Ransomware]: dragnet-ransomware-2023-4430 — Mass File Rename (rhysida)
// Status: experimental | Level: high | ID: e76719da-f27e-52c3-bcb1-3dd497364408

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
