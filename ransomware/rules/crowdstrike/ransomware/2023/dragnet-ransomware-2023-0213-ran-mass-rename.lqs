// Dragnet [Ransomware]: dragnet-ransomware-2023-0213 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 48ddd3f9-6c76-50c5-85ac-650a4ef698d3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
