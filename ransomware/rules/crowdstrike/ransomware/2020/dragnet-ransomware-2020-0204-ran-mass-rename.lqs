// Dragnet [Ransomware]: dragnet-ransomware-2020-0204 — Mass File Rename (thanos)
// Status: deprecated | Level: high | ID: 8a5c88f1-72c5-543d-8a22-f739f4829bcf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
