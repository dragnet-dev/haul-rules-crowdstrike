// Dragnet [Ransomware]: dragnet-ransomware-2022-0319 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: bb616068-0f73-5f0c-b708-f91079881cb2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
