// Dragnet [Ransomware]: dragnet-ransomware-2025-0279 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 6b67df93-f8a7-5e2e-8820-b43b1d3a32b7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
