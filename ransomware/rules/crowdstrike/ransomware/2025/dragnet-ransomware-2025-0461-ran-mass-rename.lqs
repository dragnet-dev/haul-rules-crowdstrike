// Dragnet [Ransomware]: dragnet-ransomware-2025-0461 — Mass File Rename (rhysida)
// Status: deprecated | Level: high | ID: 1864a97c-0245-5268-9913-3efe3225a837

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
