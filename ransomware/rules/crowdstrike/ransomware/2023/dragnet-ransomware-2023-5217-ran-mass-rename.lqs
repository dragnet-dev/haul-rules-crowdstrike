// Dragnet [Ransomware]: dragnet-ransomware-2023-5217 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 40bf9876-6b73-573d-8982-f60ef42ce89c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
