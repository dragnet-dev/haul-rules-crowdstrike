// Dragnet [Ransomware]: dragnet-ransomware-2026-0106 — Mass File Rename (killsec)
// Status: deprecated | Level: high | ID: 80057b5e-0c29-5276-863e-f66ea6fdafe4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
