// Dragnet [Ransomware]: dragnet-ransomware-2025-5772 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: df2276da-0b10-5d6e-b1b1-5164ebe1b8db

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
