// Dragnet [Ransomware]: dragnet-ransomware-2025-2345 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 46dbbb24-6fdb-544c-b85e-f5b6d25a9d93

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
