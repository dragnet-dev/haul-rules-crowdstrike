// Dragnet [Ransomware]: dragnet-ransomware-2025-6799 — Mass File Rename (interlock)
// Status: experimental | Level: high | ID: 84e39164-3048-5fcb-a1d5-8a3fc3806a15

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
