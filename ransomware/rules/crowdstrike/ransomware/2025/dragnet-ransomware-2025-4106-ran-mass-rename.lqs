// Dragnet [Ransomware]: dragnet-ransomware-2025-4106 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 5492b4cb-84ae-5228-9188-fb827531d76a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
