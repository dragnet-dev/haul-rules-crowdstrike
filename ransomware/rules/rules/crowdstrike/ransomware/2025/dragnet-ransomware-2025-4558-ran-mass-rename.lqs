// Dragnet [Ransomware]: dragnet-ransomware-2025-4558 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 6d9ed4ec-61b9-518b-aaae-4e02d6893fa1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
