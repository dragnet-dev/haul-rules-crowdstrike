// Dragnet [Ransomware]: dragnet-ransomware-2026-1113 — Mass File Rename (thegentlemen)
// Status: test | Level: high | ID: 403ef10b-67a9-5c77-877d-63f83efedba4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
