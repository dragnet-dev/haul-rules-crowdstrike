// Dragnet [Ransomware]: dragnet-ransomware-2023-1049 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 5db0d299-9c41-5720-a2e1-bfdaba5cd9ab

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
