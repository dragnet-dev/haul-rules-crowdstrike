// Dragnet [Ransomware]: dragnet-ransomware-2025-0123 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: d8409ca7-3ddd-5a08-840f-a7e6a54d254e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
