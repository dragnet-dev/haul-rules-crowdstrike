// Dragnet [Ransomware]: dragnet-ransomware-2025-2752 — Mass File Rename (warlock)
// Status: deprecated | Level: high | ID: bedec55a-f807-5fe3-afd0-5f41379e4255

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
