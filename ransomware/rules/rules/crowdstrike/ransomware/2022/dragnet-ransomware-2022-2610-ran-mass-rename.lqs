// Dragnet [Ransomware]: dragnet-ransomware-2022-2610 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: fb8c4ea9-4d79-563c-b12f-5d88996784f8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
