// Dragnet [Ransomware]: dragnet-ransomware-2021-0113 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 476adecb-2a89-5f6b-aa14-278ec0f5c7b9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
