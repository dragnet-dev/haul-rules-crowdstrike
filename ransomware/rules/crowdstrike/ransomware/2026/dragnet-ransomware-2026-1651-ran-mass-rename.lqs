// Dragnet [Ransomware]: dragnet-ransomware-2026-1651 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 9a8cfe9b-de9d-5ac3-8ae8-10a447c5832a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
