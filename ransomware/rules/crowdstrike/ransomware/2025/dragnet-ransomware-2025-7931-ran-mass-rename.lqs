// Dragnet [Ransomware]: dragnet-ransomware-2025-7931 — Mass File Rename (chaos)
// Status: experimental | Level: high | ID: 691e6fec-1f52-5136-895b-3ba34a7268a4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
