// Dragnet [Ransomware]: dragnet-ransomware-2023-0555 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: b8bad398-f1f9-5d5a-95f5-1019ec9d1ddc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
