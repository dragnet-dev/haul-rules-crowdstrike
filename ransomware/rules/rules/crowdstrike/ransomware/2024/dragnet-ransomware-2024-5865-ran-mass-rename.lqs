// Dragnet [Ransomware]: dragnet-ransomware-2024-5865 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 42a6148a-1b68-55c4-a480-e9dfd11d3d81

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
