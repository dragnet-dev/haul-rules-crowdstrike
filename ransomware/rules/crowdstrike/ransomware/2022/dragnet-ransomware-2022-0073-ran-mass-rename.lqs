// Dragnet [Ransomware]: dragnet-ransomware-2022-0073 — Mass File Rename (vicesociety)
// Status: deprecated | Level: high | ID: 34bb732e-bcc5-5b63-aee7-543319028a30

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
