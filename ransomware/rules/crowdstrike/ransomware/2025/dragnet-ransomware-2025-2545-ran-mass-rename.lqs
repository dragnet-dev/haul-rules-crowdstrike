// Dragnet [Ransomware]: dragnet-ransomware-2025-2545 — Mass File Rename (nightspire)
// Status: deprecated | Level: high | ID: 93f9d1d3-2da8-5379-8be1-514a65042d07

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
