// Dragnet [Ransomware]: dragnet-ransomware-2024-2681 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: ca82d56f-b947-5679-b089-095b640c1870

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
