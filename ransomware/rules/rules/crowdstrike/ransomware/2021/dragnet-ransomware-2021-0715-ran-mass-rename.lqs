// Dragnet [Ransomware]: dragnet-ransomware-2021-0715 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 9db4946c-5d01-5d25-a70d-d549e98a4c4c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
