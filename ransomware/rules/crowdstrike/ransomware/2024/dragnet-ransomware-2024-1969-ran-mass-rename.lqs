// Dragnet [Ransomware]: dragnet-ransomware-2024-1969 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 9cfeb423-b469-5269-8612-22673d4cc22d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
