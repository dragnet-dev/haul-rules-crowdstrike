// Dragnet [Ransomware]: dragnet-ransomware-2025-5317 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: e3ea97a3-6b3a-55dc-b776-d011d3b2a880

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
