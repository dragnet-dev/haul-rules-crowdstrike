// Dragnet [Ransomware]: dragnet-ransomware-2024-3177 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 1e906896-e1c2-5049-803f-181ace918d7f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
