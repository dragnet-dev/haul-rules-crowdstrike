// Dragnet [Ransomware]: dragnet-ransomware-2025-4626 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 818f71f3-fe3e-510f-ad7c-a45868e4306d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
