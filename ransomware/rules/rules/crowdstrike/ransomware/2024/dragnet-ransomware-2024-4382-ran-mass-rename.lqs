// Dragnet [Ransomware]: dragnet-ransomware-2024-4382 — Mass File Rename (SilentRansomGroup)
// Status: deprecated | Level: high | ID: e9b27e11-8b2a-5d26-b288-dad4ca2a505f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
