// Dragnet [Ransomware]: dragnet-ransomware-2024-2655 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: e976bbfd-df92-5543-8e7b-9c817aaa2f2c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
