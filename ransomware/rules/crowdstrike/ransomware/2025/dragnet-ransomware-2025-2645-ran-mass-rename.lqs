// Dragnet [Ransomware]: dragnet-ransomware-2025-2645 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: 453be3f9-ab7e-5b79-8492-66c4e25dc83f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
