// Dragnet [Container]: dragnet-container-2026-2917 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: a6d1e519-87df-5d8b-bfa5-d5db9bfa206a

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10*)
| table([timestamp, ComputerName])
| limit(1000)
