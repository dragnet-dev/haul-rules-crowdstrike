// Dragnet [Ransomware]: dragnet-ransomware-2025-1794 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: f58696d2-5579-5dcc-82e3-783d02fb7c1e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
