// Dragnet [Ransomware]: dragnet-ransomware-2025-5342 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 45f42210-819d-58a9-93f4-1dc9a33ab7bd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
