// Dragnet [Container]: dragnet-container-2026-0354 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: aa51d1a2-32a9-5990-ad1a-cf5d8de50db5

#event_simpleName=*
| (ImageFileName = *amazonlinux:1* OR ImageFileName = *chainguard:* OR ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10*)
| table([timestamp, ComputerName])
| limit(1000)
