// Dragnet [Ransomware]: dragnet-ransomware-2026-0371 — Mass File Rename (dragonforce)
// Status: stable | Level: high | ID: eb932f74-91aa-51bb-a67a-ff3b9d0c29f2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
