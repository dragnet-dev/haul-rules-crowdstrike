// Dragnet [Ransomware]: dragnet-ransomware-2023-3655 — Mass File Rename (moneymessage)
// Status: experimental | Level: high | ID: e65242cd-8f82-5704-912f-01c74aab5890

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
