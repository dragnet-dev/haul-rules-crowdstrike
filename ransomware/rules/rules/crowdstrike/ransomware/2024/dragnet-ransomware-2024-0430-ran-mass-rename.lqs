// Dragnet [Ransomware]: dragnet-ransomware-2024-0430 — Mass File Rename (play)
// Status: experimental | Level: high | ID: cecd8b0b-40b6-5a83-bf88-afdab77c5241

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
