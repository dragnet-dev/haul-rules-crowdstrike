// Dragnet [Ransomware]: dragnet-ransomware-2024-3013 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: b804c5f1-a499-5296-b24f-aac9fc641d01

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
