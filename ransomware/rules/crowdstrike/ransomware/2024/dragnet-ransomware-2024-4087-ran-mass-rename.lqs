// Dragnet [Ransomware]: dragnet-ransomware-2024-4087 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 79fccab8-12ce-5afe-ab37-a461ba8c8500

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
