// Dragnet [Ransomware]: dragnet-ransomware-2023-0988 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 471e0fc8-fc44-582a-9126-618141764b25

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
