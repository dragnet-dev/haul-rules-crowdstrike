// Dragnet [Ransomware]: dragnet-ransomware-2025-2151 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: 6519e764-6e23-5d56-9d04-0d54033f822e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
