// Dragnet [Ransomware]: dragnet-ransomware-2024-1952 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 056c7b33-6931-578c-b240-482163bd990e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
