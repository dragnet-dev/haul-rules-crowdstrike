// Dragnet [Ransomware]: dragnet-ransomware-2023-3943 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: adcf1238-67f9-516f-ad77-919560e344d1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
