// Dragnet [Ransomware]: dragnet-ransomware-2023-1972 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: def5ce14-a155-5c81-a464-b1aeaea60596

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
