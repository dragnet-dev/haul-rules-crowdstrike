// Dragnet [Ransomware]: dragnet-ransomware-2025-4321 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 701ebd4f-bcd8-5b89-83c8-6fb69caed2cd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
