// Dragnet [Ransomware]: dragnet-ransomware-2025-0583 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 2f496f4a-adde-55df-85a9-f0ad7cd41fec

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
