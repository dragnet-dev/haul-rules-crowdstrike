// Dragnet [Ransomware]: dragnet-ransomware-2022-0528 — Mass File Rename (vicesociety)
// Status: deprecated | Level: high | ID: 881619e7-cc0f-5f2e-ba2d-d7365792580b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
