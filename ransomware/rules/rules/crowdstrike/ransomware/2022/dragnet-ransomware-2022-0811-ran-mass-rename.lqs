// Dragnet [Ransomware]: dragnet-ransomware-2022-0811 — Mass File Rename (karakurt)
// Status: experimental | Level: high | ID: b7b6fa98-e5a4-5e0c-9f77-8108e601e5e7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
