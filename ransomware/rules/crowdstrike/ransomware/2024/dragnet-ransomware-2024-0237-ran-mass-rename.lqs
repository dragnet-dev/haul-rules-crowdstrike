// Dragnet [Ransomware]: dragnet-ransomware-2024-0237 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 7d75867e-3b94-53c0-b6b2-5dbcaf4eeec0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
