// Dragnet [Ransomware]: dragnet-ransomware-2026-0472 — Mass File Rename (SilentRansomGroup)
// Status: deprecated | Level: high | ID: 67b7e3cb-508f-5a81-a194-11a6bd32d7a3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
