// Dragnet [Ransomware]: dragnet-ransomware-2025-5933 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 1d9cccad-607a-5e86-824e-256c7e2c2ba8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
