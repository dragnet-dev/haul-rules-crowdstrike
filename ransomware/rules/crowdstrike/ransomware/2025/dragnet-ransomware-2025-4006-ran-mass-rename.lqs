// Dragnet [Ransomware]: dragnet-ransomware-2025-4006 — Mass File Rename (pear)
// Status: experimental | Level: high | ID: c23a9d7b-c5ee-59e3-92b2-2facfec71bb5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
