// Dragnet [Container]: dragnet-container-2026-2444 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 6112ee06-d104-5076-9345-d8ec51f7713c

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
