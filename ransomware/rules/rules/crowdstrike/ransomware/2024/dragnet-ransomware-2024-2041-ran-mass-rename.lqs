// Dragnet [Ransomware]: dragnet-ransomware-2024-2041 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: cc637311-abac-54bf-8608-d850f49de5d0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
