// Dragnet [Ransomware]: dragnet-ransomware-2024-4143 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 1bb604f0-1619-5e5a-982b-2895b8691760

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
