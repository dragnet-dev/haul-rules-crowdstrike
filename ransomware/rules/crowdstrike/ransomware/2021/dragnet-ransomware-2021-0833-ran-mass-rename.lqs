// Dragnet [Ransomware]: dragnet-ransomware-2021-0833 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 10c2815e-c10e-5eec-9f98-a924e5c2b217

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
