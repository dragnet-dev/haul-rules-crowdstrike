// Dragnet [Ransomware]: dragnet-ransomware-2025-3937 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: 524375d7-1d63-56ea-bbcf-2b3e9dee6239

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
