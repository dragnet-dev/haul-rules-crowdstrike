// Dragnet [Ransomware]: dragnet-ransomware-2022-0736 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: e6879ffd-a30d-57cf-bbd9-cf6d9d0b09a4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
