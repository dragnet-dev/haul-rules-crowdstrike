// Dragnet [Ransomware]: dragnet-ransomware-2026-2033 — Mass File Rename (ALP-001)
// Status: stable | Level: high | ID: 2c48ba41-e4d0-5c1a-b28c-54b21c4555c4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
