// Dragnet [Ransomware]: dragnet-ransomware-2024-1348 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 6f819b07-e499-5a4f-8bcc-274c900b728a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
