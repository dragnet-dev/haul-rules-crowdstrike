// Dragnet [Ransomware]: dragnet-ransomware-2022-1798 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: c4d99a04-8d87-52a2-80c4-f7f12328bb08

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
