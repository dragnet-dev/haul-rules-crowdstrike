// Dragnet [Container]: dragnet-container-2024-1560 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: f5dd094a-cc03-54b4-a0b3-d0b84f243d96

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:8* OR ImageFileName = *debian:9* OR ImageFileName = *ubuntu:14.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
