// Dragnet [Ransomware]: dragnet-ransomware-2023-3665 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 4007a2cf-93bf-5af5-ae3e-9283494a0a83

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
