// Dragnet [Ransomware]: dragnet-ransomware-2023-2809 — Mass File Rename (malas)
// Status: experimental | Level: high | ID: bbc364d4-c86f-5d7f-af50-694f4e83e94c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
