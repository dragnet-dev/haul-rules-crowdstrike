// Dragnet [Ransomware]: dragnet-ransomware-2025-0842 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: 224341e2-574d-564e-814e-29fbd09212ab

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
