// Dragnet [Ransomware]: dragnet-ransomware-2025-3825 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 98557771-8127-5e4b-a40d-94042a169096

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
