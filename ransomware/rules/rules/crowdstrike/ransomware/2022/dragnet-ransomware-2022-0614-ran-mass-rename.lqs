// Dragnet [Ransomware]: dragnet-ransomware-2022-0614 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: cbccc14c-f77a-517d-9502-bb60ff93d21b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
