// Dragnet [Ransomware]: dragnet-ransomware-2024-2784 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 08662fd3-654a-52e2-8d9a-a34e753c79fc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
