// Dragnet [Ransomware]: dragnet-ransomware-2025-6219 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: cf37f7c2-816c-5b0a-98e5-48017ab3e1a2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
