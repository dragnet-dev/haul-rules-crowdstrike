// Dragnet [Ransomware]: dragnet-ransomware-2025-6718 — Mass File Rename (gunra)
// Status: experimental | Level: high | ID: 5dbc2247-6590-52db-9a23-a02af854d9d4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
