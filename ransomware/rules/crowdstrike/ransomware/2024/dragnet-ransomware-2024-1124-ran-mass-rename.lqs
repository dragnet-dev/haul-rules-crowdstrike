// Dragnet [Ransomware]: dragnet-ransomware-2024-1124 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 181ed94c-be39-597e-a6df-bd53f13a3d95

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
