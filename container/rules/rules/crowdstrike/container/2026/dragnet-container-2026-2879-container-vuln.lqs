// Dragnet [Container]: dragnet-container-2026-2879 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 7316fbbf-d642-5bf6-87b3-bafcee5f16eb

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
