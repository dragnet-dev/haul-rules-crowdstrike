// Dragnet [Ransomware]: dragnet-ransomware-2025-4959 — Mass File Rename (stormous)
// Status: experimental | Level: high | ID: bfe7d1d8-18e9-568d-b44c-8a85696af3ba

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
