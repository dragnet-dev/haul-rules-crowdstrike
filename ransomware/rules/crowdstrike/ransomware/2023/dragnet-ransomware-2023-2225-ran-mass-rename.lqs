// Dragnet [Ransomware]: dragnet-ransomware-2023-2225 — Mass File Rename (toufan)
// Status: deprecated | Level: high | ID: 31df4c81-f038-59f3-87e2-95f01bdd12d0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
