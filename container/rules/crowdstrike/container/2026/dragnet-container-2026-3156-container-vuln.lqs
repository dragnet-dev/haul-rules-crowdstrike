// Dragnet [Container]: dragnet-container-2026-3156 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 81ba9b2a-9463-57f6-9790-857a889c639c

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:5*)
| table([timestamp, ComputerName])
| limit(1000)
