// Dragnet [Ransomware]: dragnet-ransomware-2023-0146 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 80b0e275-b671-5e2d-8a68-6428a35eb3c4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
