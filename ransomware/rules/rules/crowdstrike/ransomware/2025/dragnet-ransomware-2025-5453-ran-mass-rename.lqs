// Dragnet [Ransomware]: dragnet-ransomware-2025-5453 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 382fefc9-8d3f-5adc-8ca1-b914cac7bfcf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
