// Dragnet [Ransomware]: dragnet-ransomware-2026-2373 — Mass File Rename (kairos)
// Status: deprecated | Level: high | ID: 92a9c6cb-4fad-59ba-a70d-4802b8a67d6e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
