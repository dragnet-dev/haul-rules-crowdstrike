// Dragnet [Ransomware]: dragnet-ransomware-2022-2423 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: c64353f3-5a22-5126-b25c-ce184aa17bc0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
