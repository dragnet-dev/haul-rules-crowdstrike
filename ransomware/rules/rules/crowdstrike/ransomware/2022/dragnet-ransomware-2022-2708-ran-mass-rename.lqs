// Dragnet [Ransomware]: dragnet-ransomware-2022-2708 — Mass File Rename (sparta)
// Status: deprecated | Level: high | ID: 4a443713-d690-5bb6-b9c2-0438959c0cd1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
