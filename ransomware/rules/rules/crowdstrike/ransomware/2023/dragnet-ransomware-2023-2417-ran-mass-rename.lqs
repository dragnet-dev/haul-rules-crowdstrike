// Dragnet [Ransomware]: dragnet-ransomware-2023-2417 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 13792ff6-c70a-520a-9590-0f1f9173a5b9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
