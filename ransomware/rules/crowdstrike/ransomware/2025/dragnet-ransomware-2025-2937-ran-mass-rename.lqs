// Dragnet [Ransomware]: dragnet-ransomware-2025-2937 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 24c2627f-f68d-5308-ae74-401f8fd0f715

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
