// Dragnet [Ransomware]: dragnet-ransomware-2024-0109 — Mass File Rename (ElDorado)
// Status: experimental | Level: high | ID: 86803d88-3946-5fa0-98b7-fad9278f2245

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
