// Dragnet [Ransomware]: dragnet-ransomware-2024-3566 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 7347884c-c159-54dc-9d29-df180905e331

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
