// Dragnet [Ransomware]: dragnet-ransomware-2023-2879 — Mass File Rename (malas)
// Status: experimental | Level: high | ID: e3c0e4f1-77c2-522c-946d-d9a092cd9b85

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
