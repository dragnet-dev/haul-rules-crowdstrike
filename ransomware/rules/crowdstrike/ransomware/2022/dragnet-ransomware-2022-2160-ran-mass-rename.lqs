// Dragnet [Ransomware]: dragnet-ransomware-2022-2160 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 6813ab39-aa6d-576e-baf3-33b5bcef1793

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
