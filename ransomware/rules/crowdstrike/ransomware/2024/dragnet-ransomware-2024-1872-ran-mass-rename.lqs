// Dragnet [Ransomware]: dragnet-ransomware-2024-1872 — Mass File Rename (redransomware)
// Status: deprecated | Level: high | ID: 92aa722e-7d3a-5fb7-8412-fe249d9e2a8e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
