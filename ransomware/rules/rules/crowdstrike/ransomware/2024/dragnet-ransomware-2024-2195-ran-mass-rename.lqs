// Dragnet [Ransomware]: dragnet-ransomware-2024-2195 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 14f54779-d6cd-5f54-8f43-2385c6799567

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
