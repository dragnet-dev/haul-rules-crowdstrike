// Dragnet [Ransomware]: dragnet-ransomware-2024-2188 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 6e11a2ad-135d-5783-9cfc-18545fdc6c56

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
