// Dragnet [Ransomware]: dragnet-ransomware-2025-1778 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 9af309d7-cc84-51c5-a836-b5562e43c9bd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
