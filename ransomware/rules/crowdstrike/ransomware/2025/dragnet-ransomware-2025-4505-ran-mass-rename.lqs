// Dragnet [Ransomware]: dragnet-ransomware-2025-4505 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 3aef009d-4e9b-5131-893b-f4b00fd07101

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
