// Dragnet [Ransomware]: dragnet-ransomware-2024-1377 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: a4aff4a8-8fad-5fc8-aca2-fec16212759a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
