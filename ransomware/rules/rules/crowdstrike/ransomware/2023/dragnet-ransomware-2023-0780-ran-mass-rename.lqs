// Dragnet [Ransomware]: dragnet-ransomware-2023-0780 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: dcc10846-6ddd-5e35-b294-44b8f24bec79

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
