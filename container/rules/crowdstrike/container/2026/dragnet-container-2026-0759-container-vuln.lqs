// Dragnet [Container]: dragnet-container-2026-0759 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 4904d609-0107-53f7-b83c-a028d5dd9461

#event_simpleName=*
| (ImageFileName = *amazonlinux:1* OR ImageFileName = *chainguard:* OR ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *ubuntu:12.04*)
| table([timestamp, ComputerName])
| limit(1000)
