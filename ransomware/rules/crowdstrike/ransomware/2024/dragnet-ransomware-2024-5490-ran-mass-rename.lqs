// Dragnet [Ransomware]: dragnet-ransomware-2024-5490 — Mass File Rename (abyss)
// Status: deprecated | Level: high | ID: 1393c006-dc75-5671-8924-6161865bdab2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
