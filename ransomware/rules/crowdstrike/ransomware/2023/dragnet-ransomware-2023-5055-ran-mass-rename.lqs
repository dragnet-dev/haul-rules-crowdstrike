// Dragnet [Ransomware]: dragnet-ransomware-2023-5055 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: b7e31f26-d378-5c78-8964-53626fc67979

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
