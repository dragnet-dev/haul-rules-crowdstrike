// Dragnet [Ransomware]: dragnet-ransomware-2024-0268 — Mass File Rename (trigona)
// Status: experimental | Level: high | ID: 8e5d0e1a-d29b-5a06-9d35-d833eece9f93

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
