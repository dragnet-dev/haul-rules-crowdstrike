// Dragnet [Ransomware]: dragnet-ransomware-2024-4345 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 7b76f663-2a75-5ef1-95ec-7823988c3ff8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
