// Dragnet [Ransomware]: dragnet-ransomware-2025-6949 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 8f60de22-edc1-5ca7-835c-4ebf4156390d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
