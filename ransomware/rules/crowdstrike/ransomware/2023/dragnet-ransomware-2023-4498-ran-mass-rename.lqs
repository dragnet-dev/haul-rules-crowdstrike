// Dragnet [Ransomware]: dragnet-ransomware-2023-4498 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 6f71f16b-83a4-5abe-9eff-f6ab6792bf4e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
