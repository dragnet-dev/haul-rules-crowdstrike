// Dragnet [Ransomware]: dragnet-ransomware-2025-0613 — Mass File Rename (beast)
// Status: experimental | Level: high | ID: 54151506-ca9a-5e81-af34-cf62b04a5e0c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
