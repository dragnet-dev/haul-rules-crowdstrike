// Dragnet [Ransomware]: dragnet-ransomware-2024-2614 — Mass File Rename (meow)
// Status: experimental | Level: high | ID: 683472de-f1ed-5adc-bb9a-51141b05be08

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
