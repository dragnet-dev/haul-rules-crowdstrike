// Dragnet [Container]: dragnet-container-2026-2544 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 02bcf8ec-2cc6-5ae4-9cda-b12ce64fbdd1

#event_simpleName=*
| (ImageFileName = *amazonlinux:2023* OR ImageFileName = *azure linux:3.0* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
