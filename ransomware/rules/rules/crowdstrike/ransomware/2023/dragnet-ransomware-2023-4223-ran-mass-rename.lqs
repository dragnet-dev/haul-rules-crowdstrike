// Dragnet [Ransomware]: dragnet-ransomware-2023-4223 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 74c4d228-16c3-58eb-973f-c44b8798a611

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
