// Dragnet [Ransomware]: dragnet-ransomware-2025-4515 — Mass File Rename (warlock)
// Status: deprecated | Level: high | ID: d657a789-58a3-589d-ac71-330cbb44a420

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
