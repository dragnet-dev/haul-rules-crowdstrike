// Dragnet [Ransomware]: dragnet-ransomware-2025-7051 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: aee7a49d-dfdc-587b-a88b-24d495788cdb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
