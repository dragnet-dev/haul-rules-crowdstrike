// Dragnet [Container]: dragnet-container-2024-0519 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 25c2a820-3df3-5c3c-b195-f248745f9faa

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *ubuntu:16.04-ESM* OR ImageFileName = *ubuntu:18.04-ESM* OR ImageFileName = *ubuntu:20.04* OR ImageFileName = *ubuntu:20.04-ESM* OR ImageFileName = *ubuntu:22.04*)
| table([timestamp, ComputerName])
| limit(1000)
