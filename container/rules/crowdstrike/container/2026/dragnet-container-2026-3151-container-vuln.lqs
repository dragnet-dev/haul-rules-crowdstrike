// Dragnet [Container]: dragnet-container-2026-3151 — Vulnerable Base Image Pull
// Status: deprecated | Level: medium | ID: 1b5bd029-1a53-5147-a8d2-2234e2e212cc

#event_simpleName=*
| (ImageFileName = *alpine:3.24* OR ImageFileName = *alpine edge:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
