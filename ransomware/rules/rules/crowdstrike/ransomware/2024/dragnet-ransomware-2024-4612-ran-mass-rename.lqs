// Dragnet [Ransomware]: dragnet-ransomware-2024-4612 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 09c6f6fe-81fe-55d5-8903-a3ebc1f51a2c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
