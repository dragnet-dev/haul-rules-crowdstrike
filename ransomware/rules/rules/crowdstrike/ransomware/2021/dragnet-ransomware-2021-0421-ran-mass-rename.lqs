// Dragnet [Ransomware]: dragnet-ransomware-2021-0421 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 9327512a-1bf6-5417-b8fa-02f14bc4c731

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
