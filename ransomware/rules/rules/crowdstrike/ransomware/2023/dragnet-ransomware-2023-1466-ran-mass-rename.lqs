// Dragnet [Ransomware]: dragnet-ransomware-2023-1466 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 3c89beb0-d910-5baa-a715-ed7fdda00d91

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
