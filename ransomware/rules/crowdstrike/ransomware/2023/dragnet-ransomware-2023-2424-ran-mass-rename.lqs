// Dragnet [Ransomware]: dragnet-ransomware-2023-2424 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 5d192fe8-41db-54df-a133-9f148520adf1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
