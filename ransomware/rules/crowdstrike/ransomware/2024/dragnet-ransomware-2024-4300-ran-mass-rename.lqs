// Dragnet [Ransomware]: dragnet-ransomware-2024-4300 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 40493e94-a21d-5aa1-9bd7-8179506874b0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
