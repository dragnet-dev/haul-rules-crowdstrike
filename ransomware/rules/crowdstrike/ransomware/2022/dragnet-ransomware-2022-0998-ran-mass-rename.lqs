// Dragnet [Ransomware]: dragnet-ransomware-2022-0998 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 8e6fd57a-9881-5ddf-9d4e-14e000a1cce9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
