// Dragnet [Ransomware]: dragnet-ransomware-2025-4204 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: 6c82ee48-9baf-55de-96d8-313e39631e1d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
