// Dragnet [Ransomware]: dragnet-ransomware-2026-0639 — Mass File Rename (interlock)
// Status: test | Level: high | ID: eca86f02-b778-54cc-b088-38364adc7fc3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
