// Dragnet [Ransomware]: dragnet-ransomware-2025-2940 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 460e82d1-5b4c-5d64-b5a6-c3a19e420233

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
