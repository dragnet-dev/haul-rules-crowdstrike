// Dragnet [Ransomware]: dragnet-ransomware-2025-3697 — Mass File Rename (cloak)
// Status: deprecated | Level: high | ID: 69fa09a5-24cd-5c9e-bf56-420b52aea7af

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
