// Dragnet [Ransomware]: dragnet-ransomware-2025-0148 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 2f7ccb5a-ad70-53db-8432-4d16f5de026a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
