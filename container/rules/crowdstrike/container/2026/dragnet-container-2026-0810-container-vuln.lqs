// Dragnet [Container]: dragnet-container-2026-0810 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 20475774-1daa-55be-8902-bed3fb39bb05

#event_simpleName=*
| (ImageFileName = *chainguard:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
