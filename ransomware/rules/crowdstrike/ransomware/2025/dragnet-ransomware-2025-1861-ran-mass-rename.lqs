// Dragnet [Ransomware]: dragnet-ransomware-2025-1861 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 5b5185e4-d9b9-5c95-96e5-41d9c0318dc1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
