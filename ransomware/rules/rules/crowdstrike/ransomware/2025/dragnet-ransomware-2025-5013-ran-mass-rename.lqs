// Dragnet [Ransomware]: dragnet-ransomware-2025-5013 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 156b2bb1-fe83-5e25-a5e3-bf883c25cdcd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
