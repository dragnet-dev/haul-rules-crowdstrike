// Dragnet [Ransomware]: dragnet-ransomware-2022-0731 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 4cf4bc38-2f84-514f-ae92-912c1b10c15f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
