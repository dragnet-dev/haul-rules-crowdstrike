// Dragnet [Container]: dragnet-container-2026-0187 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 79376808-a705-5ccf-a0be-c94b7abde576

#event_simpleName=*
| (ImageFileName = *chainguard:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
