// Dragnet [Ransomware]: dragnet-ransomware-2025-0096 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: beeaa79b-289f-5412-b9a2-03ac255109bd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
