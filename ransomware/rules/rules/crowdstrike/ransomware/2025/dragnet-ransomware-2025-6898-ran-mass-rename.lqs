// Dragnet [Ransomware]: dragnet-ransomware-2025-6898 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: e1e2de0c-863a-5c16-b120-2fa5c52c2932

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
