// Dragnet [Ransomware]: dragnet-ransomware-2024-1834 — Mass File Rename (meow)
// Status: experimental | Level: high | ID: 12ea42ab-339d-590b-96fb-b7f8db25b1c1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
