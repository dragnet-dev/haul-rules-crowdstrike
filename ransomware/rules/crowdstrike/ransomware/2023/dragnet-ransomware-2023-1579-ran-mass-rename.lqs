// Dragnet [Ransomware]: dragnet-ransomware-2023-1579 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: 22556b02-0959-551c-852e-db2e10a3e01c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
