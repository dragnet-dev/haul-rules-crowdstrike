// Dragnet [Ransomware]: dragnet-ransomware-2024-3709 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: 3432a580-4baa-5e23-8962-8c10d6a98f75

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
