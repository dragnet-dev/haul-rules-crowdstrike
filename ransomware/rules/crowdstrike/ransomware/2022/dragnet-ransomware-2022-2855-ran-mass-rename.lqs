// Dragnet [Ransomware]: dragnet-ransomware-2022-2855 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 405d4388-7eab-5f31-b526-266e3379b22d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
