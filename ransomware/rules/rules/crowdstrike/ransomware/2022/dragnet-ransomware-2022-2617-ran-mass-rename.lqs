// Dragnet [Ransomware]: dragnet-ransomware-2022-2617 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: e87f2a3f-8573-5692-b6d6-d8fcabe74a15

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
