// Dragnet [Ransomware]: dragnet-ransomware-2025-4767 — Mass File Rename (sinobi)
// Status: experimental | Level: high | ID: 405daab6-e028-5e99-9576-93b1238af5b6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
