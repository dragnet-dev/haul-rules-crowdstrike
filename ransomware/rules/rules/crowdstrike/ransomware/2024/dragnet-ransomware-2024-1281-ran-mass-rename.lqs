// Dragnet [Ransomware]: dragnet-ransomware-2024-1281 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: d4a2bff9-783e-5f21-b46c-e5798d0a87b1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
