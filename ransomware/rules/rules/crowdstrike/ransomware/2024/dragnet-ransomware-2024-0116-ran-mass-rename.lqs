// Dragnet [Ransomware]: dragnet-ransomware-2024-0116 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: e9d9c76d-98fc-567b-96ea-8e6c3f25ff18

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
