// Dragnet [Ransomware]: dragnet-ransomware-2024-3821 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: c70fb8a1-895e-5fa5-a00e-0fc161b4ab90

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
