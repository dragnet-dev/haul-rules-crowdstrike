// Dragnet [Ransomware]: dragnet-ransomware-2023-1708 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 135b6e1e-2248-5c05-be18-9321347a923b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
