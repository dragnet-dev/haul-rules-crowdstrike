// Dragnet [Ransomware]: dragnet-ransomware-2024-2374 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 8cc865ad-5fef-566d-96c1-fcb06de100fa

#event_simpleName=ProcessRollup2
| (CommandLine = *recoveryenabled no* OR CommandLine = *bootstatuspolicy ignoreallfailures*) AND ImageFileName = *\bcdedit.exe
| table([timestamp, ComputerName, ImageFileName, CommandLine, ParentImageFileName])
| limit(1000)
