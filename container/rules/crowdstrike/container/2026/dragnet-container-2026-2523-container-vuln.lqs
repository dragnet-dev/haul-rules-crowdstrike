// Dragnet [Container]: dragnet-container-2026-2523 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 0f95de9f-ff1a-57f5-93c4-fe1936edcbbb

#event_simpleName=*
| (ImageFileName = *debian:7* OR ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *oraclelinux:7* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:14.04*)
| table([timestamp, ComputerName])
| limit(1000)
