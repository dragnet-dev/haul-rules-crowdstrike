// Dragnet [Ransomware]: dragnet-ransomware-2022-2955 — Mass File Rename (blackbasta)
// Status: deprecated | Level: high | ID: 40b01f88-353a-5844-911c-3db249e47ef8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
