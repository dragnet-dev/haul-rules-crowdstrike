// Dragnet [Ransomware]: dragnet-ransomware-2026-1618 — Mass File Rename (dragonforce)
// Status: stable | Level: high | ID: a09de12f-ffe1-56f3-a5cf-b410e6e03127

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
