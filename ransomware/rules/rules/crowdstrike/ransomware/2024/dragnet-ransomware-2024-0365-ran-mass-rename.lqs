// Dragnet [Ransomware]: dragnet-ransomware-2024-0365 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 509e1c4d-b86b-52b4-a76c-520ee59f8368

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
