// Dragnet [Ransomware]: dragnet-ransomware-2025-7772 — Mass File Rename (pear)
// Status: experimental | Level: high | ID: dec98868-57dc-5987-bb50-e368c049846d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
