// Dragnet [Ransomware]: dragnet-ransomware-2023-1435 — Mass File Rename (stormous)
// Status: experimental | Level: high | ID: c677f709-56dc-53d8-987c-e3b95c411ff5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
