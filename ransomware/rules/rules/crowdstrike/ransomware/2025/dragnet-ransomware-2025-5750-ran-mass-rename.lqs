// Dragnet [Ransomware]: dragnet-ransomware-2025-5750 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: 64c198e6-379d-5973-bc85-3c76bb9fcf1a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
