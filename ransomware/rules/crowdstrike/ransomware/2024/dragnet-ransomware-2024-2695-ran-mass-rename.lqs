// Dragnet [Ransomware]: dragnet-ransomware-2024-2695 — Mass File Rename (kairos)
// Status: experimental | Level: high | ID: e1028369-a404-5893-8059-b7f2f93289fb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
