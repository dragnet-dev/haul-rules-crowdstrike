// Dragnet [Ransomware]: dragnet-ransomware-2021-0321 — Mass File Rename (pay2key)
// Status: deprecated | Level: high | ID: d66c7201-ced0-5eab-82bb-cc73d848115c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
