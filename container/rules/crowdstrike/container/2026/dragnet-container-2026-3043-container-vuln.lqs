// Dragnet [Container]: dragnet-container-2026-3043 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 37f8e84f-f8fc-597e-924e-6dfa35f0730d

#event_simpleName=*
| (ImageFileName = *chainguard:* OR ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
