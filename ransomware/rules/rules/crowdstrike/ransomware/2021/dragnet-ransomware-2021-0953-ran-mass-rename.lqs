// Dragnet [Ransomware]: dragnet-ransomware-2021-0953 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 92f81f44-f216-5b15-a275-e98af24530b9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
