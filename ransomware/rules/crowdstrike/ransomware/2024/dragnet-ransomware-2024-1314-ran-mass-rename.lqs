// Dragnet [Ransomware]: dragnet-ransomware-2024-1314 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 1361d387-585c-5d02-9ab5-ce485e85561c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
