// Dragnet [Ransomware]: dragnet-ransomware-2025-7409 — Mass File Rename (hellcat)
// Status: deprecated | Level: high | ID: ce348853-7155-5410-8fb4-93b32144dd03

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
