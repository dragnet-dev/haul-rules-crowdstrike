// Dragnet [Ransomware]: dragnet-ransomware-2024-0918 — Mass File Rename (underground)
// Status: experimental | Level: high | ID: 142b94f9-f5e7-5c18-abb8-3b89836af0d6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
