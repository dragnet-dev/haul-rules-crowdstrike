// Dragnet [Ransomware]: dragnet-ransomware-2022-2737 — Mass File Rename (blackbasta)
// Status: deprecated | Level: high | ID: 5c810bac-5745-5b31-b04d-702fec87c2f7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
