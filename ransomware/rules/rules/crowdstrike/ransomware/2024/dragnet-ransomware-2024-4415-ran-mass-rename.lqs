// Dragnet [Ransomware]: dragnet-ransomware-2024-4415 — Mass File Rename (raworld)
// Status: experimental | Level: high | ID: 480919e3-ffec-55d3-8695-289a99d33563

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
