// Dragnet [Ransomware]: dragnet-ransomware-2024-0825 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: eab0f57f-8f97-5e35-a1a3-5ecc4d685ccb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
