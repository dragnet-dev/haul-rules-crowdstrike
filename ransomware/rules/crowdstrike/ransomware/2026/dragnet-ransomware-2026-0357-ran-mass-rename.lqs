// Dragnet [Ransomware]: dragnet-ransomware-2026-0357 — Mass File Rename (medusalocker)
// Status: stable | Level: high | ID: 7300b5a9-0661-5c05-ac97-35d0ff362a1c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
