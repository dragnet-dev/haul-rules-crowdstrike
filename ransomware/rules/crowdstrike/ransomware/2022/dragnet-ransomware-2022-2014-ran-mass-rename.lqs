// Dragnet [Ransomware]: dragnet-ransomware-2022-2014 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 180ca2c0-072a-575a-95ab-774550cd1e09

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
