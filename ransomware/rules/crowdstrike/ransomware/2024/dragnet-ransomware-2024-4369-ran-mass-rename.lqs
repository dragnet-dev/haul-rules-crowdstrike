// Dragnet [Ransomware]: dragnet-ransomware-2024-4369 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: b8516e34-6edb-5ea0-849a-70888ce6af10

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
