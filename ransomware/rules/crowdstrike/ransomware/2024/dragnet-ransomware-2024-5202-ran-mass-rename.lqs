// Dragnet [Ransomware]: dragnet-ransomware-2024-5202 — Mass File Rename (dAn0n)
// Status: experimental | Level: high | ID: 8a3ae001-7421-5aab-8517-698bf3c24469

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
