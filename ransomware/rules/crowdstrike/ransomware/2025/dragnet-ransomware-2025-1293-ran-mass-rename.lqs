// Dragnet [Ransomware]: dragnet-ransomware-2025-1293 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: f609622b-8dc4-5720-b80a-9eaff6622e1b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
