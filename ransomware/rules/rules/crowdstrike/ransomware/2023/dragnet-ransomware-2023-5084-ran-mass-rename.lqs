// Dragnet [Ransomware]: dragnet-ransomware-2023-5084 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 55708767-f2f1-5d74-bc08-0f1386d16ca0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
