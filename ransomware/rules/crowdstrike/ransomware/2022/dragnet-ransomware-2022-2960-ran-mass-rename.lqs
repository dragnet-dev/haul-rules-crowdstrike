// Dragnet [Ransomware]: dragnet-ransomware-2022-2960 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 162268a0-c407-5444-b075-263b6c84b2a6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
