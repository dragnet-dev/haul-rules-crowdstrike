// Dragnet [Ransomware]: dragnet-ransomware-2024-0846 — Mass File Rename (nitrogen)
// Status: experimental | Level: high | ID: 2aac0dd1-4e7c-569e-a2ba-b4ad3a9d505d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
