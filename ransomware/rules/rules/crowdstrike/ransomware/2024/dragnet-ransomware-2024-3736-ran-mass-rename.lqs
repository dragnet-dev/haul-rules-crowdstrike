// Dragnet [Ransomware]: dragnet-ransomware-2024-3736 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 2cad1e79-fc1e-5d2c-94b4-e47b7c226fc3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
