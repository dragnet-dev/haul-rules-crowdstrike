// Dragnet [Container]: dragnet-container-2026-0026 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 294d9185-fd7d-5693-9319-cb8563fae631

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:8* OR ImageFileName = *debian:9*)
| table([timestamp, ComputerName])
| limit(1000)
