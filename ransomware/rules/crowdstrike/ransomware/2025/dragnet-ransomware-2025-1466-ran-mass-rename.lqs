// Dragnet [Ransomware]: dragnet-ransomware-2025-1466 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 21b40c13-469e-5d03-84c5-eaf913983bad

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
