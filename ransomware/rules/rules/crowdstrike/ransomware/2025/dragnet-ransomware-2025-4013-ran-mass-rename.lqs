// Dragnet [Ransomware]: dragnet-ransomware-2025-4013 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: e63e24b8-87d6-5a3f-8509-ca75575b1d55

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
