// Dragnet [Ransomware]: dragnet-ransomware-2024-5213 — Mass File Rename (rhysida)
// Status: experimental | Level: high | ID: 13fc6ca0-e631-5650-a5ac-3b7646a89ab6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
