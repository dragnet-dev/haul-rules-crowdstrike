// Dragnet [Ransomware]: dragnet-ransomware-2022-2372 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 482b0903-1be6-504f-ae55-66c6ba83945e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
