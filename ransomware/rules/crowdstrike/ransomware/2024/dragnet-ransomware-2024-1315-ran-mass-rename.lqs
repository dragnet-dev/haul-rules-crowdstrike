// Dragnet [Ransomware]: dragnet-ransomware-2024-1315 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: a8b9ea74-7f9d-5feb-b7cb-fbb861634b0f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
