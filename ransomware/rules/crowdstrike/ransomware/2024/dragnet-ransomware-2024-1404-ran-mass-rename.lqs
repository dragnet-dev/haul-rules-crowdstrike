// Dragnet [Ransomware]: dragnet-ransomware-2024-1404 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: bf5b4e46-45d3-5522-9f45-c6dc9d0e49cf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
