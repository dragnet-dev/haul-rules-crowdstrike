// Dragnet [Ransomware]: dragnet-ransomware-2024-0826 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 212ff600-09ee-5f29-9dc8-1429752e46dd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
