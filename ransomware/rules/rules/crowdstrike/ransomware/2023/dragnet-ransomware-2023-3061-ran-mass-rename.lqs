// Dragnet [Ransomware]: dragnet-ransomware-2023-3061 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 0c6949c2-416f-5200-809d-a66863f63fd1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
