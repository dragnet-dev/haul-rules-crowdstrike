// Dragnet [Ransomware]: dragnet-ransomware-2025-1936 — Mass File Rename (interlock)
// Status: experimental | Level: high | ID: 53548091-2a8f-5a75-a678-693e943f0bae

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
