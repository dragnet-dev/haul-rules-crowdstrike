// Dragnet [Ransomware]: dragnet-ransomware-2023-0084 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 9eb44e3d-f43c-5f21-8fac-c6b51a225ae3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
