// Dragnet [Ransomware]: dragnet-ransomware-2026-3386 — Mass File Rename (dragonforce)
// Status: stable | Level: high | ID: 404893ac-0859-5129-98a1-ab09258ce57f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
