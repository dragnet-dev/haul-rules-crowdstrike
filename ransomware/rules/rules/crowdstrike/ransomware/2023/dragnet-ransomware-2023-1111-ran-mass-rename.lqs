// Dragnet [Ransomware]: dragnet-ransomware-2023-1111 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: b7ee3004-ad3f-54fe-9159-605e00af0b5f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
