// Dragnet [Ransomware]: dragnet-ransomware-2025-7708 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 8369377a-7155-5442-9dcf-b2a9ba7c9949

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
