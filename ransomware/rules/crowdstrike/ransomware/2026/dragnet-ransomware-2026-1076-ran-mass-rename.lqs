// Dragnet [Ransomware]: dragnet-ransomware-2026-1076 — Mass File Rename (thegentlemen)
// Status: test | Level: high | ID: e72841cf-1690-5a55-9527-957e4f5b3d1d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
