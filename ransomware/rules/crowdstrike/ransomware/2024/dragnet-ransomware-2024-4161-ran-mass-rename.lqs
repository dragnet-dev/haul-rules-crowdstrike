// Dragnet [Ransomware]: dragnet-ransomware-2024-4161 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 8495402e-cc71-5d2e-9b83-2ea53a8559dd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
