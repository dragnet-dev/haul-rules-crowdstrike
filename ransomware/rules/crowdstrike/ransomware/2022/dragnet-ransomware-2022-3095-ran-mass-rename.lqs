// Dragnet [Ransomware]: dragnet-ransomware-2022-3095 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: b10df4ef-c786-5e43-ba84-b002f691dd6c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
