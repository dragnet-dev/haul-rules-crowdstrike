// Dragnet [Container]: dragnet-container-2026-1964 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: def2b234-d94d-593d-8cdc-a9a039975425

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:5*)
| table([timestamp, ComputerName])
| limit(1000)
