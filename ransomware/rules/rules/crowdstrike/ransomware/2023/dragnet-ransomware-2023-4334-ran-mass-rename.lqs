// Dragnet [Ransomware]: dragnet-ransomware-2023-4334 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: a5c754d6-54f0-50fc-8ccd-fbfdb032b2a8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
