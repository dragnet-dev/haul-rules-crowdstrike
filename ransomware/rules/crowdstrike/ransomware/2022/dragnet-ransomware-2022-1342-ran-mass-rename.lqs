// Dragnet [Ransomware]: dragnet-ransomware-2022-1342 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 6ae268d7-d3c4-5c49-8822-0f0a47b431c1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
