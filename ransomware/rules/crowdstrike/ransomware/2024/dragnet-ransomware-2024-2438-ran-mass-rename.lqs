// Dragnet [Ransomware]: dragnet-ransomware-2024-2438 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 685db53d-7eb8-5988-beb5-557d71a02f8e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
