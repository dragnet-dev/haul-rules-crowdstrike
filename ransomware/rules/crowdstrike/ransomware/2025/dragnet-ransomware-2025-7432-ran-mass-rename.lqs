// Dragnet [Ransomware]: dragnet-ransomware-2025-7432 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 7acd16d3-5515-5cd0-bb45-89271fd28203

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
