// Dragnet [Ransomware]: dragnet-ransomware-2022-2545 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 7c937c31-9952-532a-81b4-662c56cf93b6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
