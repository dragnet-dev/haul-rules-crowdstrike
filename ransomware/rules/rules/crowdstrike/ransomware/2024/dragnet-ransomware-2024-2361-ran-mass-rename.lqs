// Dragnet [Ransomware]: dragnet-ransomware-2024-2361 — Mass File Rename (BrainCipher)
// Status: experimental | Level: high | ID: fb1aa7f5-a8dc-5b64-bd22-050daccc2096

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
