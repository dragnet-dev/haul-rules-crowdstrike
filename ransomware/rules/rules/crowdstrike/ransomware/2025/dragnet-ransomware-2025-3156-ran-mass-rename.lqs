// Dragnet [Ransomware]: dragnet-ransomware-2025-3156 — Mass File Rename (beast)
// Status: experimental | Level: high | ID: 997fea5e-9ca0-5a2c-a1c5-4b88e26192b9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
