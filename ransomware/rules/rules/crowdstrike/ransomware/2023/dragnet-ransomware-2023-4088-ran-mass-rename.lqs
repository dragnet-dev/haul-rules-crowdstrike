// Dragnet [Ransomware]: dragnet-ransomware-2023-4088 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 0d1f88a5-8b93-5088-8af0-77cec63357eb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
