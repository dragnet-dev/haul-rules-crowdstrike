// Dragnet [Ransomware]: dragnet-ransomware-2022-2572 — Mass File Rename (onyx)
// Status: deprecated | Level: high | ID: 35a4995c-7332-51d1-9602-8c36b2c1cbc4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
