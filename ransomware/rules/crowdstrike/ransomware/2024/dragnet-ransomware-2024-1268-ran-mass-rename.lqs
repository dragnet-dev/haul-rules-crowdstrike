// Dragnet [Ransomware]: dragnet-ransomware-2024-1268 — Mass File Rename (sensayq)
// Status: experimental | Level: high | ID: f939bf61-b5e3-5115-8231-58c9cd940481

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
