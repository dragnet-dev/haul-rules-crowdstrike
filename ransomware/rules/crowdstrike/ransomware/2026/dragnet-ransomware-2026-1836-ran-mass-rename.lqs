// Dragnet [Ransomware]: dragnet-ransomware-2026-1836 — Mass File Rename (moneymessage)
// Status: test | Level: high | ID: 94e16650-2788-558e-b668-d9fffcfbd9c4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
