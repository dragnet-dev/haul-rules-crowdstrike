// Dragnet [Ransomware]: dragnet-ransomware-2020-0182 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 49b309d5-438e-56c3-ae5f-035c3b024e26

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
