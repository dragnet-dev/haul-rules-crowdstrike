// Dragnet [Ransomware]: dragnet-ransomware-2023-3058 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 0248d15e-fc6e-5072-8927-12c3dea5c38f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
