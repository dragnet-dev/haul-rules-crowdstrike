// Dragnet [Container]: dragnet-container-2026-1242 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 3920f7b4-2a1b-5895-9f92-ceeda1bdc2ac

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:8* OR ImageFileName = *ubuntu:15.10*)
| table([timestamp, ComputerName])
| limit(1000)
