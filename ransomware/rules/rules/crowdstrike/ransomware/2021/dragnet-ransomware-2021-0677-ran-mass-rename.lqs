// Dragnet [Ransomware]: dragnet-ransomware-2021-0677 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: 584e23f9-56c3-5ee9-9efa-356965c790a5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
