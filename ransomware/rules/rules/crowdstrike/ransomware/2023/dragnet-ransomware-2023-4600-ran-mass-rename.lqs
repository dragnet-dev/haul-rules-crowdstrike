// Dragnet [Ransomware]: dragnet-ransomware-2023-4600 — Mass File Rename (avoslocker)
// Status: deprecated | Level: high | ID: 7cd0d9c2-a5ac-539b-b71e-265e32775819

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
