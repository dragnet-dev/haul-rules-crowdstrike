// Dragnet [Ransomware]: dragnet-ransomware-2024-4852 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: c38f44a5-1731-5f57-bd04-e838549febb2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
