// Dragnet [Ransomware]: dragnet-ransomware-2023-0122 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 7ebfb1e7-4ac8-5020-b44a-eb359457f7c5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
