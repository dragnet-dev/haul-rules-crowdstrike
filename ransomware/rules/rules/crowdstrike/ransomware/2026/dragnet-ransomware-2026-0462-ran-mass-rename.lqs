// Dragnet [Ransomware]: dragnet-ransomware-2026-0462 — Mass File Rename (incransom)
// Status: stable | Level: high | ID: 7eb6561f-72fe-59c5-b6a2-87db6f7777be

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
