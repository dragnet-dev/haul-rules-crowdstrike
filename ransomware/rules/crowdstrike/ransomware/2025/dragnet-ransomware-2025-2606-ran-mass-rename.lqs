// Dragnet [Ransomware]: dragnet-ransomware-2025-2606 — Mass File Rename (shinyhunters)
// Status: experimental | Level: high | ID: 270c66b4-e226-5a49-9917-e97ae44cf02f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
