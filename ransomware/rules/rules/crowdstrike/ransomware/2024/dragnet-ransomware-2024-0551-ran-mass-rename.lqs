// Dragnet [Ransomware]: dragnet-ransomware-2024-0551 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: d215c652-2bdd-5c47-86a8-093caa355306

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
