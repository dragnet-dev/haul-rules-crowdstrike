// Dragnet [Ransomware]: dragnet-ransomware-2025-6859 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 99ff88dc-905f-5d32-a4e9-4de3ef1e5571

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
