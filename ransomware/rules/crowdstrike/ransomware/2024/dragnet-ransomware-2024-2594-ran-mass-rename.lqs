// Dragnet [Ransomware]: dragnet-ransomware-2024-2594 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 70e4b579-24f2-5d0b-920c-84b333115760

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
