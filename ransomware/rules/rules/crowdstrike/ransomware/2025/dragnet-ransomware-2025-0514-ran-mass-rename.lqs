// Dragnet [Ransomware]: dragnet-ransomware-2025-0514 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 6d0003c2-7f27-588d-9b85-b4b958cdcf90

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
