// Dragnet [Ransomware]: dragnet-ransomware-2025-3452 — Mass File Rename (SilentRansomGroup)
// Status: deprecated | Level: high | ID: a022298e-ccee-55ab-b2ba-e9d7f0338553

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
