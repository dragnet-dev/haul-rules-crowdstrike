// Dragnet [Ransomware]: dragnet-ransomware-2025-2700 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: d0dcba9b-2e83-53a6-8723-024e282efb4f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
