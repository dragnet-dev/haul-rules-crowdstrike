// Dragnet [Container]: dragnet-container-2026-0062 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: a022325d-690e-511d-ae17-d5f9aea0662a

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *redhat/ubi9:*)
| table([timestamp, ComputerName])
| limit(1000)
