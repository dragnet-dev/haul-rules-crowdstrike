// Dragnet [Ransomware]: dragnet-ransomware-2026-0090 — Mass File Rename (lamashtu)
// Status: stable | Level: high | ID: c37f275c-a5f1-544e-ad28-607300de63e2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
