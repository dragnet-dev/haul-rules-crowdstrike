// Dragnet [Ransomware]: dragnet-ransomware-2024-0419 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 62b0b7ef-c1c2-578c-8edf-c30ba28aef0f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
