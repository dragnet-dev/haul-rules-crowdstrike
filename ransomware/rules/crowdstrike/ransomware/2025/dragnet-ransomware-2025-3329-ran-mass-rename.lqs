// Dragnet [Ransomware]: dragnet-ransomware-2025-3329 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 9362efa2-60f6-501b-b13b-21b90b1535b6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
