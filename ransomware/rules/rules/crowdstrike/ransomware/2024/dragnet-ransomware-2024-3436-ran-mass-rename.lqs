// Dragnet [Ransomware]: dragnet-ransomware-2024-3436 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: c5234b1f-f025-5d10-bc04-f9c5ba6c2503

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
