// Dragnet [Ransomware]: dragnet-ransomware-2023-0669 — Mass File Rename (snatch)
// Status: experimental | Level: high | ID: 59750e29-65fe-5549-996c-106ddd69aa66

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
