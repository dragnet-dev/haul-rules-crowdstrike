// Dragnet [Ransomware]: dragnet-ransomware-2025-1632 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: d99e837b-6bd3-54e6-8a9c-9578fc431820

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
