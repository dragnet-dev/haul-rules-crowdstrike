// Dragnet [Ransomware]: dragnet-ransomware-2025-0568 — Mass File Rename (anubis)
// Status: experimental | Level: high | ID: a5d00735-9591-5c56-8e33-4e816a0ba392

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
