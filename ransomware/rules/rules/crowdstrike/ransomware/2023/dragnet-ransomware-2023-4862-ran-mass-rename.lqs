// Dragnet [Ransomware]: dragnet-ransomware-2023-4862 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: b7ba1b17-dbf9-556a-a2f6-9126c01cc89d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
