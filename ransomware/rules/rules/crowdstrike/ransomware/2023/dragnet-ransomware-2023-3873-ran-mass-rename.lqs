// Dragnet [Ransomware]: dragnet-ransomware-2023-3873 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 9d656acc-3878-5b09-9edf-034ba58050ed

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
