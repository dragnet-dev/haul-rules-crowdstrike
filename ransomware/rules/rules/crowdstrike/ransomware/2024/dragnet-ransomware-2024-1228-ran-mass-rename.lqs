// Dragnet [Ransomware]: dragnet-ransomware-2024-1228 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: f528c3be-9230-57e4-8a9f-4347f3dda9f9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
