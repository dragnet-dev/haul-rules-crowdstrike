// Dragnet [Ransomware]: dragnet-ransomware-2025-2422 — Mass File Rename (thegentlemen)
// Status: experimental | Level: high | ID: 1fe7456d-704e-536f-960d-51ad98c457d6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
