// Dragnet [Ransomware]: dragnet-ransomware-2023-5242 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 3598751b-1055-55f8-8c98-bc973ee24ace

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
