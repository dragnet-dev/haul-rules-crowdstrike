// Dragnet [Ransomware]: dragnet-ransomware-2022-2588 — Mass File Rename (ragnarlocker)
// Status: experimental | Level: high | ID: 4f641ceb-5c7f-5432-9e13-53f4de38f7a1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
