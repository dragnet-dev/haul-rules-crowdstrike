// Dragnet [Ransomware]: dragnet-ransomware-2022-2826 — Mass File Rename (mindware)
// Status: deprecated | Level: high | ID: 3a9955f4-27a8-5ce8-9085-fcba55405de9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
