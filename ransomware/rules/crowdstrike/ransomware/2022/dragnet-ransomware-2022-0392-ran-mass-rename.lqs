// Dragnet [Ransomware]: dragnet-ransomware-2022-0392 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: d27b9423-b7fc-5117-b6d2-9c94559d89ed

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
