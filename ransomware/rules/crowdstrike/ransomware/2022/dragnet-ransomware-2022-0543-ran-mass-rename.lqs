// Dragnet [Ransomware]: dragnet-ransomware-2022-0543 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 20931c61-0df0-58f0-889e-971570b89918

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
