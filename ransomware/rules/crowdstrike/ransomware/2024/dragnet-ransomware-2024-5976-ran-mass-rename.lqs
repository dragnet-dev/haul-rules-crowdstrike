// Dragnet [Ransomware]: dragnet-ransomware-2024-5976 — Mass File Rename (SilentRansomGroup)
// Status: deprecated | Level: high | ID: 922debe1-d9dd-58ce-88a9-9ef31281104f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
