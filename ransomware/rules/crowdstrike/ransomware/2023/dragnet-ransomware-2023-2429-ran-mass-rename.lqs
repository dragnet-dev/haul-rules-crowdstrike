// Dragnet [Ransomware]: dragnet-ransomware-2023-2429 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: b4797cf5-0ab1-5e97-a76c-085972c5532b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
