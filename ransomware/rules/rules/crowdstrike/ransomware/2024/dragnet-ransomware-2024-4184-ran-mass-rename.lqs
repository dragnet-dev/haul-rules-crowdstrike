// Dragnet [Ransomware]: dragnet-ransomware-2024-4184 — Mass File Rename (underground)
// Status: experimental | Level: high | ID: 2cea8656-8838-5738-9f04-2e16835de8b9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
