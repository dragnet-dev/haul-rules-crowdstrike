// Dragnet [Container]: dragnet-container-2026-0983 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: b0751652-ee52-516e-b336-0784ce5242cf

#event_simpleName=*
| (ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10* OR ImageFileName = *ubuntu:13.04* OR ImageFileName = *ubuntu:13.10*)
| table([timestamp, ComputerName])
| limit(1000)
