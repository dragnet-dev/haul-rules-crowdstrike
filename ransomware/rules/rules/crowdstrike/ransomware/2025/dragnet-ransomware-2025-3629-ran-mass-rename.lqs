// Dragnet [Ransomware]: dragnet-ransomware-2025-3629 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 5b37c81b-9fd8-5751-9f06-06b82acaf80f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
