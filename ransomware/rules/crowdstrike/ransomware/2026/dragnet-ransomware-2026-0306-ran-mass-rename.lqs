// Dragnet [Ransomware]: dragnet-ransomware-2026-0306 — Mass File Rename (incransom)
// Status: stable | Level: high | ID: 58260f74-8838-51c2-9ab3-9fe2ae560b6d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
