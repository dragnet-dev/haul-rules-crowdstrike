// Dragnet [Ransomware]: dragnet-ransomware-2024-0821 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 43e4d1cb-a9d6-53b3-8d9a-5d7ef2230302

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
