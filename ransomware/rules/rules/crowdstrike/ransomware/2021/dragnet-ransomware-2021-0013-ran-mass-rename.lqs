// Dragnet [Ransomware]: dragnet-ransomware-2021-0013 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: cc3cab57-5831-565f-9fbb-8344919dac29

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
