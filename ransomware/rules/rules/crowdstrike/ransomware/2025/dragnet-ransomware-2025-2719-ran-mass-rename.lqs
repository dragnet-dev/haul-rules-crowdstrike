// Dragnet [Ransomware]: dragnet-ransomware-2025-2719 — Mass File Rename (coinbasecartel)
// Status: experimental | Level: high | ID: 671ba865-f735-50c8-8563-d06041393e67

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
