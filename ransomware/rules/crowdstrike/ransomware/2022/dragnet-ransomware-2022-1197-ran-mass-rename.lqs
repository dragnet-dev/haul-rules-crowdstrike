// Dragnet [Ransomware]: dragnet-ransomware-2022-1197 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 7403d47d-8b9d-50dd-8723-ca4aade08c91

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
