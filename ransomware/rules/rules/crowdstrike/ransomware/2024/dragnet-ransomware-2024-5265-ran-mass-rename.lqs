// Dragnet [Ransomware]: dragnet-ransomware-2024-5265 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 0cde6575-a175-5843-be37-ecab04cc1bec

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
