// Dragnet [Ransomware]: dragnet-ransomware-2023-2997 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 76db51f8-a6ae-5b16-b982-80257843d6d1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
