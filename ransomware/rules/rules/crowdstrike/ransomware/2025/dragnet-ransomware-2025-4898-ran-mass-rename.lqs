// Dragnet [Ransomware]: dragnet-ransomware-2025-4898 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: 9d1baa9a-dbd5-5a2e-a53f-8e8562953cd7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
