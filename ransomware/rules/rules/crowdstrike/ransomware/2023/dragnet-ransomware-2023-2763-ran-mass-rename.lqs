// Dragnet [Ransomware]: dragnet-ransomware-2023-2763 — Mass File Rename (malas)
// Status: experimental | Level: high | ID: 24f7736b-a097-589b-9b30-de14787e34e0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
