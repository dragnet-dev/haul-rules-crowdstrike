// Dragnet [Ransomware]: dragnet-ransomware-2024-5369 — Mass File Rename (blacklock)
// Status: experimental | Level: high | ID: ba4b2890-1f1e-5b09-9af0-c0a016985a4f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
