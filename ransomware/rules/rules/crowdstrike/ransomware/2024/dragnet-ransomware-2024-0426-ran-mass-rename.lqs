// Dragnet [Ransomware]: dragnet-ransomware-2024-0426 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 4038ad17-6a8a-5225-9343-659824500fc2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
