// Dragnet [Ransomware]: dragnet-ransomware-2023-3194 — Mass File Rename (losttrust)
// Status: deprecated | Level: high | ID: 39afc510-db62-5556-968a-c76778a9561e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
