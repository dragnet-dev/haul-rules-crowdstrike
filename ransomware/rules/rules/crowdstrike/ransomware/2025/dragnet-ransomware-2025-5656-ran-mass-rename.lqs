// Dragnet [Ransomware]: dragnet-ransomware-2025-5656 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 080ddf57-6262-56f0-a7ce-3b791a26ee1c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
