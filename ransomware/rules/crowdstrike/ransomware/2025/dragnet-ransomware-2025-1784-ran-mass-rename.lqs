// Dragnet [Ransomware]: dragnet-ransomware-2025-1784 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 53bf9887-2a3c-5c94-abfb-8428f6667a2c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
