// Dragnet [Ransomware]: dragnet-ransomware-2025-3542 — Mass File Rename (kairos)
// Status: experimental | Level: high | ID: 004a2126-7667-5038-a10c-102c87f5bc10

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
