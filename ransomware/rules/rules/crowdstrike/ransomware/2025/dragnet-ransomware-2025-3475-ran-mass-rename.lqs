// Dragnet [Ransomware]: dragnet-ransomware-2025-3475 — Mass File Rename (rhysida)
// Status: experimental | Level: high | ID: ae81b5ec-7de1-5006-8d71-b451419b3505

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
