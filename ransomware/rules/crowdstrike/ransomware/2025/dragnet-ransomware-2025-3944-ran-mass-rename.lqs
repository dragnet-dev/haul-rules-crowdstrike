// Dragnet [Ransomware]: dragnet-ransomware-2025-3944 — Mass File Rename (sarcoma)
// Status: deprecated | Level: high | ID: 9d6aa7fc-a50d-503a-aee6-6fdca9af6c87

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
