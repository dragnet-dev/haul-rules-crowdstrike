// Dragnet [Ransomware]: dragnet-ransomware-2024-0743 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: 5b54e3e2-db6c-5a56-849e-d19678cc5e47

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
