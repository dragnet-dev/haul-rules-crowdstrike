// Dragnet [Ransomware]: dragnet-ransomware-2025-1111 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: c70cdf4e-dc23-515d-a99e-c754f39d62a4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
