// Dragnet [Ransomware]: dragnet-ransomware-2023-1856 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 5c2baa1f-12ce-546f-998f-cef2b14a5df2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
