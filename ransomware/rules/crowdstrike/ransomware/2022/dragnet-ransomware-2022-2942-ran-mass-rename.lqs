// Dragnet [Ransomware]: dragnet-ransomware-2022-2942 — Mass File Rename (cuba)
// Status: deprecated | Level: high | ID: 973f623e-145e-5d86-9298-b3948a2e0fab

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
