// Dragnet [Ransomware]: dragnet-ransomware-2023-2068 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: 3d1a3e7d-b5c3-5bf8-b942-81b2e1385471

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
