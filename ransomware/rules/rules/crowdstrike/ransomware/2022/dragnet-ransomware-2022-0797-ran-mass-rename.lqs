// Dragnet [Ransomware]: dragnet-ransomware-2022-0797 — Mass File Rename (everest)
// Status: deprecated | Level: high | ID: 924f1168-1d3c-58b2-9b33-d536adc233ec

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
