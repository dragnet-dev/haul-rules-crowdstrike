// Dragnet [Ransomware]: dragnet-ransomware-2024-0057 — Mass File Rename (dragonforce)
// Status: deprecated | Level: high | ID: abab4253-eca2-5e73-9c6b-c5b240e71346

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
