// Dragnet [Ransomware]: dragnet-ransomware-2026-1304 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 64cccdc3-bf3d-577a-b047-1de5c4ed261a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
