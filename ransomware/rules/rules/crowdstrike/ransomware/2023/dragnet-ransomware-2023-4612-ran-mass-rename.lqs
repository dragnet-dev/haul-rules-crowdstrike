// Dragnet [Ransomware]: dragnet-ransomware-2023-4612 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 5009872f-fb7e-5f3b-87d4-c115a835e6d3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
