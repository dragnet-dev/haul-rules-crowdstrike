// Dragnet [Container]: dragnet-container-2025-0041 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: dcf4842d-e278-531b-be73-4b6e9b07cb30

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:7* OR ImageFileName = *debian:8* OR ImageFileName = *debian:9* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *oraclelinux:7* OR ImageFileName = *ubuntu:14.04* OR ImageFileName = *ubuntu:16.04* OR ImageFileName = *ubuntu:17.04* OR ImageFileName = *ubuntu:17.10* OR ImageFileName = *ubuntu:18.04*)
| table([timestamp, ComputerName])
| limit(1000)
