// Dragnet [Ransomware]: dragnet-ransomware-2025-2871 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 90324804-0459-5667-a662-cc13d9cb2802

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
