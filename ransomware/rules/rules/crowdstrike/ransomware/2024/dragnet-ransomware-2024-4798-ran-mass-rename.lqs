// Dragnet [Ransomware]: dragnet-ransomware-2024-4798 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: 1e68dedc-9af9-5631-8df9-43493c8ea976

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
