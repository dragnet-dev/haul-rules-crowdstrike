// Dragnet [Ransomware]: dragnet-ransomware-2024-5802 — Mass File Rename (dragonforce)
// Status: deprecated | Level: high | ID: 04c42ff3-995f-5c27-a073-3c3e04095f30

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
