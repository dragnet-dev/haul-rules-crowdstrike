// Dragnet [Container]: dragnet-container-2024-0253 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: fc65c441-c727-517d-a427-53e3cb48bb3f

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:9* OR ImageFileName = *ubuntu:18.04*)
| table([timestamp, ComputerName])
| limit(1000)
