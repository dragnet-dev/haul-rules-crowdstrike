// Dragnet [Ransomware]: dragnet-ransomware-2023-3371 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 4f169de5-7737-5cc6-bac4-0a58e5737595

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
