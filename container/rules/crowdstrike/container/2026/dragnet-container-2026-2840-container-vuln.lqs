// Dragnet [Container]: dragnet-container-2026-2840 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 7e439bc5-5422-5345-aa27-41773650b4b5

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:7* OR ImageFileName = *debian:8* OR ImageFileName = *ubuntu:16.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
