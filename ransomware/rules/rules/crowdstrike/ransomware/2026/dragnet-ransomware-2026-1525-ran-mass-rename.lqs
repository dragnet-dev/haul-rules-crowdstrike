// Dragnet [Ransomware]: dragnet-ransomware-2026-1525 — Mass File Rename (safepay)
// Status: stable | Level: high | ID: f96dd6a5-f828-5cbb-9396-39d996fbc914

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
