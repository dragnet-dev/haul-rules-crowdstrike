// Dragnet [Ransomware]: dragnet-ransomware-2023-0200 — Mass File Rename (stormous)
// Status: deprecated | Level: high | ID: 640a23bf-1905-5665-aea7-76f4f5bcc93b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
