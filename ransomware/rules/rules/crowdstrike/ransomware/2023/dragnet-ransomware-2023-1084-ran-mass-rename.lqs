// Dragnet [Ransomware]: dragnet-ransomware-2023-1084 — Mass File Rename (cloak)
// Status: deprecated | Level: high | ID: de823644-4422-5ccf-83ee-70a6abc4b112

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
