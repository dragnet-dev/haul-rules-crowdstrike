// Dragnet [Ransomware]: dragnet-ransomware-2026-3198 — Mass File Rename (nightspire)
// Status: deprecated | Level: high | ID: 39ec8ae7-4c13-5633-af73-148dfa12eb89

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
