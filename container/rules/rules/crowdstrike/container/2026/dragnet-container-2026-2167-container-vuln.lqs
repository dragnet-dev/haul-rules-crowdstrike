// Dragnet [Container]: dragnet-container-2026-2167 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: ba9f70a6-4b5a-5d80-a8c4-78c35fc6aec9

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:5*)
| table([timestamp, ComputerName])
| limit(1000)
