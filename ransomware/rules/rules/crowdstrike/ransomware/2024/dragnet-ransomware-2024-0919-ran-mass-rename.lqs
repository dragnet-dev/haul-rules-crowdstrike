// Dragnet [Ransomware]: dragnet-ransomware-2024-0919 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: 334e84cc-7035-542e-bd21-ea2b7d656bbc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
