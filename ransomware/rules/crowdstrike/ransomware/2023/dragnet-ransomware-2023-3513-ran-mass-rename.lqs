// Dragnet [Ransomware]: dragnet-ransomware-2023-3513 — Mass File Rename (knight)
// Status: experimental | Level: high | ID: 9a4351bf-4c72-58ea-8aaf-bdcde4519fa9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
