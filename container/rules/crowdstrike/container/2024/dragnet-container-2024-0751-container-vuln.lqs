// Dragnet [Container]: dragnet-container-2024-0751 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 67773532-fbac-5fac-ae07-2b909821fe1e

#event_simpleName=*
| (ImageFileName = *almalinux:8* OR ImageFileName = *almalinux:9* OR ImageFileName = *alpine:3.14* OR ImageFileName = *alpine:3.15* OR ImageFileName = *amazonlinux:2022* OR ImageFileName = *debian:11* OR ImageFileName = *oraclelinux:8* OR ImageFileName = *oraclelinux:9* OR ImageFileName = *ubuntu:20.04* OR ImageFileName = *ubuntu:20.04-ESM* OR ImageFileName = *ubuntu:21.10* OR ImageFileName = *ubuntu:22.04*)
| table([timestamp, ComputerName])
| limit(1000)
