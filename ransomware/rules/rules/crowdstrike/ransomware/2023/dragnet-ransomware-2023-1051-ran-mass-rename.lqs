// Dragnet [Ransomware]: dragnet-ransomware-2023-1051 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 8fcfb73b-25bd-50f9-a1c3-e553cedfa906

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
