// Dragnet [Ransomware]: dragnet-ransomware-2020-0191 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: ae29e202-4e45-5842-9ab8-1f0c95e863b4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
