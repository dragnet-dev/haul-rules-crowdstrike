// Dragnet [Ransomware]: dragnet-ransomware-2026-2124 — Mass File Rename (dragonforce)
// Status: stable | Level: high | ID: 47dbae90-e94e-5568-9ca4-48d4bde93d97

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
