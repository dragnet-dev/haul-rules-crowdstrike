// Dragnet [Ransomware]: dragnet-ransomware-2026-3207 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: af88116c-cbe4-506e-89e8-3f64f3b69bb0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
