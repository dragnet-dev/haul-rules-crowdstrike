// Dragnet [Ransomware]: dragnet-ransomware-2025-5320 — Mass File Rename (datacarry)
// Status: deprecated | Level: high | ID: deff1d69-6301-50e2-bd6d-0d31cc212d27

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
