// Dragnet [Ransomware]: dragnet-ransomware-2024-1765 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: 4733fbe4-affa-5c39-8d5f-ae578790af4f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
