// Dragnet [Ransomware]: dragnet-ransomware-2023-4509 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: b603e61b-1bcc-5b5c-8346-f7eb663d17d7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
