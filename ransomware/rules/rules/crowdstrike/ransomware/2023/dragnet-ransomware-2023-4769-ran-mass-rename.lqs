// Dragnet [Ransomware]: dragnet-ransomware-2023-4769 — Mass File Rename (rhysida)
// Status: deprecated | Level: high | ID: 9af7e2b5-f5ad-5383-9743-21ea8f0c076d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
