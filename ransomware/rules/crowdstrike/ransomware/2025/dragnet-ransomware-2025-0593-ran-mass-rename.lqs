// Dragnet [Ransomware]: dragnet-ransomware-2025-0593 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: daf46866-3384-5805-8f7a-e13fda85d47a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
