// Dragnet [Ransomware]: dragnet-ransomware-2021-0627 — Mass File Rename (everest)
// Status: deprecated | Level: high | ID: 477d85db-9dbc-548c-8327-d615f1f98327

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
