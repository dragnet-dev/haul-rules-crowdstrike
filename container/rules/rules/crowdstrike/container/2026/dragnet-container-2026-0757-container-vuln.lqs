// Dragnet [Container]: dragnet-container-2026-0757 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: ba3223c9-2a19-59e3-afb1-0e14549243da

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:5*)
| table([timestamp, ComputerName])
| limit(1000)
