// Dragnet [Ransomware]: dragnet-ransomware-2025-1197 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: d39cfadd-9948-5f06-9836-b4cc9e1e5876

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
