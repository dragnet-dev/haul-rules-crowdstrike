// Dragnet [Ransomware]: dragnet-ransomware-2022-1232 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 6ad34369-87d2-550d-a052-060730ac8653

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
