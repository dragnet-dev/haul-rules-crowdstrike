// Dragnet [Ransomware]: dragnet-ransomware-2022-1406 — Mass File Rename (leaktheanalyst)
// Status: deprecated | Level: high | ID: 8a4a9e88-f46c-5b71-a61b-8d4df92adb72

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
