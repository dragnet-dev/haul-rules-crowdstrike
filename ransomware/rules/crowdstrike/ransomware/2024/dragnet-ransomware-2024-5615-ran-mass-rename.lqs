// Dragnet [Ransomware]: dragnet-ransomware-2024-5615 — Mass File Rename (play)
// Status: experimental | Level: high | ID: e37c549e-00c8-5815-b3fa-2f24b99bf0a1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
