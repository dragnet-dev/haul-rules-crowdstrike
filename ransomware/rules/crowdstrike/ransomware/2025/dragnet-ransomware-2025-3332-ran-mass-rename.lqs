// Dragnet [Ransomware]: dragnet-ransomware-2025-3332 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 059f4f4c-5fac-5762-8a67-439a9cd614cd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
