// Dragnet [Ransomware]: dragnet-ransomware-2023-1052 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: d2a1ee27-8e38-5121-a7c8-c24be721973e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
