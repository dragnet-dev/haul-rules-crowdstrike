// Dragnet [Ransomware]: dragnet-ransomware-2020-0111 — Mass File Rename (nefilim)
// Status: deprecated | Level: high | ID: fc795ac2-b194-5c63-915d-d9cf21092ec6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
