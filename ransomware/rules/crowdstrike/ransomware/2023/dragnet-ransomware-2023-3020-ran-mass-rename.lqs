// Dragnet [Ransomware]: dragnet-ransomware-2023-3020 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 3459a31a-0b22-5941-991e-ab665b0ee7d7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
