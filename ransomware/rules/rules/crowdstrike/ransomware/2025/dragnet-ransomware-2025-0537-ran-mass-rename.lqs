// Dragnet [Ransomware]: dragnet-ransomware-2025-0537 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 24c407ef-fb3a-539d-a19a-494910931ebd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
