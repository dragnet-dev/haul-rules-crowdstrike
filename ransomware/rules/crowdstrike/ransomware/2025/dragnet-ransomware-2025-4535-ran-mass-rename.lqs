// Dragnet [Ransomware]: dragnet-ransomware-2025-4535 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 7bfc43a0-9705-5d23-9a61-a1c891aa033a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
