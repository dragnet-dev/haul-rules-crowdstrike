// Dragnet [Ransomware]: dragnet-ransomware-2024-1869 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: c5e3fc51-7943-5ee5-812f-c034a9ac7840

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
