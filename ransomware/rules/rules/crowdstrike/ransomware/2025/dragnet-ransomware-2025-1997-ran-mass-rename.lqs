// Dragnet [Ransomware]: dragnet-ransomware-2025-1997 — Mass File Rename (ralord)
// Status: experimental | Level: high | ID: 03331047-d2c4-511a-b3b9-6e18fb1c99db

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
