// Dragnet [Ransomware]: dragnet-ransomware-2023-2005 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: cbf9e04a-4259-5cee-a7ba-514bc0648842

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
