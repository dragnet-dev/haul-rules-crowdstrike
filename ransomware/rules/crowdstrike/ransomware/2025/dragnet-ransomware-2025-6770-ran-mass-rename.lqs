// Dragnet [Ransomware]: dragnet-ransomware-2025-6770 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: fa949169-efce-5365-b7f6-05d0a50a66c1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
