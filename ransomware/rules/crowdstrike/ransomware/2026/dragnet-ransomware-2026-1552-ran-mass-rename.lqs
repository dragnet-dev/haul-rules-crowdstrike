// Dragnet [Ransomware]: dragnet-ransomware-2026-1552 — Mass File Rename (dragonforce)
// Status: stable | Level: high | ID: d8e55373-8214-519a-9f02-ac07b167ad1f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
