// Dragnet [Ransomware]: dragnet-ransomware-2025-2220 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: c6452414-ced7-574b-911d-0498364d5d7e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
