// Dragnet [Ransomware]: dragnet-ransomware-2024-1003 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 14cce35e-89ad-5d88-bda0-e53a55340320

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
