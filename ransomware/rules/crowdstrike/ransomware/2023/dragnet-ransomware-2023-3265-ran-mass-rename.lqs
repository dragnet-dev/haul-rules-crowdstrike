// Dragnet [Ransomware]: dragnet-ransomware-2023-3265 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: c270b10b-7277-5908-b2d2-a15c5c0da3fb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
