// Dragnet [Ransomware]: dragnet-ransomware-2025-5289 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: 3de8e009-20a5-5d75-ad07-f170721aa7b3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
