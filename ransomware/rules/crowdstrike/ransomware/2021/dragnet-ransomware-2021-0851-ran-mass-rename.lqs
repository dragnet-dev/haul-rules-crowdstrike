// Dragnet [Ransomware]: dragnet-ransomware-2021-0851 — Mass File Rename (blackmatter)
// Status: deprecated | Level: high | ID: 279276ce-bfd6-5c87-8017-c58812878590

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
