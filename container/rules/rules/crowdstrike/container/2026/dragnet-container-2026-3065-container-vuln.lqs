// Dragnet [Container]: dragnet-container-2026-3065 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 4b60e5b8-d137-5b0c-8def-394695abda10

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
