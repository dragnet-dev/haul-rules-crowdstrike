// Dragnet [Ransomware]: dragnet-ransomware-2022-0914 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: cd10bb02-5614-5758-92ef-12c6607a67f6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
