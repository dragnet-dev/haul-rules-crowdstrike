// Dragnet [Ransomware]: dragnet-ransomware-2025-1925 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: af2f89f6-23e0-5d92-9f80-31652490fe53

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
