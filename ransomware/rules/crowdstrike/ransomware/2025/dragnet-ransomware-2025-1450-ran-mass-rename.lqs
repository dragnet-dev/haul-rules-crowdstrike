// Dragnet [Ransomware]: dragnet-ransomware-2025-1450 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: a6ee5008-01d8-5102-9583-247dfa69f23c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
