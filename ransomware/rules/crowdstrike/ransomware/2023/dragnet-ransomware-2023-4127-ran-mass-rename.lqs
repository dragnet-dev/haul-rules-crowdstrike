// Dragnet [Ransomware]: dragnet-ransomware-2023-4127 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: cd2ad7e2-bff2-556b-8b6f-4103bc85e765

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
