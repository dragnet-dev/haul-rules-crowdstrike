// Dragnet [Ransomware]: dragnet-ransomware-2021-1330 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 12a72821-0def-5b88-baa2-cfdc4061162e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
