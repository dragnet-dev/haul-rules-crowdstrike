// Dragnet [Ransomware]: dragnet-ransomware-2025-1866 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 81f90fde-9ef7-5ac4-ace9-ea55ef5ed2d8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
