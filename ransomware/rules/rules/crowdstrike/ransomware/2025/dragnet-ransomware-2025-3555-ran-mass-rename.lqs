// Dragnet [Ransomware]: dragnet-ransomware-2025-3555 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 6287e524-4b0c-56fc-bbb0-bf2179ed2d88

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
