// Dragnet [Ransomware]: dragnet-ransomware-2025-6163 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: 04ab7d7c-9529-52c4-870e-c7d04a11349f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
