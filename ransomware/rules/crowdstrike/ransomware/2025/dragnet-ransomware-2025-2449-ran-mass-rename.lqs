// Dragnet [Ransomware]: dragnet-ransomware-2025-2449 — Mass File Rename (thegentlemen)
// Status: test | Level: high | ID: 0c2c67b0-7ae0-548f-ae66-1ad7c9c93210

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
