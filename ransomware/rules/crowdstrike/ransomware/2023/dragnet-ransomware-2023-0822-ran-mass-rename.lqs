// Dragnet [Ransomware]: dragnet-ransomware-2023-0822 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: ad7f411c-3b3c-5202-a30f-d6b91dc80a83

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
