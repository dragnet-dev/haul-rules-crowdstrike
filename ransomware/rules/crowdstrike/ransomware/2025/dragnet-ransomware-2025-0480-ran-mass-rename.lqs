// Dragnet [Ransomware]: dragnet-ransomware-2025-0480 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: dbf4b274-83b1-519e-81aa-cc0feddf9680

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
