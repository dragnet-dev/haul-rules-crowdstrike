// Dragnet [Ransomware]: dragnet-ransomware-2024-4632 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 6ccdd263-6e3c-5c63-8878-e922bdca5812

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
