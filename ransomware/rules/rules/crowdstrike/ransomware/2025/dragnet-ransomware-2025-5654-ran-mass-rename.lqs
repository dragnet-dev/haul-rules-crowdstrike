// Dragnet [Ransomware]: dragnet-ransomware-2025-5654 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 87fdd880-f5d4-503f-af18-666712407034

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
