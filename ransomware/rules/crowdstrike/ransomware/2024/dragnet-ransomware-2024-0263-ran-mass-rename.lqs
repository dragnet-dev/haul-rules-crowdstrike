// Dragnet [Ransomware]: dragnet-ransomware-2024-0263 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: e307b5ee-499b-5170-a308-e046d2c8afe9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
