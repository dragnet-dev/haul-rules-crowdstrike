// Dragnet [Ransomware]: dragnet-ransomware-2025-5134 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 43aeed0a-3d1b-5580-9feb-ac8fd7f68c06

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
