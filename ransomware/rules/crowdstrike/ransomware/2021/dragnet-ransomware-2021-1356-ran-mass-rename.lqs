// Dragnet [Ransomware]: dragnet-ransomware-2021-1356 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: a84f005f-8da2-53a1-999b-f699454157e5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
