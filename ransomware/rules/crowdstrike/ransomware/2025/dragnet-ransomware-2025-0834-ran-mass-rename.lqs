// Dragnet [Ransomware]: dragnet-ransomware-2025-0834 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: e50d1d60-6594-55da-abc6-7da7945558a2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
