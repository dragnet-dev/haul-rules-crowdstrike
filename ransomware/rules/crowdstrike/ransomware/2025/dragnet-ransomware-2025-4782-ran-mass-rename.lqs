// Dragnet [Ransomware]: dragnet-ransomware-2025-4782 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 1d59177a-1c17-548a-8422-373c16a01e9a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
