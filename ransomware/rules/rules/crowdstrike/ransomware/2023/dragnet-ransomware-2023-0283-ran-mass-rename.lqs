// Dragnet [Ransomware]: dragnet-ransomware-2023-0283 — Mass File Rename (abyss)
// Status: deprecated | Level: high | ID: 89ef7538-dc65-5b6b-94d4-2fa5c1102325

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
