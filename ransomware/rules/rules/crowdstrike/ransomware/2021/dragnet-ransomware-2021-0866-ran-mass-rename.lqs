// Dragnet [Ransomware]: dragnet-ransomware-2021-0866 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: b9154e8e-c7b0-5294-b016-ad245b82773e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
