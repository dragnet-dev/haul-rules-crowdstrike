// Dragnet [Ransomware]: dragnet-ransomware-2025-0695 — Mass File Rename (coinbasecartel)
// Status: experimental | Level: high | ID: 695e7d5e-06a5-5cf0-b229-60f077f02d17

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
