// Dragnet [Ransomware]: dragnet-ransomware-2021-0480 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: f74a7eac-a321-5f71-9734-5623bad322d7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
