// Dragnet [Ransomware]: dragnet-ransomware-2024-1577 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 28d9b60b-9d23-5f66-9a28-b85c5cf963da

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
