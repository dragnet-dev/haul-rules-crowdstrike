// Dragnet [Ransomware]: dragnet-ransomware-2021-1417 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 6b8c8df7-fa45-5976-b0e9-ca9dc89d1b5f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
