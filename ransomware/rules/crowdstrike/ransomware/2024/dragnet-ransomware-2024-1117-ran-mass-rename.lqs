// Dragnet [Ransomware]: dragnet-ransomware-2024-1117 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 447edbcf-41e4-59cc-9d80-ed7bbc24a504

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
