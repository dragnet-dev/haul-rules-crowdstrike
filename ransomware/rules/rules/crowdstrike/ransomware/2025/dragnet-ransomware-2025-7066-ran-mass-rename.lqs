// Dragnet [Ransomware]: dragnet-ransomware-2025-7066 — Mass File Rename (payoutsking)
// Status: deprecated | Level: high | ID: 0019c8ac-860e-57f9-af45-8603567cebba

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
