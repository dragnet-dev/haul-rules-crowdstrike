// Dragnet [Ransomware]: dragnet-ransomware-2023-1202 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 3a83fdd4-2eff-5bf1-95de-ca1f266498f4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
