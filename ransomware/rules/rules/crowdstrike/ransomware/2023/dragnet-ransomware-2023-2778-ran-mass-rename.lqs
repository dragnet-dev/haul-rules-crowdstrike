// Dragnet [Ransomware]: dragnet-ransomware-2023-2778 — Mass File Rename (malas)
// Status: experimental | Level: high | ID: bedb83f5-7d97-5c4e-9da1-6e5a5a6fd357

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
