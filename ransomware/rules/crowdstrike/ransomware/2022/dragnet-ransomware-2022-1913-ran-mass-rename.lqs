// Dragnet [Ransomware]: dragnet-ransomware-2022-1913 — Mass File Rename (royal)
// Status: deprecated | Level: high | ID: 3445b91e-b93a-537a-8122-5837c1e8928f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
