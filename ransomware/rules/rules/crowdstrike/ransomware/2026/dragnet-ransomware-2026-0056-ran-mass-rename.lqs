// Dragnet [Ransomware]: dragnet-ransomware-2026-0056 — Mass File Rename (incransom)
// Status: stable | Level: high | ID: 9fe07bf6-b5a3-5978-aefc-67b6e89226e9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
