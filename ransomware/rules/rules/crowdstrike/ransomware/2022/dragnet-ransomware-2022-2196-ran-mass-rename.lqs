// Dragnet [Ransomware]: dragnet-ransomware-2022-2196 — Mass File Rename (karakurt)
// Status: deprecated | Level: high | ID: b72fb640-c583-5537-9655-a87b2bc50f3c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
