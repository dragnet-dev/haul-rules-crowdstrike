// Dragnet [Ransomware]: dragnet-ransomware-2025-0915 — Mass File Rename (cloak)
// Status: deprecated | Level: high | ID: e7826c3e-83bf-56a3-a7a6-93b5b81b9c85

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
