// Dragnet [Ransomware]: dragnet-ransomware-2024-3390 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 06e13466-541d-57f2-9547-1c59bf41e1e1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
