// Dragnet [Ransomware]: dragnet-ransomware-2025-2352 — Mass File Rename (arcusmedia)
// Status: experimental | Level: high | ID: ed76392a-3c26-57aa-b6b8-e16a3fc50bf2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
