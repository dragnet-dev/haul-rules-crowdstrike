// Dragnet [Ransomware]: dragnet-ransomware-2023-4583 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 555709da-235b-5831-a673-ce313cc89a81

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
