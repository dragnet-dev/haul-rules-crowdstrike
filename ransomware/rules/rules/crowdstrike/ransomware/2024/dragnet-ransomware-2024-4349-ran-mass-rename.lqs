// Dragnet [Ransomware]: dragnet-ransomware-2024-4349 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 708ea8fb-5755-5ded-a49d-fbb681acf049

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
