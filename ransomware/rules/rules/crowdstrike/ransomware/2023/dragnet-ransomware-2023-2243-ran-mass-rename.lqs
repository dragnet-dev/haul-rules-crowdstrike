// Dragnet [Ransomware]: dragnet-ransomware-2023-2243 — Mass File Rename (knight)
// Status: experimental | Level: high | ID: 94d8a601-9a21-5d72-b197-0d731bcfcea3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
