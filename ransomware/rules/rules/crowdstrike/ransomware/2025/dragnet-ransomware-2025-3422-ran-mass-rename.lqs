// Dragnet [Ransomware]: dragnet-ransomware-2025-3422 — Mass File Rename (nightspire)
// Status: deprecated | Level: high | ID: 4aef54b5-156f-5eaa-81cf-b65a55d80a8c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
