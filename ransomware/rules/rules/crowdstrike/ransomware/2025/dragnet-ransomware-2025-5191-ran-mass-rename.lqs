// Dragnet [Ransomware]: dragnet-ransomware-2025-5191 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 39b1a644-dab9-51a0-936b-91463180797f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
