// Dragnet [Ransomware]: dragnet-ransomware-2023-4549 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 588bd9fe-97a2-5d60-a3de-de3f8e59e027

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
