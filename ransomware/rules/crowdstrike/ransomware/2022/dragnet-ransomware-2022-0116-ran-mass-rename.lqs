// Dragnet [Ransomware]: dragnet-ransomware-2022-0116 — Mass File Rename (dataleak)
// Status: deprecated | Level: high | ID: a0b45b9b-5d37-5a1b-b8fd-d2ed84a96e71

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
