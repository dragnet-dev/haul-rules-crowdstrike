// Dragnet [Ransomware]: dragnet-ransomware-2026-3450 — Mass File Rename (medusalocker)
// Status: stable | Level: high | ID: bdac2a80-6978-5948-a446-9737c0d91edd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
