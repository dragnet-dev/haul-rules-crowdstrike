// Dragnet [Ransomware]: dragnet-ransomware-2025-3194 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: c290e619-1722-5d84-8c7d-7c33f0362d5a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
