// Dragnet [Ransomware]: dragnet-ransomware-2025-7334 — Mass File Rename (nightspire)
// Status: deprecated | Level: high | ID: f51114f4-7387-5b19-b52c-920e8be7a186

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
