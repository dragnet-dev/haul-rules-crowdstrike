// Dragnet [Container]: dragnet-container-2024-1389 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 236272ab-a1fb-5f41-a8d0-16149fbe5140

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *redhat/ubi9:*)
| table([timestamp, ComputerName])
| limit(1000)
