// Dragnet [Ransomware]: dragnet-ransomware-2021-1100 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 278641db-e3ed-5aa3-82cc-3f9fe491afba

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
