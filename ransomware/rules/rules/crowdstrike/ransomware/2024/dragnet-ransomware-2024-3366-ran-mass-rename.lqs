// Dragnet [Ransomware]: dragnet-ransomware-2024-3366 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: d266c8dc-43b8-5b1e-94dd-cd821fb5805a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
