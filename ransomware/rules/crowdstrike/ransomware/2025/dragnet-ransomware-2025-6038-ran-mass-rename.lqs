// Dragnet [Ransomware]: dragnet-ransomware-2025-6038 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 48589368-a3a0-5243-93ac-265b8552b7a0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
