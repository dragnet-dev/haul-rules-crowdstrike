// Dragnet [Ransomware]: dragnet-ransomware-2025-5215 — Mass File Rename (ransomhouse)
// Status: experimental | Level: high | ID: 02e1aa79-5484-5721-8653-5c3d7503568e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
