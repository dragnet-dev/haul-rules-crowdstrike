// Dragnet [Ransomware]: dragnet-ransomware-2026-3284 — Mass File Rename (incransom)
// Status: stable | Level: high | ID: 3ddba8b8-1707-583e-8ab2-8b706b73a3cf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
