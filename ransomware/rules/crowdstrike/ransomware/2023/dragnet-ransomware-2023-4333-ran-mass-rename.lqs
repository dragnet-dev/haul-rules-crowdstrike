// Dragnet [Ransomware]: dragnet-ransomware-2023-4333 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 8d72594b-d8d5-5538-bcdb-8586139eaa55

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
