// Dragnet [Ransomware]: dragnet-ransomware-2023-2484 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 3788c070-c1bf-5d6e-867a-90dc65ca6242

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
