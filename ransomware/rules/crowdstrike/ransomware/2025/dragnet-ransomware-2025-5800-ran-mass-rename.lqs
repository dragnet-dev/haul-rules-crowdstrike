// Dragnet [Ransomware]: dragnet-ransomware-2025-5800 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: da256363-2b27-5411-80fc-5ed2874637ad

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
