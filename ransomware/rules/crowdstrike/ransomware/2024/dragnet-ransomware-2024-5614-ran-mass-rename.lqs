// Dragnet [Ransomware]: dragnet-ransomware-2024-5614 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 622243b1-b767-53d0-97af-34f4bf8588d1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
