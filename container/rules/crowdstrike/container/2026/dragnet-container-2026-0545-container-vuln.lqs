// Dragnet [Container]: dragnet-container-2026-0545 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 80ee5042-d400-5429-8ed2-5a858dcb4df6

#event_simpleName=*
| (ImageFileName = *amazonlinux:1* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:8* OR ImageFileName = *ubuntu:14.10* OR ImageFileName = *ubuntu:15.04*)
| table([timestamp, ComputerName])
| limit(1000)
