// Dragnet [Ransomware]: dragnet-ransomware-2024-1674 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: d53a1eec-bc56-5944-b4db-6c6b1b150849

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
