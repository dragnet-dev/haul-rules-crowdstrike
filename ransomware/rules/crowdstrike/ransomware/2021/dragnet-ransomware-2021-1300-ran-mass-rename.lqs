// Dragnet [Ransomware]: dragnet-ransomware-2021-1300 — Mass File Rename (avaddon)
// Status: deprecated | Level: high | ID: 8974f0d0-4454-5b5b-8f3c-a65b157d0932

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
