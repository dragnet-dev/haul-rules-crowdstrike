// Dragnet [Ransomware]: dragnet-ransomware-2024-4601 — Mass File Rename (meow)
// Status: experimental | Level: high | ID: c9bbf062-447e-5528-9d96-941b4da1b7a4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
