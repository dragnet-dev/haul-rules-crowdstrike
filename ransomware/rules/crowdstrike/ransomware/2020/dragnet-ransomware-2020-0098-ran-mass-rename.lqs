// Dragnet [Ransomware]: dragnet-ransomware-2020-0098 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 8fcb4023-17d3-5578-9c98-2e8f1d19c4a4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
