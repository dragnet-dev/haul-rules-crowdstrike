// Dragnet [Ransomware]: dragnet-ransomware-2021-0178 — Mass File Rename (azroteam)
// Status: deprecated | Level: high | ID: 5299d108-ad74-5299-a205-36a1f0eb97b9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
