// Dragnet [Ransomware]: dragnet-ransomware-2021-0721 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 1e11d7b9-ec20-56ab-8e4d-e143b8996580

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
