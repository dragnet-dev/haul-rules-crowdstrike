// Dragnet [Ransomware]: dragnet-ransomware-2023-3931 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 0193c33b-f026-5ac0-8a39-d17829cc4b21

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
