// Dragnet [Ransomware]: dragnet-ransomware-2025-0947 — Mass File Rename (pear)
// Status: experimental | Level: high | ID: ae2f0956-9957-507c-8a09-027538630bd7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
