// Dragnet [Ransomware]: dragnet-ransomware-2025-3085 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: c2632de3-c488-540d-b63f-d0cef53e780f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
