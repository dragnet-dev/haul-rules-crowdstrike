// Dragnet [Ransomware]: dragnet-ransomware-2023-1587 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: a0413488-d02a-55d6-ba46-9d548777f193

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
