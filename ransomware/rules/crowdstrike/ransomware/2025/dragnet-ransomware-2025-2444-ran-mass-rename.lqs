// Dragnet [Ransomware]: dragnet-ransomware-2025-2444 — Mass File Rename (thegentlemen)
// Status: test | Level: high | ID: cbabeba8-7113-5b1d-bf77-007af2f8c540

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
