// Dragnet [Ransomware]: dragnet-ransomware-2024-3647 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 20d83fef-2c13-50ab-91d6-206527dbf0e6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
