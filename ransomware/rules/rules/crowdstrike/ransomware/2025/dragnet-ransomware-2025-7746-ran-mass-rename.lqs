// Dragnet [Ransomware]: dragnet-ransomware-2025-7746 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: ec3d6aae-aa0f-5941-87df-cb5c57281184

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
