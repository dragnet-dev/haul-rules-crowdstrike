// Dragnet [Ransomware]: dragnet-ransomware-2020-0216 — Mass File Rename (coldlock)
// Status: deprecated | Level: high | ID: 87eb4137-993c-5fad-9520-603898c76486

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
