// Dragnet [Ransomware]: dragnet-ransomware-2025-6085 — Mass File Rename (crazyhunter)
// Status: experimental | Level: high | ID: 0430588b-307f-511e-83bf-4799bfc1c75e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
