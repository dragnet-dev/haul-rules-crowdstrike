// Dragnet [Ransomware]: dragnet-ransomware-2022-1976 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 1ec8acf4-20ae-5b57-96f1-d2a41108fad3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
