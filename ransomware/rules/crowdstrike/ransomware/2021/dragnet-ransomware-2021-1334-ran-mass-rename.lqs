// Dragnet [Ransomware]: dragnet-ransomware-2021-1334 — Mass File Rename (ragnarlocker)
// Status: deprecated | Level: high | ID: 12733384-6ca6-52f8-90a6-6af0ba27df8e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
