// Dragnet [Ransomware]: dragnet-ransomware-2025-7885 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 6eada041-294c-5639-a646-aa317c512af7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
