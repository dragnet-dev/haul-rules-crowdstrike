// Dragnet [Ransomware]: dragnet-ransomware-2023-0903 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: c2e263fe-e282-5c1b-892f-5a6baeb1cfe2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
