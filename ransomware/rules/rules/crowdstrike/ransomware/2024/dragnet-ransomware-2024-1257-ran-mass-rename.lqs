// Dragnet [Ransomware]: dragnet-ransomware-2024-1257 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 3edfa733-a497-5e02-8c0c-1dea5662c6b3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
