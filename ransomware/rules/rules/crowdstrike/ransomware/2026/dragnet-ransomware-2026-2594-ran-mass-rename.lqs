// Dragnet [Ransomware]: dragnet-ransomware-2026-2594 — Mass File Rename (direwolf)
// Status: test | Level: high | ID: 58236c49-91d2-5346-a228-e6b04d8cb1d6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
