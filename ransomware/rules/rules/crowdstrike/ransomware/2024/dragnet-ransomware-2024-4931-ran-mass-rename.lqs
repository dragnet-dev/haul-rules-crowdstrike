// Dragnet [Ransomware]: dragnet-ransomware-2024-4931 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: ea210477-312a-5463-9f7c-fb4b52d4d4bb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
