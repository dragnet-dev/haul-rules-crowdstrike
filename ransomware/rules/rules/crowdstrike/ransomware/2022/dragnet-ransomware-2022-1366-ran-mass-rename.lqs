// Dragnet [Ransomware]: dragnet-ransomware-2022-1366 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: f7a181a6-5eab-58ef-900b-9e83c64a2d03

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
