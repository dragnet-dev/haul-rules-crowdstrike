// Dragnet [Ransomware]: dragnet-ransomware-2024-1031 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 677b8ae1-4a0f-5946-8e0c-d169c632615a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
