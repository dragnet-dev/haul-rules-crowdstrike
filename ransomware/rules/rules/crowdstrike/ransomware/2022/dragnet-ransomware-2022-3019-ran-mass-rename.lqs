// Dragnet [Ransomware]: dragnet-ransomware-2022-3019 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 3639f710-8109-5296-bb54-fb532f0c3966

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
