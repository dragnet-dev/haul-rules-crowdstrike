// Dragnet [Ransomware]: dragnet-ransomware-2023-2525 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 7d6a09e1-bab5-5269-9cf6-af4021fad5a3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
