// Dragnet [Ransomware]: dragnet-ransomware-2022-2581 — Mass File Rename (ransomexx)
// Status: experimental | Level: high | ID: 067b39fe-139c-59a3-9263-7f1ca7bf2328

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
