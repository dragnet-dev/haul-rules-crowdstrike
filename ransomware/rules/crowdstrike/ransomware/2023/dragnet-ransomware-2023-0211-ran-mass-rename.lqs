// Dragnet [Ransomware]: dragnet-ransomware-2023-0211 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 89f5471c-4a96-5fc9-92bc-969343956f68

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
