// Dragnet [Ransomware]: dragnet-ransomware-2025-1569 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: a94dc14e-e9c9-531a-a430-0ac9f78b1db2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
