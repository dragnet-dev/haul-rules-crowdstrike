// Dragnet [Ransomware]: dragnet-ransomware-2021-1231 — Mass File Rename (rook)
// Status: deprecated | Level: high | ID: fc1f40a3-345c-55db-a6e6-5d69c38be5f6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
