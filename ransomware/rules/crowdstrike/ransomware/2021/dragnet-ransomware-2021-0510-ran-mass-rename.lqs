// Dragnet [Ransomware]: dragnet-ransomware-2021-0510 — Mass File Rename (midas)
// Status: deprecated | Level: high | ID: b792e679-c527-5349-a6dc-7f7dca86ff86

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
