// Dragnet [Ransomware]: dragnet-ransomware-2023-1654 — Mass File Rename (cryptnet)
// Status: experimental | Level: high | ID: 09d63134-b0de-5a7f-b632-d351942e67cb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
