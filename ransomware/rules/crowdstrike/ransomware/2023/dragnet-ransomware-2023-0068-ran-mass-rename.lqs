// Dragnet [Ransomware]: dragnet-ransomware-2023-0068 — Mass File Rename (rhysida)
// Status: deprecated | Level: high | ID: 513c120d-6e17-5594-b3f8-286267fe355e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
