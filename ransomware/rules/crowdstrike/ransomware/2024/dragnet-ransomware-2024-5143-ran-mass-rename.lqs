// Dragnet [Ransomware]: dragnet-ransomware-2024-5143 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: b5ec0aa7-dcf4-5c84-8f99-d64856f5da45

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
