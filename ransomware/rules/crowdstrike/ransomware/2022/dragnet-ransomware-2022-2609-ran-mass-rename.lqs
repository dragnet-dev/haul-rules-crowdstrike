// Dragnet [Ransomware]: dragnet-ransomware-2022-2609 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 35ed15ca-cf05-5b2d-8b03-e295e74e4c83

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
