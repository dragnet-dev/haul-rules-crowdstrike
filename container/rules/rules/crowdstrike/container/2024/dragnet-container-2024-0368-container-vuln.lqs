// Dragnet [Container]: dragnet-container-2024-0368 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 516fe213-ed54-5648-b11f-8bd85106c3b3

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:8* OR ImageFileName = *debian:9*)
| table([timestamp, ComputerName])
| limit(1000)
