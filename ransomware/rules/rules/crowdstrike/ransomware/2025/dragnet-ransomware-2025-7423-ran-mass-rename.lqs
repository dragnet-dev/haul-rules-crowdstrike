// Dragnet [Ransomware]: dragnet-ransomware-2025-7423 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 60d582c5-8d1c-5f47-a051-4e863b243ca2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
