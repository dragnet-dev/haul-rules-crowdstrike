// Dragnet [Ransomware]: dragnet-ransomware-2022-2591 — Mass File Rename (snatch)
// Status: deprecated | Level: high | ID: d06eaa4e-6344-5ab0-9b4c-bcb31ac9a87b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
