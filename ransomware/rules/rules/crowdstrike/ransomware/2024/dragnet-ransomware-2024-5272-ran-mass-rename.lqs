// Dragnet [Ransomware]: dragnet-ransomware-2024-5272 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: 096f282d-e372-5faf-99fe-823e7b3724af

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
