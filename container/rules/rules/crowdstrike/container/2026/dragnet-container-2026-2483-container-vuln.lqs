// Dragnet [Container]: dragnet-container-2026-2483 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: e60df036-3036-5f37-b44e-9302ac94b581

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *photon os:1.0* OR ImageFileName = *photon os:2.0*)
| table([timestamp, ComputerName])
| limit(1000)
