// Dragnet [Ransomware]: dragnet-ransomware-2026-1048 — Mass File Rename (thegentlemen)
// Status: stable | Level: high | ID: 6e8e931c-b42a-59e5-b5a7-93fafeef91bc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
