// Dragnet [Ransomware]: dragnet-ransomware-2020-0075 — Mass File Rename (maze)
// Status: deprecated | Level: high | ID: c8f44f59-8038-5a33-9297-eab91838eda5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
