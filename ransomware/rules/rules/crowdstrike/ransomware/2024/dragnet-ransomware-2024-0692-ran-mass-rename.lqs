// Dragnet [Ransomware]: dragnet-ransomware-2024-0692 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: 90798815-cbe4-5da2-964f-9ef5aea092e7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
