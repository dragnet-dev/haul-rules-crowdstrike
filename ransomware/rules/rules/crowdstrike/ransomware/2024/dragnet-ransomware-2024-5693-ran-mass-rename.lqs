// Dragnet [Ransomware]: dragnet-ransomware-2024-5693 — Mass File Rename (blacklock)
// Status: experimental | Level: high | ID: 17b60e9f-6984-57a9-9c4e-6cdf969bf5d3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
