// Dragnet [Ransomware]: dragnet-ransomware-2023-2366 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 1f6c9a42-46b2-545a-8275-b7c1722019b8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
