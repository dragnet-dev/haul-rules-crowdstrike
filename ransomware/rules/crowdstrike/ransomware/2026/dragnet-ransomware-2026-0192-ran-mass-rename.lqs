// Dragnet [Ransomware]: dragnet-ransomware-2026-0192 — Mass File Rename (dragonforce)
// Status: stable | Level: high | ID: e9e8c112-45f2-5c0e-93db-b197b66a28d4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
