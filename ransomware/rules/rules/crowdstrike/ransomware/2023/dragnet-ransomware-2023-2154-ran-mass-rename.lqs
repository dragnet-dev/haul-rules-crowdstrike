// Dragnet [Ransomware]: dragnet-ransomware-2023-2154 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 09207b0a-a94a-5f25-891f-882647fb5143

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
