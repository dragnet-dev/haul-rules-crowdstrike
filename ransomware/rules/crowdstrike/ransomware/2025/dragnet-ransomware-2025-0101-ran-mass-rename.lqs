// Dragnet [Ransomware]: dragnet-ransomware-2025-0101 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: c02f386f-fde2-5e14-bf95-d2d6d839e8d7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
