// Dragnet [Ransomware]: dragnet-ransomware-2024-4861 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 3d9e8a2d-df40-571d-b878-62b9c1b9c1e3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
