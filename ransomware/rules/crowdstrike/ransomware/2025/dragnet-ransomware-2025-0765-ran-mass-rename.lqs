// Dragnet [Ransomware]: dragnet-ransomware-2025-0765 — Mass File Rename (play)
// Status: experimental | Level: high | ID: b528a910-e806-5530-9ba9-90196e4f4b11

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
