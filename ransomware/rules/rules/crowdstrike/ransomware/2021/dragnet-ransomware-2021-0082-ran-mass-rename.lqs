// Dragnet [Ransomware]: dragnet-ransomware-2021-0082 — Mass File Rename (avaddon)
// Status: deprecated | Level: high | ID: 72ec6576-d930-5c2b-bb15-165693191bf3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
