// Dragnet [Ransomware]: dragnet-ransomware-2023-1093 — Mass File Rename (mallox)
// Status: experimental | Level: high | ID: 380cd109-aa62-542a-af44-0163cf38e5a0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
