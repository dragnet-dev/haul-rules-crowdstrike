// Dragnet [Ransomware]: dragnet-ransomware-2023-4134 — Mass File Rename (ransomed)
// Status: deprecated | Level: high | ID: f10d0874-6941-5c8d-a3db-b9f17cfa9342

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
