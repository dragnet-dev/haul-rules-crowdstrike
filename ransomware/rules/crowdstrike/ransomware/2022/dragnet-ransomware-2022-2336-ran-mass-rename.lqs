// Dragnet [Ransomware]: dragnet-ransomware-2022-2336 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 6c21b0e9-bc67-5ab9-934b-607f4089745d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
