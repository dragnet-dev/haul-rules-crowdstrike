// Dragnet [Ransomware]: dragnet-ransomware-2026-1580 — Mass File Rename (dragonforce)
// Status: test | Level: high | ID: b31e236c-6e39-5b60-8ff6-f2f125c87dfe

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
