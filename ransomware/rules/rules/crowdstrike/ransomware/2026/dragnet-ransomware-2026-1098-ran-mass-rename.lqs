// Dragnet [Ransomware]: dragnet-ransomware-2026-1098 — Mass File Rename (thegentlemen)
// Status: test | Level: high | ID: 32404e22-e891-5cac-9b2d-0a3cc10db407

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
