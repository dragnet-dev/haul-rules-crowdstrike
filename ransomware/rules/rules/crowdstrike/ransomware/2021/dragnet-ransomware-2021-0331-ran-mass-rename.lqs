// Dragnet [Ransomware]: dragnet-ransomware-2021-0331 — Mass File Rename (karma)
// Status: deprecated | Level: high | ID: c5976838-6611-5641-9ccb-c722b983271e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
