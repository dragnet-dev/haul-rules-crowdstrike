// Dragnet [Ransomware]: dragnet-ransomware-2023-4992 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 5aff181b-1105-59b8-919e-3080164da572

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
