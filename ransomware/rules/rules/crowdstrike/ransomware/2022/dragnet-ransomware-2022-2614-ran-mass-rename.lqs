// Dragnet [Ransomware]: dragnet-ransomware-2022-2614 — Mass File Rename (cuba)
// Status: deprecated | Level: high | ID: f86c4eb3-5368-5495-b81b-d3213d4d8704

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
