// Dragnet [Ransomware]: dragnet-ransomware-2022-1090 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 3951c910-1546-5314-96b8-c7456773b783

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
