// Dragnet [Ransomware]: dragnet-ransomware-2022-0218 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: e64c7112-af0c-53aa-9651-36c00aebf0c1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
