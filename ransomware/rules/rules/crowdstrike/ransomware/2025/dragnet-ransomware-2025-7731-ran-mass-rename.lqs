// Dragnet [Ransomware]: dragnet-ransomware-2025-7731 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: b56fa182-5b4e-559f-8e5b-786e0aee6c32

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
