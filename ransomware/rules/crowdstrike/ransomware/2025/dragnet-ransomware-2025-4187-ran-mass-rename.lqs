// Dragnet [Ransomware]: dragnet-ransomware-2025-4187 — Mass File Rename (dragonforce)
// Status: test | Level: high | ID: 3dc4a76c-22ef-5e8d-86b2-08a68d63a9ae

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
