// Dragnet [Ransomware]: dragnet-ransomware-2022-1843 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 8595f64b-f5eb-5339-9c56-177c67a9e5a8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
