// Dragnet [Ransomware]: dragnet-ransomware-2024-2084 — Mass File Rename (spacebears)
// Status: experimental | Level: high | ID: f75fe063-7356-5091-b7bf-b5777b31af2e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
