// Dragnet [Ransomware]: dragnet-ransomware-2022-1153 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: bbc9e514-abc9-580e-a516-5a68de2e20b2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
