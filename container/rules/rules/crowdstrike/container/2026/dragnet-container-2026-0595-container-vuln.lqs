// Dragnet [Container]: dragnet-container-2026-0595 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 54df0d01-46f0-5baf-83ff-24183007febb

#event_simpleName=*
| (ImageFileName = *chainguard:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
