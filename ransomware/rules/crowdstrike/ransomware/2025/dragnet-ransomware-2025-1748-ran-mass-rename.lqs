// Dragnet [Ransomware]: dragnet-ransomware-2025-1748 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: cc3304ff-6a86-5051-8e22-47cb1c34d78a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
