// Dragnet [Ransomware]: dragnet-ransomware-2020-0251 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 13e967c6-a77d-59e2-b406-b22cc3d3320e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
