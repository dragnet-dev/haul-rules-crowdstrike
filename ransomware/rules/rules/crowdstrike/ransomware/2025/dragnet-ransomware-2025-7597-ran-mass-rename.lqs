// Dragnet [Ransomware]: dragnet-ransomware-2025-7597 — Mass File Rename (morpheus)
// Status: deprecated | Level: high | ID: 59e4e312-622f-586a-a961-6bf656fc6120

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
