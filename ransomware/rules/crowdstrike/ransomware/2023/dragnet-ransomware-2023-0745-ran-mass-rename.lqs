// Dragnet [Ransomware]: dragnet-ransomware-2023-0745 — Mass File Rename (ransomed)
// Status: deprecated | Level: high | ID: bcfc16fb-f8fa-578b-b787-e91d93c180f7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
