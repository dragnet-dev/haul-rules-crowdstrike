// Dragnet [Ransomware]: dragnet-ransomware-2024-4701 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: 1f6ee4a5-a0bf-5fb9-a2ea-525050c060d7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
