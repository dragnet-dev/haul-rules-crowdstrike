// Dragnet [Ransomware]: dragnet-ransomware-2024-2258 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: e61f1a1f-5cc2-5622-b5f4-4491bb3c359f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
