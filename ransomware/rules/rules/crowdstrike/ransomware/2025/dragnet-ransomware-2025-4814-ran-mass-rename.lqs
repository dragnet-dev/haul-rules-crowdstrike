// Dragnet [Ransomware]: dragnet-ransomware-2025-4814 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 9786b90e-34d8-507c-8f9a-ce0d69f41971

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
