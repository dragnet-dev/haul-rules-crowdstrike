// Dragnet [Ransomware]: dragnet-ransomware-2023-3009 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 111074f1-ab04-58e4-9983-d1657859734d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
