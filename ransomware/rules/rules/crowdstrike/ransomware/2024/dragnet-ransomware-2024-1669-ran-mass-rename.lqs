// Dragnet [Ransomware]: dragnet-ransomware-2024-1669 — Mass File Rename (meow)
// Status: experimental | Level: high | ID: a96a7135-5926-5501-987c-300574f74271

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
