// Dragnet [Ransomware]: dragnet-ransomware-2025-0016 — Mass File Rename (obscura)
// Status: deprecated | Level: high | ID: 892521ba-e374-5908-a4bb-3f9bef4c1d00

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
