// Dragnet [Ransomware]: dragnet-ransomware-2025-1234 — Mass File Rename (play)
// Status: experimental | Level: high | ID: dc2ed973-0198-5446-a196-9956f8e3db91

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
