// Dragnet [Ransomware]: dragnet-ransomware-2023-5040 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 573113dd-caa4-56db-9ece-876dc899b64c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
