// Dragnet [Ransomware]: dragnet-ransomware-2026-0567 — Mass File Rename (dragonforce)
// Status: stable | Level: high | ID: c166eca7-2f78-5581-8e03-b55d2a21233f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
