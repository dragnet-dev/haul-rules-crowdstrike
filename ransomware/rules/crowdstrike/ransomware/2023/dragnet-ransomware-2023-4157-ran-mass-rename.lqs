// Dragnet [Ransomware]: dragnet-ransomware-2023-4157 — Mass File Rename (toufan)
// Status: deprecated | Level: high | ID: 78896eb9-10ca-5580-972e-ddb85815351c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
