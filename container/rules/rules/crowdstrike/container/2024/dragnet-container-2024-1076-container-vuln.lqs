// Dragnet [Container]: dragnet-container-2024-1076 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: cd62a7c5-698e-5ca4-989d-0bf02643bb2c

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:9*)
| table([timestamp, ComputerName])
| limit(1000)
