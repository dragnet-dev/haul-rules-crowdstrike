// Dragnet [Ransomware]: dragnet-ransomware-2025-0134 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 7a0471b6-63bf-5992-a278-dee11e410e8d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
