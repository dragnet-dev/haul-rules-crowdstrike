// Dragnet [Ransomware]: dragnet-ransomware-2024-5481 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: b8ac8857-497a-52b4-8e18-f70fd049ebbf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
