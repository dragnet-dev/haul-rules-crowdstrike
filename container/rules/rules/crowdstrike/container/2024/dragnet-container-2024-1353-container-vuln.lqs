// Dragnet [Container]: dragnet-container-2024-1353 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 28d1c99c-a8e7-5fd7-9268-faecbbaed27e

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:9* OR ImageFileName = *ubuntu:16.04-ESM* OR ImageFileName = *ubuntu:18.04* OR ImageFileName = *ubuntu:18.04-ESM* OR ImageFileName = *ubuntu:19.04*)
| table([timestamp, ComputerName])
| limit(1000)
