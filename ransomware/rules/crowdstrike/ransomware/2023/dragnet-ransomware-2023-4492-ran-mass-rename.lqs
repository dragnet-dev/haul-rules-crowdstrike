// Dragnet [Ransomware]: dragnet-ransomware-2023-4492 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: 4869667a-1eb3-51f7-a1fc-7fc761b3f102

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
