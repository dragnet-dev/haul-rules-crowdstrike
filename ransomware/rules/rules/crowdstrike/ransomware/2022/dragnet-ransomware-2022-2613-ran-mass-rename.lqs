// Dragnet [Ransomware]: dragnet-ransomware-2022-2613 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 52b88818-d004-5c2e-9f42-379053e778d1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
