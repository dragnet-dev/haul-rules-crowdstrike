// Dragnet [Ransomware]: dragnet-ransomware-2024-3120 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 8b6f96ae-3d0d-5ef1-bcb6-96a953dd5fae

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
