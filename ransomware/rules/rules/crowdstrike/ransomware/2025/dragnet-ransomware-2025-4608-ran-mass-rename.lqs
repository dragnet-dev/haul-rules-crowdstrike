// Dragnet [Ransomware]: dragnet-ransomware-2025-4608 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: c0b3ac9d-6054-596c-a100-487f19fc52cb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
