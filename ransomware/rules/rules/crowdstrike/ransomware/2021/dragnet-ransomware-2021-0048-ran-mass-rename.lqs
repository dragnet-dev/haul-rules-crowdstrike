// Dragnet [Ransomware]: dragnet-ransomware-2021-0048 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: b7ef8a38-7e8c-50b5-92c9-c149013d4a0c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
