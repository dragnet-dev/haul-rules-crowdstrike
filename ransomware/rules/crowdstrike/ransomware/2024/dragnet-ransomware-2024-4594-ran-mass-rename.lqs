// Dragnet [Ransomware]: dragnet-ransomware-2024-4594 — Mass File Rename (termite)
// Status: experimental | Level: high | ID: ba6b800f-d143-5d7e-954c-ace55bc934ba

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
