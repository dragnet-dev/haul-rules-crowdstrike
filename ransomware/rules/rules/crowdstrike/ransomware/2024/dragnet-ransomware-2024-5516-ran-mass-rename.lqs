// Dragnet [Ransomware]: dragnet-ransomware-2024-5516 — Mass File Rename (spacebears)
// Status: experimental | Level: high | ID: 78e56cd1-52fc-563e-befc-2f13837491d4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
