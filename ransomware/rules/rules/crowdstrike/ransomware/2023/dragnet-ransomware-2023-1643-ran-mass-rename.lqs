// Dragnet [Ransomware]: dragnet-ransomware-2023-1643 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 457909d4-cb82-5050-a7e2-e733df56b764

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
