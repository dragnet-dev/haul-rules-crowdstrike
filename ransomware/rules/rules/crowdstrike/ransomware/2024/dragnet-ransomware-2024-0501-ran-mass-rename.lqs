// Dragnet [Ransomware]: dragnet-ransomware-2024-0501 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 5d10754a-2f1c-5dfd-be75-05c54c51f2d3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
