// Dragnet [Ransomware]: dragnet-ransomware-2023-4617 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 63f6c50f-884f-5d8e-994e-5f20f3446367

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
