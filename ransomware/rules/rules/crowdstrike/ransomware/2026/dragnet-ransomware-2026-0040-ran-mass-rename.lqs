// Dragnet [Ransomware]: dragnet-ransomware-2026-0040 — Mass File Rename (aurora)
// Status: stable | Level: high | ID: 513a77b3-3430-5081-8059-222fbfabc337

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
