// Dragnet [Ransomware]: dragnet-ransomware-2024-0752 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 06476cfa-4437-5b94-a6d1-48115594a307

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
