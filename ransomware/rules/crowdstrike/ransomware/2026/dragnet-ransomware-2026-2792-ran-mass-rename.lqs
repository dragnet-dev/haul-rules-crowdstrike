// Dragnet [Ransomware]: dragnet-ransomware-2026-2792 — Mass File Rename (kairos)
// Status: deprecated | Level: high | ID: 4db6a02e-7223-5f97-8e14-8d45e0fb21b6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
