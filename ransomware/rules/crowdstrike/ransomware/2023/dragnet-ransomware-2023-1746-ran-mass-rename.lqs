// Dragnet [Ransomware]: dragnet-ransomware-2023-1746 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: f16c22b9-bd08-56e6-9336-2da88c311b94

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
