// Dragnet [Container]: dragnet-container-2026-2356 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: ba4bc550-3b6d-5dbd-b815-4b846c64f902

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:7* OR ImageFileName = *debian:8*)
| table([timestamp, ComputerName])
| limit(1000)
