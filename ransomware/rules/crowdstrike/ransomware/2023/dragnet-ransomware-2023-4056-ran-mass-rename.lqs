// Dragnet [Ransomware]: dragnet-ransomware-2023-4056 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 12a4b5e7-cb1c-5071-a25f-4f3f08642465

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
