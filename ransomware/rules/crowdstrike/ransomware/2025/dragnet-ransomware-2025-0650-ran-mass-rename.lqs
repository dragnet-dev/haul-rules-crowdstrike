// Dragnet [Ransomware]: dragnet-ransomware-2025-0650 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: d9fdd530-5bfa-5dca-8ebe-4474c446578e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
