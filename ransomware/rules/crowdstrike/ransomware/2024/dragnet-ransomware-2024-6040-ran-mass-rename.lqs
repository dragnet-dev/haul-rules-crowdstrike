// Dragnet [Ransomware]: dragnet-ransomware-2024-6040 — Mass File Rename (apt73)
// Status: experimental | Level: high | ID: 220963d2-1ed0-5dbb-891e-512fc858e157

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
