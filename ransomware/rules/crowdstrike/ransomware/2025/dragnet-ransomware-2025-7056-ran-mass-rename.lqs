// Dragnet [Ransomware]: dragnet-ransomware-2025-7056 — Mass File Rename (coinbasecartel)
// Status: experimental | Level: high | ID: e2d62a0e-634e-53ed-adf3-8af96de7dcfa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
