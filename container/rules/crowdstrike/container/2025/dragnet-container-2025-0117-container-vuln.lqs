// Dragnet [Container]: dragnet-container-2025-0117 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 63bf5af4-a33d-5130-9ce3-6a5a228a9ff7

#event_simpleName=*
| (ImageFileName = *amazonlinux:2* OR ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *oraclelinux:9* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:20.04* OR ImageFileName = *ubuntu:20.04-ESM* OR ImageFileName = *ubuntu:22.04* OR ImageFileName = *ubuntu:23.10* OR ImageFileName = *ubuntu:24.04* OR ImageFileName = *ubuntu:24.10* OR ImageFileName = *ubuntu:25.04* OR ImageFileName = *ubuntu:25.10* OR ImageFileName = *ubuntu:26.04*)
| table([timestamp, ComputerName])
| limit(1000)
