// Dragnet [Ransomware]: dragnet-ransomware-2022-0883 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: eab614a0-fd8c-5587-b04b-96a2a89bed5b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
