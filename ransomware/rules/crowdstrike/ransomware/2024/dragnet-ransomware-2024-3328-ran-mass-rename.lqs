// Dragnet [Ransomware]: dragnet-ransomware-2024-3328 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 48288834-2075-5201-ad29-55c38b41bc60

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
