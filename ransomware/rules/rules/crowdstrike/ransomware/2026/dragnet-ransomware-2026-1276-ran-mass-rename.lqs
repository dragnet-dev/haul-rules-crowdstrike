// Dragnet [Ransomware]: dragnet-ransomware-2026-1276 — Mass File Rename (lockbit5)
// Status: stable | Level: high | ID: 68778511-4f83-5449-8205-e41ba45bb0a4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
