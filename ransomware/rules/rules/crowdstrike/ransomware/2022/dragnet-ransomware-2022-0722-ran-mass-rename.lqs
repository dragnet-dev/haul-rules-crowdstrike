// Dragnet [Ransomware]: dragnet-ransomware-2022-0722 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 87567eed-2fa2-5d6d-883b-67f318ee731a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
