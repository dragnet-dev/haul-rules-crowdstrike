// Dragnet [Container]: dragnet-container-2026-3080 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 58e3f389-006d-5a28-975c-2296c996f5de

#event_simpleName=*
| (ImageFileName = *amazonlinux:1* OR ImageFileName = *chainguard:* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *oraclelinux:7* OR ImageFileName = *ubuntu:15.10* OR ImageFileName = *ubuntu:16.04* OR ImageFileName = *ubuntu:16.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
