// Dragnet [Ransomware]: dragnet-ransomware-2022-1008 — Mass File Rename (vicesociety)
// Status: deprecated | Level: high | ID: 83912738-fa6c-58c9-b456-31cdddb4dd16

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
