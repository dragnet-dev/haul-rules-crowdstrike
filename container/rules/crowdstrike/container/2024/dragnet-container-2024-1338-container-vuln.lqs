// Dragnet [Container]: dragnet-container-2024-1338 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: a1eccd6b-c172-551e-a0ac-04918aadc60d

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:8* OR ImageFileName = *debian:9* OR ImageFileName = *ubuntu:18.04* OR ImageFileName = *ubuntu:18.04-ESM* OR ImageFileName = *ubuntu:18.10*)
| table([timestamp, ComputerName])
| limit(1000)
