// Dragnet [Ransomware]: dragnet-ransomware-2024-1373 — Mass File Rename (blacklock)
// Status: experimental | Level: high | ID: 465b7b5f-b999-53d1-a2a5-c7bb7ccc09da

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
