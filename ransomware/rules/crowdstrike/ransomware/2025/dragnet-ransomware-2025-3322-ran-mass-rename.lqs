// Dragnet [Ransomware]: dragnet-ransomware-2025-3322 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: e82b7460-3f5c-54db-ba39-e5b5c8ff49fc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
