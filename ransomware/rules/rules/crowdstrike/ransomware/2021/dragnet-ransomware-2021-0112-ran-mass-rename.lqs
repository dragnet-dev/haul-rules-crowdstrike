// Dragnet [Ransomware]: dragnet-ransomware-2021-0112 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 1b5aa08a-d5a0-50cd-b280-8c4b5b6c6018

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
