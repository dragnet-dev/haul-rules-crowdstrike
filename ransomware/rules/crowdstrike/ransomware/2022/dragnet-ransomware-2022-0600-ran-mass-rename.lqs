// Dragnet [Ransomware]: dragnet-ransomware-2022-0600 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: a76b33ff-c656-5579-8919-ddb06eb1fd8d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
