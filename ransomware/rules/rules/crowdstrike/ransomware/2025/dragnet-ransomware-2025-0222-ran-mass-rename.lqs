// Dragnet [Ransomware]: dragnet-ransomware-2025-0222 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 61387be6-33c8-5af4-b261-45622f4e3967

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
