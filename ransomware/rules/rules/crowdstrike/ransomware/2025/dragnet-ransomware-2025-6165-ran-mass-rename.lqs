// Dragnet [Ransomware]: dragnet-ransomware-2025-6165 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: b2e48ccd-bf9a-5640-bc34-76ebeffa4a33

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
