// Dragnet [Ransomware]: dragnet-ransomware-2025-6333 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 50cf7fb3-c423-5a11-bd19-f6411d6e7b31

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
