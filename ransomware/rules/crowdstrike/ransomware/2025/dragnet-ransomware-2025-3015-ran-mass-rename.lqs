// Dragnet [Ransomware]: dragnet-ransomware-2025-3015 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 3dde9e3d-448f-5e23-ba09-22f1317aaf26

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
