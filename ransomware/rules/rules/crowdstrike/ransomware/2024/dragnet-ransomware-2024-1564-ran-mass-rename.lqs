// Dragnet [Ransomware]: dragnet-ransomware-2024-1564 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: f7c908ff-938b-5a72-8cfc-888ac9098907

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
