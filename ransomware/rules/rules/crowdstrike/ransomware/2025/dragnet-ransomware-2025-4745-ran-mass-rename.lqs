// Dragnet [Ransomware]: dragnet-ransomware-2025-4745 — Mass File Rename (worldleaks)
// Status: experimental | Level: high | ID: 2cac7b1a-7dd0-58d9-9a7f-0f5635bcfd99

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
