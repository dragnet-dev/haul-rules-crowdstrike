// Dragnet [Ransomware]: dragnet-ransomware-2024-0409 — Mass File Rename (playboy)
// Status: experimental | Level: high | ID: 045146c5-3d92-581f-9340-25ef87ed6746

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
