// Dragnet [Ransomware]: dragnet-ransomware-2023-0950 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 96c55e46-5891-538e-8707-f6e503ccc8dd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
