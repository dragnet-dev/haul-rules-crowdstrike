// Dragnet [Ransomware]: dragnet-ransomware-2023-0394 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: 450d9c6d-78e2-5e1d-b365-e43aae29686e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
