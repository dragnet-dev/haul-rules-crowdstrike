// Dragnet [Ransomware]: dragnet-ransomware-2022-0561 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 7946d540-9030-5d8e-b417-605ce883b6b2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
