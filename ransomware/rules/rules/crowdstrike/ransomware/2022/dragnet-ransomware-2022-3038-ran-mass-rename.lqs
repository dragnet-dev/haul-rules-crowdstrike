// Dragnet [Ransomware]: dragnet-ransomware-2022-3038 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 1720c437-3220-58e8-9b8c-b75b615302fb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
