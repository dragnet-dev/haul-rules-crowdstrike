// Dragnet [Ransomware]: dragnet-ransomware-2024-3136 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 97d7b8b8-846f-5dd6-a064-59ea3755cf1e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
