// Dragnet [Ransomware]: dragnet-ransomware-2023-0588 — Mass File Rename (cloak)
// Status: deprecated | Level: high | ID: ab9412c1-8351-5ed6-985a-314c5e4e4d38

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
