// Dragnet [Ransomware]: dragnet-ransomware-2024-4757 — Mass File Rename (rhysida)
// Status: experimental | Level: high | ID: 41dcc906-1d5c-5f69-8297-8fe8c000e620

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
