// Dragnet [Ransomware]: dragnet-ransomware-2025-2658 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 6d7ebd7a-9037-5f8b-9a39-8cd96a30e029

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
