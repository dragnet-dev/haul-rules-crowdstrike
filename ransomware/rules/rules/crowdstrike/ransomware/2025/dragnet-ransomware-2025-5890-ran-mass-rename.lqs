// Dragnet [Ransomware]: dragnet-ransomware-2025-5890 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: a4f31203-ba68-50b3-9841-1e5fd8f2d784

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
