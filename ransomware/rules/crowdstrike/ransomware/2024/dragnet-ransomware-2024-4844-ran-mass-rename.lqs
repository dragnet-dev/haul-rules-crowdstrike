// Dragnet [Ransomware]: dragnet-ransomware-2024-4844 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 832eeb7a-5dba-5896-beef-f3272c99a40e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
