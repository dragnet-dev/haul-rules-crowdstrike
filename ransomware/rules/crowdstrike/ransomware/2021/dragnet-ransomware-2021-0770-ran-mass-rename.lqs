// Dragnet [Ransomware]: dragnet-ransomware-2021-0770 — Mass File Rename (maui)
// Status: deprecated | Level: high | ID: a8fb7e9d-ed3f-594a-829e-1b650b96f992

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
