// Dragnet [Ransomware]: dragnet-ransomware-2024-5082 — Mass File Rename (metaencryptor)
// Status: experimental | Level: high | ID: d1ed4165-4761-5c3c-898f-4ab1a13a1d2a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
