// Dragnet [Ransomware]: dragnet-ransomware-2025-7499 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: b67af833-cfdc-5f12-ac19-1a8f56677fc3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
