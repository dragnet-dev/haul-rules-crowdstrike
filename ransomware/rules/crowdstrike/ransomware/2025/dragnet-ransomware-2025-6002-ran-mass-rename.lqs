// Dragnet [Ransomware]: dragnet-ransomware-2025-6002 — Mass File Rename (cloak)
// Status: deprecated | Level: high | ID: 7dbf5021-f3a7-521e-baf0-5292d4ef3455

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
