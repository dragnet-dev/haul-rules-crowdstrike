// Dragnet [Ransomware]: dragnet-ransomware-2023-2711 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 01c680e0-5ee2-52dd-9d06-c00a63effc09

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
