// Dragnet [Ransomware]: dragnet-ransomware-2023-3657 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 5aacd311-0d31-5ad8-a26c-98f5f73ad65c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
