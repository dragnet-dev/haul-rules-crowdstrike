// Dragnet [Ransomware]: dragnet-ransomware-2025-0116 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: c34ff9df-4beb-504d-a471-1bda6cf2779c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
