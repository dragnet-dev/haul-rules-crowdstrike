// Dragnet [Ransomware]: dragnet-ransomware-2026-2052 — Mass File Rename (lockbit5)
// Status: test | Level: high | ID: 1176d11d-57d4-5985-a6d2-189abd5cd4d6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
