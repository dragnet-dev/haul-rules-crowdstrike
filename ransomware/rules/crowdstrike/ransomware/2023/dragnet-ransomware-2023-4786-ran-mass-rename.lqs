// Dragnet [Ransomware]: dragnet-ransomware-2023-4786 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: ef848d88-4335-5629-ad5d-baa9957c4089

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
