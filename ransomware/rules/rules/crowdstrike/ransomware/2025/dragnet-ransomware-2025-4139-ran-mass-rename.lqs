// Dragnet [Ransomware]: dragnet-ransomware-2025-4139 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 27b7d707-fe3e-59a4-894f-8d9edadbd72c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
