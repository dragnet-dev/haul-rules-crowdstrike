// Dragnet [Ransomware]: dragnet-ransomware-2026-0551 — Mass File Rename (worldleaks)
// Status: stable | Level: high | ID: 2907cb40-8653-563a-a6f5-be1d1d1a6b45

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
