// Dragnet [Ransomware]: dragnet-ransomware-2023-3709 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: 89a9292c-f801-5811-957f-1fe860b65493

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
