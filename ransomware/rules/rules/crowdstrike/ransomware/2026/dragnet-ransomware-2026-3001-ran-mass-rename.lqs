// Dragnet [Ransomware]: dragnet-ransomware-2026-3001 — Mass File Rename (dragonforce)
// Status: test | Level: high | ID: 443a8517-568f-558d-95b4-710a6d32b793

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
