// Dragnet [Ransomware]: dragnet-ransomware-2024-5909 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 7736da61-2ca5-5c26-be83-93c0b733690d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
