// Dragnet [Ransomware]: dragnet-ransomware-2023-2055 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 22eedb6e-121e-57a3-96b1-ecaf0ce23fcc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
