// Dragnet [Ransomware]: dragnet-ransomware-2024-1912 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: b1285c12-d5ef-5498-9bc3-7bef07a1c7d1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
