// Dragnet [Ransomware]: dragnet-ransomware-2023-2742 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: cfe7f4bf-02f2-5286-8625-0d72abb2a331

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
