// Dragnet [Ransomware]: dragnet-ransomware-2023-1888 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: caec6983-c39c-5923-a97d-38f5cc659806

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
