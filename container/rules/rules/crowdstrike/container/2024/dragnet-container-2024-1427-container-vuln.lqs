// Dragnet [Container]: dragnet-container-2024-1427 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: dc7cd79c-a27f-5903-9f61-6c4c2dbf2688

#event_simpleName=*
| (ImageFileName = *chainguard:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
