// Dragnet [Ransomware]: dragnet-ransomware-2025-1995 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: c7f3a0d8-c0f4-50e5-80ff-18373a9fab18

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
