// Dragnet [Ransomware]: dragnet-ransomware-2023-3979 — Mass File Rename (nokoyawa)
// Status: experimental | Level: high | ID: 43929207-bf2e-5666-a136-08dc8269e51d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
