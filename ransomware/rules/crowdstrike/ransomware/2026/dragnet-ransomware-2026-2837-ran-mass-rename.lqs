// Dragnet [Ransomware]: dragnet-ransomware-2026-2837 — Mass File Rename (payoutsking)
// Status: stable | Level: high | ID: 2bb552ec-abd7-5686-8523-2d2a9902f099

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
