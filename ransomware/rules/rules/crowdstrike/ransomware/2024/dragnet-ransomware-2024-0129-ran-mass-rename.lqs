// Dragnet [Ransomware]: dragnet-ransomware-2024-0129 — Mass File Rename (cloak)
// Status: experimental | Level: high | ID: af1e3a69-e825-5347-8aac-5777e38a5565

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
