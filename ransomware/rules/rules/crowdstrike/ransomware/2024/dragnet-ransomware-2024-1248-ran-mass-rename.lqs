// Dragnet [Ransomware]: dragnet-ransomware-2024-1248 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 96cc84ce-3a3e-557d-9704-bdebcc24b2ab

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
