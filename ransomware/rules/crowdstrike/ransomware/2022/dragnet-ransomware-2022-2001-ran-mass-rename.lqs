// Dragnet [Ransomware]: dragnet-ransomware-2022-2001 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: cb740e55-8643-5c19-8a09-b487f22d0c1c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
