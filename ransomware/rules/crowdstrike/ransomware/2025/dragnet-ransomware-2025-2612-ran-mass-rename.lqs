// Dragnet [Ransomware]: dragnet-ransomware-2025-2612 — Mass File Rename (play)
// Status: experimental | Level: high | ID: d83c786c-8eb9-5ebb-900e-3cb98ddf7ace

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
