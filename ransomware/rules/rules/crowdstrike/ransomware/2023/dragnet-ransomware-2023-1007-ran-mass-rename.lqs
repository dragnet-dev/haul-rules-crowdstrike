// Dragnet [Ransomware]: dragnet-ransomware-2023-1007 — Mass File Rename (toufan)
// Status: deprecated | Level: high | ID: 7e355943-576d-57cd-86b2-5db79d84d3bb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
