// Dragnet [Ransomware]: dragnet-ransomware-2025-7880 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 03ae8186-7f08-581e-8797-48570c5da463

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
