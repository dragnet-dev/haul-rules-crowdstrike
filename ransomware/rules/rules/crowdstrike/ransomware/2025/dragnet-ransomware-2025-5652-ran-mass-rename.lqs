// Dragnet [Ransomware]: dragnet-ransomware-2025-5652 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: e2ebeb02-eddd-537f-9703-5cf39e0b226d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
