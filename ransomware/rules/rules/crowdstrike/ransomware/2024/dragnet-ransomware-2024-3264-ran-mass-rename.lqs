// Dragnet [Ransomware]: dragnet-ransomware-2024-3264 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: fd2f2bc2-83c9-510d-852a-96d153a9b908

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
