// Dragnet [Ransomware]: dragnet-ransomware-2025-4192 — Mass File Rename (chaos)
// Status: experimental | Level: high | ID: 92dbcdef-5519-5562-94df-f83578077e25

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
