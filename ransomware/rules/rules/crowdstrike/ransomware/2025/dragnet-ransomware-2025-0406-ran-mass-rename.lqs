// Dragnet [Ransomware]: dragnet-ransomware-2025-0406 — Mass File Rename (kraken)
// Status: experimental | Level: high | ID: fb8a2b7d-4595-5266-9c00-3cc541debae7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
