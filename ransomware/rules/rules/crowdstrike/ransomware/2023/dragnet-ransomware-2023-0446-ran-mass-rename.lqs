// Dragnet [Ransomware]: dragnet-ransomware-2023-0446 — Mass File Rename (monti)
// Status: experimental | Level: high | ID: e5f0e112-d2cc-587e-9e9a-cccccbacb0fc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
