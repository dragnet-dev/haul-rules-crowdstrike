// Dragnet [Ransomware]: dragnet-ransomware-2025-5093 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 44be10ca-a34f-5407-a279-83b22cd2328d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
