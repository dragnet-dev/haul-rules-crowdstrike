// Dragnet [Ransomware]: dragnet-ransomware-2023-1568 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: b80f6e94-6c1f-5b81-9ffe-5c0f4f6d336c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
