// Dragnet [Ransomware]: dragnet-ransomware-2024-1027 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: f5a33b7d-ae09-5778-ba96-3a74118945f4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
