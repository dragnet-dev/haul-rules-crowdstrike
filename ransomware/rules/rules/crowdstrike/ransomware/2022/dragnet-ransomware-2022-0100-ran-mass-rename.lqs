// Dragnet [Ransomware]: dragnet-ransomware-2022-0100 — Mass File Rename (vicesociety)
// Status: deprecated | Level: high | ID: ab075dd4-73a1-52d6-a4a0-242637b749d1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
