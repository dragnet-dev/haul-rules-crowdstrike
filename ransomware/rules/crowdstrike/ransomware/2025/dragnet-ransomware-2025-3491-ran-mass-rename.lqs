// Dragnet [Ransomware]: dragnet-ransomware-2025-3491 — Mass File Rename (rhysida)
// Status: deprecated | Level: high | ID: e00604cf-1bd4-5aea-9582-bbf4ae854108

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
