// Dragnet [Ransomware]: dragnet-ransomware-2023-0210 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 155696b9-1da1-581b-a8f3-095cef6a6ca1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
