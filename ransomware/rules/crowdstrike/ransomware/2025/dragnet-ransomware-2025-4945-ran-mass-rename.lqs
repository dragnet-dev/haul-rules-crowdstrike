// Dragnet [Ransomware]: dragnet-ransomware-2025-4945 — Mass File Rename (play)
// Status: experimental | Level: high | ID: c773f610-84a8-5649-a06c-47c392e97138

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
