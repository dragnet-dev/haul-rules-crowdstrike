// Dragnet [Ransomware]: dragnet-ransomware-2024-4413 — Mass File Rename (raworld)
// Status: experimental | Level: high | ID: 033aa3ac-ad3f-54ff-bec2-2249a4de14d9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
