// Dragnet [Ransomware]: dragnet-ransomware-2026-2839 — Mass File Rename (LeakBazaar)
// Status: stable | Level: high | ID: c3f77f88-4ed4-5313-9c73-20d798121d23

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
