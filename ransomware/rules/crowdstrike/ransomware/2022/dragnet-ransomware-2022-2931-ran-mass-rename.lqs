// Dragnet [Ransomware]: dragnet-ransomware-2022-2931 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 35a3b40a-1452-5b4e-9786-d6b8fd4d6603

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
