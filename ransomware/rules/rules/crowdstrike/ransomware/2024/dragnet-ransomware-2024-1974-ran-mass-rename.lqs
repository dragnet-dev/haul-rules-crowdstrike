// Dragnet [Ransomware]: dragnet-ransomware-2024-1974 — Mass File Rename (qilin)
// Status: deprecated | Level: high | ID: f0cdf493-f5fe-5361-8635-6a696c7ac091

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
