// Dragnet [Ransomware]: dragnet-ransomware-2026-1354 — Mass File Rename (fulcrumsec)
// Status: stable | Level: high | ID: 060a58c5-d161-5468-95fa-36e34c61c312

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
