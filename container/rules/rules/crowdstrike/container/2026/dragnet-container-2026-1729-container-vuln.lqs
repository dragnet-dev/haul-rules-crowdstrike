// Dragnet [Container]: dragnet-container-2026-1729 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 0a00b9b7-b625-5bf3-9389-8297fd6a020b

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:5*)
| table([timestamp, ComputerName])
| limit(1000)
