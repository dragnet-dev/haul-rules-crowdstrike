// Dragnet [Ransomware]: dragnet-ransomware-2025-7363 — Mass File Rename (play)
// Status: experimental | Level: high | ID: f78ce77a-e277-5dd1-9e1e-45c04cd087b7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
