// Dragnet [Ransomware]: dragnet-ransomware-2023-2035 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 2a69a20e-281b-5209-9566-41220dd70652

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
