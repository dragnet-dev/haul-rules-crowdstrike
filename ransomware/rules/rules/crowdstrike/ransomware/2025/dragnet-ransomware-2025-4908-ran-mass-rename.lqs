// Dragnet [Ransomware]: dragnet-ransomware-2025-4908 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: 1943d0d1-0fb1-59b1-90ef-f6b3f5adc73f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
