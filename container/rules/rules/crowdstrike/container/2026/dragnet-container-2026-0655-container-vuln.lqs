// Dragnet [Container]: dragnet-container-2026-0655 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: a09789b0-1640-5160-b880-8aebe8acb4be

#event_simpleName=*
| (ImageFileName = *debian:7* OR ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10* OR ImageFileName = *ubuntu:13.10*)
| table([timestamp, ComputerName])
| limit(1000)
