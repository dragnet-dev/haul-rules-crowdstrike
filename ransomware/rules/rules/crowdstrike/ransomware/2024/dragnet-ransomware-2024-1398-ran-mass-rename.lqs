// Dragnet [Ransomware]: dragnet-ransomware-2024-1398 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: d966d789-04d2-593b-9375-7c48770855bb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
