// Dragnet [Ransomware]: dragnet-ransomware-2025-7889 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: b6b05f6e-5170-5bcc-8616-d8a28f36e048

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
