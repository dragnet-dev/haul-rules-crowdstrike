// Dragnet [Ransomware]: dragnet-ransomware-2023-5238 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: c002f59b-803b-580c-8abb-b3bae949fb65

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
