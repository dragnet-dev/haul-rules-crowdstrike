// Dragnet [Ransomware]: dragnet-ransomware-2025-7287 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: bc5c4347-de69-522b-8ea8-9f64ad5dc6db

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
