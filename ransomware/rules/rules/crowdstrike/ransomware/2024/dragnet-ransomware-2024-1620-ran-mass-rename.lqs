// Dragnet [Ransomware]: dragnet-ransomware-2024-1620 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 23847be4-a7f0-5c6c-9f07-763901f3f4b0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
