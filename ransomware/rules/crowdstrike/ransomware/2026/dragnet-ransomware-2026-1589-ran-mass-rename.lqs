// Dragnet [Ransomware]: dragnet-ransomware-2026-1589 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 3831eb02-0f5f-5509-88cd-dafde7081f1e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
