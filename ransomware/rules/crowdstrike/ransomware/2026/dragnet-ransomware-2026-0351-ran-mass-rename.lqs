// Dragnet [Ransomware]: dragnet-ransomware-2026-0351 — Mass File Rename (nightspire)
// Status: deprecated | Level: high | ID: 1053035a-2623-5995-b999-34f1258a7e4d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
