// Dragnet [Ransomware]: dragnet-ransomware-2024-1272 — Mass File Rename (qilin)
// Status: deprecated | Level: high | ID: 8ffaf192-c165-5e84-a280-3bd14a379733

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
