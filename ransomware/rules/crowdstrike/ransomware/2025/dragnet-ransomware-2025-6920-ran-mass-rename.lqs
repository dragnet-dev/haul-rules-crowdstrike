// Dragnet [Ransomware]: dragnet-ransomware-2025-6920 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 8936ef19-1779-52f5-b1ca-ca1d579c18ee

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
