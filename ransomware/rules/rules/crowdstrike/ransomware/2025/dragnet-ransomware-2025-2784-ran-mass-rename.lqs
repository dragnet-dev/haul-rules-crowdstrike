// Dragnet [Ransomware]: dragnet-ransomware-2025-2784 — Mass File Rename (blackshrantac)
// Status: experimental | Level: high | ID: 453a40d9-20e5-5085-b988-4df1cd50a978

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
