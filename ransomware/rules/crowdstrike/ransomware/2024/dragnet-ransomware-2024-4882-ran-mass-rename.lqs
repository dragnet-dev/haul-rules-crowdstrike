// Dragnet [Ransomware]: dragnet-ransomware-2024-4882 — Mass File Rename (dragonforce)
// Status: deprecated | Level: high | ID: 6d04981a-1e36-5132-bb1b-4e458c8ca835

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
