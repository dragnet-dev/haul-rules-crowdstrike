// Dragnet [Ransomware]: dragnet-ransomware-2025-6738 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: 8933523f-6c22-5f4e-b4ca-ec6f9079750e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
