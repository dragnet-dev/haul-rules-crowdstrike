// Dragnet [Ransomware]: dragnet-ransomware-2023-3778 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: fde214de-1742-537c-a85b-f6a2c56299c5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
