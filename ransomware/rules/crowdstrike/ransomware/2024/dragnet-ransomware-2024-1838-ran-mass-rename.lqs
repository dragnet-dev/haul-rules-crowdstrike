// Dragnet [Ransomware]: dragnet-ransomware-2024-1838 — Mass File Rename (meow)
// Status: experimental | Level: high | ID: 2dd2d3b2-5651-5cd7-99de-880a7bbe3b53

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
