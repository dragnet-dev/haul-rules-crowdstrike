// Dragnet [Ransomware]: dragnet-ransomware-2023-2159 — Mass File Rename (metaencryptor)
// Status: experimental | Level: high | ID: 07e5f6de-25ab-51d9-88f8-0f48a629b744

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
