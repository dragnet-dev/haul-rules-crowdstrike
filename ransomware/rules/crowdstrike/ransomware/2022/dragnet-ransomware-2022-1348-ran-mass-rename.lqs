// Dragnet [Ransomware]: dragnet-ransomware-2022-1348 — Mass File Rename (snatch)
// Status: deprecated | Level: high | ID: d2998771-75eb-52ef-8e06-a504778733a8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
