// Dragnet [Ransomware]: dragnet-ransomware-2023-4083 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: 8cf4a34b-d0b0-553d-9091-8a84d4cb8f26

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
