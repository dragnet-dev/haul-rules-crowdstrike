// Dragnet [Ransomware]: dragnet-ransomware-2026-0552 — Mass File Rename (lapsus$)
// Status: deprecated | Level: high | ID: 8cf37e98-20b9-5f7c-a0c9-637731ec1a59

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
