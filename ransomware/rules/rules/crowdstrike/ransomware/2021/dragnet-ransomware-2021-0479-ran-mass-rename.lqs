// Dragnet [Ransomware]: dragnet-ransomware-2021-0479 — Mass File Rename (blackmatter)
// Status: deprecated | Level: high | ID: 3554acea-c58d-55eb-866c-39f3e3840d3d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
