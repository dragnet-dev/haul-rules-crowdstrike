// Dragnet [Ransomware]: dragnet-ransomware-2025-4114 — Mass File Rename (nightspire)
// Status: deprecated | Level: high | ID: 4294c439-421c-5555-a06f-10d632470494

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
