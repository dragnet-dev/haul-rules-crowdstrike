// Dragnet [Ransomware]: dragnet-ransomware-2025-3453 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 450dc037-4e46-554b-930a-825c09609cc9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
