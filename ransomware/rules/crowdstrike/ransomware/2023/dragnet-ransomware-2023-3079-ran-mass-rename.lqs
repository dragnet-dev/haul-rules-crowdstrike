// Dragnet [Ransomware]: dragnet-ransomware-2023-3079 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 31963a4e-2745-5c95-a8bc-825475fa8807

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
