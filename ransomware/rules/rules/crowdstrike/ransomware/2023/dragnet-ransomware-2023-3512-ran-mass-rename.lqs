// Dragnet [Ransomware]: dragnet-ransomware-2023-3512 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 3c0b2260-2017-54b4-897f-7a0ccf5d2777

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
