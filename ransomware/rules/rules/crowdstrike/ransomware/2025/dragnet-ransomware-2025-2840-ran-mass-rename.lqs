// Dragnet [Ransomware]: dragnet-ransomware-2025-2840 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 68f35aef-285f-5261-9825-0174a421347a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
