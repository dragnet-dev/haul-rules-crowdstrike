// Dragnet [Ransomware]: dragnet-ransomware-2023-3191 — Mass File Rename (qilin)
// Status: deprecated | Level: high | ID: 0b2e2f72-75a6-52e3-ab8a-5b235ef29e74

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
