// Dragnet [Ransomware]: dragnet-ransomware-2021-1213 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: ac4194ee-077d-5ce3-9cf1-d9cdca94bf2d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
