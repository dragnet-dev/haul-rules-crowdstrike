// Dragnet [Ransomware]: dragnet-ransomware-2025-1758 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 94aff599-82fe-51e5-af5e-53cfca929ffa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
