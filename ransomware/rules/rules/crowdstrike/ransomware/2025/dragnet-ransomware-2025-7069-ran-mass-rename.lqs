// Dragnet [Ransomware]: dragnet-ransomware-2025-7069 — Mass File Rename (blacknevas)
// Status: experimental | Level: high | ID: 3956c105-eb74-588a-9f0f-8a8f8b78d939

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
