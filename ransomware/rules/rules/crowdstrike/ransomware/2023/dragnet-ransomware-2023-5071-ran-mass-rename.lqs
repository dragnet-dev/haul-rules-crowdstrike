// Dragnet [Ransomware]: dragnet-ransomware-2023-5071 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 6b751881-bde6-543e-94db-159bae506b1a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
