// Dragnet [Ransomware]: dragnet-ransomware-2022-1292 — Mass File Rename (cuba)
// Status: deprecated | Level: high | ID: d40e578c-af98-50d2-919a-bfd707ac4062

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
