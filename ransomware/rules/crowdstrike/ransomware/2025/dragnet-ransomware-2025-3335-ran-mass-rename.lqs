// Dragnet [Ransomware]: dragnet-ransomware-2025-3335 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 7a9e31c6-ab96-59c2-ba01-6559de13fe91

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
