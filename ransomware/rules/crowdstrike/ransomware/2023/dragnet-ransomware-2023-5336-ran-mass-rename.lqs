// Dragnet [Ransomware]: dragnet-ransomware-2023-5336 — Mass File Rename (ransomhouse)
// Status: experimental | Level: high | ID: 884b87fd-2bfc-510f-908c-508d9b5c02b0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
