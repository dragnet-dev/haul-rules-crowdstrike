// Dragnet [Ransomware]: dragnet-ransomware-2025-2224 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: 3f007de6-f606-5620-8e2e-18552a44dcd4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
