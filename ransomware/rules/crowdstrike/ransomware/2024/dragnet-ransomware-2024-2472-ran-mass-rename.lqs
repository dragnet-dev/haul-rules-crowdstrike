// Dragnet [Ransomware]: dragnet-ransomware-2024-2472 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: b6544817-2088-54e4-9ca1-97b14d9fb139

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
