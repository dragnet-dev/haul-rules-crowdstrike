// Dragnet [Ransomware]: dragnet-ransomware-2024-1043 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 3463caab-692a-572e-be9d-936849b40ae2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
