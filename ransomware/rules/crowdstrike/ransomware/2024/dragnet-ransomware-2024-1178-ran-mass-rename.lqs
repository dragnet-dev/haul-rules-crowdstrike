// Dragnet [Ransomware]: dragnet-ransomware-2024-1178 — Mass File Rename (raworld)
// Status: experimental | Level: high | ID: 6e195c33-3792-546f-b122-0dfe897c10c5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
