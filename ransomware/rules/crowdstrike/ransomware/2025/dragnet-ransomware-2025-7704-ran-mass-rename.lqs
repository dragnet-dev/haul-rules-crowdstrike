// Dragnet [Ransomware]: dragnet-ransomware-2025-7704 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 6857072b-5f0d-5acd-9a00-0b0d93b9d24f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
