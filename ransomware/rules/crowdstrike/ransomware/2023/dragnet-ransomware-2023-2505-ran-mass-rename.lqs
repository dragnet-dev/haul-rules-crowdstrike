// Dragnet [Ransomware]: dragnet-ransomware-2023-2505 — Mass File Rename (ragnarlocker)
// Status: experimental | Level: high | ID: d2255be4-51ef-589e-af44-c86fce6611af

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
