// Dragnet [Ransomware]: dragnet-ransomware-2025-1949 — Mass File Rename (dragonforce)
// Status: test | Level: high | ID: 8b671704-00da-53ae-8491-ad714a33dc0a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
