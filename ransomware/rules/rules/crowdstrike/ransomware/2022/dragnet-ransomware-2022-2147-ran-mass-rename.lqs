// Dragnet [Ransomware]: dragnet-ransomware-2022-2147 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 1f67b321-b942-50fe-9bc2-ec440ec57f79

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
