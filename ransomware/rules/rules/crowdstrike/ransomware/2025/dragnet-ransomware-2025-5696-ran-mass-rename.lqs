// Dragnet [Ransomware]: dragnet-ransomware-2025-5696 — Mass File Rename (devman)
// Status: experimental | Level: high | ID: fe7685a0-ab19-5739-97b3-664f77f2d0dc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
