// Dragnet [Ransomware]: dragnet-ransomware-2025-7537 — Mass File Rename (devman)
// Status: deprecated | Level: high | ID: c5d48d6d-e2b0-5a0a-9641-c1c262a6ae16

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
