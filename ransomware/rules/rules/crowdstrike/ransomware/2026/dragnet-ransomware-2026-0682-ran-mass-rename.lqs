// Dragnet [Ransomware]: dragnet-ransomware-2026-0682 — Mass File Rename (ciphbit)
// Status: deprecated | Level: high | ID: 18c85659-ed68-528e-a06b-133a02be8bd0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
