// Dragnet [Ransomware]: dragnet-ransomware-2022-0057 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 28e59f60-fddc-5743-8028-35d83e9fb5da

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
