// Dragnet [Ransomware]: dragnet-ransomware-2025-5221 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 60c5c675-5f66-5288-b4d0-1e4447a39b9f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
