// Dragnet [Ransomware]: dragnet-ransomware-2023-4441 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 56577878-d423-5126-b222-e00cedffe1c3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
