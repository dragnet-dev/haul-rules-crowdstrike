// Dragnet [Ransomware]: dragnet-ransomware-2025-3392 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: c0a779ee-d652-5a93-bbc5-f3364a004797

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
