// Dragnet [Ransomware]: dragnet-ransomware-2022-2503 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: a6b61d34-6008-5a95-a51e-8d02891ecfcd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
