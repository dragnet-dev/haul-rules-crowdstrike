// Dragnet [Ransomware]: dragnet-ransomware-2023-2396 — Mass File Rename (cloak)
// Status: deprecated | Level: high | ID: d37d5d99-efe0-532a-837f-dff3d30824c5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
