// Dragnet [Container]: dragnet-container-2025-0058 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 546099e4-ac1d-5844-a708-c716d5e7c6d6

#event_simpleName=*
| (ImageFileName = *chainguard:* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
