// Dragnet [Ransomware]: dragnet-ransomware-2023-1555 — Mass File Rename (monti)
// Status: experimental | Level: high | ID: c265dc10-bff1-58ca-907f-98f0eb753883

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
