// Dragnet [Ransomware]: dragnet-ransomware-2024-0485 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 05de06e0-9e3b-5e6d-a65e-c0db21007de0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
