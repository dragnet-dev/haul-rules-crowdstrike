// Dragnet [Ransomware]: dragnet-ransomware-2025-3545 — Mass File Rename (spacebears)
// Status: experimental | Level: high | ID: 5d89f54a-8f75-5cd6-af64-73faff1d3897

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
