// Dragnet [Ransomware]: dragnet-ransomware-2024-1531 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 983bb42d-3d12-57ee-9652-e15607780b73

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
