// Dragnet [Container]: dragnet-container-2026-3165 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 36e6d6c5-fe82-5c01-ada2-b70569f24aea

#event_simpleName=*
| (ImageFileName = *debian:7* OR ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10* OR ImageFileName = *ubuntu:13.04*)
| table([timestamp, ComputerName])
| limit(1000)
