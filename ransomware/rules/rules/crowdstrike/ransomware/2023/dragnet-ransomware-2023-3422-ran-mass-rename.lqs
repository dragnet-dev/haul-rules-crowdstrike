// Dragnet [Ransomware]: dragnet-ransomware-2023-3422 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: ba0e0ac0-44c4-5a2b-8211-8e7c9713432c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
