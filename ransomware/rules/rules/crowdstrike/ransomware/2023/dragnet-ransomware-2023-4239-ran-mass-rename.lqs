// Dragnet [Ransomware]: dragnet-ransomware-2023-4239 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 845cbec6-3a21-5f72-8e08-2dc35809f025

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
