// Dragnet [Ransomware]: dragnet-ransomware-2024-3881 — Mass File Rename (meow)
// Status: experimental | Level: high | ID: eb5c0d2e-c70b-590e-9682-aed22525dff2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
