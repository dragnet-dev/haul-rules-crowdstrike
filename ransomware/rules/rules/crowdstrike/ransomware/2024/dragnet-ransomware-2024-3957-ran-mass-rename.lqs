// Dragnet [Ransomware]: dragnet-ransomware-2024-3957 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: ef475104-73c9-5229-a041-f7e31acaee31

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
