// Dragnet [Container]: dragnet-container-2024-0038 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: af87e7bf-424f-5300-93f8-3e18ff2f92d7

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:14* OR ImageFileName = *debian:9*)
| table([timestamp, ComputerName])
| limit(1000)
