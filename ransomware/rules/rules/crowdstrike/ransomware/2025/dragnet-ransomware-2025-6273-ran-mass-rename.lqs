// Dragnet [Ransomware]: dragnet-ransomware-2025-6273 — Mass File Rename (BrainCipher)
// Status: experimental | Level: high | ID: d6c296b2-ef1a-53d3-bb57-812781466ce6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
