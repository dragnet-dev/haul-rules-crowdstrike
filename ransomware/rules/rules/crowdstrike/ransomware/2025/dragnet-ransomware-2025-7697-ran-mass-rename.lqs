// Dragnet [Ransomware]: dragnet-ransomware-2025-7697 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: f2baca62-c6e3-5d0c-95ec-6d0b7f6c811b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
