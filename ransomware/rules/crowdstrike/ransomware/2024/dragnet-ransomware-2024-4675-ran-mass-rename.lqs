// Dragnet [Ransomware]: dragnet-ransomware-2024-4675 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: b4b456b5-0f8f-5f03-bc3a-4a9dfb66c3c2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
