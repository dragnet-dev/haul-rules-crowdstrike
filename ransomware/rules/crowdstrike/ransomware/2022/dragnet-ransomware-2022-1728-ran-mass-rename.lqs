// Dragnet [Ransomware]: dragnet-ransomware-2022-1728 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 9f4f473c-dd23-5c2b-b1b5-37029dce8107

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
