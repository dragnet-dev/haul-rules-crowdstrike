// Dragnet [Ransomware]: dragnet-ransomware-2024-5930 — Mass File Rename (flocker)
// Status: experimental | Level: high | ID: 5ea2e67d-3a27-538e-aea9-31553d2f1d87

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
