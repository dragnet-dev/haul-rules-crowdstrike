// Dragnet [Ransomware]: dragnet-ransomware-2024-5616 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: c48169d1-58c5-5740-9deb-fb2ed527f085

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
