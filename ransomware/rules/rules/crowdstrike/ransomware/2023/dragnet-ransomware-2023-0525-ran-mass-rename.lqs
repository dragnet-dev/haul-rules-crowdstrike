// Dragnet [Ransomware]: dragnet-ransomware-2023-0525 — Mass File Rename (noescape)
// Status: experimental | Level: high | ID: d3084e34-9c77-59a4-91c2-f529b296b42d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
