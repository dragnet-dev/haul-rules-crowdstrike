// Dragnet [Ransomware]: dragnet-ransomware-2025-7710 — Mass File Rename (ralord)
// Status: experimental | Level: high | ID: 7d581ee9-d200-5208-94f5-d4c1a6d78e0e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
