// Dragnet [Container]: dragnet-container-2026-0291 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: b6497977-fe96-55a8-ba53-d31d44328df9

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
