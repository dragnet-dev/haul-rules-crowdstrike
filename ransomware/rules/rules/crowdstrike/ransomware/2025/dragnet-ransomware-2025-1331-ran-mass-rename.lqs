// Dragnet [Ransomware]: dragnet-ransomware-2025-1331 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 4fc0d12d-8efe-5bab-b5b3-6d1cd4297fe1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
