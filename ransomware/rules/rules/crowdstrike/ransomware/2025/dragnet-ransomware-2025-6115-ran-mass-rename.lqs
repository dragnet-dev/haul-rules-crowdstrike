// Dragnet [Ransomware]: dragnet-ransomware-2025-6115 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 28e34a56-378c-559d-992d-45076e84cecf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
