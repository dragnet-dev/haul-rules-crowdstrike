// Dragnet [Container]: dragnet-container-2026-2706 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: c7a19523-cbed-5b46-995e-319daba7c753

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *redhat/ubi9:*)
| table([timestamp, ComputerName])
| limit(1000)
