// Dragnet [Ransomware]: dragnet-ransomware-2024-0784 — Mass File Rename (raworld)
// Status: experimental | Level: high | ID: 9a96e18e-73ae-5339-9a74-83edf8df67a0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
