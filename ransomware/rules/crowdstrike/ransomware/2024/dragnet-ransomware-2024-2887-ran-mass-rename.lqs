// Dragnet [Ransomware]: dragnet-ransomware-2024-2887 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 56ee86bc-d1c3-5a8b-82dd-fbc2362e6f2a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
