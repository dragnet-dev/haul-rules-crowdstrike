// Dragnet [Ransomware]: dragnet-ransomware-2025-2625 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 3660e781-617f-5310-b9e3-b6ec870f043c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
