// Dragnet [Ransomware]: dragnet-ransomware-2025-7302 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 6d7e41e7-0eb1-525f-af20-2dcfc7277491

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
