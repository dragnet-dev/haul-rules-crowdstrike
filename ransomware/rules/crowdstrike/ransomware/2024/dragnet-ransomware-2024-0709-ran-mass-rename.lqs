// Dragnet [Ransomware]: dragnet-ransomware-2024-0709 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 285d3371-59f6-59e4-a681-1b60369af940

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
