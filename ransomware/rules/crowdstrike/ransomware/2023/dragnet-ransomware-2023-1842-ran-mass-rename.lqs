// Dragnet [Ransomware]: dragnet-ransomware-2023-1842 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 5c5bc8f6-f3f0-5ce9-ad74-02663cdd2dff

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
