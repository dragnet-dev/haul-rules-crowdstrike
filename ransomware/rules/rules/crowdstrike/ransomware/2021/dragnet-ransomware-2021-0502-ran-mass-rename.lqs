// Dragnet [Ransomware]: dragnet-ransomware-2021-0502 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 9e6614c3-f608-58ba-b3e4-a6803a8fff21

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
