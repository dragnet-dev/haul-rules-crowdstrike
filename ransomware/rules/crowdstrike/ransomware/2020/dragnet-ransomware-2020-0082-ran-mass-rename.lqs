// Dragnet [Ransomware]: dragnet-ransomware-2020-0082 — Mass File Rename (maze)
// Status: deprecated | Level: high | ID: 7d0fcbc2-6996-592b-af8c-5459b5d7b18e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
