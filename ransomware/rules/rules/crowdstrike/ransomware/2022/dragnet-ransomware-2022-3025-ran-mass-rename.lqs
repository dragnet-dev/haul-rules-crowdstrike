// Dragnet [Ransomware]: dragnet-ransomware-2022-3025 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: cb4375bc-cfa6-5847-acc3-c6de8fcd12ee

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
