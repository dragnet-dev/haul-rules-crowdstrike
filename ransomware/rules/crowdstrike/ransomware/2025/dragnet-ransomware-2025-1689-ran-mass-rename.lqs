// Dragnet [Ransomware]: dragnet-ransomware-2025-1689 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 1f8dfd8c-239a-56af-a4ad-9f3b85f05997

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
