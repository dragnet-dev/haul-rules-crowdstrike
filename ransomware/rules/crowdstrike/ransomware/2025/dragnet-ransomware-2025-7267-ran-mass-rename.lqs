// Dragnet [Ransomware]: dragnet-ransomware-2025-7267 — Mass File Rename (pear)
// Status: experimental | Level: high | ID: 5da40009-72c5-5b8a-bb3a-60851ce78316

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
