// Dragnet [Ransomware]: dragnet-ransomware-2026-3304 — Mass File Rename (vect)
// Status: deprecated | Level: high | ID: 5330d499-89c6-57da-8425-bc1e48176c50

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
