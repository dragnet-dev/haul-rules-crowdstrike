// Dragnet [Ransomware]: dragnet-ransomware-2022-0129 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 8985e8fb-ff2d-523e-967d-e91c4b6ecef7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
