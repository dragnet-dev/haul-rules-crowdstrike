// Dragnet [Ransomware]: dragnet-ransomware-2023-4806 — Mass File Rename (play)
// Status: experimental | Level: high | ID: fb5fea17-0138-523a-abcf-5bb9a2877d86

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
