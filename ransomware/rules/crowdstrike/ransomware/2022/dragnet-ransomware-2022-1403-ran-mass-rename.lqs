// Dragnet [Ransomware]: dragnet-ransomware-2022-1403 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: c032f73b-24cd-5af0-91dc-d5ae501e00a7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
