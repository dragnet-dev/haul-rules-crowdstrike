// Dragnet [Ransomware]: dragnet-ransomware-2022-2611 — Mass File Rename (kelvinsecurity)
// Status: deprecated | Level: high | ID: 8594180c-4879-54d9-b1f6-b4c162e7ead8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
