// Dragnet [Ransomware]: dragnet-ransomware-2023-0612 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 8bb16d6a-87c5-51d7-bf1c-01dfac6e84c9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
