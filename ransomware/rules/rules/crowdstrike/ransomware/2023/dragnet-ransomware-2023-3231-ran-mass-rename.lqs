// Dragnet [Ransomware]: dragnet-ransomware-2023-3231 — Mass File Rename (knight)
// Status: experimental | Level: high | ID: 50aee3ea-3eda-5295-b16e-5cbba5d5983e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
