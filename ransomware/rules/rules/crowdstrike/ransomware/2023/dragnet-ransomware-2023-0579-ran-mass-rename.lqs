// Dragnet [Ransomware]: dragnet-ransomware-2023-0579 — Mass File Rename (play)
// Status: experimental | Level: high | ID: f7b04ba5-6bea-5a25-95aa-b1140434c623

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
