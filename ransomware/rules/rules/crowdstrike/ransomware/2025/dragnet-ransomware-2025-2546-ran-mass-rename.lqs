// Dragnet [Ransomware]: dragnet-ransomware-2025-2546 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: c2ef8c6f-2848-5071-b035-46a064912e8b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
