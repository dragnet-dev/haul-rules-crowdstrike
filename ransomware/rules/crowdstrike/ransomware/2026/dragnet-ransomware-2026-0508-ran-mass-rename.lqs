// Dragnet [Ransomware]: dragnet-ransomware-2026-0508 — Mass File Rename (everest)
// Status: stable | Level: high | ID: 70f02e1c-fe0d-5a07-a522-ebd18daed2f1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
