// Dragnet [Ransomware]: dragnet-ransomware-2021-0355 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 270a217d-c2b9-55a9-bc01-185c04ab922f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
