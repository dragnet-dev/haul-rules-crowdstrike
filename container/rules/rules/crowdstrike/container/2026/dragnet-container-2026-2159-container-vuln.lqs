// Dragnet [Container]: dragnet-container-2026-2159 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: c3f2fe0f-bc6e-5768-90e7-38056240a138

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10*)
| table([timestamp, ComputerName])
| limit(1000)
