// Dragnet [Ransomware]: dragnet-ransomware-2023-4925 — Mass File Rename (ragnarlocker)
// Status: experimental | Level: high | ID: 21262734-af0c-56d1-b136-bdeff3c457a6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
