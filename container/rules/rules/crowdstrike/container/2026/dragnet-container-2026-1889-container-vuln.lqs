// Dragnet [Container]: dragnet-container-2026-1889 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 996f2927-c848-5582-95e4-157eabfbe21d

#event_simpleName=*
| (ImageFileName = *debian:7* OR ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *oraclelinux:7* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:14.04*)
| table([timestamp, ComputerName])
| limit(1000)
