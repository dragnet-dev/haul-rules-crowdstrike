// Dragnet [Ransomware]: dragnet-ransomware-2022-0873 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: e531c3d9-fd6a-52a3-98f8-3c2212fff2cd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
