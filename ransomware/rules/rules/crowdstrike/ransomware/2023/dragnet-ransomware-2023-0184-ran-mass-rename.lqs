// Dragnet [Ransomware]: dragnet-ransomware-2023-0184 — Mass File Rename (cactus)
// Status: deprecated | Level: high | ID: ead47a29-f55c-5faf-be7d-73de4644505d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
