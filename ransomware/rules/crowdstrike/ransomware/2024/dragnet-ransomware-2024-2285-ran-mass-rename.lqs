// Dragnet [Ransomware]: dragnet-ransomware-2024-2285 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: c30955f1-2f71-5b8b-a65e-65dbd892c735

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
