// Dragnet [Container]: dragnet-container-2026-2698 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: fc222b23-25ce-5a5a-83cc-16eb4e2b6c87

#event_simpleName=*
| (ImageFileName = *alpine:3.23* OR ImageFileName = *alpine edge:* OR ImageFileName = *amazonlinux:2* OR ImageFileName = *amazonlinux:2023* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *redhat/ubi9:*)
| table([timestamp, ComputerName])
| limit(1000)
