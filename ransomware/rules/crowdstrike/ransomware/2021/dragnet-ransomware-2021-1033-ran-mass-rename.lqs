// Dragnet [Ransomware]: dragnet-ransomware-2021-1033 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 874d3206-28fb-51c0-96a6-b25b46a3c7cc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
