// Dragnet [Ransomware]: dragnet-ransomware-2025-1541 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: e57cbd1f-b49f-555e-be14-d6a2d1fdaf4b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
