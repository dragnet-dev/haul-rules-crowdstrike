// Dragnet [Ransomware]: dragnet-ransomware-2022-2480 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 7fb14761-d173-50df-9207-bb5d6653fbe8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
