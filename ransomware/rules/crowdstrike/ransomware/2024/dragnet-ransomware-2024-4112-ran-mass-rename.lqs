// Dragnet [Ransomware]: dragnet-ransomware-2024-4112 — Mass File Rename (play)
// Status: experimental | Level: high | ID: ca13963f-5d97-596f-b051-32ec34a5da3c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
