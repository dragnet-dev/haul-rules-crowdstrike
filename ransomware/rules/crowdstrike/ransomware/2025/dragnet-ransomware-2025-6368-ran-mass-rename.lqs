// Dragnet [Ransomware]: dragnet-ransomware-2025-6368 — Mass File Rename (devman)
// Status: deprecated | Level: high | ID: b91493e1-5da9-50d0-8a02-837100b70a7c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
