// Dragnet [Ransomware]: dragnet-ransomware-2024-4934 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: b8c34f54-af87-5de9-b8fb-d072622c1440

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
