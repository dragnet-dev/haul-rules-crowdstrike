// Dragnet [Ransomware]: dragnet-ransomware-2025-1606 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 7843e071-a0f3-5f24-a72a-3f712acfd777

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
