// Dragnet [Ransomware]: dragnet-ransomware-2021-1805 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 24efbf8e-d569-511e-8717-ee34e61f0b10

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
