// Dragnet [Ransomware]: dragnet-ransomware-2024-3703 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: ae040931-f529-50ea-a607-cbca24277c92

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
