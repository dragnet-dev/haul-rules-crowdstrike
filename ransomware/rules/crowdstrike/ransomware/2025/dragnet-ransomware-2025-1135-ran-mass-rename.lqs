// Dragnet [Ransomware]: dragnet-ransomware-2025-1135 — Mass File Rename (spacebears)
// Status: experimental | Level: high | ID: acf8b657-7ae9-5f03-82c2-42f28d9cb2ed

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
