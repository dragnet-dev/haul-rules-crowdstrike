// Dragnet [Ransomware]: dragnet-ransomware-2024-3728 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 386cd381-826c-5c88-9f22-4944891506e6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
