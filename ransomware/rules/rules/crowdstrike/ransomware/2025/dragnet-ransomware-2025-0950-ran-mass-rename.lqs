// Dragnet [Ransomware]: dragnet-ransomware-2025-0950 — Mass File Rename (devman)
// Status: experimental | Level: high | ID: 52b8551b-6758-5254-91ed-ddcd13d915de

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
