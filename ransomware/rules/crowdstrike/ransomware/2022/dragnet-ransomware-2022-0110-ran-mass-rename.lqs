// Dragnet [Ransomware]: dragnet-ransomware-2022-0110 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 13156a79-1ee7-537e-8bd6-4fb73e5d6d7b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
