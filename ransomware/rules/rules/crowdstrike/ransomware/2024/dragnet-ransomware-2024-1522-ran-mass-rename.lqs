// Dragnet [Ransomware]: dragnet-ransomware-2024-1522 — Mass File Rename (threeam)
// Status: experimental | Level: high | ID: 65bd8cd9-b534-5ff6-b602-00bdcf771e4d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
