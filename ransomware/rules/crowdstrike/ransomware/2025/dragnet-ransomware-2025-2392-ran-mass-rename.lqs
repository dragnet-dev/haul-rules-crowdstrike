// Dragnet [Ransomware]: dragnet-ransomware-2025-2392 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 204e445b-cac4-5152-9912-191e1276f642

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
