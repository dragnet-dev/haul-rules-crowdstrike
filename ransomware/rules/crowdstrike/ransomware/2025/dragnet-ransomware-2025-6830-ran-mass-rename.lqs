// Dragnet [Ransomware]: dragnet-ransomware-2025-6830 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: fbcca673-2056-58e3-9219-0ea29444d41c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
