// Dragnet [Ransomware]: dragnet-ransomware-2025-4823 — Mass File Rename (pear)
// Status: experimental | Level: high | ID: 6634d22a-def7-5802-b0cf-496013cd544c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
