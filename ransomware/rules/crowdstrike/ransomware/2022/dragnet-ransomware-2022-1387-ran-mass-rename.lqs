// Dragnet [Ransomware]: dragnet-ransomware-2022-1387 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 261ba580-97a4-5fbc-b2f0-4ecd7d4521cc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
