// Dragnet [Ransomware]: dragnet-ransomware-2023-5222 — Mass File Rename (avoslocker)
// Status: deprecated | Level: high | ID: 01951948-34b5-5a71-ba8c-c6ec45595640

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
