// Dragnet [Ransomware]: dragnet-ransomware-2022-1705 — Mass File Rename (donutleaks)
// Status: deprecated | Level: high | ID: eb9f174e-02c0-5e97-9379-d2a95d783ad7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
