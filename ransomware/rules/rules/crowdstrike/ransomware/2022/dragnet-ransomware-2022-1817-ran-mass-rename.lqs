// Dragnet [Ransomware]: dragnet-ransomware-2022-1817 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 44aafa4b-a444-5171-8b1a-256725f184a3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
