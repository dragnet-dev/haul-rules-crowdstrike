// Dragnet [Ransomware]: dragnet-ransomware-2023-1927 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 4ee52459-30db-55b1-9165-3176568d3ba1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
