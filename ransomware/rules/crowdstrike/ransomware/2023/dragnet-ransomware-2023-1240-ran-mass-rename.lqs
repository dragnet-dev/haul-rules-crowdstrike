// Dragnet [Ransomware]: dragnet-ransomware-2023-1240 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 9e53935e-599b-5ff9-b79f-1d36b26fcb1a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
