// Dragnet [Ransomware]: dragnet-ransomware-2025-0499 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 5d7c2cd9-a0da-571b-afe2-f8cce21e1358

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
