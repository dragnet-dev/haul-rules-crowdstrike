// Dragnet [Ransomware]: dragnet-ransomware-2024-4634 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: bf2ac7a0-be16-59cb-a164-03ba08486b7f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
