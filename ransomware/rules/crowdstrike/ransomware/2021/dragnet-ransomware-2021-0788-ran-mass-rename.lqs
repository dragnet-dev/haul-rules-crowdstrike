// Dragnet [Ransomware]: dragnet-ransomware-2021-0788 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 1c801bb1-1701-532f-98c8-920787a04b3a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
