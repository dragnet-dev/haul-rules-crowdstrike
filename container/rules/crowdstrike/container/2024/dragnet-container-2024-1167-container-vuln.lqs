// Dragnet [Container]: dragnet-container-2024-1167 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 00078425-05a9-54c9-afba-0070d8aec1a8

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:7* OR ImageFileName = *debian:8* OR ImageFileName = *debian:9* OR ImageFileName = *ubuntu:14.04-ESM* OR ImageFileName = *ubuntu:16.04* OR ImageFileName = *ubuntu:16.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
