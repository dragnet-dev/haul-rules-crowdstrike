// Dragnet [Ransomware]: dragnet-ransomware-2024-5714 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 0bf2429d-230c-579c-8f79-711a4d43a8f8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
