// Dragnet [Container]: dragnet-container-2026-2595 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: d134e384-fff6-5a56-8ed5-1746f4421110

#event_simpleName=*
| (ImageFileName = *debian:14* OR ImageFileName = *redhat/ubi9:*)
| table([timestamp, ComputerName])
| limit(1000)
