// Dragnet [Ransomware]: dragnet-ransomware-2025-6912 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 8a6ff40b-6ad2-5044-94da-1e29abe4ae34

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
