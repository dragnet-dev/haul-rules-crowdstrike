// Dragnet [Ransomware]: dragnet-ransomware-2025-3177 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: cace379e-34e1-5601-9e72-58449ea298da

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
