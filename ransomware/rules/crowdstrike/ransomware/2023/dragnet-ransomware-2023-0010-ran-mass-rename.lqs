// Dragnet [Ransomware]: dragnet-ransomware-2023-0010 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 172a4d68-8470-5aa3-b1f0-6852321b414c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
