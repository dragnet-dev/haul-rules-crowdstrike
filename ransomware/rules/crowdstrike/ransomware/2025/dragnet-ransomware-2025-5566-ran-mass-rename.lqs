// Dragnet [Ransomware]: dragnet-ransomware-2025-5566 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 5164d052-f407-5a0a-9669-3c1d3edc0551

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
