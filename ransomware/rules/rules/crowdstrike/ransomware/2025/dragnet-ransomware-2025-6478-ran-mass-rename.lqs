// Dragnet [Ransomware]: dragnet-ransomware-2025-6478 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 4f83ebbe-7e2d-5e0d-b178-17bbbce5f352

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
