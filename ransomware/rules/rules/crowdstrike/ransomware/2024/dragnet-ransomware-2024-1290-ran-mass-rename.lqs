// Dragnet [Ransomware]: dragnet-ransomware-2024-1290 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 87d0a13f-64d5-59c2-8ab2-87cb7039fbd3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
