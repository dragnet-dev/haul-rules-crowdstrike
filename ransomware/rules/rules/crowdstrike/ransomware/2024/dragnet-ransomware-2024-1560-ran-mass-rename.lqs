// Dragnet [Ransomware]: dragnet-ransomware-2024-1560 — Mass File Rename (cicada3301)
// Status: experimental | Level: high | ID: 8e0c6c85-07c4-55df-9d78-c306c52df381

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
