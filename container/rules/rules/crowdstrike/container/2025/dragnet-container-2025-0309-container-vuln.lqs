// Dragnet [Container]: dragnet-container-2025-0309 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 8d512f59-1fc7-5ff9-aeba-57f7e2ebfe93

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
