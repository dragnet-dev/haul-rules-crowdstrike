// Dragnet [Ransomware]: dragnet-ransomware-2024-2151 — Mass File Rename (kairos)
// Status: experimental | Level: high | ID: bb0eab54-963c-530c-986e-1c0b151b1bac

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
