// Dragnet [Ransomware]: dragnet-ransomware-2025-4880 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: ef829767-7cf8-5887-a5b4-384838db3847

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
