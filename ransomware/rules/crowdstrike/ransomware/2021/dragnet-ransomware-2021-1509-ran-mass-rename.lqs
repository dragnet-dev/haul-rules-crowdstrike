// Dragnet [Ransomware]: dragnet-ransomware-2021-1509 — Mass File Rename (avaddon)
// Status: deprecated | Level: high | ID: 8d19d163-d1ee-5615-8c6e-a1d65ff0c2e6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
