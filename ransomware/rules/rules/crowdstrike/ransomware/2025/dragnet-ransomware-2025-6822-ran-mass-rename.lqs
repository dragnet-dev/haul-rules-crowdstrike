// Dragnet [Ransomware]: dragnet-ransomware-2025-6822 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: b5926a97-783b-50c0-a11e-1ce3e7b30804

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
