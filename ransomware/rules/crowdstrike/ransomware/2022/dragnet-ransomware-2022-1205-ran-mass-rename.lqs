// Dragnet [Ransomware]: dragnet-ransomware-2022-1205 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: ba966a52-512f-5d04-98c1-0be1ef3b89a8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
