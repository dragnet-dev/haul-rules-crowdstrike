// Dragnet [Ransomware]: dragnet-ransomware-2023-0648 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 9b136f61-28ba-55f2-9577-9f08ae5f4250

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
