// Dragnet [Ransomware]: dragnet-ransomware-2022-2506 — Mass File Rename (blackbasta)
// Status: deprecated | Level: high | ID: 5e602bf2-3a4e-5448-a518-48e8e620bac8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
