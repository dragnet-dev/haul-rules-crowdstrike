// Dragnet [Ransomware]: dragnet-ransomware-2022-0337 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: a4db5f53-5b3c-5fe9-8497-b8b2b0146723

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
