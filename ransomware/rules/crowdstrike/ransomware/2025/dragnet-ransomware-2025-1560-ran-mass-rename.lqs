// Dragnet [Ransomware]: dragnet-ransomware-2025-1560 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: b5d745cf-5995-5e1f-a5f3-f8169d139ca6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
