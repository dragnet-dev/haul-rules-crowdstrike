// Dragnet [Ransomware]: dragnet-ransomware-2024-3928 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 772c76b7-66a3-5548-80f6-82bc0a353371

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
