// Dragnet [Ransomware]: dragnet-ransomware-2022-2252 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 215b0a64-f346-5628-b298-38d227cf3f19

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
