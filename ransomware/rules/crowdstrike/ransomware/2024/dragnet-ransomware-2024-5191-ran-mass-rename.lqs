// Dragnet [Ransomware]: dragnet-ransomware-2024-5191 — Mass File Rename (apt73)
// Status: experimental | Level: high | ID: 56f65a59-ceae-5da8-bf38-2f64c2388123

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
