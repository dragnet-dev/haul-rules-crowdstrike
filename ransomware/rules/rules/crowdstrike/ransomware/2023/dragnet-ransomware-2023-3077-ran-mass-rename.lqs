// Dragnet [Ransomware]: dragnet-ransomware-2023-3077 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 84ed233d-e001-5068-bc3d-bc237ac3d920

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
