// Dragnet [Ransomware]: dragnet-ransomware-2021-0057 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 4e4c04d2-0fc1-543a-bdae-94f3c810aa96

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
