// Dragnet [Ransomware]: dragnet-ransomware-2023-3598 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 54fa20d5-13c1-505f-8897-8e63c0e80652

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
