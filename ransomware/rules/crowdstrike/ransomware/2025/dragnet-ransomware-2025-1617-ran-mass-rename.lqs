// Dragnet [Ransomware]: dragnet-ransomware-2025-1617 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: a19fc2fc-d3d2-58c9-b469-56100ea8d115

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
