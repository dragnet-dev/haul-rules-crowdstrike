// Dragnet [Ransomware]: dragnet-ransomware-2023-3975 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 9754f184-cfdc-5950-a83b-ee3bc625d125

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
