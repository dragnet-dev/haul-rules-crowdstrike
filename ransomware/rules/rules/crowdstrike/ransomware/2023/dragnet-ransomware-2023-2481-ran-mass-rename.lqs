// Dragnet [Ransomware]: dragnet-ransomware-2023-2481 — Mass File Rename (rhysida)
// Status: deprecated | Level: high | ID: d32622e6-80dc-51c1-8c5c-d2b158c99eeb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
