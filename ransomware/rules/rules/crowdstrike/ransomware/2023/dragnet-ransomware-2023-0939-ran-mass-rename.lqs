// Dragnet [Ransomware]: dragnet-ransomware-2023-0939 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: fa6cb3f9-87d6-539d-8688-c9270b79e479

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
