// Dragnet [Ransomware]: dragnet-ransomware-2023-4257 — Mass File Rename (noescape)
// Status: experimental | Level: high | ID: d4cdb699-4be2-5541-876e-2c56fdb017f7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
