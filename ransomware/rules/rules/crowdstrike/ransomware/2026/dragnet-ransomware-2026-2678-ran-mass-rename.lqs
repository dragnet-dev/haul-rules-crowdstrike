// Dragnet [Ransomware]: dragnet-ransomware-2026-2678 — Mass File Rename (incransom)
// Status: stable | Level: high | ID: 79bb4858-9bbf-5129-ae04-2eb3b388fb9a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
