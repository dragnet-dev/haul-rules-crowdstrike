// Dragnet [Ransomware]: dragnet-ransomware-2025-0163 — Mass File Rename (incransom)
// Status: test | Level: high | ID: 8a3cbfa5-ed0c-5667-8268-ab2b6848ccd9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
