// Dragnet [Ransomware]: dragnet-ransomware-2025-7394 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: b18eccc4-63f4-55bb-9b3e-939088ee8cec

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
