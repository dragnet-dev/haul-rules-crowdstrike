// Dragnet [Ransomware]: dragnet-ransomware-2025-0460 — Mass File Rename (J)
// Status: experimental | Level: high | ID: f31d533f-3cb5-5cfa-a5c9-d5a20f1a841e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
