// Dragnet [Ransomware]: dragnet-ransomware-2025-4752 — Mass File Rename (J)
// Status: experimental | Level: high | ID: cd302871-4923-55fa-b6f1-d056150ad268

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
