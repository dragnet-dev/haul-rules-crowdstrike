// Dragnet [Ransomware]: dragnet-ransomware-2025-6393 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: 14c84ed1-47b8-5458-9719-180eee972ab4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
