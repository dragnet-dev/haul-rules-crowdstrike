// Dragnet [Ransomware]: dragnet-ransomware-2023-5136 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: d16cb921-c1f6-5285-bd5b-4e6f646d5335

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
