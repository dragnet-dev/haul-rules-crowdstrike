// Dragnet [Ransomware]: dragnet-ransomware-2025-7705 — Mass File Rename (sinobi)
// Status: experimental | Level: high | ID: fce08b3c-626a-5c8a-b2fa-ab52625ee562

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
