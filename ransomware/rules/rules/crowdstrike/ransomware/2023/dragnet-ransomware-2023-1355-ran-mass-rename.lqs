// Dragnet [Ransomware]: dragnet-ransomware-2023-1355 — Mass File Rename (ransomed)
// Status: deprecated | Level: high | ID: ca01715f-5b59-51d9-a47c-753d866c1bdd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
