// Dragnet [Ransomware]: dragnet-ransomware-2022-2896 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 46982f60-c484-5ae8-b6de-bd75bdff25c4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
