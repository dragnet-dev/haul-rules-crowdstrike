// Dragnet [Ransomware]: dragnet-ransomware-2023-1698 — Mass File Rename (losttrust)
// Status: deprecated | Level: high | ID: 5267006b-f41e-5454-aa93-d394a740c253

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
