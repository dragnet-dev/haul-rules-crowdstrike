// Dragnet [Ransomware]: dragnet-ransomware-2026-2336 — Mass File Rename (incransom)
// Status: stable | Level: high | ID: 75136e03-0453-5f39-b508-13a1675a4c0a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
