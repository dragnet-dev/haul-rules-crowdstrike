// Dragnet [Ransomware]: dragnet-ransomware-2024-2636 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 9c088d27-998a-54c3-847e-e603d4699afe

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
