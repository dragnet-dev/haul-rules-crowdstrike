// Dragnet [Ransomware]: dragnet-ransomware-2024-4684 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: d2657d74-68ec-52db-8b08-83ab6ea36021

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
