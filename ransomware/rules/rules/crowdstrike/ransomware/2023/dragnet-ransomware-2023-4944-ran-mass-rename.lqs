// Dragnet [Ransomware]: dragnet-ransomware-2023-4944 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: ec145b6a-fca4-55b8-873f-ddecf94da9a7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
