// Dragnet [Ransomware]: dragnet-ransomware-2024-3530 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 56317c55-ae60-5029-a162-e577d4ec26f4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
