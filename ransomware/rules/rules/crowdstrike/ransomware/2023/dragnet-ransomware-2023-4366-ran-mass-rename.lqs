// Dragnet [Ransomware]: dragnet-ransomware-2023-4366 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: d123df1c-5459-54cc-a37e-3f898e717286

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
