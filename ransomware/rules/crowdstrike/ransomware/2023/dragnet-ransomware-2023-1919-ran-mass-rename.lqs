// Dragnet [Ransomware]: dragnet-ransomware-2023-1919 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: d13aa28f-2664-5705-ad1f-c482c8f17439

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
