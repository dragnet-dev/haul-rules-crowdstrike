// Dragnet [Ransomware]: dragnet-ransomware-2025-2764 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 260c217d-6a90-5be7-85d9-1fa36ae02f9d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
