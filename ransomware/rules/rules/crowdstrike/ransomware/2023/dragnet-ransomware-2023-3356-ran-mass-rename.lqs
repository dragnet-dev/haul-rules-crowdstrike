// Dragnet [Ransomware]: dragnet-ransomware-2023-3356 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 773140eb-6da3-5f82-a31d-701e1bd3ac79

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
