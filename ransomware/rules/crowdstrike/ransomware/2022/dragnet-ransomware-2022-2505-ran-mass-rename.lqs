// Dragnet [Ransomware]: dragnet-ransomware-2022-2505 — Mass File Rename (cuba)
// Status: deprecated | Level: high | ID: 795b97c2-f6b9-541c-b5e7-4e1a313cec15

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
