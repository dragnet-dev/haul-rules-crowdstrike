// Dragnet [Ransomware]: dragnet-ransomware-2023-0194 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: b1a3c44c-c7e6-5dfc-8bd4-271ac4601f6d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
