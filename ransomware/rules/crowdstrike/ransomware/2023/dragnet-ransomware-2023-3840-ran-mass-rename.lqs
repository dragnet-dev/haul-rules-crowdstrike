// Dragnet [Ransomware]: dragnet-ransomware-2023-3840 — Mass File Rename (royal)
// Status: experimental | Level: high | ID: 94320eed-23b4-5ed9-9d2a-17e665cfdd24

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
