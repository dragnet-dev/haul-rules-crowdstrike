// Dragnet [Ransomware]: dragnet-ransomware-2025-6979 — Mass File Rename (securotrop)
// Status: experimental | Level: high | ID: 907b814a-6cd2-5f6f-a3e4-b05c075e6534

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
