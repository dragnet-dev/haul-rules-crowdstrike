// Dragnet [Ransomware]: dragnet-ransomware-2026-0272 — Mass File Rename (shinyhunters)
// Status: deprecated | Level: high | ID: d83ee67f-1b86-5b94-930d-9a5b20515d46

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
