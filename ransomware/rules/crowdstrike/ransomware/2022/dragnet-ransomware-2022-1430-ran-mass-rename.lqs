// Dragnet [Ransomware]: dragnet-ransomware-2022-1430 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 29d37c4b-b200-5b80-91df-96e43dc8211e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
