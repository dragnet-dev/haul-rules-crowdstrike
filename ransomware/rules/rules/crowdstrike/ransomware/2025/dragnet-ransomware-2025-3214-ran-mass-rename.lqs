// Dragnet [Ransomware]: dragnet-ransomware-2025-3214 — Mass File Rename (rhysida)
// Status: deprecated | Level: high | ID: 81400dcc-9da6-5859-b53b-22af0a417136

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
