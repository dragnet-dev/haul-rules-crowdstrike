// Dragnet [Ransomware]: dragnet-ransomware-2024-4237 — Mass File Rename (arcusmedia)
// Status: experimental | Level: high | ID: 0f70197d-a2ae-5606-ae61-36436340f246

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
