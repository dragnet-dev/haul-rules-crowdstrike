// Dragnet [Ransomware]: dragnet-ransomware-2022-1182 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: db21410f-a9be-5f83-b961-3cd1f37248a1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
