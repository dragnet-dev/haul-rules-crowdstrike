// Dragnet [Ransomware]: dragnet-ransomware-2023-0542 — Mass File Rename (threeam)
// Status: experimental | Level: high | ID: 54620724-6941-51cc-9825-d6c01c04e247

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
