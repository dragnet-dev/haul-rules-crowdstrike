// Dragnet [Ransomware]: dragnet-ransomware-2025-0986 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: 1056d105-6072-5dbf-b025-1d460c787798

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
