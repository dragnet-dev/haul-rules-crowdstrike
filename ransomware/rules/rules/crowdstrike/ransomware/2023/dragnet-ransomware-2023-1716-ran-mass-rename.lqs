// Dragnet [Ransomware]: dragnet-ransomware-2023-1716 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: e4c6e9ad-6f8b-5b09-b389-d348d0789a51

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
