// Dragnet [Ransomware]: dragnet-ransomware-2024-5822 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: a932e0fb-9dc1-5225-8070-41a8e79ad1ec

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
