// Dragnet [Ransomware]: dragnet-ransomware-2023-1321 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 9eee6212-d3b0-514f-b9be-37949368eaea

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
