// Dragnet [Ransomware]: dragnet-ransomware-2024-3702 — Mass File Rename (darkvault)
// Status: experimental | Level: high | ID: 59cbe2b4-21b7-55b0-a2d8-75c300f5f1c1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
