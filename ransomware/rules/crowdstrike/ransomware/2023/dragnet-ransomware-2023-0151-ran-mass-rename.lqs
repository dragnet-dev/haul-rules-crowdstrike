// Dragnet [Ransomware]: dragnet-ransomware-2023-0151 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 29692ff3-a1e3-5c7d-887a-c2a09b9ea785

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
