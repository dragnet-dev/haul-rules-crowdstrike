// Dragnet [Ransomware]: dragnet-ransomware-2023-0251 — Mass File Rename (toufan)
// Status: deprecated | Level: high | ID: f4fd962d-06ca-564e-a89f-55e18e3cc4d2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
