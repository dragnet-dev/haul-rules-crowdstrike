// Dragnet [Ransomware]: dragnet-ransomware-2023-2976 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 3f1034c7-c613-5286-a872-9e384861eecc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
