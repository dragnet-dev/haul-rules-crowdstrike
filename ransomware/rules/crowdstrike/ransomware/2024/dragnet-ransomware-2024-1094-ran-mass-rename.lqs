// Dragnet [Ransomware]: dragnet-ransomware-2024-1094 — Mass File Rename (safepay)
// Status: deprecated | Level: high | ID: 8ba3a793-ede1-5a24-ba5b-6964d3be829d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
