// Dragnet [Ransomware]: dragnet-ransomware-2024-1214 — Mass File Rename (play)
// Status: experimental | Level: high | ID: d2e61cdd-5119-5c3c-b57e-887411d9afbe

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
