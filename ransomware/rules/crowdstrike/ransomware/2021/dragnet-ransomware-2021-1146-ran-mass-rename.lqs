// Dragnet [Ransomware]: dragnet-ransomware-2021-1146 — Mass File Rename (mountlocker)
// Status: deprecated | Level: high | ID: fb54a398-6288-5025-8e20-8496232fe070

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
