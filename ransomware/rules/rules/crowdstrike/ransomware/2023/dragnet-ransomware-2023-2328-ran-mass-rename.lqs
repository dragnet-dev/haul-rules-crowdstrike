// Dragnet [Ransomware]: dragnet-ransomware-2023-2328 — Mass File Rename (abyss)
// Status: deprecated | Level: high | ID: 9123edeb-5116-5918-ab89-12e4f918bcfe

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
