// Dragnet [Ransomware]: dragnet-ransomware-2024-2401 — Mass File Rename (raworld)
// Status: experimental | Level: high | ID: 0f5e9fbf-03e3-51c3-88b9-4446f80c2e40

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
