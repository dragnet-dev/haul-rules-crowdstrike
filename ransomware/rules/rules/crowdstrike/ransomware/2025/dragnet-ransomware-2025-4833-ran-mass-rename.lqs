// Dragnet [Ransomware]: dragnet-ransomware-2025-4833 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 71ca2456-5944-558e-a9cf-435453236e4b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
