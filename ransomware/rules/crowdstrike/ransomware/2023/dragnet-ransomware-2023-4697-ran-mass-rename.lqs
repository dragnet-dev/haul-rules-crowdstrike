// Dragnet [Ransomware]: dragnet-ransomware-2023-4697 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 093e584e-8526-56db-94f3-84c6c7f30924

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
