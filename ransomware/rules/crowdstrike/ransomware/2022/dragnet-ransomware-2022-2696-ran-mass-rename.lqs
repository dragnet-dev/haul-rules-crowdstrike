// Dragnet [Ransomware]: dragnet-ransomware-2022-2696 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 8ecf05c5-b615-5f13-92d9-14310d407438

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
