// Dragnet [Ransomware]: dragnet-ransomware-2025-3300 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 963ae2f7-ad74-516b-863f-b4877ea6e21e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
