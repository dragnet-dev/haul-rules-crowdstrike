// Dragnet [Ransomware]: dragnet-ransomware-2024-5610 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 072e6c28-50e0-5a10-aabb-1f085665a579

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
