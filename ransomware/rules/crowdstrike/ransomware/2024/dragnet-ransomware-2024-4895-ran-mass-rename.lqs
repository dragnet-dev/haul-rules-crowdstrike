// Dragnet [Ransomware]: dragnet-ransomware-2024-4895 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 44b5c7a0-14d5-5a4a-a108-e69cc8543e96

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
