// Dragnet [Ransomware]: dragnet-ransomware-2024-3172 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 5c635956-b251-5323-900a-4e0d4511342a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
