// Dragnet [Ransomware]: dragnet-ransomware-2023-1449 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: c98c0a2c-008f-53bf-ae20-3450c07a75c1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
