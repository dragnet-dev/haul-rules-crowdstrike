// Dragnet [Ransomware]: dragnet-ransomware-2025-6229 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: 8ed671a7-e95f-56d5-bb74-052e8b9caaa0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
