// Dragnet [Ransomware]: dragnet-ransomware-2024-2674 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: b668216d-b837-5cdc-8770-1216354f4e22

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
