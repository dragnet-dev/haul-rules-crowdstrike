// Dragnet [Ransomware]: dragnet-ransomware-2022-0578 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 9351c32e-9088-57f2-9451-1385b03194bf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
