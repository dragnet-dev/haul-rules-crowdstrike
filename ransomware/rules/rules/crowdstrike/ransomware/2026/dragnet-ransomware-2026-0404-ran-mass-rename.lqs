// Dragnet [Ransomware]: dragnet-ransomware-2026-0404 — Mass File Rename (blackshrantac)
// Status: test | Level: high | ID: fe7e7e0b-bfff-5fc4-bb5c-0a7281885aaf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
