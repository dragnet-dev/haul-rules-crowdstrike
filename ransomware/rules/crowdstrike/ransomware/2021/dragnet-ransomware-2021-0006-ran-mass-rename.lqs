// Dragnet [Ransomware]: dragnet-ransomware-2021-0006 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: f2a10f18-89b9-5deb-802d-c401cb67ae72

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
