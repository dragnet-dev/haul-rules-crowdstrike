// Dragnet [Container]: dragnet-container-2024-1325 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: c97b5b07-5911-57bc-8c22-f6a406f4edf3

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:9*)
| table([timestamp, ComputerName])
| limit(1000)
