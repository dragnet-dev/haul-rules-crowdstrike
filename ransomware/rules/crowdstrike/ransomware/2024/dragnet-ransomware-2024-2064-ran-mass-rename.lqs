// Dragnet [Ransomware]: dragnet-ransomware-2024-2064 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 80b004c2-e8ce-5755-a6c9-7ee1b9c6050b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
