// Dragnet [Ransomware]: dragnet-ransomware-2022-1295 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 21473909-2c69-5aa9-a5dd-3664411d0360

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
