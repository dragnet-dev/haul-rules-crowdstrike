// Dragnet [Ransomware]: dragnet-ransomware-2023-2541 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 6c7a355f-13ae-5cc1-9a62-aa8c547f5c10

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
