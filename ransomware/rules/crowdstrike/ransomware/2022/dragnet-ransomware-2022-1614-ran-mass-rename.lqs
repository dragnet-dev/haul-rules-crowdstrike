// Dragnet [Ransomware]: dragnet-ransomware-2022-1614 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 770b61af-4a46-5f2c-b68e-8c55f4ad431b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
