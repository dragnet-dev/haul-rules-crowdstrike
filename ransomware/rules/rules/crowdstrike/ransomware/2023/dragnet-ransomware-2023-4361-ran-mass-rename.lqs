// Dragnet [Ransomware]: dragnet-ransomware-2023-4361 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 6b173074-686e-534a-a23b-1dea83c5a031

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
