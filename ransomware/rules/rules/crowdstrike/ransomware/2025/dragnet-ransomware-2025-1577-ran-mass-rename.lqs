// Dragnet [Ransomware]: dragnet-ransomware-2025-1577 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: 5bbec4c7-662c-54f4-b25f-beb209b1ec56

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
