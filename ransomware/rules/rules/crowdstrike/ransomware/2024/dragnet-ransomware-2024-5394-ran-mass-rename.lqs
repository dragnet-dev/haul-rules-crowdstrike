// Dragnet [Ransomware]: dragnet-ransomware-2024-5394 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: f589880b-3acd-5012-9813-09da1e04291a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
