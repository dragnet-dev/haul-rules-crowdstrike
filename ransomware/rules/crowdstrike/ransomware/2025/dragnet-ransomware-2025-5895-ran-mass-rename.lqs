// Dragnet [Ransomware]: dragnet-ransomware-2025-5895 — Mass File Rename (SilentRansomGroup)
// Status: deprecated | Level: high | ID: 82072e2d-4450-5e93-a5c1-ac1cffcf22ce

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
