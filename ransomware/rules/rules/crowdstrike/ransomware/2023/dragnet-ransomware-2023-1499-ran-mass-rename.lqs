// Dragnet [Ransomware]: dragnet-ransomware-2023-1499 — Mass File Rename (arvinclub)
// Status: deprecated | Level: high | ID: 3618b2d0-ab2e-5d1e-bc4d-cc8dcb307c42

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
