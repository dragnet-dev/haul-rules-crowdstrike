// Dragnet [Ransomware]: dragnet-ransomware-2022-2975 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 2639a7d6-9b71-5a01-8320-104b8dbe41db

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
