// Dragnet [Ransomware]: dragnet-ransomware-2024-3592 — Mass File Rename (meow)
// Status: experimental | Level: high | ID: 7da0b051-f9af-5188-a188-ca6ef41a481d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
