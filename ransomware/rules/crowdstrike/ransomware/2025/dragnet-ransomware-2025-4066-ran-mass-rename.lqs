// Dragnet [Ransomware]: dragnet-ransomware-2025-4066 — Mass File Rename (radar)
// Status: deprecated | Level: high | ID: beaf5450-3ac3-5f96-add0-66fa8e8d6eaa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
