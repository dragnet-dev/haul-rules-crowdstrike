// Dragnet [Ransomware]: dragnet-ransomware-2022-3029 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: dfb2d4ea-222e-50d7-9194-204e480dea00

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
