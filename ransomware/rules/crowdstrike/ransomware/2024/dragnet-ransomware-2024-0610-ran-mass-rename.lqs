// Dragnet [Ransomware]: dragnet-ransomware-2024-0610 — Mass File Rename (meow)
// Status: experimental | Level: high | ID: ea75bb84-0ab5-56f8-997b-912edefd8537

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
