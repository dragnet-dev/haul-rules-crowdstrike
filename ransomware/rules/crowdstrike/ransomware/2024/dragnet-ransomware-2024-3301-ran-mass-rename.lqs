// Dragnet [Ransomware]: dragnet-ransomware-2024-3301 — Mass File Rename (interlock)
// Status: experimental | Level: high | ID: c5941473-db5a-508e-bee0-95e07af36032

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
