// Dragnet [Ransomware]: dragnet-ransomware-2021-1452 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 71609d7e-63e1-5c04-9b28-dbeca1faa270

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
