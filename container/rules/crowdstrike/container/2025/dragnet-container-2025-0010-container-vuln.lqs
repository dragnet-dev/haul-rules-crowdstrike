// Dragnet [Container]: dragnet-container-2025-0010 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: fe74bcd2-3767-510e-a079-d573e8364ab9

#event_simpleName=*
| (ImageFileName = *alpine:3.19* OR ImageFileName = *alpine:3.20* OR ImageFileName = *alpine:3.21* OR ImageFileName = *alpine:3.22* OR ImageFileName = *alpine:3.23* OR ImageFileName = *alpine edge:* OR ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
