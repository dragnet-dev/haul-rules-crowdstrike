// Dragnet [Ransomware]: dragnet-ransomware-2020-0187 — Mass File Rename (doppelpaymer)
// Status: deprecated | Level: high | ID: 720fbff3-467e-5ed4-af90-799f5710f869

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
