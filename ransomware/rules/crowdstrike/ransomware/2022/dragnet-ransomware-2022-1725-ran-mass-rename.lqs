// Dragnet [Ransomware]: dragnet-ransomware-2022-1725 — Mass File Rename (blackbasta)
// Status: deprecated | Level: high | ID: 792d099a-e79f-5d21-bb82-2e830775f8fc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
