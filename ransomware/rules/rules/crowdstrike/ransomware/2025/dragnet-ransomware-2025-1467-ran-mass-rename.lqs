// Dragnet [Ransomware]: dragnet-ransomware-2025-1467 — Mass File Rename (lockbit5)
// Status: experimental | Level: high | ID: 26926443-902e-59ce-82b8-926191362f8e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
