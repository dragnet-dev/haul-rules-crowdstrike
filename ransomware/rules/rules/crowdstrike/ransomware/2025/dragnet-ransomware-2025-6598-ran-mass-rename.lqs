// Dragnet [Ransomware]: dragnet-ransomware-2025-6598 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 9edd0d02-5c94-5f3b-a827-25f8267a4efb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
