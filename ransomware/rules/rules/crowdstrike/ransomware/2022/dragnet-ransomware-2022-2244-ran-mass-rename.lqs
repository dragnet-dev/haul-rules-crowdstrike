// Dragnet [Ransomware]: dragnet-ransomware-2022-2244 — Mass File Rename (lv)
// Status: deprecated | Level: high | ID: 112eead5-8d6c-59a0-911b-19d1e2b5e8e3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
