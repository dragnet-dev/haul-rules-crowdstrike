// Dragnet [Ransomware]: dragnet-ransomware-2025-1090 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 7bcc62f0-2f48-5665-a85a-3993ad610339

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
