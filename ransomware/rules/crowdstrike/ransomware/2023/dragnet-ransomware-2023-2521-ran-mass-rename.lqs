// Dragnet [Ransomware]: dragnet-ransomware-2023-2521 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: d261212a-cec1-5048-8582-0eba7c9c354b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
