// Dragnet [Ransomware]: dragnet-ransomware-2025-3659 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: eebfa939-c3c8-5795-a26c-2328751f71f4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
