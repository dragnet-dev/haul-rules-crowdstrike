// Dragnet [Ransomware]: dragnet-ransomware-2025-1829 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: d1992060-14f9-5ee6-9ce1-f75db0150b0f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
