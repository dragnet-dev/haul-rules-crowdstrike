// Dragnet [Ransomware]: dragnet-ransomware-2024-1054 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 5f5f79f2-7bb5-5f07-9848-57cd07a23272

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
