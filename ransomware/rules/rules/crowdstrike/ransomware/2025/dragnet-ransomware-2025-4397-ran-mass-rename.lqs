// Dragnet [Ransomware]: dragnet-ransomware-2025-4397 — Mass File Rename (lockbit5)
// Status: test | Level: high | ID: 0166d22f-e8e9-5c9d-8f50-5c1fe815d30a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
