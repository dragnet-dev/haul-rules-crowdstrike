// Dragnet [Ransomware]: dragnet-ransomware-2025-5951 — Mass File Rename (direwolf)
// Status: experimental | Level: high | ID: 242d2e4c-e7f2-58e2-bc20-d8f838edc733

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
