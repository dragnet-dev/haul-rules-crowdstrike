// Dragnet [Ransomware]: dragnet-ransomware-2025-0275 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 1a35536a-a24f-5319-9a1c-39c5c238647a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
