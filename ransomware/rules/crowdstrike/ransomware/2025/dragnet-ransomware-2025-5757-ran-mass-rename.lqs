// Dragnet [Ransomware]: dragnet-ransomware-2025-5757 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 177482cc-1930-5648-9e74-848a4cf7837e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
