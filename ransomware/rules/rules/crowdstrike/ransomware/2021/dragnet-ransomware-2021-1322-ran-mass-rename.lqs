// Dragnet [Ransomware]: dragnet-ransomware-2021-1322 — Mass File Rename (avaddon)
// Status: deprecated | Level: high | ID: 78f2685f-6de2-5c6d-858f-ff3d6d9a8406

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
