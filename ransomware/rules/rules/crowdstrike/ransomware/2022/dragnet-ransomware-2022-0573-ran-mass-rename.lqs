// Dragnet [Ransomware]: dragnet-ransomware-2022-0573 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 046dab51-5d94-5486-a602-d31e9fbffa39

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
