// Dragnet [Ransomware]: dragnet-ransomware-2023-4416 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 7942a002-afcf-5bbc-a670-99a397d73a1c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
