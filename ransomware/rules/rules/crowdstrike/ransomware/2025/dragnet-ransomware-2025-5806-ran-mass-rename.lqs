// Dragnet [Ransomware]: dragnet-ransomware-2025-5806 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 4584230e-3993-57c3-8c29-f4c72b979411

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
