// Dragnet [Ransomware]: dragnet-ransomware-2025-4357 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: cf8e5197-8c95-57e8-9150-8edde9f75a34

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
