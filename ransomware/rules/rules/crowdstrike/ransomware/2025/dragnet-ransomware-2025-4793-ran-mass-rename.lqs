// Dragnet [Ransomware]: dragnet-ransomware-2025-4793 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: d57bb495-a96f-57eb-9149-e536fd6254b6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
