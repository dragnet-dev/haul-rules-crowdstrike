// Dragnet [Ransomware]: dragnet-ransomware-2021-0705 — Mass File Rename (cuba)
// Status: deprecated | Level: high | ID: da005f41-bacc-50e0-8ab3-38932ede5824

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
