// Dragnet [Ransomware]: dragnet-ransomware-2023-2439 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: c379b962-544a-5b04-98b6-c9f0b513dca5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
