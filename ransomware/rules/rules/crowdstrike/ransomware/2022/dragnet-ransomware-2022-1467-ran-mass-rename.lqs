// Dragnet [Ransomware]: dragnet-ransomware-2022-1467 — Mass File Rename (suncrypt)
// Status: deprecated | Level: high | ID: 6d02b96d-566e-5c87-9478-a8d0fa7ea8e3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
