// Dragnet [Ransomware]: dragnet-ransomware-2025-3949 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 0ad54ae3-c509-5d89-b1ee-25e8d0cd09be

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
