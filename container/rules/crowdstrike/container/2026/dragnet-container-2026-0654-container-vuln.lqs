// Dragnet [Container]: dragnet-container-2026-0654 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 47bf5b22-713f-50d8-b468-4bb63347440f

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10*)
| table([timestamp, ComputerName])
| limit(1000)
