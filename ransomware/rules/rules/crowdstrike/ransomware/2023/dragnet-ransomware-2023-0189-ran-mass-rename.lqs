// Dragnet [Ransomware]: dragnet-ransomware-2023-0189 — Mass File Rename (noescape)
// Status: experimental | Level: high | ID: 65d16c60-a596-5259-91c3-b82e9547d232

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
