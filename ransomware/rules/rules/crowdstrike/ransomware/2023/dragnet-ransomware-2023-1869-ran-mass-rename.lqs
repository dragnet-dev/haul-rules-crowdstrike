// Dragnet [Ransomware]: dragnet-ransomware-2023-1869 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: feba6c3e-e47e-54c7-a9f2-911d6f09c110

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
