// Dragnet [Ransomware]: dragnet-ransomware-2025-4888 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: dc394376-920d-5764-9e19-3bf832aaeb2b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
