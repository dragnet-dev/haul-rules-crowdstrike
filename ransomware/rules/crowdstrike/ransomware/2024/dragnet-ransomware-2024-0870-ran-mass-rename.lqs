// Dragnet [Ransomware]: dragnet-ransomware-2024-0870 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: a561163d-7e93-57cf-aeb2-77654b4b6ed5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
