// Dragnet [Ransomware]: dragnet-ransomware-2025-7259 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 87489e8b-5e16-56ed-9386-bfd2ea4368cb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
