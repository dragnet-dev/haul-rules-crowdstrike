// Dragnet [Ransomware]: dragnet-ransomware-2024-5184 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 214c35d7-43d5-5505-a70b-d6d82acf0439

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
