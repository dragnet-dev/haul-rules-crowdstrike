// Dragnet [Ransomware]: dragnet-ransomware-2023-0293 — Mass File Rename (karakurt)
// Status: experimental | Level: high | ID: cc085341-5903-5ce3-a4e0-fd5d52d66748

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
