// Dragnet [Ransomware]: dragnet-ransomware-2026-1034 — Mass File Rename (thegentlemen)
// Status: test | Level: high | ID: f9a7a6ee-4837-52b8-a5f9-cf8724b156af

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
