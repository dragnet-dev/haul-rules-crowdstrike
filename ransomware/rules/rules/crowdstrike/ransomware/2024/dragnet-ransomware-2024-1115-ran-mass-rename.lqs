// Dragnet [Ransomware]: dragnet-ransomware-2024-1115 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: b82950f8-4271-5952-aef4-f637e3ff2138

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
