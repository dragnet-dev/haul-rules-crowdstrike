// Dragnet [Ransomware]: dragnet-ransomware-2025-2610 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: b1925c06-fd5c-5108-a7a9-77e1688d5103

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
