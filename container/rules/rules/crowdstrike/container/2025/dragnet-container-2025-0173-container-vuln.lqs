// Dragnet [Container]: dragnet-container-2025-0173 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 99964758-3adb-5c7b-99cb-444619766dab

#event_simpleName=*
| (ImageFileName = *azure linux:3.0* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
