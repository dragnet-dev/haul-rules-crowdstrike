// Dragnet [Ransomware]: dragnet-ransomware-2024-3505 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: fd5752eb-f1a4-5323-af2f-54bbd8b6dacd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
