// Dragnet [Ransomware]: dragnet-ransomware-2026-0005 — Mass File Rename (handala)
// Status: stable | Level: high | ID: cf0bdbf1-9146-5506-b1aa-90d93ccfcb24

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
