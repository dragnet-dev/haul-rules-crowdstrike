// Dragnet [Ransomware]: dragnet-ransomware-2025-6313 — Mass File Rename (coinbasecartel)
// Status: test | Level: high | ID: 8d128b3a-79b1-5ad4-a35d-21d7b9c420e3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
