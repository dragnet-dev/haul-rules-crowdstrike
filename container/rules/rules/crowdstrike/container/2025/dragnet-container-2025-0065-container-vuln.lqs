// Dragnet [Container]: dragnet-container-2025-0065 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 4f56bfa4-9b26-5c75-967d-9274396ea2ad

#event_simpleName=*
| (ImageFileName = *amazonlinux:2* OR ImageFileName = *chainguard:* OR ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:22.04* OR ImageFileName = *ubuntu:23.04*)
| table([timestamp, ComputerName])
| limit(1000)
