// Dragnet [Ransomware]: dragnet-ransomware-2025-2266 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: db1663aa-05b7-50b3-9d35-64240b64604a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
