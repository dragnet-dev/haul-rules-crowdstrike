// Dragnet [Ransomware]: dragnet-ransomware-2024-2331 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 81c05dd9-f5cb-55b3-b476-6704b33a06eb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
