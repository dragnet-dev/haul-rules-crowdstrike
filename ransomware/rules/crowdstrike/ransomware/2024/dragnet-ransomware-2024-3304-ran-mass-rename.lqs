// Dragnet [Ransomware]: dragnet-ransomware-2024-3304 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 73dfa67a-46d1-5851-b89e-e34d1afe5e90

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
