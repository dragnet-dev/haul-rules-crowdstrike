// Dragnet [Ransomware]: dragnet-ransomware-2023-4909 — Mass File Rename (play)
// Status: deprecated | Level: high | ID: e51947f4-7ecd-5119-aec6-75c114e48497

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
