// Dragnet [Ransomware]: dragnet-ransomware-2022-1098 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 21600446-da02-5aaf-86f9-0c80796e8f8c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
