// Dragnet [Ransomware]: dragnet-ransomware-2022-1231 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 44ac58d1-c0a2-5e1f-ab7a-b5218a125105

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
