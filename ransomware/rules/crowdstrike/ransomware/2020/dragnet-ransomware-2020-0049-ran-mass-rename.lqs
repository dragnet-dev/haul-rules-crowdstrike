// Dragnet [Ransomware]: dragnet-ransomware-2020-0049 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: fd6eb98d-6ae6-5605-baae-e30ac15d3913

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
