// Dragnet [Ransomware]: dragnet-ransomware-2024-2974 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: b026143f-01b1-5a95-8b71-b741c5b0eba6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
