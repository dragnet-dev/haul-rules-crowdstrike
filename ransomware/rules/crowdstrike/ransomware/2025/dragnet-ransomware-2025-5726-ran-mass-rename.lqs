// Dragnet [Ransomware]: dragnet-ransomware-2025-5726 — Mass File Rename (shinyhunters)
// Status: experimental | Level: high | ID: fc316df6-9460-51ce-825c-bc6cc0a6b12e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
