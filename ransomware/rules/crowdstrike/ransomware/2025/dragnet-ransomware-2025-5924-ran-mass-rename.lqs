// Dragnet [Ransomware]: dragnet-ransomware-2025-5924 — Mass File Rename (warlock)
// Status: deprecated | Level: high | ID: e9d5474c-d1df-5f45-a368-555a5b3b8ed2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
