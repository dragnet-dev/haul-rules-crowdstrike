// Dragnet [Container]: dragnet-container-2026-2971 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 11336d3b-a806-5773-9b5c-e4db2465dce3

#event_simpleName=*
| (ImageFileName = *alpine:3.20* OR ImageFileName = *alpine:3.21* OR ImageFileName = *alpine:3.22* OR ImageFileName = *alpine:3.23* OR ImageFileName = *alpine edge:* OR ImageFileName = *azure linux:3.0* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *redhat/ubi9:*)
| table([timestamp, ComputerName])
| limit(1000)
