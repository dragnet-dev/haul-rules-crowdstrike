// Dragnet [Ransomware]: dragnet-ransomware-2025-2678 — Mass File Rename (ciphbit)
// Status: deprecated | Level: high | ID: d7618f14-277a-5d5f-8258-91d7e1fd5406

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
