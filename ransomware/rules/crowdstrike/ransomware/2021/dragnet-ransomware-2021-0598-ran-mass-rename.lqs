// Dragnet [Ransomware]: dragnet-ransomware-2021-0598 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: 4a66fe8b-9fae-5e0f-ac08-2c86714b7fdb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
