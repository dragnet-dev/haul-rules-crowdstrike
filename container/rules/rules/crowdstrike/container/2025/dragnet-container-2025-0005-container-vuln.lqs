// Dragnet [Container]: dragnet-container-2025-0005 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 086aa174-9898-5ef4-933a-f70a43e02d75

#event_simpleName=*
| (ImageFileName = *amazonlinux:1* OR ImageFileName = *debian:7* OR ImageFileName = *debian:8* OR ImageFileName = *redhat/ubi9:*)
| table([timestamp, ComputerName])
| limit(1000)
