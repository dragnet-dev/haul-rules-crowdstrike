// Dragnet [Ransomware]: dragnet-ransomware-2024-4805 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 79add99d-533c-5b45-9da7-ad0a232a3755

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
