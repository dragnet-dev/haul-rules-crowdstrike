// Dragnet [Ransomware]: dragnet-ransomware-2024-2597 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: b28049ff-1a11-55cc-b23d-c2e4e00b8541

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
