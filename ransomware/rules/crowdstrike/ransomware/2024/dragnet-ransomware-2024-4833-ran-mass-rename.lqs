// Dragnet [Ransomware]: dragnet-ransomware-2024-4833 — Mass File Rename (interlock)
// Status: experimental | Level: high | ID: a2342d75-c2b2-5c98-8380-7d6b3b7aeada

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
