// Dragnet [Ransomware]: dragnet-ransomware-2024-3373 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: 4ed183e2-8f58-5e5e-bfba-53e616a47e37

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
