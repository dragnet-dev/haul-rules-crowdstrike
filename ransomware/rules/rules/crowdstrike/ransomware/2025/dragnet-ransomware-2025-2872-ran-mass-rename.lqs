// Dragnet [Ransomware]: dragnet-ransomware-2025-2872 — Mass File Rename (SilentRansomGroup)
// Status: deprecated | Level: high | ID: 7257218a-82da-5622-bbb7-85493db8a8ce

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
