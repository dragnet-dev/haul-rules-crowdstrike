// Dragnet [Container]: dragnet-container-2024-0225 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 0d5a4a14-a680-5718-a431-7542d1e170e2

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:9* OR ImageFileName = *redhat/ubi9:*)
| table([timestamp, ComputerName])
| limit(1000)
