// Dragnet [Ransomware]: dragnet-ransomware-2025-4206 — Mass File Rename (sinobi)
// Status: experimental | Level: high | ID: 85aa51ef-b4cc-5a7a-950f-4707f9efaadc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
