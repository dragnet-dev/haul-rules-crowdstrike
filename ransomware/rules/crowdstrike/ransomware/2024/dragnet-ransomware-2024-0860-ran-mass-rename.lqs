// Dragnet [Ransomware]: dragnet-ransomware-2024-0860 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: ea8b2b40-dd9c-561e-be24-6de81aa662d0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
