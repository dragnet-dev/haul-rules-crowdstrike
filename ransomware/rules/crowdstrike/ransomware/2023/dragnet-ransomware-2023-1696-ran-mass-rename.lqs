// Dragnet [Ransomware]: dragnet-ransomware-2023-1696 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: c7ea6ae3-2695-521f-9cbf-a58e3d748fbb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
