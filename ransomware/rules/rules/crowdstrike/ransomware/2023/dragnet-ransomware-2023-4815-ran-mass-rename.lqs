// Dragnet [Ransomware]: dragnet-ransomware-2023-4815 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 1d75ae1d-9e52-5447-adb6-2af24b5529d9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
