// Dragnet [Ransomware]: dragnet-ransomware-2023-0159 — Mass File Rename (cactus)
// Status: deprecated | Level: high | ID: 77649c70-b75f-51b2-8ccb-5f24b913f381

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
