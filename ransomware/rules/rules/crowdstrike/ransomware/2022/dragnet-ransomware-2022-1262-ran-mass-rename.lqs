// Dragnet [Ransomware]: dragnet-ransomware-2022-1262 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: c911e80e-8623-50e9-908b-942320515586

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
