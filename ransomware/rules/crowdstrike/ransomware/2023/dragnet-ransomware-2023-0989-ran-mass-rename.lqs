// Dragnet [Ransomware]: dragnet-ransomware-2023-0989 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 7491e5f4-2dd2-5ca9-a697-8950e06de0fb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
