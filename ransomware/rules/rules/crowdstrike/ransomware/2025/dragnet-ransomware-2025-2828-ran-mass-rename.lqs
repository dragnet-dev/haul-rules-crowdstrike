// Dragnet [Ransomware]: dragnet-ransomware-2025-2828 — Mass File Rename (play)
// Status: experimental | Level: high | ID: cef04368-67c8-5700-8733-f30b8076bdab

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
