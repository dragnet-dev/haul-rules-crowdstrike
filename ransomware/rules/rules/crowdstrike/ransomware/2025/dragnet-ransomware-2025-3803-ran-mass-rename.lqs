// Dragnet [Ransomware]: dragnet-ransomware-2025-3803 — Mass File Rename (blacknevas)
// Status: experimental | Level: high | ID: ae7b1f28-4de4-5118-9a73-4ef06559be4d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
