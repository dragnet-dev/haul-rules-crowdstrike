// Dragnet [Ransomware]: dragnet-ransomware-2024-3386 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 328d21d9-3567-56a3-92eb-e5dc3bb2d4b2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
