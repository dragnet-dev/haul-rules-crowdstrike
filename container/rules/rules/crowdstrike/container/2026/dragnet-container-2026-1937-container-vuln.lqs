// Dragnet [Container]: dragnet-container-2026-1937 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: f0b75eaa-98cb-5207-9f0e-253e73e9e501

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:7* OR ImageFileName = *debian:8* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:14.04* OR ImageFileName = *ubuntu:14.04-ESM* OR ImageFileName = *ubuntu:14.10* OR ImageFileName = *ubuntu:15.04*)
| table([timestamp, ComputerName])
| limit(1000)
