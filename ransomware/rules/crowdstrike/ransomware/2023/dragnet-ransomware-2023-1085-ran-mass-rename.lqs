// Dragnet [Ransomware]: dragnet-ransomware-2023-1085 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 08e444d3-bc3d-570f-be22-b173d8684a8d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
