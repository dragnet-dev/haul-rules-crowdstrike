// Dragnet [Ransomware]: dragnet-ransomware-2022-1423 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 8e04e147-e0b7-55b1-b059-0f1abf038b6c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
