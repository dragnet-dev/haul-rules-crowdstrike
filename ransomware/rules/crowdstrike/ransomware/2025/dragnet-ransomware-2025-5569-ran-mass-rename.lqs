// Dragnet [Ransomware]: dragnet-ransomware-2025-5569 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: d182bf54-b14e-5797-91ab-dadd25953fb8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
