// Dragnet [Ransomware]: dragnet-ransomware-2026-1731 — Mass File Rename (dragonforce)
// Status: stable | Level: high | ID: c7315fbe-5add-5834-be07-30ad91931afd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
