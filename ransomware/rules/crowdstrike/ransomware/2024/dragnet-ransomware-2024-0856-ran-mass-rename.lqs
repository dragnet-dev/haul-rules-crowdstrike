// Dragnet [Ransomware]: dragnet-ransomware-2024-0856 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: a379ef92-be82-5609-b810-cc4096db0be4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
