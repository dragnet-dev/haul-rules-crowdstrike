// Dragnet [Ransomware]: dragnet-ransomware-2023-1795 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 7c6b7323-1387-5436-a542-dba1b2fc6dba

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
