// Dragnet [Ransomware]: dragnet-ransomware-2024-5861 — Mass File Rename (raworld)
// Status: experimental | Level: high | ID: b8ad1a71-918e-57b8-9a54-5b2fa812181c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
