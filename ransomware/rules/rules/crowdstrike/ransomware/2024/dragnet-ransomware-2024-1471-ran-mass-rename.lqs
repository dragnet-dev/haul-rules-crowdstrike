// Dragnet [Ransomware]: dragnet-ransomware-2024-1471 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 1e3cb7f3-bbda-5520-b7af-2a0aae858d44

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
