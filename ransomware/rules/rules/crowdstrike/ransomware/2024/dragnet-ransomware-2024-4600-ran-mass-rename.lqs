// Dragnet [Ransomware]: dragnet-ransomware-2024-4600 — Mass File Rename (play)
// Status: experimental | Level: high | ID: e45e86fd-91ae-558f-8062-159f6af616d2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
