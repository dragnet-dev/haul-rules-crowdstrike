// Dragnet [Ransomware]: dragnet-ransomware-2022-0381 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: d5ca2ddd-ec8d-5e00-b41e-51d8bb826166

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
