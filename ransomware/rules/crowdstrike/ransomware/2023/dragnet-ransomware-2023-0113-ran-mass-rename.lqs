// Dragnet [Ransomware]: dragnet-ransomware-2023-0113 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: ec21161e-e197-5901-8f52-c5b592fe68dd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
