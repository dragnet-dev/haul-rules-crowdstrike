// Dragnet [Ransomware]: dragnet-ransomware-2021-1086 — Mass File Rename (revil)
// Status: deprecated | Level: high | ID: 16cdda1f-6de7-5f69-a46f-3c81dbbb1121

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
