// Dragnet [Ransomware]: dragnet-ransomware-2024-3323 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 91d6d479-a64e-56e5-99bb-f2446cec89e3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
