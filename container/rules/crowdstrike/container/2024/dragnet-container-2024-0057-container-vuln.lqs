// Dragnet [Container]: dragnet-container-2024-0057 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 36360c00-48c7-505b-8ff7-41532969c130

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
