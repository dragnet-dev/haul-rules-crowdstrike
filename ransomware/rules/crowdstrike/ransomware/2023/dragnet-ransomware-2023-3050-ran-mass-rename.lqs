// Dragnet [Ransomware]: dragnet-ransomware-2023-3050 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 8e46802c-9c62-5380-9df5-1b9aeec95e5a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
