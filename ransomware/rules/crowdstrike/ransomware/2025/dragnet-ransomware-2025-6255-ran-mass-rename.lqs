// Dragnet [Ransomware]: dragnet-ransomware-2025-6255 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: 77f68748-c497-5e7f-98a0-19f392dfb79d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
