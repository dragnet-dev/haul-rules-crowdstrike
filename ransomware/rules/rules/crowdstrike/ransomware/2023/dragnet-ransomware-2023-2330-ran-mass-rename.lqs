// Dragnet [Ransomware]: dragnet-ransomware-2023-2330 — Mass File Rename (royal)
// Status: experimental | Level: high | ID: 673eabea-2615-525c-a136-0b95cde6f95b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
