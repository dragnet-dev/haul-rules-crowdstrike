// Dragnet [Ransomware]: dragnet-ransomware-2024-5725 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 0171ce57-ce3f-5246-a801-b45f05700619

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
