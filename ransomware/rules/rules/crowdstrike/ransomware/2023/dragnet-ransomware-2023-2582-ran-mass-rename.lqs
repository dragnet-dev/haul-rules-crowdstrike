// Dragnet [Ransomware]: dragnet-ransomware-2023-2582 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 657ea3ba-a304-5f27-acf9-d6e788cb73ca

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
