// Dragnet [Ransomware]: dragnet-ransomware-2022-2420 — Mass File Rename (avoslocker)
// Status: deprecated | Level: high | ID: c373acc3-56eb-5659-a4c5-e6d83f7cd334

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
