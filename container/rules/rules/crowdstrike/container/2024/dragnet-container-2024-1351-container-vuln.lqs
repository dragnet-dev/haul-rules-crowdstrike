// Dragnet [Container]: dragnet-container-2024-1351 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 07fffc2e-99ad-50a5-8704-5f00ded298b9

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:9*)
| table([timestamp, ComputerName])
| limit(1000)
