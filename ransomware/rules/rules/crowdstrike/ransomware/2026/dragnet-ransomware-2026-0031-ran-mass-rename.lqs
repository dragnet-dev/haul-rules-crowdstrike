// Dragnet [Ransomware]: dragnet-ransomware-2026-0031 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: ea636777-4ec9-52af-8870-77e64726cd61

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
