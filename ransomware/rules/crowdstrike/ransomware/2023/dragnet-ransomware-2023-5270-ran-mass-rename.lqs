// Dragnet [Ransomware]: dragnet-ransomware-2023-5270 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 3b9c4ea3-d9e2-55d3-8269-f3fc59bf0d83

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
