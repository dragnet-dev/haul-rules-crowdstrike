// Dragnet [Ransomware]: dragnet-ransomware-2024-2947 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: 0c587453-7a06-51cf-9a28-60c56109be57

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
