// Dragnet [Container]: dragnet-container-2026-2798 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 55a8156a-e596-589b-b87e-1d86d90b1d5d

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
