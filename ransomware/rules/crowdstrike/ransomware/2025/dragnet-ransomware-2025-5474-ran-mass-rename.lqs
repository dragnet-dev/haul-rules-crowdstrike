// Dragnet [Ransomware]: dragnet-ransomware-2025-5474 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 6101e72b-2f24-590b-b7c1-6bd7d6b0fa42

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
