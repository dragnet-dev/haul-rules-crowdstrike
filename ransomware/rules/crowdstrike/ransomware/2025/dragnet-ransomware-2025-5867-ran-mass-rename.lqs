// Dragnet [Ransomware]: dragnet-ransomware-2025-5867 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: ece3116b-d36f-5a76-82b5-32aee2be5b5e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
