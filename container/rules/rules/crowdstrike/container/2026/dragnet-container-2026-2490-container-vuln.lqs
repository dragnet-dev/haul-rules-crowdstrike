// Dragnet [Container]: dragnet-container-2026-2490 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 641ae494-e294-5206-87d2-3233aba34a45

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10*)
| table([timestamp, ComputerName])
| limit(1000)
