// Dragnet [Ransomware]: dragnet-ransomware-2023-4768 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 02d095da-f6fe-5160-8c4c-d97fe9c5696f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
