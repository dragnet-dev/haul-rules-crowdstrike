// Dragnet [Ransomware]: dragnet-ransomware-2023-2646 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 58ed568c-b6df-5411-940e-eb744c62bd4a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
