// Dragnet [Ransomware]: dragnet-ransomware-2023-2141 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: dd1a3281-a1ad-55c6-a78e-10999acd7a5f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
