// Dragnet [Ransomware]: dragnet-ransomware-2025-3302 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: d5c59830-e782-50bb-b2e2-7b394874d980

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
