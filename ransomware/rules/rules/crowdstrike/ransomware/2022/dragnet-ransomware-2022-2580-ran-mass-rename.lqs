// Dragnet [Ransomware]: dragnet-ransomware-2022-2580 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: bf995a0a-c99a-5d58-ae82-c47b1367652b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
