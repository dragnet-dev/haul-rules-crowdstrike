// Dragnet [Ransomware]: dragnet-ransomware-2026-1578 — Mass File Rename (thegentlemen)
// Status: deprecated | Level: high | ID: 940e4c4b-6f93-53b5-8ae1-ec299705530d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
