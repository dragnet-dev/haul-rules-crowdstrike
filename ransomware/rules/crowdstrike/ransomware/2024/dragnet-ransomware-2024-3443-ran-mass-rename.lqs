// Dragnet [Ransomware]: dragnet-ransomware-2024-3443 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: fdf9e16e-2bda-5b06-85cc-1eb25e74be89

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
