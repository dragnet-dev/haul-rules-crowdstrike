// Dragnet [Ransomware]: dragnet-ransomware-2024-0088 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: 488aef93-bd3e-59a8-8c7d-de59c9804408

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
