// Dragnet [Ransomware]: dragnet-ransomware-2023-3976 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 61bc7b7e-e2c3-58e2-b2fe-c08756a70dc6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
