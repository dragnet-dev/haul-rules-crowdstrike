// Dragnet [Ransomware]: dragnet-ransomware-2025-4118 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 426b069f-49d2-5d70-8d50-d5cb2fe8531f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
