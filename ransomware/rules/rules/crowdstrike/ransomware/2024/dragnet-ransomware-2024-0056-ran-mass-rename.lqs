// Dragnet [Ransomware]: dragnet-ransomware-2024-0056 — Mass File Rename (play)
// Status: experimental | Level: high | ID: b3efe4da-be29-5030-8ce7-2e01122d064a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
