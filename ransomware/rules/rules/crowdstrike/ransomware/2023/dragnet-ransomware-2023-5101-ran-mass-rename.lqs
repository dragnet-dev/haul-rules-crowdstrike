// Dragnet [Ransomware]: dragnet-ransomware-2023-5101 — Mass File Rename (royal)
// Status: experimental | Level: high | ID: a25e66f6-9d07-57b1-980d-776687a28cd0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
