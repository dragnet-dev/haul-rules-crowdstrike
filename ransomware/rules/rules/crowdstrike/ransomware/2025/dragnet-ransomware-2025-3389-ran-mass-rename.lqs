// Dragnet [Ransomware]: dragnet-ransomware-2025-3389 — Mass File Rename (payoutsking)
// Status: test | Level: high | ID: a5d0ea0c-0131-558d-94ef-2f8bef8fc306

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
