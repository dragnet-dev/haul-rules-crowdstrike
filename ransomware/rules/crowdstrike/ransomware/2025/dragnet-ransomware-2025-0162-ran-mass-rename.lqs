// Dragnet [Ransomware]: dragnet-ransomware-2025-0162 — Mass File Rename (ransomhouse)
// Status: experimental | Level: high | ID: 32a06480-3fa6-5178-a494-c309c2291c2f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
