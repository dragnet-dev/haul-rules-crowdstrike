// Dragnet [Ransomware]: dragnet-ransomware-2021-1779 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: eadc9381-74b7-579b-bd3e-93c357c6f4ee

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
