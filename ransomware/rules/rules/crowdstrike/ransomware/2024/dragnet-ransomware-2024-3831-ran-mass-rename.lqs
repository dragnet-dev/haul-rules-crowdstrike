// Dragnet [Ransomware]: dragnet-ransomware-2024-3831 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 1a4fe19f-e7e5-5e14-956c-d366b0b87000

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
