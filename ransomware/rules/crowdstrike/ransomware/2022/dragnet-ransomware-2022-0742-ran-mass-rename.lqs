// Dragnet [Ransomware]: dragnet-ransomware-2022-0742 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 0d747563-e3b0-5248-ae82-fea7a38d662a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
