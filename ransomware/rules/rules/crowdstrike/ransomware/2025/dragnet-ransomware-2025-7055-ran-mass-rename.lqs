// Dragnet [Ransomware]: dragnet-ransomware-2025-7055 — Mass File Rename (d4rk4rmy)
// Status: experimental | Level: high | ID: 9a873d8a-d67a-553b-89f1-2528d0afe17b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
