// Dragnet [Ransomware]: dragnet-ransomware-2025-0469 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 03d6ac3c-6ba3-5af8-b86f-1c627d1b03f4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
