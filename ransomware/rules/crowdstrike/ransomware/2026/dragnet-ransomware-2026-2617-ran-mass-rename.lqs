// Dragnet [Ransomware]: dragnet-ransomware-2026-2617 — Mass File Rename (everest)
// Status: stable | Level: high | ID: 89b7faf4-7854-5cc3-8585-2c77e4e3eb33

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
