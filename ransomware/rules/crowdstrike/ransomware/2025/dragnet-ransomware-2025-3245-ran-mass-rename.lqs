// Dragnet [Ransomware]: dragnet-ransomware-2025-3245 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 9fb5fb9d-b725-5278-bcde-49e0d12d0e21

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
