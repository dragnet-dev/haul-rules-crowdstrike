// Dragnet [Ransomware]: dragnet-ransomware-2025-4555 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: d4dafd9e-84aa-5581-a446-cfd3601e1629

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
