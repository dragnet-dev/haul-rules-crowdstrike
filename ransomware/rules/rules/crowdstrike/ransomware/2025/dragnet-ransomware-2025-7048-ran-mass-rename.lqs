// Dragnet [Ransomware]: dragnet-ransomware-2025-7048 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 7a40dd5c-55cf-5235-8894-ffb1a017ed45

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
