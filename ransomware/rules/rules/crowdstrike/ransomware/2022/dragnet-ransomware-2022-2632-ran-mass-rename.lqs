// Dragnet [Ransomware]: dragnet-ransomware-2022-2632 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 05e66cd5-fdbe-517b-8a63-de1f208680e4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
