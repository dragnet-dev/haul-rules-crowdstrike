// Dragnet [Ransomware]: dragnet-ransomware-2024-1691 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 49ee29a6-01c4-5b86-b205-2a5614fbc3f5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
