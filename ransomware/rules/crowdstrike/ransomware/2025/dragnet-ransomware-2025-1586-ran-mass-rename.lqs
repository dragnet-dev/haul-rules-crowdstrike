// Dragnet [Ransomware]: dragnet-ransomware-2025-1586 — Mass File Rename (IMNCrew)
// Status: experimental | Level: high | ID: 0e7507e8-6fa8-5216-bcc1-62e5611a97df

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
