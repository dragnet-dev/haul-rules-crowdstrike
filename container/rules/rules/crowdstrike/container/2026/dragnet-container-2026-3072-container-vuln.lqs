// Dragnet [Container]: dragnet-container-2026-3072 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: c998fb0d-ecb9-5b8c-9b6e-a86f415f2719

#event_simpleName=*
| (ImageFileName = *alpine:3.23* OR ImageFileName = *alpine edge:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
