// Dragnet [Ransomware]: dragnet-ransomware-2024-1613 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: b8bf4307-6bcc-5511-b449-fd9d68738b5f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
