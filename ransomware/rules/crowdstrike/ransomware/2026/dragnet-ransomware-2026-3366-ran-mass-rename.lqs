// Dragnet [Ransomware]: dragnet-ransomware-2026-3366 — Mass File Rename (nightspire)
// Status: deprecated | Level: high | ID: f42871de-6482-5e31-a360-abb9df7de8aa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
