// Dragnet [Container]: dragnet-container-2026-0069 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 2b04b8c3-96c1-5172-ab40-af80c16a04e0

#event_simpleName=*
| (ImageFileName = *almalinux:9* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:9* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:22.04* OR ImageFileName = *ubuntu:24.04* OR ImageFileName = *ubuntu:25.10* OR ImageFileName = *ubuntu:26.04*)
| table([timestamp, ComputerName])
| limit(1000)
