// Dragnet [Ransomware]: dragnet-ransomware-2023-0048 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 635531f3-ded1-5a14-98f1-4c5e45f3e504

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
