// Dragnet [Ransomware]: dragnet-ransomware-2022-2824 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 22225b09-495e-507e-9179-05842f36af37

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
