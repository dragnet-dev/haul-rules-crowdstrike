// Dragnet [Ransomware]: dragnet-ransomware-2022-0170 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 31c54149-abaa-516d-a925-88da3c644538

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
