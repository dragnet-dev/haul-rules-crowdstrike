// Dragnet [Ransomware]: dragnet-ransomware-2024-5620 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 8e5e45d4-43b5-5c1d-be30-5fbc9564ceda

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
