// Dragnet [Ransomware]: dragnet-ransomware-2022-1448 — Mass File Rename (play)
// Status: deprecated | Level: high | ID: 6a20da0f-991c-5db4-825e-e4b85ca92f53

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
