// Dragnet [Container]: dragnet-container-2026-2660 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 30016e8d-1f4c-5f38-a7ef-b90262052884

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:8* OR ImageFileName = *ubuntu:16.04* OR ImageFileName = *ubuntu:16.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
