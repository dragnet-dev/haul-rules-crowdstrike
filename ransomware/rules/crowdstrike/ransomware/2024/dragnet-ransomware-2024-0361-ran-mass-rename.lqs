// Dragnet [Ransomware]: dragnet-ransomware-2024-0361 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: de36ca0e-e98d-5e8b-8501-44c8d714f332

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
