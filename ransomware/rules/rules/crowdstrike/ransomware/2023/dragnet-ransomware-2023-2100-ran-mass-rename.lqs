// Dragnet [Ransomware]: dragnet-ransomware-2023-2100 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 3c0581dc-e02e-55cf-8645-27bd9772bd19

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
