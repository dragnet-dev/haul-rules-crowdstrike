// Dragnet [Ransomware]: dragnet-ransomware-2023-1601 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 09b95eb6-a729-5aea-b970-d2b4c9e41478

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
