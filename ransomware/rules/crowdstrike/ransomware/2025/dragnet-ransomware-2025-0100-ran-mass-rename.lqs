// Dragnet [Ransomware]: dragnet-ransomware-2025-0100 — Mass File Rename (handala)
// Status: experimental | Level: high | ID: 0b377c71-de1e-506d-8cf0-3b1cdab80d13

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
