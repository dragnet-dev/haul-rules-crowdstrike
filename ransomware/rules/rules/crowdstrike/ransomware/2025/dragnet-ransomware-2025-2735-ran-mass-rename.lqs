// Dragnet [Ransomware]: dragnet-ransomware-2025-2735 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: a3be7df6-8285-50c4-9a0f-e8cf66dffe52

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
