// Dragnet [Ransomware]: dragnet-ransomware-2026-0302 — Mass File Rename (payoutsking)
// Status: deprecated | Level: high | ID: 21416cf7-5e8b-5054-86c8-1f611858c70b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
