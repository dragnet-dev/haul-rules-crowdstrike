// Dragnet [Ransomware]: dragnet-ransomware-2024-4097 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 7cbe88cc-8770-5705-868b-f51359bf4950

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
