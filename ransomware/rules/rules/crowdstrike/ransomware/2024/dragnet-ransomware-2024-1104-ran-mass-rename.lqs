// Dragnet [Ransomware]: dragnet-ransomware-2024-1104 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: 898933a7-4016-5a67-9ed3-63fa1f20ff94

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
