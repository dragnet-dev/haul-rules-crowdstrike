// Dragnet [Ransomware]: dragnet-ransomware-2023-4052 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 52039089-a4de-5b64-880d-663cb1964d9f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
