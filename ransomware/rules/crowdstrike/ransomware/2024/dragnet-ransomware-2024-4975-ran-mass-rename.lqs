// Dragnet [Ransomware]: dragnet-ransomware-2024-4975 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: d6c3098d-c80a-55c5-9235-aa737293c32d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
