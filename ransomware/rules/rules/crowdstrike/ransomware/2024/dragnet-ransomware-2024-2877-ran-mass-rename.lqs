// Dragnet [Ransomware]: dragnet-ransomware-2024-2877 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 34b0d1f8-a50c-53a5-863a-609701068319

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
