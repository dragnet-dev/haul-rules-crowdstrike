// Dragnet [Ransomware]: dragnet-ransomware-2023-2969 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: f4dd2b33-3e05-50ef-b661-2f4b8cbf0a95

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
