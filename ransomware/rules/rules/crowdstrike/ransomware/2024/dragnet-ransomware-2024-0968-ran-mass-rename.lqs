// Dragnet [Ransomware]: dragnet-ransomware-2024-0968 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: 00a88930-ce59-5932-b294-11de0f0d5f24

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
