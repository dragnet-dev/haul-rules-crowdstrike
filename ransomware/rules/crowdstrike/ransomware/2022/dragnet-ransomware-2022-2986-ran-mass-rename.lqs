// Dragnet [Ransomware]: dragnet-ransomware-2022-2986 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 5ed05258-456e-5d2d-adcf-1a701cd39e87

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
