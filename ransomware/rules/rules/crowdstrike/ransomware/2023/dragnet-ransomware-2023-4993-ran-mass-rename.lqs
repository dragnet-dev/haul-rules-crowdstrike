// Dragnet [Ransomware]: dragnet-ransomware-2023-4993 — Mass File Rename (blacknevas)
// Status: experimental | Level: high | ID: 6464e328-8a6d-517d-9e30-9f014216a1a2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
