// Dragnet [Ransomware]: dragnet-ransomware-2022-3147 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 94cd80c6-ba25-508c-8c8c-43add82bb728

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
