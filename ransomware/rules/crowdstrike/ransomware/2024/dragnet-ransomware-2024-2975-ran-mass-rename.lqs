// Dragnet [Ransomware]: dragnet-ransomware-2024-2975 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: cbeb17f3-c968-5a6a-963c-805fcc04c63c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
