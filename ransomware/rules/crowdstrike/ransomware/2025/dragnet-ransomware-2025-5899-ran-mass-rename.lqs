// Dragnet [Ransomware]: dragnet-ransomware-2025-5899 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 2413dbb8-c315-5738-88e8-0dceb6c4d8cd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
