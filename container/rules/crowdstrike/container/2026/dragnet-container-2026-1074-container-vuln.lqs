// Dragnet [Container]: dragnet-container-2026-1074 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: a9b05cad-5251-532f-84ec-19538151e6f5

#event_simpleName=*
| (ImageFileName = *amazonlinux:1* OR ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10* OR ImageFileName = *ubuntu:13.04*)
| table([timestamp, ComputerName])
| limit(1000)
