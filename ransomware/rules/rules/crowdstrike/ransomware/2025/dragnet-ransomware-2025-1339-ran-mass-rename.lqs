// Dragnet [Ransomware]: dragnet-ransomware-2025-1339 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: c98f3291-d003-5b12-b4f7-da670523e3f8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
