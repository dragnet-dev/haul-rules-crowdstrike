// Dragnet [Ransomware]: dragnet-ransomware-2023-4325 — Mass File Rename (abyss)
// Status: deprecated | Level: high | ID: 20600c99-4b2e-5b81-863d-137732a10ce2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
