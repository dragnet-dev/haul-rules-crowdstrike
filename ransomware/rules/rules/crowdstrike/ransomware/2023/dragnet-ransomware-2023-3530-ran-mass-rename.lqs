// Dragnet [Ransomware]: dragnet-ransomware-2023-3530 — Mass File Rename (ransomed)
// Status: deprecated | Level: high | ID: 02051bf9-d259-5074-9251-7c2aa931579d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
