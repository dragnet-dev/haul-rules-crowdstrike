// Dragnet [Ransomware]: dragnet-ransomware-2025-0049 — Mass File Rename (worldleaks)
// Status: experimental | Level: high | ID: 66b90551-c1e3-57f7-a5fb-e8697d3632c6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
