// Dragnet [Ransomware]: dragnet-ransomware-2024-0727 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 532d94f5-b8c9-5739-af2b-3fd2325aa82d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
