// Dragnet [Ransomware]: dragnet-ransomware-2023-4374 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: b6baaca9-8df9-5c4f-9cb5-196cf236756a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
