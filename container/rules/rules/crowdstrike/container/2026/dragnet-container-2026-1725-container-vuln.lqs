// Dragnet [Container]: dragnet-container-2026-1725 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: aa5cde03-c8f2-57ef-b801-a83fdaf2e46d

#event_simpleName=*
| (ImageFileName = *alpine:3.23* OR ImageFileName = *alpine edge:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
