// Dragnet [Container]: dragnet-container-2026-3040 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: ee55d6d7-832a-5929-bce4-0042d28c6280

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:7*)
| table([timestamp, ComputerName])
| limit(1000)
