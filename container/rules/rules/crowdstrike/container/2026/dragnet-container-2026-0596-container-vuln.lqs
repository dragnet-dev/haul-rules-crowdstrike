// Dragnet [Container]: dragnet-container-2026-0596 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 5a1d5d8a-0392-52a1-894e-011f296d6be2

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10*)
| table([timestamp, ComputerName])
| limit(1000)
