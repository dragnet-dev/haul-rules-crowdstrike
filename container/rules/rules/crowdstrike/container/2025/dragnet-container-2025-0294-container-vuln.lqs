// Dragnet [Container]: dragnet-container-2025-0294 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: a2ee0f3f-97cd-5156-af41-a52af2e3d092

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:14.04-ESM* OR ImageFileName = *ubuntu:16.04-ESM* OR ImageFileName = *ubuntu:18.04-ESM* OR ImageFileName = *ubuntu:20.04-ESM* OR ImageFileName = *ubuntu:22.04* OR ImageFileName = *ubuntu:22.10*)
| table([timestamp, ComputerName])
| limit(1000)
