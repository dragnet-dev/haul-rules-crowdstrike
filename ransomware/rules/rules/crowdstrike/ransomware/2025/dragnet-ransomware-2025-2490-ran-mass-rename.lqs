// Dragnet [Ransomware]: dragnet-ransomware-2025-2490 — Mass File Rename (thegentlemen)
// Status: experimental | Level: high | ID: 4e590644-a7a5-505b-9757-ec12ad3a550f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
