// Dragnet [Container]: dragnet-container-2024-0951 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 5394e742-b8f5-5775-a2f4-1ea7cc4bc385

#event_simpleName=*
| (ImageFileName = *amazonlinux:1* OR ImageFileName = *debian:11* OR ImageFileName = *debian:7* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *oraclelinux:7* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:14.04* OR ImageFileName = *ubuntu:14.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
