// Dragnet [Ransomware]: dragnet-ransomware-2024-5824 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: a26932f3-feb2-528c-a10d-03ef3782b1bc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
