// Dragnet [Container]: dragnet-container-2024-0339 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 79120fa9-2ecd-5f75-baf5-b2fcf71cc95b

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *ubuntu:20.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
