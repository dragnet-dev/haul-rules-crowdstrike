// Dragnet [Container]: dragnet-container-2026-1734 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 145e5095-646c-5d5b-83f6-2991335e2480

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:5*)
| table([timestamp, ComputerName])
| limit(1000)
