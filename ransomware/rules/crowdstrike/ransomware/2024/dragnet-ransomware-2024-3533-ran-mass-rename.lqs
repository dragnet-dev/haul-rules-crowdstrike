// Dragnet [Ransomware]: dragnet-ransomware-2024-3533 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: f2e501d7-a872-5530-94bb-734d02786d53

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
