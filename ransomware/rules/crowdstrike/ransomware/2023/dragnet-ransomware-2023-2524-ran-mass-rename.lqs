// Dragnet [Ransomware]: dragnet-ransomware-2023-2524 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: f6f5e161-6087-5a5c-8232-90d36d1f9d4b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
