// Dragnet [Ransomware]: dragnet-ransomware-2024-2805 — Mass File Rename (cloak)
// Status: deprecated | Level: high | ID: b21020ef-e8e1-51b2-8866-9be21af50b63

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
