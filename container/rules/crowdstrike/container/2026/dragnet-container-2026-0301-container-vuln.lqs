// Dragnet [Container]: dragnet-container-2026-0301 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 2c90cba2-a40d-5fcb-a26e-3db53e204fc8

#event_simpleName=*
| (ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *ubuntu:12.04*)
| table([timestamp, ComputerName])
| limit(1000)
