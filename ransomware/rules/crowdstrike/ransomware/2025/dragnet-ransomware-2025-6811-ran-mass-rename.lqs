// Dragnet [Ransomware]: dragnet-ransomware-2025-6811 — Mass File Rename (warlock)
// Status: deprecated | Level: high | ID: 6e8d0249-365a-5090-85e3-272a5c2ad5c6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
