// Dragnet [Ransomware]: dragnet-ransomware-2025-3180 — Mass File Rename (medusalocker)
// Status: experimental | Level: high | ID: 14f957c7-b147-5644-9c20-7cbdbd848e24

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
