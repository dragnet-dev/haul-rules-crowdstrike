// Dragnet [Ransomware]: dragnet-ransomware-2023-5300 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: ce4298ee-bb65-51fb-b4c6-2051fc2d4716

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
