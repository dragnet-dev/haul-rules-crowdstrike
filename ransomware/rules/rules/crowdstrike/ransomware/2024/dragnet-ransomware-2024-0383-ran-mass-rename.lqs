// Dragnet [Ransomware]: dragnet-ransomware-2024-0383 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 68f5d1b5-0879-5edf-ae8e-d807d90e324f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
