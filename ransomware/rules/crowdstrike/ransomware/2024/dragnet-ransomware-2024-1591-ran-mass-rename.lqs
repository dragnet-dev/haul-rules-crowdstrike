// Dragnet [Ransomware]: dragnet-ransomware-2024-1591 — Mass File Rename (play)
// Status: experimental | Level: high | ID: a38ea2d7-d7df-5092-8ff6-0230691c0838

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
