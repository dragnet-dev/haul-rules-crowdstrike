// Dragnet [Container]: dragnet-container-2026-0900 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: c9925ae8-2f7c-57b9-96ca-b74978cd06cf

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6*)
| table([timestamp, ComputerName])
| limit(1000)
