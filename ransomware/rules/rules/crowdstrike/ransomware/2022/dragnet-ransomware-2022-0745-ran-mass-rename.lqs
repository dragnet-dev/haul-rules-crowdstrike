// Dragnet [Ransomware]: dragnet-ransomware-2022-0745 — Mass File Rename (midas)
// Status: deprecated | Level: high | ID: 31640594-45d3-5e40-809f-c27ed05a8e3e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
