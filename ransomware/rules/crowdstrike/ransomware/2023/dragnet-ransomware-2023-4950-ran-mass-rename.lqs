// Dragnet [Ransomware]: dragnet-ransomware-2023-4950 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 2bcebbdd-4e2f-5212-9fe2-4b2c19e0e712

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
