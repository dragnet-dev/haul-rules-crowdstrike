// Dragnet [Ransomware]: dragnet-ransomware-2025-1492 — Mass File Rename (skira)
// Status: experimental | Level: high | ID: 2f15e166-5a77-5314-9de3-39db4975a9b3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
