// Dragnet [Ransomware]: dragnet-ransomware-2020-0128 — Mass File Rename (revil)
// Status: deprecated | Level: high | ID: 1ed422d3-0167-5b43-ba84-f7b49a9e51be

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
