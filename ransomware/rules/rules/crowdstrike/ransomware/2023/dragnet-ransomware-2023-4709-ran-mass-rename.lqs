// Dragnet [Ransomware]: dragnet-ransomware-2023-4709 — Mass File Rename (play)
// Status: experimental | Level: high | ID: ee4b512f-d3f1-5314-8ef5-b6f4b0f82d70

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
