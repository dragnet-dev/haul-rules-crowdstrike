// Dragnet [Container]: dragnet-container-2024-1105 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: b16816d9-cb33-51ce-a1b5-263b1b461b74

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:9*)
| table([timestamp, ComputerName])
| limit(1000)
