// Dragnet [Ransomware]: dragnet-ransomware-2023-4455 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 9f0aa2ea-7616-5b04-99b3-6e0f71d6a227

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
