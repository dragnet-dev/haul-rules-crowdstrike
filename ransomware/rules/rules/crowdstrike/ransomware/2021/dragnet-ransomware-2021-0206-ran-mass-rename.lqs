// Dragnet [Ransomware]: dragnet-ransomware-2021-0206 — Mass File Rename (ransomexx)
// Status: deprecated | Level: high | ID: 387c3750-6bb1-5250-b400-5e27e7dc752e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
