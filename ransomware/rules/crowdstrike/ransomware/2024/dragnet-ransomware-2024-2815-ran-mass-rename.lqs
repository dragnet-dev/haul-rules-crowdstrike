// Dragnet [Ransomware]: dragnet-ransomware-2024-2815 — Mass File Rename (frag)
// Status: deprecated | Level: high | ID: d616454b-6769-5d54-b44c-73e89490f422

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
