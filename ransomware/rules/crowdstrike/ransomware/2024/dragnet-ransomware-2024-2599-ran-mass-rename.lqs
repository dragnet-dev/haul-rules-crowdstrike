// Dragnet [Ransomware]: dragnet-ransomware-2024-2599 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: 495fe1d6-1fd5-5fb0-a7d2-c5783e3718b1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
