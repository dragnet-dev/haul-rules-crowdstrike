// Dragnet [Ransomware]: dragnet-ransomware-2025-2216 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 51e848ae-0b22-5a38-b9d8-784cb3535317

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
