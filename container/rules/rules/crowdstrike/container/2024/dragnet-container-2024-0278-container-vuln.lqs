// Dragnet [Container]: dragnet-container-2024-0278 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 303f6f40-cd7b-55ef-a139-294dc5689710

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12*)
| table([timestamp, ComputerName])
| limit(1000)
