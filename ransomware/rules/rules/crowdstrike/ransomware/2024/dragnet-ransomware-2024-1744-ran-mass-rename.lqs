// Dragnet [Ransomware]: dragnet-ransomware-2024-1744 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: e654a4a7-9741-5284-9364-0469337535cd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
