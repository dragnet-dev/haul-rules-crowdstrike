// Dragnet [Ransomware]: dragnet-ransomware-2025-2664 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: ea86d3a9-d5a7-5a36-9ebf-1482a487fead

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
