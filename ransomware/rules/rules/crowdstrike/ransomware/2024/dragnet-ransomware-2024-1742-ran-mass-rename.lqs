// Dragnet [Ransomware]: dragnet-ransomware-2024-1742 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: d19a3c6e-840c-51b6-b9de-304f1b462f90

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
