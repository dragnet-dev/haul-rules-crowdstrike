// Dragnet [Ransomware]: dragnet-ransomware-2023-1631 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: b7640249-96ce-59f3-a3e1-564783b0b96e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
