// Dragnet [Ransomware]: dragnet-ransomware-2025-4711 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: 3ba300d9-9458-5b28-8f28-926b397da135

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
