// Dragnet [Ransomware]: dragnet-ransomware-2023-3014 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 6678def3-9196-58f4-a48d-7e28f231bad0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
