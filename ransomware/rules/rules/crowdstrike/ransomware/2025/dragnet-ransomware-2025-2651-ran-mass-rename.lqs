// Dragnet [Ransomware]: dragnet-ransomware-2025-2651 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 0f641d0c-03fc-57a3-aa73-11fa65b4611e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
