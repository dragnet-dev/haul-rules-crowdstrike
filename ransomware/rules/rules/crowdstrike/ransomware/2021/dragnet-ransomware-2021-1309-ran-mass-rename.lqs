// Dragnet [Ransomware]: dragnet-ransomware-2021-1309 — Mass File Rename (avaddon)
// Status: deprecated | Level: high | ID: 71e6d387-0b0b-5eba-a99e-506fcb245999

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
