// Dragnet [Ransomware]: dragnet-ransomware-2025-5322 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 0d3acbd5-ca76-557c-a9b4-7b0f9882ad28

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
