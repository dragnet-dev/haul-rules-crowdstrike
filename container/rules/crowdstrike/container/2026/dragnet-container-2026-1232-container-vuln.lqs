// Dragnet [Container]: dragnet-container-2026-1232 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: f44e2da7-392a-53e3-88f4-f9123d813cfb

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6*)
| table([timestamp, ComputerName])
| limit(1000)
