// Dragnet [Ransomware]: dragnet-ransomware-2026-2631 — Mass File Rename (exitium)
// Status: stable | Level: high | ID: b1b127c9-1bbb-5f94-a670-23dcc5c261f1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
