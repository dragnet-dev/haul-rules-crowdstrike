// Dragnet [Ransomware]: dragnet-ransomware-2025-6711 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: a3d1edc6-4e60-5548-b686-790ec63c0eee

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
