// Dragnet [Ransomware]: dragnet-ransomware-2022-2087 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 26ae5d87-72d2-50f5-b866-3f19dd38e9fe

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
