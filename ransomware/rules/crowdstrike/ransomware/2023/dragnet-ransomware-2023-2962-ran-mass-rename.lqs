// Dragnet [Ransomware]: dragnet-ransomware-2023-2962 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: f969e8d0-b5a2-5f62-87c0-4cd91690f909

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
