// Dragnet [Container]: dragnet-container-2024-1274 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 3e1c5aa3-602c-5f63-8d95-3a1575140dea

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
