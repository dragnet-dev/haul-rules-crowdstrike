// Dragnet [Ransomware]: dragnet-ransomware-2023-0135 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 230ce665-a8b2-59e0-ab01-ce3ffaa0ddfc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
