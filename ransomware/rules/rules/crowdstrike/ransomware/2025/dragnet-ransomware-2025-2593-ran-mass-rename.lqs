// Dragnet [Ransomware]: dragnet-ransomware-2025-2593 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: f1ca5068-23f7-58c7-9420-17161dcd328b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
