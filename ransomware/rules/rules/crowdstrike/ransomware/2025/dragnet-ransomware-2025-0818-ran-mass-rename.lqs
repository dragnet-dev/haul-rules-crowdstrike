// Dragnet [Ransomware]: dragnet-ransomware-2025-0818 — Mass File Rename (J)
// Status: experimental | Level: high | ID: 8a2f53c3-4e90-5477-86d4-151fcd42d4da

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
