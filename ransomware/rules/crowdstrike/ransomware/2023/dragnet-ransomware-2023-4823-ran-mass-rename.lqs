// Dragnet [Ransomware]: dragnet-ransomware-2023-4823 — Mass File Rename (royal)
// Status: experimental | Level: high | ID: 41837357-c281-5ea6-8de7-25ae35e43504

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
