// Dragnet [Ransomware]: dragnet-ransomware-2024-5361 — Mass File Rename (ElDorado)
// Status: deprecated | Level: high | ID: ff055d11-4c7c-5217-9094-d92515791336

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
