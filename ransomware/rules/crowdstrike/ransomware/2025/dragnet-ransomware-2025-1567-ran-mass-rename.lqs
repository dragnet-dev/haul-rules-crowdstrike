// Dragnet [Ransomware]: dragnet-ransomware-2025-1567 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: aabf34cc-ec73-5ae1-984b-84da8ae1626e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
