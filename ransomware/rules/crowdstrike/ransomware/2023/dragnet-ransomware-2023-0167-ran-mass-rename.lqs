// Dragnet [Ransomware]: dragnet-ransomware-2023-0167 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 45a45900-403c-5375-a973-08ac8f1fa955

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
