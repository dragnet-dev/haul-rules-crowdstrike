// Dragnet [Ransomware]: dragnet-ransomware-2023-3139 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: 4ae17852-0ba4-58dd-86bc-b594dd817588

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
