// Dragnet [Ransomware]: dragnet-ransomware-2024-2297 — Mass File Rename (play)
// Status: experimental | Level: high | ID: fcb4ee7e-1905-5c89-bdac-d06f9a0b3097

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
