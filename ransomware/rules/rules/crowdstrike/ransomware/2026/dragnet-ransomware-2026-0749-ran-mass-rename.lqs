// Dragnet [Ransomware]: dragnet-ransomware-2026-0749 — Mass File Rename (alphalocker)
// Status: stable | Level: high | ID: 12eebd74-ec7b-5c68-b559-c8d6c8305d63

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
