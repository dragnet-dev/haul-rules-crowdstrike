// Dragnet [Ransomware]: dragnet-ransomware-2022-0481 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 5f011d5d-cf4e-550d-96d4-fa7540a80f75

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
