// Dragnet [Ransomware]: dragnet-ransomware-2025-6797 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 63e6a098-596f-511d-b532-01f049459cf6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
