// Dragnet [Ransomware]: dragnet-ransomware-2024-5668 — Mass File Rename (embargo)
// Status: experimental | Level: high | ID: 0e2c17d1-fecf-5467-a9c1-0a4d158a0fde

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
