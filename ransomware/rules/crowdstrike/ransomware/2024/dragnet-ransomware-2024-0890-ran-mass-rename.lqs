// Dragnet [Ransomware]: dragnet-ransomware-2024-0890 — Mass File Rename (qilin)
// Status: deprecated | Level: high | ID: d4554ac6-2b6a-521d-9bca-a868ebb07045

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
