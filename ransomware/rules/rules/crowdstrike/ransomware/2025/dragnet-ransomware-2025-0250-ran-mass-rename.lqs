// Dragnet [Ransomware]: dragnet-ransomware-2025-0250 — Mass File Rename (rhysida)
// Status: experimental | Level: high | ID: 3bfc7c57-de49-521c-b61a-dda31df5f273

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
