// Dragnet [Container]: dragnet-container-2026-0122 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: d2a2132c-f4ce-5ecd-bb39-8a261f191064

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:8* OR ImageFileName = *debian:9* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:16.04* OR ImageFileName = *ubuntu:16.04-ESM* OR ImageFileName = *ubuntu:17.10* OR ImageFileName = *ubuntu:18.04* OR ImageFileName = *ubuntu:18.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
