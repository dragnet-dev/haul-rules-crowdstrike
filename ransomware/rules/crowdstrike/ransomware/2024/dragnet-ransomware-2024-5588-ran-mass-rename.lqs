// Dragnet [Ransomware]: dragnet-ransomware-2024-5588 — Mass File Rename (blacklock)
// Status: experimental | Level: high | ID: 9d7a0867-9e8e-5b72-b6ca-dfb6f2fca773

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
