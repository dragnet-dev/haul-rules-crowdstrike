// Dragnet [Ransomware]: dragnet-ransomware-2023-0249 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 2a18bd32-dd42-5f76-9fef-9d8fbf86658b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
