// Dragnet [Ransomware]: dragnet-ransomware-2024-0469 — Mass File Rename (arcusmedia)
// Status: experimental | Level: high | ID: 88b409b4-a4b4-544a-9590-efeb2422cfa7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
