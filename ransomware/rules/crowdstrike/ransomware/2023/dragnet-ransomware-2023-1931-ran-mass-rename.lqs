// Dragnet [Ransomware]: dragnet-ransomware-2023-1931 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: f925e735-198e-54ee-9349-511afb83e806

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
