// Dragnet [Ransomware]: dragnet-ransomware-2023-0854 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: d6ef29b6-d49b-5212-b19b-87f4f3fc4f19

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
