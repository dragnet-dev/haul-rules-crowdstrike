// Dragnet [Ransomware]: dragnet-ransomware-2023-4759 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 2c76087b-3fa2-5496-b2f0-6d7641f6775a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
