// Dragnet [Ransomware]: dragnet-ransomware-2024-1634 — Mass File Rename (helldown)
// Status: experimental | Level: high | ID: 9e4cf95f-c53d-5434-b321-f8a17cbdfe1b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
