// Dragnet [Ransomware]: dragnet-ransomware-2023-0067 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: ab53497e-bdaf-546d-bebf-467452781873

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
