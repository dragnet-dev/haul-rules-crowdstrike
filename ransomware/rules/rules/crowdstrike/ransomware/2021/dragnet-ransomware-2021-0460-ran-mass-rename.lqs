// Dragnet [Ransomware]: dragnet-ransomware-2021-0460 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: fb40c196-452e-57ab-8a68-c4af09e3a49b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
