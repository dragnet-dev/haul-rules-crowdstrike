// Dragnet [Ransomware]: dragnet-ransomware-2024-3884 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: d687a93e-1c61-59d9-ac78-bff8f7cc7231

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
