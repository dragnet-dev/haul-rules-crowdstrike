// Dragnet [Ransomware]: dragnet-ransomware-2025-0023 — Mass File Rename (lockbit5)
// Status: test | Level: high | ID: ac8fd083-c5f7-58d8-bbbf-a0626f8a1f6e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
