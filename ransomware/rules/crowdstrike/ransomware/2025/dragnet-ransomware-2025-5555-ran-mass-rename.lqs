// Dragnet [Ransomware]: dragnet-ransomware-2025-5555 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: d17e7674-f0c8-5dd6-8503-36dcb7185d02

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
