// Dragnet [Ransomware]: dragnet-ransomware-2025-5240 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: e7a8ea6f-c093-5e91-820a-87de54eb2693

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
