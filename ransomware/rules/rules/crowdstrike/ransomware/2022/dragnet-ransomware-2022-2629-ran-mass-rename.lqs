// Dragnet [Ransomware]: dragnet-ransomware-2022-2629 — Mass File Rename (cuba)
// Status: deprecated | Level: high | ID: 266c385a-0251-52b4-a133-d746de035c6b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
