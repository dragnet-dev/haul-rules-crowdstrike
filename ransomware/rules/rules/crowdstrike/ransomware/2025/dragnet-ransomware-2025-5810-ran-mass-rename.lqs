// Dragnet [Ransomware]: dragnet-ransomware-2025-5810 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 3493fd8d-6593-5ca6-8857-15fa43f6f03b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
