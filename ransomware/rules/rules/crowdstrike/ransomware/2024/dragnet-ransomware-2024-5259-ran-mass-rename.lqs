// Dragnet [Ransomware]: dragnet-ransomware-2024-5259 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: bd7345b4-399b-52d3-9614-23338fe151ff

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
