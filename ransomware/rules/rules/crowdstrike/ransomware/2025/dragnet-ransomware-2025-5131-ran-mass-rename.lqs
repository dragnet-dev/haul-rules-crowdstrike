// Dragnet [Ransomware]: dragnet-ransomware-2025-5131 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: 33dde5c4-9132-566f-a47b-a43451b3e5ab

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
