// Dragnet [Ransomware]: dragnet-ransomware-2023-4664 — Mass File Rename (donutleaks)
// Status: experimental | Level: high | ID: 1e2f9faa-3730-5667-b714-7c5d83b41ba9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
