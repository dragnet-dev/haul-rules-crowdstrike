// Dragnet [Ransomware]: dragnet-ransomware-2022-0585 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: b3c5b243-6176-51e8-b67d-1864129573fa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
