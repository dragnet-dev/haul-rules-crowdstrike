// Dragnet [Ransomware]: dragnet-ransomware-2024-3876 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: f7a872ce-638d-5124-b4b1-98eacfffe05b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
