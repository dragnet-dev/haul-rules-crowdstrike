// Dragnet [Ransomware]: dragnet-ransomware-2021-1092 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 85138320-bbe0-5ba1-a6fa-5f7bf5b6328c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
