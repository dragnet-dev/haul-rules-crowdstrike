// Dragnet [Ransomware]: dragnet-ransomware-2024-0032 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: f4485139-ed01-5c8f-ba11-6b7504138e27

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
