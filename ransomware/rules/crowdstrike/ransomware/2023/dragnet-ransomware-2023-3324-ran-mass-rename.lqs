// Dragnet [Ransomware]: dragnet-ransomware-2023-3324 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: d253d01b-e26b-51b1-82c6-c2fe39cf757e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
