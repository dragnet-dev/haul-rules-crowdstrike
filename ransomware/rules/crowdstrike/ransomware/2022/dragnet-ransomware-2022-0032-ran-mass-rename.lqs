// Dragnet [Ransomware]: dragnet-ransomware-2022-0032 — Mass File Rename (vicesociety)
// Status: deprecated | Level: high | ID: c963cd21-102c-57f5-849b-9558ac241e82

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
