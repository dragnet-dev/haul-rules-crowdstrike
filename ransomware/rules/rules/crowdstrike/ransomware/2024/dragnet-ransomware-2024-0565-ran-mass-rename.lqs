// Dragnet [Ransomware]: dragnet-ransomware-2024-0565 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: d35e6cbe-dbca-5c75-8bb5-030412f7153f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
