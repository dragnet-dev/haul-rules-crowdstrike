// Dragnet [Ransomware]: dragnet-ransomware-2025-4382 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 5f886589-3f69-5ace-bfd5-f8d548bf7eff

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
