// Dragnet [Ransomware]: dragnet-ransomware-2023-0417 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: adc92fa5-245a-53cb-8982-05ca722aefbd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
