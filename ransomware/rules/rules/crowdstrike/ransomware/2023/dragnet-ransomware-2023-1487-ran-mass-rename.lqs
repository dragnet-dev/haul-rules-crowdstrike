// Dragnet [Ransomware]: dragnet-ransomware-2023-1487 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 00f47f8b-514a-5894-b863-4eea9a2ac51b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
