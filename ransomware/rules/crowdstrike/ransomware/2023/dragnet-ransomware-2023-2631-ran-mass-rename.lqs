// Dragnet [Ransomware]: dragnet-ransomware-2023-2631 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 969e123c-b6fd-565d-bab6-ec2b08b5e140

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
