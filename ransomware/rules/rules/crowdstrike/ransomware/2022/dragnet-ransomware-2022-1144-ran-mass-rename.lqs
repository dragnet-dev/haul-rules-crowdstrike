// Dragnet [Ransomware]: dragnet-ransomware-2022-1144 — Mass File Rename (mindware)
// Status: deprecated | Level: high | ID: 809ffd87-57c4-5616-8b10-8464574dfe68

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
