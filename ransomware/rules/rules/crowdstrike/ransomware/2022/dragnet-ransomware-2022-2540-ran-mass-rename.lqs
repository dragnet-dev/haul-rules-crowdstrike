// Dragnet [Ransomware]: dragnet-ransomware-2022-2540 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 9184792e-39e7-5538-80bf-855ca3b30aad

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
