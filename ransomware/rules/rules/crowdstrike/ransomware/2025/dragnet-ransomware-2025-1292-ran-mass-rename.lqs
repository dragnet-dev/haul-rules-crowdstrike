// Dragnet [Ransomware]: dragnet-ransomware-2025-1292 — Mass File Rename (ransomhouse)
// Status: experimental | Level: high | ID: 552bd63f-63b7-55e8-ae69-c992bb1ee064

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
