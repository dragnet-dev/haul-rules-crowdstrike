// Dragnet [Ransomware]: dragnet-ransomware-2023-0973 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 57756250-e6e9-5a57-983a-703a40f785d2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
