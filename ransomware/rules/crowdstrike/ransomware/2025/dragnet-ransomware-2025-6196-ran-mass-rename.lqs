// Dragnet [Ransomware]: dragnet-ransomware-2025-6196 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 0367f0c6-8077-5e1a-b758-a793a42581c1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
