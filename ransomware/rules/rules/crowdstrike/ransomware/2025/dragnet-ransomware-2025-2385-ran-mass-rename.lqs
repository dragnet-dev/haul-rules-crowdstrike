// Dragnet [Ransomware]: dragnet-ransomware-2025-2385 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: 50b94709-591c-5809-834d-a4c5c7e9c5e1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
