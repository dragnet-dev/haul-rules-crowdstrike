// Dragnet [Ransomware]: dragnet-ransomware-2025-5138 — Mass File Rename (coinbasecartel)
// Status: experimental | Level: high | ID: 005f3fb4-fe47-5f6b-83f0-fd1082890003

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
