// Dragnet [Ransomware]: dragnet-ransomware-2023-0096 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: eb789ef6-b2fe-5f5b-bb9f-215bb3c6cf5d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
