// Dragnet [Ransomware]: dragnet-ransomware-2024-0772 — Mass File Rename (blacklock)
// Status: experimental | Level: high | ID: 3525791a-a258-566b-b541-7e7954adf270

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
