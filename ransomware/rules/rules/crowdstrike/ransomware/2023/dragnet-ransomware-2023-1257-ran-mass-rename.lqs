// Dragnet [Ransomware]: dragnet-ransomware-2023-1257 — Mass File Rename (blacklock)
// Status: experimental | Level: high | ID: 74f5fdb9-ef03-546d-a273-ea4e1e9ca768

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
