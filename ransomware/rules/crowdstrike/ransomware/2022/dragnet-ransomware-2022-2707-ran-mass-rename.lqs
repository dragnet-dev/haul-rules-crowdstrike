// Dragnet [Ransomware]: dragnet-ransomware-2022-2707 — Mass File Rename (royal)
// Status: deprecated | Level: high | ID: fdfd8e69-5301-5f90-b43a-931b8ca63cd3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
