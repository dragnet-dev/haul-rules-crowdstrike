// Dragnet [Ransomware]: dragnet-ransomware-2023-5045 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 519c119b-d6ff-592c-885d-cd9f6f4c06c6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
