// Dragnet [Ransomware]: dragnet-ransomware-2023-2130 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: a4b02f1c-6fed-5c83-b6e6-432914d046ea

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
