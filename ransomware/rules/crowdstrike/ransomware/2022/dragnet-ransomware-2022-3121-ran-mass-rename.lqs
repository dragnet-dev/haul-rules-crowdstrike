// Dragnet [Ransomware]: dragnet-ransomware-2022-3121 — Mass File Rename (snatch)
// Status: deprecated | Level: high | ID: 00277175-d501-54e7-9458-d7943191d853

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
