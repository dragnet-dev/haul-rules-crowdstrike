// Dragnet [Ransomware]: dragnet-ransomware-2022-0766 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 522e41ab-9d4c-515d-a275-3e1d068c6609

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
