// Dragnet [Ransomware]: dragnet-ransomware-2025-4541 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 4e407a00-2795-57e1-bb5c-9711e41d8179

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
