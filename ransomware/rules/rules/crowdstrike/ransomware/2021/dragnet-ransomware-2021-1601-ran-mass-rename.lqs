// Dragnet [Ransomware]: dragnet-ransomware-2021-1601 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 9b043385-873d-5624-8faa-52f7502f10a6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
