// Dragnet [Ransomware]: dragnet-ransomware-2023-2388 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 30ae5cdb-ffac-51ad-971a-2c44c17e7dd8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
