// Dragnet [Ransomware]: dragnet-ransomware-2025-6277 — Mass File Rename (securotrop)
// Status: experimental | Level: high | ID: 3526b5c1-deac-5f2b-bb5e-a801cfe77e6d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
