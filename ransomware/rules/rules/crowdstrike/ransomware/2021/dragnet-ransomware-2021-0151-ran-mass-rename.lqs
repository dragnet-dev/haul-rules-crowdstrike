// Dragnet [Ransomware]: dragnet-ransomware-2021-0151 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: baa09b41-239e-5f0b-aa1d-c02275e8aaff

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
