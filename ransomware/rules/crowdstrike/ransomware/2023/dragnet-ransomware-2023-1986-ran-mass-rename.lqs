// Dragnet [Ransomware]: dragnet-ransomware-2023-1986 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 18ae7fdd-da5b-5449-9a89-6ecfcd60af18

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
