// Dragnet [Ransomware]: dragnet-ransomware-2022-2654 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 1ab53c2b-c2bf-567a-893c-596a620b9378

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
