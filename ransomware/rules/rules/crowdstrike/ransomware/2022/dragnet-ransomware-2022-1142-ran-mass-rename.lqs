// Dragnet [Ransomware]: dragnet-ransomware-2022-1142 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 1179c138-5a2e-5cdb-99d1-c3ca05e669f9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
