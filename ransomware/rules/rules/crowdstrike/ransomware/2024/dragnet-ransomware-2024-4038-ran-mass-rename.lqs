// Dragnet [Ransomware]: dragnet-ransomware-2024-4038 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 5ecc408c-5621-5d8f-9910-c84aa6261605

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
