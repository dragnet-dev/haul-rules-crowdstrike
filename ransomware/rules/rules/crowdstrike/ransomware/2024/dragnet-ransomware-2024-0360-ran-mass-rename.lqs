// Dragnet [Ransomware]: dragnet-ransomware-2024-0360 — Mass File Rename (arcusmedia)
// Status: experimental | Level: high | ID: 3c4d7641-46f6-550f-8079-9724c990341f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
