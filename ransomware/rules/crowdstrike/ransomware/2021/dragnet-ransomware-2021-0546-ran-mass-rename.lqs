// Dragnet [Ransomware]: dragnet-ransomware-2021-0546 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 2dad42d4-fcd4-57dd-be79-552c08592d40

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
