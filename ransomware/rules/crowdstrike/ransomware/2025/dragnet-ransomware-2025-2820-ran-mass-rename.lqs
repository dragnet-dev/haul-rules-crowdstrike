// Dragnet [Ransomware]: dragnet-ransomware-2025-2820 — Mass File Rename (coinbasecartel)
// Status: experimental | Level: high | ID: e8358636-56d0-5f3e-aa26-66598b250717

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
