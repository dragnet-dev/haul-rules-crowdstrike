// Dragnet [Ransomware]: dragnet-ransomware-2022-1883 — Mass File Rename (ransomhouse)
// Status: deprecated | Level: high | ID: f0a1bbc5-873f-59e7-80bb-fca9a5ba8852

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
