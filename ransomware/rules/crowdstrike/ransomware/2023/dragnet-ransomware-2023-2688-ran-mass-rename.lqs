// Dragnet [Ransomware]: dragnet-ransomware-2023-2688 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: d5d8df9d-e6f1-5151-8be2-d08d32b0c57a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
