// Dragnet [Ransomware]: dragnet-ransomware-2025-1253 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 61fbea18-3dc2-5c6e-818c-27d7a4173269

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
