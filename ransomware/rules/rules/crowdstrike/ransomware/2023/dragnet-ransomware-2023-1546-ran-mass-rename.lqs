// Dragnet [Ransomware]: dragnet-ransomware-2023-1546 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: e7830cd0-3ef4-5fa6-969d-af44af873163

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
