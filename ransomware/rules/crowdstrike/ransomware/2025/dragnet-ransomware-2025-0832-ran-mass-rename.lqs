// Dragnet [Ransomware]: dragnet-ransomware-2025-0832 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: aae99cb3-312f-5c5a-aae8-771a75500b0c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
