// Dragnet [Ransomware]: dragnet-ransomware-2020-0070 — Mass File Rename (ragnarlocker)
// Status: deprecated | Level: high | ID: e88d26d3-7b62-5639-ab48-1c6ab9b635b6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
