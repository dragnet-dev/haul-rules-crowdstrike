// Dragnet [Ransomware]: dragnet-ransomware-2024-4878 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: f6d08f44-9d9c-5842-a46a-bca1bf796f87

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
