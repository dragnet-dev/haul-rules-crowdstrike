// Dragnet [Ransomware]: dragnet-ransomware-2026-3292 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 9818bf70-f71b-5153-b2a4-01d9f1768eea

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
