// Dragnet [Ransomware]: dragnet-ransomware-2024-1441 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 11a0f0c8-68e3-5674-83d6-b97b5bdfa538

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
