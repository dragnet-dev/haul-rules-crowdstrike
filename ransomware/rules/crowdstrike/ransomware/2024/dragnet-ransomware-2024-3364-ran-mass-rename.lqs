// Dragnet [Ransomware]: dragnet-ransomware-2024-3364 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 6a3ac37c-3354-51ef-abb1-4444171957dd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
