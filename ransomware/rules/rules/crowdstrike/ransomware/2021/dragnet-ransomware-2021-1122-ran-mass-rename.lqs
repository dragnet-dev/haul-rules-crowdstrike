// Dragnet [Ransomware]: dragnet-ransomware-2021-1122 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: e545366b-166d-5f64-a69b-1c6c5555816b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
