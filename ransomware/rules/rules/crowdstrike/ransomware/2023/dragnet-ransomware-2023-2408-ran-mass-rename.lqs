// Dragnet [Ransomware]: dragnet-ransomware-2023-2408 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: c022aa75-acff-5342-a5e1-c6858617e9f7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
