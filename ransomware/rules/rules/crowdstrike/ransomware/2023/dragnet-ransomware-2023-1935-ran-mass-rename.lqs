// Dragnet [Ransomware]: dragnet-ransomware-2023-1935 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 69683b3d-bf1e-5c28-9e9e-0f724d1d64ac

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
