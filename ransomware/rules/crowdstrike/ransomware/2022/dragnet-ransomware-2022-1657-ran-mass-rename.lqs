// Dragnet [Ransomware]: dragnet-ransomware-2022-1657 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: dedce273-8ebe-5908-a536-ee23a8fe4b0d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
