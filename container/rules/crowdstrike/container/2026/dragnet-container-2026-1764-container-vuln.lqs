// Dragnet [Container]: dragnet-container-2026-1764 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 266fa469-46a0-5417-ac15-60ec517e0f84

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
