// Dragnet [Ransomware]: dragnet-ransomware-2025-4402 — Mass File Rename (abyss)
// Status: deprecated | Level: high | ID: a6fcb6e3-33af-5db1-8d65-bff769bf1422

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
