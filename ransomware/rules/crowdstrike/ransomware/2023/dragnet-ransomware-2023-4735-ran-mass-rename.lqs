// Dragnet [Ransomware]: dragnet-ransomware-2023-4735 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: f29ece56-229d-51fe-ab4a-06f38e6a7b30

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
