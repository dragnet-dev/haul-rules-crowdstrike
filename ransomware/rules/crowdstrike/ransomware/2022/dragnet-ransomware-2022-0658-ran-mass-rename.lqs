// Dragnet [Ransomware]: dragnet-ransomware-2022-0658 — Mass File Rename (yanluowang)
// Status: deprecated | Level: high | ID: 1dc76d5b-c695-5e3b-af99-3b1fde6bd444

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
