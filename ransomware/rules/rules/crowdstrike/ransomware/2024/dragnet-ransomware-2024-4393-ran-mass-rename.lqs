// Dragnet [Ransomware]: dragnet-ransomware-2024-4393 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 53b0d6e1-ac13-516b-84aa-dfe2a5cf05bd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
