// Dragnet [Container]: dragnet-container-2026-3155 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 8fea303b-77f4-59e1-8b1a-76b99c88e934

#event_simpleName=*
| (ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10*)
| table([timestamp, ComputerName])
| limit(1000)
