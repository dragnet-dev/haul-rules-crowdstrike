// Dragnet [Container]: dragnet-container-2026-3071 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 470040c9-6049-5af1-851f-8e3d07bd1b6f

#event_simpleName=*
| (ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:14.04* OR ImageFileName = *ubuntu:14.10*)
| table([timestamp, ComputerName])
| limit(1000)
