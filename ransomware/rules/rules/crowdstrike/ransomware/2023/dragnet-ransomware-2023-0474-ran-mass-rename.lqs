// Dragnet [Ransomware]: dragnet-ransomware-2023-0474 — Mass File Rename (snatch)
// Status: experimental | Level: high | ID: ae6da245-88e2-5a5d-9d46-9737c023d861

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
