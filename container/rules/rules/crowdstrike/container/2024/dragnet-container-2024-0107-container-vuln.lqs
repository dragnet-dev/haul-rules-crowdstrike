| (ImageFileName = *alpine:3.14* OR ImageFileName = *alpine:3.15* OR ImageFileName = *alpine:3.16* OR ImageFileName = *alpine:3.17* OR ImageFileName = *alpine:3.18* OR ImageFileName = *alpine:3.19* OR ImageFileName = *alpine:3.20* OR ImageFileName = *alpine:3.21* OR ImageFileName = *alpine:3.22* OR ImageFileName = *alpine:3.23* OR ImageFileName = *alpine edge:*)
| table([timestamp, ComputerName])
| limit(1000)
