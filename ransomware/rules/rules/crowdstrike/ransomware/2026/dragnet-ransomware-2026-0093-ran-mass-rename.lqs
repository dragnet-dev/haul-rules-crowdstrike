// Dragnet [Ransomware]: dragnet-ransomware-2026-0093 — Mass File Rename (interlock)
// Status: test | Level: high | ID: e80c22e0-0cbc-502b-a65b-adc7c528a5cb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
