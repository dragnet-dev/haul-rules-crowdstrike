// Dragnet [Ransomware]: dragnet-ransomware-2023-1899 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: 8d69a49f-57bd-529d-9a18-e88faa299e73

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
