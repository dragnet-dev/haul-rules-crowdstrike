// Dragnet [Ransomware]: dragnet-ransomware-2025-3777 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: b8eb0d90-33c8-5c91-ae10-110b728552c2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
