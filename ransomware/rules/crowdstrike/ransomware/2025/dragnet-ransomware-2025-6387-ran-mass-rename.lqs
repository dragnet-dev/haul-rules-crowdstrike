// Dragnet [Ransomware]: dragnet-ransomware-2025-6387 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: a525d56d-8ab8-5b6e-9d1e-f3f7ce5acf1d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
