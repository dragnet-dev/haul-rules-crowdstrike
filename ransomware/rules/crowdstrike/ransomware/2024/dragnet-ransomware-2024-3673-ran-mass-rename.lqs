// Dragnet [Ransomware]: dragnet-ransomware-2024-3673 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: f0dff262-a768-5992-8088-a01b20b8bbef

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
