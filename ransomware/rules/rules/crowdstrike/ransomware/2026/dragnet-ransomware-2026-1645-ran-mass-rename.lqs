// Dragnet [Ransomware]: dragnet-ransomware-2026-1645 — Mass File Rename (tridentlocker)
// Status: stable | Level: high | ID: 5d42476c-e546-5830-b805-fc9d4a55618f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
