// Dragnet [Ransomware]: dragnet-ransomware-2024-3339 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: 9c7e9116-a3c9-5ad5-b45c-9c54b00f5771

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
