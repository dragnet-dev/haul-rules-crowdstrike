// Dragnet [Ransomware]: dragnet-ransomware-2025-7152 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 3e9f477e-7142-50d4-a97f-cb0b15b46aa4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
