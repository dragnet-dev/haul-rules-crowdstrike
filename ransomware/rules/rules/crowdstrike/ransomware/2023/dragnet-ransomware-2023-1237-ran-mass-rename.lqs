// Dragnet [Ransomware]: dragnet-ransomware-2023-1237 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 8dfde19d-b466-58e2-a494-0bf5d87b1c3d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
