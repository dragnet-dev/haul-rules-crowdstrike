// Dragnet [Ransomware]: dragnet-ransomware-2025-4249 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: 86de097c-21f5-5f05-8ce3-b732d620e5df

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
