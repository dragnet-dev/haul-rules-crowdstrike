// Dragnet [Ransomware]: dragnet-ransomware-2024-3293 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: e22108cd-bc71-5e42-9032-0833f452e03d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
