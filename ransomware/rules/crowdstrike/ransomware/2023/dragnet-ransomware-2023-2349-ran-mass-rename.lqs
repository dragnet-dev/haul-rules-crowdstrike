// Dragnet [Ransomware]: dragnet-ransomware-2023-2349 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: bc2b6d70-a0c3-5c65-84a3-080b4259f8e4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
