// Dragnet [Ransomware]: dragnet-ransomware-2024-5563 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 92c84ee4-bd9a-5d49-873b-1af0660674aa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
