// Dragnet [Ransomware]: dragnet-ransomware-2026-3364 — Mass File Rename (dragonforce)
// Status: stable | Level: high | ID: a37a8868-693c-55db-8c4f-2595012383d2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
