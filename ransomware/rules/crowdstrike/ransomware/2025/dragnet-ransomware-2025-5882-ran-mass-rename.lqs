// Dragnet [Ransomware]: dragnet-ransomware-2025-5882 — Mass File Rename (BrainCipher)
// Status: experimental | Level: high | ID: ecc75218-d719-5438-a88d-b93c20c2264b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
