// Dragnet [Container]: dragnet-container-2024-0641 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: f52d16b9-a698-5e0d-9f51-3000eb22cae3

#event_simpleName=*
| (ImageFileName = *amazonlinux:1* OR ImageFileName = *amazonlinux:2* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:18.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
