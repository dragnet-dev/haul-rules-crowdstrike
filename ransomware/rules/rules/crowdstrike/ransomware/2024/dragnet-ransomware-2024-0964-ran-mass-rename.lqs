// Dragnet [Ransomware]: dragnet-ransomware-2024-0964 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 3d9ffc15-186d-5cec-96bd-9712426036e0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
