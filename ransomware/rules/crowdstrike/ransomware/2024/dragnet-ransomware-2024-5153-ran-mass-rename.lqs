// Dragnet [Ransomware]: dragnet-ransomware-2024-5153 — Mass File Rename (SilentRansomGroup)
// Status: deprecated | Level: high | ID: f92c783e-38ef-5157-a33a-164e5a7923bc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
