// Dragnet [Ransomware]: dragnet-ransomware-2025-5985 — Mass File Rename (termite)
// Status: experimental | Level: high | ID: f268e5fb-bf50-5e7a-8af1-c62ccaf2d0fc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
