// Dragnet [Ransomware]: dragnet-ransomware-2022-2941 — Mass File Rename (mindware)
// Status: deprecated | Level: high | ID: 21f856c5-2147-5021-a999-89c56ce4f886

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
