// Dragnet [Ransomware]: dragnet-ransomware-2025-1697 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 7d90c10d-bc98-5b60-93f0-f0072e6e7826

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
