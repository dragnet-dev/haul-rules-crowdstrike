// Dragnet [Ransomware]: dragnet-ransomware-2021-1487 — Mass File Rename (spook)
// Status: deprecated | Level: high | ID: 2d611c3d-7c30-5a09-9452-ba6ab94d6d1a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
