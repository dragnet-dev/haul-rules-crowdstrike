// Dragnet [Ransomware]: dragnet-ransomware-2026-1549 — Mass File Rename (incransom)
// Status: test | Level: high | ID: aff9fd46-0ac2-5bb9-9bda-64ca229c5ea8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
