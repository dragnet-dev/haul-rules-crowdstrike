// Dragnet [Ransomware]: dragnet-ransomware-2025-4199 — Mass File Rename (incransom)
// Status: test | Level: high | ID: c5fb6143-94d4-59bf-8930-6358da4a62d3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
