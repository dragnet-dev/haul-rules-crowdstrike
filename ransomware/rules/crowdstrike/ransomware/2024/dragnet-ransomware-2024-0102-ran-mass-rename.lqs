// Dragnet [Ransomware]: dragnet-ransomware-2024-0102 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 656f10d7-98fb-55c2-a20f-3481e8c41293

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
