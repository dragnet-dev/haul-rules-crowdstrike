// Dragnet [Container]: dragnet-container-2024-0691 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 2dec5180-ecf5-5fbb-aa98-cd3daad59f99

#event_simpleName=*
| (ImageFileName = *chainguard:* OR ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *redhat/ubi9:*)
| table([timestamp, ComputerName])
| limit(1000)
