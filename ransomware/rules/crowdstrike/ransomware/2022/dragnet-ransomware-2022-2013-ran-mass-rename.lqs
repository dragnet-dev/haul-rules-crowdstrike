// Dragnet [Ransomware]: dragnet-ransomware-2022-2013 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 1953b7ef-3eb2-5520-8bd9-09e0a8ffda69

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
