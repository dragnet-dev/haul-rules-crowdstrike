// Dragnet [Ransomware]: dragnet-ransomware-2022-2712 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: d5c9fafc-241b-55c7-9bae-daac942a2403

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
