// Dragnet [Ransomware]: dragnet-ransomware-2026-3282 — Mass File Rename (krybit)
// Status: stable | Level: high | ID: 7b78f015-50a0-5358-8dc9-e3a598239aa5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
