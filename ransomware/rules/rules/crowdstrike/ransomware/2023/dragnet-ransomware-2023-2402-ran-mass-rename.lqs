// Dragnet [Ransomware]: dragnet-ransomware-2023-2402 — Mass File Rename (nokoyawa)
// Status: experimental | Level: high | ID: 8917f2e9-4a1c-5325-b7f4-22d4248c0c37

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
