// Dragnet [Ransomware]: dragnet-ransomware-2025-5276 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 8a1c1878-4769-5525-8fc8-c3fa990532e0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
