// Dragnet [Ransomware]: dragnet-ransomware-2025-1695 — Mass File Rename (tridentlocker)
// Status: test | Level: high | ID: d979039b-e1c1-5841-a9c2-402f59f32fb7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
