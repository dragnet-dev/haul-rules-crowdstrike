// Dragnet [Ransomware]: dragnet-ransomware-2024-0977 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 48215f92-381d-52f4-8d31-8a82e5f27835

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
