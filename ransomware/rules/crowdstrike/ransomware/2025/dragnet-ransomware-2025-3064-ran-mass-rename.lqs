// Dragnet [Ransomware]: dragnet-ransomware-2025-3064 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: a7f3faca-2973-51cc-83e1-62eafbb06c17

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
