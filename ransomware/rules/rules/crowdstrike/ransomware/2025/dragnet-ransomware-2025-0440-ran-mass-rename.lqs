// Dragnet [Ransomware]: dragnet-ransomware-2025-0440 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 43d7cd53-1cc9-555f-ae29-99b04bbc2991

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
