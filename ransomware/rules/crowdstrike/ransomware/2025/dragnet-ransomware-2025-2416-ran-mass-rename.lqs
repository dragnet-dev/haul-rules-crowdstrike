// Dragnet [Ransomware]: dragnet-ransomware-2025-2416 — Mass File Rename (thegentlemen)
// Status: experimental | Level: high | ID: 3e51c0f0-d03f-54fb-bdc2-9e20b931c0f4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
