// Dragnet [Ransomware]: dragnet-ransomware-2024-1122 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: 12cedbd2-2396-5810-a4b1-f11a576f0e74

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
