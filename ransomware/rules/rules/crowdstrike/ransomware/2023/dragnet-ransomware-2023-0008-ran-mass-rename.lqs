// Dragnet [Ransomware]: dragnet-ransomware-2023-0008 — Mass File Rename (noescape)
// Status: experimental | Level: high | ID: e31f4d54-5ce4-5767-b32b-99ad8514f7d3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
