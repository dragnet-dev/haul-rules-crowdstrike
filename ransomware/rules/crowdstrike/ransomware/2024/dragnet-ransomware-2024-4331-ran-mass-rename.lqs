// Dragnet [Ransomware]: dragnet-ransomware-2024-4331 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 0291b289-d19d-599a-b989-97b111d078d9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
