// Dragnet [Ransomware]: dragnet-ransomware-2022-1771 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 5c15fefa-4e88-5039-b387-53df71b521eb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
