// Dragnet [Ransomware]: dragnet-ransomware-2024-3738 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: cb6e50b5-3604-5b60-844e-66c9ed499c67

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
