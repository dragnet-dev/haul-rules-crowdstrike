// Dragnet [Ransomware]: dragnet-ransomware-2020-0223 — Mass File Rename (suncrypt)
// Status: deprecated | Level: high | ID: c4df6fe7-4335-56e3-b5d4-7e72f61199e7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
