// Dragnet [Ransomware]: dragnet-ransomware-2023-4571 — Mass File Rename (snatch)
// Status: experimental | Level: high | ID: 2360c806-f4b9-5e14-97ca-6cce05e165f2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
