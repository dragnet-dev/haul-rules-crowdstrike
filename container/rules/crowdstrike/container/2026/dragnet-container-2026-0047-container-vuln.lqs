// Dragnet [Container]: dragnet-container-2026-0047 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 7a91dec9-7f30-5371-ac23-b596e9aa70ee

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:7* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:14.04* OR ImageFileName = *ubuntu:14.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
