// Dragnet [Ransomware]: dragnet-ransomware-2024-2893 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 384939c6-0cb4-5437-b8ee-01af884ce05c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
