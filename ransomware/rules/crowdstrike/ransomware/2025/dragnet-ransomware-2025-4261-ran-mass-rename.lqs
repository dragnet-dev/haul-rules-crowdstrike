// Dragnet [Ransomware]: dragnet-ransomware-2025-4261 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: c6d61940-17da-5cba-8c3f-c90646b3cc24

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
