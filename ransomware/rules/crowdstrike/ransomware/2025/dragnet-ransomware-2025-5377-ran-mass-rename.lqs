// Dragnet [Ransomware]: dragnet-ransomware-2025-5377 — Mass File Rename (trinity)
// Status: experimental | Level: high | ID: b3577e99-42a2-5ce1-af13-33745a4e2cc7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
