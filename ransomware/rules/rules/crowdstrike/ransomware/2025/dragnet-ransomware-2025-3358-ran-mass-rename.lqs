// Dragnet [Ransomware]: dragnet-ransomware-2025-3358 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: ffe3e49a-4a8b-5425-9d58-28d556d68984

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
