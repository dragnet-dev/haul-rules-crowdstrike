// Dragnet [Ransomware]: dragnet-ransomware-2025-5296 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 50a558b3-b217-5e6c-be0a-da3d09103123

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
