// Dragnet [Ransomware]: dragnet-ransomware-2025-3740 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: c5aef532-17fd-526e-9114-1b67977d7f54

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
