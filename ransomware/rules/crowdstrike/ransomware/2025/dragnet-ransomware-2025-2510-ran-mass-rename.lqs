// Dragnet [Ransomware]: dragnet-ransomware-2025-2510 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: ef959b46-9b5c-5162-931e-4f4e6d82c3cb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
