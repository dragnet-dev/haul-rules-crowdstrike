// Dragnet [Ransomware]: dragnet-ransomware-2024-1911 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: d0eb5032-fe89-514c-b50c-cbba1fb94f93

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
