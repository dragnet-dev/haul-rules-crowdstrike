// Dragnet [Ransomware]: dragnet-ransomware-2022-0677 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 333cecce-2602-51f8-861e-cd38afa7851d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
