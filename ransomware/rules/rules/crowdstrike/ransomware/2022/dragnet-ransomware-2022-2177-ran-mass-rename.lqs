// Dragnet [Ransomware]: dragnet-ransomware-2022-2177 — Mass File Rename (cuba)
// Status: deprecated | Level: high | ID: 180e4bef-7fbc-5e1f-ac94-2d1d95f108b2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
