// Dragnet [Ransomware]: dragnet-ransomware-2021-0157 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 4402d86a-50c0-5d19-bee6-b4768f140ed3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
