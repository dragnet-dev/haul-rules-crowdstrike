// Dragnet [Ransomware]: dragnet-ransomware-2022-2739 — Mass File Rename (stormous)
// Status: deprecated | Level: high | ID: e818531c-a2e7-554c-8474-15821801899d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
