// Dragnet [Ransomware]: dragnet-ransomware-2023-0974 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 5bd00452-2daa-52af-8bf8-64dbb1e16336

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
