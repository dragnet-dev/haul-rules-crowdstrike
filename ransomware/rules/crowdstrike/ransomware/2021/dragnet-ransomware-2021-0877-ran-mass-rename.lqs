// Dragnet [Ransomware]: dragnet-ransomware-2021-0877 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: ae7d9c8f-e578-5925-86e8-80db53c1fc7f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
