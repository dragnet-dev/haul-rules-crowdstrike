// Dragnet [Ransomware]: dragnet-ransomware-2023-1478 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 4cd79a23-b47e-539c-800b-404c9f9aac2a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
