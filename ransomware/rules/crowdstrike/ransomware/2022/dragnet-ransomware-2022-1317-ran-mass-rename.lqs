// Dragnet [Ransomware]: dragnet-ransomware-2022-1317 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 8943ed0e-953d-598d-af76-03d74c23df8e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
