// Dragnet [Ransomware]: dragnet-ransomware-2026-3453 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: d3980edc-8e34-54e8-8ad9-49d33f1dc7c8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
