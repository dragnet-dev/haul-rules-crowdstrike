// Dragnet [Ransomware]: dragnet-ransomware-2024-3450 — Mass File Rename (qiulong)
// Status: experimental | Level: high | ID: def4ded1-d998-5d6c-89eb-ed6323d80235

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
