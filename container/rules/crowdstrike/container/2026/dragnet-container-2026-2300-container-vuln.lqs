// Dragnet [Container]: dragnet-container-2026-2300 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 5dafcbdc-e968-5a16-b502-70b1313dea99

#event_simpleName=*
| (ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *redhat/ubi9:*)
| table([timestamp, ComputerName])
| limit(1000)
