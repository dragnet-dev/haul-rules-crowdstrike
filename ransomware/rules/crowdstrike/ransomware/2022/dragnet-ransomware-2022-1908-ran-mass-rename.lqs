// Dragnet [Ransomware]: dragnet-ransomware-2022-1908 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 3de2178d-c0e7-566a-90dd-0ccc2f89895c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
