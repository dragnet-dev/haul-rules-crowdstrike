// Dragnet [Ransomware]: dragnet-ransomware-2025-7091 — Mass File Rename (devman)
// Status: experimental | Level: high | ID: f3fbe64d-ba3b-5375-8a3d-eb48ca20eeab

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
