// Dragnet [Ransomware]: dragnet-ransomware-2024-2656 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 137c9681-01a9-5be2-af4b-37525b6c2a5d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
