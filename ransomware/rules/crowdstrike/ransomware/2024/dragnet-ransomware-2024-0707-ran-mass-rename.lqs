// Dragnet [Ransomware]: dragnet-ransomware-2024-0707 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: fce198dd-fcc1-58cc-9860-8541cf4f7409

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
