// Dragnet [Ransomware]: dragnet-ransomware-2025-7462 — Mass File Rename (sinobi)
// Status: experimental | Level: high | ID: 2d180925-6aff-5077-b0dd-ac36c32f5d6f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
