// Dragnet [Ransomware]: dragnet-ransomware-2024-2542 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: 2344bf56-96d2-5c3f-9336-a3223b29db94

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
