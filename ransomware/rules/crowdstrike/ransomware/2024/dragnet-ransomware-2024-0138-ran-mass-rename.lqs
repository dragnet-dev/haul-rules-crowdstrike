// Dragnet [Ransomware]: dragnet-ransomware-2024-0138 — Mass File Rename (stormous)
// Status: deprecated | Level: high | ID: c1181989-f23d-5991-9f62-2c4cb4d2edfa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
