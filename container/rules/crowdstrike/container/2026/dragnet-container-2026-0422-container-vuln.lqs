// Dragnet [Container]: dragnet-container-2026-0422 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: ffec6330-6dda-5756-b73b-0b9086944c16

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:7*)
| table([timestamp, ComputerName])
| limit(1000)
