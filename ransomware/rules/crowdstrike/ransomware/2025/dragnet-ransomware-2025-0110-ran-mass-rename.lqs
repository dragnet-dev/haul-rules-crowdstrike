// Dragnet [Ransomware]: dragnet-ransomware-2025-0110 — Mass File Rename (securotrop)
// Status: experimental | Level: high | ID: 84509ce2-49fd-5cb8-aedc-f0ae14e0f9cf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
