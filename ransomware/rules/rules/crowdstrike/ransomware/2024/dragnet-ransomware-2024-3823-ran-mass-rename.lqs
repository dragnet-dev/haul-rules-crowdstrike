// Dragnet [Ransomware]: dragnet-ransomware-2024-3823 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 5b8d1e37-c0b1-58e2-b148-e34a1bfb43ba

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
