// Dragnet [Ransomware]: dragnet-ransomware-2025-0247 — Mass File Rename (stormous)
// Status: experimental | Level: high | ID: 96ff28c2-e9a1-5fad-89f3-1dbf56f06071

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
