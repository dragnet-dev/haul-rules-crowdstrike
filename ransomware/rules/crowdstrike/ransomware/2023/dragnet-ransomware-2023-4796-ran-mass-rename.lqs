// Dragnet [Ransomware]: dragnet-ransomware-2023-4796 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 522f1e3e-6485-54ec-8766-ced3943039b8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
