// Dragnet [Ransomware]: dragnet-ransomware-2022-2657 — Mass File Rename (quantum)
// Status: deprecated | Level: high | ID: 38ebd3a8-10c4-5371-a7b3-9f79ad1d9202

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
