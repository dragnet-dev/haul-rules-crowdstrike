// Dragnet [Ransomware]: dragnet-ransomware-2026-0277 — Mass File Rename (lockbit5)
// Status: stable | Level: high | ID: 24928eb1-cf2f-5eee-8924-300b77909de9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
