// Dragnet [Ransomware]: dragnet-ransomware-2026-2502 — Mass File Rename (termite)
// Status: stable | Level: high | ID: 59dd3ec5-ba61-5de4-ab15-4005f01fdbe2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
