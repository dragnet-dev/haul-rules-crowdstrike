// Dragnet [Ransomware]: dragnet-ransomware-2025-4620 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: ef4103dc-f9e2-528e-94b1-fcd8fb319529

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
