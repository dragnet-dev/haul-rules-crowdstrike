// Dragnet [Ransomware]: dragnet-ransomware-2025-7680 — Mass File Rename (blackshrantac)
// Status: test | Level: high | ID: b0b3f3f5-cafd-5ef8-b68a-472510fd0866

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
