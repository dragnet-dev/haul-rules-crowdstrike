// Dragnet [Ransomware]: dragnet-ransomware-2025-6829 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 33f5dd51-c7db-5030-984f-e098cc56863c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
