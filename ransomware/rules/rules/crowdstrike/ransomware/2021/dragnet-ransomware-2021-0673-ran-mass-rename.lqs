// Dragnet [Ransomware]: dragnet-ransomware-2021-0673 — Mass File Rename (revil)
// Status: deprecated | Level: high | ID: d9f21a9c-02e5-5512-bc0f-1d4c3dd0a60a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
