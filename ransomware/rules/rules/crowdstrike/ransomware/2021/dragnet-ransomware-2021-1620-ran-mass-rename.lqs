// Dragnet [Ransomware]: dragnet-ransomware-2021-1620 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 47751ece-83a8-5635-84a7-310a11a791c3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
