// Dragnet [Ransomware]: dragnet-ransomware-2022-1035 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 5e6a93e4-4761-5362-b29d-f3cae6fd89cc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
