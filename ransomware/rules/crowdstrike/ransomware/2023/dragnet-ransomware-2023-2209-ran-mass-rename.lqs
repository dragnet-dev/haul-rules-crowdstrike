// Dragnet [Ransomware]: dragnet-ransomware-2023-2209 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: d86047bc-38ea-55a3-8bc7-a3d07576ef3c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
