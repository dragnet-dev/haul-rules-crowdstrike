// Dragnet [Ransomware]: dragnet-ransomware-2025-7469 — Mass File Rename (handala)
// Status: experimental | Level: high | ID: ae1c2473-9f54-5d8e-a429-5067dc2fb3f7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
