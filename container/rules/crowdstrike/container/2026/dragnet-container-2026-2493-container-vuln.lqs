// Dragnet [Container]: dragnet-container-2026-2493 — Vulnerable Base Image Pull
// Status: deprecated | Level: medium | ID: 0ca4a474-2ca4-5487-a6ad-dff057c09e10

#event_simpleName=*
| (ImageFileName = *chainguard:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
