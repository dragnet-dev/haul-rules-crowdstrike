// Dragnet [Ransomware]: dragnet-ransomware-2025-1610 — Mass File Rename (blacklock)
// Status: experimental | Level: high | ID: 5e47df57-d646-5767-b14c-1aed6805d3c9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
