// Dragnet [Ransomware]: dragnet-ransomware-2022-0223 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: a68ad8ea-7975-5e59-b082-982e2ed720b5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
