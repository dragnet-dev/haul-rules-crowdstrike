// Dragnet [Ransomware]: dragnet-ransomware-2025-0554 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 95fe80ff-1ba1-50c6-af85-b2cbefe32c56

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
