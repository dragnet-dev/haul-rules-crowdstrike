// Dragnet [Ransomware]: dragnet-ransomware-2025-3291 — Mass File Rename (datacarry)
// Status: deprecated | Level: high | ID: 99c31a96-799f-5155-b811-60239e430ed4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
