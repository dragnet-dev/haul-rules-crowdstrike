// Dragnet [Ransomware]: dragnet-ransomware-2026-0101 — Mass File Rename (fulcrumsec)
// Status: stable | Level: high | ID: 9f3825d6-fb29-5b2d-a10e-b27a3500c829

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
