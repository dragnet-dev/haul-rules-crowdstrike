// Dragnet [Ransomware]: dragnet-ransomware-2025-0762 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 15492759-5acd-526a-b4f6-68066dc932cb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
