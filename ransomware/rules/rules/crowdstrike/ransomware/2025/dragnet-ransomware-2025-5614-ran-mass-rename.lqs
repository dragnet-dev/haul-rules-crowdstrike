// Dragnet [Ransomware]: dragnet-ransomware-2025-5614 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 924e7d0c-5dd8-597a-bd16-4e1d77b77944

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
