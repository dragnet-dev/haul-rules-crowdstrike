// Dragnet [Ransomware]: dragnet-ransomware-2023-2413 — Mass File Rename (toufan)
// Status: deprecated | Level: high | ID: bd14c4cf-d0bc-56e1-aa5a-92b214e71d51

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
