// Dragnet [Ransomware]: dragnet-ransomware-2025-6959 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: fba5e441-be8f-57e4-8012-06353c5c185f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
