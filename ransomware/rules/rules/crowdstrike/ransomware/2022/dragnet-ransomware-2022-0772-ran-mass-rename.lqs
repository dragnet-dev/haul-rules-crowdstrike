// Dragnet [Ransomware]: dragnet-ransomware-2022-0772 — Mass File Rename (everest)
// Status: deprecated | Level: high | ID: d759d670-9282-50b6-b8ba-a52cdc4ca640

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
