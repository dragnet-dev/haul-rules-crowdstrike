// Dragnet [Ransomware]: dragnet-ransomware-2024-2800 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: 39037f18-3570-5259-b9ca-108d46cf21ae

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
