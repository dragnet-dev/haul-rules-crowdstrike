// Dragnet [Ransomware]: dragnet-ransomware-2022-0667 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 1603632e-c62b-510d-9f31-8b0d5fec93c2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
