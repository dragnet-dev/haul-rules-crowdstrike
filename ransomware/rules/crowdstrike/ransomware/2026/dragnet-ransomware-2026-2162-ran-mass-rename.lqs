// Dragnet [Ransomware]: dragnet-ransomware-2026-2162 — Mass File Rename (incransom)
// Status: stable | Level: high | ID: e3ee817a-37d9-50fc-b7a5-7a47e1170b91

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
