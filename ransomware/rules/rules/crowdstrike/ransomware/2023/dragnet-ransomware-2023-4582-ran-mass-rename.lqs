// Dragnet [Ransomware]: dragnet-ransomware-2023-4582 — Mass File Rename (cloak)
// Status: deprecated | Level: high | ID: c3dcd51e-92dd-5767-858f-e06959065360

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
