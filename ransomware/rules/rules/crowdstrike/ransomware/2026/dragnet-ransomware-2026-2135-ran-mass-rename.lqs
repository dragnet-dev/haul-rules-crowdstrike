// Dragnet [Ransomware]: dragnet-ransomware-2026-2135 — Mass File Rename (incransom)
// Status: stable | Level: high | ID: 8fa36d0a-16ca-5ccb-b199-d5d1c2838931

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
