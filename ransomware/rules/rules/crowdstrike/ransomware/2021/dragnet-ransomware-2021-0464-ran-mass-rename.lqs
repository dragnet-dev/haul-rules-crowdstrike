// Dragnet [Ransomware]: dragnet-ransomware-2021-0464 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: db0abcb2-3765-5a2e-8aca-4e1b2667e8c2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
