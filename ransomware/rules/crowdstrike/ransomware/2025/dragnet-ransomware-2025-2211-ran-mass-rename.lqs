// Dragnet [Ransomware]: dragnet-ransomware-2025-2211 — Mass File Rename (worldleaks)
// Status: experimental | Level: high | ID: a908a4c6-6ca0-5442-b03b-71a69e065c54

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
