// Dragnet [Ransomware]: dragnet-ransomware-2021-0692 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 08a88971-4035-5d15-aa11-d4c5ff239fe0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
