// Dragnet [Container]: dragnet-container-2026-0381 — Vulnerable Base Image Pull
// Status: deprecated | Level: medium | ID: 1c0bd9a4-da9f-505e-a599-02780202eecc

#event_simpleName=*
| (ImageFileName = *chainguard:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *redhat/ubi9:*)
| table([timestamp, ComputerName])
| limit(1000)
