// Dragnet [Ransomware]: dragnet-ransomware-2021-0247 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 83e2ad05-f27e-55ca-b02a-d234ba45049b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
