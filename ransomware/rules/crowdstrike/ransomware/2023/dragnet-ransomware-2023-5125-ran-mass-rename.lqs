// Dragnet [Ransomware]: dragnet-ransomware-2023-5125 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 674daade-91b3-58fc-9b13-19f2b158d828

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
