// Dragnet [Ransomware]: dragnet-ransomware-2024-5778 — Mass File Rename (abyss)
// Status: deprecated | Level: high | ID: d42d7d67-eef0-5d4a-b39f-e16e96c44e6b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
