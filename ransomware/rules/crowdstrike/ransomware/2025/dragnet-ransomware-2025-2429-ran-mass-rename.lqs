// Dragnet [Ransomware]: dragnet-ransomware-2025-2429 — Mass File Rename (thegentlemen)
// Status: experimental | Level: high | ID: 81857aee-0732-5a50-a4a3-e4a9576bfc25

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
