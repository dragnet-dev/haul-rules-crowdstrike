// Dragnet [Ransomware]: dragnet-ransomware-2025-3018 — Mass File Rename (beast)
// Status: experimental | Level: high | ID: c3e77e2b-1dad-5a0c-85b0-cd02e2af8f9c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
