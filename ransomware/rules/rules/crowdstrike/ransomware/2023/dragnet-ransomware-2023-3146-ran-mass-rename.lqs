// Dragnet [Ransomware]: dragnet-ransomware-2023-3146 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 8c72d9ad-7884-51dd-9ff8-4beb2781f34f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
