// Dragnet [Container]: dragnet-container-2026-2328 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 8150f83f-480a-57af-8614-166a174ba822

#event_simpleName=*
| (ImageFileName = *chainguard:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
