// Dragnet [Ransomware]: dragnet-ransomware-2025-3507 — Mass File Rename (direwolf)
// Status: experimental | Level: high | ID: 1460ff0f-d8c9-515a-8209-0b28a297df04

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
