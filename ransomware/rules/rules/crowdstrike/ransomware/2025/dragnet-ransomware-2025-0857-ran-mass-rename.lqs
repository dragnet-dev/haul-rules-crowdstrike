// Dragnet [Ransomware]: dragnet-ransomware-2025-0857 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: e8a3d889-72fc-5631-8ecf-60cad02e50a4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
