// Dragnet [Container]: dragnet-container-2024-1010 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 348abb1a-ac65-5892-ab83-54996f998684

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *ubuntu:20.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
