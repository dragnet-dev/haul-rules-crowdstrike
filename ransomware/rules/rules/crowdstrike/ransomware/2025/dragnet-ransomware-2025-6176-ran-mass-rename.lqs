// Dragnet [Ransomware]: dragnet-ransomware-2025-6176 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 6e66fca2-6331-583f-bb69-a7f1a3eea89c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
