// Dragnet [Ransomware]: dragnet-ransomware-2023-3535 — Mass File Rename (siegedsec)
// Status: experimental | Level: high | ID: 4be81110-a703-550e-a137-cf96bdbec841

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
