// Dragnet [Ransomware]: dragnet-ransomware-2025-7219 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 01d15e6a-6652-54dc-b6a9-8a50311ba655

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
