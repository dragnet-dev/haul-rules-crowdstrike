// Dragnet [Ransomware]: dragnet-ransomware-2025-2623 — Mass File Rename (kairos)
// Status: experimental | Level: high | ID: 549d94ab-82d4-526c-9fae-0d516d386e6b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
