// Dragnet [Ransomware]: dragnet-ransomware-2024-1859 — Mass File Rename (handala)
// Status: experimental | Level: high | ID: eadbe32a-7d74-507d-99c9-5f0bb77e27a3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
