// Dragnet [Container]: dragnet-container-2026-0123 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 0afe783f-53df-5034-bbee-c230c1046e7d

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
