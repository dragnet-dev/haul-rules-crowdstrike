// Dragnet [Container]: dragnet-container-2026-1464 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 51f02b70-6387-5fef-b17c-e48bef53ab87

#event_simpleName=*
| (ImageFileName = *debian:7* OR ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10* OR ImageFileName = *ubuntu:13.04*)
| table([timestamp, ComputerName])
| limit(1000)
