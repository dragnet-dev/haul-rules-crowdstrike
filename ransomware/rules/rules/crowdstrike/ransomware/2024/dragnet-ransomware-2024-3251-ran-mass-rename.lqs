// Dragnet [Ransomware]: dragnet-ransomware-2024-3251 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 91bfdb98-f18d-5dfd-9ce8-41e1ab29923f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
