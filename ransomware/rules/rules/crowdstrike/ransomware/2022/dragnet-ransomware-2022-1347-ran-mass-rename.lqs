// Dragnet [Ransomware]: dragnet-ransomware-2022-1347 — Mass File Rename (pandora)
// Status: deprecated | Level: high | ID: 517695bb-2e83-51eb-80df-2b3fc9310b22

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
