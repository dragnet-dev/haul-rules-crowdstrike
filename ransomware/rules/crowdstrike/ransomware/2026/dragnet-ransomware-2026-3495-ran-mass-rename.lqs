// Dragnet [Ransomware]: dragnet-ransomware-2026-3495 — Mass File Rename (nightspire)
// Status: deprecated | Level: high | ID: d573a7e8-b6bb-55ee-8fa0-ecc9e931906c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
