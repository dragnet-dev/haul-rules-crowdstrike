// Dragnet [Ransomware]: dragnet-ransomware-2023-1461 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 4b534bb6-e933-508f-902a-db23489ebccf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
