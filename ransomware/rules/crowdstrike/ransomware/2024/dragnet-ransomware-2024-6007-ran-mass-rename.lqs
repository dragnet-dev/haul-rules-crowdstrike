// Dragnet [Ransomware]: dragnet-ransomware-2024-6007 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 5e3cc493-8da6-5ab0-bf70-c173ac773d63

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
