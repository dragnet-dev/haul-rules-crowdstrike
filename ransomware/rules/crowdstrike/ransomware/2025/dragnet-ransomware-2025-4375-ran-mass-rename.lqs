// Dragnet [Ransomware]: dragnet-ransomware-2025-4375 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: 89a60f1f-d138-5a83-8145-0aacba77dadd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
