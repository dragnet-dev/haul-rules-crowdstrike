// Dragnet [Ransomware]: dragnet-ransomware-2021-0028 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 0fbf3e7d-dfc4-580a-8da1-cb145d6dcae0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
