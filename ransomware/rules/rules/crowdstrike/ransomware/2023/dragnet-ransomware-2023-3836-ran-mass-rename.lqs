// Dragnet [Ransomware]: dragnet-ransomware-2023-3836 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 4b9f062e-6cb9-554f-9cb1-bc2a89de6eee

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
