// Dragnet [Ransomware]: dragnet-ransomware-2025-5986 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: c26dc8c7-c5ec-5c59-984d-198cb0a3c408

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
