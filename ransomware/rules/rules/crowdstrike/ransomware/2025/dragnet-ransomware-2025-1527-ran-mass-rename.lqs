// Dragnet [Ransomware]: dragnet-ransomware-2025-1527 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 89ba7afd-9647-50b2-8b57-b2606e1ee6c3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
