// Dragnet [Ransomware]: dragnet-ransomware-2024-0573 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: 3bcaacd6-9cc7-5796-93f1-996e338d345f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
