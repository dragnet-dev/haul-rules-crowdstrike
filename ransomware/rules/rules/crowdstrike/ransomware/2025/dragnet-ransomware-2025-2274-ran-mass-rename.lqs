// Dragnet [Ransomware]: dragnet-ransomware-2025-2274 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 460f164b-ac4b-5cf6-a701-71f41a0f3154

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
