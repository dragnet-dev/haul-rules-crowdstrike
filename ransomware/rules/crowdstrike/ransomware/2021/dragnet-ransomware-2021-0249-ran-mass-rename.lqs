// Dragnet [Ransomware]: dragnet-ransomware-2021-0249 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 7eaa99bf-561b-57cb-bcb3-dc4c3a25b6a1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
