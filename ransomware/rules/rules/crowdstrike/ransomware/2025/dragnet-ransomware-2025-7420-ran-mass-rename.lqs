// Dragnet [Ransomware]: dragnet-ransomware-2025-7420 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: 2ad8d0cd-885d-5f39-8c5d-e848bb66669c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
