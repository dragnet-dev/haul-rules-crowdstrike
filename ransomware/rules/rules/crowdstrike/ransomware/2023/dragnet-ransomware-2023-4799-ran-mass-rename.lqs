// Dragnet [Ransomware]: dragnet-ransomware-2023-4799 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 3606c442-872b-54f4-99e7-e69cdbba149a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
