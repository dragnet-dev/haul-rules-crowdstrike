// Dragnet [Ransomware]: dragnet-ransomware-2026-2138 — Mass File Rename (LeakBazaar)
// Status: stable | Level: high | ID: c1bd1b24-7560-5abf-9df5-4d75f2491d34

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
