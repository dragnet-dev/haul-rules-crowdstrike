// Dragnet [Ransomware]: dragnet-ransomware-2024-3575 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 894ecedc-5651-5ba6-aa4f-6bf002b693ec

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
