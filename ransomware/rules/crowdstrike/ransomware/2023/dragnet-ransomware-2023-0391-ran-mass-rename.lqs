// Dragnet [Ransomware]: dragnet-ransomware-2023-0391 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 76f5dac5-6999-5530-933e-bb074f6b2316

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
