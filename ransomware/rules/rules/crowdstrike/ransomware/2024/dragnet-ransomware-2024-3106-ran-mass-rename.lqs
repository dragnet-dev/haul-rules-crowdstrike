// Dragnet [Ransomware]: dragnet-ransomware-2024-3106 — Mass File Rename (dragonforce)
// Status: deprecated | Level: high | ID: 9fc16765-300d-5763-9d77-bb6e020d7f84

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
