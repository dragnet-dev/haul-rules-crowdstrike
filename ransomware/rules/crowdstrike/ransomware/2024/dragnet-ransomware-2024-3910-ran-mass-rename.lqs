// Dragnet [Ransomware]: dragnet-ransomware-2024-3910 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 5d85ca3b-7539-58e0-90ab-76429fb79124

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
