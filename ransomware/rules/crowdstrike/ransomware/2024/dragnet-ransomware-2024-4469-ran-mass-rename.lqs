// Dragnet [Ransomware]: dragnet-ransomware-2024-4469 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: 1d30a0dd-4230-5341-b096-1d4671f312fc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
