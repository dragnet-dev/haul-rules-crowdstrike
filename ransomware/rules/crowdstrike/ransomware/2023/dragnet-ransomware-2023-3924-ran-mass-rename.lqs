// Dragnet [Ransomware]: dragnet-ransomware-2023-3924 — Mass File Rename (play)
// Status: experimental | Level: high | ID: b6cbeef9-b3d6-561f-8e2e-0c51dd181b31

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
