// Dragnet [Ransomware]: dragnet-ransomware-2024-5453 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 1daa30b9-0c24-5864-b4b4-87e3b5f3aaaf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
