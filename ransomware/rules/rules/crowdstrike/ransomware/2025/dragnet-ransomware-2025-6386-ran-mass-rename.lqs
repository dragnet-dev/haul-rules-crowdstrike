// Dragnet [Ransomware]: dragnet-ransomware-2025-6386 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: 9148ed04-4f30-5656-85e2-97bf70eaac44

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
