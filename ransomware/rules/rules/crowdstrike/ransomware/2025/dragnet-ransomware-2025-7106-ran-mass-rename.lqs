// Dragnet [Ransomware]: dragnet-ransomware-2025-7106 — Mass File Rename (play)
// Status: experimental | Level: high | ID: fc3d3e85-45db-5872-be7b-9e5b2cedf772

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
