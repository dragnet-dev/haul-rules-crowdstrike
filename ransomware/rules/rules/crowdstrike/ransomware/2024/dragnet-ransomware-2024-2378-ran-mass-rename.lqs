// Dragnet [Ransomware]: dragnet-ransomware-2024-2378 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 6fa02182-22de-5471-ab97-ae87d2a5a2b4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
