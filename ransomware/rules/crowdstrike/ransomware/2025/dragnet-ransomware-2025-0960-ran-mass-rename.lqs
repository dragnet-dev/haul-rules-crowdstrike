// Dragnet [Ransomware]: dragnet-ransomware-2025-0960 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: f4f5e6d3-7d6d-5e6b-bb0c-432b1c5dcf93

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
