// Dragnet [Ransomware]: dragnet-ransomware-2023-5048 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 8bc44ddf-f0a5-51cc-a15f-184ce8bb7d31

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
