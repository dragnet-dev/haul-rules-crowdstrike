// Dragnet [Ransomware]: dragnet-ransomware-2026-1544 — Mass File Rename (fulcrumsec)
// Status: stable | Level: high | ID: 696995c0-d35c-5ce1-854c-c816cedbd0fa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
