// Dragnet [Ransomware]: dragnet-ransomware-2025-4454 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 5debab42-43a2-531c-90d8-3312793b7aa2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
