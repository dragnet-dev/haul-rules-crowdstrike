// Dragnet [Ransomware]: dragnet-ransomware-2025-5649 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: ed20c62e-28c6-5ace-b21d-81ee35f2e4af

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
