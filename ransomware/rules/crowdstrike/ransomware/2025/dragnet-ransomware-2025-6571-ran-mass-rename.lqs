// Dragnet [Ransomware]: dragnet-ransomware-2025-6571 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: ffd662dd-53aa-5753-b4a3-017fc733cff8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
