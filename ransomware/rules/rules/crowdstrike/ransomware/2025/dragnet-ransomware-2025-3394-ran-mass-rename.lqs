// Dragnet [Ransomware]: dragnet-ransomware-2025-3394 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 950b4018-e1d1-590f-b12a-e485b9da843d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
