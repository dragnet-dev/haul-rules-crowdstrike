// Dragnet [Ransomware]: dragnet-ransomware-2023-4010 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: bddda24c-7cd2-52e1-99a0-6ad44c60b5bb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
