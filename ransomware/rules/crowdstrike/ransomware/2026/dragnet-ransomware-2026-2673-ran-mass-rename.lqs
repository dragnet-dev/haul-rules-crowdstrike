// Dragnet [Ransomware]: dragnet-ransomware-2026-2673 — Mass File Rename (medusalocker)
// Status: stable | Level: high | ID: 9b1870e6-adab-5d3a-9659-025bdc17d0db

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
