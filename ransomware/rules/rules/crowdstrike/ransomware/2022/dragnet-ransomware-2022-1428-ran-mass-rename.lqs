// Dragnet [Ransomware]: dragnet-ransomware-2022-1428 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 2f508916-bc73-525a-ae03-485e1763c3d0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
