// Dragnet [Ransomware]: dragnet-ransomware-2025-5051 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 757cfd77-259a-556b-afa1-cfa4fef0438d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
