// Dragnet [Ransomware]: dragnet-ransomware-2022-1189 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 7c1e2238-963b-5f77-81d6-cf61daf93ade

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
