// Dragnet [Ransomware]: dragnet-ransomware-2022-2917 — Mass File Rename (bitlocker)
// Status: deprecated | Level: high | ID: 1dc87e6f-ee64-5267-af57-7a9090953ad8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
