// Dragnet [Ransomware]: dragnet-ransomware-2023-3150 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 761eb7ff-44e8-5cac-9ba5-f6a7a14ca83c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
