// Dragnet [Ransomware]: dragnet-ransomware-2025-6671 — Mass File Rename (anubis)
// Status: experimental | Level: high | ID: c9c78df4-a9b2-5d39-99d9-d9d2d0186aba

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
