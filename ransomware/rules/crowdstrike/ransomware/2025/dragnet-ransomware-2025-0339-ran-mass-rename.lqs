// Dragnet [Ransomware]: dragnet-ransomware-2025-0339 — Mass File Rename (nightspire)
// Status: deprecated | Level: high | ID: ca74aac5-ce1e-58d6-b5be-bef8764c2dbf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
