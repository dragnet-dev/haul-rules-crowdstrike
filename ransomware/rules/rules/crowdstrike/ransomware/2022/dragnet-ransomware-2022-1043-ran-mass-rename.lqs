// Dragnet [Ransomware]: dragnet-ransomware-2022-1043 — Mass File Rename (blackbasta)
// Status: deprecated | Level: high | ID: b286cef2-65e2-5535-a21a-2f9d011fc5c5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
