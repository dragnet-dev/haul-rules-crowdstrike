// Dragnet [Ransomware]: dragnet-ransomware-2025-5793 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 86585650-cd93-52ef-8327-b230893484da

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
