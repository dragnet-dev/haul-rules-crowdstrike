// Dragnet [Ransomware]: dragnet-ransomware-2024-5898 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 722e868e-a71e-5c47-a7b6-ea378c097e9f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
