// Dragnet [Ransomware]: dragnet-ransomware-2025-6420 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 8db96c63-a91e-534b-8443-ad48992d367a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
