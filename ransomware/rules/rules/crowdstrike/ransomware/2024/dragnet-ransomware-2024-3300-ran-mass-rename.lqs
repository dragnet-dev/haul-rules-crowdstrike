// Dragnet [Ransomware]: dragnet-ransomware-2024-3300 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: 2614d8ff-5841-59cc-9aa9-494b338efa09

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
