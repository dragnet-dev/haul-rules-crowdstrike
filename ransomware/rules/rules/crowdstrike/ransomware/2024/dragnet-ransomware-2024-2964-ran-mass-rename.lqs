// Dragnet [Ransomware]: dragnet-ransomware-2024-2964 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 6d050e5e-c2a6-5a39-938c-74ed161d7306

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
