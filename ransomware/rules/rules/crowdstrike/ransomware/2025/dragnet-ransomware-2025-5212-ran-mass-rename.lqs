// Dragnet [Ransomware]: dragnet-ransomware-2025-5212 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 3a1858f8-155f-5571-b1b3-6b7b4dddf0aa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
