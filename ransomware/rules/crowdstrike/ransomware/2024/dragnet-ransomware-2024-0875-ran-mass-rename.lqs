// Dragnet [Ransomware]: dragnet-ransomware-2024-0875 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 7225da11-fddb-551a-a640-e9b4964fda76

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
