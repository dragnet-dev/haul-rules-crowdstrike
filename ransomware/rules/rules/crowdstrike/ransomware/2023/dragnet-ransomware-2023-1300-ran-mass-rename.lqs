// Dragnet [Ransomware]: dragnet-ransomware-2023-1300 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 9016f0d2-f966-5c41-87dc-799af6979677

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
