// Dragnet [Ransomware]: dragnet-ransomware-2022-0439 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: d7fd1c23-7e51-5d8f-8ecc-b8caa9b8c300

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
