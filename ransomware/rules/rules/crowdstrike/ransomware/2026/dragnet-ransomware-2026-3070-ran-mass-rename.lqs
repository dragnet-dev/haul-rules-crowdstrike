// Dragnet [Ransomware]: dragnet-ransomware-2026-3070 — Mass File Rename (kairos)
// Status: deprecated | Level: high | ID: 39a1a61d-b973-546e-ad87-a8eab2e63659

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
