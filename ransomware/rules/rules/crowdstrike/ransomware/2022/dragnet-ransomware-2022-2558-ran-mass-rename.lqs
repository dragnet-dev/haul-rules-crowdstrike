// Dragnet [Ransomware]: dragnet-ransomware-2022-2558 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 2d72e6dd-f81d-51e5-9479-86a7804f55ef

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
