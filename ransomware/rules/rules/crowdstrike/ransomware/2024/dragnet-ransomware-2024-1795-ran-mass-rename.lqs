// Dragnet [Ransomware]: dragnet-ransomware-2024-1795 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 6f41c931-7579-5811-a48d-b72721bcbe03

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
