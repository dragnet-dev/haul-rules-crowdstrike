// Dragnet [Ransomware]: dragnet-ransomware-2026-3322 — Mass File Rename (dragonforce)
// Status: test | Level: high | ID: ce2e2571-6b15-51c3-82fb-e672acdfb1dc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
