// Dragnet [Ransomware]: dragnet-ransomware-2025-6542 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 4ed1a380-1f8a-52b4-8eba-8b69c2a9065a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
