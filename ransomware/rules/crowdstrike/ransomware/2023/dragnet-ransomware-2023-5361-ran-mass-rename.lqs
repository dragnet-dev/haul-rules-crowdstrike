// Dragnet [Ransomware]: dragnet-ransomware-2023-5361 — Mass File Rename (rhysida)
// Status: experimental | Level: high | ID: 4c799016-9480-571d-b0f6-1edc1cb0c5c8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
