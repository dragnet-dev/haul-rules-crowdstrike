// Dragnet [Container]: dragnet-container-2024-0139 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: c339bd47-d743-570f-a69a-22969b329bbd

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *ubuntu:16.04* OR ImageFileName = *ubuntu:16.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
