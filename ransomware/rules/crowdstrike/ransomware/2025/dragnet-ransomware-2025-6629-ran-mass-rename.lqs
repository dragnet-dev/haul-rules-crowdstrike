// Dragnet [Ransomware]: dragnet-ransomware-2025-6629 — Mass File Rename (direwolf)
// Status: experimental | Level: high | ID: b15eb3d5-0452-55b0-967c-5ad9d9722d0c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
