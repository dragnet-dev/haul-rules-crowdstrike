// Dragnet [Ransomware]: dragnet-ransomware-2024-2002 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 60e8a732-c5ef-5ad9-814d-4a032691c764

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
