// Dragnet [Ransomware]: dragnet-ransomware-2024-5244 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 38f8ec33-b1b9-55b0-bf10-bc4808d77aa1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
