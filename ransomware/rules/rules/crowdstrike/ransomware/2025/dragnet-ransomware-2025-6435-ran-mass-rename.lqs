// Dragnet [Ransomware]: dragnet-ransomware-2025-6435 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 5cc6f613-9a86-5704-bb7b-01f98b16efc0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
