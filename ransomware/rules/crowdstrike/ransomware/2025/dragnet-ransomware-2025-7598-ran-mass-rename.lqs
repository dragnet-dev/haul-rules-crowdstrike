// Dragnet [Ransomware]: dragnet-ransomware-2025-7598 — Mass File Rename (dragonforce)
// Status: test | Level: high | ID: 1589a21d-c9f4-5091-9615-25334e6e8bee

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
