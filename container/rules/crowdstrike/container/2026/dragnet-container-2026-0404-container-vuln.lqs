// Dragnet [Container]: dragnet-container-2026-0404 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: b342c88f-a1df-55f8-ae66-b58c84947098

#event_simpleName=*
| (ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10*)
| table([timestamp, ComputerName])
| limit(1000)
