// Dragnet [Ransomware]: dragnet-ransomware-2025-0972 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: fed3328b-8cd4-5f9f-8e98-8b4b812cfe81

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
