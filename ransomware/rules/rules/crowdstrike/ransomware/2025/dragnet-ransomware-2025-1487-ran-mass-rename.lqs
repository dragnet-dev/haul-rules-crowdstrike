// Dragnet [Ransomware]: dragnet-ransomware-2025-1487 — Mass File Rename (ransomhouse)
// Status: experimental | Level: high | ID: 29c543d3-6871-56ae-b149-95138cf1cc36

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
