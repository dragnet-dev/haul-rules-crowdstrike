// Dragnet [Ransomware]: dragnet-ransomware-2024-3552 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 2218fc62-3c9f-5182-a986-bb42a1a4da10

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
