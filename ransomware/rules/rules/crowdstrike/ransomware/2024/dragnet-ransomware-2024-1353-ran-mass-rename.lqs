// Dragnet [Ransomware]: dragnet-ransomware-2024-1353 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 167b4023-a3e0-5074-8337-d5506d6e7f67

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
