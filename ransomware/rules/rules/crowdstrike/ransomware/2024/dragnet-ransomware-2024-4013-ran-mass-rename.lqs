// Dragnet [Ransomware]: dragnet-ransomware-2024-4013 — Mass File Rename (ElDorado)
// Status: deprecated | Level: high | ID: f10ec7c5-7b4c-5a92-99c2-86d36c372c4c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
