// Dragnet [Ransomware]: dragnet-ransomware-2025-3562 — Mass File Rename (crazyhunter)
// Status: experimental | Level: high | ID: 7c06a1fb-5c0e-56c9-9acf-ac649133a0f4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
