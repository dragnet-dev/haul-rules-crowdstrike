// Dragnet [Ransomware]: dragnet-ransomware-2022-2523 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 2af0c172-96a9-59cd-a5d1-018caa1c752c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
