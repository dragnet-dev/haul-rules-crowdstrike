// Dragnet [Ransomware]: dragnet-ransomware-2024-3336 — Mass File Rename (beast)
// Status: experimental | Level: high | ID: 6f210417-79de-5267-a5d6-0fc3ba4d5992

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
