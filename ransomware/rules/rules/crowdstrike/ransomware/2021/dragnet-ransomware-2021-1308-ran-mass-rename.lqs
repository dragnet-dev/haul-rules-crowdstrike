// Dragnet [Ransomware]: dragnet-ransomware-2021-1308 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 50eaaeca-1a2c-5f80-ae76-c4f323b2dee2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
