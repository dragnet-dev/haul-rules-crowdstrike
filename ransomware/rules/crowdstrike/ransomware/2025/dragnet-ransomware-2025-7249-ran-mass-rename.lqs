// Dragnet [Ransomware]: dragnet-ransomware-2025-7249 — Mass File Rename (blacknevas)
// Status: experimental | Level: high | ID: 0dd29bdf-7d4d-5908-b242-7f0b2ae6f772

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
