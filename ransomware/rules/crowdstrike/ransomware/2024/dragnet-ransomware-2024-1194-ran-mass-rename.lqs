// Dragnet [Ransomware]: dragnet-ransomware-2024-1194 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 8424cfef-70fc-5b9e-99f0-abd296e3e88f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
