// Dragnet [Ransomware]: dragnet-ransomware-2024-0656 — Mass File Rename (play)
// Status: experimental | Level: high | ID: e4603064-55aa-50b4-b23b-32fb17864bdb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
