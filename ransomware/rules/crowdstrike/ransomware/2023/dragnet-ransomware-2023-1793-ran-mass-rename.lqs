// Dragnet [Ransomware]: dragnet-ransomware-2023-1793 — Mass File Rename (cloak)
// Status: deprecated | Level: high | ID: 7442ecb5-8b52-5890-8c73-a91720c7a614

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
