// Dragnet [Ransomware]: dragnet-ransomware-2023-2827 — Mass File Rename (malas)
// Status: experimental | Level: high | ID: 59689a06-eb7b-552e-8af6-3ac8172dca98

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
