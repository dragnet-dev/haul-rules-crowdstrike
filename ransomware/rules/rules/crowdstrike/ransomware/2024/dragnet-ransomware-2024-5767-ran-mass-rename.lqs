// Dragnet [Ransomware]: dragnet-ransomware-2024-5767 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 593c6d73-ba2e-549f-b6a8-19c21211c8f3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
