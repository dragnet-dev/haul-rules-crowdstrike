// Dragnet [Container]: dragnet-container-2026-1398 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 359f485a-9f36-52fb-a392-18babba6d330

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *photon os:1.0* OR ImageFileName = *ubuntu:17.04*)
| table([timestamp, ComputerName])
| limit(1000)
