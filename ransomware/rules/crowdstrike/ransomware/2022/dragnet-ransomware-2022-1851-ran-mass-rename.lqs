// Dragnet [Ransomware]: dragnet-ransomware-2022-1851 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 772520ba-1144-5597-af70-905340b009d6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
