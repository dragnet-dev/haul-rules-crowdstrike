// Dragnet [Ransomware]: dragnet-ransomware-2025-3998 — Mass File Rename (worldleaks)
// Status: experimental | Level: high | ID: 9a23f58e-3e95-5730-a57f-135d77086234

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
