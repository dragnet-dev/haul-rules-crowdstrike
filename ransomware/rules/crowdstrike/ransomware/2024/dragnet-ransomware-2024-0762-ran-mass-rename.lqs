// Dragnet [Ransomware]: dragnet-ransomware-2024-0762 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: d1e84f8b-e03f-5f1c-a5da-7650147b3aff

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
