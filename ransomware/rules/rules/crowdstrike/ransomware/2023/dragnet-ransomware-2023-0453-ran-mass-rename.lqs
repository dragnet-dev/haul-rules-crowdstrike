// Dragnet [Ransomware]: dragnet-ransomware-2023-0453 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: fde285b1-81d7-5679-9c9d-ced792cfb8d1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
