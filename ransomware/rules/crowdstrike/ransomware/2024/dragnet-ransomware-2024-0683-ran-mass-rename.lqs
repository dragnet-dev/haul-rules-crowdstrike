// Dragnet [Ransomware]: dragnet-ransomware-2024-0683 — Mass File Rename (alphalocker)
// Status: experimental | Level: high | ID: 6800436f-07f7-5631-af94-b7d6384e2066

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
