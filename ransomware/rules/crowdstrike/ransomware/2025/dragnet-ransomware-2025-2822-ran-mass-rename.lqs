// Dragnet [Ransomware]: dragnet-ransomware-2025-2822 — Mass File Rename (play)
// Status: experimental | Level: high | ID: d12243ee-8fd7-5ee5-ba86-3ab1892f630c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
