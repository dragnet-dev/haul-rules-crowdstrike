// Dragnet [Ransomware]: dragnet-ransomware-2022-1163 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 51ec9de6-67df-5dd2-825b-a58a76db75fa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
