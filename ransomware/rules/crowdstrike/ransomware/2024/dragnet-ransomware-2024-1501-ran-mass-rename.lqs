// Dragnet [Ransomware]: dragnet-ransomware-2024-1501 — Mass File Rename (ransomhouse)
// Status: experimental | Level: high | ID: c3d8cfaa-3f0d-5d9e-99da-bd85ac71676a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
