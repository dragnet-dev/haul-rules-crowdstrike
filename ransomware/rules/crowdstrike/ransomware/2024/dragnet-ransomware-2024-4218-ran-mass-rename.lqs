// Dragnet [Ransomware]: dragnet-ransomware-2024-4218 — Mass File Rename (dunghill)
// Status: experimental | Level: high | ID: aa553a0d-6e0a-5333-9d68-8ac30501680b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
