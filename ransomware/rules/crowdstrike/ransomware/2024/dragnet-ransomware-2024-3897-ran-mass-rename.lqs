// Dragnet [Ransomware]: dragnet-ransomware-2024-3897 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: aeb5a175-d21b-547a-a46a-965f1a4eacd5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
