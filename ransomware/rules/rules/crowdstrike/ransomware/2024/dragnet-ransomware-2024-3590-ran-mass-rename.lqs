// Dragnet [Ransomware]: dragnet-ransomware-2024-3590 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 4b639901-e451-5169-943f-9ada9e50765d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
