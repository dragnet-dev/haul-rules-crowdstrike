// Dragnet [Ransomware]: dragnet-ransomware-2021-0971 — Mass File Rename (everest)
// Status: deprecated | Level: high | ID: e58cfa31-d2be-5a0b-bbec-d7ef9ecaaf45

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
