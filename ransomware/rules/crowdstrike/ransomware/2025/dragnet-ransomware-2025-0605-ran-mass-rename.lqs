// Dragnet [Ransomware]: dragnet-ransomware-2025-0605 — Mass File Rename (frag)
// Status: deprecated | Level: high | ID: 546dd2dd-9fcf-50fa-a075-e2bb0fb40272

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
