// Dragnet [Ransomware]: dragnet-ransomware-2025-1228 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 3200fbc8-d0f5-5dde-8a13-ee19667cd4bd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
