// Dragnet [Ransomware]: dragnet-ransomware-2025-7067 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 576d9bb4-29d5-559c-8428-4630a80a277a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
