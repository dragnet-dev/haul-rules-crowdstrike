// Dragnet [Ransomware]: dragnet-ransomware-2025-4874 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: 735e4c37-fd77-528a-9865-b91b21798dc0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
