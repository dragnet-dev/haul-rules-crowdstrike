// Dragnet [Ransomware]: dragnet-ransomware-2023-2910 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: fa288aa8-988b-51be-a15b-65d6e4f4e50a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
