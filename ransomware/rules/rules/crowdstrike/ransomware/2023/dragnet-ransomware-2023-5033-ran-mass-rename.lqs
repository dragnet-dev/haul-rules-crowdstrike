// Dragnet [Ransomware]: dragnet-ransomware-2023-5033 — Mass File Rename (play)
// Status: deprecated | Level: high | ID: bd7a3b3b-928d-5b64-b643-b0d414ec61db

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
