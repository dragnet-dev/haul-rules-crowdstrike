// Dragnet [Ransomware]: dragnet-ransomware-2025-4269 — Mass File Rename (global)
// Status: deprecated | Level: high | ID: d14388e2-f33f-507a-bf7e-d101f04c1f27

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
