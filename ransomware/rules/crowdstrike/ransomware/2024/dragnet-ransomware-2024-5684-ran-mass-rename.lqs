// Dragnet [Ransomware]: dragnet-ransomware-2024-5684 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 4e20d82a-be58-5e7b-bba8-cfd3cd623624

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
