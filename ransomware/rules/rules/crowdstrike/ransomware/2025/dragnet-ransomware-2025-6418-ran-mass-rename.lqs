// Dragnet [Ransomware]: dragnet-ransomware-2025-6418 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: b9265569-e290-5a3e-b6e7-d7230b34ac5c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
