// Dragnet [Ransomware]: dragnet-ransomware-2025-5595 — Mass File Rename (kairos)
// Status: experimental | Level: high | ID: b6892cda-1461-5eeb-9021-0f4bed6299d0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
