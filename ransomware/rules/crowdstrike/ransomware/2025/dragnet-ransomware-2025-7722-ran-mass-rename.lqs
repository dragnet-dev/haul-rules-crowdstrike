// Dragnet [Ransomware]: dragnet-ransomware-2025-7722 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 69c157e6-082b-571b-b50a-e523219bba89

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
