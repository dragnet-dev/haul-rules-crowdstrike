// Dragnet [Ransomware]: dragnet-ransomware-2023-1390 — Mass File Rename (raworld)
// Status: experimental | Level: high | ID: d14346a8-1f5c-5636-89c1-c448eb1362e7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
