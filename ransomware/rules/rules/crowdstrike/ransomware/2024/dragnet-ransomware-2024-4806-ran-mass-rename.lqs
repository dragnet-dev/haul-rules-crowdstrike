// Dragnet [Ransomware]: dragnet-ransomware-2024-4806 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: e9abf871-41e9-52cb-8a00-37e669f45a39

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
