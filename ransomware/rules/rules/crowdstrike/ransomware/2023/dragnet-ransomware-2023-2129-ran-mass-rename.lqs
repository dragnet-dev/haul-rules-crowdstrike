// Dragnet [Ransomware]: dragnet-ransomware-2023-2129 — Mass File Rename (stormous)
// Status: experimental | Level: high | ID: f3cc436d-4e41-56d4-84d9-d100a2665c92

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
