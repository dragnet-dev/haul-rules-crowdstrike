// Dragnet [Container]: dragnet-container-2026-1661 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: ccfd7189-d03a-5c52-a7ef-4b3b594ace09

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:6*)
| table([timestamp, ComputerName])
| limit(1000)
