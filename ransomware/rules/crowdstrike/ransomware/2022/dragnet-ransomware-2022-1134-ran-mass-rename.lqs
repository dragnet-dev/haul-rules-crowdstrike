// Dragnet [Ransomware]: dragnet-ransomware-2022-1134 — Mass File Rename (snatch)
// Status: deprecated | Level: high | ID: d5285325-f206-534a-8ef1-46aa7737f778

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
