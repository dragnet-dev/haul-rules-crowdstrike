// Dragnet [Ransomware]: dragnet-ransomware-2025-5403 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: a40eea21-7efb-56be-a319-42a248e05b08

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
