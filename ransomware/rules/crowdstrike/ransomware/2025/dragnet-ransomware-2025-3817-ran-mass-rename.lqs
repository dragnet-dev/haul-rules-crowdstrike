// Dragnet [Ransomware]: dragnet-ransomware-2025-3817 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: ced218f4-1972-522c-9057-b98dda07e23d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
