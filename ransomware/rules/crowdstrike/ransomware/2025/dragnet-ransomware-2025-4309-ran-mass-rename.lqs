// Dragnet [Ransomware]: dragnet-ransomware-2025-4309 — Mass File Rename (threeam)
// Status: experimental | Level: high | ID: 02386653-e16c-51f5-bfc0-8e40ee918398

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
