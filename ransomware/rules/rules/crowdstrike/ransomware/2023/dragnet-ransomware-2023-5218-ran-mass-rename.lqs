// Dragnet [Ransomware]: dragnet-ransomware-2023-5218 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 9eb5a62c-0da1-529b-8b26-5cc23b639a7f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
