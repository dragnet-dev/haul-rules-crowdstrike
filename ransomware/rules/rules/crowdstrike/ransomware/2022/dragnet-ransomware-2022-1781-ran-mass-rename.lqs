// Dragnet [Ransomware]: dragnet-ransomware-2022-1781 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: dd81292e-062b-5228-86da-d7791276a85f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
