// Dragnet [Ransomware]: dragnet-ransomware-2024-5922 — Mass File Rename (play)
// Status: experimental | Level: high | ID: b763c178-923d-5242-98fe-c7cc13d54177

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
