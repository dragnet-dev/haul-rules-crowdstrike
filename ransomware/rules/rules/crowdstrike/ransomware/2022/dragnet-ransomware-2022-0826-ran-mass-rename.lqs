// Dragnet [Ransomware]: dragnet-ransomware-2022-0826 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 82d99bd2-a847-51e3-9d83-0bd374926d1c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
