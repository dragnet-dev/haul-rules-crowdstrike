// Dragnet [Ransomware]: dragnet-ransomware-2023-2766 — Mass File Rename (malas)
// Status: experimental | Level: high | ID: 0cef2290-da43-54cf-a294-3c7fcf4ada1d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
