// Dragnet [Ransomware]: dragnet-ransomware-2024-5990 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: b7a388c7-cbb2-5b42-b4c8-cb0f99737388

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
