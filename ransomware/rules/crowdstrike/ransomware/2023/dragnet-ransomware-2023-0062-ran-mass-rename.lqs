// Dragnet [Ransomware]: dragnet-ransomware-2023-0062 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 7ebd8f3d-da82-58d5-bd3c-e6e0148b956b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
