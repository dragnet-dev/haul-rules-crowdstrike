// Dragnet [Ransomware]: dragnet-ransomware-2024-0879 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 9f33fc8c-44fa-555a-8f45-0fe617f8a36f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
