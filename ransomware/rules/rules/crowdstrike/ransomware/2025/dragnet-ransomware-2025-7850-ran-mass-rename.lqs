// Dragnet [Ransomware]: dragnet-ransomware-2025-7850 — Mass File Rename (play)
// Status: experimental | Level: high | ID: af4a37d4-6117-5e78-9691-b3694150edd9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
