// Dragnet [Ransomware]: dragnet-ransomware-2023-2739 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: ce9ece58-4a9e-5aea-ab13-affaec2fc0ed

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
