// Dragnet [Ransomware]: dragnet-ransomware-2024-0046 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 94199017-9ee0-5c88-8973-c74877ef0af1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
