// Dragnet [Container]: dragnet-container-2024-0294 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 1eea42eb-61b7-5eea-b7d0-6c49242e7605

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:8*)
| table([timestamp, ComputerName])
| limit(1000)
