// Dragnet [Ransomware]: dragnet-ransomware-2024-5555 — Mass File Rename (stormous)
// Status: deprecated | Level: high | ID: f6d10511-ae72-50d9-9243-a80557dbe4c5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
