// Dragnet [Ransomware]: dragnet-ransomware-2025-0701 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: 15153779-41a9-5c0a-85dd-22d87d2abb1f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
