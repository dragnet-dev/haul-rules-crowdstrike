// Dragnet [Ransomware]: dragnet-ransomware-2023-3511 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 3cbbbf26-d24c-537f-bab8-3f5abd2c42f1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
