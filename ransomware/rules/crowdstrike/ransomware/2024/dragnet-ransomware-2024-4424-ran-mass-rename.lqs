// Dragnet [Ransomware]: dragnet-ransomware-2024-4424 — Mass File Rename (raworld)
// Status: experimental | Level: high | ID: 45eabc6d-3323-5ed6-ac93-857aa2ff6782

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
