// Dragnet [Ransomware]: dragnet-ransomware-2024-2910 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 6cdce446-a91b-57f0-8d5b-31da2bf44322

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
