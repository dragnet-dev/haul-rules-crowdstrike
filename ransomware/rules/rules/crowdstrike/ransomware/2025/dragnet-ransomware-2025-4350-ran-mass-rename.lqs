// Dragnet [Ransomware]: dragnet-ransomware-2025-4350 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 1508b729-4e8f-5ece-b98f-bb70aa12604c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
