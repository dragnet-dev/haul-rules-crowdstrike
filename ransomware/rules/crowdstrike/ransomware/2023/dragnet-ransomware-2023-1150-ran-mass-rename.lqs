// Dragnet [Ransomware]: dragnet-ransomware-2023-1150 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 07ad6af6-ab5a-5a3d-8b9e-84454c71df34

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
