// Dragnet [Ransomware]: dragnet-ransomware-2022-2822 — Mass File Rename (alphv)
// Status: deprecated | Level: high | ID: 486f665b-2be6-5876-9d5e-713ad0989a92

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
