// Dragnet [Ransomware]: dragnet-ransomware-2025-2568 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 51706893-8775-569f-8bcf-624f4a201481

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
