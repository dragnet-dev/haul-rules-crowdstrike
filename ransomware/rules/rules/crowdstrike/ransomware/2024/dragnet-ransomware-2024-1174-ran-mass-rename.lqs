// Dragnet [Ransomware]: dragnet-ransomware-2024-1174 — Mass File Rename (spacebears)
// Status: experimental | Level: high | ID: ee544c37-5b39-56cb-bd22-49d831381730

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
