// Dragnet [Ransomware]: dragnet-ransomware-2022-0352 — Mass File Rename (stormous)
// Status: deprecated | Level: high | ID: b8666798-7acd-51b1-ac71-bfe16d7f4298

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
