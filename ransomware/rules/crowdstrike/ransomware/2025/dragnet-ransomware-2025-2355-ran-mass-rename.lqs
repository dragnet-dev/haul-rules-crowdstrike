// Dragnet [Ransomware]: dragnet-ransomware-2025-2355 — Mass File Rename (global)
// Status: deprecated | Level: high | ID: d1b2999b-41c5-5617-ae59-d5eeb5d483f6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
