// Dragnet [Ransomware]: dragnet-ransomware-2024-3936 — Mass File Rename (dragonforce)
// Status: deprecated | Level: high | ID: c18e7d23-1b45-5cd3-bb3b-3dcf5c1e5da1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
