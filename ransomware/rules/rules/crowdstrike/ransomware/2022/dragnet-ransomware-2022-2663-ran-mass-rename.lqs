// Dragnet [Ransomware]: dragnet-ransomware-2022-2663 — Mass File Rename (payloadbin)
// Status: deprecated | Level: high | ID: f5e067dd-b5f2-5a5c-b66a-89ab96cfa3a8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
