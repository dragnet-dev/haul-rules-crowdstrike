// Dragnet [Ransomware]: dragnet-ransomware-2025-0036 — Mass File Rename (fog)
// Status: deprecated | Level: high | ID: 1441990d-5999-5da1-b17d-1649a18f3c68

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
