// Dragnet [Ransomware]: dragnet-ransomware-2024-5758 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: e3108c94-163e-5d09-ad36-6c62d5eb9f20

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
