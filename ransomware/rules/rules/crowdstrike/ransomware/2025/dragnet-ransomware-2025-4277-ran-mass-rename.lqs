// Dragnet [Ransomware]: dragnet-ransomware-2025-4277 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 40c9026b-1265-58f8-8c62-0331bd6ab825

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
