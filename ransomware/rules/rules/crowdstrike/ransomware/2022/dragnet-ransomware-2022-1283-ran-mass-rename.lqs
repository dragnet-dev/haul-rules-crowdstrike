// Dragnet [Ransomware]: dragnet-ransomware-2022-1283 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: f668df5b-0f22-5d6c-bcd4-7e9452e776ea

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
