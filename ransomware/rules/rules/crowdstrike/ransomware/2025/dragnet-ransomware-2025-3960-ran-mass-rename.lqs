// Dragnet [Ransomware]: dragnet-ransomware-2025-3960 — Mass File Rename (medusalocker)
// Status: experimental | Level: high | ID: 3b191686-8607-5d52-bfdb-4312254ef9b6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
