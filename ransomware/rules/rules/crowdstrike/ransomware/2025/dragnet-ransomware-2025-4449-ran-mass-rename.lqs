// Dragnet [Ransomware]: dragnet-ransomware-2025-4449 — Mass File Rename (kawa4096)
// Status: experimental | Level: high | ID: fcd84836-71b8-5523-bcef-3189970b50ba

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
