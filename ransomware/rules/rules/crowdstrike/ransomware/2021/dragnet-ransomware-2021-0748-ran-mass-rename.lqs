// Dragnet [Ransomware]: dragnet-ransomware-2021-0748 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 5438d537-4108-5820-ad38-6543cb2f33fc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
