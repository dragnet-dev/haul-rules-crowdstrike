// Dragnet [Ransomware]: dragnet-ransomware-2025-1133 — Mass File Rename (obscura)
// Status: experimental | Level: high | ID: 80c99f1a-7c56-58a9-98aa-5b8b6359ed01

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
