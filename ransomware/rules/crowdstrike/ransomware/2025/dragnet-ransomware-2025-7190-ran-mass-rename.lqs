// Dragnet [Ransomware]: dragnet-ransomware-2025-7190 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 0b89afad-6d72-5365-938a-907d9eeaefa4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
