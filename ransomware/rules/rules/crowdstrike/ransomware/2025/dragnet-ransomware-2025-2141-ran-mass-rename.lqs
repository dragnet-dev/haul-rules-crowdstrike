// Dragnet [Ransomware]: dragnet-ransomware-2025-2141 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: 459ade52-6fff-5511-874f-a67ff885ab8b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
