// Dragnet [Ransomware]: dragnet-ransomware-2023-1738 — Mass File Rename (cactus)
// Status: deprecated | Level: high | ID: 163c4a61-bdf5-5e24-8ffa-cba2761b0ebe

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
