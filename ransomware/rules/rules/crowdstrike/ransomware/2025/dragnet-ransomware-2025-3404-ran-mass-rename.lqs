// Dragnet [Ransomware]: dragnet-ransomware-2025-3404 — Mass File Rename (spacebears)
// Status: test | Level: high | ID: 6c982ce2-769f-54f3-b906-73bd97990cdc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
