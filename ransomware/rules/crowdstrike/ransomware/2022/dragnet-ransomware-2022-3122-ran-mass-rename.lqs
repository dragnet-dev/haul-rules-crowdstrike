// Dragnet [Ransomware]: dragnet-ransomware-2022-3122 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 929be4b2-1ced-5f8f-8080-4cae2ffc8c4b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
