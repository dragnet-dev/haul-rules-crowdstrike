// Dragnet [Ransomware]: dragnet-ransomware-2022-0164 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 2785d2da-bc7a-5d15-bb46-e516b111ca92

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
