// Dragnet [Ransomware]: dragnet-ransomware-2023-4591 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 9eb9b57c-b459-50a9-9447-fb158fbdaac5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
