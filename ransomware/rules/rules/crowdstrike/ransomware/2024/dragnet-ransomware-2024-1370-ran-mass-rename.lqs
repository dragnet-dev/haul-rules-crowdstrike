// Dragnet [Ransomware]: dragnet-ransomware-2024-1370 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 7c7eb9fa-6b87-5065-a071-7f68b613fda2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
