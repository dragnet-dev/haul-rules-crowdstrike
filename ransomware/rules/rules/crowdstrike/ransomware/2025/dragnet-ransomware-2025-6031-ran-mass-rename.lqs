// Dragnet [Ransomware]: dragnet-ransomware-2025-6031 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 36ab8071-a982-5d36-9202-e11c8a98cf79

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
