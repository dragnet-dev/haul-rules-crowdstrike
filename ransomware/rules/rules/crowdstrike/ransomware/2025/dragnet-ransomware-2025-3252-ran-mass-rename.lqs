// Dragnet [Ransomware]: dragnet-ransomware-2025-3252 — Mass File Rename (BrainCipher)
// Status: experimental | Level: high | ID: 4df1026e-d3f9-56a2-884b-b9b276531233

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
