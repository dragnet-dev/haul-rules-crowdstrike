// Dragnet [Ransomware]: dragnet-ransomware-2026-0760 — Mass File Rename (interlock)
// Status: test | Level: high | ID: 515d343c-4a1c-5131-88db-c4304cbd4a8a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
