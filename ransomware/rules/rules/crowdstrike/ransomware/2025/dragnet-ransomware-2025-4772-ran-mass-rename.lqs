// Dragnet [Ransomware]: dragnet-ransomware-2025-4772 — Mass File Rename (global)
// Status: deprecated | Level: high | ID: 2398eb12-e3bf-522d-b3b4-9ebfa06d1228

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
