// Dragnet [Ransomware]: dragnet-ransomware-2023-1073 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: dcd50016-0a56-5c2c-a238-4aa026695dad

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
