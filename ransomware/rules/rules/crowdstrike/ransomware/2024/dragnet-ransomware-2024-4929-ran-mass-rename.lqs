// Dragnet [Ransomware]: dragnet-ransomware-2024-4929 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: ab6db1c3-10c4-57ef-85a5-a5d4c0d51865

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
