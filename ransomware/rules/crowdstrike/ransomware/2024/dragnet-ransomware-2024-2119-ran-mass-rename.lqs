// Dragnet [Ransomware]: dragnet-ransomware-2024-2119 — Mass File Rename (underground)
// Status: experimental | Level: high | ID: 7068d2de-f050-5017-b20e-637db204a77c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
