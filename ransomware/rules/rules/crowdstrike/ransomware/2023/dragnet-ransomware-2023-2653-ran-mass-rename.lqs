// Dragnet [Ransomware]: dragnet-ransomware-2023-2653 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: d7d045f2-404a-5402-96f2-79da7f0bf9c4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
