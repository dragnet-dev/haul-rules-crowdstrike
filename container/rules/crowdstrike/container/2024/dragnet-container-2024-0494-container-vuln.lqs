// Dragnet [Container]: dragnet-container-2024-0494 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: a62925ac-cc67-595d-a419-9d695302b6f6

#event_simpleName=*
| (ImageFileName = *chainguard:* OR ImageFileName = *debian:10* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
