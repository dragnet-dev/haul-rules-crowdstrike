// Dragnet [Ransomware]: dragnet-ransomware-2022-1358 — Mass File Rename (cuba)
// Status: deprecated | Level: high | ID: cd2ccd43-a87f-5053-ac40-9384fbc9d838

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
