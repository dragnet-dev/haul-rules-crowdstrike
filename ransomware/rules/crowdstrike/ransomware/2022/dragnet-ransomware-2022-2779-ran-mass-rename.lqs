// Dragnet [Ransomware]: dragnet-ransomware-2022-2779 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: f39a36d1-c581-585b-a5fc-0ae3d10994f8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
