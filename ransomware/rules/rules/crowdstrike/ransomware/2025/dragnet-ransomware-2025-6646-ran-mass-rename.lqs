// Dragnet [Ransomware]: dragnet-ransomware-2025-6646 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: 29075f0a-66f8-5c56-aa29-04ab9f6f018f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
