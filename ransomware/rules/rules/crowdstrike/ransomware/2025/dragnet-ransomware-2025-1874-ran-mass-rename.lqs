// Dragnet [Ransomware]: dragnet-ransomware-2025-1874 — Mass File Rename (rhysida)
// Status: deprecated | Level: high | ID: 45a15baa-5238-5cf6-99ae-1b7404af533c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
