// Dragnet [Ransomware]: dragnet-ransomware-2024-1283 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: eb9d1884-29c8-50e7-92f4-33029f804a8a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
