// Dragnet [Ransomware]: dragnet-ransomware-2022-1663 — Mass File Rename (everest)
// Status: deprecated | Level: high | ID: 481a4d76-f4d9-5074-806c-c733ee17158b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
