// Dragnet [Ransomware]: dragnet-ransomware-2023-5317 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 44f13224-db1c-5cc9-989c-dbdb10a5f877

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
