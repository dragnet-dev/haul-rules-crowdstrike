// Dragnet [Ransomware]: dragnet-ransomware-2025-0277 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: d68c8f58-8dd0-58d2-94f7-151a7d65ea96

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
