// Dragnet [Ransomware]: dragnet-ransomware-2021-0337 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: e3cf1275-37b3-56ab-9b0b-56a00ddd516c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
