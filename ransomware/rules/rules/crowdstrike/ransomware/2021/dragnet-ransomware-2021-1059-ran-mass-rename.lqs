// Dragnet [Ransomware]: dragnet-ransomware-2021-1059 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 015f4b96-8e12-5276-93a4-0325426c9722

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
