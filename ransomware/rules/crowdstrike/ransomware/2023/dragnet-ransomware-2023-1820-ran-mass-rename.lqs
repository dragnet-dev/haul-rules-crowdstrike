// Dragnet [Ransomware]: dragnet-ransomware-2023-1820 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: dd0e08b6-0bb7-56e1-99c7-7dbdb1d540d8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
