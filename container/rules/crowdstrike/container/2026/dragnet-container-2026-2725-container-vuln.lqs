// Dragnet [Container]: dragnet-container-2026-2725 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 3504ea85-9b8a-523b-bb16-1e3c93f4c2ff

#event_simpleName=*
| (ImageFileName = *chainguard:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
