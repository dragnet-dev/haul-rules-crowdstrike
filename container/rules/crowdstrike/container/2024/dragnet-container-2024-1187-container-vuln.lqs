// Dragnet [Container]: dragnet-container-2024-1187 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 019913ee-2797-5a17-a135-f5e261e4de3c

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:9* OR ImageFileName = *ubuntu:18.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
