// Dragnet [Ransomware]: dragnet-ransomware-2024-6019 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: d6a0cb2f-da8e-5d4f-84b2-324de0510d62

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
