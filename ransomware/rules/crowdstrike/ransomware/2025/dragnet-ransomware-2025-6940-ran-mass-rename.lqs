// Dragnet [Ransomware]: dragnet-ransomware-2025-6940 — Mass File Rename (chaos)
// Status: experimental | Level: high | ID: 4b78bd3f-78c5-5202-b024-e95042e4269a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
