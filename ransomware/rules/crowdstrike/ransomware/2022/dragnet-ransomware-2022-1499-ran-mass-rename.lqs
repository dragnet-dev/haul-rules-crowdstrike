// Dragnet [Ransomware]: dragnet-ransomware-2022-1499 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: a20411d6-6bce-5b56-afde-abc230f38f4b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
