// Dragnet [Ransomware]: dragnet-ransomware-2025-7206 — Mass File Rename (flocker)
// Status: experimental | Level: high | ID: 75843310-d93f-50a0-82ba-7a58be23dadb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
