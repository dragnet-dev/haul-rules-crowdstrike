// Dragnet [Ransomware]: dragnet-ransomware-2022-2766 — Mass File Rename (leaktheanalyst)
// Status: deprecated | Level: high | ID: fc38bf0c-cfb4-5aa9-9c2c-642488ccb72d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
