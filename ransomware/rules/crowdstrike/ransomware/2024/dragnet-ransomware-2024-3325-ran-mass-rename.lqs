// Dragnet [Ransomware]: dragnet-ransomware-2024-3325 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 9704e269-7ff7-5aad-b544-24f8f6db2250

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
