// Dragnet [Ransomware]: dragnet-ransomware-2023-5188 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: dc512cff-2b15-5c58-85b7-747ff201f687

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
