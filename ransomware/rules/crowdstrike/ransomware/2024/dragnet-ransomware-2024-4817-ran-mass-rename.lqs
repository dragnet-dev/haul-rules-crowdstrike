// Dragnet [Ransomware]: dragnet-ransomware-2024-4817 — Mass File Rename (raworld)
// Status: experimental | Level: high | ID: 2adb9c26-e4cf-5647-bbcf-f5c3c7276715

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
