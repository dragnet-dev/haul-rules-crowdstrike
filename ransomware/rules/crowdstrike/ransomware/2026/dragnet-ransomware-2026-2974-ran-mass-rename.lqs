// Dragnet [Ransomware]: dragnet-ransomware-2026-2974 — Mass File Rename (lockbit5)
// Status: test | Level: high | ID: ec5d6c64-f449-57d1-9b74-a556e043503a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
