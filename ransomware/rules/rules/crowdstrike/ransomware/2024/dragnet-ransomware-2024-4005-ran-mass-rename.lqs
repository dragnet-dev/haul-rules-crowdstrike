// Dragnet [Ransomware]: dragnet-ransomware-2024-4005 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 39143b19-fdcb-5033-b7a4-8f6a9b1c2eb7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
