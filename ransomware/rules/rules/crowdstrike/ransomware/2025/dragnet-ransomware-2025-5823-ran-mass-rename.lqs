// Dragnet [Ransomware]: dragnet-ransomware-2025-5823 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: d3b63b5d-9968-5245-b22b-8d80c56ad6cc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
