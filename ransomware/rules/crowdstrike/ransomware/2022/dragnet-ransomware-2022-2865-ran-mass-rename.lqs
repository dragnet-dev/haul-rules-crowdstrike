// Dragnet [Ransomware]: dragnet-ransomware-2022-2865 — Mass File Rename (kelvinsecurity)
// Status: deprecated | Level: high | ID: f426f8e1-05a8-50a3-a5e4-2ff2451e6348

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
