// Dragnet [Ransomware]: dragnet-ransomware-2025-0872 — Mass File Rename (killsec)
// Status: deprecated | Level: high | ID: a665ae49-6ab3-53ce-9183-ee1ccabc65aa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
