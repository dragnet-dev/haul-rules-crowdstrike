// Dragnet [Ransomware]: dragnet-ransomware-2024-0144 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 92f13dff-8f98-542f-b0b4-848cef5eef2a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
