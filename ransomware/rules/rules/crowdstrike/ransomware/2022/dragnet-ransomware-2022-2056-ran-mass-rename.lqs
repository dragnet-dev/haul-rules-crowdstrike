// Dragnet [Ransomware]: dragnet-ransomware-2022-2056 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: b8c7a58b-1394-5cce-8456-7c8d9d6c2d4a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
