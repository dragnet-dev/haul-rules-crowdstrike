// Dragnet [Ransomware]: dragnet-ransomware-2024-1621 — Mass File Rename (stormous)
// Status: experimental | Level: high | ID: ffc10391-55cf-54aa-ab87-364296beb84b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
