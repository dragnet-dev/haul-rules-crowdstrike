// Dragnet [Ransomware]: dragnet-ransomware-2022-1876 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 537e7cee-e5f9-591c-bbd0-8958d72d2276

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
