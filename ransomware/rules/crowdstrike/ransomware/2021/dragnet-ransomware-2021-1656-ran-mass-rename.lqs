// Dragnet [Ransomware]: dragnet-ransomware-2021-1656 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 48ea19df-7a05-54ba-9794-2f48d80d15b2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
