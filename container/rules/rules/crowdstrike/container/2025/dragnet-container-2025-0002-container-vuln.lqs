// Dragnet [Container]: dragnet-container-2025-0002 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 870aa7c3-8d68-5728-9310-486ffcf3a6cf

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *ubuntu:18.04-ESM* OR ImageFileName = *ubuntu:20.04-ESM* OR ImageFileName = *ubuntu:22.04* OR ImageFileName = *ubuntu:24.04*)
| table([timestamp, ComputerName])
| limit(1000)
