// Dragnet [Ransomware]: dragnet-ransomware-2024-0400 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: 9ed27aba-9ecb-5ba7-90cd-15f080a86a31

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
