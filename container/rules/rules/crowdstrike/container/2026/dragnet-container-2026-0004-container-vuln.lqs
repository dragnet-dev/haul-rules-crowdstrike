// Dragnet [Container]: dragnet-container-2026-0004 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 856afdaf-03d6-57ec-85f3-09f6466e8121

#event_simpleName=*
| (ImageFileName = *amazonlinux:1* OR ImageFileName = *chainguard:* OR ImageFileName = *debian:7* OR ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10* OR ImageFileName = *ubuntu:13.04*)
| table([timestamp, ComputerName])
| limit(1000)
