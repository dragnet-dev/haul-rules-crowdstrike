// Dragnet [Ransomware]: dragnet-ransomware-2024-5223 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 02544755-ec54-590c-8fca-6e7be16b1102

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
