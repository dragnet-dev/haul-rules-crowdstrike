// Dragnet [Ransomware]: dragnet-ransomware-2022-1248 — Mass File Rename (blackbasta)
// Status: deprecated | Level: high | ID: 8bd5f613-22af-589e-b409-efb659929444

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
