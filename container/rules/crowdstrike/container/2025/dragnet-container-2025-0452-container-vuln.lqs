// Dragnet [Container]: dragnet-container-2025-0452 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 047b219e-a6ea-5c2b-aed8-6ddbe07815cb

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
