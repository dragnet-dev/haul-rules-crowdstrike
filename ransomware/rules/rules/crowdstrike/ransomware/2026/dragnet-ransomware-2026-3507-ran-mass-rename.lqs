// Dragnet [Ransomware]: dragnet-ransomware-2026-3507 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 0f1a4c2f-cc32-55a1-96d5-526d385c160d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
