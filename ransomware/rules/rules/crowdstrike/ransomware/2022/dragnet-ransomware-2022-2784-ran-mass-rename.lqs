// Dragnet [Ransomware]: dragnet-ransomware-2022-2784 — Mass File Rename (ragnarlocker)
// Status: deprecated | Level: high | ID: f3e7a6de-5aa3-598a-b55f-1d2b60aec530

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
