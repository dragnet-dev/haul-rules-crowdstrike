// Dragnet [Ransomware]: dragnet-ransomware-2024-2653 — Mass File Rename (hellcat)
// Status: deprecated | Level: high | ID: a74d04b6-13b5-517a-bad0-a26f50785651

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
