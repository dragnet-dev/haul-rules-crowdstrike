// Dragnet [Ransomware]: dragnet-ransomware-2022-0471 — Mass File Rename (blackbasta)
// Status: deprecated | Level: high | ID: 4d97bb9a-f7c2-5cc7-9fb3-86a151863d02

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
