// Dragnet [Ransomware]: dragnet-ransomware-2024-2478 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: d8323cf2-9fc5-540d-bb9a-80cc515b65be

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
