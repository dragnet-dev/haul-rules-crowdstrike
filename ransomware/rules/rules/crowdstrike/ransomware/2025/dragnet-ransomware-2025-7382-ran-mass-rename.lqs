// Dragnet [Ransomware]: dragnet-ransomware-2025-7382 — Mass File Rename (warlock)
// Status: deprecated | Level: high | ID: 17feb1d7-fe5a-58ff-884b-8e3b805eb8c8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
