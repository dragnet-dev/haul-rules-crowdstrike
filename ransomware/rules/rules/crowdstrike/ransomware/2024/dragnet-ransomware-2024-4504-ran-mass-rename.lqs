// Dragnet [Ransomware]: dragnet-ransomware-2024-4504 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: 88eff2bc-379f-53c8-8f66-5d9e7b675c98

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
