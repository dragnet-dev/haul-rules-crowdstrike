// Dragnet [Ransomware]: dragnet-ransomware-2024-0546 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: 38c9bcad-c0cb-5f6b-8a73-0dbcab591a3b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
