// Dragnet [Ransomware]: dragnet-ransomware-2024-3130 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: 2e5373f0-54ed-5ef3-96f1-96e1e5cfbb5e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
