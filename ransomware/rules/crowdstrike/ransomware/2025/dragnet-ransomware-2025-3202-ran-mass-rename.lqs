// Dragnet [Ransomware]: dragnet-ransomware-2025-3202 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 458cb4a1-c390-5fed-8d7d-f6dc762afb36

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
