// Dragnet [Ransomware]: dragnet-ransomware-2025-0185 — Mass File Rename (flocker)
// Status: experimental | Level: high | ID: 8037e0f9-64db-53e6-9668-70eebc5273e8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
