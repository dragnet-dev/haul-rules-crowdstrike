// Dragnet [Container]: dragnet-container-2024-0638 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 16eddb3d-4866-50ab-9b45-950a21a411b7

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:9*)
| table([timestamp, ComputerName])
| limit(1000)
