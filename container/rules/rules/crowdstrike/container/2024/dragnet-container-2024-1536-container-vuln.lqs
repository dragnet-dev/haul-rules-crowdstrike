// Dragnet [Container]: dragnet-container-2024-1536 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 64592f2e-4660-5d95-8039-948365ed4e39

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
