// Dragnet [Ransomware]: dragnet-ransomware-2025-1437 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 3a09ede1-7d58-5695-9fdd-6dfcbdcdffba

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
