// Dragnet [Ransomware]: dragnet-ransomware-2025-4980 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 8f6e79ba-8450-5bc8-9531-cc629daa817e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
