// Dragnet [Ransomware]: dragnet-ransomware-2025-7481 — Mass File Rename (beast)
// Status: experimental | Level: high | ID: 37a2d620-a498-500b-81dd-3bfc79923035

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
