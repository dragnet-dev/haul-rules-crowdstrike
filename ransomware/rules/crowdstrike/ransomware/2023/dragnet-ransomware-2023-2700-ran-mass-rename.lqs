// Dragnet [Ransomware]: dragnet-ransomware-2023-2700 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: c4152af4-7271-5018-867c-4412408951e1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
