// Dragnet [Ransomware]: dragnet-ransomware-2023-3971 — Mass File Rename (stormous)
// Status: experimental | Level: high | ID: 67554167-43ce-5873-8758-f25257640ef7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
