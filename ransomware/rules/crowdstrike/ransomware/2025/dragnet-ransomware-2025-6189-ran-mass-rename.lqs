// Dragnet [Ransomware]: dragnet-ransomware-2025-6189 — Mass File Rename (cloak)
// Status: deprecated | Level: high | ID: 709a9a81-f7b4-5476-9f6e-41d95c38591e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
