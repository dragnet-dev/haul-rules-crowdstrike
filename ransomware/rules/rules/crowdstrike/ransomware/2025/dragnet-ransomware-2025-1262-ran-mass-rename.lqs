// Dragnet [Ransomware]: dragnet-ransomware-2025-1262 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: e4a1360c-6a2b-5b68-bbd4-428ba6dba82c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
