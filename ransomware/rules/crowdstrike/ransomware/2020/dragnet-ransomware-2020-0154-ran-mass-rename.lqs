// Dragnet [Ransomware]: dragnet-ransomware-2020-0154 — Mass File Rename (ryuk)
// Status: deprecated | Level: high | ID: 793baa7a-f2cf-598a-82c5-318e6dba9dd6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
