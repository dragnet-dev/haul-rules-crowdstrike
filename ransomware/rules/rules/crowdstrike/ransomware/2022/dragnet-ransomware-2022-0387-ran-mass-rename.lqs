// Dragnet [Ransomware]: dragnet-ransomware-2022-0387 — Mass File Rename (quantum)
// Status: deprecated | Level: high | ID: 476c64d3-28e1-5e05-a9be-24cdf6d43c23

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
