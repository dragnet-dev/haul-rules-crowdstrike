// Dragnet [Ransomware]: dragnet-ransomware-2024-0051 — Mass File Rename (helldown)
// Status: experimental | Level: high | ID: 3309886f-e5ed-56f4-b7e8-8fbaaed62cc6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
