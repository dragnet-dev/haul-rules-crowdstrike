// Dragnet [Ransomware]: dragnet-ransomware-2024-5491 — Mass File Rename (helldown)
// Status: experimental | Level: high | ID: c090dcb3-ee30-518e-95c7-8a373c29e695

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
