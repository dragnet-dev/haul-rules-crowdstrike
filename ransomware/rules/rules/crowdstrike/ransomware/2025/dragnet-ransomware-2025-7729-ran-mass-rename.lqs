// Dragnet [Ransomware]: dragnet-ransomware-2025-7729 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 07fec772-9265-5263-95a1-3b08ffdd1958

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
