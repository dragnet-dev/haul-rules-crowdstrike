// Dragnet [Ransomware]: dragnet-ransomware-2022-1000 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: ec4eabea-9755-5987-9765-4e4fac1f3d84

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
