// Dragnet [Ransomware]: dragnet-ransomware-2026-1907 — Mass File Rename (SilentRansomGroup)
// Status: deprecated | Level: high | ID: e6c6f3ef-e3cf-5718-bb83-dd44907b21a5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
