// Dragnet [Ransomware]: dragnet-ransomware-2026-1998 — Mass File Rename (incransom)
// Status: test | Level: high | ID: bf9ac31f-3a98-54ea-a61f-721f0c2cd6a7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
