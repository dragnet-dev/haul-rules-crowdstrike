// Dragnet [Ransomware]: dragnet-ransomware-2023-2802 — Mass File Rename (malas)
// Status: experimental | Level: high | ID: 3f94c0f9-3baf-5914-ad36-b8bf4c99bdc0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
