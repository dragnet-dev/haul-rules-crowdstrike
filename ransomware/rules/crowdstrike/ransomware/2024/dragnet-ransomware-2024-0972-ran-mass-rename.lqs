// Dragnet [Ransomware]: dragnet-ransomware-2024-0972 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: ed45ac66-d64d-5186-8bda-4d0c1a668771

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
