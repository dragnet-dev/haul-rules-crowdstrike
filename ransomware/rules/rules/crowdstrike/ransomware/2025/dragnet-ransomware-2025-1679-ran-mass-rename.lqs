// Dragnet [Ransomware]: dragnet-ransomware-2025-1679 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 8b123bf1-ead4-5c80-822a-428f49083b2b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
