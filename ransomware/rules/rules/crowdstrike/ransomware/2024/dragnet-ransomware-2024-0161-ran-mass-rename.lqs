// Dragnet [Ransomware]: dragnet-ransomware-2024-0161 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 5b3aebf6-e9a6-5d6a-a0b8-6c64b7ba9a25

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
