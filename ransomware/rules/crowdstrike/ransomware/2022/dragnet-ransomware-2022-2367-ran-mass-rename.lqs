// Dragnet [Ransomware]: dragnet-ransomware-2022-2367 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 1046fe32-d2c4-59f6-90d2-cf1a53c33589

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
