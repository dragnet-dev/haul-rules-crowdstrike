// Dragnet [Ransomware]: dragnet-ransomware-2025-7173 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: 79640aff-35c4-50af-b541-221ab748160f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
