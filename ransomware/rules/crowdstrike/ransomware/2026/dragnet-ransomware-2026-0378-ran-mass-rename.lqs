// Dragnet [Ransomware]: dragnet-ransomware-2026-0378 — Mass File Rename (krybit)
// Status: stable | Level: high | ID: ce83b6ee-bd24-5e97-8e22-ffc1b5fd93b9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
