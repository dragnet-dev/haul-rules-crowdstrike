// Dragnet [Container]: dragnet-container-2026-2247 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 0f9acf47-1cfb-5f34-bb11-05027d7cff4b

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *photon os:3.0* OR ImageFileName = *photon os:4.0* OR ImageFileName = *ubuntu:18.04* OR ImageFileName = *ubuntu:18.04-ESM* OR ImageFileName = *ubuntu:20.04* OR ImageFileName = *ubuntu:20.04-ESM* OR ImageFileName = *ubuntu:22.04*)
| table([timestamp, ComputerName])
| limit(1000)
