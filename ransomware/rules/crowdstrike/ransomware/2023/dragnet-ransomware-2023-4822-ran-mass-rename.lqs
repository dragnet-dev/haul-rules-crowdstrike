// Dragnet [Ransomware]: dragnet-ransomware-2023-4822 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: f59dceab-fcd7-5eba-950b-fc2e9fc75e9e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
