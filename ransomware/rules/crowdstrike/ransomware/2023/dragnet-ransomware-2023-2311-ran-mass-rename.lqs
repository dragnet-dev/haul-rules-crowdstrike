// Dragnet [Ransomware]: dragnet-ransomware-2023-2311 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: e14314a3-a8dd-5a80-8901-f5b0c07bfdf4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
