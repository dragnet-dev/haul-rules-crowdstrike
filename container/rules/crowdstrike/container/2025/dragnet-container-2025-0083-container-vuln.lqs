// Dragnet [Container]: dragnet-container-2025-0083 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 9930fe9d-e044-56d8-96bf-824a553f89fd

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *photon os:2.0*)
| table([timestamp, ComputerName])
| limit(1000)
