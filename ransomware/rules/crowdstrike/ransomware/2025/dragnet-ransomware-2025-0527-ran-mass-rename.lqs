// Dragnet [Ransomware]: dragnet-ransomware-2025-0527 — Mass File Rename (AiLock)
// Status: deprecated | Level: high | ID: a6997e1e-5bfd-58df-a26e-019c337c553d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
