// Dragnet [Ransomware]: dragnet-ransomware-2021-1595 — Mass File Rename (darkside)
// Status: deprecated | Level: high | ID: cd81a79f-1dcd-5d65-8f13-92c4d9e89988

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
