// Dragnet [Ransomware]: dragnet-ransomware-2022-1198 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: adf727d3-c4c4-535c-b04d-ec660c9ff0de

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
