// Dragnet [Ransomware]: dragnet-ransomware-2022-2262 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 64383d68-9bfb-5432-a92c-ca33766da1f4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
