// Dragnet [Container]: dragnet-container-2026-0657 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 495f5af1-52bd-55f2-9933-396f718196bd

#event_simpleName=*
| (ImageFileName = *chainguard:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
