// Dragnet [Ransomware]: dragnet-ransomware-2023-3246 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: f84c36f8-aea7-5b85-a318-a24f77326438

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
