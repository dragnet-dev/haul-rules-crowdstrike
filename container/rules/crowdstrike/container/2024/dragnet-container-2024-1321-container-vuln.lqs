// Dragnet [Container]: dragnet-container-2024-1321 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 443609d8-26e5-5977-8522-4d52a3eca847

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
