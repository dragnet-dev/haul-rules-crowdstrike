// Dragnet [Container]: dragnet-container-2025-0252 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: afe8934e-f32e-5b0e-bc57-4689b8c6af9a

#event_simpleName=*
| (ImageFileName = *alpine:3.5* OR ImageFileName = *alpine:3.6* OR ImageFileName = *amazonlinux:1* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:8* OR ImageFileName = *debian:9* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:14.04-ESM* OR ImageFileName = *ubuntu:16.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
