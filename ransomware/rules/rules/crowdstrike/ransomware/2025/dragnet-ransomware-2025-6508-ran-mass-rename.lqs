// Dragnet [Ransomware]: dragnet-ransomware-2025-6508 — Mass File Rename (devman)
// Status: deprecated | Level: high | ID: 43f7298e-2f15-5792-95a6-0ebddf5c198e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
