// Dragnet [Ransomware]: dragnet-ransomware-2024-2886 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: fb68b95d-7805-5d52-a8f9-202889e6af8e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
