// Dragnet [Ransomware]: dragnet-ransomware-2024-4223 — Mass File Rename (safepay)
// Status: deprecated | Level: high | ID: 02adc529-c80c-5747-8fed-3ef1c43f413e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
