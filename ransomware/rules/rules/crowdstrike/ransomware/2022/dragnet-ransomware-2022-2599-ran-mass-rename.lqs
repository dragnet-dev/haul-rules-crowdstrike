// Dragnet [Ransomware]: dragnet-ransomware-2022-2599 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: a9c9e2ae-93f7-5515-854b-5dfd59a2f7a1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
