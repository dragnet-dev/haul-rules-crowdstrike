// Dragnet [Ransomware]: dragnet-ransomware-2023-3336 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: e218796e-e6d9-5cd5-9cf9-aa160dddad77

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
