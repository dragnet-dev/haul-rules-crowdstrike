// Dragnet [Ransomware]: dragnet-ransomware-2020-0069 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: cd5d093b-7473-5946-b000-10039f02a9f2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
