// Dragnet [Ransomware]: dragnet-ransomware-2022-0977 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 2874d9e5-5eac-5c76-9c9d-99f4e01a74bb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
