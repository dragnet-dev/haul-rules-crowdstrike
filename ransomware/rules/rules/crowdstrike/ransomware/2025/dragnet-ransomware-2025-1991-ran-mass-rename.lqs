// Dragnet [Ransomware]: dragnet-ransomware-2025-1991 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 98b0a69a-8793-5dec-8bcc-20f9219bb2d4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
