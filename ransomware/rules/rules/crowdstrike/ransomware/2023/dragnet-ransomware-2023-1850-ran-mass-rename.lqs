// Dragnet [Ransomware]: dragnet-ransomware-2023-1850 — Mass File Rename (royal)
// Status: experimental | Level: high | ID: b2f30caf-f574-5c97-baf9-cca1d657b225

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
