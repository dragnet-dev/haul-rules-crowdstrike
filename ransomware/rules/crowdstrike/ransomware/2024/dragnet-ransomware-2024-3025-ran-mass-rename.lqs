// Dragnet [Ransomware]: dragnet-ransomware-2024-3025 — Mass File Rename (play)
// Status: experimental | Level: high | ID: a8e8df62-8762-5456-95fe-89c8a21f4d2e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
