// Dragnet [Ransomware]: dragnet-ransomware-2023-0142 — Mass File Rename (royal)
// Status: experimental | Level: high | ID: 8773b797-4de5-53bc-85fc-059d5e498c46

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
