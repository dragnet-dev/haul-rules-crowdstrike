// Dragnet [Ransomware]: dragnet-ransomware-2025-1968 — Mass File Rename (termite)
// Status: experimental | Level: high | ID: 614ff0fd-5bf3-5c9c-b450-18341efaf283

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
