// Dragnet [Ransomware]: dragnet-ransomware-2025-3669 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: c3b100d1-4a38-5266-8b52-4ebe7dcd19df

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
