// Dragnet [Ransomware]: dragnet-ransomware-2025-2662 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: bc19bacb-a83c-5ff5-bba4-c95bb68507b6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
