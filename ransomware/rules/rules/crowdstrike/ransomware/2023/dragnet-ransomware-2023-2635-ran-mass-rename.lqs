// Dragnet [Ransomware]: dragnet-ransomware-2023-2635 — Mass File Rename (cuba)
// Status: experimental | Level: high | ID: 7f35cbc0-df06-5920-a15a-e9666d098959

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
