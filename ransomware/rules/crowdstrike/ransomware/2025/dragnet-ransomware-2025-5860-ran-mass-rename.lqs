// Dragnet [Ransomware]: dragnet-ransomware-2025-5860 — Mass File Rename (warlock)
// Status: deprecated | Level: high | ID: 7aa79ca4-22d0-5c00-8e8d-17e2c3a5549b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
