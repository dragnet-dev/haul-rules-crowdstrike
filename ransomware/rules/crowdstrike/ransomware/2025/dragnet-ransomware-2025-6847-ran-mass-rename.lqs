// Dragnet [Ransomware]: dragnet-ransomware-2025-6847 — Mass File Rename (global)
// Status: experimental | Level: high | ID: 5373528e-3a56-5aa4-92a1-54caecc74ad1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
