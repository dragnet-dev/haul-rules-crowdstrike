// Dragnet [Ransomware]: dragnet-ransomware-2025-5887 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: d7d3375d-b2af-5b83-bd18-166f04b4d427

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
