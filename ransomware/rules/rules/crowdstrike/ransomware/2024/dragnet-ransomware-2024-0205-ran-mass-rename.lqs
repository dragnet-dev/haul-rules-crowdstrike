// Dragnet [Ransomware]: dragnet-ransomware-2024-0205 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 9a85dcb4-1df0-5b70-ac48-adbd716dc522

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
