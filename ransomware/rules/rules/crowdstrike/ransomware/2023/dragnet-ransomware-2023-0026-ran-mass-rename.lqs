// Dragnet [Ransomware]: dragnet-ransomware-2023-0026 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 5303fa7f-c0d0-50e8-9b61-a19292beca5f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
