// Dragnet [Ransomware]: dragnet-ransomware-2022-1784 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: d29bf1fd-516a-5e39-ae50-8405466e3220

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
