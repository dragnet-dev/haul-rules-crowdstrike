// Dragnet [Ransomware]: dragnet-ransomware-2021-0684 — Mass File Rename (revil)
// Status: deprecated | Level: high | ID: 5be0e96c-6adf-56fe-8e99-4b17b360774c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
