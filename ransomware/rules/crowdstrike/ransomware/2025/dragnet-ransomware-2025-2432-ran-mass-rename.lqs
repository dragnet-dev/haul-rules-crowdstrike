// Dragnet [Ransomware]: dragnet-ransomware-2025-2432 — Mass File Rename (thegentlemen)
// Status: experimental | Level: high | ID: 9320ecc4-fe61-508f-80bf-d32b6cd8a2c0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
