// Dragnet [Ransomware]: dragnet-ransomware-2023-3060 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 315e16dc-9dc0-54b3-ad85-529174025bd8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
