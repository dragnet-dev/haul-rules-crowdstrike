// Dragnet [Ransomware]: dragnet-ransomware-2025-7479 — Mass File Rename (blacklock)
// Status: experimental | Level: high | ID: ed9c10cb-8d32-5331-bb2a-667b31e33b20

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
