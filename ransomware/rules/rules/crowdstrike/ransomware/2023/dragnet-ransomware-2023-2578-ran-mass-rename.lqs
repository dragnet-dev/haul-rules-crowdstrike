// Dragnet [Ransomware]: dragnet-ransomware-2023-2578 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 118e9b08-f22e-523c-b74c-97ebed593eb7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
