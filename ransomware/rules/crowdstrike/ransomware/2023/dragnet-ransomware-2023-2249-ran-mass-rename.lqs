// Dragnet [Ransomware]: dragnet-ransomware-2023-2249 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: b9bea0a5-89ed-5746-95ff-704f547be6da

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
