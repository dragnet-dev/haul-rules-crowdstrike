// Dragnet [Ransomware]: dragnet-ransomware-2024-5535 — Mass File Rename (blacklock)
// Status: experimental | Level: high | ID: 6110aee8-cc3e-5def-bfc3-58c522562b45

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
