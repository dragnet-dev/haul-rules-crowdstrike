// Dragnet [Ransomware]: dragnet-ransomware-2025-2740 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 446481f9-7769-5f1f-bebc-5003880392a6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
