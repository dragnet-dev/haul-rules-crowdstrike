// Dragnet [Ransomware]: dragnet-ransomware-2025-6020 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 2cca6019-0cc0-5b65-b86b-0d1beba6f52c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
