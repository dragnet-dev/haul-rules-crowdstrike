// Dragnet [Ransomware]: dragnet-ransomware-2024-1594 — Mass File Rename (ElDorado)
// Status: deprecated | Level: high | ID: 1d10f76f-2f6e-54a1-8493-7b688cb2bf48

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
