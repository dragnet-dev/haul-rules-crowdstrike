// Dragnet [Ransomware]: dragnet-ransomware-2024-4751 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: b7be23ce-743b-524d-acb4-01a12fef7385

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
