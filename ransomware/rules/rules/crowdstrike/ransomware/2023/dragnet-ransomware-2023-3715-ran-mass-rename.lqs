// Dragnet [Ransomware]: dragnet-ransomware-2023-3715 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: ec0bc77c-c641-57f9-bea7-e463655e73bf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
