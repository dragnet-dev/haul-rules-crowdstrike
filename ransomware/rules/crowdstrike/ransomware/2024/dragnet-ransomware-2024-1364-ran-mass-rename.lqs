// Dragnet [Ransomware]: dragnet-ransomware-2024-1364 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: 3da52432-5656-508e-963c-675281c8c1da

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
