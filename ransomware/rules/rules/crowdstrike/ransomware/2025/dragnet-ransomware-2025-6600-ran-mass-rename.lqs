// Dragnet [Ransomware]: dragnet-ransomware-2025-6600 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: de8c145a-9e4a-5109-b34c-b0e0c201eaaf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
