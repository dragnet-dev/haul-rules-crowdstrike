// Dragnet [Ransomware]: dragnet-ransomware-2023-4491 — Mass File Rename (ransomed)
// Status: deprecated | Level: high | ID: d4be03db-7a0d-5857-8f72-d0be8552f4c9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
