// Dragnet [Ransomware]: dragnet-ransomware-2024-4790 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: bd01dbed-c41f-5d54-be60-86b658f870af

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
