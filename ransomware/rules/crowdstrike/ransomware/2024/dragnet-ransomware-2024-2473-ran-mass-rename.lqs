// Dragnet [Ransomware]: dragnet-ransomware-2024-2473 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: f975a42c-bda0-5d30-ab8c-acfd5fd98c3e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
