// Dragnet [Ransomware]: dragnet-ransomware-2022-1354 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: ea742506-852d-5e2b-9d47-420cb3b24aea

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
