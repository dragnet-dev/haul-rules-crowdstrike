// Dragnet [Ransomware]: dragnet-ransomware-2024-1335 — Mass File Rename (cicada3301)
// Status: experimental | Level: high | ID: 3483e72d-f3f3-5b2a-8317-ae10b3ce1bdf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
