// Dragnet [Ransomware]: dragnet-ransomware-2025-3897 — Mass File Rename (warlock)
// Status: deprecated | Level: high | ID: 97f72c2d-1c87-50e8-b803-d66ec9331b91

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
