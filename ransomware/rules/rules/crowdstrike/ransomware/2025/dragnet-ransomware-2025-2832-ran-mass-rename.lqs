// Dragnet [Ransomware]: dragnet-ransomware-2025-2832 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 23f9a1f5-8a63-5794-9f8a-e2057f0836dd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
