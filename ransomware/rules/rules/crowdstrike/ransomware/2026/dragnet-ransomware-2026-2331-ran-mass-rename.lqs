// Dragnet [Ransomware]: dragnet-ransomware-2026-2331 — Mass File Rename (shadowbyt3$)
// Status: deprecated | Level: high | ID: f1c7dc3d-a436-57ac-bb9c-788e7e2d5354

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
