// Dragnet [Ransomware]: dragnet-ransomware-2022-1621 — Mass File Rename (royal)
// Status: deprecated | Level: high | ID: 8ddf4ae4-e9b1-57a8-859c-ce7a4148dc84

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
