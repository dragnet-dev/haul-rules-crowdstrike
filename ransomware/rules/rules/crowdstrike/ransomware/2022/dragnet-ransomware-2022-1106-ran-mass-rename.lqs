// Dragnet [Ransomware]: dragnet-ransomware-2022-1106 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 0d4097d6-f53d-5f6d-966d-e71a64d77494

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
