// Dragnet [Ransomware]: dragnet-ransomware-2020-0207 — Mass File Rename (revil)
// Status: deprecated | Level: high | ID: bdefa858-1d53-56bb-89b5-c8ad6480987a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
