// Dragnet [Ransomware]: dragnet-ransomware-2024-2155 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: c697038e-d291-5033-ba7b-8c08a06f22da

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
