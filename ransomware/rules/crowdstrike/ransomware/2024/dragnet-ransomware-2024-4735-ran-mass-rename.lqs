// Dragnet [Ransomware]: dragnet-ransomware-2024-4735 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 1796cf6d-6a22-5902-b45a-1cf5e9b14091

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
