// Dragnet [Container]: dragnet-container-2024-0563 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 77421077-e829-5969-bab2-e494c815074e

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
