// Dragnet [Ransomware]: dragnet-ransomware-2022-2119 — Mass File Rename (mindware)
// Status: deprecated | Level: high | ID: 1f7efe28-f24c-5580-b43c-1c09692a625e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
