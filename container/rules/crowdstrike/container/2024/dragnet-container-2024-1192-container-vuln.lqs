// Dragnet [Container]: dragnet-container-2024-1192 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: e1a00f4f-cd3d-5fba-98ba-044251681168

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:9*)
| table([timestamp, ComputerName])
| limit(1000)
