// Dragnet [Ransomware]: dragnet-ransomware-2024-4139 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: d6ea36d6-69f3-52f3-8903-40d1aec374e0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
