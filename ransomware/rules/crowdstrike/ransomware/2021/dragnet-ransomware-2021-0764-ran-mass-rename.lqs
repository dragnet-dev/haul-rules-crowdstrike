// Dragnet [Ransomware]: dragnet-ransomware-2021-0764 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 5efa825b-b7bd-571b-9af2-ef61f2a7d85f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
