// Dragnet [Ransomware]: dragnet-ransomware-2024-4537 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 42b8e199-eb2b-5cec-9a18-dac940ac3128

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
