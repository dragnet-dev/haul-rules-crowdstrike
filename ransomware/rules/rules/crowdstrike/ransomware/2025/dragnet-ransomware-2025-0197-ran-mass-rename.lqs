// Dragnet [Ransomware]: dragnet-ransomware-2025-0197 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: c4a412b0-0de0-5864-a2fe-8f605a5cc7fa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
