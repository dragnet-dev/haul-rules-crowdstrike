// Dragnet [Ransomware]: dragnet-ransomware-2023-1161 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 4cde4111-e79d-59a1-8087-3fa5ee5decaf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
