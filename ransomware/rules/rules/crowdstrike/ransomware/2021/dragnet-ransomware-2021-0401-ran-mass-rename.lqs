// Dragnet [Ransomware]: dragnet-ransomware-2021-0401 — Mass File Rename (doppelpaymer)
// Status: deprecated | Level: high | ID: e5f50414-9af2-5dab-8389-8801477a6c8d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
