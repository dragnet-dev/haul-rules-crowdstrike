// Dragnet [Ransomware]: dragnet-ransomware-2025-5637 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: cb4761cc-1efd-5b51-82d0-dee426f31b6f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
