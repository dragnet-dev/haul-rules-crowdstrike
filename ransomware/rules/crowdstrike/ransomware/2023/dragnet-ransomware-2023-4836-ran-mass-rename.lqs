// Dragnet [Ransomware]: dragnet-ransomware-2023-4836 — Mass File Rename (ElDorado)
// Status: deprecated | Level: high | ID: 70d2e4a4-1ff0-51d8-917d-e0e6486e488e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
