// Dragnet [Ransomware]: dragnet-ransomware-2024-6013 — Mass File Rename (sarcoma)
// Status: deprecated | Level: high | ID: 2621113d-eb02-58dd-ab08-d620435dc892

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
