// Dragnet [Ransomware]: dragnet-ransomware-2022-1004 — Mass File Rename (leaktheanalyst)
// Status: deprecated | Level: high | ID: 1d702139-a2fd-5011-9c3c-00b3f81b71fd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
