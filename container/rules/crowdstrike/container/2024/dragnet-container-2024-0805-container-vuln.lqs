// Dragnet [Container]: dragnet-container-2024-0805 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: a2b2cd04-4be8-5c59-8108-75c3c062b06f

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:8* OR ImageFileName = *debian:9* OR ImageFileName = *ubuntu:18.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
