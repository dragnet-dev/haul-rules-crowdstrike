// Dragnet [Ransomware]: dragnet-ransomware-2022-1267 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 5f88b004-7125-5b78-9470-0b0b695a3bc5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
