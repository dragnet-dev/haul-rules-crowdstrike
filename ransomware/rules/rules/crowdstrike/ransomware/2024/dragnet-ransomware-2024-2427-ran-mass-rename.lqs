// Dragnet [Ransomware]: dragnet-ransomware-2024-2427 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: a2082af8-73d9-5773-b4cd-6ec98ee0c01f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
