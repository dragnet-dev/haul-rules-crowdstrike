// Dragnet [Ransomware]: dragnet-ransomware-2025-5112 — Mass File Rename (worldleaks)
// Status: test | Level: high | ID: 77e07a8f-3574-5bda-9a50-f0f6cede7727

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
