// Dragnet [Ransomware]: dragnet-ransomware-2024-1704 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 2f2025da-7d3c-5803-b589-498b98786a15

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
