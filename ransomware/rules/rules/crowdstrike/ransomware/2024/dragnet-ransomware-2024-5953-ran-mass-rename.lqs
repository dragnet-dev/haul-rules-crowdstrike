// Dragnet [Ransomware]: dragnet-ransomware-2024-5953 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: 9b7d3f95-b89e-52d5-9127-8e8e4d3c74f0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
