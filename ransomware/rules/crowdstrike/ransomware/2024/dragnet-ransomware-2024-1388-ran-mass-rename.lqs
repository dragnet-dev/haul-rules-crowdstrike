// Dragnet [Ransomware]: dragnet-ransomware-2024-1388 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: ba7c7203-70a9-5933-a2dc-0e144e885b06

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
