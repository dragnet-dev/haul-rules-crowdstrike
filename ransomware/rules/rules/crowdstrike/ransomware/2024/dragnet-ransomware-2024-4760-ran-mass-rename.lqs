// Dragnet [Ransomware]: dragnet-ransomware-2024-4760 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 5eec0f7c-a037-5798-b9a4-3d0519d86b3f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
