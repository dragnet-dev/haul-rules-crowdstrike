// Dragnet [Ransomware]: dragnet-ransomware-2024-1128 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 4c62b79d-8808-56c4-8f4f-7fcf81407b5d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
