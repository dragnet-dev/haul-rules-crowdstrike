// Dragnet [Ransomware]: dragnet-ransomware-2022-0213 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: f7685ba0-5a7d-5ee4-97b5-6be6e29b142d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
