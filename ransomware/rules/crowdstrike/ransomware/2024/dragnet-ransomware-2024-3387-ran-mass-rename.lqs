// Dragnet [Ransomware]: dragnet-ransomware-2024-3387 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: ffc9f0bb-8e75-532a-916b-e2ce971d6afb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
