// Dragnet [Ransomware]: dragnet-ransomware-2025-6969 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 66eb1571-c138-5e52-b66c-a509a5ac666b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
