// Dragnet [Ransomware]: dragnet-ransomware-2023-2940 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 4d775ee3-1c21-5652-ac61-add91b4ba694

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
