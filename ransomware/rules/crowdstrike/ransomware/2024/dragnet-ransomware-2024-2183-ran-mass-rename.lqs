// Dragnet [Ransomware]: dragnet-ransomware-2024-2183 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: 9fe76616-a6e6-570d-973d-b0bbe9c7045b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
