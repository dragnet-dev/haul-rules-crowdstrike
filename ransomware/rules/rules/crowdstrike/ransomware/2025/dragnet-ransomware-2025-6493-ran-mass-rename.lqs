// Dragnet [Ransomware]: dragnet-ransomware-2025-6493 — Mass File Rename (sinobi)
// Status: experimental | Level: high | ID: 1bece654-b0f0-50b3-9955-052bf47b23d3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
