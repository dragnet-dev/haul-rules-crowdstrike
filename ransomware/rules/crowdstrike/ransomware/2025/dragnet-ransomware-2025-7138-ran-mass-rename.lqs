// Dragnet [Ransomware]: dragnet-ransomware-2025-7138 — Mass File Rename (global)
// Status: deprecated | Level: high | ID: f83899cb-77db-5caa-901f-4a21a9e26210

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
