// Dragnet [Ransomware]: dragnet-ransomware-2024-3277 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: d5477918-6c5c-5823-8ceb-6a53f0600610

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
