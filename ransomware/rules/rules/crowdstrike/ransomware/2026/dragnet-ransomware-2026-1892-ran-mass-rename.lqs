// Dragnet [Ransomware]: dragnet-ransomware-2026-1892 — Mass File Rename (incransom)
// Status: test | Level: high | ID: 0175b207-024e-55ff-8164-7aadb95c3740

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
