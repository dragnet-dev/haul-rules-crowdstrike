// Dragnet [Ransomware]: dragnet-ransomware-2021-1010 — Mass File Rename (ragnarlocker)
// Status: deprecated | Level: high | ID: d4bd0e1c-ca99-5533-bcb2-0dbe5f1013f5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
