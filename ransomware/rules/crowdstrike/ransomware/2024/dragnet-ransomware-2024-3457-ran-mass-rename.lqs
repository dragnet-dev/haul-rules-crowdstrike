// Dragnet [Ransomware]: dragnet-ransomware-2024-3457 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: 03dc23ee-d91d-59b2-a882-5a4ed975a0f9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
