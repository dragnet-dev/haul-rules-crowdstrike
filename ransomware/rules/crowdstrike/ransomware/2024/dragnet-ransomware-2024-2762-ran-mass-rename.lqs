// Dragnet [Ransomware]: dragnet-ransomware-2024-2762 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 59c89142-f896-5792-914d-0d99dd20270b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
