// Dragnet [Ransomware]: dragnet-ransomware-2023-4236 — Mass File Rename (noescape)
// Status: experimental | Level: high | ID: 6b34177c-76b2-5f16-9e19-b0f038e4fe12

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
