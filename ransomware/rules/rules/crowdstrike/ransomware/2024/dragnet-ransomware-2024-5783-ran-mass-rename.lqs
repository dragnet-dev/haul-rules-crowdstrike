// Dragnet [Ransomware]: dragnet-ransomware-2024-5783 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 2c773bc6-39e0-5d41-add1-bc5e7bbe559b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
