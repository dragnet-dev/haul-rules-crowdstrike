// Dragnet [Ransomware]: dragnet-ransomware-2025-5394 — Mass File Rename (play)
// Status: experimental | Level: high | ID: b22bb0d2-34c5-5235-9035-26d3ed158e98

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
