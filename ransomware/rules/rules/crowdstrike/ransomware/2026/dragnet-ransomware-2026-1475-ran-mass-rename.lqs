// Dragnet [Ransomware]: dragnet-ransomware-2026-1475 — Mass File Rename (incransom)
// Status: stable | Level: high | ID: 81f326ec-ea17-5d16-86cd-552c74ef4f0a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
