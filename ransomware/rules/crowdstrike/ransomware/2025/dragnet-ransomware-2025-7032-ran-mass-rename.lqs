// Dragnet [Ransomware]: dragnet-ransomware-2025-7032 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 4400cfd8-55f0-5427-8519-df87d765105a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
