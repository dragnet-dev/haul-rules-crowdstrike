// Dragnet [Ransomware]: dragnet-ransomware-2024-0957 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: 03332c17-b0bb-5720-8844-bf8e534fb7ed

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
