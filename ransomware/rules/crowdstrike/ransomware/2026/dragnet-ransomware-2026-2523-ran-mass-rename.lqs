// Dragnet [Ransomware]: dragnet-ransomware-2026-2523 — Mass File Rename (payload)
// Status: stable | Level: high | ID: 1041eb8f-6fac-5549-8dcd-c9115ff1b7ec

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
