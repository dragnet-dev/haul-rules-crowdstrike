// Dragnet [Ransomware]: dragnet-ransomware-2023-2794 — Mass File Rename (malas)
// Status: experimental | Level: high | ID: 62796634-7b29-566f-a2fd-2c03ebbb9543

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
