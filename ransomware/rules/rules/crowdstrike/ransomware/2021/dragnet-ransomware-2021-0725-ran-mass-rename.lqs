// Dragnet [Ransomware]: dragnet-ransomware-2021-0725 — Mass File Rename (midas)
// Status: deprecated | Level: high | ID: 913f1d3d-379a-54da-8e1d-269715bf5bc0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
