// Dragnet [Ransomware]: dragnet-ransomware-2025-6862 — Mass File Rename (pear)
// Status: experimental | Level: high | ID: 1e28ac4c-3fcc-5d9f-ae5f-495ec95d3990

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
