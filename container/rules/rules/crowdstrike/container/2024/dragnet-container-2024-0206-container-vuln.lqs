// Dragnet [Container]: dragnet-container-2024-0206 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: a51b0301-f2c4-546c-9fd4-df6bf568d27b

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
