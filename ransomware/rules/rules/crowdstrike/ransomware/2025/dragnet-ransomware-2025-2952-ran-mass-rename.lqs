// Dragnet [Ransomware]: dragnet-ransomware-2025-2952 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 99ace9d6-807c-552a-9169-c62e791dec99

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
