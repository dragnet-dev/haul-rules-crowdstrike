// Dragnet [Ransomware]: dragnet-ransomware-2026-1204 — Mass File Rename (dragonforce)
// Status: stable | Level: high | ID: 9c525947-e12b-5433-af08-69cc6bee8c01

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
