// Dragnet [Ransomware]: dragnet-ransomware-2023-1748 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 55350758-cb51-593c-b817-3e7da99129e2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
