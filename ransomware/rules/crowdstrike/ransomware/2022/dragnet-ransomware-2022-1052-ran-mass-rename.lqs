// Dragnet [Ransomware]: dragnet-ransomware-2022-1052 — Mass File Rename (karakurt)
// Status: deprecated | Level: high | ID: 171e26d4-0a58-51a8-9cab-7a5c97060253

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
