// Dragnet [Ransomware]: dragnet-ransomware-2023-2686 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 4f712fdd-d93a-5325-838a-3ceaeea75dcb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
