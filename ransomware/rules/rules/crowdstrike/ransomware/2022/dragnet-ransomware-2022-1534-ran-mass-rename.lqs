// Dragnet [Ransomware]: dragnet-ransomware-2022-1534 — Mass File Rename (cheers)
// Status: deprecated | Level: high | ID: c1acb86a-87e7-5cb0-9ed3-1803d403307c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
