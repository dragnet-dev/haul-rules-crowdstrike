// Dragnet [Ransomware]: dragnet-ransomware-2021-1800 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: edbb5c7e-030d-51b3-b4f3-f4329d5593ad

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
