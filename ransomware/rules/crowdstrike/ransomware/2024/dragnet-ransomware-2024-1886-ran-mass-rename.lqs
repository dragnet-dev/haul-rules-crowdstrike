// Dragnet [Ransomware]: dragnet-ransomware-2024-1886 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 2e11ff08-0f1a-515b-924a-02f809bcf1ef

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
