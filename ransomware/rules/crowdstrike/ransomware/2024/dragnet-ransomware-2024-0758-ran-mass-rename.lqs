// Dragnet [Ransomware]: dragnet-ransomware-2024-0758 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 98915203-9a4a-5f30-91d4-ec5d90776780

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
