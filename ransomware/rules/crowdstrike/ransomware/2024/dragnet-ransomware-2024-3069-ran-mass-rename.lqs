// Dragnet [Ransomware]: dragnet-ransomware-2024-3069 — Mass File Rename (darkvault)
// Status: experimental | Level: high | ID: 8c8cf60e-88f7-5d27-ac83-27179b6451cd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
