// Dragnet [Ransomware]: dragnet-ransomware-2025-2381 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 3161bb13-c83e-5b66-8dfb-f2f24f925888

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
