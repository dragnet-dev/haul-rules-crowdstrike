// Dragnet [Ransomware]: dragnet-ransomware-2022-2891 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 66f77e0a-e50a-5ca1-b0af-15a594c5007a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
