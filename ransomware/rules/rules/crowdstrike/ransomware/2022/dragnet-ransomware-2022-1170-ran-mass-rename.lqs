// Dragnet [Ransomware]: dragnet-ransomware-2022-1170 — Mass File Rename (lapsus$)
// Status: deprecated | Level: high | ID: d33b2e90-472c-582a-9545-b757bfd65658

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
