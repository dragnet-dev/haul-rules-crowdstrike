// Dragnet [Ransomware]: dragnet-ransomware-2023-3633 — Mass File Rename (monti)
// Status: experimental | Level: high | ID: 2e908266-49a8-5a02-b8c2-5a1cfeceff16

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
