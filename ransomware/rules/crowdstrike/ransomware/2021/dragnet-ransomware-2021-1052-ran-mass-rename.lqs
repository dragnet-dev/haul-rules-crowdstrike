// Dragnet [Ransomware]: dragnet-ransomware-2021-1052 — Mass File Rename (midas)
// Status: deprecated | Level: high | ID: 69130e96-0a38-58f1-8863-9151b259ceb5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
