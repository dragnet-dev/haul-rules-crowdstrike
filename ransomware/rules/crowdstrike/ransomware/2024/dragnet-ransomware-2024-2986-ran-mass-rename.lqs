// Dragnet [Ransomware]: dragnet-ransomware-2024-2986 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: ce2f5cab-2171-5277-8130-cc1d6ffcbb06

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
