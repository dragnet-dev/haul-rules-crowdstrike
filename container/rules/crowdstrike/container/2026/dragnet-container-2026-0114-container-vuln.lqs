// Dragnet [Container]: dragnet-container-2026-0114 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: e3320248-0490-52cf-9bcd-c019ebd153ad

#event_simpleName=*
| (ImageFileName = *chainguard:* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:20.04* OR ImageFileName = *ubuntu:22.04* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
