// Dragnet [Ransomware]: dragnet-ransomware-2024-4268 — Mass File Rename (stormous)
// Status: experimental | Level: high | ID: 1b3537fd-b8df-5d6d-bdcb-535a6d338a25

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
