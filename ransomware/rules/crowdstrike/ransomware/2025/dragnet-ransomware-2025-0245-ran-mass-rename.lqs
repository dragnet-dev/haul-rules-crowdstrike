// Dragnet [Ransomware]: dragnet-ransomware-2025-0245 — Mass File Rename (nitrogen)
// Status: test | Level: high | ID: b31619fd-818e-5d86-9259-bbc911fe7491

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
