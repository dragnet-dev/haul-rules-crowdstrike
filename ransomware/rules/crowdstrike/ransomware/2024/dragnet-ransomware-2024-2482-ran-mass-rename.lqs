// Dragnet [Ransomware]: dragnet-ransomware-2024-2482 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: afd2d1dc-903c-5363-8480-ff6ac6c31510

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
