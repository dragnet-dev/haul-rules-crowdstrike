// Dragnet [Ransomware]: dragnet-ransomware-2021-1303 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 009e7b0a-b4a8-5d91-9163-9bdd39b19729

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
