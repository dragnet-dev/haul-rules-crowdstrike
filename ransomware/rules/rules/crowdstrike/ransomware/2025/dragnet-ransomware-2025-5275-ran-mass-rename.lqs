// Dragnet [Ransomware]: dragnet-ransomware-2025-5275 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: ce561a2b-aa49-50f6-ae6e-5287da54fa0a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
