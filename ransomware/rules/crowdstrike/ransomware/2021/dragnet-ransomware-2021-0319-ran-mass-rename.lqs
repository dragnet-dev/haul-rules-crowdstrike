// Dragnet [Ransomware]: dragnet-ransomware-2021-0319 — Mass File Rename (doppelpaymer)
// Status: deprecated | Level: high | ID: 6e2c39e7-6cea-53ce-9a47-a36dbd967ef8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
