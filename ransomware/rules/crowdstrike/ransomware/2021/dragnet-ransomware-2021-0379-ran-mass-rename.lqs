// Dragnet [Ransomware]: dragnet-ransomware-2021-0379 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: b91a764c-3b0b-57ef-b90f-6b83aeed1a7c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
