// Dragnet [Ransomware]: dragnet-ransomware-2022-1672 — Mass File Rename (royal)
// Status: deprecated | Level: high | ID: 01e1e360-cab5-5211-a3da-a9d1b9d75c6e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
