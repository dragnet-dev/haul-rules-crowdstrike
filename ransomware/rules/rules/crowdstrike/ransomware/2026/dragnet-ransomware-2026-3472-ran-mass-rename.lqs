// Dragnet [Ransomware]: dragnet-ransomware-2026-3472 — Mass File Rename (dragonforce)
// Status: stable | Level: high | ID: 49879e77-16e0-582a-b0db-4fedcfeb5315

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
