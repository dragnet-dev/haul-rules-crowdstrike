// Dragnet [Ransomware]: dragnet-ransomware-2025-2045 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 69f25365-47f1-5c9f-9735-f835d744262c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
