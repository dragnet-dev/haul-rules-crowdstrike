// Dragnet [Ransomware]: dragnet-ransomware-2025-0599 — Mass File Rename (interlock)
// Status: experimental | Level: high | ID: d786637e-0264-58fd-9632-8f96eeeb5974

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
