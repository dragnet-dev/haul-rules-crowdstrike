// Dragnet [Ransomware]: dragnet-ransomware-2025-6348 — Mass File Rename (monti)
// Status: experimental | Level: high | ID: 6a871f37-6cb9-5a06-b8f8-91b189149de4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
