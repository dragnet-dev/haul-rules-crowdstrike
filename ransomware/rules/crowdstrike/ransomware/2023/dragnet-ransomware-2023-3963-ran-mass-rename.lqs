// Dragnet [Ransomware]: dragnet-ransomware-2023-3963 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 6d6be457-ad85-50fb-b2e0-77753579f2c0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
