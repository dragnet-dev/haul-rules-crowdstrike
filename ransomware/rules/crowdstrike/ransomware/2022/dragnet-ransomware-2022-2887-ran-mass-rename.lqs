// Dragnet [Ransomware]: dragnet-ransomware-2022-2887 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 68fcb1a8-628f-5e1a-b8ab-1730387ba7f4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
