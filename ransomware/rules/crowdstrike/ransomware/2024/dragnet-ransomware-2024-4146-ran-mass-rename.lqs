// Dragnet [Ransomware]: dragnet-ransomware-2024-4146 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: 56a74b41-1142-5b42-ac5c-c7d21dae390c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
