// Dragnet [Ransomware]: dragnet-ransomware-2021-1369 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: cca39c8f-2fa6-5c7b-b8a6-7155201fe08b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
