// Dragnet [Ransomware]: dragnet-ransomware-2024-4309 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 54936593-994c-544b-a7d7-666630890753

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
