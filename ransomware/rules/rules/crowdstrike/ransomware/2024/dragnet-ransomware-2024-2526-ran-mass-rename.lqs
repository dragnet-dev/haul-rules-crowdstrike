// Dragnet [Ransomware]: dragnet-ransomware-2024-2526 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 767d4446-d6af-5f53-a55f-264c6c1f0f58

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
