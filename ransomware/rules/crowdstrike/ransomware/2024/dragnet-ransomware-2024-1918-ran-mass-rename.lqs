// Dragnet [Ransomware]: dragnet-ransomware-2024-1918 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: c5a155ac-f050-58e6-aac2-35f033b00096

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
