// Dragnet [Ransomware]: dragnet-ransomware-2021-1555 — Mass File Rename (suncrypt)
// Status: deprecated | Level: high | ID: c51209e5-2712-5954-8d67-28e61d6b47f2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
