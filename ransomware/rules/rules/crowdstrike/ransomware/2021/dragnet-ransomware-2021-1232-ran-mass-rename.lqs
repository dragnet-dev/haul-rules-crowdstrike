// Dragnet [Ransomware]: dragnet-ransomware-2021-1232 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: dd70eea9-dd2d-54c5-8ce4-65f8c9d0c5f4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
