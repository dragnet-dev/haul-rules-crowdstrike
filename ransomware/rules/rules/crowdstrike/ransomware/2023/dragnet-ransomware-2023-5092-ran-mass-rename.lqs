// Dragnet [Ransomware]: dragnet-ransomware-2023-5092 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: c87277a9-b54f-5c2c-9982-643fb3c45197

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
