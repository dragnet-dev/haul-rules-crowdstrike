// Dragnet [Ransomware]: dragnet-ransomware-2026-2358 — Mass File Rename (osiris)
// Status: deprecated | Level: high | ID: 59f67657-65e7-5161-98e2-d5f46387b54a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
