// Dragnet [Ransomware]: dragnet-ransomware-2023-2377 — Mass File Rename (play)
// Status: experimental | Level: high | ID: b2059c83-c2e0-57a1-bc9a-4a541ca1a670

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
