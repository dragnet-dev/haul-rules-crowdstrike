// Dragnet [Ransomware]: dragnet-ransomware-2025-4587 — Mass File Rename (flocker)
// Status: experimental | Level: high | ID: fabbaaff-2d96-5a48-bccf-2866a4ccc43d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
