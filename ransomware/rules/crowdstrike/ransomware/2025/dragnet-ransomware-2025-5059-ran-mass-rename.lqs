// Dragnet [Ransomware]: dragnet-ransomware-2025-5059 — Mass File Rename (worldleaks)
// Status: experimental | Level: high | ID: 820d6818-b8ab-566c-84a9-156efacbd62b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
