// Dragnet [Ransomware]: dragnet-ransomware-2022-2366 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: fdb362fe-0e6d-504c-b21a-62f0ebac4673

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
