// Dragnet [Ransomware]: dragnet-ransomware-2023-3582 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 1db6881b-0018-54ab-a5cf-baa723f0f427

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
