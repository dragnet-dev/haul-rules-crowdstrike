// Dragnet [Ransomware]: dragnet-ransomware-2024-3688 — Mass File Rename (cloak)
// Status: deprecated | Level: high | ID: 3da95029-3bc7-5904-9d7d-364157bbcec1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
