// Dragnet [Ransomware]: dragnet-ransomware-2025-1194 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 289dd92b-a820-54be-b5a8-1ca018424cdd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
