// Dragnet [Ransomware]: dragnet-ransomware-2025-6498 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: cccf2ddd-6447-5f42-897d-d62fab1b9ee0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
