// Dragnet [Ransomware]: dragnet-ransomware-2023-3639 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 52960749-26bc-5eb8-b924-7684f03e266b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
