// Dragnet [Ransomware]: dragnet-ransomware-2024-3165 — Mass File Rename (ransomexx)
// Status: experimental | Level: high | ID: 5a6be128-dbf7-5c09-a671-be3d997a06ae

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
