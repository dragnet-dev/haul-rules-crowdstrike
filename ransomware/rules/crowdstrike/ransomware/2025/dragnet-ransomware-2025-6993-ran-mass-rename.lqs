// Dragnet [Ransomware]: dragnet-ransomware-2025-6993 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: ff851082-1569-5694-a044-bc5502195d97

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
