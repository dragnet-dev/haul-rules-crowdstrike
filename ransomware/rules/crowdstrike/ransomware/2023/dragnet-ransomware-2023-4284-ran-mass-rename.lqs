// Dragnet [Ransomware]: dragnet-ransomware-2023-4284 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: c5ba8722-3532-5e1f-a41b-f28f4a77cc0b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
