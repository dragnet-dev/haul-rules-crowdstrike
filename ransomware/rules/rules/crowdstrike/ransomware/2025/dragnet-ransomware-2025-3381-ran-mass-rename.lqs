// Dragnet [Ransomware]: dragnet-ransomware-2025-3381 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 29126f13-7230-5040-9eb8-e363061f63c9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
