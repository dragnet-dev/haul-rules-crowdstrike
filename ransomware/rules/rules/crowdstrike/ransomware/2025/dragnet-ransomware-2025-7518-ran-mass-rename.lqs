// Dragnet [Ransomware]: dragnet-ransomware-2025-7518 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 15e4ba8a-afda-565e-a4bf-d718a7834976

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
