// Dragnet [Container]: dragnet-container-2026-1405 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 542d42ce-d880-5adf-ae7d-d7d26cac721c

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:5*)
| table([timestamp, ComputerName])
| limit(1000)
