// Dragnet [Ransomware]: dragnet-ransomware-2025-6896 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 52cc6fd6-4b50-580f-b32f-b2a145c8efe4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
