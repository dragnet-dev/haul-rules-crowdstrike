// Dragnet [Ransomware]: dragnet-ransomware-2024-0198 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 10601e51-ae46-5dae-bb5a-3bd5f981d208

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
