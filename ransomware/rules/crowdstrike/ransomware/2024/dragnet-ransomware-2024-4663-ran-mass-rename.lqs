// Dragnet [Ransomware]: dragnet-ransomware-2024-4663 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: b44b89fc-f318-5f4d-a010-fd08a08ae949

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
