// Dragnet [Ransomware]: dragnet-ransomware-2022-0395 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 17b725b2-49c8-5ff7-9f29-78e0a3e09507

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
