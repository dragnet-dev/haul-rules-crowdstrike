// Dragnet [Ransomware]: dragnet-ransomware-2025-2478 — Mass File Rename (thegentlemen)
// Status: experimental | Level: high | ID: 98afc5d9-df0b-52a7-afb0-7b7dece7d6c8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
