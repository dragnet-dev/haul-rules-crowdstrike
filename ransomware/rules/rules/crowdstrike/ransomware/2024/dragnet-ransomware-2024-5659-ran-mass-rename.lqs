// Dragnet [Ransomware]: dragnet-ransomware-2024-5659 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: ab5bdf06-8a3c-5573-90e3-0b87bf9bc9a2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
