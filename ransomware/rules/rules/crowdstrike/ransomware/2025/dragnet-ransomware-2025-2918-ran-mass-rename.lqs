// Dragnet [Ransomware]: dragnet-ransomware-2025-2918 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: 17d10cf6-1061-5d70-acb0-2ff735593ca4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
