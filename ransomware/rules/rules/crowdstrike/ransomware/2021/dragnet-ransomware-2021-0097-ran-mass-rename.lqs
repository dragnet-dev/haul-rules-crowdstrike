// Dragnet [Ransomware]: dragnet-ransomware-2021-0097 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 227df685-8985-5274-b975-5930c34bd12a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
