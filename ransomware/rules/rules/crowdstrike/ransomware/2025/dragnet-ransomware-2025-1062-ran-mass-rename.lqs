// Dragnet [Ransomware]: dragnet-ransomware-2025-1062 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 41212dfc-f58e-5d59-a202-cda2396aa672

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
