// Dragnet [Ransomware]: dragnet-ransomware-2025-3323 — Mass File Rename (arkana)
// Status: deprecated | Level: high | ID: 9b2ef87f-98d6-50d7-bb69-6d04d92bd791

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
