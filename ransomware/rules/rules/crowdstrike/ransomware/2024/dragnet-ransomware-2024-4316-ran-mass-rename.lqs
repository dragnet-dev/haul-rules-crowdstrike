// Dragnet [Ransomware]: dragnet-ransomware-2024-4316 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 6cffeb52-89cb-549e-8305-3ac6b2ca0a83

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
