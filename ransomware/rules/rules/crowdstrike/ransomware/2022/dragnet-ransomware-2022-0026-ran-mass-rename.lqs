// Dragnet [Ransomware]: dragnet-ransomware-2022-0026 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 8c7072b9-ca61-5343-89f6-14e147a33fba

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
