// Dragnet [Ransomware]: dragnet-ransomware-2025-4267 — Mass File Rename (direwolf)
// Status: experimental | Level: high | ID: 9c2042eb-7ff2-5250-b699-eb64f535239a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
