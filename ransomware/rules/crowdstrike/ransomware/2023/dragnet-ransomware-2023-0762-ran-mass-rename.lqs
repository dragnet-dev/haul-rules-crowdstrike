// Dragnet [Ransomware]: dragnet-ransomware-2023-0762 — Mass File Rename (medusalocker)
// Status: experimental | Level: high | ID: 89d5937c-09d2-50b6-b14b-603f0031280d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
