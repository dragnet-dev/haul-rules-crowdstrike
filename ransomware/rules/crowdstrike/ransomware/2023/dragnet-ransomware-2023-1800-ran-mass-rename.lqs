// Dragnet [Ransomware]: dragnet-ransomware-2023-1800 — Mass File Rename (noescape)
// Status: experimental | Level: high | ID: be65c076-8829-5bbc-92f0-d343c5ec7d92

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
