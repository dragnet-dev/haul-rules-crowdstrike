// Dragnet [Ransomware]: dragnet-ransomware-2023-0545 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 970d304e-5d40-54cb-a676-393476548956

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
