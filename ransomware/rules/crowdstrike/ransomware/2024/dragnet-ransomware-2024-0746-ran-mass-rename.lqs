// Dragnet [Ransomware]: dragnet-ransomware-2024-0746 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 4fcf57ff-634e-5269-bfbb-e1820a740c50

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
