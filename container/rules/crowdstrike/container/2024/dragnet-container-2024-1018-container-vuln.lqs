// Dragnet [Container]: dragnet-container-2024-1018 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: cc45c2b3-d934-58af-af2a-9cdeca920b3b

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
