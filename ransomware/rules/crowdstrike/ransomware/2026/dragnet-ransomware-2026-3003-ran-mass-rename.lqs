// Dragnet [Ransomware]: dragnet-ransomware-2026-3003 — Mass File Rename (incransom)
// Status: stable | Level: high | ID: 0c8efb61-a728-5f9e-83d1-933eb81ea6a7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
