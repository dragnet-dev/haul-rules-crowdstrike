// Dragnet [Ransomware]: dragnet-ransomware-2025-0874 — Mass File Rename (direwolf)
// Status: experimental | Level: high | ID: 09150a65-78a3-5eeb-ba08-b661a184bcc6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
