// Dragnet [Ransomware]: dragnet-ransomware-2026-1943 — Mass File Rename (incransom)
// Status: stable | Level: high | ID: d5cec244-2ecc-5d01-ae44-2e14aab6b8f2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
