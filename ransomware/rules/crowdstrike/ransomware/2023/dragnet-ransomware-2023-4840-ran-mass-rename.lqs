// Dragnet [Ransomware]: dragnet-ransomware-2023-4840 — Mass File Rename (cryptbb)
// Status: experimental | Level: high | ID: 25baf5c3-e978-5e1d-921f-25b7ed6dd82f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
