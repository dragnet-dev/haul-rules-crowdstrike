// Dragnet [Ransomware]: dragnet-ransomware-2025-3009 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 54e358df-bd8e-5ac7-9d3f-399abbd15ae0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
