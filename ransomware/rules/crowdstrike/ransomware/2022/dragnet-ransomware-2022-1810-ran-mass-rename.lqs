// Dragnet [Ransomware]: dragnet-ransomware-2022-1810 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: ba4d663e-a10e-56c1-a488-18bc880c7009

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
