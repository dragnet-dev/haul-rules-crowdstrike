// Dragnet [Ransomware]: dragnet-ransomware-2025-7458 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 12f73275-fe03-54e5-8de2-42c0ad32a374

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
