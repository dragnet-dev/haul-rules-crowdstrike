// Dragnet [Ransomware]: dragnet-ransomware-2025-2159 — Mass File Rename (incransom)
// Status: test | Level: high | ID: ac1bfcb5-748c-579c-ac5d-568cdfb5351b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
