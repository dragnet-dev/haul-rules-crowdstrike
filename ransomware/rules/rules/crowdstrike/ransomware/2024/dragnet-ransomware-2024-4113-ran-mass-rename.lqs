// Dragnet [Ransomware]: dragnet-ransomware-2024-4113 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: 8850529e-bb81-5fa5-8ffe-30775aa685f7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
