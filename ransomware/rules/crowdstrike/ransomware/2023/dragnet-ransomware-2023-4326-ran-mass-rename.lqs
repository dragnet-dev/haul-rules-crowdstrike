// Dragnet [Ransomware]: dragnet-ransomware-2023-4326 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 433194aa-d79e-5a4f-9006-4d657bd2a6a2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
