// Dragnet [Ransomware]: dragnet-ransomware-2025-7084 — Mass File Rename (nova)
// Status: experimental | Level: high | ID: 646de7b0-459d-5055-9320-747b226ad0d0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
