// Dragnet [Ransomware]: dragnet-ransomware-2023-4386 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: b0019257-e6d3-5e35-994c-16ba6911631f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
