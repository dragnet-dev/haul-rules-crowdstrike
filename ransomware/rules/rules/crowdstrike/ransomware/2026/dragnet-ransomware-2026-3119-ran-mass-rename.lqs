// Dragnet [Ransomware]: dragnet-ransomware-2026-3119 — Mass File Rename (sinobi)
// Status: stable | Level: high | ID: c308c395-3d91-5ad6-a936-1b03d1f48a4b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
