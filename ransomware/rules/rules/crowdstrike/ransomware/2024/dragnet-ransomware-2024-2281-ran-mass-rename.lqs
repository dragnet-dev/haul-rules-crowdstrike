// Dragnet [Ransomware]: dragnet-ransomware-2024-2281 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: f2630700-e50e-5a05-a176-c2d49405bf18

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
