// Dragnet [Ransomware]: dragnet-ransomware-2025-0248 — Mass File Rename (stormous)
// Status: experimental | Level: high | ID: 50febb13-b7ff-5cd9-a4b2-60c0db1657a3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
