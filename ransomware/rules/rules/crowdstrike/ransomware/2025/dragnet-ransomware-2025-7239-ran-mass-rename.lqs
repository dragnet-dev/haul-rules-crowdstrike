// Dragnet [Ransomware]: dragnet-ransomware-2025-7239 — Mass File Rename (sinobi)
// Status: experimental | Level: high | ID: ba4f13aa-5102-526d-ab73-1ed8743d13a1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
