// Dragnet [Ransomware]: dragnet-ransomware-2023-4737 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 681172f3-b708-5af4-8f9b-b6319ebe991a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
