// Dragnet [Ransomware]: dragnet-ransomware-2024-1154 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 1e7cca8b-07b5-5ecf-a554-2de764ea1b2b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
