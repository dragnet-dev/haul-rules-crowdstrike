// Dragnet [Ransomware]: dragnet-ransomware-2024-2012 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: e72ce21c-96d7-58b9-8fdf-e0cb2a939659

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
