// Dragnet [Ransomware]: dragnet-ransomware-2023-3237 — Mass File Rename (royal)
// Status: deprecated | Level: high | ID: bedcacee-7fe2-5350-aaaf-96fc0d25baa2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
