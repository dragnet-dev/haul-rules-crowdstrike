// Dragnet [Ransomware]: dragnet-ransomware-2024-4740 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 52ca8666-40d4-5547-ad47-ddc8afcdab50

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
