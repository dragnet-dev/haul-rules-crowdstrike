// Dragnet [Ransomware]: dragnet-ransomware-2022-0524 — Mass File Rename (ransomexx)
// Status: experimental | Level: high | ID: 4caaf83f-483c-5edc-a37d-5a5cf38d7e6b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
