// Dragnet [Ransomware]: dragnet-ransomware-2025-3467 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 29e518ea-4411-5115-a071-b26f18f5f78e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
