// Dragnet [Ransomware]: dragnet-ransomware-2021-0675 — Mass File Rename (ragnarlocker)
// Status: deprecated | Level: high | ID: 71181c10-47b6-5796-9cef-2adf9d41d754

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
