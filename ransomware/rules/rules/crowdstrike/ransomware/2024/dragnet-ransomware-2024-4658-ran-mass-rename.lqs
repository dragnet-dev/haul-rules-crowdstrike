// Dragnet [Ransomware]: dragnet-ransomware-2024-4658 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: 90fbe9bd-8327-56a2-82b7-79dcc0cb1797

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
