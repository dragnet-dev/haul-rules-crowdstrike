// Dragnet [Ransomware]: dragnet-ransomware-2022-2866 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: a450a7e4-4026-5dd1-a94d-f6e0509f5264

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
