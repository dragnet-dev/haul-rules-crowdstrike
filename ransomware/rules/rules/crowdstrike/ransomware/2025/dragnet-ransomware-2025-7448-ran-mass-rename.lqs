// Dragnet [Ransomware]: dragnet-ransomware-2025-7448 — Mass File Rename (sinobi)
// Status: experimental | Level: high | ID: 70ea173d-2cf6-5847-afea-7b260da0ae4f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
