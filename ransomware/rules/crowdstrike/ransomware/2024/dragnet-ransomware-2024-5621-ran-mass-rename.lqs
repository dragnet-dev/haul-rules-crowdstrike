// Dragnet [Ransomware]: dragnet-ransomware-2024-5621 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: a3d2e110-c863-5750-a7bf-32f03543e434

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
