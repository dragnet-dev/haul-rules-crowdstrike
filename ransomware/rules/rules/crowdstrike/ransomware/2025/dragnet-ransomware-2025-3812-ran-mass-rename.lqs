// Dragnet [Ransomware]: dragnet-ransomware-2025-3812 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: a8894a8c-8614-5101-82a6-837568c187ac

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
