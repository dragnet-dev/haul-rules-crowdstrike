// Dragnet [Ransomware]: dragnet-ransomware-2024-1698 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 080aae1f-bf55-55fe-ae72-6737ad2db41c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
