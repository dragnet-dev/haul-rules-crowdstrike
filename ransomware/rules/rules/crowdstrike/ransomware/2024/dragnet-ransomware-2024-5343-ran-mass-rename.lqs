// Dragnet [Ransomware]: dragnet-ransomware-2024-5343 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 70d0d58b-05f8-561e-8da9-56efcde5fc1d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
