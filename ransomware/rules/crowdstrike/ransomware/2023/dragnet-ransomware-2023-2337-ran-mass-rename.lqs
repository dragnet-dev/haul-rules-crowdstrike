// Dragnet [Ransomware]: dragnet-ransomware-2023-2337 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 7a1bf3e7-6dc1-5f51-a539-5ede8b3454d4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
