// Dragnet [Ransomware]: dragnet-ransomware-2026-1003 — Mass File Rename (genesis)
// Status: stable | Level: high | ID: 274a136c-62c4-510d-a2ab-39efa1b51b7c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
