// Dragnet [Ransomware]: dragnet-ransomware-2026-1672 — Mass File Rename (krybit)
// Status: stable | Level: high | ID: c32c33d9-6d7e-58d3-b9f5-ab032ac9fe74

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
