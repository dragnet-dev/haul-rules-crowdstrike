// Dragnet [Ransomware]: dragnet-ransomware-2026-2959 — Mass File Rename (incransom)
// Status: test | Level: high | ID: 7b6e1264-915f-5ded-b896-201114bd76d4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
