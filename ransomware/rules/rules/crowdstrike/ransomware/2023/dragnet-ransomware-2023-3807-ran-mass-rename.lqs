// Dragnet [Ransomware]: dragnet-ransomware-2023-3807 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 37645255-91da-5c24-8103-90de691423a9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
