// Dragnet [Ransomware]: dragnet-ransomware-2025-1501 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 9d2d0458-9859-5681-80cf-49d1c82c1d2b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
