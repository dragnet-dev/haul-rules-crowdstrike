// Dragnet [Ransomware]: dragnet-ransomware-2021-0039 — Mass File Rename (avaddon)
// Status: deprecated | Level: high | ID: ad7cc12a-46f7-5ca6-b782-f41203e2f331

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
