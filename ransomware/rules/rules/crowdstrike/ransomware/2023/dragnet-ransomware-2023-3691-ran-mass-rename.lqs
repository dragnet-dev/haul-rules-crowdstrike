// Dragnet [Ransomware]: dragnet-ransomware-2023-3691 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: e7945aec-0e8b-5103-830b-915e476713b7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
