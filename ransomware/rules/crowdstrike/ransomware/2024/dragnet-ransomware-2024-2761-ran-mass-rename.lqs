// Dragnet [Ransomware]: dragnet-ransomware-2024-2761 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: c47e5273-c239-56b0-b828-cd1610caa635

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
