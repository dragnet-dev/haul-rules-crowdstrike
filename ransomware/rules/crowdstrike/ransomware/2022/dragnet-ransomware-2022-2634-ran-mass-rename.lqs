// Dragnet [Ransomware]: dragnet-ransomware-2022-2634 — Mass File Rename (avoslocker)
// Status: deprecated | Level: high | ID: 195df989-3978-586c-8bc9-cccd5fd51569

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
