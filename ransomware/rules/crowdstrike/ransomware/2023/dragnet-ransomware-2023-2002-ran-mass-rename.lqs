// Dragnet [Ransomware]: dragnet-ransomware-2023-2002 — Mass File Rename (karakurt)
// Status: experimental | Level: high | ID: ac82c0c4-0b6f-5230-b556-7ec750d8bb6d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
