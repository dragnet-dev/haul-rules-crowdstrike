// Dragnet [Container]: dragnet-container-2026-1721 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 412ae72b-e188-5aef-96dd-e36f9af753b7

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
