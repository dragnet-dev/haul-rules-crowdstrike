// Dragnet [Ransomware]: dragnet-ransomware-2022-0285 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: e6aa3bff-dc67-5746-8920-116917f8c247

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
