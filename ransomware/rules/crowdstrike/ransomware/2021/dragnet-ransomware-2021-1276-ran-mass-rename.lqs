// Dragnet [Ransomware]: dragnet-ransomware-2021-1276 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 94a7fbf0-bfbc-5d27-b74c-f01d8b140316

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
