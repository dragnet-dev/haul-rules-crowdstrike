// Dragnet [Container]: dragnet-container-2025-0598 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 4c57eb81-b8c3-5c33-a26d-3079dd885636

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:7* OR ImageFileName = *ubuntu:14.04*)
| table([timestamp, ComputerName])
| limit(1000)
