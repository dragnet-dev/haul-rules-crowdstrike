// Dragnet [Ransomware]: dragnet-ransomware-2025-1685 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: b8e899c6-3b05-52b5-ae7d-3a59f3af4502

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
