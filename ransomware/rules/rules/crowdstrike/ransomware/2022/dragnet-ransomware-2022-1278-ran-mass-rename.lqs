// Dragnet [Ransomware]: dragnet-ransomware-2022-1278 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 8f032f44-3cd2-5674-98bc-d4ed4e831800

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
