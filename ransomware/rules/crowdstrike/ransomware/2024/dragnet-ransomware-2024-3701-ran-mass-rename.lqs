// Dragnet [Ransomware]: dragnet-ransomware-2024-3701 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 85c93927-e14b-545a-8fa6-eefdba03f9e1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
