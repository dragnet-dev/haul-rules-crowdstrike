// Dragnet [Ransomware]: dragnet-ransomware-2023-1531 — Mass File Rename (ransomhouse)
// Status: deprecated | Level: high | ID: beac4152-41de-5bae-a8dc-86770cc27987

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
