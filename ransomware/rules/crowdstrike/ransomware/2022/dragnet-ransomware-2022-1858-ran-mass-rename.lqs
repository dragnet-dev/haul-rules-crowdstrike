// Dragnet [Ransomware]: dragnet-ransomware-2022-1858 — Mass File Rename (everest)
// Status: deprecated | Level: high | ID: ff69884c-6c50-535b-b022-5ece3c23e275

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
