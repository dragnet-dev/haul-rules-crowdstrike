// Dragnet [Ransomware]: dragnet-ransomware-2025-0522 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 1113e7ef-eddf-53aa-86e9-61f142ab7965

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
