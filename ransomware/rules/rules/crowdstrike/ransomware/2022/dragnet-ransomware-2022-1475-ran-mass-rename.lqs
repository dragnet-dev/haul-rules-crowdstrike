// Dragnet [Ransomware]: dragnet-ransomware-2022-1475 — Mass File Rename (royal)
// Status: deprecated | Level: high | ID: 72f4ad6f-450e-5a81-a9c7-559d81f73736

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
