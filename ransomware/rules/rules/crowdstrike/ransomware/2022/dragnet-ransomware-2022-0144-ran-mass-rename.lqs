// Dragnet [Ransomware]: dragnet-ransomware-2022-0144 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 32286ee6-761d-5aa2-8d47-5f8b1a874d31

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
