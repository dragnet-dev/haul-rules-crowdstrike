// Dragnet [Ransomware]: dragnet-ransomware-2025-2570 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: cb103e86-b2bc-5564-852e-de82753b6e24

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
