// Dragnet [Ransomware]: dragnet-ransomware-2023-1565 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 53a8b912-6f63-58ba-8128-49c23e763f48

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
