// Dragnet [Ransomware]: dragnet-ransomware-2022-2758 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 6fa3d1a9-78bd-5a85-8286-b1dd84af4099

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
