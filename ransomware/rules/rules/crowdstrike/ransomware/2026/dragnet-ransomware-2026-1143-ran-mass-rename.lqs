// Dragnet [Ransomware]: dragnet-ransomware-2026-1143 — Mass File Rename (thegentlemen)
// Status: stable | Level: high | ID: 44582a07-7d6c-5d40-8f4d-eecd5248bcee

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
