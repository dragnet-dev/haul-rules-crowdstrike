// Dragnet [Ransomware]: dragnet-ransomware-2024-3308 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 46246978-25dc-5bbd-926b-b6aa8909b77f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
