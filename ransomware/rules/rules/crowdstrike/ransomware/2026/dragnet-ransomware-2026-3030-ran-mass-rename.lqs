// Dragnet [Ransomware]: dragnet-ransomware-2026-3030 — Mass File Rename (incransom)
// Status: test | Level: high | ID: b26413e4-ccbe-5970-98b3-a1897fefc9e6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
