// Dragnet [Ransomware]: dragnet-ransomware-2025-1345 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: fece11ca-4cb1-5c1d-8a0c-a024e07a7d30

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
