// Dragnet [Ransomware]: dragnet-ransomware-2024-3996 — Mass File Rename (embargo)
// Status: experimental | Level: high | ID: 28065a68-b7e2-5cd2-b5c9-bed256854dd1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
