// Dragnet [Ransomware]: dragnet-ransomware-2023-1380 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: d5d089fb-ed2b-5efb-92dc-0fd49f55d857

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
