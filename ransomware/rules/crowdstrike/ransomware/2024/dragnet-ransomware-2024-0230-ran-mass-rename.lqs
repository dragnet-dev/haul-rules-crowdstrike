// Dragnet [Ransomware]: dragnet-ransomware-2024-0230 — Mass File Rename (redransomware)
// Status: deprecated | Level: high | ID: 24584376-963f-5e2a-bd5d-639e92476a31

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
