// Dragnet [Ransomware]: dragnet-ransomware-2025-0029 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: fa392ab6-844b-5f7a-a0b6-70628744d672

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
