// Dragnet [Ransomware]: dragnet-ransomware-2024-1654 — Mass File Rename (termite)
// Status: experimental | Level: high | ID: f328bb4c-58e0-56c1-b388-f930003d367c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
