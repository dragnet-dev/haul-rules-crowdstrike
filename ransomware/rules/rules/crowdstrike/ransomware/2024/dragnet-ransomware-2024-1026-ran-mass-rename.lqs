// Dragnet [Ransomware]: dragnet-ransomware-2024-1026 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 8c85684c-72cd-5140-8700-1472593c2685

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
