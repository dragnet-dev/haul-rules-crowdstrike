// Dragnet [Ransomware]: dragnet-ransomware-2022-1303 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: d43844df-b02b-543b-9230-34bf2377c6b3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
