// Dragnet [Ransomware]: dragnet-ransomware-2024-1221 — Mass File Rename (donutleaks)
// Status: experimental | Level: high | ID: 302bff43-a42c-5d18-997a-12caa9838212

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
