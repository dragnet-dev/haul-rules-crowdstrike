// Dragnet [Ransomware]: dragnet-ransomware-2023-2050 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 8c432f82-c4aa-5a6c-9f34-903a81043da8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
