// Dragnet [Ransomware]: dragnet-ransomware-2025-3931 — Mass File Rename (warlock)
// Status: deprecated | Level: high | ID: cb0b2b1b-10c9-5e71-835d-d73c9491baf1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
