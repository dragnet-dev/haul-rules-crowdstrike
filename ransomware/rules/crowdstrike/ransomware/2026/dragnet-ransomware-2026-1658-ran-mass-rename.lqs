// Dragnet [Ransomware]: dragnet-ransomware-2026-1658 — Mass File Rename (radar)
// Status: deprecated | Level: high | ID: 1c8054ed-f5b3-5d45-b4c6-3b72682b02ed

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
