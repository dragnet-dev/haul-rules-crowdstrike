// Dragnet [Ransomware]: dragnet-ransomware-2023-0030 — Mass File Rename (knight)
// Status: experimental | Level: high | ID: 02c120d1-6dc9-5903-a5ac-a2c906cc5407

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
