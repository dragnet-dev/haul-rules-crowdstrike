// Dragnet [Ransomware]: dragnet-ransomware-2025-7749 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 4a1e1bf6-b972-563f-a43c-309971a6adb4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
