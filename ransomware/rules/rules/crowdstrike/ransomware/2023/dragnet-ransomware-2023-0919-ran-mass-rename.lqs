// Dragnet [Ransomware]: dragnet-ransomware-2023-0919 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 95b9b6d5-dc5c-5e94-bda4-5ad491063676

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
