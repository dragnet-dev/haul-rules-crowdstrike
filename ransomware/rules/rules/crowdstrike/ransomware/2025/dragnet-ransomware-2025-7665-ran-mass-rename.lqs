// Dragnet [Ransomware]: dragnet-ransomware-2025-7665 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 7fe5e390-4b09-56d3-978f-1b3ffb5f032b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
