// Dragnet [Ransomware]: dragnet-ransomware-2023-4415 — Mass File Rename (play)
// Status: deprecated | Level: high | ID: 69631c1f-8a4b-50c0-97dd-467d92ae01c1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
