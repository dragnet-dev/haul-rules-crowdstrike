// Dragnet [Ransomware]: dragnet-ransomware-2025-7340 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: e3729618-3625-57c8-ac74-0c7237eecde8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
