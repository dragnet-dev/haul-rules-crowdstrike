// Dragnet [Ransomware]: dragnet-ransomware-2022-2184 — Mass File Rename (alphv)
// Status: deprecated | Level: high | ID: a93f83f2-8ada-5b4b-b7ea-390883ee48a5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
