// Dragnet [Ransomware]: dragnet-ransomware-2023-0705 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 868c7136-9b74-50e6-b8a3-27d9460ad895

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
