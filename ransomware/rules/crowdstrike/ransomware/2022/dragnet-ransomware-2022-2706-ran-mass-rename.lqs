// Dragnet [Ransomware]: dragnet-ransomware-2022-2706 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 5371ec3e-d233-5ad4-b140-c3d42c403912

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
