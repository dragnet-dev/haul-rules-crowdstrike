// Dragnet [Ransomware]: dragnet-ransomware-2024-4568 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: 5d459143-e622-5ecc-99df-de007275760e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
