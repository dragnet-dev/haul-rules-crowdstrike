// Dragnet [Ransomware]: dragnet-ransomware-2023-3240 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: ad824a3a-7b5c-550b-8210-7feb4d66dd07

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
