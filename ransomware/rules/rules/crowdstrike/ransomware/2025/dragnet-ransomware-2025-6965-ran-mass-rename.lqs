// Dragnet [Ransomware]: dragnet-ransomware-2025-6965 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: a1844eb4-f03f-54d8-a871-04a1a5ec5d04

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
