// Dragnet [Ransomware]: dragnet-ransomware-2023-1080 — Mass File Rename (metaencryptor)
// Status: experimental | Level: high | ID: 86aa7c22-7cf9-5c2e-a218-65de76f7cdc8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
