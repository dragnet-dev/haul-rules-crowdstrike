// Dragnet [Ransomware]: dragnet-ransomware-2023-0552 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 5796dd82-8631-5ec7-b8ad-cd68d5520b5a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
