// Dragnet [Ransomware]: dragnet-ransomware-2024-1803 — Mass File Rename (darkvault)
// Status: experimental | Level: high | ID: 6ed68b21-6c03-5429-9192-cd5f74116781

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
