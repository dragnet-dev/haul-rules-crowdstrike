// Dragnet [Ransomware]: dragnet-ransomware-2025-2228 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: e19e6bae-1e37-59ec-bf25-7326124a276a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
