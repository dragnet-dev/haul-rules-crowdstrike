// Dragnet [Ransomware]: dragnet-ransomware-2022-0362 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: b489dc90-43eb-5794-81a3-6b282f10553a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
