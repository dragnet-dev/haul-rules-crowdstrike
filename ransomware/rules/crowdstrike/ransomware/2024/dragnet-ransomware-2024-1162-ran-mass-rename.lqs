// Dragnet [Ransomware]: dragnet-ransomware-2024-1162 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: ff47b055-260e-552b-a81d-f9f483f13e41

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
