// Dragnet [Ransomware]: dragnet-ransomware-2025-3210 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 9fda0563-7895-5b0d-9fb5-c26f0f99744e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
