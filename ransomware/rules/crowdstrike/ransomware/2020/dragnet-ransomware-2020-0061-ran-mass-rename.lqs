// Dragnet [Ransomware]: dragnet-ransomware-2020-0061 — Mass File Rename (egregor)
// Status: deprecated | Level: high | ID: c89fe281-0438-55ce-9db3-ef250d6ffda3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
