// Dragnet [Ransomware]: dragnet-ransomware-2025-0273 — Mass File Rename (anubis)
// Status: experimental | Level: high | ID: 4e81ab25-866c-567b-8408-617c8ec27fb5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
