// Dragnet [Ransomware]: dragnet-ransomware-2021-1775 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 73e28537-3a25-5e14-add8-ff040b855789

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
