// Dragnet [Ransomware]: dragnet-ransomware-2024-3018 — Mass File Rename (sarcoma)
// Status: deprecated | Level: high | ID: 0b71a4f4-a9dd-5a1d-863a-5fcf812536d7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
