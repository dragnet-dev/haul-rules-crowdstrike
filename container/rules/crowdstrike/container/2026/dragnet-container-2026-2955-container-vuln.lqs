// Dragnet [Container]: dragnet-container-2026-2955 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: d6e3eda0-e685-5648-82d6-2f9c36c39602

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
