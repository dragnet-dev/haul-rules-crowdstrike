// Dragnet [Ransomware]: dragnet-ransomware-2022-0353 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 93ed8278-c68f-5158-9550-8076e7df735a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
