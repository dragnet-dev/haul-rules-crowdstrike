// Dragnet [Ransomware]: dragnet-ransomware-2023-4000 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 4fe4044e-e8a4-5670-b076-f5e830ebba04

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
