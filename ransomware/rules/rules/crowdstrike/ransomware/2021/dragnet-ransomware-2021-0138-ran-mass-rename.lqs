// Dragnet [Ransomware]: dragnet-ransomware-2021-0138 — Mass File Rename (spook)
// Status: deprecated | Level: high | ID: 3e3e811c-8299-57ae-94e4-35588d2fe959

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
