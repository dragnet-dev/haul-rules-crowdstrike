// Dragnet [Container]: dragnet-container-2026-0086 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 15b4a92c-5622-52f6-851b-b0925265e108

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
