// Dragnet [Ransomware]: dragnet-ransomware-2025-1884 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 4a08b587-5de5-5e95-8ca9-20dc05828c0b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
