// Dragnet [Ransomware]: dragnet-ransomware-2024-0009 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 5bbd9862-b121-53f1-a1d0-b7b079c54449

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
