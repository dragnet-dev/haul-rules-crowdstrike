// Dragnet [Ransomware]: dragnet-ransomware-2025-3375 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 1386ef28-7e35-5bc8-b0ba-57c6d8913d1a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
