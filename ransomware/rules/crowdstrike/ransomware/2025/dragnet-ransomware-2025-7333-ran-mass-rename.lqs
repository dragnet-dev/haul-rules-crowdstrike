// Dragnet [Ransomware]: dragnet-ransomware-2025-7333 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 48739289-4779-5716-8a36-31cd113b4e4e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
