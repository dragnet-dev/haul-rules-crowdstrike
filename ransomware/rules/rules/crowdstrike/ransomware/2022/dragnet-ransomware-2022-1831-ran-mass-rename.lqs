// Dragnet [Ransomware]: dragnet-ransomware-2022-1831 — Mass File Rename (cuba)
// Status: deprecated | Level: high | ID: 06c2fa0f-51b7-5290-afa0-612c9186cf1f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
