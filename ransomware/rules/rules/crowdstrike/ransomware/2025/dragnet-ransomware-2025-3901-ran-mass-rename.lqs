// Dragnet [Ransomware]: dragnet-ransomware-2025-3901 — Mass File Rename (beast)
// Status: experimental | Level: high | ID: 5f9129ac-bd23-5975-a429-cc0b0c3b7ce9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
