// Dragnet [Ransomware]: dragnet-ransomware-2023-3367 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 764c4559-ff9b-5ea2-ac86-40338406d739

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
