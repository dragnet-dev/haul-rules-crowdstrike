// Dragnet [Ransomware]: dragnet-ransomware-2024-5768 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 38837250-9963-56c5-91e5-be1d63e4050f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
