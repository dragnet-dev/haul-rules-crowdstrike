// Dragnet [Ransomware]: dragnet-ransomware-2025-7323 — Mass File Rename (coinbasecartel)
// Status: experimental | Level: high | ID: 5131e7ee-84ba-5e20-8323-b1528b81ce33

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
