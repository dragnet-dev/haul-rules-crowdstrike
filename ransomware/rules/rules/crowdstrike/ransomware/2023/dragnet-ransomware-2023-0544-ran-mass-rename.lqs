// Dragnet [Ransomware]: dragnet-ransomware-2023-0544 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: ee06d440-4338-5f0e-974e-61de1e2eca00

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
