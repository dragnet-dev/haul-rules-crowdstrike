// Dragnet [Ransomware]: dragnet-ransomware-2025-4631 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 99f06c3f-5bd2-5b7a-a415-b0eb38cc1259

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
