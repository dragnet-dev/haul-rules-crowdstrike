// Dragnet [Ransomware]: dragnet-ransomware-2023-3700 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 3050b012-8195-516d-a2ff-4451be530f6a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
