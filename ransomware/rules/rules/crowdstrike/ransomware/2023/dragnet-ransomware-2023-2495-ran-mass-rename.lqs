// Dragnet [Ransomware]: dragnet-ransomware-2023-2495 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 29ea1fda-930a-5260-a534-9eff216e1640

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
