// Dragnet [Ransomware]: dragnet-ransomware-2021-0295 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: befb3308-16df-5cfd-8acf-af6e81436d2c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
