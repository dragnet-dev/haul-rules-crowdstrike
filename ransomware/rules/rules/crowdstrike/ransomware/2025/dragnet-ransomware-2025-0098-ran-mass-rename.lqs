// Dragnet [Ransomware]: dragnet-ransomware-2025-0098 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 0ff36c79-0010-59a1-8115-e703383e8a60

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
