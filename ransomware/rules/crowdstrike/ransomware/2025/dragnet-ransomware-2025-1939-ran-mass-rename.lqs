// Dragnet [Ransomware]: dragnet-ransomware-2025-1939 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 18bfade2-b210-59ff-ac29-0ca83171e077

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
