// Dragnet [Ransomware]: dragnet-ransomware-2022-0808 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: c4d3be69-afde-5379-9d53-ee33641fac27

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
