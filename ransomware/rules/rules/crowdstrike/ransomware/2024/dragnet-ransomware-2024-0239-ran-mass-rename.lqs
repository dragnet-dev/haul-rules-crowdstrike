// Dragnet [Ransomware]: dragnet-ransomware-2024-0239 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 97f0794a-a5ed-5c2e-a2aa-cfc6176bb6f7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
