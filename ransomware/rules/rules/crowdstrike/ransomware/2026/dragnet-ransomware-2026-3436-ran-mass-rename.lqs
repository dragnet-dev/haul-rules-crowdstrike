// Dragnet [Ransomware]: dragnet-ransomware-2026-3436 — Mass File Rename (incransom)
// Status: test | Level: high | ID: a0da5af1-00b5-5040-9fcf-0226d730870d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
