// Dragnet [Ransomware]: dragnet-ransomware-2025-4224 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: b27da988-4a1a-51eb-b46f-be78dc992efb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
