// Dragnet [Ransomware]: dragnet-ransomware-2024-0693 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: c10b19f3-132d-5748-9409-7d04e3cd426d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
