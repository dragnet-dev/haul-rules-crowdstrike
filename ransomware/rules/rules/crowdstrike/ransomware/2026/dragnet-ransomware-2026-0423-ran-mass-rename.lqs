// Dragnet [Ransomware]: dragnet-ransomware-2026-0423 — Mass File Rename (krybit)
// Status: stable | Level: high | ID: 831ebd4c-ec6b-5a29-8858-1bb7a0f41cc4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
