// Dragnet [Ransomware]: dragnet-ransomware-2021-1318 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: fd233c57-cf22-5e49-b51f-bcce5335b84d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
