// Dragnet [Ransomware]: dragnet-ransomware-2026-3305 — Mass File Rename (thegentlemen)
// Status: deprecated | Level: high | ID: 8496a015-b1d1-51a4-b45c-581d0fa75d4d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
