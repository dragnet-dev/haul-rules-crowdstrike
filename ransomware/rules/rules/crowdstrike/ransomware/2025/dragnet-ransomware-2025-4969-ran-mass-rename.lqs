// Dragnet [Ransomware]: dragnet-ransomware-2025-4969 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: b70f8515-f6c4-5adf-92ec-956f6772fe75

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
