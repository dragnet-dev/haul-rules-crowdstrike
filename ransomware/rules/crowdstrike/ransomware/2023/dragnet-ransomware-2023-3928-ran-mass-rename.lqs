// Dragnet [Ransomware]: dragnet-ransomware-2023-3928 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: b82f7566-b381-521f-a7de-78a54ba5a7d9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
