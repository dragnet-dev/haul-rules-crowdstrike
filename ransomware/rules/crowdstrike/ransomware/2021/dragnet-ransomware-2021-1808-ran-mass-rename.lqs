// Dragnet [Ransomware]: dragnet-ransomware-2021-1808 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 3da73daf-74a1-5c39-8129-89712975c514

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
