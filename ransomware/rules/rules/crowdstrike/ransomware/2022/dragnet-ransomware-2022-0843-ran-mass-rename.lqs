// Dragnet [Ransomware]: dragnet-ransomware-2022-0843 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: eb801c49-3623-53b7-b8a7-3488ad1b1b9d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
