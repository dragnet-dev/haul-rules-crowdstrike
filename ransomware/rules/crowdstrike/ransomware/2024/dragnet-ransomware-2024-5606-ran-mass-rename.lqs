// Dragnet [Ransomware]: dragnet-ransomware-2024-5606 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 3c6c1b90-b690-58d5-ade2-7e09253f8f79

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
