// Dragnet [Ransomware]: dragnet-ransomware-2023-3636 — Mass File Rename (cloak)
// Status: deprecated | Level: high | ID: 538908f8-03d2-5ebd-9d6f-4a8387c6f147

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
