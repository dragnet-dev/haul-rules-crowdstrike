// Dragnet [Ransomware]: dragnet-ransomware-2024-3181 — Mass File Rename (vanirgroup)
// Status: deprecated | Level: high | ID: 395c18bc-0b7b-5815-b799-bf645a6d5c9e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
