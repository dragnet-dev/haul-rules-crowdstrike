// Dragnet [Ransomware]: dragnet-ransomware-2023-1087 — Mass File Rename (noescape)
// Status: experimental | Level: high | ID: 9edb3ec3-a84a-5913-8ab2-511ea371e4ba

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
