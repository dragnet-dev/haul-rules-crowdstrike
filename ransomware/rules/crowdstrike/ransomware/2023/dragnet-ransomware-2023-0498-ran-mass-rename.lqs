// Dragnet [Ransomware]: dragnet-ransomware-2023-0498 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 95220bd7-00c8-5ee8-81d8-3176e8148849

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
