// Dragnet [Ransomware]: dragnet-ransomware-2025-7220 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 1b24b15a-6608-5aba-87cc-b79f921ccece

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
