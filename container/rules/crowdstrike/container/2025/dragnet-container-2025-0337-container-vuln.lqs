// Dragnet [Container]: dragnet-container-2025-0337 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: bdc890fb-3db6-548c-b4c0-d86e7cbdf647

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:9*)
| table([timestamp, ComputerName])
| limit(1000)
