// Dragnet [Ransomware]: dragnet-ransomware-2026-2096 — Mass File Rename (incransom)
// Status: test | Level: high | ID: 8d4cbb6f-7c9a-567b-b4b7-dc27027613c2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
