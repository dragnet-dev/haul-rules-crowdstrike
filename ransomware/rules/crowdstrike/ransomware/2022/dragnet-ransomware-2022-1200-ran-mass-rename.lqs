// Dragnet [Ransomware]: dragnet-ransomware-2022-1200 — Mass File Rename (alphv)
// Status: deprecated | Level: high | ID: c702f891-0e1b-54c7-a0d7-35b2598e33a7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
