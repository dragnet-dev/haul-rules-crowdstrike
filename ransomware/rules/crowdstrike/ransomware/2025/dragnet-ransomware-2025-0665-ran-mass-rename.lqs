// Dragnet [Ransomware]: dragnet-ransomware-2025-0665 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: dd2ba9bb-a4f8-5913-bd39-cdcbb0ed3f6d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
