// Dragnet [Container]: dragnet-container-2026-1979 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 0e6fa4a8-9454-542b-b70f-cfb4011c5edb

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
