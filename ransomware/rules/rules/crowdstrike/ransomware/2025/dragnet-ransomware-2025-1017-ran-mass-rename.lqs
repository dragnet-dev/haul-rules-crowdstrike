// Dragnet [Ransomware]: dragnet-ransomware-2025-1017 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 1d035f43-c1f5-5d6e-93be-ac36a5bf5fc7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
