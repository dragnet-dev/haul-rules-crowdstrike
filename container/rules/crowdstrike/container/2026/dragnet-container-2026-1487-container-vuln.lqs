// Dragnet [Container]: dragnet-container-2026-1487 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 2330ab7a-e226-5b2e-b62b-bef67241d631

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
