// Dragnet [Ransomware]: dragnet-ransomware-2023-0332 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 0647c9e4-a262-5d16-b5ad-e3b1501f6430

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
