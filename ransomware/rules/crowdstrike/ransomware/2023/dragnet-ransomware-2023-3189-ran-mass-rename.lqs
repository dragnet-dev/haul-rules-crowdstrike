// Dragnet [Ransomware]: dragnet-ransomware-2023-3189 — Mass File Rename (mallox)
// Status: deprecated | Level: high | ID: 61b23d98-9369-5418-b325-c4de9154dbdf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
