// Dragnet [Ransomware]: dragnet-ransomware-2025-5700 — Mass File Rename (devman)
// Status: experimental | Level: high | ID: bdacd40e-d230-506a-87fc-43c63733c075

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
