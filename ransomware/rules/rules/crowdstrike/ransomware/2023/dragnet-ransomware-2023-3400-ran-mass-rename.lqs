// Dragnet [Ransomware]: dragnet-ransomware-2023-3400 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: a2592a4a-a3b8-592f-8e2a-b269b2b9864f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
