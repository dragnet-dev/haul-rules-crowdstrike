// Dragnet [Ransomware]: dragnet-ransomware-2024-2680 — Mass File Rename (vanirgroup)
// Status: deprecated | Level: high | ID: b8cb563d-c5de-5ebd-9d37-e42d6af8b9d1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
