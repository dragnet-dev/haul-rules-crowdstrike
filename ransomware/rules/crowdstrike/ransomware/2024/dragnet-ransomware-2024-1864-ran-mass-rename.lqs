// Dragnet [Ransomware]: dragnet-ransomware-2024-1864 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 514bfda2-c73b-5724-9c6e-86a066134a95

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
