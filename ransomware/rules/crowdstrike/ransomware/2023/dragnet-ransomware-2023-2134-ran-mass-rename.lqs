// Dragnet [Ransomware]: dragnet-ransomware-2023-2134 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: e04ce43c-c4d4-5930-b35c-6d09d4dcccf1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
