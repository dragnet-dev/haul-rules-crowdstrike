// Dragnet [Ransomware]: dragnet-ransomware-2022-0252 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 403b1b20-e6b8-52c8-bd3c-1bdde0b36428

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
