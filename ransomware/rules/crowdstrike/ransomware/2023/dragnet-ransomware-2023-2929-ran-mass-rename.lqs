// Dragnet [Ransomware]: dragnet-ransomware-2023-2929 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 4421dd00-8d4b-53be-99dc-e2f400a6ab32

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
