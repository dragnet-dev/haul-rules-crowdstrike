// Dragnet [Ransomware]: dragnet-ransomware-2022-2744 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 5050e57c-ef4a-5440-ac85-c0987e2cb127

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
