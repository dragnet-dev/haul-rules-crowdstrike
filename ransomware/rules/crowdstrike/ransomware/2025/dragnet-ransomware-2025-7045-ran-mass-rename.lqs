// Dragnet [Ransomware]: dragnet-ransomware-2025-7045 — Mass File Rename (sarcoma)
// Status: deprecated | Level: high | ID: a46b9b5d-2d5e-52df-a0a7-baff4c8366c1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
