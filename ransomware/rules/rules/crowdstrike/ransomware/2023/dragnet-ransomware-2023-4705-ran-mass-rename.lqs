// Dragnet [Ransomware]: dragnet-ransomware-2023-4705 — Mass File Rename (noescape)
// Status: experimental | Level: high | ID: f7c9d847-a315-50d4-9904-02cae51e5d9c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
