// Dragnet [Ransomware]: dragnet-ransomware-2025-2028 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 2e510d5d-ec11-5317-bbab-54fcb3d56b8d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
