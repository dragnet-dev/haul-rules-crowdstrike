// Dragnet [Ransomware]: dragnet-ransomware-2024-0267 — Mass File Rename (spacebears)
// Status: experimental | Level: high | ID: fa8a010b-3319-5f95-a8bd-a4b4eb57626f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
