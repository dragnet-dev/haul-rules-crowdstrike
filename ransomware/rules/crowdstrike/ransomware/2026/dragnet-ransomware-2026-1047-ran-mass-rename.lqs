// Dragnet [Ransomware]: dragnet-ransomware-2026-1047 — Mass File Rename (thegentlemen)
// Status: stable | Level: high | ID: 70e4fbe2-a4e4-5886-8f74-f57b04d7deb4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
