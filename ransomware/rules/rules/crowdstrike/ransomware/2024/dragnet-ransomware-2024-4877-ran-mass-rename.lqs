// Dragnet [Ransomware]: dragnet-ransomware-2024-4877 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: ef9c8bb8-6edf-5583-a2c7-bcb712729fca

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
