// Dragnet [Ransomware]: dragnet-ransomware-2025-4225 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 84e0bb84-e88e-5f30-a0ae-a154180f2889

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
