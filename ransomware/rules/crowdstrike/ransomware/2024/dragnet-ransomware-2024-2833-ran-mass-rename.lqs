// Dragnet [Ransomware]: dragnet-ransomware-2024-2833 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: 4ae90e15-5c72-53ca-b073-a05f076643c8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
