// Dragnet [Ransomware]: dragnet-ransomware-2023-3819 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 9076fe01-782f-53f5-baa7-58608ce8a9d0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
