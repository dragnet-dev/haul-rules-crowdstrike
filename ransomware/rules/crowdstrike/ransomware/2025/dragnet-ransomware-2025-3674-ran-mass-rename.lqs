// Dragnet [Ransomware]: dragnet-ransomware-2025-3674 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 9ae422d2-0159-56a7-b70d-505956c6849a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
