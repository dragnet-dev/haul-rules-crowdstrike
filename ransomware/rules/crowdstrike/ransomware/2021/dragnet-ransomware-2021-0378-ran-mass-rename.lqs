// Dragnet [Ransomware]: dragnet-ransomware-2021-0378 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 70da378a-710c-5a48-b663-e21fb10ac262

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
