// Dragnet [Container]: dragnet-container-2024-0591 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 4bec8f0b-8df4-5697-b881-4fced166f25f

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
