// Dragnet [Ransomware]: dragnet-ransomware-2023-2374 — Mass File Rename (toufan)
// Status: deprecated | Level: high | ID: 3f3e3e59-4f8e-5eb9-bfdc-9bf940369fa3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
