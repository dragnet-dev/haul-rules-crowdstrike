// Dragnet [Ransomware]: dragnet-ransomware-2025-1550 — Mass File Rename (worldleaks)
// Status: experimental | Level: high | ID: d00814ea-e3ef-58ab-ac19-b4baa2cc8d17

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
