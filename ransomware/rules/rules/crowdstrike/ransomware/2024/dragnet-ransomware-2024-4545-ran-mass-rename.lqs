// Dragnet [Ransomware]: dragnet-ransomware-2024-4545 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: d864d317-b007-5355-92dc-e47a512b06ae

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
