// Dragnet [Ransomware]: dragnet-ransomware-2020-0099 — Mass File Rename (ragnarlocker)
// Status: deprecated | Level: high | ID: edbd8ae7-f36b-588a-b479-a95a923b6c9d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
