// Dragnet [Ransomware]: dragnet-ransomware-2024-1017 — Mass File Rename (ElDorado)
// Status: deprecated | Level: high | ID: fc2ba6fd-facf-5091-b9d1-1a9b10fae5b5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
