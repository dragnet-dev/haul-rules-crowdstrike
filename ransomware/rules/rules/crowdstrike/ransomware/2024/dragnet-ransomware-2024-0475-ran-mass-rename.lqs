// Dragnet [Ransomware]: dragnet-ransomware-2024-0475 — Mass File Rename (arcusmedia)
// Status: experimental | Level: high | ID: f446bfa3-854f-5f76-9da2-63b34ef67668

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
