// Dragnet [Ransomware]: dragnet-ransomware-2025-7820 — Mass File Rename (lockbit5)
// Status: test | Level: high | ID: 7ca26a96-e231-5400-926c-91ffab18ebb1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
