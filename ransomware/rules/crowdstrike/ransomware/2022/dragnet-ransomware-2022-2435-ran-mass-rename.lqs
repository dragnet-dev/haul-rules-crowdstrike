// Dragnet [Ransomware]: dragnet-ransomware-2022-2435 — Mass File Rename (cuba)
// Status: deprecated | Level: high | ID: c5373b75-de32-5e7b-80df-1a27e16b1c6d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
