// Dragnet [Ransomware]: dragnet-ransomware-2025-6045 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 1da24b93-c38e-591d-993f-b533d2c36f5c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
