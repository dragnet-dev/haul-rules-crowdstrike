// Dragnet [Ransomware]: dragnet-ransomware-2023-2023 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 8a331032-1db5-5804-85c4-b1ddb9c7feee

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
