// Dragnet [Ransomware]: dragnet-ransomware-2024-0597 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: ec7c3b7e-d25f-5aa4-b161-271adacef9d4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
