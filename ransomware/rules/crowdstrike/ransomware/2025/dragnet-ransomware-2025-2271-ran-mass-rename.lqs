// Dragnet [Ransomware]: dragnet-ransomware-2025-2271 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: edfe4766-7354-5b48-b67c-2694eaba6cf4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
