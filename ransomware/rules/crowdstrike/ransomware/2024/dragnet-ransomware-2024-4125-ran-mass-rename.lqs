// Dragnet [Ransomware]: dragnet-ransomware-2024-4125 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 8cb7da8d-6a4c-5efc-897c-91d578c81913

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
