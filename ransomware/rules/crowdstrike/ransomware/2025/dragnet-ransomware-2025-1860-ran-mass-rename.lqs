// Dragnet [Ransomware]: dragnet-ransomware-2025-1860 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: d9fddb71-7c59-5cfb-81e5-b9f8b027dfeb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
