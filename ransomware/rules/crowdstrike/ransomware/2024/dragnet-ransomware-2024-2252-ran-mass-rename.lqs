// Dragnet [Ransomware]: dragnet-ransomware-2024-2252 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 691ebc63-6987-5343-8781-6cefc4c82f8c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
