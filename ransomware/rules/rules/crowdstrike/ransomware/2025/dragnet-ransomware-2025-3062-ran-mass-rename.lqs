// Dragnet [Ransomware]: dragnet-ransomware-2025-3062 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 3c8329b4-9381-5c9d-a3d7-fe2e59a32be9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
