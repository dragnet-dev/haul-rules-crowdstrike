// Dragnet [Ransomware]: dragnet-ransomware-2024-2602 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 7da7d054-ffae-50e4-ac2b-4f91bd19e5a8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
