// Dragnet [Ransomware]: dragnet-ransomware-2021-0697 — Mass File Rename (mountlocker)
// Status: deprecated | Level: high | ID: 30a9d015-29f3-5e2b-9820-6e75415d16f5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
