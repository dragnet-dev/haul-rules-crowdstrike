// Dragnet [Ransomware]: dragnet-ransomware-2026-1951 — Mass File Rename (insomnia)
// Status: stable | Level: high | ID: ddc9e370-386a-544f-8548-ca1337f12243

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
