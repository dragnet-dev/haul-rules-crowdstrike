// Dragnet [Container]: dragnet-container-2024-1241 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 277ce25d-2f69-5936-aff8-4472b51c1220

#event_simpleName=*
| (ImageFileName = *amazonlinux:2023* OR ImageFileName = *azure linux:3.0* OR ImageFileName = *cbl-mariner:2.0* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *photon os:3.0* OR ImageFileName = *photon os:4.0* OR ImageFileName = *photon os:5.0* OR ImageFileName = *ubuntu:22.04* OR ImageFileName = *ubuntu:23.04* OR ImageFileName = *ubuntu:23.10*)
| table([timestamp, ComputerName])
| limit(1000)
