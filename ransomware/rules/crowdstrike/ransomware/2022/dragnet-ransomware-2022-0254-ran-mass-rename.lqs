// Dragnet [Ransomware]: dragnet-ransomware-2022-0254 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 78c20206-c1e6-5ea0-84ce-a4b36c558421

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
