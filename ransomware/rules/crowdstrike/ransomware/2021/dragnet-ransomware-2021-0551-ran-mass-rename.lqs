// Dragnet [Ransomware]: dragnet-ransomware-2021-0551 — Mass File Rename (suncrypt)
// Status: deprecated | Level: high | ID: de737531-e0e7-5d44-b94c-7d1f4b3dfb51

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
