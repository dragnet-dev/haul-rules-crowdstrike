// Dragnet [Ransomware]: dragnet-ransomware-2023-1597 — Mass File Rename (toufan)
// Status: deprecated | Level: high | ID: 47fd8f8b-f975-5865-925f-09e5dd2c62e2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
