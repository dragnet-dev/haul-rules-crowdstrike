// Dragnet [Ransomware]: dragnet-ransomware-2021-0498 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: deaf563e-ceb3-553d-b55e-3c5c56554e65

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
