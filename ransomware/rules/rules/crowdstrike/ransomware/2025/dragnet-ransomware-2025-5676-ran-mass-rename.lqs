// Dragnet [Ransomware]: dragnet-ransomware-2025-5676 — Mass File Rename (payoutsking)
// Status: deprecated | Level: high | ID: 05bdd371-4c04-53cb-93b0-e7e81d4f99a1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
