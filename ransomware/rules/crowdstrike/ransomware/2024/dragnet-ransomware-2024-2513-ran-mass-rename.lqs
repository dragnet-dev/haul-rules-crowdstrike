// Dragnet [Ransomware]: dragnet-ransomware-2024-2513 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 9f361231-b23e-5a4c-8132-19ad0936716b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
