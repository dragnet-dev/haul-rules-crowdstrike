// Dragnet [Ransomware]: dragnet-ransomware-2024-5287 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 35bcc80b-51e2-5943-b141-d8f5e26d7b35

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
