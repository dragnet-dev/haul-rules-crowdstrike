// Dragnet [Ransomware]: dragnet-ransomware-2022-1699 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 20c4566b-9eb9-5e29-91c9-ed5aea5033e6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
