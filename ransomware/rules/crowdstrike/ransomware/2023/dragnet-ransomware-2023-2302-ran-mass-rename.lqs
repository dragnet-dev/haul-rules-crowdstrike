// Dragnet [Ransomware]: dragnet-ransomware-2023-2302 — Mass File Rename (rhysida)
// Status: experimental | Level: high | ID: c3760321-faaf-5bb6-af83-e6bd663b1d7e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
