// Dragnet [Ransomware]: dragnet-ransomware-2025-5428 — Mass File Rename (spacebears)
// Status: experimental | Level: high | ID: c5822ef5-5ce1-5e62-b7ed-5d17459a8cfe

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
