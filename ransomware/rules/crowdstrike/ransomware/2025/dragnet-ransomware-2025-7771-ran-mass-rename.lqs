// Dragnet [Ransomware]: dragnet-ransomware-2025-7771 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: f3408b88-44eb-5d03-a1ad-d0d57936c192

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
