// Dragnet [Ransomware]: dragnet-ransomware-2021-0226 — Mass File Rename (revil)
// Status: deprecated | Level: high | ID: c7444005-6c76-587f-a7a0-b3b5f1013079

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
