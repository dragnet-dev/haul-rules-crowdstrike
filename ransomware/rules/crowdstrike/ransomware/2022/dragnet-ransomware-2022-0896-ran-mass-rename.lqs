// Dragnet [Ransomware]: dragnet-ransomware-2022-0896 — Mass File Rename (royal)
// Status: deprecated | Level: high | ID: 155671d3-3122-5d19-a5a8-045106bd0f26

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
