// Dragnet [Ransomware]: dragnet-ransomware-2026-2730 — Mass File Rename (direwolf)
// Status: test | Level: high | ID: e345ac79-43b7-5679-b94a-37a2e6ccb6b2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
