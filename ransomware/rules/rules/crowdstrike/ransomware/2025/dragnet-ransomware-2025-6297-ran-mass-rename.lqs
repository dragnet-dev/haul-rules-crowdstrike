// Dragnet [Ransomware]: dragnet-ransomware-2025-6297 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 2440aede-be14-5d20-aac4-b63c757fa813

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
