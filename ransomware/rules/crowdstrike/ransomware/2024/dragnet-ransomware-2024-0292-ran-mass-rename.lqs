// Dragnet [Ransomware]: dragnet-ransomware-2024-0292 — Mass File Rename (sensayq)
// Status: experimental | Level: high | ID: 4dd3e717-897a-509c-8fc6-dba71eef8633

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
