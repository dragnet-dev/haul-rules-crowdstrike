// Dragnet [Ransomware]: dragnet-ransomware-2024-2709 — Mass File Rename (werewolves)
// Status: experimental | Level: high | ID: f742ae2f-b804-5c88-b430-489090bad2e8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
