// Dragnet [Ransomware]: dragnet-ransomware-2023-1755 — Mass File Rename (threeam)
// Status: experimental | Level: high | ID: 779a73c0-5e6b-5189-b975-2dcdcab53562

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
