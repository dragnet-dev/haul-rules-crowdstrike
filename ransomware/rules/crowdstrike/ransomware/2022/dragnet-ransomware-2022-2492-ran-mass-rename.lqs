// Dragnet [Ransomware]: dragnet-ransomware-2022-2492 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 6260a335-3d08-582e-ba39-c5f750a66d42

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
