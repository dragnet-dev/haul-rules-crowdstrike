// Dragnet [Ransomware]: dragnet-ransomware-2024-5051 — Mass File Rename (ElDorado)
// Status: deprecated | Level: high | ID: 7e942b52-91c7-5713-8ebb-bd952aaa296b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
