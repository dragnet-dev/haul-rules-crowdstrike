// Dragnet [Ransomware]: dragnet-ransomware-2021-0576 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: d61bf129-8f30-5e06-aaaa-4ca72ec4830f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
