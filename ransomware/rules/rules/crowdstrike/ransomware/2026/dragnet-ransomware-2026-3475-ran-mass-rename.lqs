// Dragnet [Ransomware]: dragnet-ransomware-2026-3475 — Mass File Rename (PrinzEugen)
// Status: stable | Level: high | ID: 05b2cddc-4c19-5beb-80ff-10920402aef5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
