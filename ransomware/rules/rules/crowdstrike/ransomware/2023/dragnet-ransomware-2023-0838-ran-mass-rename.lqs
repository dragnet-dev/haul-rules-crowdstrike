// Dragnet [Ransomware]: dragnet-ransomware-2023-0838 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 942e2ec6-8220-517d-a5f7-adc3f70686e2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
