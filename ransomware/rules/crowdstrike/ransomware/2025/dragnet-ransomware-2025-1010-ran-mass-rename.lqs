// Dragnet [Ransomware]: dragnet-ransomware-2025-1010 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 77b07e6b-2b0a-5621-9574-e7972fcb0e53

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
