// Dragnet [Ransomware]: dragnet-ransomware-2022-1491 — Mass File Rename (vicesociety)
// Status: deprecated | Level: high | ID: adca7162-e54f-5736-a8df-b00e8841eff6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
