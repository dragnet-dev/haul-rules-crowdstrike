// Dragnet [Ransomware]: dragnet-ransomware-2024-5880 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 376534c4-ece5-58b7-b0c1-434d3387758c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
