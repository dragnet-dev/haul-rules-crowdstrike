// Dragnet [Ransomware]: dragnet-ransomware-2025-3728 — Mass File Rename (apos)
// Status: deprecated | Level: high | ID: b7a513bf-a517-5938-b336-7705192dd4ed

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
