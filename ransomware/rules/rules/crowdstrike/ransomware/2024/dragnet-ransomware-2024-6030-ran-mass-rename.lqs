// Dragnet [Ransomware]: dragnet-ransomware-2024-6030 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: ae15b60b-42c8-5809-8776-c2ae72b23d97

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
