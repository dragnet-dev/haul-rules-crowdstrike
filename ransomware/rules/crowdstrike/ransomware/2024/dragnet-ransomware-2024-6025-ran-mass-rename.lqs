// Dragnet [Ransomware]: dragnet-ransomware-2024-6025 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 3fe15955-1328-520f-b845-6ac7c95b0e59

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
