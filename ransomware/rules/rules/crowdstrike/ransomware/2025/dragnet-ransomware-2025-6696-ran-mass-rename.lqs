// Dragnet [Ransomware]: dragnet-ransomware-2025-6696 — Mass File Rename (worldleaks)
// Status: experimental | Level: high | ID: afa4ba1f-abe0-5128-8635-983a6fd001c1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
