// Dragnet [Ransomware]: dragnet-ransomware-2021-0651 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: a06a5903-a1c3-5863-8e03-27d6d8ddce8d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
