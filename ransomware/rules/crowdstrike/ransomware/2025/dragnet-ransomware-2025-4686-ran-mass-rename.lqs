// Dragnet [Ransomware]: dragnet-ransomware-2025-4686 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: 8f6eff23-e0fe-53ef-8ce1-38459d27b44a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
