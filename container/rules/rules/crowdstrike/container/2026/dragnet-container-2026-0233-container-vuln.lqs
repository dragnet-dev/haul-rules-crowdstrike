// Status: deprecated | Level: critical | ID: 3be649c8-d1b0-5a33-af59-d3caf4e9d222

#event_simpleName=*
| (ImageFileName = *chainguard:* OR ImageFileName = *debian:14* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:16.04-ESM* OR ImageFileName = *ubuntu:18.04-ESM* OR ImageFileName = *ubuntu:20.04-ESM* OR ImageFileName = *ubuntu:22.04* OR ImageFileName = *ubuntu:24.04* OR ImageFileName = *ubuntu:25.10* OR ImageFileName = *ubuntu:26.04* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
