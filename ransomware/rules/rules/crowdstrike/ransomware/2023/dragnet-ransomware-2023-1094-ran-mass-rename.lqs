// Dragnet [Ransomware]: dragnet-ransomware-2023-1094 — Mass File Rename (ransomed)
// Status: deprecated | Level: high | ID: 2efd6121-9445-5d39-b55a-79e0e915c376

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
