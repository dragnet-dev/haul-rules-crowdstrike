// Dragnet [Ransomware]: dragnet-ransomware-2026-2379 — Mass File Rename (lockbit5)
// Status: stable | Level: high | ID: efc2a142-464a-5627-bd60-89eb8a738963

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
