// Dragnet [Ransomware]: dragnet-ransomware-2023-5003 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: e0434b8f-ff7a-50aa-b940-0cca5b56155a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
