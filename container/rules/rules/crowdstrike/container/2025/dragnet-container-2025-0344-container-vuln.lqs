// Dragnet [Container]: dragnet-container-2025-0344 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 7098eb71-f154-56c5-b372-9bb200f62331

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:8* OR ImageFileName = *debian:9*)
| table([timestamp, ComputerName])
| limit(1000)
