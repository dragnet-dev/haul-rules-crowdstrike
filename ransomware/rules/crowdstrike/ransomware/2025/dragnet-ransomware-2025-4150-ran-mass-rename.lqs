// Dragnet [Ransomware]: dragnet-ransomware-2025-4150 — Mass File Rename (dragonforce)
// Status: test | Level: high | ID: 5549ffeb-e24d-5ad3-801a-c151583c63ba

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
