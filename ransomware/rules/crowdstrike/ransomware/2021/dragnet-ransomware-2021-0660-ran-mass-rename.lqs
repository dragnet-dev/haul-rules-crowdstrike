// Dragnet [Ransomware]: dragnet-ransomware-2021-0660 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 26c22837-c15c-5050-8e65-9e366b488fa8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
