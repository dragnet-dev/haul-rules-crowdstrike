// Dragnet [Ransomware]: dragnet-ransomware-2025-3724 — Mass File Rename (sinobi)
// Status: experimental | Level: high | ID: 06a3abe9-5cce-5695-9668-2ce3e88b073b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
