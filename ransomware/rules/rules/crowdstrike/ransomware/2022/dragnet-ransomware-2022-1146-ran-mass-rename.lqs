// Dragnet [Ransomware]: dragnet-ransomware-2022-1146 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: e8879d5b-b23f-5976-a459-8b1a98f89c79

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
