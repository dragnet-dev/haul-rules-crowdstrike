// Dragnet [Ransomware]: dragnet-ransomware-2024-2055 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: 516f7a56-56fa-546f-9dd8-9aff15585095

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
