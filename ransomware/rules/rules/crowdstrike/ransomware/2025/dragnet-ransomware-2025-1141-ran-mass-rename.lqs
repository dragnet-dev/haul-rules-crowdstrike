// Dragnet [Ransomware]: dragnet-ransomware-2025-1141 — Mass File Rename (devman)
// Status: experimental | Level: high | ID: 78998e7b-6fcb-57a5-9830-890eb74515d6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
