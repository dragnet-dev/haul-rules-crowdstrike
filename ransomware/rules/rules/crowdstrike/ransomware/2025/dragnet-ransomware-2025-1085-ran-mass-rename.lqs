// Dragnet [Ransomware]: dragnet-ransomware-2025-1085 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 1c9d37b7-fb15-5052-b25a-c949c3abc788

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
