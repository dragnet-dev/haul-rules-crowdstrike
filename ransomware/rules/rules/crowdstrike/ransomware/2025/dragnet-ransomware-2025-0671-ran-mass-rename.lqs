// Dragnet [Ransomware]: dragnet-ransomware-2025-0671 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 36d77244-ac92-5d27-9f54-da9ccce5e2c9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
