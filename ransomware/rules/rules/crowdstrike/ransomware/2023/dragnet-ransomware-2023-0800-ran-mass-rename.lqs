// Dragnet [Ransomware]: dragnet-ransomware-2023-0800 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: cb98e9c5-872d-555f-9a94-8f2e9a105f9c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
