// Dragnet [Ransomware]: dragnet-ransomware-2024-2280 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: b278f3f1-287f-5996-8862-ea0e1b0ef41a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
