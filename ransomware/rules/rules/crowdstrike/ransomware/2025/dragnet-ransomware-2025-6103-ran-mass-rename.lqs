// Dragnet [Ransomware]: dragnet-ransomware-2025-6103 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 4c6a35ec-0bbe-570a-ad07-2a3778f1a594

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
