// Dragnet [Ransomware]: dragnet-ransomware-2024-5855 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 346ba0f4-ae6d-5f80-8efb-3bfbb2c72907

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
