// Dragnet [Container]: dragnet-container-2024-1354 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 0239b1d9-f3ee-5b4d-bbc6-96acf4fc1dda

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:7* OR ImageFileName = *debian:8*)
| table([timestamp, ComputerName])
| limit(1000)
