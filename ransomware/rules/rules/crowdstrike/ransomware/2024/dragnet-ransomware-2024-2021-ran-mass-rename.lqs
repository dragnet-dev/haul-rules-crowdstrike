// Dragnet [Ransomware]: dragnet-ransomware-2024-2021 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 8c148964-ff49-5ee2-bc54-3f94c677e827

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
