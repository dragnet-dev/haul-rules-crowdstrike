// Dragnet [Ransomware]: dragnet-ransomware-2023-3672 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: d952b9a8-9e0a-5899-ac79-d7cfafa38a15

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
