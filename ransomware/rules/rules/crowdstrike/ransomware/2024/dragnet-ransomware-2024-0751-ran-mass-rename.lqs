// Dragnet [Ransomware]: dragnet-ransomware-2024-0751 — Mass File Rename (play)
// Status: experimental | Level: high | ID: d81c902a-1717-5231-b245-3c2869994d4a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
