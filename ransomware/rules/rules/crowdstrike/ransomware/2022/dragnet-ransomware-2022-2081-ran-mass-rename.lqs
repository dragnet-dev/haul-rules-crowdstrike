// Dragnet [Ransomware]: dragnet-ransomware-2022-2081 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: f0de66d4-c2ac-574e-9474-b045ff754433

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
