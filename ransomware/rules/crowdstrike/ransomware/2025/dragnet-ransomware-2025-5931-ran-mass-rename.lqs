// Dragnet [Ransomware]: dragnet-ransomware-2025-5931 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 51d5bf7a-4507-5082-a84d-f07415770f9b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
