// Dragnet [Ransomware]: dragnet-ransomware-2024-5895 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 564faa32-715a-5dcf-beda-e22cc30326c9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
