// Dragnet [Ransomware]: dragnet-ransomware-2023-4535 — Mass File Rename (play)
// Status: experimental | Level: high | ID: efd9fe50-9f33-5e33-85d1-3cc4df98d38b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
