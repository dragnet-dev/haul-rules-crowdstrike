// Dragnet [Ransomware]: dragnet-ransomware-2023-3203 — Mass File Rename (malas)
// Status: experimental | Level: high | ID: 0ca44959-8d32-5026-9684-96d4299fc0e5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
