// Dragnet [Ransomware]: dragnet-ransomware-2024-4547 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: eeaa78f1-5a01-51c7-89ab-18dc9b2b81a3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
