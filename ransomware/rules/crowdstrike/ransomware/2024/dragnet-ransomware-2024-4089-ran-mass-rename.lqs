// Dragnet [Ransomware]: dragnet-ransomware-2024-4089 — Mass File Rename (meow)
// Status: experimental | Level: high | ID: 03b15a04-8f0f-5742-bf72-1a659716d055

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
