// Dragnet [Ransomware]: dragnet-ransomware-2025-2982 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 25f21d87-f077-53bf-a79c-2dd960a6dfb4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
