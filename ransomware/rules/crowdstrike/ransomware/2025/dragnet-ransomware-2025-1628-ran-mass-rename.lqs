// Dragnet [Ransomware]: dragnet-ransomware-2025-1628 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: dbc6e592-8712-5c9a-bf73-cef03ccddebd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
