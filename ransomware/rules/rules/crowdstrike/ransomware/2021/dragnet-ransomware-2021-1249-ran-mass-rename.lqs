// Dragnet [Ransomware]: dragnet-ransomware-2021-1249 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 45d67b8a-d7cc-52b8-a765-8b6c0e82e978

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
