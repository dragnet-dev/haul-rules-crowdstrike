// Dragnet [Ransomware]: dragnet-ransomware-2024-5636 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 30540361-2181-52c6-9b92-19787d0e783f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
