// Dragnet [Ransomware]: dragnet-ransomware-2023-2365 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 0c688d82-ebd8-533b-99a9-dd29469ebca7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
