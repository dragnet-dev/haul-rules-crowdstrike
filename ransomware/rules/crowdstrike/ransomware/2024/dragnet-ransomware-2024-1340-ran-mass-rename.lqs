// Dragnet [Ransomware]: dragnet-ransomware-2024-1340 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 4b6a2615-064d-578c-a31f-1b873bc2bf46

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
