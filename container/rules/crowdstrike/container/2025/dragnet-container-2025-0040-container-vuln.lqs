// Dragnet [Container]: dragnet-container-2025-0040 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: bda74395-e4cc-52e2-8068-3f556c22bdc4

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *ubuntu:20.04-ESM* OR ImageFileName = *ubuntu:22.04* OR ImageFileName = *ubuntu:24.04* OR ImageFileName = *ubuntu:25.10*)
| table([timestamp, ComputerName])
| limit(1000)
