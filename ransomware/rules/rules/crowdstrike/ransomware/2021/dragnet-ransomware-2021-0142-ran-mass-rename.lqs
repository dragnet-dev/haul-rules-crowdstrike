// Dragnet [Ransomware]: dragnet-ransomware-2021-0142 — Mass File Rename (spook)
// Status: deprecated | Level: high | ID: 1c323168-0e24-5405-93d2-1137922e584c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
