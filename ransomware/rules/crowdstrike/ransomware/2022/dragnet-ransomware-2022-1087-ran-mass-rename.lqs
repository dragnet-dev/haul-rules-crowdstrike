// Dragnet [Ransomware]: dragnet-ransomware-2022-1087 — Mass File Rename (blackbasta)
// Status: deprecated | Level: high | ID: 22e6bff8-e8bb-51bf-801e-1b359df426fc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
