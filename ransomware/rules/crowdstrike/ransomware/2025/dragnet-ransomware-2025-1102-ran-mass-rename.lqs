// Dragnet [Ransomware]: dragnet-ransomware-2025-1102 — Mass File Rename (cephalus)
// Status: deprecated | Level: high | ID: d7dd235e-2a58-5fd2-95db-595d13b35983

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
