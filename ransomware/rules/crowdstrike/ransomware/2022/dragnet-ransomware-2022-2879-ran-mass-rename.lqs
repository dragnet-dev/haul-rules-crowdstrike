// Dragnet [Ransomware]: dragnet-ransomware-2022-2879 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 63293731-954a-5021-9ac4-33f984b80e65

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
