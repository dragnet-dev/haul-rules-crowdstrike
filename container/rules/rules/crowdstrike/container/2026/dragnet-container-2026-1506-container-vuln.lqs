// Dragnet [Container]: dragnet-container-2026-1506 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 227c1588-8815-5a40-a377-dbc85d6a2074

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *ubuntu:14.04* OR ImageFileName = *ubuntu:14.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
