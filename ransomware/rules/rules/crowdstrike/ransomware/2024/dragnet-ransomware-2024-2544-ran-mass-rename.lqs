// Dragnet [Ransomware]: dragnet-ransomware-2024-2544 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 313519b1-1ccc-58ec-b7c6-203647555487

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
