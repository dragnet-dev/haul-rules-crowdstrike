// Dragnet [Ransomware]: dragnet-ransomware-2025-6576 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: 2e4bd8bf-420c-52b8-b8cc-2b13386720d9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
