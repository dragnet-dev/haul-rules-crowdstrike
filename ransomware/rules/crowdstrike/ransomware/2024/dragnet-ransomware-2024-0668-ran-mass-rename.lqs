// Dragnet [Ransomware]: dragnet-ransomware-2024-0668 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: e255497b-a193-5067-9a5c-ab112e766fc6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
