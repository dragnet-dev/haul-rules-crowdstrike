// Dragnet [Ransomware]: dragnet-ransomware-2023-0935 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: d2bb4ec0-82a6-5d48-adf6-f92f9edcb694

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
