// Dragnet [Ransomware]: dragnet-ransomware-2026-3338 — Mass File Rename (everest)
// Status: stable | Level: high | ID: 59daa04a-2048-563c-a290-864b32fff2ab

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
