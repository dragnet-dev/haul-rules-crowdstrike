// Dragnet [Ransomware]: dragnet-ransomware-2026-3247 — Mass File Rename (incransom)
// Status: test | Level: high | ID: 7bb99ba0-7b87-5e76-a52e-6057e68d7348

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
