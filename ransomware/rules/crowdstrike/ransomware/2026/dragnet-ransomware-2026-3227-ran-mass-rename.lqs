// Dragnet [Ransomware]: dragnet-ransomware-2026-3227 — Mass File Rename (vect)
// Status: deprecated | Level: high | ID: e5a99c96-fac5-5d73-ad34-a0ecf41485f4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
