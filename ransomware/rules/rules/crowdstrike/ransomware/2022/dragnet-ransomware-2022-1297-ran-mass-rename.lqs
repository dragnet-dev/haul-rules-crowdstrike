// Dragnet [Ransomware]: dragnet-ransomware-2022-1297 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 97d17379-ab10-501e-b2a1-944f5e9d64aa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
