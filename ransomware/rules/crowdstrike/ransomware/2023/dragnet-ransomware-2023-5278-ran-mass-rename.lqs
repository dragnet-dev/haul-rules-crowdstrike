// Dragnet [Ransomware]: dragnet-ransomware-2023-5278 — Mass File Rename (vicesociety)
// Status: experimental | Level: high | ID: 8bd767bd-d0e8-5d6f-8a78-e4a72ba93a8a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
