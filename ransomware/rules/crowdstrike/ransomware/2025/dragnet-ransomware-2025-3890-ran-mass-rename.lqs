// Dragnet [Ransomware]: dragnet-ransomware-2025-3890 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 5034d888-fee3-5f18-9677-5e40d1046442

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
