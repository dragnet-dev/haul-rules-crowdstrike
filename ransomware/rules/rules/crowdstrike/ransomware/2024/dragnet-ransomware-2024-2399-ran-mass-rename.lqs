// Dragnet [Ransomware]: dragnet-ransomware-2024-2399 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: f4b0b7c9-ef7f-5491-8371-7c04d51af46a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
