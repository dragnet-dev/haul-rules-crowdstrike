// Dragnet [Ransomware]: dragnet-ransomware-2022-0533 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: cb260563-5c79-5207-8dae-06b1582c30f6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
