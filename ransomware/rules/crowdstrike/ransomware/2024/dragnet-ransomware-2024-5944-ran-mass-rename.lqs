// Dragnet [Ransomware]: dragnet-ransomware-2024-5944 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: b27a1269-542e-5170-9e26-f206d367fa84

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
