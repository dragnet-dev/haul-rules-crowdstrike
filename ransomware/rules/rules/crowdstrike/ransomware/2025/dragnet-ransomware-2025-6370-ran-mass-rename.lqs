// Dragnet [Ransomware]: dragnet-ransomware-2025-6370 — Mass File Rename (killsec)
// Status: deprecated | Level: high | ID: 280c1c4d-bd49-5cb3-9c4f-f5e09d3994e5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
