// Dragnet [Ransomware]: dragnet-ransomware-2022-0328 — Mass File Rename (qilin)
// Status: deprecated | Level: high | ID: 146c0120-49e0-5d42-b829-60bc97941bb6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
