// Dragnet [Ransomware]: dragnet-ransomware-2025-3110 — Mass File Rename (nightspire)
// Status: deprecated | Level: high | ID: bd652d71-fc3b-5aa8-b43d-f0bb5b547d40

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
