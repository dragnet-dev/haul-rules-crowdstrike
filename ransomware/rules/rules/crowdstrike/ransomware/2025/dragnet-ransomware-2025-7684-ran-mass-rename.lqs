// Dragnet [Ransomware]: dragnet-ransomware-2025-7684 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: 1f78197f-3cd3-50ed-83a1-eefec5de8c8a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
