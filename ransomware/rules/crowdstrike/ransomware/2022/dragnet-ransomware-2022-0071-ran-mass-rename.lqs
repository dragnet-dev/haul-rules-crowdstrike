// Dragnet [Ransomware]: dragnet-ransomware-2022-0071 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 1e59415a-78c4-5428-a58e-56ad796ace43

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
