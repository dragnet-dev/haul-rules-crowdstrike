// Dragnet [Ransomware]: dragnet-ransomware-2021-0316 — Mass File Rename (avoslocker)
// Status: deprecated | Level: high | ID: c8511b8e-c406-5be9-b40a-fd2f82fae6e8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
