// Dragnet [Ransomware]: dragnet-ransomware-2025-1301 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: 58d0187e-2d78-5bb0-a1c9-313d1685d050

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
