// Dragnet [Ransomware]: dragnet-ransomware-2023-1789 — Mass File Rename (losttrust)
// Status: deprecated | Level: high | ID: 1028c0bc-cc9b-53f6-b356-89c5a1da7e4e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
