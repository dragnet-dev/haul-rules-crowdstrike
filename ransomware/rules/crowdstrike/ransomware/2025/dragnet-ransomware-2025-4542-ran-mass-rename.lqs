// Dragnet [Ransomware]: dragnet-ransomware-2025-4542 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 17703ea1-f1de-5f39-920e-92225d63d5c2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
