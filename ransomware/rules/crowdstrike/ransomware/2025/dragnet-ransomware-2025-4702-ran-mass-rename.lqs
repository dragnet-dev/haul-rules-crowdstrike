// Dragnet [Ransomware]: dragnet-ransomware-2025-4702 — Mass File Rename (obscura)
// Status: experimental | Level: high | ID: ef9a2104-4ecf-58fa-81fc-e40f70df5ddd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
