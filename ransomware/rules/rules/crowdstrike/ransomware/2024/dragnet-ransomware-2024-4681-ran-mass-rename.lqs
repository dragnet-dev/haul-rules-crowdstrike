// Dragnet [Ransomware]: dragnet-ransomware-2024-4681 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 2db7cea6-de0f-5859-b666-07ff63e0e4ea

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
