// Dragnet [Ransomware]: dragnet-ransomware-2026-1169 — Mass File Rename (thegentlemen)
// Status: stable | Level: high | ID: af8baaa1-d6cf-5d38-9cfa-fa28bd88567d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
