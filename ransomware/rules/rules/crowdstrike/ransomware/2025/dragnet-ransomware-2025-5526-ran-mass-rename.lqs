// Dragnet [Ransomware]: dragnet-ransomware-2025-5526 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 7c4fb6a7-dc36-57d2-9385-84988de6b144

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
