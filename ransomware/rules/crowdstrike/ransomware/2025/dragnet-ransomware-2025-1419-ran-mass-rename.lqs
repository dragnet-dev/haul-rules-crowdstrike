// Dragnet [Ransomware]: dragnet-ransomware-2025-1419 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: a3b0f871-a72d-5d0e-958e-87d7b0b1558a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
