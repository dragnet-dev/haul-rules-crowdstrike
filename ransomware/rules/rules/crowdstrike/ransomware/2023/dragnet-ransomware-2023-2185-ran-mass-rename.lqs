// Dragnet [Ransomware]: dragnet-ransomware-2023-2185 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: a7317fa4-3212-572b-8d62-c6024ef9e754

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
