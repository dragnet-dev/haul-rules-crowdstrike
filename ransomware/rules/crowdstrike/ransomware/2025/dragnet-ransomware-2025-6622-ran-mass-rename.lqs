// Dragnet [Ransomware]: dragnet-ransomware-2025-6622 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 3d3aedcd-c6a1-5a2b-9af5-2383be4491c9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
