// Dragnet [Ransomware]: dragnet-ransomware-2025-4629 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: c6f154e4-474b-571e-8c38-d3749b65aeec

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
