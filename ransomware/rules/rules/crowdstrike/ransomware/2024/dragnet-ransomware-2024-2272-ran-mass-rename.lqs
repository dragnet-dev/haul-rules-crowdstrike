// Dragnet [Ransomware]: dragnet-ransomware-2024-2272 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: cff0bee9-ee5e-51e3-ae64-8b7ceca80c9c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
