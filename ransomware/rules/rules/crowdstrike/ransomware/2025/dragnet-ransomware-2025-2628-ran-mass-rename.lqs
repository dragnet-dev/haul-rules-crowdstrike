// Dragnet [Ransomware]: dragnet-ransomware-2025-2628 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 2fbad3d7-c902-53a3-9be7-91bf53ad45e6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
