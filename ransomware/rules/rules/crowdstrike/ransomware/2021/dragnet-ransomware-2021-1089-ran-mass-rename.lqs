// Dragnet [Ransomware]: dragnet-ransomware-2021-1089 — Mass File Rename (lv)
// Status: deprecated | Level: high | ID: 39de1fcd-4127-5393-a6a6-ea1ac725c850

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
