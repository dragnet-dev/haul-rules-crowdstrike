// Dragnet [Ransomware]: dragnet-ransomware-2025-7714 — Mass File Rename (play)
// Status: experimental | Level: high | ID: dd8e63b8-569c-547f-b3f9-2903dfe14e8f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
