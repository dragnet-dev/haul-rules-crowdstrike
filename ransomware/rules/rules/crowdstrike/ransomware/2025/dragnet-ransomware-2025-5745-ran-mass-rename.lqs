// Dragnet [Ransomware]: dragnet-ransomware-2025-5745 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 813d7b71-34b1-57b8-aa47-25b755e91de0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
