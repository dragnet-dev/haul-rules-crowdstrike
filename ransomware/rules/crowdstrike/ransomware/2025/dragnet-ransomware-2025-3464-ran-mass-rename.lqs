// Dragnet [Ransomware]: dragnet-ransomware-2025-3464 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: eb0884b2-5310-577a-9e8c-b5e400b2747b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
