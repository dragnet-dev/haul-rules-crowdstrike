// Dragnet [Ransomware]: dragnet-ransomware-2022-1964 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 58eac1d6-b5f4-53a4-a57e-c38f2db21bd8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
