// Dragnet [Ransomware]: dragnet-ransomware-2022-2003 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 610631eb-3ced-520f-a209-d3751c7771e4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
