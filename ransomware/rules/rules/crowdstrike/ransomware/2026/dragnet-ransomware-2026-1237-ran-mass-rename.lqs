// Dragnet [Ransomware]: dragnet-ransomware-2026-1237 — Mass File Rename (netrunner)
// Status: stable | Level: high | ID: 64073962-e44d-5cd8-8df6-0ff873ee19b4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
