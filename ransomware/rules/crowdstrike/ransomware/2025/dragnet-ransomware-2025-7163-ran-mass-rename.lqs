// Dragnet [Ransomware]: dragnet-ransomware-2025-7163 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 9a8e6df1-d2dd-54e8-923c-f669ed33c611

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
