// Dragnet [Ransomware]: dragnet-ransomware-2025-5080 — Mass File Rename (rhysida)
// Status: experimental | Level: high | ID: aab3fae5-3d9e-5e79-92e9-6b000d3b6a23

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
