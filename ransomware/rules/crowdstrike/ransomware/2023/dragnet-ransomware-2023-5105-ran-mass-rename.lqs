// Dragnet [Ransomware]: dragnet-ransomware-2023-5105 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 0d7bc891-d93a-53b5-980b-a5b77a9b1e42

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
