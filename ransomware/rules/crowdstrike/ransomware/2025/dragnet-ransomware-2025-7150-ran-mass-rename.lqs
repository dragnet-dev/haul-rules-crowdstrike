// Dragnet [Ransomware]: dragnet-ransomware-2025-7150 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: ee01d6c6-32d5-5fd7-a864-3b38649ccfef

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
