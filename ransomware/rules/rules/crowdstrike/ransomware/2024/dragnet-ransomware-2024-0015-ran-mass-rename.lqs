// Dragnet [Ransomware]: dragnet-ransomware-2024-0015 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: f65fc004-8266-5163-b439-92bdfb061cce

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
