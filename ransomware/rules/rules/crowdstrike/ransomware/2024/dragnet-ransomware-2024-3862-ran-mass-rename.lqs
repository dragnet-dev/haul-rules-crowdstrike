// Dragnet [Ransomware]: dragnet-ransomware-2024-3862 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: dbde374a-78fc-54dd-bd1a-3a5cb347d636

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
