// Dragnet [Ransomware]: dragnet-ransomware-2023-5034 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 29f89220-4901-5fe8-8630-774c333fc704

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
