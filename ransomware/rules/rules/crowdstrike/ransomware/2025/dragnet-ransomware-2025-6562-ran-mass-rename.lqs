// Dragnet [Ransomware]: dragnet-ransomware-2025-6562 — Mass File Rename (incransom)
// Status: test | Level: high | ID: 15ce1daf-dca4-5a57-9a02-807384edd1c2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
