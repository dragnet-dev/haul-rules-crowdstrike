// Dragnet [Ransomware]: dragnet-ransomware-2021-0192 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 42947e8d-851a-5537-b527-f0fc2c310078

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
