// Dragnet [Ransomware]: dragnet-ransomware-2023-4771 — Mass File Rename (nokoyawa)
// Status: experimental | Level: high | ID: ec9dc12c-43f5-5922-8d60-d223d36248a6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
