// Dragnet [Ransomware]: dragnet-ransomware-2023-2799 — Mass File Rename (malas)
// Status: experimental | Level: high | ID: df879836-7744-59e5-8971-d0d8d271ae03

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
