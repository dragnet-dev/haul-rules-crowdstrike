// Dragnet [Ransomware]: dragnet-ransomware-2025-0353 — Mass File Rename (nightspire)
// Status: deprecated | Level: high | ID: ae06c354-c006-58ce-9ea6-d18f0493511d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
