// Dragnet [Container]: dragnet-container-2026-1997 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 793c8c3f-c1f4-5c85-b487-2e5fd2906a7c

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13*)
| table([timestamp, ComputerName])
| limit(1000)
