// Dragnet [Ransomware]: dragnet-ransomware-2022-2296 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 5bbfa578-3574-5d75-8b8b-87689b5de42b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
