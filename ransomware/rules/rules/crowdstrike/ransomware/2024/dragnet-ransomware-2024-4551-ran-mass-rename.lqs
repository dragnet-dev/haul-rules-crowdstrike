// Dragnet [Ransomware]: dragnet-ransomware-2024-4551 — Mass File Rename (raworld)
// Status: experimental | Level: high | ID: 8b54e904-8f0f-5f49-bfc8-7e26df20d506

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
