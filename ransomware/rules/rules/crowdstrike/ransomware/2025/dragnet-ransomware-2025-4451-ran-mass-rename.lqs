// Dragnet [Ransomware]: dragnet-ransomware-2025-4451 — Mass File Rename (warlock)
// Status: deprecated | Level: high | ID: f1b5278d-f385-5c40-a445-5859f2317f9f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
