// Dragnet [Ransomware]: dragnet-ransomware-2023-3117 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: d8a0e716-3978-549c-b380-6e86d1435dcd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
