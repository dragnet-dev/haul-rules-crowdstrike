// Dragnet [Ransomware]: dragnet-ransomware-2022-1629 — Mass File Rename (blackbasta)
// Status: deprecated | Level: high | ID: 60bd3078-8dfe-5c43-b25e-05eaa8fafdb7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
