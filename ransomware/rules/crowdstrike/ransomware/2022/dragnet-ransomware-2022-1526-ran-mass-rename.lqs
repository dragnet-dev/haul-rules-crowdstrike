// Dragnet [Ransomware]: dragnet-ransomware-2022-1526 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 4a27619c-e04e-51c8-9c8c-f54a1ab93596

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
