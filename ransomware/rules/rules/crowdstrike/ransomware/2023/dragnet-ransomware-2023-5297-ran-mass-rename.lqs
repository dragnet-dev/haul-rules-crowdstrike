// Dragnet [Ransomware]: dragnet-ransomware-2023-5297 — Mass File Rename (rhysida)
// Status: deprecated | Level: high | ID: 9da044d5-b150-50b9-b321-baf5dc2cb4ed

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
