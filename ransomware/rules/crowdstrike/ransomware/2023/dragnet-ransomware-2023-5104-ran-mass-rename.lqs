// Dragnet [Ransomware]: dragnet-ransomware-2023-5104 — Mass File Rename (noescape)
// Status: experimental | Level: high | ID: adabe497-7ed2-58ec-a640-e57daf845ef4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
