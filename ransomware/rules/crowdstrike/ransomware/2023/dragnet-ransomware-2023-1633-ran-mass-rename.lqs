// Dragnet [Ransomware]: dragnet-ransomware-2023-1633 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 523fe80f-8d12-5c1f-9af5-017f00da52da

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
