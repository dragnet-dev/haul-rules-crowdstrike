// Dragnet [Ransomware]: dragnet-ransomware-2025-4134 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: c5ef3297-aa9c-5794-8e09-91d47d1c540d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
