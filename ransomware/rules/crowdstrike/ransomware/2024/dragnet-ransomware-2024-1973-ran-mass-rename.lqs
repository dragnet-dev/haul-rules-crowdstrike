// Dragnet [Ransomware]: dragnet-ransomware-2024-1973 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 5cdfe850-c6da-5d31-b12c-e6170952e180

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
