// Dragnet [Ransomware]: dragnet-ransomware-2022-2493 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 0ae4df24-ebf1-5f03-804f-afb92f60e0db

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
