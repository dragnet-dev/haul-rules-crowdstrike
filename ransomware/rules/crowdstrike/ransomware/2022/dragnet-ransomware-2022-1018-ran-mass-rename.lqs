// Dragnet [Ransomware]: dragnet-ransomware-2022-1018 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 80dee2f0-8e45-583e-b82f-10775f3552cb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
