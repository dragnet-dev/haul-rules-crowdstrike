// Dragnet [Ransomware]: dragnet-ransomware-2023-1776 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 40c6b75b-82d0-561e-b7ea-c4ad1cd2d393

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
