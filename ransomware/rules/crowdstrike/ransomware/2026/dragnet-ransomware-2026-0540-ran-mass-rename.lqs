// Dragnet [Ransomware]: dragnet-ransomware-2026-0540 — Mass File Rename (incransom)
// Status: test | Level: high | ID: c9683c2d-3a3c-5b29-9a4c-e0089cedc2dc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
