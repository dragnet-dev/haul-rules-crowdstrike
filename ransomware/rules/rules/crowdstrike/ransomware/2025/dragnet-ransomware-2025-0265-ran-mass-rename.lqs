// Dragnet [Ransomware]: dragnet-ransomware-2025-0265 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 80a2514b-164f-5535-9041-57e323433093

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
