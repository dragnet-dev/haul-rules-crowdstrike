// Dragnet [Ransomware]: dragnet-ransomware-2023-4959 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: adb096a8-1568-5978-bb9e-52aa01f17ff7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
