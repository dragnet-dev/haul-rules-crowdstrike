// Dragnet [Ransomware]: dragnet-ransomware-2024-1280 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: 12ba0f54-a71e-584e-af55-0404ee0e5293

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
