// Dragnet [Ransomware]: dragnet-ransomware-2024-2199 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: a45c62e7-c6de-5001-a5b1-e914b055eb22

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
