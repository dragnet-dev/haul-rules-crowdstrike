// Dragnet [Ransomware]: dragnet-ransomware-2025-4669 — Mass File Rename (lockbit5)
// Status: experimental | Level: high | ID: 641e5d75-9724-55b8-94a8-0ef896f2a345

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
