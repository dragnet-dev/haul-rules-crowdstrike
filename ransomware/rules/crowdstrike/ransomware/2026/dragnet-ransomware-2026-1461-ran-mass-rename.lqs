// Dragnet [Ransomware]: dragnet-ransomware-2026-1461 — Mass File Rename (payoutsking)
// Status: deprecated | Level: high | ID: c29d8bc6-74df-56cb-bc6c-97d765ed27b5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
