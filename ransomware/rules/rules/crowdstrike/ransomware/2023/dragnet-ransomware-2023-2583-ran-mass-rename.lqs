// Dragnet [Ransomware]: dragnet-ransomware-2023-2583 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 56a4e027-14bf-5ae0-923f-5a5180db69b0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
