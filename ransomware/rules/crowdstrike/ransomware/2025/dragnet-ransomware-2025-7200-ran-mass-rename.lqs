// Dragnet [Ransomware]: dragnet-ransomware-2025-7200 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: accd0755-2f50-56b8-9da7-4afd908da5f2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
