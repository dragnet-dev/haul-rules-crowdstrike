// Dragnet [Ransomware]: dragnet-ransomware-2024-5057 — Mass File Rename (BrainCipher)
// Status: experimental | Level: high | ID: 31970ea9-a69c-5d58-980f-424e840b5a95

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
