// Dragnet [Ransomware]: dragnet-ransomware-2023-0951 — Mass File Rename (mallox)
// Status: experimental | Level: high | ID: 5af6fc18-13b8-5e16-96f2-328aaa26eaf5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
