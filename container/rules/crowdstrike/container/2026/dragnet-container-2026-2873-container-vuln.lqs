// Dragnet [Container]: dragnet-container-2026-2873 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 9fc1505a-168f-58bc-8366-acf624dac418

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
