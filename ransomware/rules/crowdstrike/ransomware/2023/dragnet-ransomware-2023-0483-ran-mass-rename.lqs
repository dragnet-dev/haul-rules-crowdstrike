// Dragnet [Ransomware]: dragnet-ransomware-2023-0483 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: c2c9cbaf-7964-58b7-8191-3072a2268427

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
