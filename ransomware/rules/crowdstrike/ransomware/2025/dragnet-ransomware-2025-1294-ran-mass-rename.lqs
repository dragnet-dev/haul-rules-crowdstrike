// Dragnet [Ransomware]: dragnet-ransomware-2025-1294 — Mass File Rename (interlock)
// Status: experimental | Level: high | ID: ef41abf3-b971-521d-903e-18daf46b1390

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
