// Dragnet [Ransomware]: dragnet-ransomware-2023-3279 — Mass File Rename (knight)
// Status: experimental | Level: high | ID: 0afc3b30-0a04-5181-963c-c54693568e8a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
