// Dragnet [Ransomware]: dragnet-ransomware-2023-4540 — Mass File Rename (ransomed)
// Status: experimental | Level: high | ID: d8ec5cbf-e7c5-58ab-8867-68cdf20bfe4a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
