// Dragnet [Ransomware]: dragnet-ransomware-2023-2812 — Mass File Rename (malas)
// Status: experimental | Level: high | ID: b9d84011-9290-5851-bb98-3ec6a266966d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
