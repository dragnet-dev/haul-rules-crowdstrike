// Dragnet [Ransomware]: dragnet-ransomware-2024-1550 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: eb3da4d8-c6c2-5973-9574-6c5a47e9eba9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
