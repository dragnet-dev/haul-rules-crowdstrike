// Dragnet [Ransomware]: dragnet-ransomware-2025-4705 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: d4c9707b-883f-5cad-ba8b-105ed12549aa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
