// Dragnet [Ransomware]: dragnet-ransomware-2023-1739 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 3b80702d-6b76-5e45-a2a0-e77bfe6c5eb6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
