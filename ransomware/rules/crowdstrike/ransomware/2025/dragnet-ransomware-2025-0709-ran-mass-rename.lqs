// Dragnet [Ransomware]: dragnet-ransomware-2025-0709 — Mass File Rename (hellcat)
// Status: deprecated | Level: high | ID: f377c6a3-6909-503b-b405-ce514028512f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
