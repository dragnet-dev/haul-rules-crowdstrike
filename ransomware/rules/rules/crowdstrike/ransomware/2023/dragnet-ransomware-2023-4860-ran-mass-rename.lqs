// Dragnet [Ransomware]: dragnet-ransomware-2023-4860 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 66bbd9b1-49a0-5cca-8030-7e2494434fb7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
