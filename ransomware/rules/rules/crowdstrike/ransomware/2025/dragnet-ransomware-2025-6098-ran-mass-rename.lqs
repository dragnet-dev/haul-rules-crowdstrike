// Dragnet [Ransomware]: dragnet-ransomware-2025-6098 — Mass File Rename (direwolf)
// Status: experimental | Level: high | ID: c73633c5-b282-5643-b31e-e7f540acc2c1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
