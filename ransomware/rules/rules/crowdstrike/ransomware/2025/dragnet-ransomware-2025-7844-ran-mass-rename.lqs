// Dragnet [Ransomware]: dragnet-ransomware-2025-7844 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 11c03ee2-35be-5634-b105-267bcaf06967

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
