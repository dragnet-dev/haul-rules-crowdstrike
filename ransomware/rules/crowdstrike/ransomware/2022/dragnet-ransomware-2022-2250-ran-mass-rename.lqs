// Dragnet [Ransomware]: dragnet-ransomware-2022-2250 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: df485660-664d-5a9c-a414-d9810919c791

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
