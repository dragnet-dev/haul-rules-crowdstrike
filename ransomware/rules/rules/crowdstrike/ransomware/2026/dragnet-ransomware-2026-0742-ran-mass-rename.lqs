// Dragnet [Ransomware]: dragnet-ransomware-2026-0742 — Mass File Rename (BrainCipher)
// Status: stable | Level: high | ID: 95fe53d7-6c75-541f-aea3-66bb244e6354

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
