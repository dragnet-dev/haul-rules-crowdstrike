// Dragnet [Ransomware]: dragnet-ransomware-2025-3658 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 7436374f-3d8f-583d-94a6-bd8f4bf52124

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
