// Dragnet [Ransomware]: dragnet-ransomware-2025-4053 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: cec09fd0-cecd-5a6e-bd58-7a42d1020593

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
