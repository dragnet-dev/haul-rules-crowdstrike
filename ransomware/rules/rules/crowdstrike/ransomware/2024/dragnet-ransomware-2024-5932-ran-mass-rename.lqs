// Dragnet [Ransomware]: dragnet-ransomware-2024-5932 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 90e47cce-b0a8-5cba-b6ae-718c462fa663

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
