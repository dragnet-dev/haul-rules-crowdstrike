// Dragnet [Ransomware]: dragnet-ransomware-2024-2156 — Mass File Rename (raworld)
// Status: experimental | Level: high | ID: 39229c08-c273-545a-ad78-bd48b135344e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
