// Dragnet [Container]: dragnet-container-2026-1457 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: a97cb855-a10d-5350-a5ed-9fdb98d92d6f

#event_simpleName=*
| (ImageFileName = *amazonlinux:1* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:7* OR ImageFileName = *oraclelinux:7* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:14.04* OR ImageFileName = *ubuntu:14.04-ESM* OR ImageFileName = *ubuntu:14.10*)
| table([timestamp, ComputerName])
| limit(1000)
