// Dragnet [Ransomware]: dragnet-ransomware-2026-2288 — Mass File Rename (nightspire)
// Status: deprecated | Level: high | ID: 1096ea5c-71a0-5048-b71b-a2c7be8e8c02

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
