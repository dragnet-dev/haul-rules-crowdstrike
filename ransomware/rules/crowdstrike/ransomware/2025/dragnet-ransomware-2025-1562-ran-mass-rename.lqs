// Dragnet [Ransomware]: dragnet-ransomware-2025-1562 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 4bd65dbf-db5c-5436-81b7-670c2dcfdda1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
