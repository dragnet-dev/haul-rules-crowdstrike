// Dragnet [Ransomware]: dragnet-ransomware-2024-5770 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 00c25987-2fca-5d9d-bf74-fb5bb874a78c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
