// Dragnet [Ransomware]: dragnet-ransomware-2026-3090 — Mass File Rename (incransom)
// Status: test | Level: high | ID: 22dbd5b4-8254-5599-9c46-75271c8d7451

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
