// Dragnet [Ransomware]: dragnet-ransomware-2025-4163 — Mass File Rename (interlock)
// Status: experimental | Level: high | ID: 25640d12-a140-5b00-a3cb-122d1152f1aa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
