// Dragnet [Ransomware]: dragnet-ransomware-2024-0673 — Mass File Rename (darkvault)
// Status: experimental | Level: high | ID: 147739d3-0a4e-5271-96d6-252e9c12a0fe

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
