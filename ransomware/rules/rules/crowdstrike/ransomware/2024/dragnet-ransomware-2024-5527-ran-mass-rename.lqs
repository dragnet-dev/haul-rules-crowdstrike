// Dragnet [Ransomware]: dragnet-ransomware-2024-5527 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 9a624433-caaf-598a-9e22-c072166a8a38

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
