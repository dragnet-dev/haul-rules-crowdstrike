// Dragnet [Ransomware]: dragnet-ransomware-2025-5987 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 826dd867-55d5-5760-90fc-8d4b73cc8542

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
