// Dragnet [Ransomware]: dragnet-ransomware-2025-4933 — Mass File Rename (datacarry)
// Status: deprecated | Level: high | ID: 69725cb0-7327-5d3b-b2c3-4dea9d30076f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
