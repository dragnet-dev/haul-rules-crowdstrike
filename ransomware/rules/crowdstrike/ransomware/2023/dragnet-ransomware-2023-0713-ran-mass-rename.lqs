// Dragnet [Ransomware]: dragnet-ransomware-2023-0713 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 7d5e4d15-ea4c-55e9-8012-a49798e9ed42

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
