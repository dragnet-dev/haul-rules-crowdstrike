// Dragnet [Ransomware]: dragnet-ransomware-2023-3299 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: f505983e-7c81-5ddb-814e-962614261897

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
