// Dragnet [Ransomware]: dragnet-ransomware-2024-5979 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 73995394-016b-5281-92c3-b05d2d678c9e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
