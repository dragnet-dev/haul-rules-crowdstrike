// Dragnet [Ransomware]: dragnet-ransomware-2025-0724 — Mass File Rename (handala)
// Status: experimental | Level: high | ID: ca026b46-cb1a-573d-9e3f-b3429c74e9bd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
