// Dragnet [Ransomware]: dragnet-ransomware-2025-5642 — Mass File Rename (flocker)
// Status: experimental | Level: high | ID: bd227b46-f2da-59da-ac66-a962e483109c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
