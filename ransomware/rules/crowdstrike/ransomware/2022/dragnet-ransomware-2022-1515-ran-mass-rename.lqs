// Dragnet [Ransomware]: dragnet-ransomware-2022-1515 — Mass File Rename (blackbasta)
// Status: deprecated | Level: high | ID: b14acf6e-8bc5-5300-9279-332f8f2f028d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
