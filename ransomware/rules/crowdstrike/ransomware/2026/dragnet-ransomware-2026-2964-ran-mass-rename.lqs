// Dragnet [Ransomware]: dragnet-ransomware-2026-2964 — Mass File Rename (lapsus$)
// Status: deprecated | Level: high | ID: a676ce1a-68a0-5e6a-9ddf-1bacda5bd162

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
