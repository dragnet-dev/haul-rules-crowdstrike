// Dragnet [Ransomware]: dragnet-ransomware-2025-4174 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 7bcaa0d7-8d3f-52b3-b5b4-6d5a061d8eba

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
