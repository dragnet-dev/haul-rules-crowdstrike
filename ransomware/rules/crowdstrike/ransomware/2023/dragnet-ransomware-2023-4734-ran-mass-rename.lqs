// Dragnet [Ransomware]: dragnet-ransomware-2023-4734 — Mass File Rename (losttrust)
// Status: deprecated | Level: high | ID: 6c131fe1-0dcf-5166-aa14-c59ac06ab5d2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
