// Dragnet [Ransomware]: dragnet-ransomware-2026-1934 — Mass File Rename (lockbit5)
// Status: stable | Level: high | ID: 19edb8a1-6f2c-51aa-9ec0-bcd588f3fdb4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
