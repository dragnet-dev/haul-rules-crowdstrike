// Dragnet [Ransomware]: dragnet-ransomware-2022-1254 — Mass File Rename (dataleak)
// Status: deprecated | Level: high | ID: baf431bb-ffcc-5cc9-a48b-8a9ec9eba01f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
