// Dragnet [Ransomware]: dragnet-ransomware-2023-4901 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: ffbd9f33-a262-58ed-8ce7-8e9b139a6833

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
