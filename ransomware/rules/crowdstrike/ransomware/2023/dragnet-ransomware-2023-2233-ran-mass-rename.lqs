// Dragnet [Ransomware]: dragnet-ransomware-2023-2233 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 194605a3-3dc1-5163-bca2-d5aa37b082f5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
