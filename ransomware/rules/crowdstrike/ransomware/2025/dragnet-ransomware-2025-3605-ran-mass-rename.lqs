// Dragnet [Ransomware]: dragnet-ransomware-2025-3605 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 397cc2d0-79b8-5aaf-b918-487166319ad5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
