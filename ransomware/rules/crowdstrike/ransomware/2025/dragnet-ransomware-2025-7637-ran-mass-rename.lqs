// Dragnet [Ransomware]: dragnet-ransomware-2025-7637 — Mass File Rename (payoutsking)
// Status: deprecated | Level: high | ID: 2192e446-727d-5509-b534-02aeddd4ab91

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
