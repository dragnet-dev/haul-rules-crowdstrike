// Dragnet [Ransomware]: dragnet-ransomware-2025-2226 — Mass File Rename (fog)
// Status: deprecated | Level: high | ID: 22e3eebf-c430-5167-969b-c0312be2d116

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
