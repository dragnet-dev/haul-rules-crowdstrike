// Dragnet [Ransomware]: dragnet-ransomware-2024-0542 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: 7a828412-a7e6-5e3f-97dc-fb3a1231d6af

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
