// Dragnet [Ransomware]: dragnet-ransomware-2026-2224 — Mass File Rename (lamashtu)
// Status: stable | Level: high | ID: fdc4f760-dd9a-5a8c-9b53-238ddcb6d4b5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
