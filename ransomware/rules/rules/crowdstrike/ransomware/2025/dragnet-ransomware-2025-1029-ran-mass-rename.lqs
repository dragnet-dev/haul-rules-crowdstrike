// Dragnet [Ransomware]: dragnet-ransomware-2025-1029 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 5b17d3ef-a354-53a2-85cb-6f25f391bcce

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
