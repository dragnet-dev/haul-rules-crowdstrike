// Dragnet [Ransomware]: dragnet-ransomware-2025-5920 — Mass File Rename (devman)
// Status: experimental | Level: high | ID: b863fa3f-4325-5157-9fd8-619c3203da71

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
