// Dragnet [Ransomware]: dragnet-ransomware-2022-2584 — Mass File Rename (cuba)
// Status: deprecated | Level: high | ID: 463659ce-6050-5686-806c-913f47bc9213

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
