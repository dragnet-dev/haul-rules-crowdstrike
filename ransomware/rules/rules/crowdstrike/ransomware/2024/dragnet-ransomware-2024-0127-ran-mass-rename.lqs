// Dragnet [Ransomware]: dragnet-ransomware-2024-0127 — Mass File Rename (cloak)
// Status: experimental | Level: high | ID: 3b82e368-911e-5899-9bdb-1bea194d53d7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
