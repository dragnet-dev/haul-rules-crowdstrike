// Dragnet [Ransomware]: dragnet-ransomware-2024-5485 — Mass File Rename (cloak)
// Status: deprecated | Level: high | ID: bc3f132c-fe8e-5457-8b2d-84dee2a3f5d8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
