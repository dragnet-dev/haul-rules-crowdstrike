// Dragnet [Ransomware]: dragnet-ransomware-2022-1640 — Mass File Rename (blackbasta)
// Status: deprecated | Level: high | ID: df1aa26e-9dd5-531c-b082-e83a82e1b782

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
