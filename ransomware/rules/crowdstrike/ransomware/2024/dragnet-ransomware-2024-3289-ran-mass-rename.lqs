// Dragnet [Ransomware]: dragnet-ransomware-2024-3289 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 124827a2-d584-5ab5-b8de-ce2e07dc7675

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
