// Dragnet [Ransomware]: dragnet-ransomware-2026-0185 — Mass File Rename (spacebears)
// Status: test | Level: high | ID: 32995cd6-3a66-563c-bedc-c3dcd41c718e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
