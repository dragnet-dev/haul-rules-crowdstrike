// Dragnet [Ransomware]: dragnet-ransomware-2024-0007 — Mass File Rename (dragonforce)
// Status: deprecated | Level: high | ID: cc4b0d77-e0e3-541a-bdac-d62fef97d567

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
