// Dragnet [Ransomware]: dragnet-ransomware-2022-3043 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 2422ee88-782f-5c4c-abaa-c29306a87feb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
