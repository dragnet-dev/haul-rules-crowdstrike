// Dragnet [Ransomware]: dragnet-ransomware-2023-3270 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 96095812-664a-5bcd-abf5-67b859f17452

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
