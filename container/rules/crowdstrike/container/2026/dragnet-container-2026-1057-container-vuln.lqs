// Dragnet [Container]: dragnet-container-2026-1057 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 46669105-b3b4-581e-9265-636d8e4f8057

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:8* OR ImageFileName = *ubuntu:16.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
