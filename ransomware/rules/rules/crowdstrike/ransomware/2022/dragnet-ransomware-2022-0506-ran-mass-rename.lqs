// Dragnet [Ransomware]: dragnet-ransomware-2022-0506 — Mass File Rename (royal)
// Status: deprecated | Level: high | ID: b9b14a0e-c99d-56e4-a661-4ac47aa25ffe

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
