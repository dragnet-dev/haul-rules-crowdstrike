// Dragnet [Ransomware]: dragnet-ransomware-2024-0713 — Mass File Rename (play)
// Status: experimental | Level: high | ID: e3e1bc2f-f1f0-50f7-9070-9f693c7bf142

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
