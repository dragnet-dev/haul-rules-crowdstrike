// Dragnet [Container]: dragnet-container-2024-0772 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: a72e043c-2527-5ab8-8dc0-2e7707d1ba24

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:9* OR ImageFileName = *ubuntu:16.04* OR ImageFileName = *ubuntu:18.04* OR ImageFileName = *ubuntu:19.10*)
| table([timestamp, ComputerName])
| limit(1000)
