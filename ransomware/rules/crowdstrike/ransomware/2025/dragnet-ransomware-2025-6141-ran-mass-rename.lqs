// Dragnet [Ransomware]: dragnet-ransomware-2025-6141 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 52838d36-ab1b-59cc-8ae3-f1d7eca9d04f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
