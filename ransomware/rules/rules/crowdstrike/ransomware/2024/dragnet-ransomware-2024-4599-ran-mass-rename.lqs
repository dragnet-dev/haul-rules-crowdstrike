// Dragnet [Ransomware]: dragnet-ransomware-2024-4599 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 426d2c92-2506-551e-a403-53872e1e2ccf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
