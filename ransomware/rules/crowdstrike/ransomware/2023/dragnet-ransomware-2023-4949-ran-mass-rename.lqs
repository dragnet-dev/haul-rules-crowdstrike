// Dragnet [Ransomware]: dragnet-ransomware-2023-4949 — Mass File Rename (trigona)
// Status: experimental | Level: high | ID: aeb68479-2d27-5b5b-94c8-575a4618a7e5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
