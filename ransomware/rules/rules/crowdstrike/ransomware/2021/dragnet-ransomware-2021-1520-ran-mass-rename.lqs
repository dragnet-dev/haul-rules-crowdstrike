// Dragnet [Ransomware]: dragnet-ransomware-2021-1520 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 466bb9e3-08f5-5a10-bb50-a846c3e94856

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
