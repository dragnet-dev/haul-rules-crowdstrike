// Dragnet [Ransomware]: dragnet-ransomware-2022-3015 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 354d8cc4-45da-55a5-8c8b-74f0cfc38ea4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
