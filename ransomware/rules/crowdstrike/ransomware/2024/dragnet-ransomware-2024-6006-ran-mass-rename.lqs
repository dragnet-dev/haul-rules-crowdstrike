// Dragnet [Ransomware]: dragnet-ransomware-2024-6006 — Mass File Rename (snatch)
// Status: experimental | Level: high | ID: cc9e770d-81c4-5fee-abe7-959db5e0a33d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
