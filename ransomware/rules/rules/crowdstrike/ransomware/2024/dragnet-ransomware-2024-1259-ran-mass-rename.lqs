// Dragnet [Ransomware]: dragnet-ransomware-2024-1259 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 910ab053-0854-5900-8517-e6a034fa6221

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
