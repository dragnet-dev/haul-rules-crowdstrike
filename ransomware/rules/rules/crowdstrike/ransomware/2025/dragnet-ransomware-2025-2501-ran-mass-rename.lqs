// Dragnet [Ransomware]: dragnet-ransomware-2025-2501 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 72d75481-74e7-5889-90e7-90caabada2d2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
