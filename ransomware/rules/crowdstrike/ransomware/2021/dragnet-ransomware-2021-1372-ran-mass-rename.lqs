// Dragnet [Ransomware]: dragnet-ransomware-2021-1372 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 3d715bbc-e7d3-580e-a336-5126f8ae37d2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
