// Dragnet [Ransomware]: dragnet-ransomware-2022-1856 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 3e9aac1c-e6be-5dd3-9a55-da433387d13f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
