// Dragnet [Ransomware]: dragnet-ransomware-2025-3899 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 81f18824-5421-514d-b2f0-1c7c7a90d412

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
