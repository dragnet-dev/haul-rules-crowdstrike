// Dragnet [Ransomware]: dragnet-ransomware-2022-1940 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 7dc4d2aa-2658-5543-9877-0e188d2f6fdc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
