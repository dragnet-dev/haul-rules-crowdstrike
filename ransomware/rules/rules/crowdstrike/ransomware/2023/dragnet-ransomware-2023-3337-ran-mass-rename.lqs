// Dragnet [Ransomware]: dragnet-ransomware-2023-3337 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 4aeb8346-8cf4-5f2d-969b-17c15467048c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
