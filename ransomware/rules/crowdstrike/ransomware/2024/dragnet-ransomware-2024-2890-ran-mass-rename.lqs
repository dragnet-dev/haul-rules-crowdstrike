// Dragnet [Ransomware]: dragnet-ransomware-2024-2890 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 4fd17594-058f-5a5c-94b5-0b28f7569b6e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
