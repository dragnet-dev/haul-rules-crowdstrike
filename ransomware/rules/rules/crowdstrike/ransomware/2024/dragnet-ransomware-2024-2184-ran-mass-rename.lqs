// Dragnet [Ransomware]: dragnet-ransomware-2024-2184 — Mass File Rename (ElDorado)
// Status: deprecated | Level: high | ID: 16a6faf2-d037-59bf-94c2-4234dfe3d401

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
