// Dragnet [Ransomware]: dragnet-ransomware-2026-1349 — Mass File Rename (ciphbit)
// Status: deprecated | Level: high | ID: a6352b91-87ef-5e54-97b8-b93444b5bf2b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
