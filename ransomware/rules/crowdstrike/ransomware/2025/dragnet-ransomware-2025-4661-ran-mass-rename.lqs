// Dragnet [Ransomware]: dragnet-ransomware-2025-4661 — Mass File Rename (lockbit5)
// Status: experimental | Level: high | ID: c1d7e120-1364-5381-bde3-b97ae63e6610

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
