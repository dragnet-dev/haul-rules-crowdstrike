// Dragnet [Ransomware]: dragnet-ransomware-2025-2321 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 06162ee9-a6e3-531f-a2b2-e83268ea9a21

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
