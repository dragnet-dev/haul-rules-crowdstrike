// Dragnet [Ransomware]: dragnet-ransomware-2022-1520 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 65d68f83-32c2-5554-becd-19abe81ce34d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
