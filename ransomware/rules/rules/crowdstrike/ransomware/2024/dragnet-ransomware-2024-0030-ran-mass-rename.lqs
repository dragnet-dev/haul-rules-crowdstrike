// Dragnet [Ransomware]: dragnet-ransomware-2024-0030 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 22c62144-96f3-5a78-8fe6-8d8485b26350

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
