// Dragnet [Container]: dragnet-container-2024-0796 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 4644a7e3-5a40-58e8-8ecb-57b814a1f330

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
