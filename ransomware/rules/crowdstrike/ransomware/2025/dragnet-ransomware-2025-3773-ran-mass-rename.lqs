// Dragnet [Ransomware]: dragnet-ransomware-2025-3773 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 0b509fa1-8c25-530e-bd11-d8f91dc25ab2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
