// Dragnet [Ransomware]: dragnet-ransomware-2025-7365 — Mass File Rename (weyhro)
// Status: experimental | Level: high | ID: a3348757-e096-58f1-bdea-224a9921d14d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
