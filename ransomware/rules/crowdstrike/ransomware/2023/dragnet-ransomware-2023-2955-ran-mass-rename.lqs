// Dragnet [Ransomware]: dragnet-ransomware-2023-2955 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 671ba2ed-266e-599e-9d2a-94b5092c9275

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
