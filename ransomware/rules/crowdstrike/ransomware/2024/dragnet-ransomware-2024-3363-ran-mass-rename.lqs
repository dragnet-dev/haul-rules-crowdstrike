// Dragnet [Ransomware]: dragnet-ransomware-2024-3363 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: 7ebb64fb-1358-5d7e-9468-f7a8517761ea

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
