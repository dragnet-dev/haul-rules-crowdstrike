// Dragnet [Ransomware]: dragnet-ransomware-2026-1425 — Mass File Rename (lockbit5)
// Status: stable | Level: high | ID: 61aceb30-f768-5f28-8e83-63455e3a06a1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
