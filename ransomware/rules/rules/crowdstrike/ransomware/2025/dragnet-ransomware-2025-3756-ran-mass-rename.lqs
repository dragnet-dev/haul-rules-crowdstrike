// Dragnet [Ransomware]: dragnet-ransomware-2025-3756 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: a22d39f8-7750-5344-8315-3d473bdda5dc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
