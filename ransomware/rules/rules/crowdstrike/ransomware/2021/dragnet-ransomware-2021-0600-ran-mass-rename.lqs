// Dragnet [Ransomware]: dragnet-ransomware-2021-0600 — Mass File Rename (blackshadow)
// Status: deprecated | Level: high | ID: c6540eab-0f0e-50f7-905d-601602af3fe5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
