// Dragnet [Ransomware]: dragnet-ransomware-2025-4340 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: c2e37b09-8c03-552d-8b27-60a122693bc2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
