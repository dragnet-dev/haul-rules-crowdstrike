// Dragnet [Ransomware]: dragnet-ransomware-2022-2948 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: dc27fb8d-b0c2-5eb2-b005-65c44b1df1ef

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
