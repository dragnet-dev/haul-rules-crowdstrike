// Dragnet [Ransomware]: dragnet-ransomware-2024-1966 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 584bcb4d-de06-5c8e-8a63-a9e505bb2c75

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
