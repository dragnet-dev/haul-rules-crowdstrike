// Dragnet [Ransomware]: dragnet-ransomware-2024-2718 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: c45f5d11-df4f-5e31-9f0d-07cf3999803a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
