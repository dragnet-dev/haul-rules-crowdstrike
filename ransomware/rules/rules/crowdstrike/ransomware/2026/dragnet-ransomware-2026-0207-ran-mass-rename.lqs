// Dragnet [Ransomware]: dragnet-ransomware-2026-0207 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: b5b9615a-52ee-5b1c-8795-e064a5a61840

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
