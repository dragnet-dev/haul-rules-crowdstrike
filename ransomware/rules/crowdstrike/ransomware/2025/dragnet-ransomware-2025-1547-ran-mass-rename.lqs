// Dragnet [Ransomware]: dragnet-ransomware-2025-1547 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: 9cec0ccd-713a-5767-ab1b-c44b36bb8a55

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
