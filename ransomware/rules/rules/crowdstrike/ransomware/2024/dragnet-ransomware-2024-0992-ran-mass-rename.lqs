// Dragnet [Ransomware]: dragnet-ransomware-2024-0992 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 39bd766f-b95e-525e-a540-777316552f36

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
