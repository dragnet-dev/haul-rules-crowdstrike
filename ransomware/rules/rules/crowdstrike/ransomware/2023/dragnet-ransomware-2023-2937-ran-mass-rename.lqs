// Dragnet [Ransomware]: dragnet-ransomware-2023-2937 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: eefd2a4d-e5fb-57a8-bd2e-9ca435be347d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
