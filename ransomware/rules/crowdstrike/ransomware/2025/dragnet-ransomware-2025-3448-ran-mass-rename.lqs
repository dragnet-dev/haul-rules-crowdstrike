// Dragnet [Ransomware]: dragnet-ransomware-2025-3448 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 7c0d18af-44b6-59c5-931a-b4b9d494ff48

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
