// Dragnet [Ransomware]: dragnet-ransomware-2024-4660 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: f848eba7-b08a-5bcf-baac-a1bdff8e8108

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
