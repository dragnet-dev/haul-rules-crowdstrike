// Dragnet [Ransomware]: dragnet-ransomware-2024-2624 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: da264c4c-0c5b-5e5b-9f54-88ec85aa205b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
