// Dragnet [Ransomware]: dragnet-ransomware-2022-2841 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: ff53a65d-7590-5816-aa06-4866fdc640b4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
