// Dragnet [Ransomware]: dragnet-ransomware-2024-5473 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: f21c5173-f587-55ab-a941-5e31a4414fa1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
