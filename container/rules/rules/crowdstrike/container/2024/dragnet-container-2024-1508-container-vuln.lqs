// Dragnet [Container]: dragnet-container-2024-1508 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: cec9be0d-c1a6-5241-b73d-e6e4bbe079ca

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:9*)
| table([timestamp, ComputerName])
| limit(1000)
