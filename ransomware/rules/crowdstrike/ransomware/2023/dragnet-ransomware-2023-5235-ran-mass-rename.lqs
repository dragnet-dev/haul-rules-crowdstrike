// Dragnet [Ransomware]: dragnet-ransomware-2023-5235 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: a31c9a9c-e68c-56cf-a7e1-e72094f394c0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
