// Dragnet [Ransomware]: dragnet-ransomware-2025-0178 — Mass File Rename (kraken)
// Status: experimental | Level: high | ID: 76edb845-f2a1-55d4-be8f-436bc869d4c2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
