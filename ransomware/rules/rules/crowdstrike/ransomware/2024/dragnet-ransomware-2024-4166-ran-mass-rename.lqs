// Dragnet [Ransomware]: dragnet-ransomware-2024-4166 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 4a649d07-8eb9-56b3-9533-26f67c094aeb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
