// Dragnet [Ransomware]: dragnet-ransomware-2022-1862 — Mass File Rename (onyx)
// Status: deprecated | Level: high | ID: 46cec21b-5bba-5fee-b3aa-86f436ce3054

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
