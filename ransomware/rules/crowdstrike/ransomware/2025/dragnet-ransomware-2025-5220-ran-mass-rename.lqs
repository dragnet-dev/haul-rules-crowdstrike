// Dragnet [Ransomware]: dragnet-ransomware-2025-5220 — Mass File Rename (ciphbit)
// Status: deprecated | Level: high | ID: ef3daf9c-2f72-5e50-b374-2b79e495b2fc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
