// Dragnet [Ransomware]: dragnet-ransomware-2020-0178 — Mass File Rename (ragnarlocker)
// Status: deprecated | Level: high | ID: 6590a86b-1d33-5f92-8f24-4130500482b6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
