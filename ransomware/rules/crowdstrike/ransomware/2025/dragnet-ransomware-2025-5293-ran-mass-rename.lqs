// Dragnet [Ransomware]: dragnet-ransomware-2025-5293 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: f0e1157e-7314-5611-9ada-af3c01b975bb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
