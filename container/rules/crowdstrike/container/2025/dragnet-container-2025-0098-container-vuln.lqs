// Dragnet [Container]: dragnet-container-2025-0098 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: bac2f47f-a56a-5a64-b0c2-0aa7973ebc03

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *redhat/ubi9:*)
| table([timestamp, ComputerName])
| limit(1000)
