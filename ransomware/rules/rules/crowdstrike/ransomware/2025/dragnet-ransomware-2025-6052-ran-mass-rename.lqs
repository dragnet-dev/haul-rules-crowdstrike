// Dragnet [Ransomware]: dragnet-ransomware-2025-6052 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 8e0c6f8f-557f-5f67-991b-09678c1fc8e7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
