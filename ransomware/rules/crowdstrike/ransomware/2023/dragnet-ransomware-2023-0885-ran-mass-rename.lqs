// Dragnet [Ransomware]: dragnet-ransomware-2023-0885 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: f7e6ad42-6c23-5090-95c6-4ac965eae54b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
