// Dragnet [Ransomware]: dragnet-ransomware-2021-1031 — Mass File Rename (atomsilo)
// Status: deprecated | Level: high | ID: 517c6ac0-2b12-5b9a-86cc-52c579f3ae23

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
