// Dragnet [Ransomware]: dragnet-ransomware-2025-2714 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 2d753567-f44c-5416-85c9-e07d1de1e654

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
