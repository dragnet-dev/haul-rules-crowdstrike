// Dragnet [Ransomware]: dragnet-ransomware-2023-4576 — Mass File Rename (medusalocker)
// Status: experimental | Level: high | ID: 931e4b1a-7ace-5104-9b42-0d53eb1499cb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
