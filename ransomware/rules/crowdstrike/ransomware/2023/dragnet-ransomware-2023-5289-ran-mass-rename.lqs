// Dragnet [Ransomware]: dragnet-ransomware-2023-5289 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 34922052-f7e0-585d-a349-7e82317f9f55

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
