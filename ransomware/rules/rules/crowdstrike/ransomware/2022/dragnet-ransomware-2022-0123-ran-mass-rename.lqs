// Dragnet [Ransomware]: dragnet-ransomware-2022-0123 — Mass File Rename (darkleakmarket)
// Status: deprecated | Level: high | ID: d81aaa50-5851-5ece-b381-72486483710d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
