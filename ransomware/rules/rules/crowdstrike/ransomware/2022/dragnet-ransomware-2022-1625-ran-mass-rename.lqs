// Dragnet [Ransomware]: dragnet-ransomware-2022-1625 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 0f4f437f-d42b-5b13-b9f0-a72a23b19187

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
