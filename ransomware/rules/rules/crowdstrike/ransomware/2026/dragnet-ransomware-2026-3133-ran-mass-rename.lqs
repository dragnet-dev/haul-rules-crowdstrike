// Dragnet [Ransomware]: dragnet-ransomware-2026-3133 — Mass File Rename (AiLock)
// Status: deprecated | Level: high | ID: 321009b8-8adc-5737-be20-24035473c732

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
