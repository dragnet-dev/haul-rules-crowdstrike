// Dragnet [Ransomware]: dragnet-ransomware-2023-0119 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 9808538b-2f7f-514c-a10a-eb366dc07829

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
