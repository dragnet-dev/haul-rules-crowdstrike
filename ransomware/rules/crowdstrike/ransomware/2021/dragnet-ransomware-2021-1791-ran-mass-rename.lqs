// Dragnet [Ransomware]: dragnet-ransomware-2021-1791 — Mass File Rename (alphv)
// Status: deprecated | Level: high | ID: 10d4a31e-7b30-5f58-8d23-7e6ab0429e10

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
