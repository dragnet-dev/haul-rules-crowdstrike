// Dragnet [Ransomware]: dragnet-ransomware-2022-1346 — Mass File Rename (lv)
// Status: deprecated | Level: high | ID: 0d98c635-8758-5df5-8e26-610ef5f5d84d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
