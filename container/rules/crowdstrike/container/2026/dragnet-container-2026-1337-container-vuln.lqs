// Status: deprecated | Level: high | ID: 59dc1335-c173-575c-bd85-3469b66e8e35

#event_simpleName=*
| (ImageFileName = *debian:7* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:14.04* OR ImageFileName = *ubuntu:14.10* OR ImageFileName = *ubuntu:15.04* OR ImageFileName = *ubuntu:15.10* OR ImageFileName = *ubuntu:16.04* OR ImageFileName = *ubuntu:16.04-ESM* OR ImageFileName = *ubuntu:16.10* OR ImageFileName = *ubuntu:17.04* OR ImageFileName = *ubuntu:17.10* OR ImageFileName = *ubuntu:18.04* OR ImageFileName = *ubuntu:18.10*)
| table([timestamp, ComputerName])
| limit(1000)
