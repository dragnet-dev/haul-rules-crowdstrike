// Dragnet [Container]: dragnet-container-2024-0450 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: c53607d5-b3e9-525a-b7c6-4125ccb0adda

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
