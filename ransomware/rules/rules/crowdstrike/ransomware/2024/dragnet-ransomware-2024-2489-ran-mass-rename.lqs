// Dragnet [Ransomware]: dragnet-ransomware-2024-2489 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 4535515c-0279-5411-af5c-df94437c08b6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
