// Dragnet [Ransomware]: dragnet-ransomware-2023-0399 — Mass File Rename (meow)
// Status: experimental | Level: high | ID: 72928d49-e95b-5fe0-bc7c-68c4b4563721

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
