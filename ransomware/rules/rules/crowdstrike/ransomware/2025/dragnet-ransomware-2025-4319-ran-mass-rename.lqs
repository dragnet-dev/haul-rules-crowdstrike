// Dragnet [Ransomware]: dragnet-ransomware-2025-4319 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 6c6a9102-d7b6-58eb-b874-a058999aba66

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
