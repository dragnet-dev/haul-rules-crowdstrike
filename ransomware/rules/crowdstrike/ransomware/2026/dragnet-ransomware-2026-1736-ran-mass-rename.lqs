// Dragnet [Ransomware]: dragnet-ransomware-2026-1736 — Mass File Rename (lockbit5)
// Status: test | Level: high | ID: 9950f913-465f-58ae-a081-da6b8f428de5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
