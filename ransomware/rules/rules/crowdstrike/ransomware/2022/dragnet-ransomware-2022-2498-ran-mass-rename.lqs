// Dragnet [Ransomware]: dragnet-ransomware-2022-2498 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 0c7dc58c-1373-5a84-9f7f-75166d65584e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
