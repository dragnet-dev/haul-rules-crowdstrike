// Dragnet [Ransomware]: dragnet-ransomware-2024-2934 — Mass File Rename (ElDorado)
// Status: deprecated | Level: high | ID: 7ac2844d-8dae-5881-9f41-e593d5f90ec3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
