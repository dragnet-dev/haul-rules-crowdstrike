// Dragnet [Ransomware]: dragnet-ransomware-2025-4992 — Mass File Rename (handala)
// Status: experimental | Level: high | ID: a1a31be5-c60e-54de-9003-ef69cb9bae86

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
