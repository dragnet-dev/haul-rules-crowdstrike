// Dragnet [Ransomware]: dragnet-ransomware-2025-5719 — Mass File Rename (killsec)
// Status: deprecated | Level: high | ID: 05cd7f72-48ef-5d64-ae94-0596f0b277af

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
