// Dragnet [Ransomware]: dragnet-ransomware-2022-1438 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: c6069cf3-0252-5104-a0de-96c6ad882aa4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
