// Dragnet [Ransomware]: dragnet-ransomware-2021-1326 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: de3bf8a5-e7a3-5f1e-b77e-8234a2d0df38

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
