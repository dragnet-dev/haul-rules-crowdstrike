// Dragnet [Ransomware]: dragnet-ransomware-2024-5161 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 1e86f30c-a23f-5060-8aee-eab61faa6d31

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
