// Dragnet [Ransomware]: dragnet-ransomware-2026-2630 — Mass File Rename (incransom)
// Status: test | Level: high | ID: 5f0e6c03-5af1-5423-9620-733f936d5d55

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
