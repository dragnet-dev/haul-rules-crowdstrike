// Dragnet [Ransomware]: dragnet-ransomware-2024-5669 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: c2406e90-1fde-5769-af05-452126b29d0d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
