// Dragnet [Ransomware]: dragnet-ransomware-2023-1468 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 4127d0ef-ca48-5880-96f9-b8132420e680

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
