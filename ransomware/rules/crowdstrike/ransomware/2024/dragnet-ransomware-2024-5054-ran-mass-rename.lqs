// Dragnet [Ransomware]: dragnet-ransomware-2024-5054 — Mass File Rename (play)
// Status: experimental | Level: high | ID: e99d21e1-0cad-5d09-91a2-a45a10d73629

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
