// Dragnet [Ransomware]: dragnet-ransomware-2025-0272 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: e83d432c-d3bf-5ddb-a28f-1454944720e9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
