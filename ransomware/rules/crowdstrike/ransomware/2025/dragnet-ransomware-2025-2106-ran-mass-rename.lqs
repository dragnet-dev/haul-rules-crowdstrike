// Dragnet [Ransomware]: dragnet-ransomware-2025-2106 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 6e7e07e0-80d9-5d89-9b73-32e6f2027295

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
