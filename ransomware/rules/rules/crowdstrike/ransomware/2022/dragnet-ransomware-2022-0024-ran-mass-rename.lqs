// Dragnet [Ransomware]: dragnet-ransomware-2022-0024 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 325e8f42-3393-5f42-9dff-938b836cf462

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
