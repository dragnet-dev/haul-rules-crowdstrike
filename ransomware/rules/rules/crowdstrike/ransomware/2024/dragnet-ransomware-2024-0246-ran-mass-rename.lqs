// Dragnet [Ransomware]: dragnet-ransomware-2024-0246 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: a268db04-d3ee-53b8-a727-1a678b002593

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
