// Dragnet [Ransomware]: dragnet-ransomware-2021-0465 — Mass File Rename (sabbath)
// Status: deprecated | Level: high | ID: 9e75221e-cfe6-56fb-ba7b-330b87abd2d5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
