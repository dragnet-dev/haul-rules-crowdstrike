// Dragnet [Ransomware]: dragnet-ransomware-2025-3919 — Mass File Rename (sinobi)
// Status: experimental | Level: high | ID: 58ed88c0-5748-54f3-af35-ecf4b66eb27b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
