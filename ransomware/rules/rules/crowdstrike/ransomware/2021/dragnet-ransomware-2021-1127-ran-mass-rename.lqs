// Dragnet [Ransomware]: dragnet-ransomware-2021-1127 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 487dc3ac-1bc2-51ea-a3cc-87c012324173

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
