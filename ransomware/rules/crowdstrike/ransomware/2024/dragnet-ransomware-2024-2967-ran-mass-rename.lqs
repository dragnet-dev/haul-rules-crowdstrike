// Dragnet [Ransomware]: dragnet-ransomware-2024-2967 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 0a51743b-bfbe-5c87-93b1-ae6a544038ef

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
