// Dragnet [Ransomware]: dragnet-ransomware-2023-4784 — Mass File Rename (qilin)
// Status: deprecated | Level: high | ID: 53591755-f79a-5bf0-999f-5019e46a442d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
