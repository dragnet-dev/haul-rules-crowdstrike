// Dragnet [Ransomware]: dragnet-ransomware-2025-5948 — Mass File Rename (payoutsking)
// Status: experimental | Level: high | ID: e8cadd94-79a6-5e40-850b-e90736180787

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
