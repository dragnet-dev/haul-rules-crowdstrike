// Dragnet [Ransomware]: dragnet-ransomware-2025-5029 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 89d6a131-0027-5f37-b3ba-b4de16b3df14

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
