// Dragnet [Ransomware]: dragnet-ransomware-2022-2761 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 868dd535-3e96-5cf4-8f87-21aaffaec556

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
