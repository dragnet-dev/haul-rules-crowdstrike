// Dragnet [Container]: dragnet-container-2024-0722 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 42cf821f-0555-59a6-93d7-8a1ee7b31ffb

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *ubuntu:18.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
