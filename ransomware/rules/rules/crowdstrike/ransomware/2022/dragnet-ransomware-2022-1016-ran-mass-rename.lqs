// Dragnet [Ransomware]: dragnet-ransomware-2022-1016 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 48ca7690-24d7-5d73-93c3-2acd8533da0f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
