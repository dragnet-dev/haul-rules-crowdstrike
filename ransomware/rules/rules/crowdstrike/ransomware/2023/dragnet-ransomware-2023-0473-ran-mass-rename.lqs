// Dragnet [Ransomware]: dragnet-ransomware-2023-0473 — Mass File Rename (play)
// Status: experimental | Level: high | ID: d5ded45e-fab3-54fe-813d-da1434bc5468

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
