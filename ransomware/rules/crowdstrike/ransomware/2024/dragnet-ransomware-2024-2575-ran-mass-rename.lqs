// Dragnet [Ransomware]: dragnet-ransomware-2024-2575 — Mass File Rename (apt73)
// Status: experimental | Level: high | ID: a0d12767-ee62-5877-82a6-10cd71b63256

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
