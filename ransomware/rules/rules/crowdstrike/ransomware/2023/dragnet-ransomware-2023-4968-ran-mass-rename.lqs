// Dragnet [Ransomware]: dragnet-ransomware-2023-4968 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: acf19311-bee5-58f2-b4cf-52ee60eeb608

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
