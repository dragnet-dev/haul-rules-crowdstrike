// Dragnet [Ransomware]: dragnet-ransomware-2026-1471 — Mass File Rename (dragonforce)
// Status: stable | Level: high | ID: a3fc2766-e0c8-5724-856c-cbfd23c2e7f6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
