// Dragnet [Ransomware]: dragnet-ransomware-2026-1300 — Mass File Rename (AiLock)
// Status: deprecated | Level: high | ID: a1daf42a-17be-5c86-b8e7-19e21adfa062

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
