// Dragnet [Ransomware]: dragnet-ransomware-2023-4518 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: 1564a504-8ad6-5d8e-9efa-252b2710a1a6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
