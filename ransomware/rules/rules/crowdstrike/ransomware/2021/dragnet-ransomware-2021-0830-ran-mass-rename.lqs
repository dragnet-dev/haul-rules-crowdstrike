// Dragnet [Ransomware]: dragnet-ransomware-2021-0830 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 3e7876db-6ece-5eca-abad-5a044b839000

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
