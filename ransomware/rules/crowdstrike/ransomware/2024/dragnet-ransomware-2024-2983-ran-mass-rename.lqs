// Dragnet [Ransomware]: dragnet-ransomware-2024-2983 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 5564a895-6c0c-5396-8e0e-44bedfff3781

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
