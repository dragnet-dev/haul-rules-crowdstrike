// Dragnet [Ransomware]: dragnet-ransomware-2022-1218 — Mass File Rename (royal)
// Status: deprecated | Level: high | ID: 99f3e68f-e6ff-5ad3-9411-ce08998fae84

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
