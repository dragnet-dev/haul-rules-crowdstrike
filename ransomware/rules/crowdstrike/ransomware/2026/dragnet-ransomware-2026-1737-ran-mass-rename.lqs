// Dragnet [Ransomware]: dragnet-ransomware-2026-1737 — Mass File Rename (kairos)
// Status: deprecated | Level: high | ID: f30306f2-c764-513c-96da-3ee51e9bc2d4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
