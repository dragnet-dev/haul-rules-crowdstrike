// Dragnet [Ransomware]: dragnet-ransomware-2023-0779 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: d2a0cf22-266b-57f5-a519-ecb54c3c2909

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
