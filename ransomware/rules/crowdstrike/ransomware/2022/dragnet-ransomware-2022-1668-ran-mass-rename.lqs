// Dragnet [Ransomware]: dragnet-ransomware-2022-1668 — Mass File Rename (lv)
// Status: deprecated | Level: high | ID: 83914462-5ef3-5e87-990f-a1fcc227b1f0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
