// Dragnet [Ransomware]: dragnet-ransomware-2022-2721 — Mass File Rename (onyx)
// Status: deprecated | Level: high | ID: d32255fb-4eb7-5b20-b890-4c1603df2cfe

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
