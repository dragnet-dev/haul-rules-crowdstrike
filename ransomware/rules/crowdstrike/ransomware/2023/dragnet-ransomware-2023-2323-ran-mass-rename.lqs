// Dragnet [Ransomware]: dragnet-ransomware-2023-2323 — Mass File Rename (royal)
// Status: experimental | Level: high | ID: df60eb4d-945f-5f36-8971-92b3d7ea33ef

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
