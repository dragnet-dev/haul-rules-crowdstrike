// Dragnet [Ransomware]: dragnet-ransomware-2023-4631 — Mass File Rename (noescape)
// Status: experimental | Level: high | ID: ca79921c-d9ee-5384-839d-60cd4f3f62c8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
