// Dragnet [Ransomware]: dragnet-ransomware-2026-1844 — Mass File Rename (krybit)
// Status: stable | Level: high | ID: f74f7c24-756f-5b7f-9e57-af4b2f22b64c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
