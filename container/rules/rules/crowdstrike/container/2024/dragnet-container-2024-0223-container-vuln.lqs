// Dragnet [Container]: dragnet-container-2024-0223 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: b221f7f0-42ee-5df4-b766-a3dfe52c4aa2

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:8* OR ImageFileName = *debian:9* OR ImageFileName = *ubuntu:18.04* OR ImageFileName = *ubuntu:18.04-ESM* OR ImageFileName = *ubuntu:20.04* OR ImageFileName = *ubuntu:20.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
