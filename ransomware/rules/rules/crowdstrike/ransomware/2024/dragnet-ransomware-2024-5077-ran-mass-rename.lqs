// Dragnet [Ransomware]: dragnet-ransomware-2024-5077 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: d25f763c-2e87-5a1a-8fa3-3459a0cac7de

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
