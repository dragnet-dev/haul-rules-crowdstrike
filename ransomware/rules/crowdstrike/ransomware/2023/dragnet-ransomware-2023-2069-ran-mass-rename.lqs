// Dragnet [Ransomware]: dragnet-ransomware-2023-2069 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: b990ad72-336b-583e-9dad-1323d1fe9205

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
