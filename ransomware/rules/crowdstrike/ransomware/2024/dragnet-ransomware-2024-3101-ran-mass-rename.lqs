// Dragnet [Ransomware]: dragnet-ransomware-2024-3101 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 2ca99b67-d2a7-5554-9d9b-c88a3b0228c9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
