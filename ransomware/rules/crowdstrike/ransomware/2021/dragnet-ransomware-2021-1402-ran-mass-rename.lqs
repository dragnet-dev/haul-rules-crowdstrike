// Dragnet [Ransomware]: dragnet-ransomware-2021-1402 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 59491b2f-513d-5d9b-9a5c-6b6039e60cb8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
