// Dragnet [Ransomware]: dragnet-ransomware-2024-5640 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 65b08324-8520-5015-83f3-3215d2f2bd33

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
