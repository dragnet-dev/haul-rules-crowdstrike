// Dragnet [Ransomware]: dragnet-ransomware-2021-0127 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 4e564144-d3f7-5dfc-b5dc-818f5b19dae8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
