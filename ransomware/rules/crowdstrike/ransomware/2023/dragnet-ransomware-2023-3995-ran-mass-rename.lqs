// Dragnet [Ransomware]: dragnet-ransomware-2023-3995 — Mass File Rename (rhysida)
// Status: experimental | Level: high | ID: 23972d31-3092-5134-848f-503e018d7ee6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
