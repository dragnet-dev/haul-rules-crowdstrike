// Dragnet [Ransomware]: dragnet-ransomware-2026-1648 — Mass File Rename (lockbit5)
// Status: test | Level: high | ID: c9c2cb07-c533-5478-bb78-770730969046

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
