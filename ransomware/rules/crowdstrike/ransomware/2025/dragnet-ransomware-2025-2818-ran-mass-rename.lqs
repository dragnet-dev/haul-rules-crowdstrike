// Dragnet [Ransomware]: dragnet-ransomware-2025-2818 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: a01135ec-af3e-5857-89c9-f512f26193a8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
