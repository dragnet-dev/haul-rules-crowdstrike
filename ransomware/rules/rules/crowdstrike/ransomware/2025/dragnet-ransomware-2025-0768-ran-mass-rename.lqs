// Dragnet [Ransomware]: dragnet-ransomware-2025-0768 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: 766e9919-938e-52ae-889d-32e015d7e227

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
