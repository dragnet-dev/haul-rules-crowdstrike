// Dragnet [Ransomware]: dragnet-ransomware-2023-2566 — Mass File Rename (stormous)
// Status: experimental | Level: high | ID: c5ffe08c-3b05-54f9-abc7-55e33c6b72c7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
