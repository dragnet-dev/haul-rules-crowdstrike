// Dragnet [Ransomware]: dragnet-ransomware-2022-2873 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: aca39f36-3c86-56fc-b0eb-7267db4a7127

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
