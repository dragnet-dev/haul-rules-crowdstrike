// Dragnet [Ransomware]: dragnet-ransomware-2025-6483 — Mass File Rename (lockbit5)
// Status: experimental | Level: high | ID: 6ba1f2ee-6e08-5e3a-9df9-d7573185ffe2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
