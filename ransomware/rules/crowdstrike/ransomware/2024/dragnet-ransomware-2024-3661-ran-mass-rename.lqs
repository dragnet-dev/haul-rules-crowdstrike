// Dragnet [Ransomware]: dragnet-ransomware-2024-3661 — Mass File Rename (embargo)
// Status: experimental | Level: high | ID: 8fca0f4d-688b-5087-9834-afe6af28e0f0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
