// Dragnet [Ransomware]: dragnet-ransomware-2025-1976 — Mass File Rename (obscura)
// Status: experimental | Level: high | ID: 768719d2-99b0-527a-86d7-137588f1bbf5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
