// Dragnet [Ransomware]: dragnet-ransomware-2024-3807 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 327e112b-fdab-59a4-8fec-fa730ef90cbf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
