// Dragnet [Ransomware]: dragnet-ransomware-2022-0691 — Mass File Rename (royal)
// Status: deprecated | Level: high | ID: 144c3df8-a15f-5340-9d36-f18af958501e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
