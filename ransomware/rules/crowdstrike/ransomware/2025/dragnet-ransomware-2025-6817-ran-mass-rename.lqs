// Dragnet [Ransomware]: dragnet-ransomware-2025-6817 — Mass File Rename (kairos)
// Status: deprecated | Level: high | ID: ef525817-6b7d-5216-8500-27df75e0b84d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
