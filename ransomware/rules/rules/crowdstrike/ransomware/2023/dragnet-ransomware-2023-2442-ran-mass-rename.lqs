// Dragnet [Ransomware]: dragnet-ransomware-2023-2442 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: a7133061-ed94-5f4c-8812-4284bc5d3c26

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
