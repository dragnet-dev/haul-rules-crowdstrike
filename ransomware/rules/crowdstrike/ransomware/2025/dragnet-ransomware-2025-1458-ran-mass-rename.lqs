// Dragnet [Ransomware]: dragnet-ransomware-2025-1458 — Mass File Rename (kryptos)
// Status: deprecated | Level: high | ID: 5f6d687a-35a6-5092-985a-2f03b36d8b82

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
