// Dragnet [Ransomware]: dragnet-ransomware-2023-1913 — Mass File Rename (dragonforce)
// Status: deprecated | Level: high | ID: 9a966c7b-4b1e-583d-a8ea-cbd978f7a825

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
