// Dragnet [Ransomware]: dragnet-ransomware-2026-2387 — Mass File Rename (lockbit5)
// Status: test | Level: high | ID: 8e692cb8-08a2-5835-8261-902a11ed6d46

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
