// Dragnet [Ransomware]: dragnet-ransomware-2023-2363 — Mass File Rename (ransomed)
// Status: deprecated | Level: high | ID: 494cf3ac-d05a-535c-88c9-0c6c79e32969

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
