// Dragnet [Ransomware]: dragnet-ransomware-2024-4414 — Mass File Rename (raworld)
// Status: experimental | Level: high | ID: 910be5e1-0b97-5b33-8e10-559de8958bf4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
