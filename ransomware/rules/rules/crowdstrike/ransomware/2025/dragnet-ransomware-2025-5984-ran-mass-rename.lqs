// Dragnet [Ransomware]: dragnet-ransomware-2025-5984 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 84e4cfc0-17ec-5c23-b93f-ace26da2d5c4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
