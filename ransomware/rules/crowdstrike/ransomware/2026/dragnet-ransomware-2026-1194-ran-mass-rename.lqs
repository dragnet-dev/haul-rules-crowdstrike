// Dragnet [Ransomware]: dragnet-ransomware-2026-1194 — Mass File Rename (coinbasecartel)
// Status: test | Level: high | ID: 71510d0a-87a2-5aa8-80d1-23c96045170a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
