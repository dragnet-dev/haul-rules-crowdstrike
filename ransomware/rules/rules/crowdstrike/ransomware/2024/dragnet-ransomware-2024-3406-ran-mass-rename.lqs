// Dragnet [Ransomware]: dragnet-ransomware-2024-3406 — Mass File Rename (ransomhouse)
// Status: experimental | Level: high | ID: cc028120-3b07-562f-b217-2f789299de93

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
