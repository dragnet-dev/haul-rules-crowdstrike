// Dragnet [Container]: dragnet-container-2026-3070 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: af3f68cf-f04e-568d-b92f-c8372887f797

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:5*)
| table([timestamp, ComputerName])
| limit(1000)
