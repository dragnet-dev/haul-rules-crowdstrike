// Dragnet [Ransomware]: dragnet-ransomware-2024-3065 — Mass File Rename (play)
// Status: experimental | Level: high | ID: bbb8be05-d7d6-5fe6-9586-56f6371d5b98

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
