// Dragnet [Ransomware]: dragnet-ransomware-2025-0372 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 4f0d2b38-4bf8-5d3a-8876-bbc2fd41592d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
