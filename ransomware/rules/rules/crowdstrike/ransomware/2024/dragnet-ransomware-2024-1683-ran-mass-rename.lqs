// Dragnet [Ransomware]: dragnet-ransomware-2024-1683 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: e7c17897-0e33-556d-8e7b-92559284fce7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
