// Dragnet [Ransomware]: dragnet-ransomware-2026-1782 — Mass File Rename (direwolf)
// Status: test | Level: high | ID: 0558ffd4-561d-5003-a9d6-26eee5e76451

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
