// Dragnet [Ransomware]: dragnet-ransomware-2024-1243 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 3f3a280b-dc1d-59b2-9e8a-64805778d743

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
