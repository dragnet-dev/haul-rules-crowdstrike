// Dragnet [Ransomware]: dragnet-ransomware-2026-2127 — Mass File Rename (nightspire)
// Status: deprecated | Level: high | ID: 37e93c13-1591-5db1-9b23-edff45231930

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
