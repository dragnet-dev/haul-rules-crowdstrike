// Dragnet [Ransomware]: dragnet-ransomware-2024-4253 — Mass File Rename (play)
// Status: experimental | Level: high | ID: f7855c00-21a2-520c-b2ce-73b3cea0d19a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
