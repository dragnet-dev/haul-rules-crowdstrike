// Dragnet [Ransomware]: dragnet-ransomware-2022-0407 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: b2a9c788-b16e-5e5d-9b31-255bc19d49d3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
