// Dragnet [Ransomware]: dragnet-ransomware-2025-2249 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: efcbcd6e-9c06-5b7b-b042-875192780f68

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
