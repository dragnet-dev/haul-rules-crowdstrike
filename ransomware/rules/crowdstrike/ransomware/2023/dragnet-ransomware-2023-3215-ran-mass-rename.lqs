// Dragnet [Ransomware]: dragnet-ransomware-2023-3215 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: f7b0e750-962b-5e5b-8791-e3b5dd89b0ef

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
