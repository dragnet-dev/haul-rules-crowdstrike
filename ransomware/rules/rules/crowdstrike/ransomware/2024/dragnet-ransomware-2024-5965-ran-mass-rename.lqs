// Dragnet [Ransomware]: dragnet-ransomware-2024-5965 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 7f36865e-44a0-573f-bb12-eb70702ad51f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
