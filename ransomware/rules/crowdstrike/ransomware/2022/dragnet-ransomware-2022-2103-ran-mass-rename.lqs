// Dragnet [Ransomware]: dragnet-ransomware-2022-2103 — Mass File Rename (vicesociety)
// Status: deprecated | Level: high | ID: 6de8ee79-18a1-5612-9c2c-7bed2cb34265

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
