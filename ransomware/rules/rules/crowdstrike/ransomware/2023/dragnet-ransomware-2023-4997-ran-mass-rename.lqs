// Dragnet [Ransomware]: dragnet-ransomware-2023-4997 — Mass File Rename (nokoyawa)
// Status: experimental | Level: high | ID: 3e21c768-3ac1-5563-a4c2-b9e2914b0f58

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
