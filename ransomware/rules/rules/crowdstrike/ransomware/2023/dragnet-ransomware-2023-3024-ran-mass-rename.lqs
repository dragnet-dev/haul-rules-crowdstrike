// Dragnet [Ransomware]: dragnet-ransomware-2023-3024 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: cb3cdb48-8c2b-54e5-8903-048a5ca87e1f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
