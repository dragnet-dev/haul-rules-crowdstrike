// Dragnet [Container]: dragnet-container-2026-2478 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 202f9ab9-9f52-584d-afc9-d5154d4df52f

#event_simpleName=*
| (ImageFileName = *debian:7* OR ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10* OR ImageFileName = *ubuntu:13.10*)
| table([timestamp, ComputerName])
| limit(1000)
