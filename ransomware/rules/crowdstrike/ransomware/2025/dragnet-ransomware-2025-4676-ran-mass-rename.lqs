// Dragnet [Ransomware]: dragnet-ransomware-2025-4676 — Mass File Rename (sarcoma)
// Status: deprecated | Level: high | ID: 53724e78-eca9-5548-8304-42001fa1e156

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
