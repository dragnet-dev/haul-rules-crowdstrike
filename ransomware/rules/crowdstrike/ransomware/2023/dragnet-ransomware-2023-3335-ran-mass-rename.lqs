// Dragnet [Ransomware]: dragnet-ransomware-2023-3335 — Mass File Rename (play)
// Status: experimental | Level: high | ID: d52b8eae-e522-53cc-b57a-7c9b2d5344d0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
