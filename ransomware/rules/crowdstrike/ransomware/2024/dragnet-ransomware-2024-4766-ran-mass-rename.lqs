// Dragnet [Ransomware]: dragnet-ransomware-2024-4766 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 0cd8feba-501b-53ca-bdc1-68d794b111e0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
