// Dragnet [Ransomware]: dragnet-ransomware-2025-2412 — Mass File Rename (thegentlemen)
// Status: experimental | Level: high | ID: 7f3a8a2b-95fd-54bb-9431-31ed3257199a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
