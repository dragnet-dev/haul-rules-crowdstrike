// Dragnet [Ransomware]: dragnet-ransomware-2025-3151 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 18a3861c-327f-59b3-9ef1-77b12dc3d008

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
