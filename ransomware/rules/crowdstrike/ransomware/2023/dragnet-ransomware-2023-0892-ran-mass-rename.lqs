// Dragnet [Ransomware]: dragnet-ransomware-2023-0892 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: dff4ac29-ff87-5fcf-9167-d41fdfb2745a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
