// Dragnet [Ransomware]: dragnet-ransomware-2023-2123 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 400273b0-8b10-5b39-ac3d-8654c1b8e2e3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
