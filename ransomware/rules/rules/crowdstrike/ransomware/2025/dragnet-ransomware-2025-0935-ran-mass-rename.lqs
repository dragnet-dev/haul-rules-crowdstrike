// Dragnet [Ransomware]: dragnet-ransomware-2025-0935 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 77cbf79c-1e38-5c93-a199-0deb48c033d0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
