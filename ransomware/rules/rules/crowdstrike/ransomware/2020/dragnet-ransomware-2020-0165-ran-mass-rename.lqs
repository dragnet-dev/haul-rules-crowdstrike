// Dragnet [Ransomware]: dragnet-ransomware-2020-0165 — Mass File Rename (maze)
// Status: deprecated | Level: high | ID: 0a52faa0-469f-516f-92a5-437ccdab4c81

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
