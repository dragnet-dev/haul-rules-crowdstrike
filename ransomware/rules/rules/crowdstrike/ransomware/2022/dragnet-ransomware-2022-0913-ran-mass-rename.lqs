// Dragnet [Ransomware]: dragnet-ransomware-2022-0913 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: e34ab3f2-2b6e-53ee-8e03-bfb87bdec47d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
