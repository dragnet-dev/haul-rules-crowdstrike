// Dragnet [Ransomware]: dragnet-ransomware-2026-3337 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: ce5504c0-8ac3-566b-8c03-b815eb1b923f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
