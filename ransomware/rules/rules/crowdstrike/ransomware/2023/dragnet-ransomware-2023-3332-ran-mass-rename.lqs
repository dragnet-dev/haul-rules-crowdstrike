// Dragnet [Ransomware]: dragnet-ransomware-2023-3332 — Mass File Rename (play)
// Status: deprecated | Level: high | ID: 55857d8f-55f8-54be-bd6e-fc8227f96e73

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
