// Dragnet [Container]: dragnet-container-2026-1566 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: f711b5fe-d520-5481-9c4f-3961fca5a2f5

#event_simpleName=*
| (ImageFileName = *chainguard:* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *ubuntu:25.10* OR ImageFileName = *ubuntu:26.04* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
