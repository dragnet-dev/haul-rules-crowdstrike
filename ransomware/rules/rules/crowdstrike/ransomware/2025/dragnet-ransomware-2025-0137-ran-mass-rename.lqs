// Dragnet [Ransomware]: dragnet-ransomware-2025-0137 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 20737462-0117-5bd6-9c04-263fe7a9b54a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
