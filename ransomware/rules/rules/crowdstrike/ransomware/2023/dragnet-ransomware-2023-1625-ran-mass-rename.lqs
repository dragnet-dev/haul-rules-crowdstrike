// Dragnet [Ransomware]: dragnet-ransomware-2023-1625 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 55fb073c-0040-5201-9ed1-76b7af1c785d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
