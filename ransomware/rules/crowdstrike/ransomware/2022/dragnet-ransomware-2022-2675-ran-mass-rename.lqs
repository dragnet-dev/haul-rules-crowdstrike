// Dragnet [Ransomware]: dragnet-ransomware-2022-2675 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 97576a0f-3cbb-5e20-865b-18bf8cf1a1e9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
