// Dragnet [Ransomware]: dragnet-ransomware-2023-0604 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: ad08f051-8aab-5883-91ae-dc1b076123e1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
