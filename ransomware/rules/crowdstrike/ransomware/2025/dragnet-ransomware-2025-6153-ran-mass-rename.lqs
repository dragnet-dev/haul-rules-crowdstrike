// Dragnet [Ransomware]: dragnet-ransomware-2025-6153 — Mass File Rename (worldleaks)
// Status: experimental | Level: high | ID: 8cd22538-819f-54b6-8277-7bdc6794eab3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
