// Dragnet [Ransomware]: dragnet-ransomware-2024-2044 — Mass File Rename (SilentRansomGroup)
// Status: deprecated | Level: high | ID: 6c700857-3a96-5e65-91ed-7b4ab0c9dccb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
