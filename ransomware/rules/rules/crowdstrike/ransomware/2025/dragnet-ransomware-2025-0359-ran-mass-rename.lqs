// Dragnet [Ransomware]: dragnet-ransomware-2025-0359 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 4c84879f-176d-530d-8c24-faf136026422

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
