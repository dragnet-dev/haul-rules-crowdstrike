// Dragnet [Ransomware]: dragnet-ransomware-2021-0063 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 0095afbc-aabd-5a87-9616-e7f4443e8fcb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
