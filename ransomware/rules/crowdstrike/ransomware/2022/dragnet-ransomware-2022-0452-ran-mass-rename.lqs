// Dragnet [Ransomware]: dragnet-ransomware-2022-0452 — Mass File Rename (snatch)
// Status: deprecated | Level: high | ID: 119f6a4c-5f38-545b-bc18-ef337e6e07d3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
