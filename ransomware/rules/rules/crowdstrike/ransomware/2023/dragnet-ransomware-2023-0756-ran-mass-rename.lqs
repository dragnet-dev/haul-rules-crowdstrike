// Dragnet [Ransomware]: dragnet-ransomware-2023-0756 — Mass File Rename (snatch)
// Status: experimental | Level: high | ID: 29e8e742-1b04-5328-be57-6650f834af44

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
