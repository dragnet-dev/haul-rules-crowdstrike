// Dragnet [Ransomware]: dragnet-ransomware-2023-2512 — Mass File Rename (play)
// Status: experimental | Level: high | ID: bc92b8a1-aaec-5a74-8d0a-89d36d297b14

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
