// Dragnet [Ransomware]: dragnet-ransomware-2024-1856 — Mass File Rename (darkvault)
// Status: experimental | Level: high | ID: 6fb18573-0af3-553d-b5fd-62edc959ad12

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
