// Dragnet [Ransomware]: dragnet-ransomware-2024-2403 — Mass File Rename (arcusmedia)
// Status: experimental | Level: high | ID: b6950e47-24bf-5771-8c85-f49aa1189fcb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
