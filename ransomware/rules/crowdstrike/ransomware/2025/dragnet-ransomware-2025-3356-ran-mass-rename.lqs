// Dragnet [Ransomware]: dragnet-ransomware-2025-3356 — Mass File Rename (blackshrantac)
// Status: test | Level: high | ID: 2bb4744b-b680-50b4-8fd9-8e14bb3b7f85

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
