// Dragnet [Ransomware]: dragnet-ransomware-2023-3574 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 46b2cd5a-a603-524a-9425-a48600477bc0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
