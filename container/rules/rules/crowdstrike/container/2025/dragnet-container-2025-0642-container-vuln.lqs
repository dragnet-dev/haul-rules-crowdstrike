// Dragnet [Container]: dragnet-container-2025-0642 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: d1ccd2d2-7faf-5988-adfd-4397e3ce37ad

#event_simpleName=*
| (ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *ubuntu:18.04-ESM* OR ImageFileName = *ubuntu:20.04-ESM* OR ImageFileName = *ubuntu:22.04*)
| table([timestamp, ComputerName])
| limit(1000)
