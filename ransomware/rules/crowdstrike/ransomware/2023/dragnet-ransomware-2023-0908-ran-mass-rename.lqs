// Dragnet [Ransomware]: dragnet-ransomware-2023-0908 — Mass File Rename (raworld)
// Status: experimental | Level: high | ID: 3734fc6e-1b33-5ad8-a8d8-3d2807d098c3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
