// Dragnet [Ransomware]: dragnet-ransomware-2024-1734 — Mass File Rename (handala)
// Status: experimental | Level: high | ID: 6aa701a8-f793-5d99-8faa-eef8e669fbef

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
