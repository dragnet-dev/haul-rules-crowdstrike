// Dragnet [Ransomware]: dragnet-ransomware-2026-2821 — Mass File Rename (dragonforce)
// Status: stable | Level: high | ID: a101bfd4-ba2b-5729-87df-bc471ef1d34d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
