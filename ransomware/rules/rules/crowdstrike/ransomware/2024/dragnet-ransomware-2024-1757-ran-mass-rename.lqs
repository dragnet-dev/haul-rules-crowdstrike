// Dragnet [Ransomware]: dragnet-ransomware-2024-1757 — Mass File Rename (dragonransomware)
// Status: experimental | Level: high | ID: 5b1e7d38-3a53-5092-8ac1-f7c9cb1a1e7e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
