// Dragnet [Ransomware]: dragnet-ransomware-2025-7742 — Mass File Rename (crazyhunter)
// Status: experimental | Level: high | ID: c9d3215d-664e-5a78-9700-84a47ab66c09

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
