// Dragnet [Ransomware]: dragnet-ransomware-2024-2924 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 9f74f971-51b8-5f4e-ad2c-6c0332bfb8bf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
