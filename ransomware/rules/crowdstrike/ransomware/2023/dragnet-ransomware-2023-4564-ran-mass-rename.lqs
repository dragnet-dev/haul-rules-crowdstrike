// Dragnet [Ransomware]: dragnet-ransomware-2023-4564 — Mass File Rename (knight)
// Status: experimental | Level: high | ID: 90927475-8ef2-5764-92b5-a18ba76571ec

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
