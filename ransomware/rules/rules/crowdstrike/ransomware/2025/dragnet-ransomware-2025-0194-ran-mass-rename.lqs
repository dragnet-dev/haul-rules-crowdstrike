// Dragnet [Ransomware]: dragnet-ransomware-2025-0194 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 2e458611-1c42-5733-b3ba-69a444d63e37

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
