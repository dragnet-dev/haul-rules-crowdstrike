// Dragnet [Ransomware]: dragnet-ransomware-2024-5533 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 71434692-48ca-56e2-afa0-ef78a9a5d714

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
