// Dragnet [Ransomware]: dragnet-ransomware-2025-1745 — Mass File Rename (radar)
// Status: deprecated | Level: high | ID: 2d2597b1-0485-5061-b565-8de04693e514

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
