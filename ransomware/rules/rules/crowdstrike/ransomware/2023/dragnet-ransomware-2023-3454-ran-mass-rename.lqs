// Dragnet [Ransomware]: dragnet-ransomware-2023-3454 — Mass File Rename (cuba)
// Status: experimental | Level: high | ID: 195aa06e-ebff-577b-84a4-a8854c004a41

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
