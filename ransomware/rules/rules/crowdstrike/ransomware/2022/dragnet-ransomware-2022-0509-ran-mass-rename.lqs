// Dragnet [Ransomware]: dragnet-ransomware-2022-0509 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 4dadc7ed-4000-5309-8ca1-c73e6948234f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
