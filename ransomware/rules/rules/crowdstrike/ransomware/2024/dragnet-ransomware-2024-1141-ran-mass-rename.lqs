// Dragnet [Ransomware]: dragnet-ransomware-2024-1141 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 1f74aa6c-dcaa-5c2f-8f9a-5c9015a15ac7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
