// Dragnet [Ransomware]: dragnet-ransomware-2021-1674 — Mass File Rename (avoslocker)
// Status: deprecated | Level: high | ID: 3a90e2c6-6472-5093-bba9-7a9877ee3229

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
