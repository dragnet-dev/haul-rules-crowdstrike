// Dragnet [Ransomware]: dragnet-ransomware-2025-6547 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 85a3ac9c-f25c-5359-9615-70f345f77280

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
