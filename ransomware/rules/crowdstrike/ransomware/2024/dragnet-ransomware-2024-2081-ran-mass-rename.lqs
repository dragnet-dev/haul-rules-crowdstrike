// Dragnet [Ransomware]: dragnet-ransomware-2024-2081 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 2e0d484e-7db7-520b-af03-d0ea9a5e1f2d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
