// Dragnet [Ransomware]: dragnet-ransomware-2024-1354 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: d838ea49-1348-5517-88d8-d1958ebbcbe9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
