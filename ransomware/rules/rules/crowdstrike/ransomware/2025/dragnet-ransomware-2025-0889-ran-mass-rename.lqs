// Dragnet [Ransomware]: dragnet-ransomware-2025-0889 — Mass File Rename (kairos)
// Status: experimental | Level: high | ID: 4c13e73e-8a3d-52ff-8c46-de9f65a3b1da

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
