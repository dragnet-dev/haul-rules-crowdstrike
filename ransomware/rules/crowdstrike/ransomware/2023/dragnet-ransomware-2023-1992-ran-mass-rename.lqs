// Dragnet [Ransomware]: dragnet-ransomware-2023-1992 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: fb3c0bf7-2c12-5fb8-98df-4199bb83da77

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
