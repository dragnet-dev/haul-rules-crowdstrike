// Dragnet [Ransomware]: dragnet-ransomware-2024-3981 — Mass File Rename (cloak)
// Status: deprecated | Level: high | ID: acc6d263-c2e5-5696-ac08-d533387ac202

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
