// Dragnet [Ransomware]: dragnet-ransomware-2025-0244 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: 62311e8c-6082-530b-9e42-5f834c833286

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
