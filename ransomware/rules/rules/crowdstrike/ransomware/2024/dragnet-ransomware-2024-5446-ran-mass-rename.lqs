// Dragnet [Ransomware]: dragnet-ransomware-2024-5446 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 87203a3d-dde6-5b00-b881-ddf4a6bbe016

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
