// Dragnet [Ransomware]: dragnet-ransomware-2025-6788 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: c0186967-9c3f-5e6e-a6cf-1407fcb9c92d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
