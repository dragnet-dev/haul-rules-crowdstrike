// Dragnet [Ransomware]: dragnet-ransomware-2023-1339 — Mass File Rename (monti)
// Status: experimental | Level: high | ID: 5f2118ae-b352-5a23-b54c-95df6502a9f9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
