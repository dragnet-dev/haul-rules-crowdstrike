// Dragnet [Ransomware]: dragnet-ransomware-2025-6082 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 11b6a63b-3f87-5c30-9c30-35261ad0c93c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
