// Dragnet [Ransomware]: dragnet-ransomware-2022-0172 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: d92cc7cf-7186-5dda-b239-eaef108e3927

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
