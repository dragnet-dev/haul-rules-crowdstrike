// Dragnet [Ransomware]: dragnet-ransomware-2022-2444 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 4b908ee5-a0b5-5893-bdcb-53ae6949255c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
