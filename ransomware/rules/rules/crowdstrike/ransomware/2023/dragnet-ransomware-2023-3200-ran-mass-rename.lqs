// Dragnet [Ransomware]: dragnet-ransomware-2023-3200 — Mass File Rename (royal)
// Status: experimental | Level: high | ID: 665c1a48-dd84-55bd-a458-483b1da9d155

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
