// Dragnet [Ransomware]: dragnet-ransomware-2024-3419 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: dd8d4cd6-95f5-5411-b3c2-e3afe9d97dfd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
