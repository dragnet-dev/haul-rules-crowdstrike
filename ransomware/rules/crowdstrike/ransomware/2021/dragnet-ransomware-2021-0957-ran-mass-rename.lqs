// Dragnet [Ransomware]: dragnet-ransomware-2021-0957 — Mass File Rename (spook)
// Status: deprecated | Level: high | ID: 189aed58-b3b4-5ef1-864f-91912b7c26e0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
