// Dragnet [Ransomware]: dragnet-ransomware-2021-0509 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 2d1486f1-e4d0-519d-bed4-91a6ee7940a6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
