// Dragnet [Ransomware]: dragnet-ransomware-2025-0885 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 462e1e18-c1b6-5428-9a77-87644d34c69c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
