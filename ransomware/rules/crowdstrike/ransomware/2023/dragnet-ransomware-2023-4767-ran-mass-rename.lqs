// Dragnet [Ransomware]: dragnet-ransomware-2023-4767 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 4b829718-e874-542f-9123-39729729c6b6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
