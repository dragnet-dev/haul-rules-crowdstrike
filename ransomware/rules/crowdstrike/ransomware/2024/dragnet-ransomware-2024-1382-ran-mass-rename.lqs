// Dragnet [Ransomware]: dragnet-ransomware-2024-1382 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 6e09c373-a232-520e-b27d-3302c25e067a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
