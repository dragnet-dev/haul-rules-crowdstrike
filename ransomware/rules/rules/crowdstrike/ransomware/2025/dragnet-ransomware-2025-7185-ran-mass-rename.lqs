// Dragnet [Ransomware]: dragnet-ransomware-2025-7185 — Mass File Rename (payoutsking)
// Status: experimental | Level: high | ID: 5d5cd889-6826-599d-a9ae-f1c4251a75ea

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
