// Dragnet [Ransomware]: dragnet-ransomware-2020-0239 — Mass File Rename (maze)
// Status: deprecated | Level: high | ID: b12fae99-0fec-5351-8bc6-2a2160369173

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
