// Dragnet [Ransomware]: dragnet-ransomware-2026-0232 — Mass File Rename (incransom)
// Status: test | Level: high | ID: 4e66e455-3507-556f-a239-fd69a0f15b6f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
