// Dragnet [Container]: dragnet-container-2024-0409 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 8c049ccf-f4db-504b-945c-62ebd4131778

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:9*)
| table([timestamp, ComputerName])
| limit(1000)
