// Dragnet [Ransomware]: dragnet-ransomware-2025-5967 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 29692fdb-2c6f-54f5-80d6-2f008f7dd633

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
