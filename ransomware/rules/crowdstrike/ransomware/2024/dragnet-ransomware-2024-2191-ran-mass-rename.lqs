// Dragnet [Ransomware]: dragnet-ransomware-2024-2191 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 983cc6a4-198d-57b1-afc0-e84bc41097b4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
