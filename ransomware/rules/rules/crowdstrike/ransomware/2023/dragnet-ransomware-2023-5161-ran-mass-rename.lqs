// Dragnet [Ransomware]: dragnet-ransomware-2023-5161 — Mass File Rename (ransomhouse)
// Status: experimental | Level: high | ID: 3e3ec271-32f2-54d7-91c8-fe313bc1d2ff

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
