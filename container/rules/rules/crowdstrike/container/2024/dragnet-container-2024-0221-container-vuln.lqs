// Dragnet [Container]: dragnet-container-2024-0221 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: aced6eae-d537-563e-b438-874ecc02b5c4

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
