// Dragnet [Ransomware]: dragnet-ransomware-2023-1553 — Mass File Rename (medusa)
// Status: deprecated | Level: high | ID: aebb38e7-bd17-5046-bee4-f2812b08b0ff

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
