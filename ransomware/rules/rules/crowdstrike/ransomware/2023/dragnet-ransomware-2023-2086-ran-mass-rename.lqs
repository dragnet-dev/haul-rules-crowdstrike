// Dragnet [Ransomware]: dragnet-ransomware-2023-2086 — Mass File Rename (avoslocker)
// Status: deprecated | Level: high | ID: 570a88c9-0f12-5d58-abef-fd3a4c176536

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
