// Dragnet [Ransomware]: dragnet-ransomware-2022-1718 — Mass File Rename (everest)
// Status: deprecated | Level: high | ID: 9e68133c-695b-5ef0-8e67-85ac92a60835

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
