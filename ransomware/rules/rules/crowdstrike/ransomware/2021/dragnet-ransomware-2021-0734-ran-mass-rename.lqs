// Dragnet [Ransomware]: dragnet-ransomware-2021-0734 — Mass File Rename (revil)
// Status: deprecated | Level: high | ID: 34719326-cd8e-52cd-9444-8a8ae1be49f4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
