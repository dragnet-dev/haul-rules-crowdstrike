// Dragnet [Ransomware]: dragnet-ransomware-2025-2411 — Mass File Rename (thegentlemen)
// Status: experimental | Level: high | ID: 2fade246-1c56-5586-a829-8c206d749538

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
