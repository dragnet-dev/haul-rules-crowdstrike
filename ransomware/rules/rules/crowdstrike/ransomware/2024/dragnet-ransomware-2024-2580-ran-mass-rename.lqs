// Dragnet [Ransomware]: dragnet-ransomware-2024-2580 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 3035da42-cd19-5732-b737-4d6a5b13182d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
