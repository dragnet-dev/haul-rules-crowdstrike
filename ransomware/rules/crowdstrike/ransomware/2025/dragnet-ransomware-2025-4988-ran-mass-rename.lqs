// Dragnet [Ransomware]: dragnet-ransomware-2025-4988 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: b0746553-b2c7-5e1a-a22a-2bc21f36b76c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
