// Dragnet [Ransomware]: dragnet-ransomware-2022-1971 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 453350e0-b3c2-5ca6-a324-a22c67fd3e45

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
