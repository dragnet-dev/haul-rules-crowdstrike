// Dragnet [Ransomware]: dragnet-ransomware-2024-0827 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 69909ad0-fe53-5b93-a923-a774e8df601b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
