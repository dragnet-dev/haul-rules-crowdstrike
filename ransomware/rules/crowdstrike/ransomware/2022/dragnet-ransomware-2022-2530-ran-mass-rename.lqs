// Dragnet [Ransomware]: dragnet-ransomware-2022-2530 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: e6218c96-d7bf-5dd4-af5b-be0c56b270ac

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
