// Dragnet [Container]: dragnet-container-2024-1462 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 0942bc81-2c47-59ac-8c8e-bc8d7cfb0930

#event_simpleName=*
| (ImageFileName = *amazonlinux:2* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:7* OR ImageFileName = *photon os:3.0* OR ImageFileName = *redhat/ubi9:*)
| table([timestamp, ComputerName])
| limit(1000)
