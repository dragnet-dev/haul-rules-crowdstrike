// Dragnet [Ransomware]: dragnet-ransomware-2023-1734 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 8bd6c9b7-e220-566d-a0fc-9b775dc0f940

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
