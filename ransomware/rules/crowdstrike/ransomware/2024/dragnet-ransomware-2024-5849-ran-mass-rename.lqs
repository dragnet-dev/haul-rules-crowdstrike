// Dragnet [Ransomware]: dragnet-ransomware-2024-5849 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 4c48767e-a8f9-511b-b3b7-7a27414eca55

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
