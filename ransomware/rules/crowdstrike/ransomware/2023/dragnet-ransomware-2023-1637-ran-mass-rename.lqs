// Dragnet [Ransomware]: dragnet-ransomware-2023-1637 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 3e43fd61-9a49-5513-a347-f722f986a796

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
