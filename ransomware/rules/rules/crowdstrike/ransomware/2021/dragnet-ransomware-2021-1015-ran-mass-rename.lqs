// Dragnet [Ransomware]: dragnet-ransomware-2021-1015 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 863d80c2-6193-5400-b24c-7dfee5eb9359

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
