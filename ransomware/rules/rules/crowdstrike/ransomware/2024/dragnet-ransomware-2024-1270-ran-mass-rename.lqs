// Dragnet [Ransomware]: dragnet-ransomware-2024-1270 — Mass File Rename (cicada3301)
// Status: experimental | Level: high | ID: b537bb08-8bc8-527b-b533-2e86805def69

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
