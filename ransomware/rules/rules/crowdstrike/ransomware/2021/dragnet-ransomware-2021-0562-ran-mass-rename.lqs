// Dragnet [Ransomware]: dragnet-ransomware-2021-0562 — Mass File Rename (alphv)
// Status: deprecated | Level: high | ID: 5fb517e5-eb71-53f3-9b05-0551c1dd33f1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
