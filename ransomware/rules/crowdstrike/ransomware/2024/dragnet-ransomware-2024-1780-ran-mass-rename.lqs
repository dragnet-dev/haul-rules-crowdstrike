// Dragnet [Ransomware]: dragnet-ransomware-2024-1780 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 3bd9ab69-00fe-5a2e-82dd-dc2dde5bcea9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
