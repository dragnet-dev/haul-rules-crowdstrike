// Dragnet [Ransomware]: dragnet-ransomware-2023-5128 — Mass File Rename (nokoyawa)
// Status: experimental | Level: high | ID: 56530eca-cea1-5c70-8227-c128a2ec72c1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
