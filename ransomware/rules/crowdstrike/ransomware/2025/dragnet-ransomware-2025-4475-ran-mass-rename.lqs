// Dragnet [Ransomware]: dragnet-ransomware-2025-4475 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: a1e045c6-9707-570f-9d6b-2e665d9d4d03

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
