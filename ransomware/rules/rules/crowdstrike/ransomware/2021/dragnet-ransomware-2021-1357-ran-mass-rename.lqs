// Dragnet [Ransomware]: dragnet-ransomware-2021-1357 — Mass File Rename (groove)
// Status: deprecated | Level: high | ID: 4a36ea3a-3740-57b9-a84c-ff39ec844d78

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
