// Dragnet [Ransomware]: dragnet-ransomware-2024-1217 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: 4e47d33e-3a51-55f2-a326-1b218184d3f4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
