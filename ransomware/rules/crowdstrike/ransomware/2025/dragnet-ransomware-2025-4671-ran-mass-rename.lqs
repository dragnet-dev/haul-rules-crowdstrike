// Dragnet [Ransomware]: dragnet-ransomware-2025-4671 — Mass File Rename (flocker)
// Status: experimental | Level: high | ID: 5a542718-c1e5-541a-a5a0-378425a8490b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
