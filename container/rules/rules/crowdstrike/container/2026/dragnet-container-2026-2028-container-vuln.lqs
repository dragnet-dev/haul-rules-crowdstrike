// Dragnet [Container]: dragnet-container-2026-2028 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: d743d345-3d30-57ef-93f2-f91624e51c7d

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:7* OR ImageFileName = *debian:8* OR ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *oraclelinux:7* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:14.04* OR ImageFileName = *ubuntu:16.04*)
| table([timestamp, ComputerName])
| limit(1000)
