// Dragnet [Ransomware]: dragnet-ransomware-2025-7339 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 6da36321-e1cd-5a06-99d9-6642316280a1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
