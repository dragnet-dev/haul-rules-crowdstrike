// Dragnet [Ransomware]: dragnet-ransomware-2024-0640 — Mass File Rename (embargo)
// Status: experimental | Level: high | ID: 99295d30-ab5d-50e2-8a1f-d9add20df5ff

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
