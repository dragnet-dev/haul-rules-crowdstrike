// Dragnet [Ransomware]: dragnet-ransomware-2023-3666 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 3b7eea17-0a8f-5e77-ab98-918e5faa1e4a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
