// Dragnet [Ransomware]: dragnet-ransomware-2023-4046 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 60e34854-17b4-5473-9cff-be34289ff32a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
