// Dragnet [Container]: dragnet-container-2026-0221 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 123b83d7-6390-5c17-a197-aa48503241a4

#event_simpleName=*
| (ImageFileName = *amazonlinux:1* OR ImageFileName = *debian:7* OR ImageFileName = *debian:8* OR ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *oraclelinux:7* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:14.04* OR ImageFileName = *ubuntu:14.10*)
| table([timestamp, ComputerName])
| limit(1000)
