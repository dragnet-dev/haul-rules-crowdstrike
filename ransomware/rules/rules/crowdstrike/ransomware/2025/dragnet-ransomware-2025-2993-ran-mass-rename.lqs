// Dragnet [Ransomware]: dragnet-ransomware-2025-2993 — Mass File Rename (chaos)
// Status: experimental | Level: high | ID: 9ad8e530-2da1-54ee-9c14-a266648cf455

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
