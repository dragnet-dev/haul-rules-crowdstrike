// Dragnet [Ransomware]: dragnet-ransomware-2024-1705 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: c44eb36c-54cb-514e-8610-fc7f8d41d066

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
