// Dragnet [Ransomware]: dragnet-ransomware-2024-4716 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 839fecd5-fb17-57f3-b95f-f80ec41874f5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
