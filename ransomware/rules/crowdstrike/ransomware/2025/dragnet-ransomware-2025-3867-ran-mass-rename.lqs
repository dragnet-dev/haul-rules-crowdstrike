// Dragnet [Ransomware]: dragnet-ransomware-2025-3867 — Mass File Rename (kairos)
// Status: deprecated | Level: high | ID: 00c436af-910d-53b4-b153-314d37b3d16c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
