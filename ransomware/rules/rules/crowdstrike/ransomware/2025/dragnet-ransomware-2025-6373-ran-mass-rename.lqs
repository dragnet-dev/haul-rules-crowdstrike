// Dragnet [Ransomware]: dragnet-ransomware-2025-6373 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 2e695455-fa51-54f7-a036-21deac3d1828

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
