// Dragnet [Ransomware]: dragnet-ransomware-2023-2304 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 35a2d9cc-3e72-5973-9f67-7227fc68b612

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
