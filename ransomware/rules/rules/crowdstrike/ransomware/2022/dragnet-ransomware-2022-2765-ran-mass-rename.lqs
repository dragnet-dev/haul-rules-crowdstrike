// Dragnet [Ransomware]: dragnet-ransomware-2022-2765 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: f600d0c6-d8ad-54f2-b4a9-5bebae748909

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
