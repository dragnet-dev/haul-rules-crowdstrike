// Dragnet [Ransomware]: dragnet-ransomware-2022-2383 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: 9fed5cf6-6a08-517d-99c0-f2ac829b4363

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
