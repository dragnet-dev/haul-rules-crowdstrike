// Dragnet [Ransomware]: dragnet-ransomware-2025-2225 — Mass File Rename (weyhro)
// Status: experimental | Level: high | ID: 4da506e8-fdf8-5e85-8890-0a787f2431f5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
