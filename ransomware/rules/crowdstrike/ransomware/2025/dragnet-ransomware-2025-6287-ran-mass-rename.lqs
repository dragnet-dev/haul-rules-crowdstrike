// Dragnet [Ransomware]: dragnet-ransomware-2025-6287 — Mass File Rename (beast)
// Status: experimental | Level: high | ID: b1308656-497b-5235-b860-ebc5b2c1ede5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
