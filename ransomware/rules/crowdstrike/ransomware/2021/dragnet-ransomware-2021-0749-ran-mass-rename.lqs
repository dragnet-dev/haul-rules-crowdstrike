// Dragnet [Ransomware]: dragnet-ransomware-2021-0749 — Mass File Rename (xinglocker)
// Status: deprecated | Level: high | ID: 640ac810-8666-596f-953e-19a9d66bb9c3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
