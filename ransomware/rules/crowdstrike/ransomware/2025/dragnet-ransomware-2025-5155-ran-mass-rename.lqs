// Dragnet [Ransomware]: dragnet-ransomware-2025-5155 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: dfcd3649-4bc5-5d88-a2e8-bcb0d16289ab

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
