// Dragnet [Ransomware]: dragnet-ransomware-2022-0903 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 001256d8-3b34-5a57-966b-a7235fe3e766

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
