// Dragnet [Ransomware]: dragnet-ransomware-2025-6938 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 4903c430-6a77-528b-94e3-7c924b96379b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
