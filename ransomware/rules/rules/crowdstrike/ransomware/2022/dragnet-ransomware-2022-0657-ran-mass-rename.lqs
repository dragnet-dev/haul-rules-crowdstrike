// Dragnet [Ransomware]: dragnet-ransomware-2022-0657 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 4e081d1e-84a9-5066-bdab-029aab15553a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
