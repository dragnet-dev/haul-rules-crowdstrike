// Dragnet [Ransomware]: dragnet-ransomware-2026-0087 — Mass File Rename (lockbit5)
// Status: stable | Level: high | ID: 0c305b3c-8b87-558e-848a-6dc90e68cc63

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
