// Dragnet [Ransomware]: dragnet-ransomware-2023-1464 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 1c14b3b6-711c-5bb4-8e51-184597ac9897

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
