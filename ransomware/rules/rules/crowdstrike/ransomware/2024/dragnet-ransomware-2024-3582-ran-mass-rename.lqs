// Dragnet [Ransomware]: dragnet-ransomware-2024-3582 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 6ded85f1-49ac-5e93-9edd-8a9bc1fe278b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
