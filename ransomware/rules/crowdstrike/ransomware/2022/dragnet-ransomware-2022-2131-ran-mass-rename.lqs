// Dragnet [Ransomware]: dragnet-ransomware-2022-2131 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: b598e91c-addf-54f2-88f6-26f97e871f8f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
