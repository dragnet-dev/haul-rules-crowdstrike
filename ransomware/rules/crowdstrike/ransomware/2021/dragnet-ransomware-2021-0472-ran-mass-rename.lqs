// Dragnet [Ransomware]: dragnet-ransomware-2021-0472 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 90e5cbd4-b682-5dbf-9ae5-d55a4fd9c3fb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
