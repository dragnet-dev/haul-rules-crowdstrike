// Dragnet [Ransomware]: dragnet-ransomware-2025-5424 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 1f3c9362-20f3-5ebb-8262-5f3b310f0898

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
