// Dragnet [Ransomware]: dragnet-ransomware-2025-4415 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: d4e04baa-42eb-5c93-8c58-d3bec55526f8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
