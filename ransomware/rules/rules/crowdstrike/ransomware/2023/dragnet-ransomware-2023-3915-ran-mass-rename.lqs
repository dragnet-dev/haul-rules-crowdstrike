// Dragnet [Ransomware]: dragnet-ransomware-2023-3915 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 9be95612-5426-5ece-b43c-0cf2fab18ec8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
