// Dragnet [Ransomware]: dragnet-ransomware-2024-5342 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 6b5d0a4e-1f6c-50f2-8a15-84a182532ceb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
