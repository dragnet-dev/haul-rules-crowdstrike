// Dragnet [Container]: dragnet-container-2026-3099 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 838fc306-b9f1-5c95-8d55-f331be426330

#event_simpleName=*
| (ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10*)
| table([timestamp, ComputerName])
| limit(1000)
