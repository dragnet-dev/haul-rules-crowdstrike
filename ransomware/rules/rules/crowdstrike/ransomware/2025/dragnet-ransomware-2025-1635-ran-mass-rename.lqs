// Dragnet [Ransomware]: dragnet-ransomware-2025-1635 — Mass File Rename (arcusmedia)
// Status: experimental | Level: high | ID: 08671aaf-9dbc-5315-8b8e-cee7d1617876

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
