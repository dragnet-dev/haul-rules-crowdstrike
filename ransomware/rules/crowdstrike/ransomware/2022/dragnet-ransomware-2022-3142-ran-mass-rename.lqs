// Dragnet [Ransomware]: dragnet-ransomware-2022-3142 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: a216897e-5911-579f-b85a-284ef38081c1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
