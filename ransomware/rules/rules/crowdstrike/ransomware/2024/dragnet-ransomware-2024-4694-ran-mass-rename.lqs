// Dragnet [Ransomware]: dragnet-ransomware-2024-4694 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: b8745a34-3b44-5938-9ecf-890da5a6bdcf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
