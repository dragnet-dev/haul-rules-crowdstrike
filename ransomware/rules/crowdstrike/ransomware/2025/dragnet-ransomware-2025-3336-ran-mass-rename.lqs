// Dragnet [Ransomware]: dragnet-ransomware-2025-3336 — Mass File Rename (play)
// Status: experimental | Level: high | ID: d256096d-347b-5737-ba2f-c397a8defd16

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
