// Dragnet [Ransomware]: dragnet-ransomware-2022-1360 — Mass File Rename (blackbasta)
// Status: deprecated | Level: high | ID: 020439a5-6b3a-510a-a61b-3e51d0f214a3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
