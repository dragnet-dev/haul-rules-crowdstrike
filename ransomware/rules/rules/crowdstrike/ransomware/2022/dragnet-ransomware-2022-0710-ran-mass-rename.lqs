// Dragnet [Ransomware]: dragnet-ransomware-2022-0710 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 85005cf2-ca32-53f9-b52c-1dd2a6fb71d6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
