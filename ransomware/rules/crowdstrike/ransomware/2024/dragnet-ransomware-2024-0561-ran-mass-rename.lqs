// Dragnet [Ransomware]: dragnet-ransomware-2024-0561 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 6013939f-dd3f-5806-a12b-6da625070b66

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
