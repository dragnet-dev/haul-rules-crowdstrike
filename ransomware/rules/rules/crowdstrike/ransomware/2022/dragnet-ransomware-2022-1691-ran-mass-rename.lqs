// Dragnet [Ransomware]: dragnet-ransomware-2022-1691 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 4ed8b2e2-f7e4-56fb-b6d1-5350d0183c56

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
