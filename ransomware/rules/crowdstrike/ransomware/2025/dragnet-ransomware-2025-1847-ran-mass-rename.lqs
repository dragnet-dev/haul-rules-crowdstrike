// Dragnet [Ransomware]: dragnet-ransomware-2025-1847 — Mass File Rename (brotherhood)
// Status: experimental | Level: high | ID: 85ccdd2d-272d-5455-9124-e4be2a492f33

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
