// Dragnet [Ransomware]: dragnet-ransomware-2025-2500 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 7e518ed4-40f7-5bc3-a7aa-28bc641b3352

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
