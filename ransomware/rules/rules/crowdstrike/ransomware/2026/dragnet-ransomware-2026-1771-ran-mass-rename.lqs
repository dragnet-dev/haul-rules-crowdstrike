// Dragnet [Ransomware]: dragnet-ransomware-2026-1771 — Mass File Rename (lapsus$)
// Status: deprecated | Level: high | ID: 242adc5c-3fee-5070-b29b-cf2e3e3948e3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
