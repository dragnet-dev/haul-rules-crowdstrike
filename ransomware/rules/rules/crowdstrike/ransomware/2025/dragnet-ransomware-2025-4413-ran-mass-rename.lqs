// Dragnet [Ransomware]: dragnet-ransomware-2025-4413 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: e01a6491-35be-5785-b724-25354aa16990

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
