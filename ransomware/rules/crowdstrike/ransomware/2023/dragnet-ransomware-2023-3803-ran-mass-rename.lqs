// Dragnet [Ransomware]: dragnet-ransomware-2023-3803 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: d92d1a8d-c359-5e6a-a4e4-8412469e6085

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
