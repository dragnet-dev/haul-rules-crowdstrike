// Dragnet [Ransomware]: dragnet-ransomware-2023-0767 — Mass File Rename (snatch)
// Status: experimental | Level: high | ID: 2ac1dbe1-1131-5022-af89-f8092362a6fb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
