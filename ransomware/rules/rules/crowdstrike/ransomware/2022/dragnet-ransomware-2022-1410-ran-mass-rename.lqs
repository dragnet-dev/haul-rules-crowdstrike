// Dragnet [Ransomware]: dragnet-ransomware-2022-1410 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 5ebe0b46-31f2-5fd4-8ff3-4d04a3812025

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
