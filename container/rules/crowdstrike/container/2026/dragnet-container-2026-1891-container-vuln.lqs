// Dragnet [Container]: dragnet-container-2026-1891 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: a6068d2b-2ab5-52aa-ac6f-e01221cd59f1

#event_simpleName=*
| (ImageFileName = *chainguard:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
