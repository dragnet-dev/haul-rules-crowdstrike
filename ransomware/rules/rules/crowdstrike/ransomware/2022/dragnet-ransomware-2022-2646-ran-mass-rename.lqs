// Dragnet [Ransomware]: dragnet-ransomware-2022-2646 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 07c1b390-841b-57ca-bc6b-abf68080f361

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
