// Dragnet [Ransomware]: dragnet-ransomware-2023-3028 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: ddcfd151-2bde-5a25-8033-3379190508fc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
