// Dragnet [Ransomware]: dragnet-ransomware-2022-0233 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 6a43f561-733e-5923-8c16-07394f796a92

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
