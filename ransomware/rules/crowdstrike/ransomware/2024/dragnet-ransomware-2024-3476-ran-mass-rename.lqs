// Dragnet [Ransomware]: dragnet-ransomware-2024-3476 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: b158983f-b961-5908-8f8f-7024bd752dff

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
