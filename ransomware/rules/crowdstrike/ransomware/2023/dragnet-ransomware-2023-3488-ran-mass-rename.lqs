// Dragnet [Ransomware]: dragnet-ransomware-2023-3488 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 02187e21-6429-521e-8f38-2f5998252e8c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
