// Dragnet [Ransomware]: dragnet-ransomware-2023-3897 — Mass File Rename (noescape)
// Status: experimental | Level: high | ID: df8956b8-91d6-588d-bd8f-477b439d5393

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
