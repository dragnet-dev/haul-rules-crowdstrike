// Dragnet [Ransomware]: dragnet-ransomware-2023-1947 — Mass File Rename (ransomed)
// Status: deprecated | Level: high | ID: 783bd1aa-1780-51fb-9bb2-3db1a44f0e4d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
