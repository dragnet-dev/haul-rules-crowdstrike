// Dragnet [Ransomware]: dragnet-ransomware-2025-1623 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: 6c25a7e9-1001-5b3f-aceb-13a96e1e9b41

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
