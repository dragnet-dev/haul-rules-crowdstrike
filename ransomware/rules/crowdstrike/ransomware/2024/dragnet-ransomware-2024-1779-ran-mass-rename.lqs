// Dragnet [Ransomware]: dragnet-ransomware-2024-1779 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 326c8e3f-7f2f-5dc4-88cb-8de320cb3c11

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
