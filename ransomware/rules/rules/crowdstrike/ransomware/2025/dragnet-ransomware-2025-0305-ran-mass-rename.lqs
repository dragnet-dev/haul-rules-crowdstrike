// Dragnet [Ransomware]: dragnet-ransomware-2025-0305 — Mass File Rename (coinbasecartel)
// Status: test | Level: high | ID: 6036253f-7274-597f-924b-6b638ab57866

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
