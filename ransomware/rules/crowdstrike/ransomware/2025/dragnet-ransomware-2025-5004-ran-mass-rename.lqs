// Dragnet [Ransomware]: dragnet-ransomware-2025-5004 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 017fd1c6-b62c-5130-8b4d-11a68804025a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
