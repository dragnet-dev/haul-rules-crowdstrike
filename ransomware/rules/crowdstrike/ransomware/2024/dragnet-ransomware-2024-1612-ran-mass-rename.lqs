// Dragnet [Ransomware]: dragnet-ransomware-2024-1612 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 00b8f45c-c388-5fc9-9a02-f21bdd37a0e4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
