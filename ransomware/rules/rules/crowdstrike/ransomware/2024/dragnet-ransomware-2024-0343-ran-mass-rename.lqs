// Dragnet [Ransomware]: dragnet-ransomware-2024-0343 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: c1cb4723-30ec-5752-af26-11a0109f7696

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
