// Dragnet [Ransomware]: dragnet-ransomware-2022-3128 — Mass File Rename (everest)
// Status: deprecated | Level: high | ID: e4ac9a59-75bf-5675-824e-583a79a819ec

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
