// Dragnet [Ransomware]: dragnet-ransomware-2024-2691 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 1db1a370-c054-54d9-8bdf-575d7184dce0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
