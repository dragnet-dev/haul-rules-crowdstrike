// Dragnet [Ransomware]: dragnet-ransomware-2023-2746 — Mass File Rename (malas)
// Status: experimental | Level: high | ID: 38b5b5f0-e84d-554a-a874-4af8c48bb107

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
