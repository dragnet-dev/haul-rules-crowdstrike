// Dragnet [Ransomware]: dragnet-ransomware-2024-4843 — Mass File Rename (safepay)
// Status: deprecated | Level: high | ID: e19e5e10-a2c3-556e-a6c9-299c2f38b73d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
