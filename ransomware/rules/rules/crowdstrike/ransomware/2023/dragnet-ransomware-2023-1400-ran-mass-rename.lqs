// Dragnet [Ransomware]: dragnet-ransomware-2023-1400 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 793480a1-9d12-5a4b-afbe-f1f674648e52

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
