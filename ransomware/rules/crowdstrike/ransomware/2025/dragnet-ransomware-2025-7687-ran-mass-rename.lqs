// Dragnet [Ransomware]: dragnet-ransomware-2025-7687 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: e9ad9d6b-4aa0-5872-9e21-90c26b4cd573

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
