// Dragnet [Ransomware]: dragnet-ransomware-2026-2616 — Mass File Rename (dragonforce)
// Status: stable | Level: high | ID: 8927f846-a54d-5d62-871d-4c52a16bd8e5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
