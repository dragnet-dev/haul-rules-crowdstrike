// Dragnet [Ransomware]: dragnet-ransomware-2025-3326 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 7bf62ddb-29c7-5b42-b00b-4ef06204062e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
