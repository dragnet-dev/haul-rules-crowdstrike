// Dragnet [Ransomware]: dragnet-ransomware-2023-2193 — Mass File Rename (monti)
// Status: experimental | Level: high | ID: 5d57bcc3-b8c4-5523-a122-ee813edd70bf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
