// Dragnet [Ransomware]: dragnet-ransomware-2025-6682 — Mass File Rename (devman)
// Status: experimental | Level: high | ID: 5fd9ae24-6825-598c-ac81-a530c333c307

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
