// Dragnet [Ransomware]: dragnet-ransomware-2024-3792 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 01e108d8-753d-5bf4-95a4-9e3397d0d9c4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
