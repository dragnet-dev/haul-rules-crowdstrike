// Dragnet [Ransomware]: dragnet-ransomware-2021-0573 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 9a1ae72a-66ed-5833-9c72-1895714b2889

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
