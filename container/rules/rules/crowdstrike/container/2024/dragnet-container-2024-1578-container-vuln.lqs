// Dragnet [Container]: dragnet-container-2024-1578 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: f32e6b72-b3d5-51c2-9fda-8ce95e68e01c

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:9* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:16.04* OR ImageFileName = *ubuntu:18.04*)
| table([timestamp, ComputerName])
| limit(1000)
