// Dragnet [Ransomware]: dragnet-ransomware-2022-1765 — Mass File Rename (mallox)
// Status: deprecated | Level: high | ID: 8091a41d-933e-5cd1-b867-31d0ed906eb6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
