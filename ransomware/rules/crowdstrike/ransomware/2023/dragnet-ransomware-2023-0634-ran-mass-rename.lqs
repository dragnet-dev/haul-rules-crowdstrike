// Dragnet [Ransomware]: dragnet-ransomware-2023-0634 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 007a2a79-5ae4-5c52-bd86-281bb21f9659

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
