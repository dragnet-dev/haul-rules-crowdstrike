// Dragnet [Ransomware]: dragnet-ransomware-2025-1602 — Mass File Rename (devman)
// Status: experimental | Level: high | ID: e56e28da-1d9b-5739-9fc0-47f947ec510a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
