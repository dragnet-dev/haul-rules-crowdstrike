// Dragnet [Ransomware]: dragnet-ransomware-2025-2080 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 6fb86573-306d-501b-a223-e9c6ef7cba63

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
