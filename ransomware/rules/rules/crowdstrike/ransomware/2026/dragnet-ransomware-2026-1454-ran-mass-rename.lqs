// Dragnet [Ransomware]: dragnet-ransomware-2026-1454 — Mass File Rename (payload)
// Status: stable | Level: high | ID: 745aab8e-a9ab-5ace-8a15-e013d8ef7af9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
