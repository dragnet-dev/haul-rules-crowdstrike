// Dragnet [Ransomware]: dragnet-ransomware-2026-1117 — Mass File Rename (thegentlemen)
// Status: test | Level: high | ID: 6bfb5b99-5ad5-5860-9bbc-94815cc9c7c1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
