// Dragnet [Ransomware]: dragnet-ransomware-2021-0286 — Mass File Rename (payloadbin)
// Status: deprecated | Level: high | ID: c75318f7-db29-5645-964e-e718f3542b5a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
