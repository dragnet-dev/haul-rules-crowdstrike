// Dragnet [Ransomware]: dragnet-ransomware-2024-2787 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: 675aa4db-0095-5dbf-8d6d-965e093bbddc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
