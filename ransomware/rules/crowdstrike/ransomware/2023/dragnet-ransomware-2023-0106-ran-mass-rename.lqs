// Dragnet [Ransomware]: dragnet-ransomware-2023-0106 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: bbcebf83-6871-53ce-a073-3d67ef2f46b1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
