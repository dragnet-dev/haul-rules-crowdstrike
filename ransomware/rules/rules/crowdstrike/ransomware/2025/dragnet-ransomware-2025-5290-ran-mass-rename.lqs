// Dragnet [Ransomware]: dragnet-ransomware-2025-5290 — Mass File Rename (obscura)
// Status: deprecated | Level: high | ID: 7cb33f8a-5191-550c-896c-852bd69189dd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
