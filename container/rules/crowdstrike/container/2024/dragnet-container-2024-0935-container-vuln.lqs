// Dragnet [Container]: dragnet-container-2024-0935 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 55ec846f-6414-56e5-b112-4ca519c9d8d8

#event_simpleName=*
| (ImageFileName = *almalinux:8* OR ImageFileName = *almalinux:9* OR ImageFileName = *chainguard:* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:7* OR ImageFileName = *oraclelinux:8* OR ImageFileName = *oraclelinux:9* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:20.04* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
