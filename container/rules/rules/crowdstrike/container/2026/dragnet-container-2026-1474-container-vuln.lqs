// Dragnet [Container]: dragnet-container-2026-1474 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: a68c784c-04e2-54ac-bec4-1b1c18fb1cb8

#event_simpleName=*
| (ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10* OR ImageFileName = *ubuntu:13.04* OR ImageFileName = *ubuntu:13.10*)
| table([timestamp, ComputerName])
| limit(1000)
