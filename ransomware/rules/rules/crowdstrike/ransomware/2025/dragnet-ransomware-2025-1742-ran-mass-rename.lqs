// Dragnet [Ransomware]: dragnet-ransomware-2025-1742 — Mass File Rename (rhysida)
// Status: deprecated | Level: high | ID: 597e7ff5-9bf1-5835-83b5-cbb8bebe5ca0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
