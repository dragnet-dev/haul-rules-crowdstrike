// Dragnet [Ransomware]: dragnet-ransomware-2024-1579 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: ff740ff1-96fa-5719-911f-4ad47d151f34

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
