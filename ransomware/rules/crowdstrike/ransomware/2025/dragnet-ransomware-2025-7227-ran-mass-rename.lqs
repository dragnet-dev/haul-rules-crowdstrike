// Dragnet [Ransomware]: dragnet-ransomware-2025-7227 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 9d1c8efe-4c1e-544b-9b11-a2ba546d479e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
