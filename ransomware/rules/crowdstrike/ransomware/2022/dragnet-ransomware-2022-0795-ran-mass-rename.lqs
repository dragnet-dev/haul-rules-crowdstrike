// Dragnet [Ransomware]: dragnet-ransomware-2022-0795 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 8fa14e9a-b689-542e-a17c-68a501b2e9f2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
