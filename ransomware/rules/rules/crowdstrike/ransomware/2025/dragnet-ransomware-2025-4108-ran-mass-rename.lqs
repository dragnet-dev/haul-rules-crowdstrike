// Dragnet [Ransomware]: dragnet-ransomware-2025-4108 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: be43cee4-65a2-5ccc-be6e-778601617dd5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
