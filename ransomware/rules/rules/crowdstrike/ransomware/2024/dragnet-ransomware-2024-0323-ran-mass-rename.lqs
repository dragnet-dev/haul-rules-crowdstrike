// Dragnet [Ransomware]: dragnet-ransomware-2024-0323 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: c56cba1b-d3d4-516a-898c-6cb98b079c34

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
