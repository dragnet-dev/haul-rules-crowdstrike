// Dragnet [Ransomware]: dragnet-ransomware-2024-3205 — Mass File Rename (rhysida)
// Status: deprecated | Level: high | ID: a69ce463-3a58-5196-b482-70de8fdfcdbb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
