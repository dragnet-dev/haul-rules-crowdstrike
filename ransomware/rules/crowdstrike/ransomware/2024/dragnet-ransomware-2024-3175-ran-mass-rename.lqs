// Dragnet [Ransomware]: dragnet-ransomware-2024-3175 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: 345409ec-9866-58c1-85dd-0cf19106cf30

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
