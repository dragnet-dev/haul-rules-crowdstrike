// Dragnet [Ransomware]: dragnet-ransomware-2024-5448 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 7dbdb562-1203-55cb-b6d5-70d0514ff3b6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
