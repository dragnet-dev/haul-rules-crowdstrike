// Dragnet [Ransomware]: dragnet-ransomware-2024-5900 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: c27b7a74-dd4c-5a94-885e-15e28c95f3d1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
