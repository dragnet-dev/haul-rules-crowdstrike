// Dragnet [Ransomware]: dragnet-ransomware-2021-0514 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: b93ba66a-7d28-56d0-97a6-18dd11b344f6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
