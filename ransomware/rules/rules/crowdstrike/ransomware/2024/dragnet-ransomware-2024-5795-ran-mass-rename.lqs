// Dragnet [Ransomware]: dragnet-ransomware-2024-5795 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: e766e72e-4673-5d18-bebb-fe3da3b68517

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
