// Dragnet [Ransomware]: dragnet-ransomware-2023-2797 — Mass File Rename (malas)
// Status: experimental | Level: high | ID: dd1f9054-7f5a-5f2a-81b1-0f0f70ab54c9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
