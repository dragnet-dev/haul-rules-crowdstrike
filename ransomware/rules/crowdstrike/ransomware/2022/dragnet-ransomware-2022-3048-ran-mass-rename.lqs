// Dragnet [Ransomware]: dragnet-ransomware-2022-3048 — Mass File Rename (suncrypt)
// Status: deprecated | Level: high | ID: 17ff0f82-9654-5ca0-ad73-ce578da5b5a0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
