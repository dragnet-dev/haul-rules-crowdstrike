// Dragnet [Ransomware]: dragnet-ransomware-2026-1322 — Mass File Rename (incransom)
// Status: stable | Level: high | ID: 730799c0-0637-51d2-8ea0-18c523b30441

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
