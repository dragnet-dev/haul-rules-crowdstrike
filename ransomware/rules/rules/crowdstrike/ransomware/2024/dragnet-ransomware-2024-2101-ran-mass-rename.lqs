// Dragnet [Ransomware]: dragnet-ransomware-2024-2101 — Mass File Rename (stormous)
// Status: deprecated | Level: high | ID: c849c79a-0139-559a-af8b-57b241e619b2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
