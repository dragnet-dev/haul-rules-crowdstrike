// Dragnet [Ransomware]: dragnet-ransomware-2022-2053 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 91747af6-13c9-5fd0-9f2e-fe2d1764a81f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
