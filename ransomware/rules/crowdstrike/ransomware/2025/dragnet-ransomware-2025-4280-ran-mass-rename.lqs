// Dragnet [Ransomware]: dragnet-ransomware-2025-4280 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 65874120-1c2f-52bf-9507-9c07da3d46a7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
