// Dragnet [Ransomware]: dragnet-ransomware-2024-2498 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: c4ce6fd0-e59c-5f24-958f-b4d191576275

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
