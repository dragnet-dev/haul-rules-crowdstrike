// Dragnet [Ransomware]: dragnet-ransomware-2022-0256 — Mass File Rename (cuba)
// Status: deprecated | Level: high | ID: c305e29a-779c-5ac7-8407-f4da0b46baa5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
