// Dragnet [Ransomware]: dragnet-ransomware-2025-6564 — Mass File Rename (devman)
// Status: experimental | Level: high | ID: 674b859b-e6a2-5e82-bb6b-bcb68a787387

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
