// Dragnet [Ransomware]: dragnet-ransomware-2022-2851 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 73e4a20c-353c-5bdb-a3bf-37c883a14a98

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
