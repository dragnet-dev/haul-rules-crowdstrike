// Dragnet [Container]: dragnet-container-2026-0881 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 69771eb4-8689-5b3f-a8dc-510a6d09f30f

#event_simpleName=*
| (ImageFileName = *debian:7* OR ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10* OR ImageFileName = *ubuntu:13.04*)
| table([timestamp, ComputerName])
| limit(1000)
