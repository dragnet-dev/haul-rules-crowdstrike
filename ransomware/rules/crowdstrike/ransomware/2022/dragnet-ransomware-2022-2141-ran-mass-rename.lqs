// Dragnet [Ransomware]: dragnet-ransomware-2022-2141 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 91ce2abc-1ac8-5907-a245-31bf59f1dae1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
