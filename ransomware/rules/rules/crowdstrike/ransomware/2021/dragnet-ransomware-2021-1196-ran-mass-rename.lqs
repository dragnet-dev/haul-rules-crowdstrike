// Dragnet [Ransomware]: dragnet-ransomware-2021-1196 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 241f0a3f-0b50-536a-8f49-d4bda441447f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
