// Dragnet [Ransomware]: dragnet-ransomware-2023-2192 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 9f728d5e-f53d-531d-9ff5-63372802f6c6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
