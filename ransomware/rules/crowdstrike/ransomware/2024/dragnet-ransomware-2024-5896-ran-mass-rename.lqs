// Dragnet [Ransomware]: dragnet-ransomware-2024-5896 — Mass File Rename (rhysida)
// Status: deprecated | Level: high | ID: 2243034b-09a2-5246-918b-8731d765ca1d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
