// Dragnet [Ransomware]: dragnet-ransomware-2025-5976 — Mass File Rename (nightspire)
// Status: deprecated | Level: high | ID: c1270a83-587c-5616-bd76-eda16106ce5c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
