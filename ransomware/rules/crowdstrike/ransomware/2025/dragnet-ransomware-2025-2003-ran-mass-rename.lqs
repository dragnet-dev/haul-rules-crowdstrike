// Dragnet [Ransomware]: dragnet-ransomware-2025-2003 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: c0ee31cf-eecb-59ba-a32c-0a863bded439

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
