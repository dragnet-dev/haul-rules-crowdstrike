// Dragnet [Container]: dragnet-container-2024-0806 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 19525e40-804d-5444-89fd-6347bb471bb4

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:9* OR ImageFileName = *ubuntu:18.04*)
| table([timestamp, ComputerName])
| limit(1000)
