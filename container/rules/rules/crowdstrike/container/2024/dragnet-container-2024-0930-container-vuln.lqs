// Dragnet [Container]: dragnet-container-2024-0930 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: ae1e9474-6a5d-5ce1-8714-e30b3802fe29

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:7* OR ImageFileName = *redhat/ubi9:*)
| table([timestamp, ComputerName])
| limit(1000)
