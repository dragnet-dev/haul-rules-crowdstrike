// Dragnet [Ransomware]: dragnet-ransomware-2024-2726 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: c2f8d98a-9dd9-5a26-b90e-938fa5445584

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
