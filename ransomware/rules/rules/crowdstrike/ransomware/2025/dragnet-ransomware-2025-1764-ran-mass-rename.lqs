// Dragnet [Ransomware]: dragnet-ransomware-2025-1764 — Mass File Rename (sinobi)
// Status: experimental | Level: high | ID: 1206ac24-a4cc-5fee-b049-09ff2fa152c4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
