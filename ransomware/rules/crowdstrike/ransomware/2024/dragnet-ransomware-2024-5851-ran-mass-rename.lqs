// Dragnet [Ransomware]: dragnet-ransomware-2024-5851 — Mass File Rename (cloak)
// Status: deprecated | Level: high | ID: 6d35baf0-7700-557f-a807-03a131867091

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
