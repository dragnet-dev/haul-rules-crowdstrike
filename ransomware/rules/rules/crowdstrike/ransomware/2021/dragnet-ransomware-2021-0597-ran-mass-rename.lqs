// Dragnet [Ransomware]: dragnet-ransomware-2021-0597 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 14ea2bd8-dee7-5a0b-9247-22f984a61376

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
