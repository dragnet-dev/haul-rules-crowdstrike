// Dragnet [Ransomware]: dragnet-ransomware-2021-0322 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 308a66d8-e7b0-5473-a313-d59a3036d22c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
