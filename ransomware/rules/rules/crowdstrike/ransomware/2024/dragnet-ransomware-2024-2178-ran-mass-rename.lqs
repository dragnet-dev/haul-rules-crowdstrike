// Dragnet [Ransomware]: dragnet-ransomware-2024-2178 — Mass File Rename (meow)
// Status: experimental | Level: high | ID: 5fdc7639-df5c-549b-b260-cdc769b50852

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
