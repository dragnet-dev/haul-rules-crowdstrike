// Dragnet [Ransomware]: dragnet-ransomware-2023-0933 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 082196f5-c6ff-5168-9922-12007a3e9a86

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
