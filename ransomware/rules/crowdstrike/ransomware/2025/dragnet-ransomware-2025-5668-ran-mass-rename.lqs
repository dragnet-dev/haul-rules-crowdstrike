// Dragnet [Ransomware]: dragnet-ransomware-2025-5668 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 3e8222f4-a8cb-54c4-bd63-8301aa07d47f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
