// Dragnet [Ransomware]: dragnet-ransomware-2023-2040 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 5370a3f5-a565-59c9-ac0d-d6d54be711bb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
