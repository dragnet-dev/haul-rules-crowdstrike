// Dragnet [Container]: dragnet-container-2026-2019 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 4ec44727-c946-571a-8abc-101d32565002

#event_simpleName=*
| (ImageFileName = *ubuntu:14.04* OR ImageFileName = *ubuntu:16.04* OR ImageFileName = *ubuntu:16.04-ESM* OR ImageFileName = *ubuntu:16.10* OR ImageFileName = *ubuntu:17.04*)
| table([timestamp, ComputerName])
| limit(1000)
