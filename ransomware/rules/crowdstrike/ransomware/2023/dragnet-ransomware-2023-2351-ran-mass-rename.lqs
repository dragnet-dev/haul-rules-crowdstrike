// Dragnet [Ransomware]: dragnet-ransomware-2023-2351 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: f662d914-f968-5670-a3bc-a3195a2b23e0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
