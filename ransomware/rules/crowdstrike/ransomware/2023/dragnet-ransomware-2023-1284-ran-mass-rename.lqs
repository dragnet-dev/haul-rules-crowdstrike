// Dragnet [Ransomware]: dragnet-ransomware-2023-1284 — Mass File Rename (royal)
// Status: deprecated | Level: high | ID: 9b1804c5-dbd8-5b6d-bd4b-a302f50defbd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
