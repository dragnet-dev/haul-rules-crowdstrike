// Dragnet [Ransomware]: dragnet-ransomware-2024-5847 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: ab3113b8-f3ca-55c9-9230-c7d16c303b7e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
