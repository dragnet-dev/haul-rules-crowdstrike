// Dragnet [Ransomware]: dragnet-ransomware-2023-0503 — Mass File Rename (rhysida)
// Status: experimental | Level: high | ID: 083d4949-d9c4-5d0d-a53e-0921e28ca7d7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
