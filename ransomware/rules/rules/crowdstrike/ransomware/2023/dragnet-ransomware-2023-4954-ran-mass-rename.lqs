// Dragnet [Ransomware]: dragnet-ransomware-2023-4954 — Mass File Rename (ransomed)
// Status: experimental | Level: high | ID: a63e4f23-7d6e-5c88-b40a-bcf5377fcd01

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
