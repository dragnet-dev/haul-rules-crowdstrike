// Dragnet [Ransomware]: dragnet-ransomware-2022-0651 — Mass File Rename (karakurt)
// Status: deprecated | Level: high | ID: 36f79a1b-87c3-5a18-9117-5c67e241bd1c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
