// Dragnet [Ransomware]: dragnet-ransomware-2025-2400 — Mass File Rename (thegentlemen)
// Status: experimental | Level: high | ID: 11c26154-a4ce-5570-a4e1-f668862809c3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
