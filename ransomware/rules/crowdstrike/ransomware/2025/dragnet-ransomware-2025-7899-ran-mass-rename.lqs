// Dragnet [Ransomware]: dragnet-ransomware-2025-7899 — Mass File Rename (anubis)
// Status: experimental | Level: high | ID: 70b02aee-a94c-5ffb-9c29-d13b0fe14530

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
