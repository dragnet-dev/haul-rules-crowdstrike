// Dragnet [Ransomware]: dragnet-ransomware-2025-4501 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: cc1998ad-9b5f-5182-86e7-3339f902a2bf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
