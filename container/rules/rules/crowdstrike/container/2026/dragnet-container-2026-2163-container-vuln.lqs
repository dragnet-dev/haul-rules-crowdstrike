// Dragnet [Container]: dragnet-container-2026-2163 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: e0af0acf-7bf8-5010-bae0-d43a89b3211e

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
