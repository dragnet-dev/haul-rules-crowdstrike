// Dragnet [Ransomware]: dragnet-ransomware-2023-3631 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 4a0a11c3-dbbb-5164-aea9-1154d558ee77

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
