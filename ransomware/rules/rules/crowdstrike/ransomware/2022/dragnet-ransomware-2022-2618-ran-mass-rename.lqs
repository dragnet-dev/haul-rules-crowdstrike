// Dragnet [Ransomware]: dragnet-ransomware-2022-2618 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: bbea19e1-3464-5d16-89c1-01117bd02339

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
