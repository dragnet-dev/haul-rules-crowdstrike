// Dragnet [Ransomware]: dragnet-ransomware-2022-2297 — Mass File Rename (icefire)
// Status: deprecated | Level: high | ID: a2696230-a152-5c20-829c-88150bf1a65c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
