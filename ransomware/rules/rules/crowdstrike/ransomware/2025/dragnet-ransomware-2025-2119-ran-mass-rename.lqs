// Dragnet [Ransomware]: dragnet-ransomware-2025-2119 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: a44ec8a4-8200-58d0-ab41-d02b069d1407

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
