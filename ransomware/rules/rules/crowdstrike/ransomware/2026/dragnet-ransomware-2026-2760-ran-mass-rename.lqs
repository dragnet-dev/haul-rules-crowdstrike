// Dragnet [Ransomware]: dragnet-ransomware-2026-2760 — Mass File Rename (vect)
// Status: deprecated | Level: high | ID: 8ddc2216-5a4b-5ecf-98bd-7c242537276c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
