// Dragnet [Container]: dragnet-container-2026-2923 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 3429a796-a2ea-5cf4-925c-bd3795dda654

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:7* OR ImageFileName = *debian:8* OR ImageFileName = *photon os:3.0* OR ImageFileName = *photon os:4.0* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:14.04*)
| table([timestamp, ComputerName])
| limit(1000)
