// Dragnet [Ransomware]: dragnet-ransomware-2025-1727 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 0af242a0-3544-5ff1-addc-a4604086ad46

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
