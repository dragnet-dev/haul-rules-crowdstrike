// Dragnet [Ransomware]: dragnet-ransomware-2022-1628 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 4c261647-3ce4-580d-8da5-cf9586cc4610

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
