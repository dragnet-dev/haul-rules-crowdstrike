// Dragnet [Ransomware]: dragnet-ransomware-2022-1636 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 3e5c6dfa-4401-5ee6-9a71-0bb57e8baabb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
