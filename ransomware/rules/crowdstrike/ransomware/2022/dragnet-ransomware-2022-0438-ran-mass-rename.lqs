// Dragnet [Ransomware]: dragnet-ransomware-2022-0438 — Mass File Rename (karakurt)
// Status: experimental | Level: high | ID: 5cc2ca86-36c2-5055-916a-ff15a5994d23

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
