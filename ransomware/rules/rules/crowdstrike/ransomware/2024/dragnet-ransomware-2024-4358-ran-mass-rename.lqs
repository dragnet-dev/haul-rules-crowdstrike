// Dragnet [Ransomware]: dragnet-ransomware-2024-4358 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: da5a0d0a-ec8a-5763-a646-32b26c707504

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
