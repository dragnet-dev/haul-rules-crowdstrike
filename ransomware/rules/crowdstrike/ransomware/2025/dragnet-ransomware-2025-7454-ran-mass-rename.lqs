// Dragnet [Ransomware]: dragnet-ransomware-2025-7454 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 947c3123-68da-5293-ae9f-376ce41dac63

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
