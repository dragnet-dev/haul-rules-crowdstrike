// Dragnet [Ransomware]: dragnet-ransomware-2025-6813 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 87818547-1504-5cc9-a5cb-9d93e19bf687

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
