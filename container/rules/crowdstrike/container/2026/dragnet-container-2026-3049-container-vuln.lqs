// Dragnet [Container]: dragnet-container-2026-3049 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 6c77fd70-d3ae-57e0-a978-3c904a024d45

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *redhat/ubi9:*)
| table([timestamp, ComputerName])
| limit(1000)
