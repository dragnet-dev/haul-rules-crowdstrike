// Dragnet [Ransomware]: dragnet-ransomware-2025-6963 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 2446b652-3917-5738-a31f-4c43257ad81f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
