// Dragnet [Ransomware]: dragnet-ransomware-2021-0637 — Mass File Rename (midas)
// Status: deprecated | Level: high | ID: 9c9295e6-f397-59dc-9aac-2e5fe1c97367

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
