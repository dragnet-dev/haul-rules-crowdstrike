// Dragnet [Ransomware]: dragnet-ransomware-2022-2500 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: e24ba79a-884c-54af-a178-a0923547f3bc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
