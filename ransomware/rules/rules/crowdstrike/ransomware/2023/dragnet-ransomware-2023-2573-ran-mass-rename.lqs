// Dragnet [Ransomware]: dragnet-ransomware-2023-2573 — Mass File Rename (ransomhouse)
// Status: experimental | Level: high | ID: 5e62e984-9ca2-5927-b8b0-2419330bb4f5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
