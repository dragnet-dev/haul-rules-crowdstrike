// Dragnet [Ransomware]: dragnet-ransomware-2023-3751 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 0c1949b4-b2a8-5793-bc67-dac165196de9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
