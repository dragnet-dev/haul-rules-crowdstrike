// Dragnet [Ransomware]: dragnet-ransomware-2021-0813 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 79daa5fe-6cad-5c86-a17f-5108a24514d8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
