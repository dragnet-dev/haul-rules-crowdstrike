// Dragnet [Ransomware]: dragnet-ransomware-2025-1382 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: 6598359e-dc1d-535e-87f3-9854ec7c1242

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
