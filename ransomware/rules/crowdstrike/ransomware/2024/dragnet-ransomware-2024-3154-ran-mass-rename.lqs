// Dragnet [Ransomware]: dragnet-ransomware-2024-3154 — Mass File Rename (trinity)
// Status: experimental | Level: high | ID: 4b774c8e-1e2e-5170-a625-29d28ad64dff

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
