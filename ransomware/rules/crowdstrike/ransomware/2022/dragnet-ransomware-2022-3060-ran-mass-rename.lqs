// Dragnet [Ransomware]: dragnet-ransomware-2022-3060 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 1b13ccfb-9072-5b0e-9a3f-bf877d184b88

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
