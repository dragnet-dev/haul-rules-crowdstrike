// Dragnet [Ransomware]: dragnet-ransomware-2025-4014 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 32884c86-172c-597e-a31c-97b43992ecc1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
