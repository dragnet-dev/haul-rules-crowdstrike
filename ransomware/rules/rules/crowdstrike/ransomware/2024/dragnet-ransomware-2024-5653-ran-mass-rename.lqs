// Dragnet [Ransomware]: dragnet-ransomware-2024-5653 — Mass File Rename (handala)
// Status: experimental | Level: high | ID: 3351d354-e0fd-586e-910c-b9bd7bb203bd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
