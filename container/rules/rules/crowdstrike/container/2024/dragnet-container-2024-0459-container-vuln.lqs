// Dragnet [Container]: dragnet-container-2024-0459 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 99a02e1e-d08f-5d76-a1b1-712dc1cd8cb6

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:8* OR ImageFileName = *debian:9*)
| table([timestamp, ComputerName])
| limit(1000)
