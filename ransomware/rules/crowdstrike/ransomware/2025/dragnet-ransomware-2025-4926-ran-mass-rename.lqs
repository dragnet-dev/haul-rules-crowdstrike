// Dragnet [Ransomware]: dragnet-ransomware-2025-4926 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 56eac45f-0181-5364-a94d-bb512d5a1fc1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
