// Dragnet [Ransomware]: dragnet-ransomware-2025-0425 — Mass File Rename (J)
// Status: experimental | Level: high | ID: 4bece8e5-f161-5f85-bacb-358736adb193

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
