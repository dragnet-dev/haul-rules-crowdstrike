// Dragnet [Ransomware]: dragnet-ransomware-2024-4454 — Mass File Rename (darkvault)
// Status: experimental | Level: high | ID: aae7a1a9-be05-51de-bcc5-26f8a56cc904

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
