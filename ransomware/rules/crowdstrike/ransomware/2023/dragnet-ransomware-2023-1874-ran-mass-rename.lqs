// Dragnet [Ransomware]: dragnet-ransomware-2023-1874 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: d8a7bcb6-72fe-53fb-9f6d-1b74e0589981

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
