// Dragnet [Ransomware]: dragnet-ransomware-2022-1662 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: a367ab4d-0ebc-595e-9627-bb3dffd26117

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
