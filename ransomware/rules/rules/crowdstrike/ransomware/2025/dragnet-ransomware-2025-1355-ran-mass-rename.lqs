// Dragnet [Ransomware]: dragnet-ransomware-2025-1355 — Mass File Rename (devman)
// Status: experimental | Level: high | ID: 7f39e765-9fb3-517d-b926-63338c480b45

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
