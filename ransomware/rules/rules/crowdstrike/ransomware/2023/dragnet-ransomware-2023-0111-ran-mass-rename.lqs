// Dragnet [Ransomware]: dragnet-ransomware-2023-0111 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 9eb7545b-74d1-52ef-950a-3431292e8131

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
