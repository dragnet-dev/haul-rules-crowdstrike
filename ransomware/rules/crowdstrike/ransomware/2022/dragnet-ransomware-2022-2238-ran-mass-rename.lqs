// Dragnet [Ransomware]: dragnet-ransomware-2022-2238 — Mass File Rename (vicesociety)
// Status: deprecated | Level: high | ID: ccdac171-9fcd-5f46-aa99-2e436d19933d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
