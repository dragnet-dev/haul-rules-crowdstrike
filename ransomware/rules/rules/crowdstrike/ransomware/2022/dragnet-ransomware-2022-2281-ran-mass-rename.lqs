// Dragnet [Ransomware]: dragnet-ransomware-2022-2281 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: f80ae75c-991a-5485-a507-8b5111c82a42

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
