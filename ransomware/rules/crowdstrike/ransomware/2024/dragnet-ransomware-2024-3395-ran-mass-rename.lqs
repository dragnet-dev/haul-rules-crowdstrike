// Dragnet [Ransomware]: dragnet-ransomware-2024-3395 — Mass File Rename (raworld)
// Status: experimental | Level: high | ID: 786fa3e8-d3ce-5e9c-9b02-8f7f7fca7c64

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
