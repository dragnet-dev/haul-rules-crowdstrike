// Dragnet [Ransomware]: dragnet-ransomware-2024-1056 — Mass File Rename (dragonforce)
// Status: deprecated | Level: high | ID: 532e2fab-7e3c-5b76-a8f7-db79234e9349

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
