// Dragnet [Ransomware]: dragnet-ransomware-2025-1002 — Mass File Rename (ransomhouse)
// Status: test | Level: high | ID: a524e841-d2e3-5e31-b97c-1a33efdf905f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
