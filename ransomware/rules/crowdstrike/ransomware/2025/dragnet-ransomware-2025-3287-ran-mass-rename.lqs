// Dragnet [Ransomware]: dragnet-ransomware-2025-3287 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 7a2effa1-8120-5426-b1ee-a7548a1a5c66

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
