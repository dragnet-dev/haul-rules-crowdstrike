// Dragnet [Ransomware]: dragnet-ransomware-2023-0179 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 0a117a71-0296-5339-a1df-e078fb5417ba

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
