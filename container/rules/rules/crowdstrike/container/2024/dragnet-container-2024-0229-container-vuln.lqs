// Dragnet [Container]: dragnet-container-2024-0229 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 1e30c28e-ab49-5409-bd71-f56714d61766

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *ubuntu:18.04* OR ImageFileName = *ubuntu:18.04-ESM* OR ImageFileName = *ubuntu:18.10* OR ImageFileName = *ubuntu:19.04*)
| table([timestamp, ComputerName])
| limit(1000)
