// Dragnet [Ransomware]: dragnet-ransomware-2022-2589 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 81011aa3-d159-5427-b5c9-4cb845c651ee

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
