// Dragnet [Ransomware]: dragnet-ransomware-2025-2319 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 6f2b3ee8-aa29-51da-a4b9-9c7aaac77a6c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
