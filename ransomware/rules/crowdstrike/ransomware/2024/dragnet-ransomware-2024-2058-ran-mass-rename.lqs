// Dragnet [Ransomware]: dragnet-ransomware-2024-2058 — Mass File Rename (dragonransomware)
// Status: experimental | Level: high | ID: c099e3bb-812c-5ae9-a906-b31a61b44b17

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
