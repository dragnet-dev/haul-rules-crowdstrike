// Dragnet [Container]: dragnet-container-2026-0616 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: b6f2fb4c-4d45-5ed1-a148-b80133a80d52

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *ubuntu:12.04*)
| table([timestamp, ComputerName])
| limit(1000)
