// Dragnet [Ransomware]: dragnet-ransomware-2023-5378 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 08927b22-d0f2-5b38-ae72-9f8faf449a31

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
