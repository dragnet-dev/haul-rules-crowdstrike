// Dragnet [Ransomware]: dragnet-ransomware-2022-0539 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: f5a28c71-dafb-56e1-8e6e-4d5afe0e3055

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
