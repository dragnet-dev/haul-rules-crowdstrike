// Dragnet [Ransomware]: dragnet-ransomware-2022-1374 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 4daf7492-e4d1-5933-bb2f-49fb5fba61dc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
