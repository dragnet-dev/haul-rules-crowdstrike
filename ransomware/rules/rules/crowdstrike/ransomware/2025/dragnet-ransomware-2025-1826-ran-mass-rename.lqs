// Dragnet [Ransomware]: dragnet-ransomware-2025-1826 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: b0228680-f0f2-59e0-bdde-ab35acd00678

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
