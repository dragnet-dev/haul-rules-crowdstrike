// Dragnet [Ransomware]: dragnet-ransomware-2024-4544 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: e6d2bcfa-8473-5bd8-bd0c-461f08a44095

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
