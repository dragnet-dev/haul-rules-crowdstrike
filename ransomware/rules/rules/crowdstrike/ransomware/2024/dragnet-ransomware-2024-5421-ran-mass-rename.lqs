// Dragnet [Ransomware]: dragnet-ransomware-2024-5421 — Mass File Rename (hellogookie)
// Status: experimental | Level: high | ID: cd2579bb-5cbd-5f87-b884-bf258d72ed1e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
