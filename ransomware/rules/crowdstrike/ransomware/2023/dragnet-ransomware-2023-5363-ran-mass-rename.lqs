// Dragnet [Ransomware]: dragnet-ransomware-2023-5363 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: e90dda84-b434-549d-8ced-6f40002a9686

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
