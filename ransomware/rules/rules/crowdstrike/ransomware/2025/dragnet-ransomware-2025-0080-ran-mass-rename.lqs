// Dragnet [Ransomware]: dragnet-ransomware-2025-0080 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 15475949-f275-5f08-b45f-b12c999a760e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
