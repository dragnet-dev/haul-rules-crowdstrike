// Dragnet [Ransomware]: dragnet-ransomware-2026-1069 — Mass File Rename (thegentlemen)
// Status: test | Level: high | ID: 35783ebc-4f4c-574c-905f-6bbf9ff38eae

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
