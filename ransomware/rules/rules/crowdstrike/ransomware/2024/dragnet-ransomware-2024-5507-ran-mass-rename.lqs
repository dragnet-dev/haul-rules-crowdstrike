// Dragnet [Ransomware]: dragnet-ransomware-2024-5507 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: 12cee3b5-bb61-5a32-a762-2d9a42ac99b0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
