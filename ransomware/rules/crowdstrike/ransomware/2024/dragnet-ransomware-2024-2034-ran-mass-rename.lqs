// Dragnet [Ransomware]: dragnet-ransomware-2024-2034 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 27a29e6b-483f-546a-8f88-8543e19a31a7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
