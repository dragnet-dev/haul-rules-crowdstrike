// Dragnet [Ransomware]: dragnet-ransomware-2023-5261 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 3b0bc90e-2fd9-5a6e-b9d2-f4351c580ac8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
