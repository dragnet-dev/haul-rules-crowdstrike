// Dragnet [Ransomware]: dragnet-ransomware-2022-0507 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 8da8c9f5-7eb5-518c-b08b-854795c82909

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
