// Dragnet [Ransomware]: dragnet-ransomware-2024-0336 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 443bbc6c-0a70-5525-bb5d-25940056757f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
