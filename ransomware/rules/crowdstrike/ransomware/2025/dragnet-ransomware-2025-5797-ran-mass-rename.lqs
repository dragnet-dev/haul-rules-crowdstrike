// Dragnet [Ransomware]: dragnet-ransomware-2025-5797 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: ee9a0064-7794-5b41-bc3e-f58401c06a22

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
