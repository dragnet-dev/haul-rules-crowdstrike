// Dragnet [Ransomware]: dragnet-ransomware-2025-1640 — Mass File Rename (ciphbit)
// Status: deprecated | Level: high | ID: a75b2f64-74be-5e33-bdfe-d490d76522e6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
