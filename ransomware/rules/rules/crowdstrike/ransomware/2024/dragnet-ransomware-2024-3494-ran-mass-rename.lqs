// Dragnet [Ransomware]: dragnet-ransomware-2024-3494 — Mass File Rename (ElDorado)
// Status: experimental | Level: high | ID: 279751a8-f918-51d6-8a8e-2ed3e65b99c9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
