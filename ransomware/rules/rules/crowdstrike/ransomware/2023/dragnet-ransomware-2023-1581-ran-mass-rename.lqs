// Dragnet [Ransomware]: dragnet-ransomware-2023-1581 — Mass File Rename (ransomed)
// Status: experimental | Level: high | ID: 610dcb09-6564-58e2-b88d-38ac3502d543

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
