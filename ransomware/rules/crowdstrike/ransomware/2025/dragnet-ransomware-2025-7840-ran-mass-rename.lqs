// Dragnet [Ransomware]: dragnet-ransomware-2025-7840 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 8c5d1a95-4d17-5adf-9e5e-e05202df680c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
