// Dragnet [Ransomware]: dragnet-ransomware-2022-1322 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: be94e96a-2fe5-5322-9cf8-f06d93e022f1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
