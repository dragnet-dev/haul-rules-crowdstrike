// Dragnet [Ransomware]: dragnet-ransomware-2023-2793 — Mass File Rename (malas)
// Status: experimental | Level: high | ID: bdca5d1a-56cd-5fa4-9679-4d74791f6a80

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
