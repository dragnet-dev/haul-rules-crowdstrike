// Dragnet [Container]: dragnet-container-2026-2632 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: dbefe079-0c10-58d0-a962-8ecc36f66098

#event_simpleName=*
| (ImageFileName = *debian:7* OR ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10* OR ImageFileName = *ubuntu:13.04*)
| table([timestamp, ComputerName])
| limit(1000)
