// Dragnet [Ransomware]: dragnet-ransomware-2025-6405 — Mass File Rename (pear)
// Status: experimental | Level: high | ID: f2d79b02-9849-5c06-94fc-9af7b4d88cc8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
