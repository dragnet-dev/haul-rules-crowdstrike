// Dragnet [Ransomware]: dragnet-ransomware-2024-2707 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 12c9d3fd-1b92-5b0b-b08d-57948c8b90e5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
