// Dragnet [Ransomware]: dragnet-ransomware-2026-1409 — Mass File Rename (nightspire)
// Status: deprecated | Level: high | ID: 05aa2014-7ec9-5248-be3d-463410c39ece

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
