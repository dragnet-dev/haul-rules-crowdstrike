// Dragnet [Ransomware]: dragnet-ransomware-2024-0290 — Mass File Rename (qilin)
// Status: deprecated | Level: high | ID: 00a524f2-25ee-50b0-9845-99b439075013

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
