// Dragnet [Ransomware]: dragnet-ransomware-2025-7575 — Mass File Rename (nova)
// Status: experimental | Level: high | ID: 570998cc-3fa8-5ab8-a5a7-4c01d5615679

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
