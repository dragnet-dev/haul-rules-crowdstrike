// Dragnet [Ransomware]: dragnet-ransomware-2025-4903 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 15fc7183-4a77-5655-905c-95942ef17df7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
