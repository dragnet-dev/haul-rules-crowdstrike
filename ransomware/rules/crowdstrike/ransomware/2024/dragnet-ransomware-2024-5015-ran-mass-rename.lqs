// Dragnet [Ransomware]: dragnet-ransomware-2024-5015 — Mass File Rename (ElDorado)
// Status: deprecated | Level: high | ID: a0257115-af1e-54de-bd57-f189781d57df

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
