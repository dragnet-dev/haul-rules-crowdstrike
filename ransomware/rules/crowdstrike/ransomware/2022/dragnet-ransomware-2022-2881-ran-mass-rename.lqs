// Dragnet [Ransomware]: dragnet-ransomware-2022-2881 — Mass File Rename (onyx)
// Status: deprecated | Level: high | ID: ff5e4816-7bb9-579c-9066-9b2e1ec6b128

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
