// Dragnet [Ransomware]: dragnet-ransomware-2023-1264 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: d65337a0-d7e2-5df8-b44b-8cb6f818ec56

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
