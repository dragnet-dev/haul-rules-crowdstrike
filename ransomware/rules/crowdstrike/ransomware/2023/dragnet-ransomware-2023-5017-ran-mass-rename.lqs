// Dragnet [Ransomware]: dragnet-ransomware-2023-5017 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: a5cdbb99-13ad-579c-91d3-9c152fcfa69d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
