// Dragnet [Ransomware]: dragnet-ransomware-2022-1246 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 242bc646-9d04-5623-abe3-fc308111c465

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
