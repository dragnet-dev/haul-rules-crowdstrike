// Dragnet [Ransomware]: dragnet-ransomware-2023-0093 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: fbb73fb1-5780-57f3-b0cc-912064f82ffb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
