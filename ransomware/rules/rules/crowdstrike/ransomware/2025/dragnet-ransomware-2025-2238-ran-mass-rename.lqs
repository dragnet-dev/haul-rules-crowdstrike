// Dragnet [Ransomware]: dragnet-ransomware-2025-2238 — Mass File Rename (apt73)
// Status: experimental | Level: high | ID: 4e43e0a2-e09e-53a8-a9b5-45b6df7e5b11

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
