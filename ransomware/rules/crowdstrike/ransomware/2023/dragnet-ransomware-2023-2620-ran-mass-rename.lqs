// Dragnet [Ransomware]: dragnet-ransomware-2023-2620 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 17ae598b-6eda-51b4-ab19-77c37b65dd5c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
