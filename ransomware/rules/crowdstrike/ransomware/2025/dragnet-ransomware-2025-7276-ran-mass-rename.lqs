// Dragnet [Ransomware]: dragnet-ransomware-2025-7276 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 76c26e4f-5a96-5159-bba3-9954f417425c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
