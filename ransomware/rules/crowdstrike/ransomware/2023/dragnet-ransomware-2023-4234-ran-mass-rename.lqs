// Dragnet [Ransomware]: dragnet-ransomware-2023-4234 — Mass File Rename (cloak)
// Status: deprecated | Level: high | ID: bd73910e-e5ec-59a3-909a-589c5d6faa07

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
