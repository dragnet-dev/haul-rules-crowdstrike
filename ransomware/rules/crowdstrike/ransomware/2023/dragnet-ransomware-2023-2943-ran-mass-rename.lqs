// Dragnet [Ransomware]: dragnet-ransomware-2023-2943 — Mass File Rename (losttrust)
// Status: deprecated | Level: high | ID: 769e8f94-4b02-52c0-a4c9-8ef8c4833feb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
