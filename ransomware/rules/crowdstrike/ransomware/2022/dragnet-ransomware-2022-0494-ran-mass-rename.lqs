// Dragnet [Ransomware]: dragnet-ransomware-2022-0494 — Mass File Rename (snatch)
// Status: experimental | Level: high | ID: 37049304-f879-55b6-8206-af4c19d75143

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
