// Dragnet [Ransomware]: dragnet-ransomware-2024-5781 — Mass File Rename (raworld)
// Status: experimental | Level: high | ID: 43a3033e-3609-5541-8d58-c369e2d425d1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
