// Dragnet [Ransomware]: dragnet-ransomware-2021-0061 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 8375c4cc-e470-58ec-b649-9e22dea77735

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
