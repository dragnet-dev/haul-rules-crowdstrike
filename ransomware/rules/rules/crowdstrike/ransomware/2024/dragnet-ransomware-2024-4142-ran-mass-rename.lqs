// Dragnet [Ransomware]: dragnet-ransomware-2024-4142 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 0f7fa3a2-49cc-51f5-be9f-8c9cfc17745a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
