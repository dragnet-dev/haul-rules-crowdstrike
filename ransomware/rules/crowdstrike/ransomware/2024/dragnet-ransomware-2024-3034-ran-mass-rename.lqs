// Dragnet [Ransomware]: dragnet-ransomware-2024-3034 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 8b957e50-68fd-58ef-81bb-34d096f3b6b8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
