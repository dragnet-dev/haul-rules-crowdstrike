// Dragnet [Ransomware]: dragnet-ransomware-2024-5779 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 76a43781-54cd-5385-94ba-c7cb78704756

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
