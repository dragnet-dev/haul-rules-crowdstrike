// Dragnet [Ransomware]: dragnet-ransomware-2024-3678 — Mass File Rename (apt73)
// Status: experimental | Level: high | ID: f93339b6-0aff-5493-aa70-c46c5a53f12d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
