// Dragnet [Ransomware]: dragnet-ransomware-2025-0087 — Mass File Rename (spacebears)
// Status: experimental | Level: high | ID: 4fc2d65f-faa4-5338-bacc-cf68431959a1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
