// Dragnet [Container]: dragnet-container-2026-1830 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 6dfdeef3-b40f-54fc-9fdb-36698cec1694

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:8*)
| table([timestamp, ComputerName])
| limit(1000)
