// Dragnet [Ransomware]: dragnet-ransomware-2023-1267 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: a6d86ee0-8a4e-5d54-8414-367b6b8231e1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
