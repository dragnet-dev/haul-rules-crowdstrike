// Dragnet [Ransomware]: dragnet-ransomware-2025-2684 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 3941cccc-593b-5d89-8b90-9349da05d873

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
