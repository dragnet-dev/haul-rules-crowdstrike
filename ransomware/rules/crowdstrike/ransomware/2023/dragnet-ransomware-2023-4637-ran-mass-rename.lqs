// Dragnet [Ransomware]: dragnet-ransomware-2023-4637 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 7619a878-68c3-56fe-ba83-b7f13f3d740c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
