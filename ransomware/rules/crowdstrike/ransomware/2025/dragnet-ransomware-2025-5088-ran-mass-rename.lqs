// Dragnet [Ransomware]: dragnet-ransomware-2025-5088 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 76e2f731-6fc2-59a4-ae54-f399ecca693b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
