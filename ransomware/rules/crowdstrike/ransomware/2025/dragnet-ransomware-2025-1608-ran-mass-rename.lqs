// Dragnet [Ransomware]: dragnet-ransomware-2025-1608 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: e5d23a57-4574-5120-8a6c-86b9d56e0413

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
