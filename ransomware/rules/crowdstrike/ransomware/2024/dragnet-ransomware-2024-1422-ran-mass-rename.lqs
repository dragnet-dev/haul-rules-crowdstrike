// Dragnet [Ransomware]: dragnet-ransomware-2024-1422 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: e4c3ee38-822d-5959-845a-f2743db0c14d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
