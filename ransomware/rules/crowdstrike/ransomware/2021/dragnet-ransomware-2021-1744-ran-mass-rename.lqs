// Dragnet [Ransomware]: dragnet-ransomware-2021-1744 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: ace73874-fcfd-5d4d-8918-3fd4a32ff8db

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
