// Dragnet [Ransomware]: dragnet-ransomware-2025-5133 — Mass File Rename (J)
// Status: experimental | Level: high | ID: 58d325b4-e71a-52cc-a6a4-9617cf97d8c0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
