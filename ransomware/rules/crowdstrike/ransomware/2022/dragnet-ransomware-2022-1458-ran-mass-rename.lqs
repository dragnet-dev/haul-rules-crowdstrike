// Dragnet [Ransomware]: dragnet-ransomware-2022-1458 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: cab71859-162f-5ee4-b5b5-06cc3f722351

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
