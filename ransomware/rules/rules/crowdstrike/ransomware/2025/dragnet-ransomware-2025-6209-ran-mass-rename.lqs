// Dragnet [Ransomware]: dragnet-ransomware-2025-6209 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 3c950ac3-bfbd-5045-8cb1-9832f7f43033

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
