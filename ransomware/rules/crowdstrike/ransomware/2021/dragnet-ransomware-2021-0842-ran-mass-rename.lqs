// Dragnet [Ransomware]: dragnet-ransomware-2021-0842 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 5985a93f-75db-5fdc-90a1-57c8e6612ec7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
