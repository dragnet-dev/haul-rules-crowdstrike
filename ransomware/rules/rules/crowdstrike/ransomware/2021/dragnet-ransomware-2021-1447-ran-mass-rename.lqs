// Dragnet [Ransomware]: dragnet-ransomware-2021-1447 — Mass File Rename (ragnarok)
// Status: deprecated | Level: high | ID: 21ab8a8c-d4b2-57cb-a2d5-a42f06ee7179

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
