// Dragnet [Ransomware]: dragnet-ransomware-2024-4148 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: 4aed9017-67ec-55fe-acea-148862020198

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
