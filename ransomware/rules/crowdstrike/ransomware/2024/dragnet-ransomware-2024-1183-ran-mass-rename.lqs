// Dragnet [Ransomware]: dragnet-ransomware-2024-1183 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 90f566a0-828a-5afa-9b53-342f7204a479

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
