// Dragnet [Ransomware]: dragnet-ransomware-2024-3995 — Mass File Rename (play)
// Status: experimental | Level: high | ID: c680b843-3113-5e91-9ef5-220230f5620a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
