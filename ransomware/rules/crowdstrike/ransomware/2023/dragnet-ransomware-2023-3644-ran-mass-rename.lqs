// Dragnet [Ransomware]: dragnet-ransomware-2023-3644 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: de2afc9a-30c6-54cf-85ec-e9ca39b4e295

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
