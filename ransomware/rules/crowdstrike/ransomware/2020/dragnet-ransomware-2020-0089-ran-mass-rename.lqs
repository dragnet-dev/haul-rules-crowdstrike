// Dragnet [Ransomware]: dragnet-ransomware-2020-0089 — Mass File Rename (maze)
// Status: deprecated | Level: high | ID: af35509e-ef7e-576b-beaf-9f3f403bc836

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
