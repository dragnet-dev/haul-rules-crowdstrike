// Dragnet [Ransomware]: dragnet-ransomware-2023-4208 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 4e5caffe-a7ec-5488-83a9-d96dd2628ace

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
