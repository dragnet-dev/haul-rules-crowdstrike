// Dragnet [Ransomware]: dragnet-ransomware-2024-2284 — Mass File Rename (cloak)
// Status: deprecated | Level: high | ID: 7e72f8fc-215a-5acf-88fd-acee9f1d1716

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
