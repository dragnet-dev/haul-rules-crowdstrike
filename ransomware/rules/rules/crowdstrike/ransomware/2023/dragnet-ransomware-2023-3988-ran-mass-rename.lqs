// Dragnet [Ransomware]: dragnet-ransomware-2023-3988 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 963a8e8b-9d7c-574e-9416-74d1daad0670

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
