// Dragnet [Ransomware]: dragnet-ransomware-2026-0147 — Mass File Rename (cloak)
// Status: deprecated | Level: high | ID: 5a95469e-ed43-593e-8237-e67038b67ac2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
