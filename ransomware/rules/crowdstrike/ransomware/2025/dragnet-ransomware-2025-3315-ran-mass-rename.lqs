// Dragnet [Ransomware]: dragnet-ransomware-2025-3315 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 45f0c68a-ed00-5b80-8e06-a3c150516ac4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
