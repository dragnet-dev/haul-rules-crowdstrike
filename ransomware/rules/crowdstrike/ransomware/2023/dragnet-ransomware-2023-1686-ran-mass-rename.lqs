// Dragnet [Ransomware]: dragnet-ransomware-2023-1686 — Mass File Rename (snatch)
// Status: experimental | Level: high | ID: 34016960-02f1-54f7-95f2-05dcc1e8fcb8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
