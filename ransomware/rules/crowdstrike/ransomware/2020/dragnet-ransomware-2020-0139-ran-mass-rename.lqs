// Dragnet [Ransomware]: dragnet-ransomware-2020-0139 — Mass File Rename (ragnarlocker)
// Status: deprecated | Level: high | ID: 59c159c1-aa9c-5c62-95f9-521cccbccdc3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
