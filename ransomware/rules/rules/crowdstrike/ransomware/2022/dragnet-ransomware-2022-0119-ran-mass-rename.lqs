// Dragnet [Ransomware]: dragnet-ransomware-2022-0119 — Mass File Rename (cheers)
// Status: deprecated | Level: high | ID: f3ebbf76-ad4d-5db1-ad61-de86343a6011

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
