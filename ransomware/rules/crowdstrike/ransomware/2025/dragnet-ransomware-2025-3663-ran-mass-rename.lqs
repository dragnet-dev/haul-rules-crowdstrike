// Dragnet [Ransomware]: dragnet-ransomware-2025-3663 — Mass File Rename (global)
// Status: experimental | Level: high | ID: ee32b1b3-6890-50b8-9dea-245b33216078

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
