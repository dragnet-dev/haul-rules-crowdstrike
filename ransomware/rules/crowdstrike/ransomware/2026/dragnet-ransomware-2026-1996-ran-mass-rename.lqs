// Dragnet [Ransomware]: dragnet-ransomware-2026-1996 — Mass File Rename (SilentRansomGroup)
// Status: deprecated | Level: high | ID: d56b00c9-357c-5c1e-ae87-55e6cc1d6805

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
