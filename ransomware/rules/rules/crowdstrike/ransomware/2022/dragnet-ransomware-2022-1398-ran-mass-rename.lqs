// Dragnet [Ransomware]: dragnet-ransomware-2022-1398 — Mass File Rename (karakurt)
// Status: deprecated | Level: high | ID: 85e3e6ce-6443-5516-a4db-d7cfde1ad3a8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
