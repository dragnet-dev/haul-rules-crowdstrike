// Dragnet [Ransomware]: dragnet-ransomware-2024-5005 — Mass File Rename (interlock)
// Status: experimental | Level: high | ID: d8c77e62-45c7-5d8b-807a-2157d46cc56d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
