// Dragnet [Ransomware]: dragnet-ransomware-2026-2478 — Mass File Rename (lockbit5)
// Status: stable | Level: high | ID: 85745b86-ca91-5bad-beef-ed57be3172e5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
