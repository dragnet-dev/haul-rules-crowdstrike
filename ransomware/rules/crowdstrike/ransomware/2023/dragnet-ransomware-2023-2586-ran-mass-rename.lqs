// Dragnet [Ransomware]: dragnet-ransomware-2023-2586 — Mass File Rename (ransomexx)
// Status: experimental | Level: high | ID: 5a1ce5a2-81e4-540d-b6f0-780e559ad8d3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
