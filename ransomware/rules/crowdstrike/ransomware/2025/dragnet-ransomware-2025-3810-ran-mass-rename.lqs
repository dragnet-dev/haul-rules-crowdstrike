// Dragnet [Ransomware]: dragnet-ransomware-2025-3810 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: e096100e-d797-548f-8850-380c8dc081b4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
