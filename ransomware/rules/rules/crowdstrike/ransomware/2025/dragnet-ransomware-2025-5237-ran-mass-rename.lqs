// Dragnet [Ransomware]: dragnet-ransomware-2025-5237 — Mass File Rename (sinobi)
// Status: experimental | Level: high | ID: a0f63663-bc4e-577c-9a35-e63bea1d7c2c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
