// Dragnet [Ransomware]: dragnet-ransomware-2025-1934 — Mass File Rename (lockbit5)
// Status: test | Level: high | ID: 4a190b9d-7d99-54ac-8b33-13ea8eed52a8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
