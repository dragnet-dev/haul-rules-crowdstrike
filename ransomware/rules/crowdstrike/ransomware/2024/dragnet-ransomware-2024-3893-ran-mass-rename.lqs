// Dragnet [Ransomware]: dragnet-ransomware-2024-3893 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: b876b57b-00cd-57e5-a4e8-531e8170ad2a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
