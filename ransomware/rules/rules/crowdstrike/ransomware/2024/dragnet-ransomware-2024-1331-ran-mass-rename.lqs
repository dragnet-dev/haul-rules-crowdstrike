// Dragnet [Ransomware]: dragnet-ransomware-2024-1331 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 496e3eb1-c748-51f6-8a2a-a2dfb93a75a0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
