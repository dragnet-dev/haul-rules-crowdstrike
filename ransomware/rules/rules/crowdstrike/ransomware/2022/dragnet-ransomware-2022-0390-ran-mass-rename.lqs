// Dragnet [Ransomware]: dragnet-ransomware-2022-0390 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: bffccd77-e510-5404-93f5-fc0c853d4428

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
