// Dragnet [Ransomware]: dragnet-ransomware-2025-0505 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 0052c4e0-835a-577f-bb73-ff02e44b5736

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
