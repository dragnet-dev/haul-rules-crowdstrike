// Dragnet [Ransomware]: dragnet-ransomware-2024-4398 — Mass File Rename (apt73)
// Status: experimental | Level: high | ID: 91072072-a74e-563e-ae26-8fa6945a86a2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
