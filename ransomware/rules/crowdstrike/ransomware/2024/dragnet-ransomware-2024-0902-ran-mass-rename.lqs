// Dragnet [Ransomware]: dragnet-ransomware-2024-0902 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 8607210e-3f87-5416-bb22-20e67bc4960a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
