// Dragnet [Ransomware]: dragnet-ransomware-2025-3798 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: d0e6537a-3d1d-5ac4-8797-9219b5ec0735

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
