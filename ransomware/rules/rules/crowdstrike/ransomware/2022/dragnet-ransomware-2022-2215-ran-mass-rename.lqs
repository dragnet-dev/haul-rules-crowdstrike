// Dragnet [Ransomware]: dragnet-ransomware-2022-2215 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 31c87d53-8c37-5872-8b3e-80d99eef015c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
