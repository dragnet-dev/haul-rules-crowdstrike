// Dragnet [Ransomware]: dragnet-ransomware-2022-1539 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 31aa4c95-48ee-5044-9ef6-fcea145928f6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
