// Dragnet [Ransomware]: dragnet-ransomware-2022-0005 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 9e18ae08-7a3c-5f89-857f-9809f2ecfaad

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
