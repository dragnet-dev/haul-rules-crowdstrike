// Dragnet [Ransomware]: dragnet-ransomware-2025-1019 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 9fcdaaa2-0240-56b4-a0f0-21522073b715

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
