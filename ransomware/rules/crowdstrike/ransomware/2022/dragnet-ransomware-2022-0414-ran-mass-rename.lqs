// Dragnet [Ransomware]: dragnet-ransomware-2022-0414 — Mass File Rename (daixin)
// Status: deprecated | Level: high | ID: 855de5af-503f-52f5-b45c-aba2d696e216

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
