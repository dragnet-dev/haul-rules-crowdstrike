// Dragnet [Ransomware]: dragnet-ransomware-2025-2916 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: e78f3247-9fd4-51ff-85b7-8cd5a5ffd443

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
