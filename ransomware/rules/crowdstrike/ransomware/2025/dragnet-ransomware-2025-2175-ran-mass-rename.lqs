// Dragnet [Ransomware]: dragnet-ransomware-2025-2175 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: cd43f869-003a-53f5-b6c7-06fcc777a465

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
