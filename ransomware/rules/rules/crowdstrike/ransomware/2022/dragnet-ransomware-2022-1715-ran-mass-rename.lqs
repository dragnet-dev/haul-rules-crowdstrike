// Dragnet [Ransomware]: dragnet-ransomware-2022-1715 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 734093ae-d39e-533f-9c0c-d29b83938dce

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
