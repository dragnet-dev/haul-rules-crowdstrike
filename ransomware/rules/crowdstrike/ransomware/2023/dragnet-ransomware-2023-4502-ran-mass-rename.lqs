// Dragnet [Ransomware]: dragnet-ransomware-2023-4502 — Mass File Rename (snatch)
// Status: experimental | Level: high | ID: acc74568-d4eb-5deb-95cf-30a44789e17b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
