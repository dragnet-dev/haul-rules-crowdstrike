// Dragnet [Ransomware]: dragnet-ransomware-2022-2058 — Mass File Rename (donutleaks)
// Status: deprecated | Level: high | ID: 453b8e67-ad57-5c25-b3ee-1e197712e408

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
