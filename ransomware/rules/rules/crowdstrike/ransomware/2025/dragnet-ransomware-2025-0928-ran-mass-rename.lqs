// Dragnet [Ransomware]: dragnet-ransomware-2025-0928 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 08ab1bd1-379e-5147-b682-776fba46c9de

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
