// Dragnet [Ransomware]: dragnet-ransomware-2025-2335 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: dcf12e33-3715-54a8-a408-0581ccb0885d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
