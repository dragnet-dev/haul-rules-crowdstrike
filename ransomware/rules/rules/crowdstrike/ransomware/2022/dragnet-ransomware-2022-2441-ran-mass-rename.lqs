// Dragnet [Ransomware]: dragnet-ransomware-2022-2441 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: f415e2c5-8695-5546-9291-ae4b6c66e937

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
