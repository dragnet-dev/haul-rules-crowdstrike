// Dragnet [Ransomware]: dragnet-ransomware-2025-6070 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 89695041-8f50-51b7-9d2e-487a373c1f76

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
