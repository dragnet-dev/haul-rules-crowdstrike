// Dragnet [Ransomware]: dragnet-ransomware-2025-3786 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 0cd7ce3f-ee94-5a7c-aa85-10939b4a878d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
