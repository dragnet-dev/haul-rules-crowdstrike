// Dragnet [Ransomware]: dragnet-ransomware-2023-0807 — Mass File Rename (play)
// Status: experimental | Level: high | ID: d2bad1cd-a236-5225-8a03-e0b43211e57e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
