// Dragnet [Ransomware]: dragnet-ransomware-2022-1761 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 0f4e7b56-2419-5bd4-94be-1b47ce3ab1ee

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
