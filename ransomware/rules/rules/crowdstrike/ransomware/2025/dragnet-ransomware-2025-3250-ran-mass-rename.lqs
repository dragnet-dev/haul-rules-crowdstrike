// Dragnet [Ransomware]: dragnet-ransomware-2025-3250 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: c46e4bbb-f6aa-5e1c-8436-e940921254ff

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
