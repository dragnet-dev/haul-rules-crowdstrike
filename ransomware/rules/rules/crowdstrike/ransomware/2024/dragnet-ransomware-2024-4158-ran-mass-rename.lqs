// Dragnet [Ransomware]: dragnet-ransomware-2024-4158 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 6aa77735-a449-5568-a41f-2000d9c64d10

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
