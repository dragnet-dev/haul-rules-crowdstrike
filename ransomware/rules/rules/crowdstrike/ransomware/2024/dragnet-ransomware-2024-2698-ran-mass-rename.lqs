// Dragnet [Ransomware]: dragnet-ransomware-2024-2698 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: 5a0b278c-a826-59f9-8c9a-25079d86faa2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
