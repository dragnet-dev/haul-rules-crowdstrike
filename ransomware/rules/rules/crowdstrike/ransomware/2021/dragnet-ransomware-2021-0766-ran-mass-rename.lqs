// Dragnet [Ransomware]: dragnet-ransomware-2021-0766 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: fc04f7d7-bec9-50c1-ae7f-efe965180011

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
