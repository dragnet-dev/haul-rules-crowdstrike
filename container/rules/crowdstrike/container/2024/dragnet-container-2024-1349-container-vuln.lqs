// Dragnet [Container]: dragnet-container-2024-1349 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: faef4ede-0efe-51b3-bb72-d06c4dac9c6b

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:8* OR ImageFileName = *debian:9* OR ImageFileName = *ubuntu:18.04-ESM* OR ImageFileName = *ubuntu:20.04* OR ImageFileName = *ubuntu:20.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
