// Dragnet [Ransomware]: dragnet-ransomware-2025-5818 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 76b73d0f-641a-5658-80fe-ca320ea98f46

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
