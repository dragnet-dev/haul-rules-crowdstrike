// Dragnet [Ransomware]: dragnet-ransomware-2025-1833 — Mass File Rename (cicada3301)
// Status: experimental | Level: high | ID: 7a599d2d-6673-548a-a79d-36bd2e8522ca

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
