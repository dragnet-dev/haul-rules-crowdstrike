// Dragnet [Ransomware]: dragnet-ransomware-2026-2848 — Mass File Rename (genesis)
// Status: stable | Level: high | ID: ac24a7c7-31c9-5bc9-bc92-ebb9006ec10a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
