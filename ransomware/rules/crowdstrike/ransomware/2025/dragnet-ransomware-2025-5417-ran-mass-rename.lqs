// Dragnet [Ransomware]: dragnet-ransomware-2025-5417 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: bf26f245-8eab-54d7-94d8-35b7e61009f9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
