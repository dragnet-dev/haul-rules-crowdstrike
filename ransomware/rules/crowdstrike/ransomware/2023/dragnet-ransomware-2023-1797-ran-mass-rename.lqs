// Dragnet [Ransomware]: dragnet-ransomware-2023-1797 — Mass File Rename (rhysida)
// Status: deprecated | Level: high | ID: 253d8615-10a7-570d-9189-18ef3c78cc64

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
