// Dragnet [Ransomware]: dragnet-ransomware-2025-0003 — Mass File Rename (fog)
// Status: deprecated | Level: high | ID: 8f29c3b4-60ec-50a7-be10-b8a104a1e3cd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
