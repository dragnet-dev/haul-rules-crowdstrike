// Dragnet [Ransomware]: dragnet-ransomware-2024-0350 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: bc14002e-5d66-5f34-8e77-ed210c53b3eb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
