// Dragnet [Ransomware]: dragnet-ransomware-2023-1401 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 87d78daf-553a-5100-9743-a00e524f550b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
