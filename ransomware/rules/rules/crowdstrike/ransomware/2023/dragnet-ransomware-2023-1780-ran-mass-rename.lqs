// Dragnet [Ransomware]: dragnet-ransomware-2023-1780 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: f0a0ff3a-abef-5e18-8120-73bbb0cd828c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
