// Dragnet [Ransomware]: dragnet-ransomware-2024-2397 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: c7b77e1a-7f50-5c5f-891d-86eaebd6df1e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
