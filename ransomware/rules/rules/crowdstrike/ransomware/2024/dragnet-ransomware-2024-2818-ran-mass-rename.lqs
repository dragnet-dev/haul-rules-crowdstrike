// Dragnet [Ransomware]: dragnet-ransomware-2024-2818 — Mass File Rename (ransomhouse)
// Status: experimental | Level: high | ID: 1c2bb8d1-6e6b-555c-9cbb-7d1dcc5868ee

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
