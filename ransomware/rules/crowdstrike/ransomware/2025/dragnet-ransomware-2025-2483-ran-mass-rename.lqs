// Dragnet [Ransomware]: dragnet-ransomware-2025-2483 — Mass File Rename (thegentlemen)
// Status: experimental | Level: high | ID: 0c833d26-379e-5aca-a234-8713d7602068

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
