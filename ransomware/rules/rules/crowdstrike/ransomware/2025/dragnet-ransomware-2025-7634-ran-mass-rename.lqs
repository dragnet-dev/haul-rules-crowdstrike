// Dragnet [Ransomware]: dragnet-ransomware-2025-7634 — Mass File Rename (alphalocker)
// Status: experimental | Level: high | ID: df7febda-dd98-572f-b478-bf8a46f6bd3c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
