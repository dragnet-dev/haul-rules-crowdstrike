// Dragnet [Ransomware]: dragnet-ransomware-2023-2714 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: cc9ca96c-13cd-52ef-af4c-506a88787556

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
