// Dragnet [Ransomware]: dragnet-ransomware-2022-2448 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 62eb441c-c78c-5841-b6ca-3e3c0e816c6b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
