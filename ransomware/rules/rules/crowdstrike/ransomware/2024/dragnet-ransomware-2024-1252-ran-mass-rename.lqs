// Dragnet [Ransomware]: dragnet-ransomware-2024-1252 — Mass File Rename (dragonforce)
// Status: deprecated | Level: high | ID: 92dc9226-edf9-557a-8bdf-5be21afd384a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
