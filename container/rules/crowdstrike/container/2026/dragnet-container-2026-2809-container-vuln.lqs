// Dragnet [Container]: dragnet-container-2026-2809 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 3667549e-70af-547e-8699-4b4de1e57c51

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
