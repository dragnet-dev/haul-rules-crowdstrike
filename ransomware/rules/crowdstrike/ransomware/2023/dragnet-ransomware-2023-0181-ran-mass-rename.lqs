// Dragnet [Ransomware]: dragnet-ransomware-2023-0181 — Mass File Rename (royal)
// Status: deprecated | Level: high | ID: f8ab83fe-a121-5354-8535-ed99d1398473

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
