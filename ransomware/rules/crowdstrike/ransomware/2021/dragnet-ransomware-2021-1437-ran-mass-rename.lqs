// Dragnet [Ransomware]: dragnet-ransomware-2021-1437 — Mass File Rename (revil)
// Status: deprecated | Level: high | ID: ba1da322-99c3-5c04-bebe-e1f749a02a9f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
