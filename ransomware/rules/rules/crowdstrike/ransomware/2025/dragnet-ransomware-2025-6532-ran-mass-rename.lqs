// Dragnet [Ransomware]: dragnet-ransomware-2025-6532 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 9490f2d2-66e4-5f3a-9839-57fdcf9b1a5b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
