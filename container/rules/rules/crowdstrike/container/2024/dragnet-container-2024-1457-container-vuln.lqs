// Dragnet [Container]: dragnet-container-2024-1457 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: c8152ad3-880c-510e-ba7f-d5b44e7e331d

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:8*)
| table([timestamp, ComputerName])
| limit(1000)
