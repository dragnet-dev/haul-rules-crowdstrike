// Dragnet [Ransomware]: dragnet-ransomware-2021-1796 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: d251b454-08e4-571a-a759-ead6d4082896

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
