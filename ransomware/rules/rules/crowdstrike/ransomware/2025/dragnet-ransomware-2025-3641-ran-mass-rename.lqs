// Dragnet [Ransomware]: dragnet-ransomware-2025-3641 — Mass File Rename (devman)
// Status: experimental | Level: high | ID: 4028c4a4-aafd-5b7e-83c2-f10f0196b1c6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
