// Dragnet [Ransomware]: dragnet-ransomware-2025-3256 — Mass File Rename (flocker)
// Status: experimental | Level: high | ID: f7e86db0-7c68-5b6f-b7ee-24a978adc4b6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
