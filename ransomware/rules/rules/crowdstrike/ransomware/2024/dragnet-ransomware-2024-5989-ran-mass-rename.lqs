// Dragnet [Ransomware]: dragnet-ransomware-2024-5989 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: e2a692d5-90e7-57ea-bce6-a388254ca0ea

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
