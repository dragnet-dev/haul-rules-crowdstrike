// Dragnet [Container]: dragnet-container-2024-1142 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: d02495b1-418d-5e94-a4bb-622f3c7164b7

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:8* OR ImageFileName = *debian:9*)
| table([timestamp, ComputerName])
| limit(1000)
