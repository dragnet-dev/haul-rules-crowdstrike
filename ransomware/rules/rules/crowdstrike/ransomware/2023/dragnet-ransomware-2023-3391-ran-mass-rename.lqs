// Dragnet [Ransomware]: dragnet-ransomware-2023-3391 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 4e22ac97-3d8e-5a45-baf5-4217792a429d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
