// Dragnet [Ransomware]: dragnet-ransomware-2025-1486 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 156b792e-7ab3-5fc4-9e11-779e3378c4b2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
