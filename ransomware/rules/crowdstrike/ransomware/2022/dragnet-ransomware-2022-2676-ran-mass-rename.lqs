// Dragnet [Ransomware]: dragnet-ransomware-2022-2676 — Mass File Rename (cuba)
// Status: deprecated | Level: high | ID: c7f87e17-2a3b-57d5-af41-f0124d1b1374

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
