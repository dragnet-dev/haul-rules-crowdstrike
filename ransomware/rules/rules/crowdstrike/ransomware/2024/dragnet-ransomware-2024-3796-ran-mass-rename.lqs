// Dragnet [Ransomware]: dragnet-ransomware-2024-3796 — Mass File Rename (cloak)
// Status: deprecated | Level: high | ID: 26e5efc4-f94c-51bc-9228-07a1e929b87b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
