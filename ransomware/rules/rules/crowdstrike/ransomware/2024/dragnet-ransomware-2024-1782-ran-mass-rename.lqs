// Dragnet [Ransomware]: dragnet-ransomware-2024-1782 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 2c2f02f5-74c9-5bd6-888d-f00f8bed0dec

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
