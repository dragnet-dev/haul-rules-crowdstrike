// Dragnet [Ransomware]: dragnet-ransomware-2024-4404 — Mass File Rename (raworld)
// Status: experimental | Level: high | ID: 1c9542fb-3ecc-5299-919f-b7b3ca0b7511

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
