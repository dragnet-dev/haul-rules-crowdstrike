// Dragnet [Container]: dragnet-container-2024-1086 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 13c90f49-2591-512b-8da4-30caddc1ce0a

#event_simpleName=*
| (ImageFileName = *alpine:3.10* OR ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:8* OR ImageFileName = *debian:9* OR ImageFileName = *ubuntu:18.04* OR ImageFileName = *ubuntu:18.04-ESM* OR ImageFileName = *ubuntu:19.04*)
| table([timestamp, ComputerName])
| limit(1000)
