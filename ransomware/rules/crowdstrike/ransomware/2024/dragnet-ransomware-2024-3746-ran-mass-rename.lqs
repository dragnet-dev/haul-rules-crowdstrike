// Dragnet [Ransomware]: dragnet-ransomware-2024-3746 — Mass File Rename (arcusmedia)
// Status: experimental | Level: high | ID: a1614de5-256c-52cb-93c7-4ec125929552

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
