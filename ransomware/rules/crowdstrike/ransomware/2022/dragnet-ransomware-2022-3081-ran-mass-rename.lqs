// Dragnet [Ransomware]: dragnet-ransomware-2022-3081 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 8307464e-5715-505e-b072-9d5bb3c60356

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
