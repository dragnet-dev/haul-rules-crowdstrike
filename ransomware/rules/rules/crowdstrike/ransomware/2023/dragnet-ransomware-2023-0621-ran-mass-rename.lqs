// Dragnet [Ransomware]: dragnet-ransomware-2023-0621 — Mass File Rename (ransomhouse)
// Status: experimental | Level: high | ID: b9368c90-9120-5e57-93fa-71862d2a77f4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
