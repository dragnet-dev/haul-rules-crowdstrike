// Dragnet [Ransomware]: dragnet-ransomware-2022-2497 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 495f9fb0-37b6-5642-97a7-702080055ed4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
