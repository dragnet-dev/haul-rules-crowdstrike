// Dragnet [Ransomware]: dragnet-ransomware-2021-0104 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 41b52a24-8552-5d03-a095-1334036aeaa4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
