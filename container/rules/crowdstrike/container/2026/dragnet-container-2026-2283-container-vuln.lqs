// Dragnet [Container]: dragnet-container-2026-2283 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 650f8771-de0e-5286-9564-ab7364b9215d

#event_simpleName=*
| (ImageFileName = *debian:7* OR ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10* OR ImageFileName = *ubuntu:13.04*)
| table([timestamp, ComputerName])
| limit(1000)
