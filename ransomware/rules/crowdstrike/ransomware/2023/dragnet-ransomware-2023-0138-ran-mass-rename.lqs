// Dragnet [Ransomware]: dragnet-ransomware-2023-0138 — Mass File Rename (monti)
// Status: experimental | Level: high | ID: 1a4a8e12-8631-59b4-91f2-44d56dcff95b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
