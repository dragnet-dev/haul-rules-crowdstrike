// Dragnet [Ransomware]: dragnet-ransomware-2022-1849 — Mass File Rename (quantum)
// Status: deprecated | Level: high | ID: 6025292f-b35f-53f5-91c1-592678cba88b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
