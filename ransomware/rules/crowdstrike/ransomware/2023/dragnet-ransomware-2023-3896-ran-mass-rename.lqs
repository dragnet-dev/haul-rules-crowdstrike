// Dragnet [Ransomware]: dragnet-ransomware-2023-3896 — Mass File Rename (noescape)
// Status: experimental | Level: high | ID: 9d39b4b4-3418-5291-8f07-1d322b34d2f2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
