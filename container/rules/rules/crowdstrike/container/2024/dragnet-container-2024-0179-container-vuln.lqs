// Dragnet [Container]: dragnet-container-2024-0179 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 92b347c0-e5a8-5335-9b10-caba32af58f9

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:7* OR ImageFileName = *ubuntu:16.04-ESM* OR ImageFileName = *ubuntu:18.04* OR ImageFileName = *ubuntu:18.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
