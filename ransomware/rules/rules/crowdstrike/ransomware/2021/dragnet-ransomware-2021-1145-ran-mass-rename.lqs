// Dragnet [Ransomware]: dragnet-ransomware-2021-1145 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: dfa5c492-b078-5c0c-9400-134dea272c4f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
