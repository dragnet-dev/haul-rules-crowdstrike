// Dragnet [Ransomware]: dragnet-ransomware-2023-4621 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 329c767e-667f-5882-b307-011b024b8cb7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
