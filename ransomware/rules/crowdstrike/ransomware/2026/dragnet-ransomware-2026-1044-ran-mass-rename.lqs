// Dragnet [Ransomware]: dragnet-ransomware-2026-1044 — Mass File Rename (thegentlemen)
// Status: stable | Level: high | ID: 251f11d2-f1ba-5487-91e4-07e885de9dfe

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
