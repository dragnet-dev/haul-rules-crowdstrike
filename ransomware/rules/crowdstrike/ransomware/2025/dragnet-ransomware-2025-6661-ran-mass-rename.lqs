// Dragnet [Ransomware]: dragnet-ransomware-2025-6661 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 04e4d064-6a61-517f-bd93-1a9fd60e74ae

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
