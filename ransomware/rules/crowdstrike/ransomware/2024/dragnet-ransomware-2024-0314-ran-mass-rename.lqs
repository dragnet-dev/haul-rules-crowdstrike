// Dragnet [Ransomware]: dragnet-ransomware-2024-0314 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: fb6d1fdf-b4b2-57f9-b7c7-dcf52dbedaf4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
