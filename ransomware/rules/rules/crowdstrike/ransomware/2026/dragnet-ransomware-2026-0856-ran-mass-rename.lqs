// Dragnet [Ransomware]: dragnet-ransomware-2026-0856 — Mass File Rename (nitrogen)
// Status: test | Level: high | ID: 21517fb0-2066-53d0-9afc-0fa07dc92a0b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
