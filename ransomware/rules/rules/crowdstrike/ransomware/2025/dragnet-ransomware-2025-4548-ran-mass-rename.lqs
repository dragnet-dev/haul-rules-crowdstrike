// Dragnet [Ransomware]: dragnet-ransomware-2025-4548 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 8a074b6e-d7be-5b27-8bc1-6c31ce4c43ab

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
