// Dragnet [Ransomware]: dragnet-ransomware-2025-6183 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: c5e82293-ee0f-5fc6-ab62-4db24593409e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
