// Dragnet [Ransomware]: dragnet-ransomware-2025-3818 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 6c4faa5d-6416-5cac-87d6-f71807ccefbc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
