// Dragnet [Ransomware]: dragnet-ransomware-2022-0195 — Mass File Rename (avoslocker)
// Status: deprecated | Level: high | ID: 868b70da-ce18-5e4d-9bff-520ef160f925

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
