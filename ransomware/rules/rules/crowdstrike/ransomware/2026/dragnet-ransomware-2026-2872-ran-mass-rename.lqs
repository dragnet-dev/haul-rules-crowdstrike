// Dragnet [Ransomware]: dragnet-ransomware-2026-2872 — Mass File Rename (dragonforce)
// Status: test | Level: high | ID: 241aba2d-7977-56ce-84d7-d15acd497e64

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
