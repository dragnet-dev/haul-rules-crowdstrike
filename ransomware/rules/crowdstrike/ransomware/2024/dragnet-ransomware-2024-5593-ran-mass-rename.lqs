// Dragnet [Ransomware]: dragnet-ransomware-2024-5593 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: a4093b6b-c433-5b6a-a2e0-a3dd992127e5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
