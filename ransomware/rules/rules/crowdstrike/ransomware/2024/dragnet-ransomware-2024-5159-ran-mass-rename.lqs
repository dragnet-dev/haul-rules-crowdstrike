// Dragnet [Ransomware]: dragnet-ransomware-2024-5159 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 9d412753-b737-5f25-98a0-f892d493bd40

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
