// Dragnet [Ransomware]: dragnet-ransomware-2022-0514 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: e70f3a8d-84d6-531d-8c89-f35df8ce8911

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
