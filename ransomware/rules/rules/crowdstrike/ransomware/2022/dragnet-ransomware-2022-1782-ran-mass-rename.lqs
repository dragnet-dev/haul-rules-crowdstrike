// Dragnet [Ransomware]: dragnet-ransomware-2022-1782 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: f7f24073-909e-56a9-907b-88ae6373d071

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
