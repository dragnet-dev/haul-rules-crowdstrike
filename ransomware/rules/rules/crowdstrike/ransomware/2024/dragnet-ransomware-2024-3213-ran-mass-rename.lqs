// Dragnet [Ransomware]: dragnet-ransomware-2024-3213 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 3df61193-df8c-5945-ad87-9aaa70ca8950

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
