// Dragnet [Ransomware]: dragnet-ransomware-2024-1006 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 8bdf8ab9-dd4a-5d9b-aae4-3d85ae263ce5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
