// Dragnet [Container]: dragnet-container-2024-1039 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: dc3cad91-54a0-545a-8837-7849d7bd3c93

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:8* OR ImageFileName = *debian:9*)
| table([timestamp, ComputerName])
| limit(1000)
