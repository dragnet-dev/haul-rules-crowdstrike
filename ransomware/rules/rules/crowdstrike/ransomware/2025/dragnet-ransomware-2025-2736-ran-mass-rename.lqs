// Dragnet [Ransomware]: dragnet-ransomware-2025-2736 — Mass File Rename (nightspire)
// Status: deprecated | Level: high | ID: ee878ae4-53f0-54eb-ace3-2d822b1bc97a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
