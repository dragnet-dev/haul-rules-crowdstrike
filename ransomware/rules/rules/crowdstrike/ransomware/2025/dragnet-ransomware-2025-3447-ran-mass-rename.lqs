// Dragnet [Ransomware]: dragnet-ransomware-2025-3447 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 7d932e0d-19cb-5da4-80ed-e430157aa62a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
