// Dragnet [Ransomware]: dragnet-ransomware-2025-7455 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: 9ac852e2-75b2-5722-bc8c-f5224bf9d1fe

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
