// Dragnet [Ransomware]: dragnet-ransomware-2025-2556 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 82949bba-317b-530f-b118-827d35e94cfd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
