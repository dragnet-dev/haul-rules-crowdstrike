// Dragnet [Ransomware]: dragnet-ransomware-2023-3761 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: cfa5b5fe-6479-5f2a-87b7-66559974a41e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
