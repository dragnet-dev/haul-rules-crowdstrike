// Dragnet [Ransomware]: dragnet-ransomware-2023-5201 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: 7e741eba-a933-5247-a0f7-51d13bb91f56

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
