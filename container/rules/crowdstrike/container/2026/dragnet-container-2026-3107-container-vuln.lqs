// Dragnet [Container]: dragnet-container-2026-3107 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 49f5dd5e-a591-5bf0-ba28-57c1e4afa3c1

#event_simpleName=*
| (ImageFileName = *amazonlinux:1* OR ImageFileName = *chainguard:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *oraclelinux:7* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
