// Dragnet [Ransomware]: dragnet-ransomware-2024-3526 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 82387087-796d-5c89-8df8-e756f387fef6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
