// Dragnet [Ransomware]: dragnet-ransomware-2025-6380 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: cff61c04-708f-5f20-81a0-37c7b6b911c3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
