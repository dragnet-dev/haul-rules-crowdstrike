// Dragnet [Container]: dragnet-container-2026-1539 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 6a152713-40eb-5faf-b65f-b0d0b90364eb

#event_simpleName=*
| (ImageFileName = *chainguard:* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
