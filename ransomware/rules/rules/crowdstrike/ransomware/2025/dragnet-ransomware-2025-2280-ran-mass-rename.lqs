// Dragnet [Ransomware]: dragnet-ransomware-2025-2280 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: 2fa994b2-ed4d-58d0-825c-b13d625e02e5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
