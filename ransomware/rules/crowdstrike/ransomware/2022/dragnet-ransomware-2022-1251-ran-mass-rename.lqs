// Dragnet [Ransomware]: dragnet-ransomware-2022-1251 — Mass File Rename (medusalocker)
// Status: deprecated | Level: high | ID: 4d3fe19a-aef6-55f8-adf6-87a28be09c06

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
