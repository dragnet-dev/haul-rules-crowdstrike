// Dragnet [Ransomware]: dragnet-ransomware-2024-5175 — Mass File Rename (play)
// Status: experimental | Level: high | ID: d9d6f90b-41b1-50f4-a522-becd13319b85

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
