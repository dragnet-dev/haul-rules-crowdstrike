// Dragnet [Ransomware]: dragnet-ransomware-2024-2688 — Mass File Rename (monti)
// Status: experimental | Level: high | ID: 9f1f049d-e9ba-53f6-8aee-a62d303290fa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
