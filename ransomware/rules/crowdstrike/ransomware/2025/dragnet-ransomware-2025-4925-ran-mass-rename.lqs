// Dragnet [Ransomware]: dragnet-ransomware-2025-4925 — Mass File Rename (IMNCrew)
// Status: experimental | Level: high | ID: 653baf7f-2f01-53aa-a33d-82b158347288

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
