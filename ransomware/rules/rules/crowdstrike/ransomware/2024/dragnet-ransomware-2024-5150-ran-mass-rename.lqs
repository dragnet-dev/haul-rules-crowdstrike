// Dragnet [Ransomware]: dragnet-ransomware-2024-5150 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 4a4cc717-1fc3-5a87-9a89-4288d64b0f35

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
