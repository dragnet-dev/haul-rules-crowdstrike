// Dragnet [Ransomware]: dragnet-ransomware-2025-6504 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: fa7d813a-bd41-5fb0-b222-1885d20a1773

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
