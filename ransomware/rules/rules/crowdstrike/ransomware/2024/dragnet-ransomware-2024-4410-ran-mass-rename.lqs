// Dragnet [Ransomware]: dragnet-ransomware-2024-4410 — Mass File Rename (raworld)
// Status: experimental | Level: high | ID: 7ac23e2f-db04-56cf-88f4-b33f97751eef

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
