// Dragnet [Ransomware]: dragnet-ransomware-2026-1351 — Mass File Rename (lockbit5)
// Status: stable | Level: high | ID: ade6ebe0-50a8-5e9f-b709-61aa96401012

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
