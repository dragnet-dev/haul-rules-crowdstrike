// Dragnet [Ransomware]: dragnet-ransomware-2021-1722 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 5aef6717-edd8-5144-8591-84da1e61b4b7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
