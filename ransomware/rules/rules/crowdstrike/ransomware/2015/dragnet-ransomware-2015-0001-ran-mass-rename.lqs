// Dragnet [Ransomware]: dragnet-ransomware-2015-0001 — Mass File Rename (AiLock)
// Status: deprecated | Level: high | ID: 80319903-673d-5704-b566-7ce542a7527a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
