// Dragnet [Ransomware]: dragnet-ransomware-2021-1192 — Mass File Rename (avaddon)
// Status: deprecated | Level: high | ID: 8469e314-b9f5-5118-9bb1-cf31ee9e6e28

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
