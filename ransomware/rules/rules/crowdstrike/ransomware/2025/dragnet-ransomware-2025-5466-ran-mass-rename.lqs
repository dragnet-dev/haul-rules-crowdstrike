// Dragnet [Ransomware]: dragnet-ransomware-2025-5466 — Mass File Rename (interlock)
// Status: experimental | Level: high | ID: ebee2a68-0fcc-52c9-ab36-b383790ff17d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
