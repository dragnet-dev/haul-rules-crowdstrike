// Dragnet [Ransomware]: dragnet-ransomware-2021-1038 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 1ef1c57e-6afe-542b-a8b7-abf5c4166b6e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
