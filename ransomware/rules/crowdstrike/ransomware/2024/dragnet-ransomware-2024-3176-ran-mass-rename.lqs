// Dragnet [Ransomware]: dragnet-ransomware-2024-3176 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: f5c4f261-80a3-5826-bc74-6e28cec7a25b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
