// Dragnet [Ransomware]: dragnet-ransomware-2022-1611 — Mass File Rename (everest)
// Status: deprecated | Level: high | ID: 50117e7c-c093-5a62-bfe2-dbb2b615d2da

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
