// Dragnet [Ransomware]: dragnet-ransomware-2024-0370 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: 547bd690-30f2-582f-addf-0027408fd44e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
