// Dragnet [Ransomware]: dragnet-ransomware-2023-4419 — Mass File Rename (cactus)
// Status: deprecated | Level: high | ID: fb4ad9bd-fcb0-5b9d-850e-d1af01ba10a3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
