// Dragnet [Ransomware]: dragnet-ransomware-2023-2643 — Mass File Rename (metaencryptor)
// Status: experimental | Level: high | ID: ff10e12f-eaa7-5c59-8b12-3cb4b1ac9b30

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
