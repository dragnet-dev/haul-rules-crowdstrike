// Dragnet [Ransomware]: dragnet-ransomware-2024-4727 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 1a7c7b03-ae53-54ff-91e8-52bfb424214e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
