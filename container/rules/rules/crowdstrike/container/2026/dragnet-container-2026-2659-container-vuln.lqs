// Dragnet [Container]: dragnet-container-2026-2659 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 724780dc-9fc2-5689-be05-60cc7cefa68c

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6*)
| table([timestamp, ComputerName])
| limit(1000)
