// Dragnet [Ransomware]: dragnet-ransomware-2025-6702 — Mass File Rename (arkana)
// Status: experimental | Level: high | ID: 148f7da0-d21b-5fa0-aecb-cba21b19c5b1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
