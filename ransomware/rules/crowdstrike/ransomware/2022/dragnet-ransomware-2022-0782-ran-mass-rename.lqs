// Dragnet [Ransomware]: dragnet-ransomware-2022-0782 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 017acdc3-bf19-5179-88bc-ee5a18758754

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
