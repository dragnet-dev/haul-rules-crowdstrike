// Dragnet [Ransomware]: dragnet-ransomware-2024-3284 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 73691ea1-f371-5c55-b8a3-1071bcf67570

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
