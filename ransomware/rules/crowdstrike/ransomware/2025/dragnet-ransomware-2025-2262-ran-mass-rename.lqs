// Dragnet [Ransomware]: dragnet-ransomware-2025-2262 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: e981695d-86e1-55b9-8599-44f7a13d7268

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
