// Dragnet [Ransomware]: dragnet-ransomware-2025-3579 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 6b1de51c-d1f1-5253-ab11-e1fc674b0d9c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
