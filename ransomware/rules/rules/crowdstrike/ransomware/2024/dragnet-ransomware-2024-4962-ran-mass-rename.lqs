// Dragnet [Ransomware]: dragnet-ransomware-2024-4962 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 6e746873-21f7-5412-9cbb-68a8f92a8d9d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
