// Dragnet [Ransomware]: dragnet-ransomware-2024-0664 — Mass File Rename (blackout)
// Status: experimental | Level: high | ID: abced355-0d4e-541c-8487-65cd4bd41e14

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
