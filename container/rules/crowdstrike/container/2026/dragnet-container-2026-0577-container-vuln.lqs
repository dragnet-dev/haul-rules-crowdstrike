// Dragnet [Container]: dragnet-container-2026-0577 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: db9c7734-8677-5e58-b7cc-554c1af7a889

#event_simpleName=*
| (ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10* OR ImageFileName = *ubuntu:13.04* OR ImageFileName = *ubuntu:13.10*)
| table([timestamp, ComputerName])
| limit(1000)
