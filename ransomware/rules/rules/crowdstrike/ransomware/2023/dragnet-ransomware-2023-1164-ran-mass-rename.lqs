// Dragnet [Ransomware]: dragnet-ransomware-2023-1164 — Mass File Rename (play)
// Status: experimental | Level: high | ID: a86f6358-fc8e-594b-bdcf-30ed51ed9647

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
