// Dragnet [Ransomware]: dragnet-ransomware-2025-6545 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 6f492f6f-18dc-5480-830d-ddcd1a63ef4b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
