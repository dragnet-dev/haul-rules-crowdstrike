// Dragnet [Ransomware]: dragnet-ransomware-2021-1654 — Mass File Rename (sabbath)
// Status: deprecated | Level: high | ID: 94bf067a-f994-5b46-9ca3-d4d641bfac9e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
