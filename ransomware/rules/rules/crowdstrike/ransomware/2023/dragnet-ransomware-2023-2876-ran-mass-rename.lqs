// Dragnet [Ransomware]: dragnet-ransomware-2023-2876 — Mass File Rename (malas)
// Status: experimental | Level: high | ID: 6826b4d3-7e8e-5c10-b171-9c5122fc2e51

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
