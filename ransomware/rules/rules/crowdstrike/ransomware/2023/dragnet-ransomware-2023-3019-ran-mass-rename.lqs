// Dragnet [Ransomware]: dragnet-ransomware-2023-3019 — Mass File Rename (qilin)
// Status: deprecated | Level: high | ID: 504db1b3-ca40-5f74-b677-9605001317ea

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
