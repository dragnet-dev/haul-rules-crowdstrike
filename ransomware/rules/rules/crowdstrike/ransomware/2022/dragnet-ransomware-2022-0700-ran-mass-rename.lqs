// Dragnet [Ransomware]: dragnet-ransomware-2022-0700 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: d5ca010f-af24-5e2b-bb77-c908f59d78c1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
