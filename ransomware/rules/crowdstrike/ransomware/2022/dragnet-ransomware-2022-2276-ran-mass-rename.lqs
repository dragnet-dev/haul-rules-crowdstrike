// Dragnet [Ransomware]: dragnet-ransomware-2022-2276 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 8a830caf-d898-5033-890b-5ee190baba0d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
