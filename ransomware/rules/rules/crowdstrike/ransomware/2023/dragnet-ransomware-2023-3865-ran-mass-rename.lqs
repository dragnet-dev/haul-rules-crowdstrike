// Dragnet [Ransomware]: dragnet-ransomware-2023-3865 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 7f4595db-3831-51ff-9a0c-17cf5a69f924

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
