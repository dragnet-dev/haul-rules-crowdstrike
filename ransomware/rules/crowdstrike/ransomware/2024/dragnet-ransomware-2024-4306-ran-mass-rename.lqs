// Dragnet [Ransomware]: dragnet-ransomware-2024-4306 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 8317e23c-459c-5923-bf45-e028609a8f7f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
