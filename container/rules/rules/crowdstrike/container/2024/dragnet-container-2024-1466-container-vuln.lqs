// Dragnet [Container]: dragnet-container-2024-1466 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 6d066394-cb8f-5976-bbe1-5b5e41a4f14c

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
