// Dragnet [Ransomware]: dragnet-ransomware-2023-1050 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 3add1f4d-b211-5bbb-8b53-93a8cba6c5e2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
