// Dragnet [Ransomware]: dragnet-ransomware-2024-0549 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 85f0486b-dfab-528c-9c32-6a767be91054

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
