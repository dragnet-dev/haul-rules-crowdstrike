// Dragnet [Ransomware]: dragnet-ransomware-2023-1977 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: d13f0ec1-d4e4-5565-9389-04987378e491

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
