// Dragnet [Ransomware]: dragnet-ransomware-2025-4248 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 61095064-a999-593e-947a-4cc3213e9474

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
