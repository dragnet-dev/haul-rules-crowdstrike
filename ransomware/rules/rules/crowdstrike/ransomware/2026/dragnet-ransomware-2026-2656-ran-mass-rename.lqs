// Dragnet [Ransomware]: dragnet-ransomware-2026-2656 — Mass File Rename (killsec)
// Status: deprecated | Level: high | ID: bf11d35e-1cf5-53d9-8303-749986f5cdd1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
