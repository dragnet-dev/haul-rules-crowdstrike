// Dragnet [Ransomware]: dragnet-ransomware-2025-2741 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: a7812e25-6856-5e9e-b51f-c02af9b2372b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
