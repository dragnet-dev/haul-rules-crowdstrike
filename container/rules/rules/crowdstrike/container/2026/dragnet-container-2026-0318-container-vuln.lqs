// Dragnet [Container]: dragnet-container-2026-0318 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: c36c64ee-6a44-5ad8-bdd2-39af5eb2b030

#event_simpleName=*
| (ImageFileName = *almalinux:10* OR ImageFileName = *almalinux:8* OR ImageFileName = *almalinux:9* OR ImageFileName = *alpine:3.23* OR ImageFileName = *alpine edge:* OR ImageFileName = *amazonlinux:2* OR ImageFileName = *amazonlinux:2023* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:8* OR ImageFileName = *oraclelinux:9*)
| table([timestamp, ComputerName])
| limit(1000)
