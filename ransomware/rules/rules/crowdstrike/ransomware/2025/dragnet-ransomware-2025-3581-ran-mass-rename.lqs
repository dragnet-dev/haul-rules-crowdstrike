// Dragnet [Ransomware]: dragnet-ransomware-2025-3581 — Mass File Rename (underground)
// Status: experimental | Level: high | ID: 6004ae78-6c4c-53d8-88b7-e5c70fafc1de

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
