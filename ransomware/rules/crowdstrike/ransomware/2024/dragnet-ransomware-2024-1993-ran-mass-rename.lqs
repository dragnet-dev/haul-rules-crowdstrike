// Dragnet [Ransomware]: dragnet-ransomware-2024-1993 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: ca4f4f52-e6fc-59d3-8b83-a9fde14dbeb2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
