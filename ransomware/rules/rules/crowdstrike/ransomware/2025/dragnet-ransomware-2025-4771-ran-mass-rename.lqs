// Dragnet [Ransomware]: dragnet-ransomware-2025-4771 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: b9d6cd13-3372-571f-a017-181d91524929

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
