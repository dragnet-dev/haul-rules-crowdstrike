// Dragnet [Ransomware]: dragnet-ransomware-2025-1396 — Mass File Rename (nightspire)
// Status: deprecated | Level: high | ID: 5b00ae53-a46e-58f4-b7ed-472550f47329

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
