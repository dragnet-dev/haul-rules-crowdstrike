// Dragnet [Ransomware]: dragnet-ransomware-2025-7376 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 605daef7-3d21-5904-82ef-09cd98e8e948

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
