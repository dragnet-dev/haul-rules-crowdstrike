// Dragnet [Container]: dragnet-container-2026-2484 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 154a68dd-29b3-527b-9cb9-75ae1ff726c2

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:7* OR ImageFileName = *debian:8* OR ImageFileName = *debian:9*)
| table([timestamp, ComputerName])
| limit(1000)
