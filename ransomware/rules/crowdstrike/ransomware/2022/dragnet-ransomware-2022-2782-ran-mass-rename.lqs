// Dragnet [Ransomware]: dragnet-ransomware-2022-2782 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: f3c2ee11-028d-560a-a2cb-2e594007e1c9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
