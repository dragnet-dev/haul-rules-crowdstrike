// Dragnet [Ransomware]: dragnet-ransomware-2025-0001 — Mass File Rename (coinbasecartel)
// Status: experimental | Level: high | ID: 10a517cc-26e6-5ebe-a71a-a1053fba1029

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
