// Dragnet [Ransomware]: dragnet-ransomware-2022-2894 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 701f009b-e4be-5008-adef-b28f85bec4e5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
