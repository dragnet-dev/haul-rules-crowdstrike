// Dragnet [Ransomware]: dragnet-ransomware-2025-4471 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: dad68b14-c2e8-53e9-903e-86ff46cc0a87

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
