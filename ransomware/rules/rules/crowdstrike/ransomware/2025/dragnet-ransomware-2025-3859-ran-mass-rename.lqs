// Dragnet [Ransomware]: dragnet-ransomware-2025-3859 — Mass File Rename (interlock)
// Status: test | Level: high | ID: d4e91cfa-01ad-5737-bc53-66c769f138c7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
