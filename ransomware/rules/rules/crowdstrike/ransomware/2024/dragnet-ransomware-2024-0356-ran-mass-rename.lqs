// Dragnet [Ransomware]: dragnet-ransomware-2024-0356 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 15cc1682-e8e9-5f3e-b191-55b5e499b166

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
