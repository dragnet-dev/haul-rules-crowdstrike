// Dragnet [Ransomware]: dragnet-ransomware-2025-3258 — Mass File Rename (play)
// Status: experimental | Level: high | ID: bc5b4b86-b7cb-591b-9b2a-dac548c967a6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
