// Dragnet [Ransomware]: dragnet-ransomware-2024-4726 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: 32516203-adf1-5eda-a926-d83c0fd76703

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
