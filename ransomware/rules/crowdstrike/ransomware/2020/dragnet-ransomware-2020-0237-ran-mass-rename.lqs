// Dragnet [Ransomware]: dragnet-ransomware-2020-0237 — Mass File Rename (maze)
// Status: deprecated | Level: high | ID: c5744fb0-1374-5cf7-a2f4-02a6bb9c8eb7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
