// Dragnet [Ransomware]: dragnet-ransomware-2023-5337 — Mass File Rename (stormous)
// Status: experimental | Level: high | ID: 9cb03a3c-8820-5f37-9e2d-32ba9ed771d6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
