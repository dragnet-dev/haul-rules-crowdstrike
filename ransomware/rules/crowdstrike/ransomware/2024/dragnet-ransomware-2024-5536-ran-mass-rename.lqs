// Dragnet [Ransomware]: dragnet-ransomware-2024-5536 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 280fa95f-44ad-5c05-97fa-ac4895985ff4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
