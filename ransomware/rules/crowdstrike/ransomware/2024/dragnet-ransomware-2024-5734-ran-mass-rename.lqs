// Dragnet [Ransomware]: dragnet-ransomware-2024-5734 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: a0eb2342-8c0c-5aec-936e-4f9a0b83a9cd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
