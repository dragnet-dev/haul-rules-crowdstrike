// Dragnet [Ransomware]: dragnet-ransomware-2022-1391 — Mass File Rename (cheers)
// Status: deprecated | Level: high | ID: d01d9fbe-b17f-5358-90d8-1d554c99c445

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
