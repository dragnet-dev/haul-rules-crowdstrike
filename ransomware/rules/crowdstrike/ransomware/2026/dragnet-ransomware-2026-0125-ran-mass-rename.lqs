// Dragnet [Ransomware]: dragnet-ransomware-2026-0125 — Mass File Rename (krybit)
// Status: stable | Level: high | ID: 56843cbb-72a9-510c-bb99-24b1aba743cf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
