// Dragnet [Ransomware]: dragnet-ransomware-2021-0966 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 7803518e-86ba-547d-aa1f-1c01da131636

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
