// Dragnet [Ransomware]: dragnet-ransomware-2025-5100 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 4cbbcca5-e708-55c2-8859-290cfef5244b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
