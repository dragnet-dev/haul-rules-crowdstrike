// Dragnet [Ransomware]: dragnet-ransomware-2024-0100 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 3df15ab8-a3df-587a-80ad-ac3b55f348f6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
