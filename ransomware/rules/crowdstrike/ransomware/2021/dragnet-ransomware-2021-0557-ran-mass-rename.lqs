// Dragnet [Ransomware]: dragnet-ransomware-2021-0557 — Mass File Rename (revil)
// Status: deprecated | Level: high | ID: 229541c7-a281-53e3-8330-d21722cbaa50

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
