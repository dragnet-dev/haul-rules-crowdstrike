// Dragnet [Ransomware]: dragnet-ransomware-2022-2746 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: e8fa87e4-2ceb-590c-8df4-081fadc8a975

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
