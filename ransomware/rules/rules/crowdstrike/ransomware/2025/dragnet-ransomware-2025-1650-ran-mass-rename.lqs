// Dragnet [Ransomware]: dragnet-ransomware-2025-1650 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 1d1b903e-b475-5b51-bc07-cce6da42b264

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
