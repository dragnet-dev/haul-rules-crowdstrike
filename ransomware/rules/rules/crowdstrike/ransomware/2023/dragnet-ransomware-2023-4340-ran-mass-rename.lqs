// Dragnet [Ransomware]: dragnet-ransomware-2023-4340 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 8014f951-f3e1-58e1-bfa0-66771e371614

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
