// Dragnet [Ransomware]: dragnet-ransomware-2023-1915 — Mass File Rename (ransomhouse)
// Status: deprecated | Level: high | ID: b7ae47aa-3de6-554f-b362-df97cb534edc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
