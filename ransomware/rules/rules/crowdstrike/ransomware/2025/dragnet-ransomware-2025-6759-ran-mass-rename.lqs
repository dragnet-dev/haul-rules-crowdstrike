// Dragnet [Ransomware]: dragnet-ransomware-2025-6759 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: ed3eda79-dfea-559c-b99f-3bae284df9da

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
