// Dragnet [Ransomware]: dragnet-ransomware-2023-2591 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 39e9a78d-9be2-512d-90ea-819d426a25b9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
