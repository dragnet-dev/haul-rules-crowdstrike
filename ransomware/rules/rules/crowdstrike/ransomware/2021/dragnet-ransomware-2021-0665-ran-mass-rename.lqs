// Dragnet [Ransomware]: dragnet-ransomware-2021-0665 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: d20e7126-7ea7-50c3-8b6f-e90a39bbe5a7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
