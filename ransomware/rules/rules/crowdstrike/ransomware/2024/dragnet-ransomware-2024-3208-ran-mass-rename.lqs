// Dragnet [Ransomware]: dragnet-ransomware-2024-3208 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: 06fdaf76-25b0-54f8-99b0-b755b5256818

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
