// Dragnet [Ransomware]: dragnet-ransomware-2021-1543 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 3f7c82cf-472c-5229-833d-a8794e721a24

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
