// Dragnet [Ransomware]: dragnet-ransomware-2023-2404 — Mass File Rename (trigona)
// Status: experimental | Level: high | ID: a335228d-06da-5771-9fd3-db43a138efc3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
