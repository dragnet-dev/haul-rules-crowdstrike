// Dragnet [Ransomware]: dragnet-ransomware-2024-1157 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 961b3725-9233-500a-b4da-aa5f0d62398f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
