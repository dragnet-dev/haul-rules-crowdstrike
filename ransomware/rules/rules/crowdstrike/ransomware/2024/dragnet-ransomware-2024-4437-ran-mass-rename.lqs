// Dragnet [Ransomware]: dragnet-ransomware-2024-4437 — Mass File Rename (spacebears)
// Status: experimental | Level: high | ID: b45fe625-2449-5c81-ae22-2aa2b83b5f30

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
