// Dragnet [Ransomware]: dragnet-ransomware-2023-4927 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 717bc65e-cddf-5c52-bcd1-634b845a3456

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
