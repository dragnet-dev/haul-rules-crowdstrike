// Dragnet [Ransomware]: dragnet-ransomware-2025-7099 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: e4b1f2a0-0f39-571a-8eb5-b9b308987f99

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
