// Dragnet [Ransomware]: dragnet-ransomware-2025-5878 — Mass File Rename (silent)
// Status: experimental | Level: high | ID: 414d172f-bd7c-57c0-992b-7f9841a4d7aa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
