// Dragnet [Ransomware]: dragnet-ransomware-2024-4163 — Mass File Rename (safepay)
// Status: deprecated | Level: high | ID: cd50b0de-02e9-5bac-8389-fc87c04c2407

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
