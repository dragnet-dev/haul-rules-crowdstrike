// Dragnet [Ransomware]: dragnet-ransomware-2023-1934 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: aa1213b3-2af2-5382-9c70-73b231c39c99

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
