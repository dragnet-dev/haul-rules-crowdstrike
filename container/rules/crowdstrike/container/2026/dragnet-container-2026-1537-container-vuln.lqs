// Dragnet [Container]: dragnet-container-2026-1537 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 9e9693f0-9d15-593c-8b91-5fbc5e6fa66d

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:5*)
| table([timestamp, ComputerName])
| limit(1000)
