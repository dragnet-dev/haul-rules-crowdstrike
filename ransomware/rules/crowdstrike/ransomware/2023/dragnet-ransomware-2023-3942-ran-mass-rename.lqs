// Dragnet [Ransomware]: dragnet-ransomware-2023-3942 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 6166e7ac-32c2-514a-bc93-7a121a08ed77

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
