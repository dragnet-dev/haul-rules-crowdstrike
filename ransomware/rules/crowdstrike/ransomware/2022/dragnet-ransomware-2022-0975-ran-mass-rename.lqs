// Dragnet [Ransomware]: dragnet-ransomware-2022-0975 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 0d683b38-8395-57e4-b76a-e7215220b3dd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
