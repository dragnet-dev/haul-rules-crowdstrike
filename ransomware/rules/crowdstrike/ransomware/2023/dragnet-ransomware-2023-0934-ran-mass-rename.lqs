// Dragnet [Ransomware]: dragnet-ransomware-2023-0934 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 9ccda1b3-e170-5a14-9f3c-018c2321f891

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
