// Dragnet [Ransomware]: dragnet-ransomware-2022-0698 — Mass File Rename (avoslocker)
// Status: deprecated | Level: high | ID: ae2ee8aa-0cfc-517e-bc4b-69cf745b762d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
