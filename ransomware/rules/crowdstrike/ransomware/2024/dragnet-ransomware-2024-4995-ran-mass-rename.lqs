// Dragnet [Ransomware]: dragnet-ransomware-2024-4995 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 282979d9-1720-58af-b228-e98aa5365f41

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
