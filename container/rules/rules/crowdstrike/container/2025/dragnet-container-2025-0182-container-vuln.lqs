// Dragnet [Container]: dragnet-container-2025-0182 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 64411d85-5d06-5f55-b533-69470bc4078e

#event_simpleName=*
| (ImageFileName = *amazonlinux:2* OR ImageFileName = *azure linux:3.0* OR ImageFileName = *cbl-mariner:2.0* OR ImageFileName = *photon os:3.0* OR ImageFileName = *photon os:4.0* OR ImageFileName = *photon os:5.0* OR ImageFileName = *ubuntu:16.04-ESM* OR ImageFileName = *ubuntu:18.04-ESM* OR ImageFileName = *ubuntu:20.04-ESM* OR ImageFileName = *ubuntu:22.04*)
| table([timestamp, ComputerName])
| limit(1000)
