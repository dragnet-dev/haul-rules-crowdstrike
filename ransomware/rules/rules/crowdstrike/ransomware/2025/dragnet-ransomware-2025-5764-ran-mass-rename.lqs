// Dragnet [Ransomware]: dragnet-ransomware-2025-5764 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 6f1e7d2c-9fd5-5a50-a59a-49c3c48ccf04

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
