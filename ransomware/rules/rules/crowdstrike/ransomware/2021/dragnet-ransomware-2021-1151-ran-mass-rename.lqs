// Dragnet [Ransomware]: dragnet-ransomware-2021-1151 — Mass File Rename (everest)
// Status: deprecated | Level: high | ID: 306c9117-fc7d-5f27-b47b-280dabcf8915

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
