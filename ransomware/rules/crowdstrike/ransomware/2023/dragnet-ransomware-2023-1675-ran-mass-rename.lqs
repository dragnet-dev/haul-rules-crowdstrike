// Dragnet [Ransomware]: dragnet-ransomware-2023-1675 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: b7a851ce-622a-5837-8929-29f9b7eabaae

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
