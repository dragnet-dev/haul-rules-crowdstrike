// Dragnet [Ransomware]: dragnet-ransomware-2024-2958 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 086dec6b-748f-5a3c-8087-3025382836d0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
