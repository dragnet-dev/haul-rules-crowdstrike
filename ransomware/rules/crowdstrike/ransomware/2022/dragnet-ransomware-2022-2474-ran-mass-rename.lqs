// Dragnet [Ransomware]: dragnet-ransomware-2022-2474 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: d8354541-8bda-51a7-b32c-9a7d85281230

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
