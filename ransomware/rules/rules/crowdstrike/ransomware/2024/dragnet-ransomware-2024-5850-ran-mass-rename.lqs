// Dragnet [Ransomware]: dragnet-ransomware-2024-5850 — Mass File Rename (play)
// Status: experimental | Level: high | ID: a6332a32-4813-50d4-8921-045332f50be9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
