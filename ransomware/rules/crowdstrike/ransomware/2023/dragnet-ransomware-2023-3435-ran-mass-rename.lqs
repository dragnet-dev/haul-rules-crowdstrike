// Dragnet [Ransomware]: dragnet-ransomware-2023-3435 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 5ce57e75-4098-59eb-9a14-a0dff9489a30

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
