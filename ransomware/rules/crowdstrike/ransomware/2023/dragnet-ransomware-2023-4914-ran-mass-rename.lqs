// Dragnet [Ransomware]: dragnet-ransomware-2023-4914 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: cfe29b3b-b257-5e73-9c1a-ccd3c6d03e83

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
