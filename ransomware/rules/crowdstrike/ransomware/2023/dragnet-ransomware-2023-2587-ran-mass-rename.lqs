// Dragnet [Ransomware]: dragnet-ransomware-2023-2587 — Mass File Rename (rhysida)
// Status: deprecated | Level: high | ID: 255a1b82-b9b7-5e80-b8d3-0df20fa5d6e2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
