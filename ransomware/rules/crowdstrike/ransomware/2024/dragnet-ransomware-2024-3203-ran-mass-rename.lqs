// Dragnet [Ransomware]: dragnet-ransomware-2024-3203 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 9f946c01-0dbd-563b-854f-344d082bff29

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
