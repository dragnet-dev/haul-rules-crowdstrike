// Dragnet [Ransomware]: dragnet-ransomware-2025-1218 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 50df0faf-8a4d-5668-9973-ebcd90dc2c82

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
