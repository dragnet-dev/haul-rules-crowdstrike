// Dragnet [Ransomware]: dragnet-ransomware-2024-2858 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 21b3aa64-1e13-54f9-843e-52716619ffa2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
