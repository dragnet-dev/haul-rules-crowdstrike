// Dragnet [Ransomware]: dragnet-ransomware-2024-0905 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: e8e46f79-91f5-5c5f-b91b-7e09b99a4ddd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
