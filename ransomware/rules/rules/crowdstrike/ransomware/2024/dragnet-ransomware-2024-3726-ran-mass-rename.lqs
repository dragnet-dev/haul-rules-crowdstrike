// Dragnet [Ransomware]: dragnet-ransomware-2024-3726 — Mass File Rename (arcusmedia)
// Status: experimental | Level: high | ID: 9cf31a0b-5368-5d27-b778-bcc19bbfdfdc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
