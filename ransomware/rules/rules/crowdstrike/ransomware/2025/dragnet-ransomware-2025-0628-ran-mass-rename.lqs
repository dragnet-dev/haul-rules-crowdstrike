// Dragnet [Ransomware]: dragnet-ransomware-2025-0628 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 0a2ebcf7-f926-56aa-a73e-73aaaf68ee94

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
