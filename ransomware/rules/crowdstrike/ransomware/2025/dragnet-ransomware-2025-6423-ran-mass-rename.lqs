// Dragnet [Ransomware]: dragnet-ransomware-2025-6423 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: 0f015bec-5875-51a0-8e1a-5698f3e41e50

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
