// Dragnet [Ransomware]: dragnet-ransomware-2024-3961 — Mass File Rename (BrainCipher)
// Status: experimental | Level: high | ID: e2c8832f-82f7-5008-a25b-48d77a637239

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
