// Dragnet [Ransomware]: dragnet-ransomware-2024-5808 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 4b890904-22f2-5ca1-9317-bbc85975bc79

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
