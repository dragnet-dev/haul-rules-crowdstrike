// Dragnet [Ransomware]: dragnet-ransomware-2023-3099 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: c7e65b47-7336-586f-8c07-1d56f557cb9d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
