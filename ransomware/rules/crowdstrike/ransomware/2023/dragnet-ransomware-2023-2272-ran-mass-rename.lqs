// Dragnet [Ransomware]: dragnet-ransomware-2023-2272 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 33477952-6a8b-53ce-9689-fbd4c52c20a0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
