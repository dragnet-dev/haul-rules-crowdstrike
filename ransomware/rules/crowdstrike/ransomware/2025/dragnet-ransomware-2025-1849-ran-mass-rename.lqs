// Dragnet [Ransomware]: dragnet-ransomware-2025-1849 — Mass File Rename (brotherhood)
// Status: experimental | Level: high | ID: bcbc8a7f-cc16-5c77-bbf5-4389e5c461a8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
