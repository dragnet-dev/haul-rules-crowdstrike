// Dragnet [Ransomware]: dragnet-ransomware-2024-0461 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 8fbdce6b-8862-56b4-9bb8-5bc886655355

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
