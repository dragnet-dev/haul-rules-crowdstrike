// Dragnet [Ransomware]: dragnet-ransomware-2024-0578 — Mass File Rename (cicada3301)
// Status: experimental | Level: high | ID: d38e2e8c-cc11-570b-ac93-9d2e28bb091f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
