// Dragnet [Ransomware]: dragnet-ransomware-2025-7895 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 03c522d4-a659-53aa-a3fa-33c1a3266062

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
