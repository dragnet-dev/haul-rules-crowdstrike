// Dragnet [Ransomware]: dragnet-ransomware-2025-7428 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 72b308fa-352e-5f12-9688-1a4b3ab39e22

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
