// Dragnet [Ransomware]: dragnet-ransomware-2024-0217 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: a9646a74-1d4e-5726-a189-c2726aeae39c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
