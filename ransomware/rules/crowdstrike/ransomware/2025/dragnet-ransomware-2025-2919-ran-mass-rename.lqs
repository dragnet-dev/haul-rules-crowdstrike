// Dragnet [Ransomware]: dragnet-ransomware-2025-2919 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: ac3c048e-5b0c-58ed-a96d-fc6d41bf5ecc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
