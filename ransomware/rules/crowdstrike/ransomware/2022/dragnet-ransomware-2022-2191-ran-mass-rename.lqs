// Dragnet [Ransomware]: dragnet-ransomware-2022-2191 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: bcb43260-382c-5e46-97d5-620a30356314

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
