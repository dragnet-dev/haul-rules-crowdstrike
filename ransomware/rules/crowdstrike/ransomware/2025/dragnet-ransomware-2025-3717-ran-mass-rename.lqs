// Dragnet [Ransomware]: dragnet-ransomware-2025-3717 — Mass File Rename (crypto24)
// Status: deprecated | Level: high | ID: 38789c44-5420-522f-b36d-812e4e14bb58

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
