// Dragnet [Ransomware]: dragnet-ransomware-2026-1652 — Mass File Rename (SilentRansomGroup)
// Status: deprecated | Level: high | ID: 23a1f404-73b3-5c4d-a426-10df267915c0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
