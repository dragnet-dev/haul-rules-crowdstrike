// Dragnet [Ransomware]: dragnet-ransomware-2023-3029 — Mass File Rename (snatch)
// Status: experimental | Level: high | ID: f8538130-4f26-5a40-898d-123f26d4859f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
