// Dragnet [Ransomware]: dragnet-ransomware-2026-0172 — Mass File Rename (ransomhouse)
// Status: stable | Level: high | ID: 1d0d6f83-a4e8-57ca-b98b-ef9ebfd7fbda

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
