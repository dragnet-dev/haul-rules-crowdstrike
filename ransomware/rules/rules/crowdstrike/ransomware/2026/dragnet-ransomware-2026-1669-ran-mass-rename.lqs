// Dragnet [Ransomware]: dragnet-ransomware-2026-1669 — Mass File Rename (nightspire)
// Status: deprecated | Level: high | ID: 1be844ab-aaa0-525a-bf16-8d23bd67c4d8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
