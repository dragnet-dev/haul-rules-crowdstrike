// Dragnet [Ransomware]: dragnet-ransomware-2025-3349 — Mass File Rename (rebornvc)
// Status: deprecated | Level: high | ID: c3ec3f82-9d62-5da4-a16d-a5290ae3d1fb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
