// Dragnet [Ransomware]: dragnet-ransomware-2023-4995 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 49e0fc38-3d2e-5f0c-bae8-eab2062b975b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
