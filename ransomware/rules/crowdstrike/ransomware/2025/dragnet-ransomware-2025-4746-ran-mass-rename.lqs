// Dragnet [Ransomware]: dragnet-ransomware-2025-4746 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 874b7d9a-c1b3-51d7-a3b6-27931314d9cc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
