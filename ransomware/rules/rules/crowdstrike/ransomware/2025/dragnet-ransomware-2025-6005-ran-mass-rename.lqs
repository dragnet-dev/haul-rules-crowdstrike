// Dragnet [Ransomware]: dragnet-ransomware-2025-6005 — Mass File Rename (rhysida)
// Status: experimental | Level: high | ID: df145fdb-6f95-5ff7-b414-d51784dea7a3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
