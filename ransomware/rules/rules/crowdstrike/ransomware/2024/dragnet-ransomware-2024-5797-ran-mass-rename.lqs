// Dragnet [Ransomware]: dragnet-ransomware-2024-5797 — Mass File Rename (helldown)
// Status: experimental | Level: high | ID: b58dce96-48e3-57ff-ad01-d81af1a2d56f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
