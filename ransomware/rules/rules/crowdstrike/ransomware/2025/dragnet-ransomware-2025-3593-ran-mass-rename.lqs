// Dragnet [Ransomware]: dragnet-ransomware-2025-3593 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 0a6e388d-12cb-58c4-a49c-21876b9bc3a7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
