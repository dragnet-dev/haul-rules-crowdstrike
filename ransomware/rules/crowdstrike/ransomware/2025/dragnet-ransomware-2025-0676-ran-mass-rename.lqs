// Dragnet [Ransomware]: dragnet-ransomware-2025-0676 — Mass File Rename (nitrogen)
// Status: experimental | Level: high | ID: e86a7e48-c84e-5ce7-af6e-628cfce0c5ec

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
