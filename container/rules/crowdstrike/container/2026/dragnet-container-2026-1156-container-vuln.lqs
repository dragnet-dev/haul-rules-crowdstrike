// Dragnet [Container]: dragnet-container-2026-1156 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 7717235f-7d64-56ea-ad40-989835acab8f

#event_simpleName=*
| (ImageFileName = *chainguard:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
