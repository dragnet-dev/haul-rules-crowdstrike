// Dragnet [Ransomware]: dragnet-ransomware-2023-1999 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 71280e86-acca-55ef-ac1f-cddd23b52878

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
