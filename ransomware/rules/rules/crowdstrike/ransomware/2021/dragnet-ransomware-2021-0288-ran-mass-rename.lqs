// Dragnet [Ransomware]: dragnet-ransomware-2021-0288 — Mass File Rename (spook)
// Status: deprecated | Level: high | ID: 5a75e121-6516-535c-bded-524591b615df

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
