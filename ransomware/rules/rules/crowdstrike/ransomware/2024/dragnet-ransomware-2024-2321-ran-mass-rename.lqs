// Dragnet [Ransomware]: dragnet-ransomware-2024-2321 — Mass File Rename (dragonforce)
// Status: deprecated | Level: high | ID: 944458d7-cca1-5d3e-9a19-31088845696e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
