// Dragnet [Ransomware]: dragnet-ransomware-2024-4297 — Mass File Rename (dragonransomware)
// Status: experimental | Level: high | ID: f85fc730-6466-504e-bfd0-6e7575c5617c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
