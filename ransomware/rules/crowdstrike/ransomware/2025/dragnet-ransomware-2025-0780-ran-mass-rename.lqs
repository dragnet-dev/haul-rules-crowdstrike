// Dragnet [Ransomware]: dragnet-ransomware-2025-0780 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 5535c7cf-b015-5f50-ad12-7fcd27efd655

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
