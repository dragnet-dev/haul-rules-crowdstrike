// Dragnet [Ransomware]: dragnet-ransomware-2026-2718 — Mass File Rename (incransom)
// Status: test | Level: high | ID: 9225a7d6-41a5-5e70-bd10-2929a4a85e57

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
