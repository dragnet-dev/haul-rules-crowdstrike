// Dragnet [Ransomware]: dragnet-ransomware-2022-2735 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: 6ef6684a-531c-5b3d-ac92-fc74e60a116f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
