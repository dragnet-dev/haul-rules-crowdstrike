// Dragnet [Ransomware]: dragnet-ransomware-2023-0635 — Mass File Rename (werewolves)
// Status: experimental | Level: high | ID: aa386b6e-547c-5f0a-a60d-d3c10085ff0d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
