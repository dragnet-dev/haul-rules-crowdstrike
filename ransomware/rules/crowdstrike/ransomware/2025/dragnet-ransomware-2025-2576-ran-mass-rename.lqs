// Dragnet [Ransomware]: dragnet-ransomware-2025-2576 — Mass File Rename (arcusmedia)
// Status: experimental | Level: high | ID: 41928a62-581c-5dff-bc91-9a2956f2b0a4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
