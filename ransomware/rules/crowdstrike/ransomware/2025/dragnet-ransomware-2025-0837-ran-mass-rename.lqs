// Dragnet [Ransomware]: dragnet-ransomware-2025-0837 — Mass File Rename (J)
// Status: experimental | Level: high | ID: 53e606e8-f993-591f-a805-8eb67d0858f3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
