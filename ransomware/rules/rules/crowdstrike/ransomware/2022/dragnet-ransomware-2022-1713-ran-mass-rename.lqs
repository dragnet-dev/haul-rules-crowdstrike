// Dragnet [Ransomware]: dragnet-ransomware-2022-1713 — Mass File Rename (suncrypt)
// Status: deprecated | Level: high | ID: 3f3d88aa-a4ee-5c67-906f-ad92c88c4178

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
