// Dragnet [Container]: dragnet-container-2026-2199 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: daa2b1b3-5f48-55e7-9a0c-8ad29b9d9739

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:5*)
| table([timestamp, ComputerName])
| limit(1000)
