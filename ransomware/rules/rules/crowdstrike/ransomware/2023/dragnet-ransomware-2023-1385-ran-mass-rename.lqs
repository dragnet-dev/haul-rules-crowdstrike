// Dragnet [Ransomware]: dragnet-ransomware-2023-1385 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: d5934e3f-68aa-5171-a878-26056736d232

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
