// Dragnet [Ransomware]: dragnet-ransomware-2025-3161 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: c9832a9f-833c-512a-8afc-587fb2b90ff6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
