// Dragnet [Ransomware]: dragnet-ransomware-2021-1501 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: e78fa98d-b4b9-5292-93f2-5b98cdfcc514

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
