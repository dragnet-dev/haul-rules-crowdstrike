// Dragnet [Ransomware]: dragnet-ransomware-2021-1526 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 49e8295c-b359-527a-882b-03ca271e0438

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
