// Dragnet [Ransomware]: dragnet-ransomware-2023-2210 — Mass File Rename (royal)
// Status: deprecated | Level: high | ID: 4b052e3a-7d43-5ac6-bc97-ba8e2fe44c98

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
