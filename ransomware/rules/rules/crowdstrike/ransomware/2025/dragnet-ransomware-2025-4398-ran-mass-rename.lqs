// Dragnet [Ransomware]: dragnet-ransomware-2025-4398 — Mass File Rename (payoutsking)
// Status: experimental | Level: high | ID: 7cdd8f58-1ac9-5e49-be5a-76d61053af92

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
