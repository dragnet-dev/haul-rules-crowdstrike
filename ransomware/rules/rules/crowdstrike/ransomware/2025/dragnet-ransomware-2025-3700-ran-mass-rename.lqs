// Dragnet [Ransomware]: dragnet-ransomware-2025-3700 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 6849a060-c6be-51dc-82b7-4b1aef7fcc4a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
