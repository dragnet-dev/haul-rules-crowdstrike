// Dragnet [Ransomware]: dragnet-ransomware-2026-1231 — Mass File Rename (incransom)
// Status: stable | Level: high | ID: 1dce5884-ced6-51fb-a001-e44d25b33ebd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
