// Dragnet [Ransomware]: dragnet-ransomware-2022-1935 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 0b15302d-7171-5d7d-948f-d727ce37608e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
