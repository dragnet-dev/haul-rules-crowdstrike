// Dragnet [Ransomware]: dragnet-ransomware-2024-4024 — Mass File Rename (dragonransomware)
// Status: experimental | Level: high | ID: c2b23bd7-bd3c-5dcd-9883-1b2fc9c5f486

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
