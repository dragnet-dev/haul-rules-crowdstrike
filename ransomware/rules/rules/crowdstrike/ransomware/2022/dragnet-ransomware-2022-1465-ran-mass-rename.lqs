// Dragnet [Ransomware]: dragnet-ransomware-2022-1465 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 8b315389-c068-5b51-ba78-208ff80603e0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
