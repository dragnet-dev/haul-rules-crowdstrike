// Dragnet [Ransomware]: dragnet-ransomware-2023-3347 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 24bb351e-2568-51c4-aa45-9ba6f27403f5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
