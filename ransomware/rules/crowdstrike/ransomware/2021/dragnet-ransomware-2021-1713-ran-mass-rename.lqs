// Dragnet [Ransomware]: dragnet-ransomware-2021-1713 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 280d9147-0a72-538c-a3ea-0f81a2034281

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
