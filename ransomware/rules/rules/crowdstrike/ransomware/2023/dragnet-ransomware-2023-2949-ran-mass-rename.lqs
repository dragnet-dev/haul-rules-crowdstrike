// Dragnet [Ransomware]: dragnet-ransomware-2023-2949 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 895ae2ed-d2ae-501d-90b2-d80d4e31668b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
