// Dragnet [Container]: dragnet-container-2026-0762 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: a0619250-3e3e-5b7a-8a67-6c52a6ca82bb

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:7* OR ImageFileName = *debian:8*)
| table([timestamp, ComputerName])
| limit(1000)
