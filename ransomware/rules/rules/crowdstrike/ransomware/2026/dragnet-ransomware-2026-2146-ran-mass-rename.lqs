// Dragnet [Ransomware]: dragnet-ransomware-2026-2146 — Mass File Rename (nightspire)
// Status: deprecated | Level: high | ID: 9b06a9c4-aec5-55cb-9c0e-0eaff0d65eb8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
