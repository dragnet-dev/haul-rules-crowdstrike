// Dragnet [Ransomware]: dragnet-ransomware-2023-2805 — Mass File Rename (malas)
// Status: experimental | Level: high | ID: 35da9329-bed0-58a7-8b8b-2f045c93a2c3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
