// Dragnet [Ransomware]: dragnet-ransomware-2024-2508 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 22096965-6e2e-586c-a5a5-3784bbd29401

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
