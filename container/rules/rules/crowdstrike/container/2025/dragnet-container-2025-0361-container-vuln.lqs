// Dragnet [Container]: dragnet-container-2025-0361 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 16557f20-cb32-55a8-a3f9-d0c525165fc3

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *redhat/ubi9:*)
| table([timestamp, ComputerName])
| limit(1000)
