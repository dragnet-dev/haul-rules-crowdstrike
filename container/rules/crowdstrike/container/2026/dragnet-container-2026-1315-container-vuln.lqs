// Dragnet [Container]: dragnet-container-2026-1315 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: b8adf9aa-66b8-50af-aeba-29e49709f3f2

#event_simpleName=*
| (ImageFileName = *debian:7* OR ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10* OR ImageFileName = *ubuntu:13.04*)
| table([timestamp, ComputerName])
| limit(1000)
