// Dragnet [Container]: dragnet-container-2026-1841 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: fd962f01-6b74-544a-9ae9-c9182fb4deec

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6*)
| table([timestamp, ComputerName])
| limit(1000)
