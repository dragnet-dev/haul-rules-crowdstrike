// Dragnet [Ransomware]: dragnet-ransomware-2025-5277 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 155b96bf-12df-5767-ad62-261a048eaa73

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
