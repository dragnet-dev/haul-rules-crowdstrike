// Dragnet [Ransomware]: dragnet-ransomware-2024-3215 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 73ed6cc3-c4f2-5bab-9848-d8a5def727e6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
