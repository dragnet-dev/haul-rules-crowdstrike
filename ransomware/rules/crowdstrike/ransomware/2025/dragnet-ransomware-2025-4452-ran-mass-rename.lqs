// Dragnet [Ransomware]: dragnet-ransomware-2025-4452 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: cbda5160-083c-51fa-bd7e-59548d6d2d9a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
