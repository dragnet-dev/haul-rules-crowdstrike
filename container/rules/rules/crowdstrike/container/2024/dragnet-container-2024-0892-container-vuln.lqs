// Dragnet [Container]: dragnet-container-2024-0892 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 32a8c37d-827e-5c4d-82ac-ee71c56e50ae

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:9*)
| table([timestamp, ComputerName])
| limit(1000)
