// Dragnet [Ransomware]: dragnet-ransomware-2022-0895 — Mass File Rename (alphv)
// Status: deprecated | Level: high | ID: c2d681c1-f1bb-5dd0-a295-98f2edb13c01

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
