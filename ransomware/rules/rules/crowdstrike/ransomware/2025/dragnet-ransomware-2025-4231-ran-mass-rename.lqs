// Dragnet [Ransomware]: dragnet-ransomware-2025-4231 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 3cbd394f-7973-5011-b21e-6af34b8913f9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
