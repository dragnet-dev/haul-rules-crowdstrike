// Dragnet [Ransomware]: dragnet-ransomware-2024-1649 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 9e84c225-774d-5964-8d67-2ea48feb9fa7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
