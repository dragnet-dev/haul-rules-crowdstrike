// Dragnet [Ransomware]: dragnet-ransomware-2025-3204 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: dd502671-2c36-5da5-b9c4-ee73faa30378

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
