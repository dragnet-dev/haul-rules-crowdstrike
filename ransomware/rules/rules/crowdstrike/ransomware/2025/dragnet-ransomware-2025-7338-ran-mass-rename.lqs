// Dragnet [Ransomware]: dragnet-ransomware-2025-7338 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 1f6b896b-fd1a-53ca-bbc9-1055ce0f3d62

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
