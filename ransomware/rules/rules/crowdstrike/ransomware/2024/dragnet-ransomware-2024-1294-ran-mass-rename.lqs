// Dragnet [Ransomware]: dragnet-ransomware-2024-1294 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: c7285057-5bc2-5ec5-a345-80f4c0c341b8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
