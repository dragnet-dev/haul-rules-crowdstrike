// Dragnet [Ransomware]: dragnet-ransomware-2025-4500 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: ab6ae470-79e3-52e8-b04a-adee3e1a4433

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
