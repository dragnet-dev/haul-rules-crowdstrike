// Dragnet [Ransomware]: dragnet-ransomware-2023-5267 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 06b8f08d-c364-5fe4-a0c3-5b33701472f2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
