// Dragnet [Ransomware]: dragnet-ransomware-2025-5783 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 025f7b59-f823-52a8-b1af-f3080b06dbff

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
