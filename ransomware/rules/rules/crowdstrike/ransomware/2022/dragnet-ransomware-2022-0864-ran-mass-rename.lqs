// Dragnet [Ransomware]: dragnet-ransomware-2022-0864 — Mass File Rename (sparta)
// Status: deprecated | Level: high | ID: 90db297b-52e1-5659-929a-9e59685e2f53

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
