// Dragnet [Ransomware]: dragnet-ransomware-2023-0725 — Mass File Rename (royal)
// Status: experimental | Level: high | ID: b294103a-336a-5526-b111-933d892c456a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
