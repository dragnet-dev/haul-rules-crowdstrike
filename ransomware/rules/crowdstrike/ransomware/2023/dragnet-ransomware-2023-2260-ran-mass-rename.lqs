// Dragnet [Ransomware]: dragnet-ransomware-2023-2260 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: fe7bf2fd-f79f-5fae-87d1-72e17940802c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
