// Dragnet [Ransomware]: dragnet-ransomware-2025-2602 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 2849e8db-2eee-59d5-8106-edd94def1c25

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
