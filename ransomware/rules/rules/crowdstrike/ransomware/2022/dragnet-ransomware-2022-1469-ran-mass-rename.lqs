// Dragnet [Ransomware]: dragnet-ransomware-2022-1469 — Mass File Rename (ragnarlocker)
// Status: experimental | Level: high | ID: 601632e1-ff3a-5ba0-a8f6-4f861edc595e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
