// Dragnet [Ransomware]: dragnet-ransomware-2024-0663 — Mass File Rename (dragonransomware)
// Status: experimental | Level: high | ID: b1d00d79-e647-5cd5-819e-c062a720d2e7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
