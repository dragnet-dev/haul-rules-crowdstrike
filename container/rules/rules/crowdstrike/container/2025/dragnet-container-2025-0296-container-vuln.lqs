// Dragnet [Container]: dragnet-container-2025-0296 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: b9c6e3fd-569d-57be-a2eb-43b6d4c10274

#event_simpleName=*
| (ImageFileName = *amazonlinux:1* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:8* OR ImageFileName = *debian:9* OR ImageFileName = *oraclelinux:7* OR ImageFileName = *ubuntu:14.04* OR ImageFileName = *ubuntu:16.04* OR ImageFileName = *ubuntu:16.04-ESM* OR ImageFileName = *ubuntu:17.10*)
| table([timestamp, ComputerName])
| limit(1000)
