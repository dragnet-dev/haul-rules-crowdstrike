// Dragnet [Ransomware]: dragnet-ransomware-2026-2088 — Mass File Rename (handala)
// Status: stable | Level: high | ID: bbb6b330-50aa-581f-9105-d788cea3fb3b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
