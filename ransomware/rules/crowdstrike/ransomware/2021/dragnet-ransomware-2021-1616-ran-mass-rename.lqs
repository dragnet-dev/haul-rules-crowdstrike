// Dragnet [Ransomware]: dragnet-ransomware-2021-1616 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 4ebd1957-f35a-5a3b-a7e5-c091b55364a1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
