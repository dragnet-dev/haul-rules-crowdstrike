// Dragnet [Ransomware]: dragnet-ransomware-2025-5703 — Mass File Rename (apt73)
// Status: experimental | Level: high | ID: 08ef580d-776d-578b-bf9e-cb6340ae3498

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
