// Dragnet [Ransomware]: dragnet-ransomware-2024-6012 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 2ca9f024-13f6-5858-9450-309f19d15389

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
