// Dragnet [Ransomware]: dragnet-ransomware-2021-0435 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 91d3e9fe-4af9-5da2-a63e-24d94cdabc79

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
