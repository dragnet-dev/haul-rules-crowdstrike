// Dragnet [Ransomware]: dragnet-ransomware-2023-5138 — Mass File Rename (noescape)
// Status: experimental | Level: high | ID: a7827b9c-52cf-5daa-849f-b3dce231522a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
