// Dragnet [Ransomware]: dragnet-ransomware-2025-5154 — Mass File Rename (warlock)
// Status: deprecated | Level: high | ID: fb6148d6-ec13-53cc-89a9-d0a0e87d6780

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
