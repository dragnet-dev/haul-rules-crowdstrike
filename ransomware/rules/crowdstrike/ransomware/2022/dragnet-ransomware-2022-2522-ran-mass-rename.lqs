// Dragnet [Ransomware]: dragnet-ransomware-2022-2522 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: f221021e-d41b-5336-af55-5dd1836444ae

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
