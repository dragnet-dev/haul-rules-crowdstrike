// Dragnet [Ransomware]: dragnet-ransomware-2023-1046 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 660c0746-ddd8-5d48-9452-47f371e75ea5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
