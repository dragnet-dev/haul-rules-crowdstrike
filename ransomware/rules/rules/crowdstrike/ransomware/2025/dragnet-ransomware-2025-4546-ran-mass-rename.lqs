// Dragnet [Ransomware]: dragnet-ransomware-2025-4546 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 73377e9c-988f-50c6-8ef0-def377e02a8d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
