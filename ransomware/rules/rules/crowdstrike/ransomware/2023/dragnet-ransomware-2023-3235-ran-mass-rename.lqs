// Dragnet [Ransomware]: dragnet-ransomware-2023-3235 — Mass File Rename (play)
// Status: experimental | Level: high | ID: ab7012e8-08dc-57a9-ab18-ee16bf241ac2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
