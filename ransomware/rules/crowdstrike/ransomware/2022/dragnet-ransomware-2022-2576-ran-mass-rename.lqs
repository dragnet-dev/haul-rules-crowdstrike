// Dragnet [Ransomware]: dragnet-ransomware-2022-2576 — Mass File Rename (quantum)
// Status: deprecated | Level: high | ID: b92b043c-a854-5015-b577-b198cd5e3196

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
