// Dragnet [Ransomware]: dragnet-ransomware-2024-3988 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 180fdf2b-ecf0-5a94-8195-d0ce14e88d44

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
