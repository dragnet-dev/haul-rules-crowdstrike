// Dragnet [Container]: dragnet-container-2026-1711 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: ba5d0190-7ad3-5966-8402-edb6cc84f124

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
