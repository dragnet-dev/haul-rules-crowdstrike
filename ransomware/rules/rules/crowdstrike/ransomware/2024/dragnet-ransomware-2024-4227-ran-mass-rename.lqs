// Dragnet [Ransomware]: dragnet-ransomware-2024-4227 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 4dce50e9-c3ff-5d71-85b6-e3e224abaf88

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
