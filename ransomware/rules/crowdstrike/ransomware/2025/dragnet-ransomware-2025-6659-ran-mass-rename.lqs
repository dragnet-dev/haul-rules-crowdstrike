// Dragnet [Ransomware]: dragnet-ransomware-2025-6659 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: c16a3f6f-6dab-53e8-904f-bbb37fc533d7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
