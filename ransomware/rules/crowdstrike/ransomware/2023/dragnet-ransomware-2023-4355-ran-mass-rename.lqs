// Dragnet [Ransomware]: dragnet-ransomware-2023-4355 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 9c4c4e95-65ec-50ac-9de0-81c336d59f33

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
