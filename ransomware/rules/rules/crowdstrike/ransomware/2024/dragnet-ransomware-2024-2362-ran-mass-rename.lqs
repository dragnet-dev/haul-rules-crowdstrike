// Dragnet [Ransomware]: dragnet-ransomware-2024-2362 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 65a83c7b-76ea-5b24-84d1-241d3d212a3d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
