// Dragnet [Ransomware]: dragnet-ransomware-2025-2488 — Mass File Rename (thegentlemen)
// Status: experimental | Level: high | ID: c561681d-4685-55ca-a753-8068244a5f83

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
