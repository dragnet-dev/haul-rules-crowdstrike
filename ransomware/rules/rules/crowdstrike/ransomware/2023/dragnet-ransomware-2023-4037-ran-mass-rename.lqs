// Dragnet [Ransomware]: dragnet-ransomware-2023-4037 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: faba37d1-4bc4-5038-b827-8618dc0420fb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
