// Dragnet [Ransomware]: dragnet-ransomware-2022-1394 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 15e5f334-26b3-5394-a317-747de1017e68

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
