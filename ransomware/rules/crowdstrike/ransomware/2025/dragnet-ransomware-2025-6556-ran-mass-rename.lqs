// Dragnet [Ransomware]: dragnet-ransomware-2025-6556 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 1ce3b96d-7a51-5892-8781-69a9f7642eb8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
