// Dragnet [Ransomware]: dragnet-ransomware-2024-3482 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 8f15cdd5-a3b1-587f-9daa-900913fc903e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
