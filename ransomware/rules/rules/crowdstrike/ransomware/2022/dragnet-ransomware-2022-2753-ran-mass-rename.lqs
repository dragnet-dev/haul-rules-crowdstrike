// Dragnet [Ransomware]: dragnet-ransomware-2022-2753 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: d29e3537-e919-523d-abef-493301f04bf3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
