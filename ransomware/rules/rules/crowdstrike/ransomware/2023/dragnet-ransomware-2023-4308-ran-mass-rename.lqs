// Dragnet [Ransomware]: dragnet-ransomware-2023-4308 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 8973ad0f-f43d-560e-b851-a9be7d2ab35e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
