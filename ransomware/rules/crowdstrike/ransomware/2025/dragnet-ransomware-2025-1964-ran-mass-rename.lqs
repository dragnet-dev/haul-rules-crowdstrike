// Dragnet [Ransomware]: dragnet-ransomware-2025-1964 — Mass File Rename (global)
// Status: deprecated | Level: high | ID: 51b66c02-0925-526d-a9e1-254a41d22d79

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
