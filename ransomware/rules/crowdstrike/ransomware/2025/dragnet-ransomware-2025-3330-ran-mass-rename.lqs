// Dragnet [Ransomware]: dragnet-ransomware-2025-3330 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 2afb1f17-b145-5442-b659-8ef2e14fc133

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
