// Dragnet [Ransomware]: dragnet-ransomware-2023-1861 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: af25a760-6c68-5014-af4f-e93e7f7771d1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
