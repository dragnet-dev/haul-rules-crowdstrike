// Dragnet [Ransomware]: dragnet-ransomware-2024-3103 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: e571c96f-a63d-524b-b7a5-fd4b0c4db2ea

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
