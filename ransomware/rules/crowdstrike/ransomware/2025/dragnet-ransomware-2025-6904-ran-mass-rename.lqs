// Dragnet [Ransomware]: dragnet-ransomware-2025-6904 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: 9d22e8a9-fdf5-569f-8c69-3f79684ff462

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
