// Dragnet [Ransomware]: dragnet-ransomware-2023-2399 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 142aa3bf-7629-5d58-91e0-3d7274c77815

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
