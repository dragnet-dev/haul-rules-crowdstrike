// Dragnet [Ransomware]: dragnet-ransomware-2023-2672 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: d1d304aa-17af-551d-9f15-bdfbfa79c9c2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
