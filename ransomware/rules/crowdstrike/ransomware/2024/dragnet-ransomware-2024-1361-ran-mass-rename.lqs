// Dragnet [Ransomware]: dragnet-ransomware-2024-1361 — Mass File Rename (threeam)
// Status: experimental | Level: high | ID: 09ac1116-8052-5f2f-b5f3-071093311d26

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
