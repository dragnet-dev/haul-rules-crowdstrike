// Dragnet [Ransomware]: dragnet-ransomware-2025-1285 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: a92b6c50-6740-5ce6-b15e-0d678defce7e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
