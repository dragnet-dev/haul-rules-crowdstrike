// Dragnet [Ransomware]: dragnet-ransomware-2025-1776 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: b4ac6b6c-fb66-58c8-81c5-75d86d205497

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
