// Dragnet [Container]: dragnet-container-2025-0196 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: b5ae731e-295d-5c22-b77f-6c1ae84978da

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *ubuntu:24.04*)
| table([timestamp, ComputerName])
| limit(1000)
