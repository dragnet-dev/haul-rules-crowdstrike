// Dragnet [Ransomware]: dragnet-ransomware-2026-2204 — Mass File Rename (safepay)
// Status: stable | Level: high | ID: da9b6784-7e2e-5a2b-a17d-c3274904afe0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
