// Dragnet [Container]: dragnet-container-2024-1491 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 7aa32d03-b06d-5b94-90d5-91ff90b1eac8

#event_simpleName=*
| (ImageFileName = *almalinux:8* OR ImageFileName = *amazonlinux:1* OR ImageFileName = *amazonlinux:2* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:8* OR ImageFileName = *debian:9* OR ImageFileName = *oraclelinux:7* OR ImageFileName = *oraclelinux:8* OR ImageFileName = *photon os:1.0* OR ImageFileName = *photon os:2.0* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:16.04* OR ImageFileName = *ubuntu:16.04-ESM* OR ImageFileName = *ubuntu:18.04* OR ImageFileName = *ubuntu:18.04-ESM* OR ImageFileName = *ubuntu:18.10*)
| table([timestamp, ComputerName])
| limit(1000)
