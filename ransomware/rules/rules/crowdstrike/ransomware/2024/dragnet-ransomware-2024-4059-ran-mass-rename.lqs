// Dragnet [Ransomware]: dragnet-ransomware-2024-4059 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 6d12b4b9-e22a-5dc1-99f1-2fbae205a9be

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
