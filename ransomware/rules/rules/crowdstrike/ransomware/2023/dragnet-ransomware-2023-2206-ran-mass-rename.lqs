// Dragnet [Ransomware]: dragnet-ransomware-2023-2206 — Mass File Rename (toufan)
// Status: deprecated | Level: high | ID: 73717211-454a-528d-a86f-a190fbebd8ff

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
