// Dragnet [Ransomware]: dragnet-ransomware-2026-2862 — Mass File Rename (krybit)
// Status: stable | Level: high | ID: 963ab173-7cc8-5b48-95a4-b416eda821d0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
