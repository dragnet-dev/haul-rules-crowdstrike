// Dragnet [Ransomware]: dragnet-ransomware-2025-2713 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 5b01d0af-3132-5b06-a52b-d04f7496e103

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
