// Dragnet [Ransomware]: dragnet-ransomware-2023-2579 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 4d6e0406-ac19-59ab-8e04-67175ba4edd9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
