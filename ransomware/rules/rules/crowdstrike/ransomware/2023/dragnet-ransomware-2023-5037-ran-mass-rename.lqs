// Dragnet [Ransomware]: dragnet-ransomware-2023-5037 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: f756a21c-c56a-5317-9807-658e9b446411

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
