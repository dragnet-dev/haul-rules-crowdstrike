// Dragnet [Ransomware]: dragnet-ransomware-2025-4096 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: 5288926d-c159-51f2-b095-47e0d22c8a4d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
