// Dragnet [Ransomware]: dragnet-ransomware-2023-3919 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 79e78313-8ebe-5dec-bd1a-afefc5ca8711

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
