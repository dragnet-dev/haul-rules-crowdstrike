// Dragnet [Ransomware]: dragnet-ransomware-2025-4801 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: b727f9da-03e0-51bd-a0f6-b1ab1466caa7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
