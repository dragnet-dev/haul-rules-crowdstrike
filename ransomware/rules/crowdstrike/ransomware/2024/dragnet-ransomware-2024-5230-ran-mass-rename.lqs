// Dragnet [Ransomware]: dragnet-ransomware-2024-5230 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: ae7581cf-b765-56eb-bc37-d9911869b53b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
