// Dragnet [Ransomware]: dragnet-ransomware-2025-6558 — Mass File Rename (interlock)
// Status: test | Level: high | ID: b686316a-9681-5504-8e00-abf4ea724093

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
