// Dragnet [Container]: dragnet-container-2026-2147 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 33d55fb3-987d-59bd-8ee0-fe165ca9dc10

#event_simpleName=*
| (ImageFileName = *alpine:3.2* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:8*)
| table([timestamp, ComputerName])
| limit(1000)
