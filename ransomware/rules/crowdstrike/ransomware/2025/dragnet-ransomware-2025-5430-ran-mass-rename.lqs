// Dragnet [Ransomware]: dragnet-ransomware-2025-5430 — Mass File Rename (devman)
// Status: experimental | Level: high | ID: 398dd432-cebd-57df-a32b-697013c4d433

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
