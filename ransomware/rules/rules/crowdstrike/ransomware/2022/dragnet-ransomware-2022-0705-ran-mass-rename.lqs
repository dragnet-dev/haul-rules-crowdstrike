// Dragnet [Ransomware]: dragnet-ransomware-2022-0705 — Mass File Rename (blackbasta)
// Status: deprecated | Level: high | ID: 02bc11bb-91c3-51bb-9429-5506b4545516

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
