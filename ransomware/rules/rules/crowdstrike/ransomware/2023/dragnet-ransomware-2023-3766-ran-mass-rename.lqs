// Dragnet [Ransomware]: dragnet-ransomware-2023-3766 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 3b35eed9-0bc3-5321-aa7b-56d847bbc441

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
