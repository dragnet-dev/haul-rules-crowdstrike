// Dragnet [Container]: dragnet-container-2024-0789 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: c981ddb3-ee06-5b22-9186-7054bd430550

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *ubuntu:16.04* OR ImageFileName = *ubuntu:16.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
