// Dragnet [Ransomware]: dragnet-ransomware-2023-1308 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 624c7b53-5526-5341-9cdd-57586e404974

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
