// Dragnet [Ransomware]: dragnet-ransomware-2023-4996 — Mass File Rename (royal)
// Status: experimental | Level: high | ID: 8ea33e6b-9b53-5b44-85b2-aaa637f04dfc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
