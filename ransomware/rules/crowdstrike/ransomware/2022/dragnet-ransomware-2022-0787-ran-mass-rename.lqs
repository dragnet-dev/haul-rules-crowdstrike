// Dragnet [Ransomware]: dragnet-ransomware-2022-0787 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: dd7d0df6-d496-59c6-a090-e394bdef85a0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
