// Dragnet [Ransomware]: dragnet-ransomware-2025-3268 — Mass File Rename (nightspire)
// Status: deprecated | Level: high | ID: d23637a6-d784-5005-84e7-476d896ee5b1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
