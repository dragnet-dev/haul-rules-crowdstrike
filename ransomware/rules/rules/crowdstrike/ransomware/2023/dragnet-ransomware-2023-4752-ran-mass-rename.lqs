// Dragnet [Ransomware]: dragnet-ransomware-2023-4752 — Mass File Rename (stormous)
// Status: deprecated | Level: high | ID: bcb144c6-0eda-55a7-8e4c-502d03daa512

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
