// Dragnet [Container]: dragnet-container-2026-2061 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: ec62d2e5-c084-5344-ad43-26a17e0f407e

#event_simpleName=*
| (ImageFileName = *alpine edge:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
