// Dragnet [Ransomware]: dragnet-ransomware-2025-0955 — Mass File Rename (cloak)
// Status: deprecated | Level: high | ID: 9c87f793-56cc-51ea-b34c-3d84dd2949b1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
