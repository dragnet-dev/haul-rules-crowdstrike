// Dragnet [Ransomware]: dragnet-ransomware-2022-1495 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 71520be3-83f4-572e-a12c-2dea68de8a73

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
