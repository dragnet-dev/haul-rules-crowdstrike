// Dragnet [Ransomware]: dragnet-ransomware-2024-2501 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 9eae7a47-8605-575e-b25f-7fc36cb7cf8d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
