// Dragnet [Container]: dragnet-container-2024-1394 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: d76abf4f-783f-5f9f-8f4b-675d2bcd91e1

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *ubuntu:22.04*)
| table([timestamp, ComputerName])
| limit(1000)
