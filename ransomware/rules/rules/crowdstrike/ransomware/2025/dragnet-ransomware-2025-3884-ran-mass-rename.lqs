// Dragnet [Ransomware]: dragnet-ransomware-2025-3884 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 5f69dd59-644e-5a99-9e3d-82312868491b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
