// Dragnet [Ransomware]: dragnet-ransomware-2024-3346 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 29dbd0b1-a146-522f-aaac-d029843af69f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
