// Dragnet [Ransomware]: dragnet-ransomware-2022-0794 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 85dfa811-4cf5-5eaa-9da2-315550c1dd84

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
