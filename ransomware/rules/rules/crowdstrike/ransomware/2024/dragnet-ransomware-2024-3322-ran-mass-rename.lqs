// Dragnet [Ransomware]: dragnet-ransomware-2024-3322 — Mass File Rename (frag)
// Status: deprecated | Level: high | ID: 9ccbb7fd-39a7-5c88-a4aa-cd568bdfd0f7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
