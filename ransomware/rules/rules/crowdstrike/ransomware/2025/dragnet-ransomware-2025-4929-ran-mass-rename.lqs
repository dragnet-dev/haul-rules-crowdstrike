// Dragnet [Ransomware]: dragnet-ransomware-2025-4929 — Mass File Rename (arcusmedia)
// Status: experimental | Level: high | ID: 6c1a875e-118e-5c38-b6dc-8c6accf5be61

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
