// Dragnet [Ransomware]: dragnet-ransomware-2025-2824 — Mass File Rename (J)
// Status: experimental | Level: high | ID: 9e39c4b8-e575-5a6c-ac61-36b52c3107c2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
