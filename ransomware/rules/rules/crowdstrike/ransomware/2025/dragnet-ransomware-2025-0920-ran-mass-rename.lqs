// Dragnet [Ransomware]: dragnet-ransomware-2025-0920 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 46b03d2b-7f93-5c2e-8547-242a95d448c1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
