// Dragnet [Ransomware]: dragnet-ransomware-2023-4673 — Mass File Rename (knight)
// Status: experimental | Level: high | ID: bdac4b66-5101-5429-9843-23628a572ba5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
