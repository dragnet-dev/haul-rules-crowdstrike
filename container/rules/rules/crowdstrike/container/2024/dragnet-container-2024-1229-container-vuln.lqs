// Dragnet [Container]: dragnet-container-2024-1229 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 67f2ba95-85a0-57c6-906c-efb93d7a47fa

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:8* OR ImageFileName = *debian:9* OR ImageFileName = *oraclelinux:7* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:14.04* OR ImageFileName = *ubuntu:16.04*)
| table([timestamp, ComputerName])
| limit(1000)
