// Dragnet [Ransomware]: dragnet-ransomware-2024-3201 — Mass File Rename (handala)
// Status: experimental | Level: high | ID: dc401b01-e525-5951-b7db-28b6c31ca76d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
