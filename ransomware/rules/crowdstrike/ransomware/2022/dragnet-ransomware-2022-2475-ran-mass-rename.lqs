// Dragnet [Ransomware]: dragnet-ransomware-2022-2475 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 0337e442-b950-5336-81e5-a81892f70695

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
