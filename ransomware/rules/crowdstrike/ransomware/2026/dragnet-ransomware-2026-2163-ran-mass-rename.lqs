// Dragnet [Ransomware]: dragnet-ransomware-2026-2163 — Mass File Rename (threeam)
// Status: stable | Level: high | ID: 44c31fa4-bb27-5ae2-ad17-037b40c29e1b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
