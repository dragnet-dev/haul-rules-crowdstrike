// Dragnet [Ransomware]: dragnet-ransomware-2026-0490 — Mass File Rename (dragonforce)
// Status: test | Level: high | ID: bb3e2de1-35e5-5512-b9fc-b4220c24c850

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
