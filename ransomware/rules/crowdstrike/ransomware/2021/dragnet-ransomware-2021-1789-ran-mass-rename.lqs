// Dragnet [Ransomware]: dragnet-ransomware-2021-1789 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: f1904788-abb6-5a71-bf69-300ad937e86c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
