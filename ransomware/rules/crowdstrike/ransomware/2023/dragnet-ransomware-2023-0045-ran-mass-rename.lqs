// Dragnet [Ransomware]: dragnet-ransomware-2023-0045 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: a5657df6-1ffe-576c-ae05-786a74218fc5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
