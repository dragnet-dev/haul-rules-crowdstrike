// Dragnet [Ransomware]: dragnet-ransomware-2021-0389 — Mass File Rename (avaddon)
// Status: deprecated | Level: high | ID: 4938bc12-7da6-5701-addb-110445962278

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
