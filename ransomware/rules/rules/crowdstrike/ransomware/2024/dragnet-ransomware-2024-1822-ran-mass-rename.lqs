// Dragnet [Ransomware]: dragnet-ransomware-2024-1822 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 1b2e0864-3d5e-57ac-b7d3-7396d5953544

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
