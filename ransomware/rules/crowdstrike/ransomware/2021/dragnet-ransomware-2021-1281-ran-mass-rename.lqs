// Dragnet [Ransomware]: dragnet-ransomware-2021-1281 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 5b4d07d9-b3fb-5dd0-b289-6261bd7e1a5f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
