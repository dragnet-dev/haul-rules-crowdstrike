// Dragnet [Ransomware]: dragnet-ransomware-2023-2298 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 15485a96-339e-5d81-870e-ee3addee2e24

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
