// Dragnet [Ransomware]: dragnet-ransomware-2025-0704 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: f8d13b39-5530-5d37-aba9-24e42a98f280

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
