// Dragnet [Ransomware]: dragnet-ransomware-2024-4752 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 252b3902-9080-545c-8939-31d3b399f8c6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
