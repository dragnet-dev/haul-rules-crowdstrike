// Dragnet [Ransomware]: dragnet-ransomware-2025-5748 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: ab6a139b-2113-5489-9007-9ef70ef2006e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
