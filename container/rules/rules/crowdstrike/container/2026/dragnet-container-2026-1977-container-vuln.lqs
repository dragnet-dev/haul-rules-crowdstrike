// Dragnet [Container]: dragnet-container-2026-1977 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 80a65e22-bf2c-5cee-9ff7-8e85e32e6383

#event_simpleName=*
| (ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *redhat/ubi9:*)
| table([timestamp, ComputerName])
| limit(1000)
