// Dragnet [Ransomware]: dragnet-ransomware-2025-7698 — Mass File Rename (benzona)
// Status: deprecated | Level: high | ID: 21de7ef0-c70e-5371-856e-5c3dd2845bd8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
