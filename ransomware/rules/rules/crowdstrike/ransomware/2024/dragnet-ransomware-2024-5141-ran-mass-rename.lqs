// Dragnet [Ransomware]: dragnet-ransomware-2024-5141 — Mass File Rename (snatch)
// Status: experimental | Level: high | ID: 169511ad-6794-59a0-b21d-f2eef5ab857d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
