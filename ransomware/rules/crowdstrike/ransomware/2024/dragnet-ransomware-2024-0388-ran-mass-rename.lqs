// Dragnet [Ransomware]: dragnet-ransomware-2024-0388 — Mass File Rename (abyss)
// Status: deprecated | Level: high | ID: 3c00d8e3-47f0-5dae-be22-c117f961fdaa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
