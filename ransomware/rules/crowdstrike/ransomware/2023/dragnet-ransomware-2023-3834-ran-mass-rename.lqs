// Dragnet [Ransomware]: dragnet-ransomware-2023-3834 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 2b86012a-2f94-5780-94c2-3e1e76731c57

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
