// Dragnet [Ransomware]: dragnet-ransomware-2023-2883 — Mass File Rename (malas)
// Status: experimental | Level: high | ID: c478098b-01fb-5f6a-81bc-cff4a37542dc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
