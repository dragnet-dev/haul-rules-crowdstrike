// Dragnet [Ransomware]: dragnet-ransomware-2026-0669 — Mass File Rename (termite)
// Status: stable | Level: high | ID: 31422bc0-2e9d-5cf8-b0a0-fffc5adf0dac

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
