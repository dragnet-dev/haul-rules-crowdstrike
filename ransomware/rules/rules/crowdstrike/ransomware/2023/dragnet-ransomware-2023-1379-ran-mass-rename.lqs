// Dragnet [Ransomware]: dragnet-ransomware-2023-1379 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 38d8f6ab-f13e-58b7-b164-e53e7755cb1e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
