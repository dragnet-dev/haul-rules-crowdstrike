// Dragnet [Ransomware]: dragnet-ransomware-2025-6275 — Mass File Rename (worldleaks)
// Status: experimental | Level: high | ID: 10c30320-7da9-5bb2-ad9b-1dac63b336fc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
