// Dragnet [Ransomware]: dragnet-ransomware-2021-0763 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: c171d718-c888-5725-9362-f05d551695bf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
