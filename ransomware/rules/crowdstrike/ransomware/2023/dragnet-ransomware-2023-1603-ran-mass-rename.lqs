// Dragnet [Ransomware]: dragnet-ransomware-2023-1603 — Mass File Rename (trigona)
// Status: experimental | Level: high | ID: 6baafdde-baf8-5e9c-b44a-2c1655114596

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
