// Dragnet [Ransomware]: dragnet-ransomware-2025-4665 — Mass File Rename (kawa4096)
// Status: experimental | Level: high | ID: 37308e50-6e12-5df3-aa98-8d3638854a1a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
