// Dragnet [Ransomware]: dragnet-ransomware-2021-1135 — Mass File Rename (alphv)
// Status: deprecated | Level: high | ID: de8fe91b-4f35-5bb9-9022-05b708801667

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
