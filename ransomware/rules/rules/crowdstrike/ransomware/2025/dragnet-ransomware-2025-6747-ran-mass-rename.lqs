// Dragnet [Ransomware]: dragnet-ransomware-2025-6747 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 29aca521-d051-5c37-9c9e-90bfbacc8152

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
