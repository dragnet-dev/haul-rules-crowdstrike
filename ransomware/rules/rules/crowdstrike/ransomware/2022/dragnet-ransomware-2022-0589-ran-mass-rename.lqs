// Dragnet [Ransomware]: dragnet-ransomware-2022-0589 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: dd1ecbb5-f004-5547-993f-68b7d90c7ea3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
