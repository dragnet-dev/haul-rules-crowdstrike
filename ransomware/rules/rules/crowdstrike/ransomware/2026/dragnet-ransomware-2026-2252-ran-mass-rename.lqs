// Dragnet [Ransomware]: dragnet-ransomware-2026-2252 — Mass File Rename (bravox)
// Status: stable | Level: high | ID: 4f0bdc2a-c02c-54b1-8971-394e1260a027

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
