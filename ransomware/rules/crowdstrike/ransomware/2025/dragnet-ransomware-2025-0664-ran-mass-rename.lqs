// Dragnet [Ransomware]: dragnet-ransomware-2025-0664 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: 97e9e100-065a-522f-b56c-96c1024d2b77

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
