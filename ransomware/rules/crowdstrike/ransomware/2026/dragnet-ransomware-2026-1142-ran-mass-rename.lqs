// Dragnet [Ransomware]: dragnet-ransomware-2026-1142 — Mass File Rename (thegentlemen)
// Status: stable | Level: high | ID: 8d221281-e817-52fd-a601-b230925f581d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
