// Dragnet [Ransomware]: dragnet-ransomware-2025-6819 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: 9c939cc3-900d-59d2-9ffa-2ec08b177924

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
