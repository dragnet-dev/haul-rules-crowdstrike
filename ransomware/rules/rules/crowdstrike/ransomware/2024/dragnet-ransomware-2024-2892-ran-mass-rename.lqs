// Dragnet [Ransomware]: dragnet-ransomware-2024-2892 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: c67823d4-070e-55b0-b083-484c384708e6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
