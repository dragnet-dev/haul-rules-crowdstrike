// Dragnet [Container]: dragnet-container-2026-0010 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 2a5d9364-f221-5e3a-b52a-b710e79307e2

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:7* OR ImageFileName = *debian:8* OR ImageFileName = *ubuntu:16.04* OR ImageFileName = *ubuntu:16.04-ESM* OR ImageFileName = *ubuntu:16.10* OR ImageFileName = *ubuntu:17.04*)
| table([timestamp, ComputerName])
| limit(1000)
