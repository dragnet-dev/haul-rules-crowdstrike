// Dragnet [Ransomware]: dragnet-ransomware-2025-7650 — Mass File Rename (tengu)
// Status: experimental | Level: high | ID: 7a73b41c-e110-531c-bed1-d95b24e37b37

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
