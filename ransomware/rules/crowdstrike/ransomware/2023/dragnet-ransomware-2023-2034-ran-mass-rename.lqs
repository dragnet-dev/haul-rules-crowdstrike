// Dragnet [Ransomware]: dragnet-ransomware-2023-2034 — Mass File Rename (meow)
// Status: experimental | Level: high | ID: 41c1ba7c-1660-5202-a1cc-05ee19745a02

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
