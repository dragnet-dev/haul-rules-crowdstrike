// Dragnet [Ransomware]: dragnet-ransomware-2024-1750 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 16f673bf-4f35-5d4f-b538-6ae389e31075

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
