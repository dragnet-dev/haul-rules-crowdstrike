// Dragnet [Ransomware]: dragnet-ransomware-2021-1339 — Mass File Rename (avaddon)
// Status: deprecated | Level: high | ID: 2e4d36bb-462d-5d67-bed7-052a18941623

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
