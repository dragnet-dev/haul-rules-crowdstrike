// Dragnet [Ransomware]: dragnet-ransomware-2024-5635 — Mass File Rename (SilentRansomGroup)
// Status: deprecated | Level: high | ID: 7429eae4-10df-5a34-83d0-0d5d113f30b1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
