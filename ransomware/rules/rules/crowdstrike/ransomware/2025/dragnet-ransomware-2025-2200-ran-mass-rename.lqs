// Dragnet [Ransomware]: dragnet-ransomware-2025-2200 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: f35b0d98-1ed3-5360-9e44-df1c79db1261

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
