// Dragnet [Ransomware]: dragnet-ransomware-2025-3068 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: 6508ac6f-10fc-5e4b-a58c-7a45cae7a0a4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
