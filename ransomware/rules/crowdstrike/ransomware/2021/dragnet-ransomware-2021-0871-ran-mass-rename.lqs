// Dragnet [Ransomware]: dragnet-ransomware-2021-0871 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: d564ce9f-7df2-5fbb-bd4c-0440f61c76c5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
