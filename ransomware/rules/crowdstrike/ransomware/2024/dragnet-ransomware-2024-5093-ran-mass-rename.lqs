// Dragnet [Ransomware]: dragnet-ransomware-2024-5093 — Mass File Rename (snatch)
// Status: experimental | Level: high | ID: ce988023-42f2-5e0e-8411-25a3caacad59

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
