// Dragnet [Ransomware]: dragnet-ransomware-2025-0590 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: fbb2f6e4-532c-51ab-8c9c-630dfe0e77a6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
