// Dragnet [Ransomware]: dragnet-ransomware-2025-3319 — Mass File Rename (interlock)
// Status: experimental | Level: high | ID: 0c4d5715-4145-5fb0-bca8-7dc611e15440

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
