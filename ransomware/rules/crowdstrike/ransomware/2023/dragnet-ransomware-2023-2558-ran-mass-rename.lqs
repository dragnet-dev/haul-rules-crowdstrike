// Dragnet [Ransomware]: dragnet-ransomware-2023-2558 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: e54bcedc-1da1-528a-a412-247268eab4f4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
