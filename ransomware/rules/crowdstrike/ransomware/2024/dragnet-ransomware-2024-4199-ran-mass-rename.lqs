// Dragnet [Ransomware]: dragnet-ransomware-2024-4199 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 2cef25fe-6659-552e-a415-cd4803af3482

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
