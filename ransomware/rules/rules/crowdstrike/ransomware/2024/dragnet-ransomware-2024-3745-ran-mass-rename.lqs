// Dragnet [Ransomware]: dragnet-ransomware-2024-3745 — Mass File Rename (threeam)
// Status: experimental | Level: high | ID: b7d319a1-b117-58ab-a63a-75dde9f0b392

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
