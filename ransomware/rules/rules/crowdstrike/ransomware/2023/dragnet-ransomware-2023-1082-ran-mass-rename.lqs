// Dragnet [Ransomware]: dragnet-ransomware-2023-1082 — Mass File Rename (trigona)
// Status: deprecated | Level: high | ID: 8deba036-c6be-5c3e-88c8-25d9d468c75c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
