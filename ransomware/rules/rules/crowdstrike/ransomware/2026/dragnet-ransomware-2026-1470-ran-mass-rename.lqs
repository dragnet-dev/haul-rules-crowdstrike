// Dragnet [Ransomware]: dragnet-ransomware-2026-1470 — Mass File Rename (dragonforce)
// Status: stable | Level: high | ID: d19736b5-4e45-53fc-9b80-9cb1c93290b4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
