// Dragnet [Ransomware]: dragnet-ransomware-2025-2503 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: b619a9b4-97f0-5bda-b883-57c62517ccdb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
