// Dragnet [Ransomware]: dragnet-ransomware-2022-2472 — Mass File Rename (snatch)
// Status: deprecated | Level: high | ID: 25d1d729-1633-53c5-b41f-43ab30116688

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
