// Dragnet [Container]: dragnet-container-2026-1227 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 56130d44-0fda-57fb-a92f-8c433b1ce12d

#event_simpleName=*
| (ImageFileName = *almalinux:10* OR ImageFileName = *almalinux:8* OR ImageFileName = *almalinux:9* OR ImageFileName = *alpine:3.23* OR ImageFileName = *alpine edge:* OR ImageFileName = *amazonlinux:2* OR ImageFileName = *amazonlinux:2023* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:7* OR ImageFileName = *oraclelinux:8* OR ImageFileName = *oraclelinux:9* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:24.04* OR ImageFileName = *ubuntu:25.10*)
| table([timestamp, ComputerName])
| limit(1000)
