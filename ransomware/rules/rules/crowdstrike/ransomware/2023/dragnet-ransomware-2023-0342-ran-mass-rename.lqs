// Dragnet [Ransomware]: dragnet-ransomware-2023-0342 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: e213c947-5ac8-5f25-a987-8f86ebd013d3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
