// Dragnet [Ransomware]: dragnet-ransomware-2023-3180 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: d34a515a-e0e3-553f-9a9e-4d5451b293de

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
