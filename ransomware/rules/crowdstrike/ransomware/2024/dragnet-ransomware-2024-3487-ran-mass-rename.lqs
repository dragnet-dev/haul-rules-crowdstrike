// Dragnet [Ransomware]: dragnet-ransomware-2024-3487 — Mass File Rename (cloak)
// Status: deprecated | Level: high | ID: 0cf38485-191f-5be3-9256-f18122216a77

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
