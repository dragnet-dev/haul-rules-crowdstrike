// Dragnet [Ransomware]: dragnet-ransomware-2023-0054 — Mass File Rename (cryptbb)
// Status: experimental | Level: high | ID: a9b13a23-137f-511a-95fd-ce3c5bbfaa04

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
