// Dragnet [Ransomware]: dragnet-ransomware-2024-3413 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 676bb162-7cbc-5ebc-9b9b-c408eadd9757

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
