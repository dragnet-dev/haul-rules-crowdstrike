// Dragnet [Ransomware]: dragnet-ransomware-2024-5107 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: e6c3c16e-ac85-5ca9-866d-f791951e916c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
