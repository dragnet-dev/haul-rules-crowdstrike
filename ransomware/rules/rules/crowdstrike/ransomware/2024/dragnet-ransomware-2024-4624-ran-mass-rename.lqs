// Dragnet [Ransomware]: dragnet-ransomware-2024-4624 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: d49d6cd4-8a4f-5b16-adb7-c9180a7a3766

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
