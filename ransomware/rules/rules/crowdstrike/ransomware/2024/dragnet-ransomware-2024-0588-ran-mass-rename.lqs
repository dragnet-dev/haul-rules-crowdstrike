// Dragnet [Ransomware]: dragnet-ransomware-2024-0588 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 4288e8f9-101a-5bf2-826a-90e1fbb389be

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
