// Dragnet [Ransomware]: dragnet-ransomware-2025-4846 — Mass File Rename (cloak)
// Status: deprecated | Level: high | ID: 9369f071-96b7-5211-9611-ccb1e209f80d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
