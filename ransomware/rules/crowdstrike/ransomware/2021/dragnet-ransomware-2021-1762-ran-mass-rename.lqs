// Dragnet [Ransomware]: dragnet-ransomware-2021-1762 — Mass File Rename (avaddon)
// Status: deprecated | Level: high | ID: 82aae3e2-f5d3-570d-8b97-3b613682a6e7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
