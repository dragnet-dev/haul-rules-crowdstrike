// Dragnet [Ransomware]: dragnet-ransomware-2025-2482 — Mass File Rename (thegentlemen)
// Status: experimental | Level: high | ID: 05fc77ed-5f37-59c9-98a6-d5b35f469213

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
