// Dragnet [Ransomware]: dragnet-ransomware-2025-5629 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 637fb002-5558-5399-b80c-0291509361ab

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
