// Dragnet [Ransomware]: dragnet-ransomware-2024-2769 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 873d8e88-5c47-56ca-a505-921a8bcbd692

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
