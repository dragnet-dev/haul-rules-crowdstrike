// Dragnet [Ransomware]: dragnet-ransomware-2025-4182 — Mass File Rename (play)
// Status: experimental | Level: high | ID: ffe7e060-121d-52d4-91c4-57518dae83a0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
