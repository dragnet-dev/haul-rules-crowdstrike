// Dragnet [Ransomware]: dragnet-ransomware-2023-4296 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: a545539a-0b10-508c-a0be-c0704986add1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
