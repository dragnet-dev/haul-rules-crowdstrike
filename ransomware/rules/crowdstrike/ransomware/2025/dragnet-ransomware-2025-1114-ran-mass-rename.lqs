// Dragnet [Ransomware]: dragnet-ransomware-2025-1114 — Mass File Rename (handala)
// Status: experimental | Level: high | ID: 32326e72-3597-57f6-9b0b-3f87aa471cde

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
