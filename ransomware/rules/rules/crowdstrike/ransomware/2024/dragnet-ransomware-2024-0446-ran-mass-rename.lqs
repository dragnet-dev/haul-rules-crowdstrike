// Dragnet [Ransomware]: dragnet-ransomware-2024-0446 — Mass File Rename (rhysida)
// Status: deprecated | Level: high | ID: f5399d76-bb12-5022-8008-40c5262a7ce8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
