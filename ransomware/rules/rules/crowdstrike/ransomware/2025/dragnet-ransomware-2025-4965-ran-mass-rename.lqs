// Dragnet [Ransomware]: dragnet-ransomware-2025-4965 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 15448828-a156-512d-aa7b-5eed1b2e4c96

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
