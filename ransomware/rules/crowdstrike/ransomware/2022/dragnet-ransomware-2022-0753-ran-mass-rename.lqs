// Dragnet [Ransomware]: dragnet-ransomware-2022-0753 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: c9e05815-4df1-5009-ba5a-a0460b3866f7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
