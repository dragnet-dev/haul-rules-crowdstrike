// Dragnet [Ransomware]: dragnet-ransomware-2023-3467 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 4e9dff30-4264-5ad2-b70e-b12982b36ca5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
