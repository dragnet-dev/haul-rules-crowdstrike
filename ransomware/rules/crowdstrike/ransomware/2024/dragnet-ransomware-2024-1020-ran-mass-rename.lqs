// Dragnet [Ransomware]: dragnet-ransomware-2024-1020 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: fb71b081-3eff-5d0c-a515-efe6187fb065

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
