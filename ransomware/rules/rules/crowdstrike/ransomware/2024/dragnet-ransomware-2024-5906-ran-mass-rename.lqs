// Dragnet [Ransomware]: dragnet-ransomware-2024-5906 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 976dacb3-7bea-54e3-a020-0ba296b95a0b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
