// Dragnet [Ransomware]: dragnet-ransomware-2026-0474 — Mass File Rename (nightspire)
// Status: deprecated | Level: high | ID: 67f7c145-0e68-58bf-bcb2-b655fed60c3d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
