// Dragnet [Container]: dragnet-container-2026-0887 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 37030435-8f76-5a3e-a71e-38bf6f990664

#event_simpleName=*
| (ImageFileName = *debian:7* OR ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10* OR ImageFileName = *ubuntu:13.04*)
| table([timestamp, ComputerName])
| limit(1000)
