// Dragnet [Ransomware]: dragnet-ransomware-2021-1283 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 21cb751e-3f64-535f-827b-15a88493cca3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
