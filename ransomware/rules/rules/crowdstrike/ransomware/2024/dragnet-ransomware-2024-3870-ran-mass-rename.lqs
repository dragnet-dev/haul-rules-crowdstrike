// Dragnet [Ransomware]: dragnet-ransomware-2024-3870 — Mass File Rename (dragonforce)
// Status: deprecated | Level: high | ID: 9e824973-d98e-538b-9aaa-a4c47c27e68f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
