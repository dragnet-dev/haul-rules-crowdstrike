// Dragnet [Container]: dragnet-container-2026-2667 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 41dbabb1-d140-592d-a979-111875390af2

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
