// Dragnet [Container]: dragnet-container-2026-1249 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: c1590f5f-3fbb-5af5-83cf-885b40c492d8

#event_simpleName=*
| (ImageFileName = *debian:7* OR ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10* OR ImageFileName = *ubuntu:13.04*)
| table([timestamp, ComputerName])
| limit(1000)
