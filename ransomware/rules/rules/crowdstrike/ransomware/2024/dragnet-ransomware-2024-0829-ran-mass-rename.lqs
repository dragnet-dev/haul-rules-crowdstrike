// Dragnet [Ransomware]: dragnet-ransomware-2024-0829 — Mass File Rename (play)
// Status: experimental | Level: high | ID: eb8bf055-b1b9-5d0a-9d68-9a978ce9bceb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
