// Dragnet [Container]: dragnet-container-2024-0040 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: bb63c14c-7dff-594e-b3c5-8f8c6327d0da

#event_simpleName=*
| (ImageFileName = *amazonlinux:2023* OR ImageFileName = *azure linux:3.0* OR ImageFileName = *cbl-mariner:2.0* OR ImageFileName = *chainguard:* OR ImageFileName = *oraclelinux:7*)
| table([timestamp, ComputerName])
| limit(1000)
