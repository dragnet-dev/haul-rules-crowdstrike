// Dragnet [Ransomware]: dragnet-ransomware-2026-3488 — Mass File Rename (fulcrumsec)
// Status: stable | Level: high | ID: d67b4bbe-cbd0-56f2-84a6-09a175d55789

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
