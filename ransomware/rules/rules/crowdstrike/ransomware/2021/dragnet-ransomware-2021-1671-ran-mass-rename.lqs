// Dragnet [Ransomware]: dragnet-ransomware-2021-1671 — Mass File Rename (atomsilo)
// Status: experimental | Level: high | ID: 70a5f0ae-4dc8-508e-a3f9-7a3881f43f8a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
