// Dragnet [Ransomware]: dragnet-ransomware-2022-0177 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 6a9188e9-b308-52c8-b3c2-684e7f7ef6a7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
