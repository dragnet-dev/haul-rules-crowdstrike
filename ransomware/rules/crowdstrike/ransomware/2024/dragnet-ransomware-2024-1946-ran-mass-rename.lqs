// Dragnet [Ransomware]: dragnet-ransomware-2024-1946 — Mass File Rename (arcusmedia)
// Status: experimental | Level: high | ID: 38db236f-ca4c-59d5-8d3a-44ac0ca3272a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
