// Dragnet [Ransomware]: dragnet-ransomware-2024-0616 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 71a0e284-52f1-587b-a2bc-648024d60dc2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
