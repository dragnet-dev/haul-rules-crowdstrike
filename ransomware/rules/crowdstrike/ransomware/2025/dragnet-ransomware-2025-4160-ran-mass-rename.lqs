// Dragnet [Ransomware]: dragnet-ransomware-2025-4160 — Mass File Rename (SilentRansomGroup)
// Status: deprecated | Level: high | ID: 5e3ba24b-8158-529f-9e4d-5b5a42e25034

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
