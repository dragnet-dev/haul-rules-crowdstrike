// Dragnet [Ransomware]: dragnet-ransomware-2021-0730 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 15bded61-074e-5c2f-b42c-e1831e87f665

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
