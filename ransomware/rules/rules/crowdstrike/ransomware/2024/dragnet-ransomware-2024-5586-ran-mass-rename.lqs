// Dragnet [Ransomware]: dragnet-ransomware-2024-5586 — Mass File Rename (cicada3301)
// Status: experimental | Level: high | ID: fe38d1cc-a16c-5d60-b1d6-b438ef0c84c8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
