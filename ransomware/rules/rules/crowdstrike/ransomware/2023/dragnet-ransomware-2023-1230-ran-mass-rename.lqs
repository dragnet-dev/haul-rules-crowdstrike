// Dragnet [Ransomware]: dragnet-ransomware-2023-1230 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: fe5bff96-b155-55ec-bd51-5e9dd09c72c0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
