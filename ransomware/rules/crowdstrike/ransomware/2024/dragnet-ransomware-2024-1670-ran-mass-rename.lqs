// Dragnet [Ransomware]: dragnet-ransomware-2024-1670 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 2b3b2501-5ec9-570f-8b42-56078d053b0e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
