// Dragnet [Ransomware]: dragnet-ransomware-2024-1890 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: fae8d737-c425-5f02-be31-91e41c8b3236

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
