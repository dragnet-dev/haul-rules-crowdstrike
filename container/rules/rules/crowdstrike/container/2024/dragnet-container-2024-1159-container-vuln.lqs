// Dragnet [Container]: dragnet-container-2024-1159 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: bc386e92-e4d7-5922-8643-0f2a508c922b

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6*)
| table([timestamp, ComputerName])
| limit(1000)
