// Dragnet [Ransomware]: dragnet-ransomware-2024-2329 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 7bd86682-bc3e-5051-9d30-1a72cc8146cf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
