// Dragnet [Ransomware]: dragnet-ransomware-2022-0225 — Mass File Rename (blackbasta)
// Status: deprecated | Level: high | ID: f23e1fbf-3cc2-51ab-aeca-a4c5b19de5d2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
