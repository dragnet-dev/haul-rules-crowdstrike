// Dragnet [Ransomware]: dragnet-ransomware-2024-1452 — Mass File Rename (ransomexx)
// Status: experimental | Level: high | ID: 105979e9-3bb7-5ab2-bfed-68b90df79b40

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
