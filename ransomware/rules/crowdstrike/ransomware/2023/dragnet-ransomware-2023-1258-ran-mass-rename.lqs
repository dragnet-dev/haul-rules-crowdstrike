// Dragnet [Ransomware]: dragnet-ransomware-2023-1258 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 822e415d-01df-53c2-bad5-ea3e64631f2c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
