// Dragnet [Ransomware]: dragnet-ransomware-2024-5751 — Mass File Rename (dragonforce)
// Status: deprecated | Level: high | ID: 7c01de3c-c7c9-54b5-84c6-4568f32d357c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
