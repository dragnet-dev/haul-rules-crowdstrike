// Dragnet [Ransomware]: dragnet-ransomware-2022-0817 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 5ee6bbdf-57b0-5c45-8854-dbff7cd28e2f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
