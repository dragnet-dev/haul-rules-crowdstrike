// Dragnet [Ransomware]: dragnet-ransomware-2025-7619 — Mass File Rename (frag)
// Status: deprecated | Level: high | ID: b638880f-2be3-53bb-8a66-0828cce020b0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
