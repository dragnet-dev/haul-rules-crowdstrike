// Dragnet [Ransomware]: dragnet-ransomware-2025-2261 — Mass File Rename (lockbit5)
// Status: test | Level: high | ID: 4a51ba45-8aec-56f1-bb2f-1eeba9f90bde

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
