// Dragnet [Ransomware]: dragnet-ransomware-2022-2197 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: e963c7b4-2595-5f53-b8ee-822418e8fc42

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
