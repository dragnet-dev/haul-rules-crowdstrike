// Dragnet [Ransomware]: dragnet-ransomware-2025-2533 — Mass File Rename (stormous)
// Status: deprecated | Level: high | ID: af419432-0b77-5833-ab5f-abab94e30d3c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
