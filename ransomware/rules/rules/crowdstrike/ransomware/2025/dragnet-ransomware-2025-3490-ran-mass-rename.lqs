// Dragnet [Ransomware]: dragnet-ransomware-2025-3490 — Mass File Rename (arcusmedia)
// Status: experimental | Level: high | ID: 6b826c86-f327-58d8-9b68-aee5c0d1309c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
