// Dragnet [Ransomware]: dragnet-ransomware-2025-3284 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: b496a864-1710-5d0f-953d-16a717834e2f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
