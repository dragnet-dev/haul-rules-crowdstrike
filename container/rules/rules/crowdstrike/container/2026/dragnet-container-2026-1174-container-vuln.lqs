// Dragnet [Container]: dragnet-container-2026-1174 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 23ed9546-3cb1-5c18-ac7b-7f341de9ee45

#event_simpleName=*
| (ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10*)
| table([timestamp, ComputerName])
| limit(1000)
