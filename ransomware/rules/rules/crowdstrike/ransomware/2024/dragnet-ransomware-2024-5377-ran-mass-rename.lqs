// Dragnet [Ransomware]: dragnet-ransomware-2024-5377 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 2a10400b-3df2-502f-8723-91a9e5d1a523

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
