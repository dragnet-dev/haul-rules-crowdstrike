// Dragnet [Ransomware]: dragnet-ransomware-2022-2829 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 13d62455-9eb0-5219-99fb-72894c7f9f21

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
