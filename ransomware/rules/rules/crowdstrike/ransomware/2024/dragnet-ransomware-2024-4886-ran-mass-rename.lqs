// Dragnet [Ransomware]: dragnet-ransomware-2024-4886 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: b90ef9cb-fdc1-55f2-af1f-c3b38794157b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
