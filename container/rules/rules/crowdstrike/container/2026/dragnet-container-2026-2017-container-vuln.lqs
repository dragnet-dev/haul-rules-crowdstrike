// Dragnet [Container]: dragnet-container-2026-2017 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 9834982e-e1c6-5617-af9b-ecf09c73e0d2

#event_simpleName=*
| (ImageFileName = *debian:7* OR ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10*)
| table([timestamp, ComputerName])
| limit(1000)
