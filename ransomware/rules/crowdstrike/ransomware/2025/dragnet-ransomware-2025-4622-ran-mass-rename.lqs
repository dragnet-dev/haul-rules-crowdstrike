// Dragnet [Ransomware]: dragnet-ransomware-2025-4622 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: ee3a991e-c93b-50bb-acb8-3729c76262c5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
