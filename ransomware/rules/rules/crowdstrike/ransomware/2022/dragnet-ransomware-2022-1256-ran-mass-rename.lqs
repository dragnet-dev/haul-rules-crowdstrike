// Dragnet [Ransomware]: dragnet-ransomware-2022-1256 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 023716e6-339c-5fb8-849a-f05bf3ca0868

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
