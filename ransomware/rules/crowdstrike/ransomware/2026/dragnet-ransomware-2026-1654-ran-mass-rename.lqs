// Dragnet [Ransomware]: dragnet-ransomware-2026-1654 — Mass File Rename (payoutsking)
// Status: test | Level: high | ID: 17d4e5bd-331c-55ee-9771-8a8f2825fc78

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
