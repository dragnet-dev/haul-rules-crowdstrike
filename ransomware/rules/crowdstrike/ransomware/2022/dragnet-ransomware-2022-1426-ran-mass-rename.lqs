// Dragnet [Ransomware]: dragnet-ransomware-2022-1426 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 22e57e1c-62df-5a4a-ab1d-c599122cab4c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
