// Dragnet [Ransomware]: dragnet-ransomware-2024-4257 — Mass File Rename (redransomware)
// Status: deprecated | Level: high | ID: d111c690-303a-522e-a4e5-e0bc4733b7c1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
