// Dragnet [Ransomware]: dragnet-ransomware-2025-7403 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: 71cb8888-6dfb-53a1-b722-906bd0a55fd3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
