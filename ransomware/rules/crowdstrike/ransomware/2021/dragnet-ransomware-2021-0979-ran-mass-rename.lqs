// Dragnet [Ransomware]: dragnet-ransomware-2021-0979 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 73943e1c-b2d5-57ec-bd81-5604dbb8e066

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
