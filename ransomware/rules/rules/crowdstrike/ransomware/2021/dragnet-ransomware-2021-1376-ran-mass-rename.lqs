// Dragnet [Ransomware]: dragnet-ransomware-2021-1376 — Mass File Rename (avaddon)
// Status: deprecated | Level: high | ID: fb27c5c0-9573-5f3f-b052-2a34911cb0e5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
