// Dragnet [Ransomware]: dragnet-ransomware-2023-4191 — Mass File Rename (raworld)
// Status: experimental | Level: high | ID: d0633235-d996-56d0-9fe7-a0ab4c4a03c6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
