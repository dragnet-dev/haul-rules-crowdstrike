// Dragnet [Ransomware]: dragnet-ransomware-2024-3679 — Mass File Rename (raworld)
// Status: experimental | Level: high | ID: 41fe5035-3957-54d9-beeb-89b9ca8acaf6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
