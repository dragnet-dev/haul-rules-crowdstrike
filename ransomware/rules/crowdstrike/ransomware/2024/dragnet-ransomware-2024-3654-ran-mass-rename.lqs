// Dragnet [Ransomware]: dragnet-ransomware-2024-3654 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 73581b52-f9af-549f-b5c4-8299a6793199

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
