// Dragnet [Ransomware]: dragnet-ransomware-2024-6015 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: 93ce8089-eaa8-5011-be34-60d201295f25

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
