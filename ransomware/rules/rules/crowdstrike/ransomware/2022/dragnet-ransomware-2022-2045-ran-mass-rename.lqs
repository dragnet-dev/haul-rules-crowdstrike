// Dragnet [Ransomware]: dragnet-ransomware-2022-2045 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 1d3eb95d-b5f4-5469-a21a-c6cd5791c12f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
