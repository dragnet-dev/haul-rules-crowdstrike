// Dragnet [Ransomware]: dragnet-ransomware-2026-1115 — Mass File Rename (thegentlemen)
// Status: test | Level: high | ID: a677e7cf-111e-5afb-ac24-fd50eae9ac32

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
