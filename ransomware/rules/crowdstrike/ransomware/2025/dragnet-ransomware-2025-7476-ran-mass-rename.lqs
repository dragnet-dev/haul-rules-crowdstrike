// Dragnet [Ransomware]: dragnet-ransomware-2025-7476 — Mass File Rename (darkvault)
// Status: experimental | Level: high | ID: 8f7e942b-2de6-593e-8f64-7914fd60b7d8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
