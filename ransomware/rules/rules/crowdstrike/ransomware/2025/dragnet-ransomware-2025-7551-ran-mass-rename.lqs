// Dragnet [Ransomware]: dragnet-ransomware-2025-7551 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: 5fef4647-6baa-5fbe-adf8-2f4c13ea1583

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
