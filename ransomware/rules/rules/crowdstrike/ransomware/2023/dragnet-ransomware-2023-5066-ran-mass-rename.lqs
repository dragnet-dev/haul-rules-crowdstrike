// Dragnet [Ransomware]: dragnet-ransomware-2023-5066 — Mass File Rename (werewolves)
// Status: experimental | Level: high | ID: 80aaa091-9afe-5dce-9df6-ffdd03cd0f06

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
