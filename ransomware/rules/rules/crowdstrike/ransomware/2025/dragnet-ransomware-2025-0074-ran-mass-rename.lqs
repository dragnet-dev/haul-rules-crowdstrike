// Dragnet [Ransomware]: dragnet-ransomware-2025-0074 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: c27cfe76-5747-527b-acbe-4029f3c87b5f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
