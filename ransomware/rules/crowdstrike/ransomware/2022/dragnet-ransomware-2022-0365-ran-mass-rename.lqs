// Dragnet [Ransomware]: dragnet-ransomware-2022-0365 — Mass File Rename (lv)
// Status: deprecated | Level: high | ID: 2dd9212c-1cb0-5cd2-8bd4-9d2d728cd743

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
