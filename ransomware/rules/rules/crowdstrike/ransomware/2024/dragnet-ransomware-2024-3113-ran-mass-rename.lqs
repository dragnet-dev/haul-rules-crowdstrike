// Dragnet [Ransomware]: dragnet-ransomware-2024-3113 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 8a07b767-5c70-5425-8a33-be54c0353ad5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
