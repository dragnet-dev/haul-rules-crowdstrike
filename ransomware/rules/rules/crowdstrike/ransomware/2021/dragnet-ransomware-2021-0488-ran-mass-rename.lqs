// Dragnet [Ransomware]: dragnet-ransomware-2021-0488 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: ea3d5e72-3519-53f8-933a-b6f9334e8e4a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
