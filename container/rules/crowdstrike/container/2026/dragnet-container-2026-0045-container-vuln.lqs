// Dragnet [Container]: dragnet-container-2026-0045 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 716b5147-a51e-5ac7-9dec-fa165b108878

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
