// Dragnet [Ransomware]: dragnet-ransomware-2022-2759 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: ecd11aa7-9a69-501e-9778-d893f16297c9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
