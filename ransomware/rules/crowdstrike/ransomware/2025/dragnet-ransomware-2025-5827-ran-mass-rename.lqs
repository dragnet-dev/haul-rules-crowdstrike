// Dragnet [Ransomware]: dragnet-ransomware-2025-5827 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: 2570566d-1ac9-501f-85ab-c97df60327dd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
