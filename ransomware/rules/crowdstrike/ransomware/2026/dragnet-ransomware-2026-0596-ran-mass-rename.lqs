// Dragnet [Ransomware]: dragnet-ransomware-2026-0596 — Mass File Rename (AiLock)
// Status: deprecated | Level: high | ID: cb37e4f9-0bbc-5758-9b27-89189b5c65d3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
