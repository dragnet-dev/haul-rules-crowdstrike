// Dragnet [Ransomware]: dragnet-ransomware-2024-5648 — Mass File Rename (meow)
// Status: experimental | Level: high | ID: c432146b-1d0f-580c-8825-e9746d2bc853

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
