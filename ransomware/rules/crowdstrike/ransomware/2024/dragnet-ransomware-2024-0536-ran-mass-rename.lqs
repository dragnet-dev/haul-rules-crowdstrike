// Dragnet [Ransomware]: dragnet-ransomware-2024-0536 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: 15aa3a4c-5826-50f5-a910-6e0696601ec1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
