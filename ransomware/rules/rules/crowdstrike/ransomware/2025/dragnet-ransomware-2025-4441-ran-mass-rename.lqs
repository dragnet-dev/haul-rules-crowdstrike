// Dragnet [Ransomware]: dragnet-ransomware-2025-4441 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 1ba52b05-8005-5511-8150-7da4f010807d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
