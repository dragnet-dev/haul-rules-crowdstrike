// Dragnet [Ransomware]: dragnet-ransomware-2022-1034 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 04c6e8e2-f454-55c9-a8c5-9fd575a80999

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
