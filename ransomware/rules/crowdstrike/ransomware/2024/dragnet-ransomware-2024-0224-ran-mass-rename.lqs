// Dragnet [Ransomware]: dragnet-ransomware-2024-0224 — Mass File Rename (nitrogen)
// Status: experimental | Level: high | ID: 96dce56a-5ded-5037-9520-6961f85a5515

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
