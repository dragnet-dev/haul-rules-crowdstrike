// Dragnet [Ransomware]: dragnet-ransomware-2025-2180 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 5e1b12f6-39ad-589e-9dc9-957833a5397c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
