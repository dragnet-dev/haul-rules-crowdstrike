// Dragnet [Ransomware]: dragnet-ransomware-2024-5391 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: f42f5371-1453-5b9e-9aa6-cb88f17ac3c0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
