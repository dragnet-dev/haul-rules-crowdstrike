// Dragnet [Ransomware]: dragnet-ransomware-2023-1536 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 16f250be-7650-53e2-b06b-832a920e028c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
