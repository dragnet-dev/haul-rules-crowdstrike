// Dragnet [Ransomware]: dragnet-ransomware-2023-2470 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: a8427a6f-f89c-53f3-9c33-f3534c7965f7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
