// Dragnet [Ransomware]: dragnet-ransomware-2022-1839 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: b89de143-8da0-59aa-8343-70c4f1b2ef88

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
