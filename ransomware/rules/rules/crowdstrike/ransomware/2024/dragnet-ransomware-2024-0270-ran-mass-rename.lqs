// Dragnet [Ransomware]: dragnet-ransomware-2024-0270 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: b41aa402-d658-5c0e-ae2c-a69b3a668daa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
