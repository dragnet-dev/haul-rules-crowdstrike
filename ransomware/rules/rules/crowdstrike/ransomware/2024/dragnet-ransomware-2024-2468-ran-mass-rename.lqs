// Dragnet [Ransomware]: dragnet-ransomware-2024-2468 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 50fac545-ef46-5228-844b-2f100ae5fe57

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
