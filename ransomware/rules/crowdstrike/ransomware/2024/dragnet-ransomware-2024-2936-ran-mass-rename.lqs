// Dragnet [Ransomware]: dragnet-ransomware-2024-2936 — Mass File Rename (dragonransomware)
// Status: experimental | Level: high | ID: 32e31abf-ef30-5264-8193-646149606191

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
