// Dragnet [Ransomware]: dragnet-ransomware-2021-1681 — Mass File Rename (revil)
// Status: deprecated | Level: high | ID: 43438550-64c2-5896-a977-092251ca7f10

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
