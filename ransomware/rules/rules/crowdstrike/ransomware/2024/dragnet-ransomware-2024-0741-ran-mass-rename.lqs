// Dragnet [Ransomware]: dragnet-ransomware-2024-0741 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 8250424c-789f-5330-b9ce-c58b27f0f892

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
