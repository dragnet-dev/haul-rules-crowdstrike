// Dragnet [Container]: dragnet-container-2026-2010 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: ec939aee-a606-54e1-a799-f62dd24496b5

#event_simpleName=*
| (ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10* OR ImageFileName = *ubuntu:13.04* OR ImageFileName = *ubuntu:13.10*)
| table([timestamp, ComputerName])
| limit(1000)
