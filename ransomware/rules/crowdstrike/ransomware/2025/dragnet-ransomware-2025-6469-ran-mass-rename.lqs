// Dragnet [Ransomware]: dragnet-ransomware-2025-6469 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 12a4dd94-c49d-53d8-a2ec-f093a22ccf51

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
