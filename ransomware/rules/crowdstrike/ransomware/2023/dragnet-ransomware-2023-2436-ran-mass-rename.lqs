// Dragnet [Ransomware]: dragnet-ransomware-2023-2436 — Mass File Rename (royal)
// Status: experimental | Level: high | ID: 7dbf11aa-0783-5de4-a012-aee5b483c16b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
