// Dragnet [Ransomware]: dragnet-ransomware-2020-0005 — Mass File Rename (maze)
// Status: deprecated | Level: high | ID: 2b55c090-ae33-5044-bd7e-735f1084e071

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
