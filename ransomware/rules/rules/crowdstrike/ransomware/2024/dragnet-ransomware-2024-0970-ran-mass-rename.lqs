// Dragnet [Ransomware]: dragnet-ransomware-2024-0970 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: e19c4939-860f-5361-98c1-22ee6e64e562

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
