// Dragnet [Ransomware]: dragnet-ransomware-2024-3137 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 6d635369-4652-5e18-a658-785257fa1ad2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
