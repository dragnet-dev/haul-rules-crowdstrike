// Dragnet [Ransomware]: dragnet-ransomware-2022-2075 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 13889a5a-d671-59ce-8152-c243e265ad95

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
