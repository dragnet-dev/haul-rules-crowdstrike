// Dragnet [Ransomware]: dragnet-ransomware-2024-3674 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 0cdf4259-d1f5-50b5-ac2c-2119309d96c7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
