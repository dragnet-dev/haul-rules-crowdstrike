// Dragnet [Ransomware]: dragnet-ransomware-2022-0577 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: b815885a-4ce1-54fe-9d76-826a6d800872

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
