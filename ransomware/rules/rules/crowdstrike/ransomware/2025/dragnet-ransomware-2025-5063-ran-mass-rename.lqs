// Dragnet [Ransomware]: dragnet-ransomware-2025-5063 — Mass File Rename (blackshrantac)
// Status: experimental | Level: high | ID: 4099c407-57b8-5cfe-8028-61c1c6e1a6ba

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
