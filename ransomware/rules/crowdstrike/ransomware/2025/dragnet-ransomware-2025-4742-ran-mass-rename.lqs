// Dragnet [Ransomware]: dragnet-ransomware-2025-4742 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 1f60b642-04c7-5516-8e8a-878624f298aa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
