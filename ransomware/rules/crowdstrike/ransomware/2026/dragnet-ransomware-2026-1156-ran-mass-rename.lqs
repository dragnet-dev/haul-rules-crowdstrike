// Dragnet [Ransomware]: dragnet-ransomware-2026-1156 — Mass File Rename (thegentlemen)
// Status: stable | Level: high | ID: a84c97cc-ba9e-5873-b7e7-a705fd20cffa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
