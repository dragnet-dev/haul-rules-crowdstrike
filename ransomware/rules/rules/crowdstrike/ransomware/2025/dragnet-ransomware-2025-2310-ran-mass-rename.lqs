// Dragnet [Ransomware]: dragnet-ransomware-2025-2310 — Mass File Rename (termite)
// Status: experimental | Level: high | ID: 0c4c934b-26ce-5b6c-aa02-e5efcf543c0e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
