// Dragnet [Ransomware]: dragnet-ransomware-2025-0409 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 122cc556-7e77-5775-8029-50455bd3c356

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
