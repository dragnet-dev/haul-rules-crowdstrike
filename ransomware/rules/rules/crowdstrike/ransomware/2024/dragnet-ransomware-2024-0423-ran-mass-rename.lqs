// Dragnet [Ransomware]: dragnet-ransomware-2024-0423 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 32cddb9f-ed66-518c-8bf0-3a5aee256909

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
