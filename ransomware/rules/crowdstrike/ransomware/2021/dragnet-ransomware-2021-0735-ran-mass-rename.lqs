// Dragnet [Ransomware]: dragnet-ransomware-2021-0735 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: b20508b0-ff8b-58e7-be36-42985b1880a7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
