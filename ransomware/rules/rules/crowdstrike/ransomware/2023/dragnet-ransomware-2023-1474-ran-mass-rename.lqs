// Dragnet [Ransomware]: dragnet-ransomware-2023-1474 — Mass File Rename (toufan)
// Status: deprecated | Level: high | ID: acba9d08-aad5-590c-ac6c-e6c10d48b6bd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
