// Dragnet [Ransomware]: dragnet-ransomware-2022-1013 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: b3fdf366-f8dd-5503-a01d-e52a4b79e930

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
