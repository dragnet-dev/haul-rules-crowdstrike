// Dragnet [Ransomware]: dragnet-ransomware-2022-1620 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 8e677b25-6e65-5bf1-9d52-f7a7f5855a97

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
