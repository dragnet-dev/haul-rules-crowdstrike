// Dragnet [Ransomware]: dragnet-ransomware-2025-7364 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: db569c68-ab80-53b8-b7d6-9e6bf2b33ef8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
