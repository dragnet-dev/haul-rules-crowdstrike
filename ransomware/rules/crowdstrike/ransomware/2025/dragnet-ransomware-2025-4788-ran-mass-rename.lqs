// Dragnet [Ransomware]: dragnet-ransomware-2025-4788 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 2502f4a1-19de-552f-919b-83857065cd0d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
