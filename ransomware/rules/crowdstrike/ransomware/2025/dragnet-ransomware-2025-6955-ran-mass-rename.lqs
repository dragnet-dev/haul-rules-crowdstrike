// Dragnet [Ransomware]: dragnet-ransomware-2025-6955 — Mass File Rename (blacknevas)
// Status: experimental | Level: high | ID: bf1e7956-3427-50d0-88fc-184403bfa13d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
