// Dragnet [Ransomware]: dragnet-ransomware-2025-3808 — Mass File Rename (weyhro)
// Status: experimental | Level: high | ID: 1113d6fa-be69-5721-b0d6-a9663d24cdb3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
