// Dragnet [Ransomware]: dragnet-ransomware-2025-0358 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: e8c7e25f-0b4c-589c-8121-ac43f9a0b680

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
