// Dragnet [Ransomware]: dragnet-ransomware-2025-3425 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: d4bc365d-c00f-5f06-9f94-8bda90767936

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
