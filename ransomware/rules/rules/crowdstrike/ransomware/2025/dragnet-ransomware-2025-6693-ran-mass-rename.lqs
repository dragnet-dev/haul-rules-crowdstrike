// Dragnet [Ransomware]: dragnet-ransomware-2025-6693 — Mass File Rename (pear)
// Status: experimental | Level: high | ID: f99bd238-c45e-5113-8f45-f168aa60db5e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
