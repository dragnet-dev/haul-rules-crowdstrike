// Dragnet [Ransomware]: dragnet-ransomware-2024-4863 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 48cafa1c-90cf-58ce-9c46-5479e77fd33f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
