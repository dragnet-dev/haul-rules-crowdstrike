// Dragnet [Ransomware]: dragnet-ransomware-2024-0047 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 99813986-597f-5581-9df6-142531a452eb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
