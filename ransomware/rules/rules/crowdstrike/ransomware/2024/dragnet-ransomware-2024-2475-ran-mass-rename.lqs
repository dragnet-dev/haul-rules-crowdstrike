// Dragnet [Ransomware]: dragnet-ransomware-2024-2475 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 774d55ff-1c8a-5a7e-9b46-d5a769a68ba1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
