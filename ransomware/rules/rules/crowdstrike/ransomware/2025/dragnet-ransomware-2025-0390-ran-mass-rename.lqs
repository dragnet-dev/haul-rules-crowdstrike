// Dragnet [Ransomware]: dragnet-ransomware-2025-0390 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 92e6fb73-b3f6-51e4-aea1-3be49e87200a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
