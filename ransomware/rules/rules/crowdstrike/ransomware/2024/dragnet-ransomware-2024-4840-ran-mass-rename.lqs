// Dragnet [Ransomware]: dragnet-ransomware-2024-4840 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: a8f9f06a-49ba-5b3f-907e-9b7c7bd2af5d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
