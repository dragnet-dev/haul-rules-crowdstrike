// Dragnet [Container]: dragnet-container-2024-1129 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 964df582-bd26-5af9-8510-aea1b1940317

#event_simpleName=*
| (ImageFileName = *amazonlinux:1* OR ImageFileName = *amazonlinux:2* OR ImageFileName = *amazonlinux:2023* OR ImageFileName = *azure linux:3.0* OR ImageFileName = *cbl-mariner:2.0* OR ImageFileName = *chainguard:* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *ubuntu:22.04* OR ImageFileName = *ubuntu:24.04* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
