// Dragnet [Ransomware]: dragnet-ransomware-2020-0123 — Mass File Rename (netwalker)
// Status: deprecated | Level: high | ID: e31435bc-463a-51da-8d9a-fce74c188852

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
