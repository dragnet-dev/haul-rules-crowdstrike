// Dragnet [Ransomware]: dragnet-ransomware-2025-0672 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: b2dc49c6-94b9-578b-af3b-7858c74873f1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
