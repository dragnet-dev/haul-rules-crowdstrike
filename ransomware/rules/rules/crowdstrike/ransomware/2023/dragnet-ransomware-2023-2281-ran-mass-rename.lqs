// Dragnet [Ransomware]: dragnet-ransomware-2023-2281 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 17ed074a-eab6-57de-a0ed-f9a1bed20d1f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
