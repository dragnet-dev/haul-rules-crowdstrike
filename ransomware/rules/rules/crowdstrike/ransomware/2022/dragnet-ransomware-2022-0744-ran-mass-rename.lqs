// Dragnet [Ransomware]: dragnet-ransomware-2022-0744 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 981c6b86-3da6-5f34-a44e-51a040d8bfec

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
