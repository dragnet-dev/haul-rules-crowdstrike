// Dragnet [Ransomware]: dragnet-ransomware-2023-3929 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 599c21a2-375e-50ea-82d5-7fb8ec5dfcee

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
