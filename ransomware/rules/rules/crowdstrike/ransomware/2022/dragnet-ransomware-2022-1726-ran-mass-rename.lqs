// Dragnet [Ransomware]: dragnet-ransomware-2022-1726 — Mass File Rename (unsafe)
// Status: deprecated | Level: high | ID: 6871cb54-82ec-50b4-8207-486fb332e1fd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
