// Dragnet [Container]: dragnet-container-2026-0939 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 3e26db15-8d86-50a9-968e-dc512e0927d0

#event_simpleName=*
| (ImageFileName = *chainguard:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
