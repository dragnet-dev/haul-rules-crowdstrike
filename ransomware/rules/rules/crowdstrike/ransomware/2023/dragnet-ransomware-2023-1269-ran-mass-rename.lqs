// Dragnet [Ransomware]: dragnet-ransomware-2023-1269 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 59f6ecb3-8760-570f-9d3e-7cd86ad9fb94

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
