// Dragnet [Container]: dragnet-container-2026-2537 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 60468887-72c6-5a24-bf65-bea07558c110

#event_simpleName=*
| (ImageFileName = *chainguard:* OR ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10*)
| table([timestamp, ComputerName])
| limit(1000)
