// Dragnet [Ransomware]: dragnet-ransomware-2024-4742 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 24622007-339e-59bb-99b8-131a3a97d4eb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
