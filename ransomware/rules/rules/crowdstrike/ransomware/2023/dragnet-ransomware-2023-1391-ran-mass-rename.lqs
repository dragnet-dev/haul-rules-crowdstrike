// Dragnet [Ransomware]: dragnet-ransomware-2023-1391 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: e885f73c-2f15-5220-ad8d-a798374d785b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
