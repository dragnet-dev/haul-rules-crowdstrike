// Dragnet [Ransomware]: dragnet-ransomware-2025-6784 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: 2a11e251-b51a-57f2-882d-258447834550

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
