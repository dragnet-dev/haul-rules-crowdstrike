// Dragnet [Ransomware]: dragnet-ransomware-2022-0712 — Mass File Rename (stormous)
// Status: deprecated | Level: high | ID: d3d09838-998d-5481-b098-ee08f5d8e84f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
