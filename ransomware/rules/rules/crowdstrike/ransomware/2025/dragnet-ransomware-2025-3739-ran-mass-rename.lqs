// Dragnet [Ransomware]: dragnet-ransomware-2025-3739 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: a653381c-e259-509d-907a-7032bbc8276e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
