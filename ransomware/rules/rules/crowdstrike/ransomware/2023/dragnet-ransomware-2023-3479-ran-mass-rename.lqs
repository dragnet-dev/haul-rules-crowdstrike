// Dragnet [Ransomware]: dragnet-ransomware-2023-3479 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: b2a5ca72-dd24-5711-a7a4-cef57ff156f2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
