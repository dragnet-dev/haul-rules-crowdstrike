// Dragnet [Ransomware]: dragnet-ransomware-2023-2693 — Mass File Rename (ragnarlocker)
// Status: experimental | Level: high | ID: 2ff649d2-b59b-5098-a046-3d863c96e4e3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
