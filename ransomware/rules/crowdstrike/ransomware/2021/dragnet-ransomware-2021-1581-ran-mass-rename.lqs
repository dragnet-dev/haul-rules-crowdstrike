// Dragnet [Ransomware]: dragnet-ransomware-2021-1581 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 9029c7ab-b72e-5829-946d-43deb0b32c86

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
