// Dragnet [Ransomware]: dragnet-ransomware-2025-6535 — Mass File Rename (warlock)
// Status: deprecated | Level: high | ID: 3d7de220-07c3-547a-a4a5-887d331ef138

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
