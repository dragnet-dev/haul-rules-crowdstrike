// Dragnet [Ransomware]: dragnet-ransomware-2025-2915 — Mass File Rename (handala)
// Status: experimental | Level: high | ID: 21dd9ff6-c97f-5ea5-9419-ea41b5c785bc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
