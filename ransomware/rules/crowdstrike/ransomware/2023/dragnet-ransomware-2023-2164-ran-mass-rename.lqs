// Dragnet [Ransomware]: dragnet-ransomware-2023-2164 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 9f862cfc-7e9e-51cf-af8e-bbb896e78207

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
