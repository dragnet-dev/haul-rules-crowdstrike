// Dragnet [Ransomware]: dragnet-ransomware-2025-0443 — Mass File Rename (rhysida)
// Status: deprecated | Level: high | ID: 692880e5-de0b-5fa7-9dd5-2cc4bd652ac1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
