// Dragnet [Ransomware]: dragnet-ransomware-2026-0546 — Mass File Rename (stormous)
// Status: deprecated | Level: high | ID: 7a4ac925-e789-51f4-a9a4-a5ec3737769a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
