// Dragnet [Ransomware]: dragnet-ransomware-2022-0415 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: 64fa1137-52f1-54f9-996c-63057984c9bf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
