// Dragnet [Ransomware]: dragnet-ransomware-2024-1096 — Mass File Rename (abyss)
// Status: deprecated | Level: high | ID: 8c19a87a-c97d-53e5-aa69-a55477ef639c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
