// Dragnet [Ransomware]: dragnet-ransomware-2025-1483 — Mass File Rename (nightspire)
// Status: deprecated | Level: high | ID: d2b1befd-1690-5d33-b377-d41c9307b839

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
