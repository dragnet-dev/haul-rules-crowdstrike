// Dragnet [Ransomware]: dragnet-ransomware-2021-1426 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: 2a9b4571-11f6-5cd8-9452-87c5f16a7186

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
