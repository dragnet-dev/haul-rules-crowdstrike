// Dragnet [Container]: dragnet-container-2024-1322 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: e59f47b4-e783-5d70-bbab-89df108bdef0

#event_simpleName=*
| (ImageFileName = *amazonlinux:2* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:8* OR ImageFileName = *debian:9* OR ImageFileName = *oraclelinux:7* OR ImageFileName = *ubuntu:14.04-ESM* OR ImageFileName = *ubuntu:16.04-ESM* OR ImageFileName = *ubuntu:18.04* OR ImageFileName = *ubuntu:18.04-ESM* OR ImageFileName = *ubuntu:19.04*)
| table([timestamp, ComputerName])
| limit(1000)
