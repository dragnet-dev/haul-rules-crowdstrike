// Dragnet [Ransomware]: dragnet-ransomware-2025-6627 — Mass File Rename (blacknevas)
// Status: experimental | Level: high | ID: d259cb4d-e82a-5fd5-9895-df4dd637ea84

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
