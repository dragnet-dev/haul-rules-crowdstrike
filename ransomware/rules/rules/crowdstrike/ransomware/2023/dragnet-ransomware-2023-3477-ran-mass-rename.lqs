// Dragnet [Ransomware]: dragnet-ransomware-2023-3477 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 02473da0-255e-53dc-ae8d-b1fa3529cfe8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
