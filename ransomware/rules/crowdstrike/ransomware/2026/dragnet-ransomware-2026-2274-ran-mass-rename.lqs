// Dragnet [Ransomware]: dragnet-ransomware-2026-2274 — Mass File Rename (lockbit5)
// Status: test | Level: high | ID: ea624aa9-5b45-5f67-b9cf-5cddeceb7349

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
