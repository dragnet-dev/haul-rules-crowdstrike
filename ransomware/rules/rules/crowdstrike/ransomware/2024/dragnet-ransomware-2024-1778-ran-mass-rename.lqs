// Dragnet [Ransomware]: dragnet-ransomware-2024-1778 — Mass File Rename (trigona)
// Status: experimental | Level: high | ID: d0accb9e-b053-599e-92c9-112dd43f30b9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
