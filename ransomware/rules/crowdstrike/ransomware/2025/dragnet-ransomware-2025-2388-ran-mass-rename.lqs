// Dragnet [Ransomware]: dragnet-ransomware-2025-2388 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: a88253af-a833-5a6e-88e6-80fc379983d4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
