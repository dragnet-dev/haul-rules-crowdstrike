// Dragnet [Ransomware]: dragnet-ransomware-2024-1305 — Mass File Rename (safepay)
// Status: deprecated | Level: high | ID: 79aa80f3-44bd-5589-be7a-b174a29308fb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
