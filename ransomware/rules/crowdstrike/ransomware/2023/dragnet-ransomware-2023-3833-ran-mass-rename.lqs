// Dragnet [Ransomware]: dragnet-ransomware-2023-3833 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: f5f477a7-2f1f-5fc2-ae9a-dfdbbb20ddda

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
