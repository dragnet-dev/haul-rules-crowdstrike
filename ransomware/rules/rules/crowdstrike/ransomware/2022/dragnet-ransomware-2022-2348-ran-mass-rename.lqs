// Dragnet [Ransomware]: dragnet-ransomware-2022-2348 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: fbe17674-caef-59ac-ba38-e7626d1a2251

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
