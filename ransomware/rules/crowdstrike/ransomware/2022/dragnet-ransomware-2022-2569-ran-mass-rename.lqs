// Dragnet [Ransomware]: dragnet-ransomware-2022-2569 — Mass File Rename (ransomexx)
// Status: deprecated | Level: high | ID: 1638b7fa-a795-5e25-908d-86235c6d64bc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
