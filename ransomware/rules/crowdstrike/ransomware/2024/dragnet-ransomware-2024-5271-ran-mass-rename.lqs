// Dragnet [Ransomware]: dragnet-ransomware-2024-5271 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: 465d99ae-c568-538a-9c64-807c2493329f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
