// Dragnet [Ransomware]: dragnet-ransomware-2022-1577 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 4659090c-420c-5de8-bfb0-d60e57a04c7c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
