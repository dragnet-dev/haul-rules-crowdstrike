// Dragnet [Ransomware]: dragnet-ransomware-2026-2159 — Mass File Rename (anubis)
// Status: stable | Level: high | ID: f16e9c36-f353-5981-8588-c83a5e9f1436

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
