// Dragnet [Ransomware]: dragnet-ransomware-2022-0535 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 7dac5b8f-8848-5276-88df-098fc4870146

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
