// Dragnet [Ransomware]: dragnet-ransomware-2023-1522 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 7fe784d2-e497-5552-9a2a-ce104634518a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
