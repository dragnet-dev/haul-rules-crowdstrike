// Dragnet [Ransomware]: dragnet-ransomware-2020-0014 — Mass File Rename (doppelpaymer)
// Status: deprecated | Level: high | ID: e85c3620-678d-556a-97f3-5577dbdcf9e9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
