// Dragnet [Ransomware]: dragnet-ransomware-2025-4272 — Mass File Rename (interlock)
// Status: experimental | Level: high | ID: 5f433587-f4f3-5f9e-8eff-bf4ae19ae09f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
