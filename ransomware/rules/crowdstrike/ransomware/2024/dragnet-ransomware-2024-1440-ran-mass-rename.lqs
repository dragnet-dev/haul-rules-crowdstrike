// Dragnet [Ransomware]: dragnet-ransomware-2024-1440 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: e9c4241e-a595-5030-84e3-31749e35ea7d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
