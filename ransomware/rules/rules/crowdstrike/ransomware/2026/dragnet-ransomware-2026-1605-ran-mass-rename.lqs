// Dragnet [Ransomware]: dragnet-ransomware-2026-1605 — Mass File Rename (incransom)
// Status: stable | Level: high | ID: 5d8b3290-038e-5c14-9c17-46d909ecf720

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
