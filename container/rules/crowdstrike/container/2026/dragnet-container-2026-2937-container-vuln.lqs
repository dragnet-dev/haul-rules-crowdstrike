// Dragnet [Container]: dragnet-container-2026-2937 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 2bb78b1e-6c6c-565a-a0ba-89c1ddc43220

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:5*)
| table([timestamp, ComputerName])
| limit(1000)
