// Dragnet [Ransomware]: dragnet-ransomware-2024-0023 — Mass File Rename (SilentRansomGroup)
// Status: deprecated | Level: high | ID: e987fd67-6eb2-53f2-a521-fe9b89194340

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
