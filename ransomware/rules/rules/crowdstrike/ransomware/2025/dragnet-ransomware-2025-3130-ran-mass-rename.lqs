// Dragnet [Ransomware]: dragnet-ransomware-2025-3130 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 62867126-104e-5af0-8bf7-869530b72018

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
