// Dragnet [Ransomware]: dragnet-ransomware-2024-0759 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 9af3de5b-faf8-5a58-9267-b8177bd9a176

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
