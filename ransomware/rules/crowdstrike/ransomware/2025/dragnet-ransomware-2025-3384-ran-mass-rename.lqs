// Dragnet [Ransomware]: dragnet-ransomware-2025-3384 — Mass File Rename (tridentlocker)
// Status: experimental | Level: high | ID: 72c6f4c3-464e-514a-9992-55a37e9772d1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
