// Dragnet [Ransomware]: dragnet-ransomware-2025-7769 — Mass File Rename (handala)
// Status: experimental | Level: high | ID: e1b8a154-3051-5967-aeb1-aae21224f517

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
