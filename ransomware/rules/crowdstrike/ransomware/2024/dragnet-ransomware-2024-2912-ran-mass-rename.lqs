// Dragnet [Ransomware]: dragnet-ransomware-2024-2912 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: f3a2c94f-c98b-5ecf-b5fd-f6df86cc2d32

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
