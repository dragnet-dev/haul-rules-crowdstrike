// Dragnet [Ransomware]: dragnet-ransomware-2025-0229 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: a34eb5a0-f3d8-5fae-9128-f9f7c96e5e4d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
