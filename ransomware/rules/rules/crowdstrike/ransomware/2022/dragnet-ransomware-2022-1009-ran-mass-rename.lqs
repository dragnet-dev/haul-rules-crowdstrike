// Dragnet [Ransomware]: dragnet-ransomware-2022-1009 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 161d1a98-c715-547e-991d-9d26a6b9e9a8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
