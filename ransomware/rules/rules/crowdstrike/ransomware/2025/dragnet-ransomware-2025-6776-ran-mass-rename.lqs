// Dragnet [Ransomware]: dragnet-ransomware-2025-6776 — Mass File Rename (termite)
// Status: experimental | Level: high | ID: 039da8e7-9f9d-5207-823d-76d1f834e8b1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
