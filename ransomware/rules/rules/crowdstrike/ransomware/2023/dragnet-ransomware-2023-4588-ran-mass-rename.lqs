// Dragnet [Ransomware]: dragnet-ransomware-2023-4588 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: f3b2df76-94b4-5110-8105-75d14c17de2a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
