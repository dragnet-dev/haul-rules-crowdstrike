// Dragnet [Ransomware]: dragnet-ransomware-2026-1679 — Mass File Rename (krybit)
// Status: stable | Level: high | ID: a92f590c-b6bd-522b-91ce-60a042531818

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
