// Dragnet [Ransomware]: dragnet-ransomware-2024-5123 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: c79603df-0159-572a-b6ab-fe11bcc2c093

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
