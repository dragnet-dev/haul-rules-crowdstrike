// Dragnet [Ransomware]: dragnet-ransomware-2024-5099 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: 3d134c53-fd21-5bd7-9835-18a5adca12db

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
