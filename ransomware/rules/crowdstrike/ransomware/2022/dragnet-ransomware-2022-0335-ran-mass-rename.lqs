// Dragnet [Ransomware]: dragnet-ransomware-2022-0335 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 385fe2b8-55e9-52c2-abdf-3d8c7669608e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
