// Dragnet [Ransomware]: dragnet-ransomware-2026-2137 — Mass File Rename (payload)
// Status: stable | Level: high | ID: 486d4566-e9ff-5e02-bc96-61bfab5750ed

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
