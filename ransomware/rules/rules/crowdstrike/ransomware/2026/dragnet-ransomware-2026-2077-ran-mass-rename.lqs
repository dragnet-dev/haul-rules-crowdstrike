// Dragnet [Ransomware]: dragnet-ransomware-2026-2077 — Mass File Rename (lockbit5)
// Status: stable | Level: high | ID: 34b6808d-25f8-554b-b3c3-38b4564830f4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
