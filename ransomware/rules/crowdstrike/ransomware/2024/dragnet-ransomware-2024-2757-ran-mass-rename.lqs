// Dragnet [Ransomware]: dragnet-ransomware-2024-2757 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 2f0a4e0d-74f1-5bcb-8da0-0a265cbcb93c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
