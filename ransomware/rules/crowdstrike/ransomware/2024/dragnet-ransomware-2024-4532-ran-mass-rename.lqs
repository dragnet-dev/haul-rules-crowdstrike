// Dragnet [Ransomware]: dragnet-ransomware-2024-4532 — Mass File Rename (nitrogen)
// Status: experimental | Level: high | ID: 50d0f01f-bcb8-52d7-8bb1-891608f11c65

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
