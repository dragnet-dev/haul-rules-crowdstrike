// Dragnet [Ransomware]: dragnet-ransomware-2020-0188 — Mass File Rename (revil)
// Status: deprecated | Level: high | ID: 549a8ae1-2047-55fc-ba97-1cd7f47e8019

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
