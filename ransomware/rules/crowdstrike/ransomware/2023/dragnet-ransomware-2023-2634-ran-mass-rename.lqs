// Dragnet [Ransomware]: dragnet-ransomware-2023-2634 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 0e6c040d-4eed-54f6-995f-d7937eb09fd9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
