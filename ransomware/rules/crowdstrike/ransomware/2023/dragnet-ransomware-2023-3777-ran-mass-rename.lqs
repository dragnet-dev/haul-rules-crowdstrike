// Dragnet [Ransomware]: dragnet-ransomware-2023-3777 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 71406c14-c40e-54aa-a89a-99542671d16e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
