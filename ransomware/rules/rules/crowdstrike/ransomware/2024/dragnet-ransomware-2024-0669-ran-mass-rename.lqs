// Dragnet [Ransomware]: dragnet-ransomware-2024-0669 — Mass File Rename (monti)
// Status: experimental | Level: high | ID: 849fd5c9-5931-5d50-9ae6-db4268615be0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
