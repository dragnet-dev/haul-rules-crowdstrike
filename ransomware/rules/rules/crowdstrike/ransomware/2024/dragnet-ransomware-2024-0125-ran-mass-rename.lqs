// Dragnet [Ransomware]: dragnet-ransomware-2024-0125 — Mass File Rename (cloak)
// Status: experimental | Level: high | ID: d536346e-7a75-5480-b795-e3edd68d8af7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
