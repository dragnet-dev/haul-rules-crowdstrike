// Dragnet [Ransomware]: dragnet-ransomware-2024-4527 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 88e391b7-afb7-5e29-9d1d-744e06b49834

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
