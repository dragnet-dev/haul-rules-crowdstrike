// Dragnet [Ransomware]: dragnet-ransomware-2024-2637 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: fac25d59-b9d9-50b3-b292-2339f84a80c3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
