// Dragnet [Ransomware]: dragnet-ransomware-2021-1131 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 8c841ab1-a2c2-5518-81cc-d3365987a522

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
