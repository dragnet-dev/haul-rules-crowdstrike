// Dragnet [Ransomware]: dragnet-ransomware-2024-1783 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: cc268a84-5204-5cd1-9cc3-168402774f19

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
