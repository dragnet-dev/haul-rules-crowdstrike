// Dragnet [Ransomware]: dragnet-ransomware-2025-2367 — Mass File Rename (J)
// Status: experimental | Level: high | ID: 26ae240c-4b2c-5502-9de0-6a84dc60f834

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
