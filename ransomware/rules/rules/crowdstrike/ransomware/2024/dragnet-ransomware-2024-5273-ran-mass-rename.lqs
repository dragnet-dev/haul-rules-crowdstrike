// Dragnet [Ransomware]: dragnet-ransomware-2024-5273 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 0184cfb3-08b1-5a3b-8a50-340bacdd007f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
