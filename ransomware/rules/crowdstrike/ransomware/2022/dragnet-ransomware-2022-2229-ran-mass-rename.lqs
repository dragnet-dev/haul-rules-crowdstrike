// Dragnet [Ransomware]: dragnet-ransomware-2022-2229 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 2f18a2e4-41c3-5f8c-812f-38b6336d78be

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
