// Dragnet [Ransomware]: dragnet-ransomware-2023-4464 — Mass File Rename (snatch)
// Status: experimental | Level: high | ID: 70dc7dab-26d0-5296-b86f-307cb09c558b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
