// Dragnet [Ransomware]: dragnet-ransomware-2024-5497 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: 8f1e41fc-2da6-50d3-b7d8-a88e4af48a50

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
