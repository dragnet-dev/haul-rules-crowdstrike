// Dragnet [Ransomware]: dragnet-ransomware-2025-2518 — Mass File Rename (interlock)
// Status: experimental | Level: high | ID: a97481af-064b-5206-af37-dd06f18898a4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
