// Dragnet [Ransomware]: dragnet-ransomware-2025-3875 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 24b7566b-d4c2-5e9b-b6f1-319f997c7cfa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
