// Dragnet [Ransomware]: dragnet-ransomware-2025-0985 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 0005f583-eb3a-5fa2-a450-de093035bc61

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
