// Dragnet [Ransomware]: dragnet-ransomware-2025-1565 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: f910707a-49b2-58e9-8175-425db1f9586d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
