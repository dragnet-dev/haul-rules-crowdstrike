// Dragnet [Ransomware]: dragnet-ransomware-2026-1993 — Mass File Rename (payload)
// Status: stable | Level: high | ID: c9153062-192c-592d-b082-450f918d55bb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
