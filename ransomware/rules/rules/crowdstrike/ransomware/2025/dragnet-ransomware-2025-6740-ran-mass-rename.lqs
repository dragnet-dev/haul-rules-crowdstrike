// Dragnet [Ransomware]: dragnet-ransomware-2025-6740 — Mass File Rename (medusalocker)
// Status: experimental | Level: high | ID: 046fda50-b76e-53e3-8883-22e8e658f427

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
