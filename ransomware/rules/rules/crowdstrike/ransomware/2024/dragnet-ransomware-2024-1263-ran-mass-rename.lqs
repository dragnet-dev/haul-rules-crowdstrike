// Dragnet [Ransomware]: dragnet-ransomware-2024-1263 — Mass File Rename (ransomhouse)
// Status: experimental | Level: high | ID: 0b40182e-d5c3-54dd-96c9-6415bf547a46

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
