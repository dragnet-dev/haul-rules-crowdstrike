// Dragnet [Ransomware]: dragnet-ransomware-2025-2534 — Mass File Rename (insomnia)
// Status: experimental | Level: high | ID: 37f29709-6fe6-589c-911c-911705904ff1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
