// Dragnet [Ransomware]: dragnet-ransomware-2021-0368 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 8e9d61de-a58a-582e-b44a-ab64c8403024

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
