// Dragnet [Container]: dragnet-container-2025-0552 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 7980927b-94c4-50ea-934d-820e4d971210

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *ubuntu:18.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
