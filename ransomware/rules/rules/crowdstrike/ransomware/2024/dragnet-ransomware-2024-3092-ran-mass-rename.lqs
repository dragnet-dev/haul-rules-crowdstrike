// Dragnet [Ransomware]: dragnet-ransomware-2024-3092 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: b66d8a96-3216-5fd3-9450-a8563a2188c1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
