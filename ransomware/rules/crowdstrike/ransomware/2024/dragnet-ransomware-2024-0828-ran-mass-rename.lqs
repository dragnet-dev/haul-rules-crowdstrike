// Dragnet [Ransomware]: dragnet-ransomware-2024-0828 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 512efba8-a189-52a8-bf9b-81915c5ddbc4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
