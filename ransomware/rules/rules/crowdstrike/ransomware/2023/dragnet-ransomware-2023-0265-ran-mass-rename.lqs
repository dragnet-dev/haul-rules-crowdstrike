// Dragnet [Ransomware]: dragnet-ransomware-2023-0265 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 3610be34-1815-56b2-8231-114f342f4298

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
