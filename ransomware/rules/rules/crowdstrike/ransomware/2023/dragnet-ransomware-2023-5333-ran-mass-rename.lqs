// Dragnet [Ransomware]: dragnet-ransomware-2023-5333 — Mass File Rename (rhysida)
// Status: experimental | Level: high | ID: 5a2f22d1-4397-522d-a275-db66c09d1a51

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
