// Dragnet [Ransomware]: dragnet-ransomware-2024-2488 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: fc23e206-9600-5424-9e9c-6da3fbe8a2b4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
