// Dragnet [Ransomware]: dragnet-ransomware-2024-3441 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: 903cb326-edf2-5e86-833e-3abade63bc60

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
