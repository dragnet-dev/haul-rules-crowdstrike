// Dragnet [Ransomware]: dragnet-ransomware-2021-0861 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 94dff2ae-50bf-5543-be76-d86fef135e72

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
