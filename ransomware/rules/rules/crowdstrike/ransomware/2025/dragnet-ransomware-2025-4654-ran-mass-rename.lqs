// Dragnet [Ransomware]: dragnet-ransomware-2025-4654 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: 98f881e0-f501-598c-9caa-a9212256a81c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
