// Dragnet [Ransomware]: dragnet-ransomware-2024-2225 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 5a4771ee-092f-5ff2-a4cd-b3fbbc24fbc8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
