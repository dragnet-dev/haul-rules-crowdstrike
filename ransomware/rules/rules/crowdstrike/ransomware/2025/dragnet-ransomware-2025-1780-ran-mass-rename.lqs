// Dragnet [Ransomware]: dragnet-ransomware-2025-1780 — Mass File Rename (bqtlock)
// Status: experimental | Level: high | ID: f2d55883-d9c4-5ea2-8460-344e7294d8fe

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
