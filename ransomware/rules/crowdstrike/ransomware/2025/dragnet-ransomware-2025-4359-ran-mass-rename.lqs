// Dragnet [Ransomware]: dragnet-ransomware-2025-4359 — Mass File Rename (direwolf)
// Status: experimental | Level: high | ID: 4630b2b6-64e5-5636-a972-f0c8a80247d1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
