// Dragnet [Ransomware]: dragnet-ransomware-2023-1867 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 6d621a04-d589-52fb-8c4d-bb294e4ce0a8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
