// Dragnet [Ransomware]: dragnet-ransomware-2024-1109 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: d244dfd3-5f22-5181-a964-c2a0403c34a1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
