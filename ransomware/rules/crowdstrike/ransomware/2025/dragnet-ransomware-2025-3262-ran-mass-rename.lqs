// Dragnet [Ransomware]: dragnet-ransomware-2025-3262 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: 77c28a4e-a9d0-54c0-a543-a660e5a95c20

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
