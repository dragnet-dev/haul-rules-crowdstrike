// Dragnet [Ransomware]: dragnet-ransomware-2022-0752 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: afe6e39f-3b8a-5c06-9d19-1c28fc2d2076

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
