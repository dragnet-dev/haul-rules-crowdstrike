// Dragnet [Ransomware]: dragnet-ransomware-2022-0261 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: bcc33b25-0e43-5bb3-9d98-f8f8d45e50b0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
