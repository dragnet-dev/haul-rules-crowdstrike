// Dragnet [Ransomware]: dragnet-ransomware-2024-0477 — Mass File Rename (meow)
// Status: experimental | Level: high | ID: e8f7602d-d897-5528-b9c5-445b082d6ef5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
