// Dragnet [Ransomware]: dragnet-ransomware-2024-5582 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 96c057a9-c73c-5bd7-a209-892e19dea476

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
