// Dragnet [Ransomware]: dragnet-ransomware-2023-1672 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 78efebd3-433a-50ba-aaab-1d382bdfc359

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
