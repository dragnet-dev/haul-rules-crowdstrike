// Dragnet [Ransomware]: dragnet-ransomware-2025-1797 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 7e9f1459-61fb-558e-ab4d-d0cc6d902dd7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
