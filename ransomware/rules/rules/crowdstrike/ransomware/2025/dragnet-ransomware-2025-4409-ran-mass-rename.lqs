// Dragnet [Ransomware]: dragnet-ransomware-2025-4409 — Mass File Rename (interlock)
// Status: experimental | Level: high | ID: 8f554767-aa52-5959-894e-add43b6c4ade

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
