// Dragnet [Ransomware]: dragnet-ransomware-2022-2402 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 7f74631a-d89b-5919-bf1e-2a44ad5d3c91

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
