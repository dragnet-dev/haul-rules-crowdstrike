// Dragnet [Ransomware]: dragnet-ransomware-2024-0644 — Mass File Rename (flocker)
// Status: experimental | Level: high | ID: 81142672-aab0-5144-9153-1f984261c8c9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
