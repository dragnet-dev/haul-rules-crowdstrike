// Dragnet [Ransomware]: dragnet-ransomware-2026-2603 — Mass File Rename (ransomhouse)
// Status: stable | Level: high | ID: 85225957-d2a0-5d0d-a266-c7da97af2e77

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
