// Dragnet [Ransomware]: dragnet-ransomware-2025-4783 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: ce87fea9-5de6-5562-a601-43f7a109497d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
