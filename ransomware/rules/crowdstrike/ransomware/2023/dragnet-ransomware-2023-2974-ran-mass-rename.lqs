// Dragnet [Ransomware]: dragnet-ransomware-2023-2974 — Mass File Rename (moneymessage)
// Status: experimental | Level: high | ID: 68734ac5-0d5a-5a4c-945a-49eb62a68340

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
