// Dragnet [Ransomware]: dragnet-ransomware-2022-1652 — Mass File Rename (blackbasta)
// Status: deprecated | Level: high | ID: 284295a0-99dd-58a1-92d4-8b4cdb6aa90d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
