// Dragnet [Ransomware]: dragnet-ransomware-2023-5195 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: b3905a13-56c6-5c5c-8026-18fc5226f0db

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
