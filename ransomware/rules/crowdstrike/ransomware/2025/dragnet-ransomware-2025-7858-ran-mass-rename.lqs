// Dragnet [Ransomware]: dragnet-ransomware-2025-7858 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 36737405-cf7c-53b4-9fdd-ff4c8b0ef1df

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
