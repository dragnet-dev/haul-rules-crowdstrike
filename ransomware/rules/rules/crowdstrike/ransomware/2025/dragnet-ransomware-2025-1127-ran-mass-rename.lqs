// Dragnet [Ransomware]: dragnet-ransomware-2025-1127 — Mass File Rename (threeam)
// Status: experimental | Level: high | ID: 24486130-b867-5922-af84-042126b88393

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
