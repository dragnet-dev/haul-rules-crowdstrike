// Dragnet [Ransomware]: dragnet-ransomware-2023-0270 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 025099be-738b-563b-8c23-eaa1d28dc1a0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
