// Dragnet [Ransomware]: dragnet-ransomware-2024-5888 — Mass File Rename (rhysida)
// Status: experimental | Level: high | ID: c4cfce01-a0d9-5d6d-8c4f-f176558cfac8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
