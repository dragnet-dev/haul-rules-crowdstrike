// Dragnet [Ransomware]: dragnet-ransomware-2024-2275 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: c88e8c22-9d44-599c-8f3b-29bc0fc6e0ee

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
