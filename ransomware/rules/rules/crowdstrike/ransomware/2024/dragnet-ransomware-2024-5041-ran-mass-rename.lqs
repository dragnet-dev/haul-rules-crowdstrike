// Dragnet [Ransomware]: dragnet-ransomware-2024-5041 — Mass File Rename (flocker)
// Status: experimental | Level: high | ID: 7cd90994-3d09-5351-a78c-ff36f8d4bbda

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
