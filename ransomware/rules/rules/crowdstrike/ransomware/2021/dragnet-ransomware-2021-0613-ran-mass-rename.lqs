// Dragnet [Ransomware]: dragnet-ransomware-2021-0613 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: e7675538-0b6a-5aba-9cd5-db87ed01a482

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
