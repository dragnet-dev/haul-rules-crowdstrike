// Dragnet [Ransomware]: dragnet-ransomware-2024-3434 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: c83fe404-20b3-5baa-8143-c3055662a0b3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
