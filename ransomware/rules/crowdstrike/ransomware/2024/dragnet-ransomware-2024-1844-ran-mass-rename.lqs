// Dragnet [Ransomware]: dragnet-ransomware-2024-1844 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 85f96ed0-72fb-5618-9614-3e53c545df35

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
