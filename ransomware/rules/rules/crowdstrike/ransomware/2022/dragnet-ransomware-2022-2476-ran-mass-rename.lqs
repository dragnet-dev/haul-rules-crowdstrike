// Dragnet [Ransomware]: dragnet-ransomware-2022-2476 — Mass File Rename (vicesociety)
// Status: deprecated | Level: high | ID: d847ecd1-fafa-5ff1-9da9-7e1c1ba11d11

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
