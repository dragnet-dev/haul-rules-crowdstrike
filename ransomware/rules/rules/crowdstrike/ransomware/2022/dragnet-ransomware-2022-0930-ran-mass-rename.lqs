// Dragnet [Ransomware]: dragnet-ransomware-2022-0930 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: c3db51a3-7e11-5268-aba3-7f273c4140c3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
