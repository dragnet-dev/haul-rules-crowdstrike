// Dragnet [Ransomware]: dragnet-ransomware-2021-1181 — Mass File Rename (azroteam)
// Status: deprecated | Level: high | ID: a323995f-b96e-581d-9304-d362171a0e6b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
