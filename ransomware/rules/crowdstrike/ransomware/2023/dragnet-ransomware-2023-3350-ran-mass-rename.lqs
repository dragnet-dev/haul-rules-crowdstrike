// Dragnet [Ransomware]: dragnet-ransomware-2023-3350 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 2827638d-6d2f-5201-8a5d-c30d48cc2675

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
