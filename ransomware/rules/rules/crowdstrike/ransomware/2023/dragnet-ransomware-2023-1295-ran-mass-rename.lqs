// Dragnet [Ransomware]: dragnet-ransomware-2023-1295 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 75eb3105-5fc1-5f43-b9d6-f6e11e3d7863

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
