// Dragnet [Ransomware]: dragnet-ransomware-2025-7605 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 50c810d9-aed1-58b1-a4f5-df415df27b86

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
