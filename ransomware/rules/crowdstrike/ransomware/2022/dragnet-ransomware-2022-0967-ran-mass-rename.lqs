// Dragnet [Ransomware]: dragnet-ransomware-2022-0967 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: df50847f-c8f0-5875-a820-f97f25b52b6b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
