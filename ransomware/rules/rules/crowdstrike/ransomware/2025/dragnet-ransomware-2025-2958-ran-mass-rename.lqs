// Dragnet [Ransomware]: dragnet-ransomware-2025-2958 — Mass File Rename (payoutsking)
// Status: experimental | Level: high | ID: e2f65e4d-0065-5379-a5ec-6a95186238a2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
