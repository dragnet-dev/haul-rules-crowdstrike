// Dragnet [Ransomware]: dragnet-ransomware-2025-7157 — Mass File Rename (interlock)
// Status: experimental | Level: high | ID: 835ec0aa-3dc6-5e89-b979-ed8f25969f1a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
