// Dragnet [Ransomware]: dragnet-ransomware-2022-2695 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 1344a68d-3681-598c-97c4-add85844ac56

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
