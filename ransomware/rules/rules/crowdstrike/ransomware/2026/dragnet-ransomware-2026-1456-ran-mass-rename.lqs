// Dragnet [Ransomware]: dragnet-ransomware-2026-1456 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 498a9441-3d73-5841-ba4f-e2948622268a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
