// Dragnet [Ransomware]: dragnet-ransomware-2024-5747 — Mass File Rename (argonauts)
// Status: experimental | Level: high | ID: 4d362e09-2d06-5aa8-aa82-3adf234841c3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
