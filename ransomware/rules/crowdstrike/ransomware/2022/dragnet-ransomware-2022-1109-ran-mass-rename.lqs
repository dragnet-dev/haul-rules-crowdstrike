// Dragnet [Ransomware]: dragnet-ransomware-2022-1109 — Mass File Rename (stormous)
// Status: deprecated | Level: high | ID: e2e34f11-4da9-5e3e-807e-b422ab08fc9f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
