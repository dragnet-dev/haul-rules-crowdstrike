// Dragnet [Ransomware]: dragnet-ransomware-2022-2756 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: bf1ccd57-54e4-54cc-930b-ac74f43abce9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
