// Dragnet [Ransomware]: dragnet-ransomware-2023-0236 — Mass File Rename (rhysida)
// Status: deprecated | Level: high | ID: 9f7927dd-c900-520d-8b16-8768d05a75a2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
