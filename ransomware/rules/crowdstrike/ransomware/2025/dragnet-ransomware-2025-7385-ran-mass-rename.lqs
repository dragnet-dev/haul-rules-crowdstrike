// Dragnet [Ransomware]: dragnet-ransomware-2025-7385 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: ed701531-8417-5218-97a6-dee16dbb0a43

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
