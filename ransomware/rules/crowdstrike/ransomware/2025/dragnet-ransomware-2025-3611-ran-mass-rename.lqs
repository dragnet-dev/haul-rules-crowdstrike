// Dragnet [Ransomware]: dragnet-ransomware-2025-3611 — Mass File Rename (bert)
// Status: experimental | Level: high | ID: ad84d851-b102-5e15-820c-3e754bd1db1a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
