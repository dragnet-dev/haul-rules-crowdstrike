// Dragnet [Ransomware]: dragnet-ransomware-2023-5096 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 15e17771-cbbd-5ff2-9a73-a705aaa8b8b0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
