// Dragnet [Ransomware]: dragnet-ransomware-2021-0496 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 38bc014a-9b45-506c-a470-898225ada9d2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
