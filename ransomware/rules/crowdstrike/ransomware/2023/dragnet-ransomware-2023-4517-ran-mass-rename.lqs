// Dragnet [Ransomware]: dragnet-ransomware-2023-4517 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 70236186-0a37-5dbf-85cc-d64514e1834f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
