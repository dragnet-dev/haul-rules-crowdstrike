// Dragnet [Container]: dragnet-container-2026-2366 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 3a705135-217d-5812-bb81-3cb1e9ac722e

#event_simpleName=*
| (ImageFileName = *alpine:3.23* OR ImageFileName = *alpine edge:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
