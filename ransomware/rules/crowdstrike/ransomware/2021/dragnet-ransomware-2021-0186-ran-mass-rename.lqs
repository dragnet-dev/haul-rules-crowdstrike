// Dragnet [Ransomware]: dragnet-ransomware-2021-0186 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 696fa8cc-92f2-54b6-8524-775f0fd03ec9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
