// Dragnet [Ransomware]: dragnet-ransomware-2023-4880 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 210534db-a09f-554e-bc83-06b899463f30

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
