// Dragnet [Ransomware]: dragnet-ransomware-2023-0120 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 7f1fa0f9-26af-5a49-84d6-2a7e46670a01

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
