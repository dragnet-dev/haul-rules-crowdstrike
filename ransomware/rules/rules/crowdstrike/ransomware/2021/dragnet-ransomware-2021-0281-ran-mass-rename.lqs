// Dragnet [Ransomware]: dragnet-ransomware-2021-0281 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 46540ccb-25dd-5c0b-bbb1-413857922e47

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
