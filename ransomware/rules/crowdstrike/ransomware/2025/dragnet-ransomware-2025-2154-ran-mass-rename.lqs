// Dragnet [Ransomware]: dragnet-ransomware-2025-2154 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 39480f62-0117-5f29-a358-9a34e79d2c4d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
