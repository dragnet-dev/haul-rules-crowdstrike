// Dragnet [Ransomware]: dragnet-ransomware-2024-4952 — Mass File Rename (cicada3301)
// Status: experimental | Level: high | ID: 59aced6e-78e2-5f64-a161-74288f4ecac3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
