// Dragnet [Ransomware]: dragnet-ransomware-2022-2113 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 82d23ccf-7b8b-5fbe-9ebf-ed9958753b9e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
