// Dragnet [Ransomware]: dragnet-ransomware-2024-1040 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 73a61c2e-152e-5af8-8a4c-f949a735ce4a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
