// Dragnet [Ransomware]: dragnet-ransomware-2024-4661 — Mass File Rename (stormous)
// Status: deprecated | Level: high | ID: a7d8445c-c440-5d12-a16d-1ecb09f051d3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
