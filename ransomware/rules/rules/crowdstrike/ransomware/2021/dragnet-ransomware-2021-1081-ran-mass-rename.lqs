// Dragnet [Ransomware]: dragnet-ransomware-2021-1081 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: cb4eaef5-4207-57a2-880c-da5145a7626c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
