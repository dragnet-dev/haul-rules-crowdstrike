// Dragnet [Ransomware]: dragnet-ransomware-2025-0876 — Mass File Rename (stormous)
// Status: experimental | Level: high | ID: daf7300b-5643-585a-9d4c-8a0f663e44ac

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
