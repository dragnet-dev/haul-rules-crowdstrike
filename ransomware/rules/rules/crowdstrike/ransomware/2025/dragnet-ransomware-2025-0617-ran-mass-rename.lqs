// Dragnet [Ransomware]: dragnet-ransomware-2025-0617 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: de9de0ee-08c2-5b5b-9340-97a420197e04

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
