// Dragnet [Ransomware]: dragnet-ransomware-2023-1375 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: d49cd2ce-ccd5-533a-a3b8-26c3bc91e0e3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
