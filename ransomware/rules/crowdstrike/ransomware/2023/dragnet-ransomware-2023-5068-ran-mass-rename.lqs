// Dragnet [Ransomware]: dragnet-ransomware-2023-5068 — Mass File Rename (noescape)
// Status: experimental | Level: high | ID: 88ee6059-62dc-5050-80ba-6b69e6a2006f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
