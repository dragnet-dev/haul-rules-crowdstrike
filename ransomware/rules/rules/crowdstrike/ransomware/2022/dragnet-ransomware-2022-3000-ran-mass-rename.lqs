// Dragnet [Ransomware]: dragnet-ransomware-2022-3000 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: 976145ae-0169-57ef-8b5a-17c6cbbb20c2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
