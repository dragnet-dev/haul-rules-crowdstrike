// Dragnet [Ransomware]: dragnet-ransomware-2023-2597 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 71ea91b2-328d-5026-9247-09e8a656eb81

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
