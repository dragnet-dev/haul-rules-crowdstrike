// Dragnet [Ransomware]: dragnet-ransomware-2022-2494 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: eee6b985-ec4c-5550-bfa9-99e12683e11c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
