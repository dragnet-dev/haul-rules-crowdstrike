// Dragnet [Ransomware]: dragnet-ransomware-2026-0486 — Mass File Rename (lockbit5)
// Status: test | Level: high | ID: 68eb5768-bf12-5786-893a-8d33a3299e05

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
