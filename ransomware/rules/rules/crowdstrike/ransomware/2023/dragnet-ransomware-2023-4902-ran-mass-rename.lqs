// Dragnet [Ransomware]: dragnet-ransomware-2023-4902 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: c9aa656b-2b44-5c92-85f9-1e81808bc5e3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
