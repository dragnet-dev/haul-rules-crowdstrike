// Dragnet [Ransomware]: dragnet-ransomware-2024-1470 — Mass File Rename (play)
// Status: experimental | Level: high | ID: f774ac9f-87cf-5e70-8b25-d2966cc64093

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
