// Dragnet [Ransomware]: dragnet-ransomware-2024-2194 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 50e7f4cb-dce7-5b49-b1e4-9af0efce02d7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
