// Dragnet [Ransomware]: dragnet-ransomware-2025-6573 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 2cd62b4e-6455-5c89-a7fa-feb694d92896

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
