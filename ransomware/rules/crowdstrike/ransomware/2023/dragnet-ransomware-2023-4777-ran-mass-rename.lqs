// Dragnet [Ransomware]: dragnet-ransomware-2023-4777 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: ce4ec2ca-9de8-5d5c-b9cf-7b9c784ac566

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
