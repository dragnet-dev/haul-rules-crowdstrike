// Dragnet [Ransomware]: dragnet-ransomware-2025-7488 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 88b96bb8-b46a-5f0d-b576-a7b3124b47c9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
