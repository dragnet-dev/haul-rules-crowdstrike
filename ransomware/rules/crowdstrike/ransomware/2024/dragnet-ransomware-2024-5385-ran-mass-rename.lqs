// Dragnet [Ransomware]: dragnet-ransomware-2024-5385 — Mass File Rename (play)
// Status: experimental | Level: high | ID: c755fb51-1b94-5efc-9198-cd4789767ce2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
