// Dragnet [Ransomware]: dragnet-ransomware-2024-4422 — Mass File Rename (raworld)
// Status: experimental | Level: high | ID: 5ae5bbd6-15b7-5a95-a489-cde1e37e5c07

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
