// Dragnet [Ransomware]: dragnet-ransomware-2025-6466 — Mass File Rename (global)
// Status: deprecated | Level: high | ID: 7429a916-048d-57e2-b3f0-21069683241a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
