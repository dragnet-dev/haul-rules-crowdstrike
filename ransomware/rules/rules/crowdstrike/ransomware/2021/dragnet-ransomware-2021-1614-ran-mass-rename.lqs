// Dragnet [Ransomware]: dragnet-ransomware-2021-1614 — Mass File Rename (avaddon)
// Status: deprecated | Level: high | ID: 06443601-0046-5610-a367-078001076fe5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
