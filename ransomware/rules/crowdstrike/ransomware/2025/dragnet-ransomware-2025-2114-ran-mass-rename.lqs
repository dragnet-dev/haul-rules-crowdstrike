// Dragnet [Ransomware]: dragnet-ransomware-2025-2114 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: ed7d4435-9b56-5f60-8b3f-2bba1111b50d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
