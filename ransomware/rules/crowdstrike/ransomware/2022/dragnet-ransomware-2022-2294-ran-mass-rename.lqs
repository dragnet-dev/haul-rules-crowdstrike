// Dragnet [Ransomware]: dragnet-ransomware-2022-2294 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 93492b4c-fcfd-5ab8-b0db-4a0958914466

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
