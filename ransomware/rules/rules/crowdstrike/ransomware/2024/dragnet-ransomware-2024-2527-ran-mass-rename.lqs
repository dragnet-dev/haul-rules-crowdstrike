// Dragnet [Ransomware]: dragnet-ransomware-2024-2527 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: 4a86a31a-8210-5f0d-816d-492ea820c464

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
