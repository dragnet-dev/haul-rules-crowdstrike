// Dragnet [Ransomware]: dragnet-ransomware-2021-0003 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 8dcb5943-dd6f-5259-9653-533545ebe6a5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
