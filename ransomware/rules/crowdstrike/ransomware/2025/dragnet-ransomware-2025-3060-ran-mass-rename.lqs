// Dragnet [Ransomware]: dragnet-ransomware-2025-3060 — Mass File Rename (worldleaks)
// Status: experimental | Level: high | ID: ee7dd198-7f82-5522-8c25-46cb153e24ee

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
