// Dragnet [Ransomware]: dragnet-ransomware-2022-0142 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: c76de199-b0fa-5aa3-bca1-f418694453bf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
