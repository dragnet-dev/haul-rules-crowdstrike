// Dragnet [Ransomware]: dragnet-ransomware-2024-4169 — Mass File Rename (meow)
// Status: experimental | Level: high | ID: 9331becc-910a-55a5-9b71-d6b534b5907b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
