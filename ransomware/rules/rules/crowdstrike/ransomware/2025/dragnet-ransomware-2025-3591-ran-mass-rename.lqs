// Dragnet [Ransomware]: dragnet-ransomware-2025-3591 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 3f6fbb69-3d8b-5a84-8c2f-25724c8dc46f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
