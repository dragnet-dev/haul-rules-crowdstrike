// Dragnet [Ransomware]: dragnet-ransomware-2022-3069 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 0f9f81c6-d7af-5f4a-8ffe-7f41c705cfb8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
