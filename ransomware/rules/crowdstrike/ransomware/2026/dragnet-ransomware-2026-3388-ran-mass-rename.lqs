// Dragnet [Ransomware]: dragnet-ransomware-2026-3388 — Mass File Rename (lockbit5)
// Status: stable | Level: high | ID: 4279b925-1bed-5b48-b1f1-3d5a06f9b175

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
