// Dragnet [Ransomware]: dragnet-ransomware-2025-5335 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: b8848efb-0ec3-537a-a0af-5b084889b2cc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
