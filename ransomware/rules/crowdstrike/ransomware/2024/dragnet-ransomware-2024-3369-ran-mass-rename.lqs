// Dragnet [Ransomware]: dragnet-ransomware-2024-3369 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 48439009-7271-5344-aa3a-0d3d5b3af195

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
