// Dragnet [Ransomware]: dragnet-ransomware-2020-0096 — Mass File Rename (doppelpaymer)
// Status: deprecated | Level: high | ID: fa1efa4d-8ac5-5522-b176-2c82a0fc067b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
