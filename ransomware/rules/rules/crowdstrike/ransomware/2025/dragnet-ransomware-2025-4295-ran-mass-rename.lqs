// Dragnet [Ransomware]: dragnet-ransomware-2025-4295 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: 2365ebdf-56d8-5da8-94ac-ffc2fe702f73

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
