// Dragnet [Ransomware]: dragnet-ransomware-2026-1167 — Mass File Rename (thegentlemen)
// Status: stable | Level: high | ID: 69e994f9-81fb-5b34-aac4-341c15d502ae

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
