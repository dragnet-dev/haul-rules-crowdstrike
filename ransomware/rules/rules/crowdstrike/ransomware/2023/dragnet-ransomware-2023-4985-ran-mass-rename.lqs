// Dragnet [Ransomware]: dragnet-ransomware-2023-4985 — Mass File Rename (raznatovic)
// Status: experimental | Level: high | ID: fba2adb8-d730-5040-b9bf-86bed27eb8ed

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
