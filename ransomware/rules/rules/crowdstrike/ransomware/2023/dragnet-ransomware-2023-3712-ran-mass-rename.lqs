// Dragnet [Ransomware]: dragnet-ransomware-2023-3712 — Mass File Rename (play)
// Status: deprecated | Level: high | ID: 17c76212-0858-5575-be59-b17a12f14d36

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
