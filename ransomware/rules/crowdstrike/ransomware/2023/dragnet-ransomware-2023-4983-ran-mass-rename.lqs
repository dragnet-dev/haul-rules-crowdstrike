// Dragnet [Ransomware]: dragnet-ransomware-2023-4983 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 351f4c88-1c99-5ff1-87b7-1a7fa75b9896

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
