// Dragnet [Ransomware]: dragnet-ransomware-2023-5252 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: e578e170-1944-5023-bbcd-85d9c66967be

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
