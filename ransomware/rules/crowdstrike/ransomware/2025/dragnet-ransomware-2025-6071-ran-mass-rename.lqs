// Dragnet [Ransomware]: dragnet-ransomware-2025-6071 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: 04b84ef3-3c95-590a-816c-ac3603f0c772

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
