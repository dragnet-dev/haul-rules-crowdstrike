// Dragnet [Ransomware]: dragnet-ransomware-2024-0757 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: caabcf9a-c33e-5c52-bed8-7860f6f40405

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
