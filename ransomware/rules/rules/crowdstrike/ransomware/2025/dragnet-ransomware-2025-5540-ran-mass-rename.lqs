// Dragnet [Ransomware]: dragnet-ransomware-2025-5540 — Mass File Rename (shinyhunters)
// Status: experimental | Level: high | ID: b01691e3-527a-5a8a-9fa3-189d20223fdd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
