// Dragnet [Ransomware]: dragnet-ransomware-2025-6394 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: ab9c0d1b-9a4a-5ecc-8cb6-3f71479792d7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
