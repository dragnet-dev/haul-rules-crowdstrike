// Dragnet [Ransomware]: dragnet-ransomware-2021-0525 — Mass File Rename (avaddon)
// Status: deprecated | Level: high | ID: 471c212e-7cae-5248-992f-9609528528c8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
