// Dragnet [Ransomware]: dragnet-ransomware-2025-5054 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 18a980a4-5f78-5cc6-9e30-9c90020a85e8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
