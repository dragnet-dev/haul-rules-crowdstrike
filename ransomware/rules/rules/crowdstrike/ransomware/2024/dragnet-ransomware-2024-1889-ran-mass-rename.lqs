// Dragnet [Ransomware]: dragnet-ransomware-2024-1889 — Mass File Rename (cicada3301)
// Status: experimental | Level: high | ID: 8845608d-f2b7-5947-a7e0-677fcd92604e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
