// Dragnet [Ransomware]: dragnet-ransomware-2022-0400 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 7d4a3a2a-1428-54ca-a88a-d5b995b74176

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
