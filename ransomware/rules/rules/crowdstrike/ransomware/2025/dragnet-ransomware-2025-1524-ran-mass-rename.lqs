// Dragnet [Ransomware]: dragnet-ransomware-2025-1524 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: d5f2de9c-d8a3-5ffe-b1ad-ff11b2c1be26

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
