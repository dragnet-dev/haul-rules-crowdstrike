// Dragnet [Ransomware]: dragnet-ransomware-2023-4250 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: de8adb3a-8e09-5d48-bc03-715bdc5f2383

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
