// Dragnet [Ransomware]: dragnet-ransomware-2021-0440 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: eef7f680-956e-5cd4-8335-23811c27888e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
