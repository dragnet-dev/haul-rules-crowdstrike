// Dragnet [Ransomware]: dragnet-ransomware-2023-0378 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 84784c82-7cd9-572a-ad4e-93df2f5cd1fc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
