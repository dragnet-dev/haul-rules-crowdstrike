// Dragnet [Ransomware]: dragnet-ransomware-2024-2865 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: d09244a3-0fb5-5a12-a1a7-cd056d25458c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
