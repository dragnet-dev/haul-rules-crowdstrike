// Dragnet [Ransomware]: dragnet-ransomware-2024-4779 — Mass File Rename (play)
// Status: experimental | Level: high | ID: dbb45b54-d21c-5168-bad4-e3220f4b508e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
