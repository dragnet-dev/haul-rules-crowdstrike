// Dragnet [Ransomware]: dragnet-ransomware-2023-3106 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 4a1353a9-a9ef-5088-a88e-ad725e508d49

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
