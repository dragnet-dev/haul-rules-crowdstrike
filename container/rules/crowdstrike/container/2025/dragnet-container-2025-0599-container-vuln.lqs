// Dragnet [Container]: dragnet-container-2025-0599 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 9ef45efd-5921-5c30-96ef-0daaf324d483

#event_simpleName=*
| (ImageFileName = *almalinux:8* OR ImageFileName = *amazonlinux:2* OR ImageFileName = *amazonlinux:2023* OR ImageFileName = *azure linux:3.0* OR ImageFileName = *cbl-mariner:2.0* OR ImageFileName = *chainguard:* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:8* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:22.04* OR ImageFileName = *ubuntu:24.04* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
