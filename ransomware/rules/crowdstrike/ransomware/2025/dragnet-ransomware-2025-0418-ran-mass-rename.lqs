// Dragnet [Ransomware]: dragnet-ransomware-2025-0418 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 4e18da5d-3dc7-5523-aa2a-af1f2553b168

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
