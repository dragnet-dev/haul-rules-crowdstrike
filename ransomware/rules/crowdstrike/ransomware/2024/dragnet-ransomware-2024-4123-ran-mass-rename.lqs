// Dragnet [Ransomware]: dragnet-ransomware-2024-4123 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: e431dbb4-fb75-57a2-88c3-e86761e98c7f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
