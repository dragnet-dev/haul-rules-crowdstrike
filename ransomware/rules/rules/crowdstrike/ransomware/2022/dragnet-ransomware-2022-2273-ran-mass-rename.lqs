// Dragnet [Ransomware]: dragnet-ransomware-2022-2273 — Mass File Rename (lv)
// Status: deprecated | Level: high | ID: 80cfbfd9-fa29-51a9-ab20-879b04bccffe

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
