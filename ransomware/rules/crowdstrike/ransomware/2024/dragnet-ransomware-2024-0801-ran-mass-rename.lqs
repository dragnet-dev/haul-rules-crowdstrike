// Dragnet [Ransomware]: dragnet-ransomware-2024-0801 — Mass File Rename (embargo)
// Status: experimental | Level: high | ID: 41e85531-f898-5df4-9f11-42a54494c4e4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
