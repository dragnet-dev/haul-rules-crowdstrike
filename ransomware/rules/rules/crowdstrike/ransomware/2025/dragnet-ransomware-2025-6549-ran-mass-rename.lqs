// Dragnet [Ransomware]: dragnet-ransomware-2025-6549 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: 8abb9552-763d-5169-bf57-f2c56d616206

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
