// Dragnet [Ransomware]: dragnet-ransomware-2024-4920 — Mass File Rename (stormous)
// Status: deprecated | Level: high | ID: c200212e-fef5-57c1-a52a-c411475fce11

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
