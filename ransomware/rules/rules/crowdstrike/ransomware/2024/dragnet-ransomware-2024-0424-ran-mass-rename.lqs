// Dragnet [Ransomware]: dragnet-ransomware-2024-0424 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 597c52de-2973-55e6-b529-7cc6f26b783b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
