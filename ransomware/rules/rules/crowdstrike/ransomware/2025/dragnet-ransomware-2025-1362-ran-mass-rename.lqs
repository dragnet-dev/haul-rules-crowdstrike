// Dragnet [Ransomware]: dragnet-ransomware-2025-1362 — Mass File Rename (rhysida)
// Status: deprecated | Level: high | ID: f729f6d1-cce3-52fa-9925-9a103f0e4f1e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
