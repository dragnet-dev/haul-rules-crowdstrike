// Dragnet [Ransomware]: dragnet-ransomware-2024-1415 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 20dd6686-39b3-58fe-a293-b3c9894635e2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
