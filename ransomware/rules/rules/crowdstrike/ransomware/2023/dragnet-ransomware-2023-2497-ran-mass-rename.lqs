// Dragnet [Ransomware]: dragnet-ransomware-2023-2497 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 2f81ca85-0a23-5ad5-b24e-d050fdbb0ee2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
