// Dragnet [Ransomware]: dragnet-ransomware-2024-1914 — Mass File Rename (meow)
// Status: experimental | Level: high | ID: baa867c9-1aba-5211-990d-ffb90df543b7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
