// Dragnet [Ransomware]: dragnet-ransomware-2024-0096 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 6243c5d9-1d98-56cf-87fb-e21f81a136ae

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
