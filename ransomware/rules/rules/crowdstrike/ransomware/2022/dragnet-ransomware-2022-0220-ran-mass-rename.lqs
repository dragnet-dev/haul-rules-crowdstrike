// Dragnet [Ransomware]: dragnet-ransomware-2022-0220 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: fd49b93f-9f27-509b-aeff-41d549e40c71

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
