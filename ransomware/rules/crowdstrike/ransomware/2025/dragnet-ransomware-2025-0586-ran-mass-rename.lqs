// Dragnet [Ransomware]: dragnet-ransomware-2025-0586 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 2ed8aec2-9af2-5285-96c4-c414235af0a7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
