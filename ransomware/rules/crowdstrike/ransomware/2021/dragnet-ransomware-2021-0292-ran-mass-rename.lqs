// Dragnet [Ransomware]: dragnet-ransomware-2021-0292 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 1612228f-fae2-518f-8fdd-22bbb22bd3ad

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
