// Dragnet [Ransomware]: dragnet-ransomware-2025-6269 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 3e6151d4-5c8b-51d5-96b0-48db78e69510

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
