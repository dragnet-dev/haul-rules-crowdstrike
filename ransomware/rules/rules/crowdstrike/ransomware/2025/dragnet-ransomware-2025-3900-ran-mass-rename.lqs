// Dragnet [Ransomware]: dragnet-ransomware-2025-3900 — Mass File Rename (handala)
// Status: experimental | Level: high | ID: 8029bc88-6beb-5e33-a97a-a94137f179ad

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
