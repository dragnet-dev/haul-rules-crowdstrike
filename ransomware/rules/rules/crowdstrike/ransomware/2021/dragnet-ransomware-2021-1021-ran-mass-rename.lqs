// Dragnet [Ransomware]: dragnet-ransomware-2021-1021 — Mass File Rename (avaddon)
// Status: deprecated | Level: high | ID: 3370b77a-df1b-52e3-a9c4-915f7a36235c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
