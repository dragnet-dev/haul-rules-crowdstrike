// Dragnet [Ransomware]: dragnet-ransomware-2024-3942 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: 84beb5cb-182b-5a9b-a283-d51e39b0f2e8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
