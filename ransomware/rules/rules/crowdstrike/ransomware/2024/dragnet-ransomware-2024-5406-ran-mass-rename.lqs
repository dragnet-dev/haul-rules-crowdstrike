// Dragnet [Ransomware]: dragnet-ransomware-2024-5406 — Mass File Rename (handala)
// Status: experimental | Level: high | ID: 6a78aef7-800b-5a75-98bd-8c4892305939

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
