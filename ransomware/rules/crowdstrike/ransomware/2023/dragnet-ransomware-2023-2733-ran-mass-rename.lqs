// Dragnet [Ransomware]: dragnet-ransomware-2023-2733 — Mass File Rename (royal)
// Status: experimental | Level: high | ID: c746dbd1-d503-5dd0-a19e-726cdc3ed61e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
