// Dragnet [Ransomware]: dragnet-ransomware-2025-5539 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: a8d2b103-c4bc-522f-a004-a84efc1905ee

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
