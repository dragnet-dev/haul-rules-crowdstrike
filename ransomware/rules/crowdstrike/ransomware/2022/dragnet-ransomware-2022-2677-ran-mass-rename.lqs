// Dragnet [Ransomware]: dragnet-ransomware-2022-2677 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: ba65f5bb-0240-5134-be67-c8046b60d1a6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
