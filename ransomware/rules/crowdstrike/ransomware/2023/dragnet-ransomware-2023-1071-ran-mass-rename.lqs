// Dragnet [Ransomware]: dragnet-ransomware-2023-1071 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 8a7821a8-38f1-524a-bd8c-a60e46d5c21f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
