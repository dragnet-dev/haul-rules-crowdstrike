// Dragnet [Ransomware]: dragnet-ransomware-2025-2010 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 80e49bd7-77e1-52ed-9e18-b4f11b888d83

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
