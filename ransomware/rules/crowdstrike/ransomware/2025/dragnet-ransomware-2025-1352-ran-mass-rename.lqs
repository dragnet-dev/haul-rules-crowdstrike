// Dragnet [Ransomware]: dragnet-ransomware-2025-1352 — Mass File Rename (sinobi)
// Status: experimental | Level: high | ID: dca9b40b-0a57-5e10-873a-4c70b9c931ac

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
