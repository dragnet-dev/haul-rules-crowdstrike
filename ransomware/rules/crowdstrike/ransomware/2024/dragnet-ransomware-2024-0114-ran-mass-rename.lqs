// Dragnet [Ransomware]: dragnet-ransomware-2024-0114 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 4b77ba2d-d33b-5d3e-b805-0404963e5c15

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
