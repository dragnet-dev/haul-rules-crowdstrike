// Dragnet [Ransomware]: dragnet-ransomware-2025-1701 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 0d2d1e1b-3bc5-5fa7-a3ab-293939abd467

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
