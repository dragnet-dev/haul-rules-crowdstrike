// Dragnet [Ransomware]: dragnet-ransomware-2026-1634 — Mass File Rename (lamashtu)
// Status: stable | Level: high | ID: 1b5687e8-4392-50d1-9ceb-fd54e2e16915

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
