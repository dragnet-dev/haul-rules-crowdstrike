// Dragnet [Ransomware]: dragnet-ransomware-2024-4641 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 5f648624-1332-52df-8b9a-d115b51f60e7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
