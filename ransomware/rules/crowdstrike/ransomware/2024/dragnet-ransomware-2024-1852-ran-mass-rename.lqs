// Dragnet [Ransomware]: dragnet-ransomware-2024-1852 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 41262649-f714-5564-b618-a027202bf09a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
