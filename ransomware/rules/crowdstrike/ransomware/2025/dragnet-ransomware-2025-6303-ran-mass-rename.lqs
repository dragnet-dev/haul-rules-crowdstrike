// Dragnet [Ransomware]: dragnet-ransomware-2025-6303 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: c4282ad6-eca5-5ea5-b7a1-3df2ef73ff12

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
