// Dragnet [Ransomware]: dragnet-ransomware-2025-0744 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 387eac40-f528-55e2-9bd6-024985023022

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
