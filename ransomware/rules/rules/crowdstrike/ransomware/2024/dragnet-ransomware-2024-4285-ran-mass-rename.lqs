// Dragnet [Ransomware]: dragnet-ransomware-2024-4285 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: 0353b125-88fa-5ba0-ae30-09baa68e0a14

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
