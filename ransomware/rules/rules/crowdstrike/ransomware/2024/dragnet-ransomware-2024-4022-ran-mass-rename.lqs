// Dragnet [Ransomware]: dragnet-ransomware-2024-4022 — Mass File Rename (play)
// Status: experimental | Level: high | ID: cb3cce35-7606-5013-a5a4-c95694fdcea0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
