// Dragnet [Ransomware]: dragnet-ransomware-2024-3052 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: f85f9dcf-6052-52de-89cb-aa49d49f5272

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
