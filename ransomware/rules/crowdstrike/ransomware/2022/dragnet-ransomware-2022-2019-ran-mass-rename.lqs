// Dragnet [Ransomware]: dragnet-ransomware-2022-2019 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 3c53ba47-59b3-5659-bdfd-de0622fccf47

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
