// Dragnet [Ransomware]: dragnet-ransomware-2022-1065 — Mass File Rename (avoslocker)
// Status: deprecated | Level: high | ID: 93f2ebd4-6a38-595e-9d49-c816dfa1d90c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
