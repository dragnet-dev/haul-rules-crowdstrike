// Dragnet [Ransomware]: dragnet-ransomware-2024-1567 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 34b4e6e3-186a-5700-82fc-7fc30c35f58d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
