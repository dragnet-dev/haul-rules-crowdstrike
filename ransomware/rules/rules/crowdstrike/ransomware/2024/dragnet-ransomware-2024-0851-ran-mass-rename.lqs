// Dragnet [Ransomware]: dragnet-ransomware-2024-0851 — Mass File Rename (arcusmedia)
// Status: experimental | Level: high | ID: ec8bec59-1503-59d1-8eb9-3c38f06ec2ab

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
