// Dragnet [Ransomware]: dragnet-ransomware-2023-1609 — Mass File Rename (play)
// Status: experimental | Level: high | ID: e860b707-b166-5b42-8a94-639719af1830

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
