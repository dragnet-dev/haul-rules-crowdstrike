// Dragnet [Ransomware]: dragnet-ransomware-2022-2063 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: d473b1c5-4aa5-52fb-a6cf-d6896b0a9019

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
