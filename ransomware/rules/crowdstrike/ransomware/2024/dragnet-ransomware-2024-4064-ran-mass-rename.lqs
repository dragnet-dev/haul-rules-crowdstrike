// Dragnet [Ransomware]: dragnet-ransomware-2024-4064 — Mass File Rename (play)
// Status: experimental | Level: high | ID: b8380acd-aebf-5be5-8d94-847ee04501f9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
