// Dragnet [Ransomware]: dragnet-ransomware-2021-1275 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 0c6f9f3e-4358-55d4-8707-9220a4459add

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
