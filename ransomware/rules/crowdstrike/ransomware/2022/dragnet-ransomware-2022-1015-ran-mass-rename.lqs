// Dragnet [Ransomware]: dragnet-ransomware-2022-1015 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 145bc765-3a41-51f5-9221-72d5275e757c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
