// Dragnet [Ransomware]: dragnet-ransomware-2023-1890 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 9cfa5966-8508-5df7-ae09-08c77ca6b55a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
