// Dragnet [Ransomware]: dragnet-ransomware-2023-4338 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: c21ca40f-9a6e-513d-819d-1559f69d57b3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
