// Dragnet [Ransomware]: dragnet-ransomware-2022-2189 — Mass File Rename (ransomhouse)
// Status: deprecated | Level: high | ID: 4e8200d2-9768-5c4d-b93e-b6acdc68ffca

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
