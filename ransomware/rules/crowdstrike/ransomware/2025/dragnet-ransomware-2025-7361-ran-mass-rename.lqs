// Dragnet [Ransomware]: dragnet-ransomware-2025-7361 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 549ede01-66b2-550c-a4a0-68f3578f6fac

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
