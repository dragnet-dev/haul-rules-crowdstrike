// Dragnet [Ransomware]: dragnet-ransomware-2021-1527 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 92bf83bd-588f-500a-a319-b61080c293b1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
