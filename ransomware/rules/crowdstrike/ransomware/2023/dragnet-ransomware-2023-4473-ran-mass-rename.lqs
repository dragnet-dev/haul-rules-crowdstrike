// Dragnet [Ransomware]: dragnet-ransomware-2023-4473 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 786ebcc6-bb5b-5ad7-b5d7-26e6f9c1a201

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
