// Dragnet [Ransomware]: dragnet-ransomware-2023-1223 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: b8b5464e-f1fa-5221-afc1-ca40fbc2a0f9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
