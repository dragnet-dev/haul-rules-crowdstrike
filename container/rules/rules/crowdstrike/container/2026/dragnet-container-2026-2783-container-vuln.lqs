// Dragnet [Container]: dragnet-container-2026-2783 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: e9ceaa48-c3fc-5e28-acd6-e3dbfdb19717

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:8* OR ImageFileName = *ubuntu:16.04* OR ImageFileName = *ubuntu:16.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
