// Dragnet [Ransomware]: dragnet-ransomware-2022-3107 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 226acef5-4b8f-5153-be60-0f4885ab85f1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
