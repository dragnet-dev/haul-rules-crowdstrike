// Dragnet [Ransomware]: dragnet-ransomware-2024-1905 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 033ca56c-ae33-506e-a349-ede08e5cb192

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
