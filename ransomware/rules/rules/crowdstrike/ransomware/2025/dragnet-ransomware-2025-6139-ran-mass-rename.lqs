// Dragnet [Ransomware]: dragnet-ransomware-2025-6139 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: b813f483-d757-5ede-b50f-6bd20077cc05

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
