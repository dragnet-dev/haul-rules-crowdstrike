// Dragnet [Ransomware]: dragnet-ransomware-2023-4633 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 018006ff-91e0-5ba0-bdb4-f061f281a8db

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
