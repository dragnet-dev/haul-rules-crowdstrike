// Dragnet [Ransomware]: dragnet-ransomware-2024-4027 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: fe515095-031e-5e30-873c-7e553b066b5f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
