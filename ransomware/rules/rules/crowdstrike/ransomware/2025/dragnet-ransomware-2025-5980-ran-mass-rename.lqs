// Dragnet [Ransomware]: dragnet-ransomware-2025-5980 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 52d66f0e-faa5-5405-80ac-3a3be560bf4a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
