// Dragnet [Ransomware]: dragnet-ransomware-2023-2741 — Mass File Rename (monti)
// Status: experimental | Level: high | ID: 9755c9fe-254a-585c-be1c-de5f01c91c36

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
