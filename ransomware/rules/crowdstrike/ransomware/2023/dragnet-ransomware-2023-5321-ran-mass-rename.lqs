// Dragnet [Ransomware]: dragnet-ransomware-2023-5321 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 8dfd546f-a5c8-58cb-b444-1913ead552e6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
