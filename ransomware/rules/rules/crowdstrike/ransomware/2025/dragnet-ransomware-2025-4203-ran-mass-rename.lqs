// Dragnet [Ransomware]: dragnet-ransomware-2025-4203 — Mass File Rename (play)
// Status: experimental | Level: high | ID: af2b6b96-b74a-5934-96df-59e74d6622c6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
