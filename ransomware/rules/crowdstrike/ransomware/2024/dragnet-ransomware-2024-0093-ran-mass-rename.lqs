// Dragnet [Ransomware]: dragnet-ransomware-2024-0093 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: e0c3af36-a52f-59f7-ba34-c3ce1b8270b0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
