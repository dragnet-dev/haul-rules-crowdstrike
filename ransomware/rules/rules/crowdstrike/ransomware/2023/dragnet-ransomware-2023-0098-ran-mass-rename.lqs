// Dragnet [Ransomware]: dragnet-ransomware-2023-0098 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 16beb0e5-b7ba-500e-9139-47b8ae70b065

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
