// Dragnet [Ransomware]: dragnet-ransomware-2025-6838 — Mass File Rename (direwolf)
// Status: experimental | Level: high | ID: 158228b4-de20-54e2-aedf-bbb2413a7307

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
