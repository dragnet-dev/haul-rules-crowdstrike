// Dragnet [Ransomware]: dragnet-ransomware-2023-4279 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 338ca1a8-edcd-5be7-9ca3-206096f368a8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
