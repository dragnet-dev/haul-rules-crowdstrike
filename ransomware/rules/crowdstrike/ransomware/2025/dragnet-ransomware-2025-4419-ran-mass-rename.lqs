// Dragnet [Ransomware]: dragnet-ransomware-2025-4419 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 550ed7d8-c9f9-525c-a1cb-6cd404cc5b71

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
