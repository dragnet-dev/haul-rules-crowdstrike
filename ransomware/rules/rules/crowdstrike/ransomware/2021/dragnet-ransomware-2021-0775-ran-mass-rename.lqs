// Dragnet [Ransomware]: dragnet-ransomware-2021-0775 — Mass File Rename (spook)
// Status: deprecated | Level: high | ID: 06cdf5fd-5a8c-581f-8dea-99a6e34c2cb4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
