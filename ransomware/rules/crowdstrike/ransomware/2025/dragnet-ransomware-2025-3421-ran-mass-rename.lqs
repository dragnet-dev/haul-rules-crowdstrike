// Dragnet [Ransomware]: dragnet-ransomware-2025-3421 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 2744143c-ce07-5f45-b27b-bb6857118947

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
