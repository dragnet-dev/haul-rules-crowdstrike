// Dragnet [Ransomware]: dragnet-ransomware-2023-0711 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 01c6351a-338c-54ff-b0c6-35e16542e35c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
