// Dragnet [Ransomware]: dragnet-ransomware-2025-3838 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: ab51424e-abf8-56ab-bfd1-3894c3be5cfc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
