// Dragnet [Ransomware]: dragnet-ransomware-2024-4743 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 7df2d7cc-8839-5621-a189-6045552b01c6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
