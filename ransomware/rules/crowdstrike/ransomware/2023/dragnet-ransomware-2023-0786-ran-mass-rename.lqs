// Dragnet [Ransomware]: dragnet-ransomware-2023-0786 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 24607ea5-6850-5b4c-9b17-c060b5610bc8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
