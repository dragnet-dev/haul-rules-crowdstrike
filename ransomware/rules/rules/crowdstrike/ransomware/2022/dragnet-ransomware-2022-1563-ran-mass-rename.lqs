// Dragnet [Ransomware]: dragnet-ransomware-2022-1563 — Mass File Rename (ragnarlocker)
// Status: experimental | Level: high | ID: 308f71c6-cbb6-5b93-bbe8-5371f84dcab7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
