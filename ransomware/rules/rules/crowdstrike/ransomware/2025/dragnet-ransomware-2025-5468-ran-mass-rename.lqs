// Dragnet [Ransomware]: dragnet-ransomware-2025-5468 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 0d021d40-9622-5d35-9b16-b9a9d435d9e9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
