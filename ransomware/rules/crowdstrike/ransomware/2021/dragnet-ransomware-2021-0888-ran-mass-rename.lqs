// Dragnet [Ransomware]: dragnet-ransomware-2021-0888 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 137301f1-8a3c-5df4-a8e5-17beede17ca4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
