// Dragnet [Ransomware]: dragnet-ransomware-2024-5387 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: d60aed7b-4d51-5c50-993a-f60855815167

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
