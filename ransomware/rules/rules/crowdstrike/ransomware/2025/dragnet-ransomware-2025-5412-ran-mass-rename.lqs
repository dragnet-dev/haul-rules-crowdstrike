// Dragnet [Ransomware]: dragnet-ransomware-2025-5412 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 4987eb44-b8d1-5971-936d-8bfd743d5686

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
