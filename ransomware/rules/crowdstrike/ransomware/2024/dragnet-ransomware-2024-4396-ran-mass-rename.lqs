// Dragnet [Ransomware]: dragnet-ransomware-2024-4396 — Mass File Rename (flocker)
// Status: experimental | Level: high | ID: 87b63c5d-9aae-50c1-bd95-a9409eb7d41d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
