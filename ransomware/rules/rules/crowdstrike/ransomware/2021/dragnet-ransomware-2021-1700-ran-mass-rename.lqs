// Dragnet [Ransomware]: dragnet-ransomware-2021-1700 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 50472d9c-d2ef-5e3a-b8f8-898f6f90b88e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
