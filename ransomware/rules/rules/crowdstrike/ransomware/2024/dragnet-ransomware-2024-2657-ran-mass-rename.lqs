// Dragnet [Ransomware]: dragnet-ransomware-2024-2657 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: cb80d455-2edf-56a3-8f57-816389e6e4cf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
