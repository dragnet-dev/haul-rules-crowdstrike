// Dragnet [Ransomware]: dragnet-ransomware-2022-2678 — Mass File Rename (snatch)
// Status: experimental | Level: high | ID: 2c2e7fa2-2fa7-540e-99e0-3e0bc69adc1a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
