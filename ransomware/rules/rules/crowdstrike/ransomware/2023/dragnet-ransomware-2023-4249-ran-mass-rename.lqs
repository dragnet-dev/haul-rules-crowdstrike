// Dragnet [Ransomware]: dragnet-ransomware-2023-4249 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 33a81431-87d1-5942-8f21-f26477ed5c96

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
