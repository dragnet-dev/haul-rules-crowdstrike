// Dragnet [Ransomware]: dragnet-ransomware-2025-2866 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: ba982c84-8ced-5199-b97d-bbd3c327e863

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
