// Dragnet [Ransomware]: dragnet-ransomware-2022-1296 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: c06d22c2-ac43-524a-965d-4a9ec95e86cf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
