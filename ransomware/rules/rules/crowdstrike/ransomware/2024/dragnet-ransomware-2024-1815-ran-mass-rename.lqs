// Dragnet [Ransomware]: dragnet-ransomware-2024-1815 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: ca9e2e16-2f28-5c3a-8663-7bb01817a12c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
