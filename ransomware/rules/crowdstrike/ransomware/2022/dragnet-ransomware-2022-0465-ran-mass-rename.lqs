// Dragnet [Ransomware]: dragnet-ransomware-2022-0465 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: d82cdcd6-4a04-5a94-85b2-05fb5b7ad10c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
