// Dragnet [Ransomware]: dragnet-ransomware-2025-0567 — Mass File Rename (payoutsking)
// Status: experimental | Level: high | ID: 4d2cb9e1-a5c4-55a7-9694-a0e575368812

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
