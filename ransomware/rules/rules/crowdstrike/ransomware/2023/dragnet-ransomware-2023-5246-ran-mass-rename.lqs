// Dragnet [Ransomware]: dragnet-ransomware-2023-5246 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: be206c75-baf4-5707-9baf-686b19204b9f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
