// Dragnet [Ransomware]: dragnet-ransomware-2021-1378 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 47249512-8e80-5439-a486-e11596c65f59

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
