// Dragnet [Ransomware]: dragnet-ransomware-2024-2551 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: b6ae8713-484b-596f-86ce-b3c8cfa2c136

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
