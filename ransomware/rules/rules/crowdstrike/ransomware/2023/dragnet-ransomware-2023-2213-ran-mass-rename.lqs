// Dragnet [Ransomware]: dragnet-ransomware-2023-2213 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: 0ac33c82-94e9-53d8-a871-51b74f4b5743

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
