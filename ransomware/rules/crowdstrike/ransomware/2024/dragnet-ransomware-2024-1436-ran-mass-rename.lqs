// Dragnet [Ransomware]: dragnet-ransomware-2024-1436 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 29e464be-4911-5581-92db-e88145a3c528

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
