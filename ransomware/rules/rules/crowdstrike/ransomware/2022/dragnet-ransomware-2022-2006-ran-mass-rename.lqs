// Dragnet [Ransomware]: dragnet-ransomware-2022-2006 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 928bff0c-763f-5d99-a270-36773a01020d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
