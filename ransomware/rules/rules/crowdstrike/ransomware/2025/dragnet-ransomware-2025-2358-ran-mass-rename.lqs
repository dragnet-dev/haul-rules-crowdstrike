// Dragnet [Ransomware]: dragnet-ransomware-2025-2358 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 8b8065ce-63c8-5520-bea4-e3cc8d05e029

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
