// Dragnet [Ransomware]: dragnet-ransomware-2023-0554 — Mass File Rename (abyss)
// Status: deprecated | Level: high | ID: 87e2f87f-776d-5e66-97fd-6a5bce2a455d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
