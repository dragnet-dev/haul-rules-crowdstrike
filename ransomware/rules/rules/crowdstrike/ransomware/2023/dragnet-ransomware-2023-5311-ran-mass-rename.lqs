// Dragnet [Ransomware]: dragnet-ransomware-2023-5311 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: 5b54b19e-d157-55a1-bc9c-217419e9b724

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
