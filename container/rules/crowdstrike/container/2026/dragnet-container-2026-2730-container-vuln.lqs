// Dragnet [Container]: dragnet-container-2026-2730 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: b8784be2-21c6-5f1c-8096-95b1873a84b4

#event_simpleName=*
| (ImageFileName = *debian:7* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10* OR ImageFileName = *ubuntu:13.04* OR ImageFileName = *ubuntu:13.10* OR ImageFileName = *ubuntu:14.04* OR ImageFileName = *ubuntu:14.10* OR ImageFileName = *ubuntu:15.04* OR ImageFileName = *ubuntu:15.10* OR ImageFileName = *ubuntu:16.04* OR ImageFileName = *ubuntu:16.10*)
| table([timestamp, ComputerName])
| limit(1000)
