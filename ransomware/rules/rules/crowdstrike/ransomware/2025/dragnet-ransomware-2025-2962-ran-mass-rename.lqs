// Dragnet [Ransomware]: dragnet-ransomware-2025-2962 — Mass File Rename (sinobi)
// Status: experimental | Level: high | ID: 85d2b5c4-c7d7-527c-85fb-517d21d4c354

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
