// Dragnet [Ransomware]: dragnet-ransomware-2024-1854 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: e181f866-529c-502c-9d01-c6e5449ef1cc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
