// Dragnet [Ransomware]: dragnet-ransomware-2020-0058 — Mass File Rename (lockbit)
// Status: deprecated | Level: high | ID: 3daa0971-7225-5caf-9c30-919fed02f93e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
