// Dragnet [Ransomware]: dragnet-ransomware-2023-4096 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: c549ba3f-c477-5823-a4c1-ff56bd137525

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
