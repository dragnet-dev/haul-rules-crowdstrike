// Dragnet [Ransomware]: dragnet-ransomware-2023-3345 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: fcbba4f6-d4c5-5006-8fd2-b0a989933c13

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
