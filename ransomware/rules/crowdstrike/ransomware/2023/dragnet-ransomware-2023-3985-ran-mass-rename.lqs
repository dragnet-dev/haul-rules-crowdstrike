// Dragnet [Ransomware]: dragnet-ransomware-2023-3985 — Mass File Rename (royal)
// Status: experimental | Level: high | ID: cf5d4d6f-22bf-54a4-aba5-f7daa12b470b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
