// Dragnet [Ransomware]: dragnet-ransomware-2025-7050 — Mass File Rename (kairos)
// Status: experimental | Level: high | ID: b6f8eecf-3535-5cd1-9f85-962be7ca10c8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
