// Dragnet [Ransomware]: dragnet-ransomware-2024-3063 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 00462984-3f90-5172-83f1-14d406527954

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
