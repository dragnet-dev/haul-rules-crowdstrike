// Dragnet [Ransomware]: dragnet-ransomware-2021-1689 — Mass File Rename (ragnarlocker)
// Status: deprecated | Level: high | ID: 32a295da-91ae-5a36-bbc2-25c919a96efb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
