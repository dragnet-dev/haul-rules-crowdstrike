// Dragnet [Ransomware]: dragnet-ransomware-2024-5948 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: 6fd26901-a5a2-5b0b-99b2-cf4f68853aaf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
