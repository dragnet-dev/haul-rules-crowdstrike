// Dragnet [Ransomware]: dragnet-ransomware-2021-1043 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 7138840c-ae9e-59ce-a733-506917898226

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
