// Dragnet [Ransomware]: dragnet-ransomware-2023-0772 — Mass File Rename (meow)
// Status: experimental | Level: high | ID: 8d4c78d9-acef-5d79-987a-6c1a07ab9657

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
