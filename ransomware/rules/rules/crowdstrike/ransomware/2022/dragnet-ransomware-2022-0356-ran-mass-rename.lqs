// Dragnet [Ransomware]: dragnet-ransomware-2022-0356 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 51b4d0de-cb1c-50c7-9ec2-a13b2a270b16

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
