// Dragnet [Ransomware]: dragnet-ransomware-2026-3500 — Mass File Rename (handala)
// Status: stable | Level: high | ID: d5cae406-32ad-58d5-bf89-4d08491e091d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
