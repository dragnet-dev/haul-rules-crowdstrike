// Dragnet [Ransomware]: dragnet-ransomware-2024-0833 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 00fc905c-7ca3-5947-96f8-202c227bab01

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
