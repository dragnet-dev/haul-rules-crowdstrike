// Dragnet [Ransomware]: dragnet-ransomware-2024-5060 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: cb52d3b2-563b-52ae-acf4-bb73a0a49729

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
