// Dragnet [Ransomware]: dragnet-ransomware-2023-0507 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 03181e75-6bcc-5d43-bae3-12cffa69d0f3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
