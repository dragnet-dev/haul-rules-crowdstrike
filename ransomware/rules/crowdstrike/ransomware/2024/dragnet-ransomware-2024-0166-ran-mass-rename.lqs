// Dragnet [Ransomware]: dragnet-ransomware-2024-0166 — Mass File Rename (stormous)
// Status: deprecated | Level: high | ID: d458b244-6dec-5e63-80ff-abb70b27cf4f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
