// Dragnet [Ransomware]: dragnet-ransomware-2021-0718 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 5de223bb-cd33-55a5-bd30-050ffacc3bbe

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
