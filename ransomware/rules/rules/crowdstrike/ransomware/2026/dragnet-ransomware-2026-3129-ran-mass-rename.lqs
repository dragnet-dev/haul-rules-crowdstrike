// Dragnet [Ransomware]: dragnet-ransomware-2026-3129 — Mass File Rename (krybit)
// Status: stable | Level: high | ID: 58e9c5b8-809c-5c8c-a493-203f949ff9e1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
