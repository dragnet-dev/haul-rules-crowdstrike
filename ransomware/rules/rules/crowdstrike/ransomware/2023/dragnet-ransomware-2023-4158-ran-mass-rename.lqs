// Dragnet [Ransomware]: dragnet-ransomware-2023-4158 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 837ff29f-9c28-573e-8d73-53d85429f694

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
