// Dragnet [Ransomware]: dragnet-ransomware-2024-5089 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 1fee6c1e-8773-5d53-b8ca-09c58333fe63

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
