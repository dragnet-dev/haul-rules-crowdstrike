// Dragnet [Ransomware]: dragnet-ransomware-2026-2909 — Mass File Rename (worldleaks)
// Status: stable | Level: high | ID: 9edcb65b-04d4-5175-9dce-adb89a385436

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
