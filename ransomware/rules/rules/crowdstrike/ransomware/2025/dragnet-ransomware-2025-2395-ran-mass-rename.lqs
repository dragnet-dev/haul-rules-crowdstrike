// Dragnet [Ransomware]: dragnet-ransomware-2025-2395 — Mass File Rename (thegentlemen)
// Status: experimental | Level: high | ID: efe39b6f-1c3e-5b80-84ff-2d9edd9a83a9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
