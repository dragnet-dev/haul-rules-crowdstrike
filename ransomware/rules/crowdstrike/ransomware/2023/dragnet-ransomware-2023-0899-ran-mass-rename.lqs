// Dragnet [Ransomware]: dragnet-ransomware-2023-0899 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 00c07e7e-8265-5ffd-a2a3-b617e4b97d73

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
