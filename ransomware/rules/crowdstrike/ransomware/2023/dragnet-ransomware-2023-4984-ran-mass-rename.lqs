// Dragnet [Ransomware]: dragnet-ransomware-2023-4984 — Mass File Rename (cactus)
// Status: deprecated | Level: high | ID: 185ee33d-c7aa-5834-8a91-55029bd119db

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
