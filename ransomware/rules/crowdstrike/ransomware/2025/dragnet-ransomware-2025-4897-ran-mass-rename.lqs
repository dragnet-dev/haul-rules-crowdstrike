// Dragnet [Ransomware]: dragnet-ransomware-2025-4897 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: aa8c87f2-5a6d-5945-a963-b151aae53d98

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
