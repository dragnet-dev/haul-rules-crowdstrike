// Dragnet [Ransomware]: dragnet-ransomware-2024-1540 — Mass File Rename (cloak)
// Status: deprecated | Level: high | ID: 7ed77356-7d80-534a-a3e5-bcd1dc7520ee

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
