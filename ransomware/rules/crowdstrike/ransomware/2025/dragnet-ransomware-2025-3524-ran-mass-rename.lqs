// Dragnet [Ransomware]: dragnet-ransomware-2025-3524 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: 0e2c8a5a-42e0-5378-8cc8-44b1f732d777

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
