// Dragnet [Ransomware]: dragnet-ransomware-2024-0487 — Mass File Rename (spacebears)
// Status: experimental | Level: high | ID: 8f37d11c-8e54-5a57-ad89-3af08723eee6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
