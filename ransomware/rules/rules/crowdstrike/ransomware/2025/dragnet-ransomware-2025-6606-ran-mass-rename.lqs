// Dragnet [Ransomware]: dragnet-ransomware-2025-6606 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 100041a3-ee57-587e-a3b7-7595557636ce

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
