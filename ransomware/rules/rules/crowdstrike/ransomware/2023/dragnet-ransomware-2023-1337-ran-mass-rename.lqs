// Dragnet [Ransomware]: dragnet-ransomware-2023-1337 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 07e7b8e1-6d06-5b35-a193-e03d575e58b9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
