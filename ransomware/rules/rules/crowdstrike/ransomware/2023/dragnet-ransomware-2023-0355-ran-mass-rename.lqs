// Dragnet [Ransomware]: dragnet-ransomware-2023-0355 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 2107ae07-73ef-556c-83e1-246179b08df9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
