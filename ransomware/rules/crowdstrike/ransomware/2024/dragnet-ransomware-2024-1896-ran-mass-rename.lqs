// Dragnet [Ransomware]: dragnet-ransomware-2024-1896 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: d9767673-f02e-567e-8423-f4971309ec39

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
