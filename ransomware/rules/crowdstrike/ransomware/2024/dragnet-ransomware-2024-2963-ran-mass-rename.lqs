// Dragnet [Ransomware]: dragnet-ransomware-2024-2963 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 7e27d1ec-c242-556d-8bdd-d51df0bdce39

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
