// Dragnet [Ransomware]: dragnet-ransomware-2021-0647 — Mass File Rename (revil)
// Status: deprecated | Level: high | ID: 1f40a312-9386-5f44-a10b-d18db91b5827

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
