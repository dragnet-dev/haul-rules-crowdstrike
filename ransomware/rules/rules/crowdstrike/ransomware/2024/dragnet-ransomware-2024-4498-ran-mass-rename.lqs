// Dragnet [Ransomware]: dragnet-ransomware-2024-4498 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 7b23e46d-12ce-5965-a7e8-d505b136024e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
