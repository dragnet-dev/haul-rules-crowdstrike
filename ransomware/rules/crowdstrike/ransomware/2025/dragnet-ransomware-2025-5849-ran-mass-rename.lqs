// Dragnet [Ransomware]: dragnet-ransomware-2025-5849 — Mass File Rename (gunra)
// Status: experimental | Level: high | ID: 91b5b183-36a9-5c95-a103-b378c97e6bf1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
