// Dragnet [Ransomware]: dragnet-ransomware-2025-5147 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 2514264f-4ec9-55ff-9a77-97ca3f333ab4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
