// Dragnet [Ransomware]: dragnet-ransomware-2025-7578 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 98f0b7f0-0acb-5aed-8516-5f51e1f2f85a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
