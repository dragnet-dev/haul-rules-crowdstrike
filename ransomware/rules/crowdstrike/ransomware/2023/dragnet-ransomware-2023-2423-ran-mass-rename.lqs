// Dragnet [Ransomware]: dragnet-ransomware-2023-2423 — Mass File Rename (medusalocker)
// Status: experimental | Level: high | ID: 9a56ab11-11e4-55e7-9e22-d0b8e3da18da

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
