// Dragnet [Ransomware]: dragnet-ransomware-2025-4825 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 1c772cc8-e66c-57c0-903f-3f3ebc8674e1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
