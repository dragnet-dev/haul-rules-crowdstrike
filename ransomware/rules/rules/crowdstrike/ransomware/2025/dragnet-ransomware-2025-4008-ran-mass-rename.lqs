// Dragnet [Ransomware]: dragnet-ransomware-2025-4008 — Mass File Rename (payoutsking)
// Status: experimental | Level: high | ID: 2f504bcc-1a31-5d5c-8892-e5c567dad531

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
