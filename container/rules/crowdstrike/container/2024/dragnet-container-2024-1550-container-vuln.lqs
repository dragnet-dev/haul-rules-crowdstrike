// Dragnet [Container]: dragnet-container-2024-1550 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: d3c85508-56a6-5c39-82bd-9839adbce8e4

#event_simpleName=*
| (ImageFileName = *almalinux:8* OR ImageFileName = *cbl-mariner:1.0* OR ImageFileName = *cbl-mariner:2.0* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:8* OR ImageFileName = *photon os:4.0* OR ImageFileName = *ubuntu:20.04* OR ImageFileName = *ubuntu:20.04-ESM* OR ImageFileName = *ubuntu:21.04* OR ImageFileName = *ubuntu:21.10*)
| table([timestamp, ComputerName])
| limit(1000)
