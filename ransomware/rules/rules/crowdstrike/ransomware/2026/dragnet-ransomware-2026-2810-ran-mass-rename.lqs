// Dragnet [Ransomware]: dragnet-ransomware-2026-2810 — Mass File Rename (killsec)
// Status: deprecated | Level: high | ID: ee11137a-bc3b-5670-907e-a6207d238e3d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
