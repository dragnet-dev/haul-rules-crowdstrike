// Dragnet [Ransomware]: dragnet-ransomware-2024-4914 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 4a334c77-8260-5444-9884-94798a7c5034

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
