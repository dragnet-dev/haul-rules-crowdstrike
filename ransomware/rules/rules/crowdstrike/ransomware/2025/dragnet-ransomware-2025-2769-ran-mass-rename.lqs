// Dragnet [Ransomware]: dragnet-ransomware-2025-2769 — Mass File Rename (GDLockerSec)
// Status: experimental | Level: high | ID: 2fc5424a-daf2-578f-9b5e-423de0a2ba6e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
