// Dragnet [Ransomware]: dragnet-ransomware-2024-3508 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 574558c9-f0c0-575e-a087-752a73607e1e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
