// Dragnet [Ransomware]: dragnet-ransomware-2022-0064 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 769cfad5-6f8a-5b08-abb6-09f7066cdcbd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
