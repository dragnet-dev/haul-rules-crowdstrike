// Dragnet [Ransomware]: dragnet-ransomware-2024-1593 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 833f41d0-c2b6-5cb4-bdf6-895e9e8418a5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
