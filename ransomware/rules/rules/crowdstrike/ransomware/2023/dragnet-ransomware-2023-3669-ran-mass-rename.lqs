// Dragnet [Ransomware]: dragnet-ransomware-2023-3669 — Mass File Rename (cyclops)
// Status: deprecated | Level: high | ID: 78488e81-5c7a-51d8-8e71-3f99c0735f92

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
