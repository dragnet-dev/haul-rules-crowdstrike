// Dragnet [Ransomware]: dragnet-ransomware-2025-7795 — Mass File Rename (worldleaks)
// Status: experimental | Level: high | ID: 7443ac5c-f619-5b11-b5f0-8d5aff8f4390

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
