// Dragnet [Ransomware]: dragnet-ransomware-2025-0525 — Mass File Rename (global)
// Status: deprecated | Level: high | ID: 30dc2ea6-302d-5ff1-91aa-5787a3aecbd6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
