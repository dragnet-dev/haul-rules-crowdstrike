// Dragnet [Container]: dragnet-container-2026-2751 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 51c080f7-6c5f-563d-a89b-c3dcc24a161d

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:7* OR ImageFileName = *debian:8*)
| table([timestamp, ComputerName])
| limit(1000)
