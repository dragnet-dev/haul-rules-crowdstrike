// Dragnet [Ransomware]: dragnet-ransomware-2025-6396 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: 3f625955-9cc7-5721-8103-f80e4291a6c6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
