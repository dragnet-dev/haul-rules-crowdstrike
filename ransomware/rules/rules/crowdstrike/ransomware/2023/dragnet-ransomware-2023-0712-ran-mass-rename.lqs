// Dragnet [Ransomware]: dragnet-ransomware-2023-0712 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 941bdc7b-130f-5c88-b544-eb12abcfbebf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
