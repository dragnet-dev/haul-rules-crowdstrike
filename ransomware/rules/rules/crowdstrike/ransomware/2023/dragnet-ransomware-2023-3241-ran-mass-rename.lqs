// Dragnet [Ransomware]: dragnet-ransomware-2023-3241 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 3651c9e2-e04d-5fbc-ab4c-b88f3ed57e1b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
