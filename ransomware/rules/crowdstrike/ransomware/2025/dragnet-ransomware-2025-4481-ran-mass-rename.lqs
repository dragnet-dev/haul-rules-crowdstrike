// Dragnet [Ransomware]: dragnet-ransomware-2025-4481 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: d56000ba-08a8-519c-84ff-9428c6140b24

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
