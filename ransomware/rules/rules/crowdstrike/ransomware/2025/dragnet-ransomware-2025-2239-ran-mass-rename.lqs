// Dragnet [Ransomware]: dragnet-ransomware-2025-2239 — Mass File Rename (dragonforce)
// Status: test | Level: high | ID: 0d11952c-f9a2-5693-bb38-9babbd11f036

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
