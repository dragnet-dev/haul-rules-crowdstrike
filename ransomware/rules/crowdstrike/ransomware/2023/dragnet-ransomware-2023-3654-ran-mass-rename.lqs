// Dragnet [Ransomware]: dragnet-ransomware-2023-3654 — Mass File Rename (moneymessage)
// Status: experimental | Level: high | ID: de13df81-92fb-5b76-85e4-7f08620aeb3e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
