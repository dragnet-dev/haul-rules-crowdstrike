// Dragnet [Ransomware]: dragnet-ransomware-2023-2372 — Mass File Rename (donutleaks)
// Status: experimental | Level: high | ID: ecb257be-b7f1-5dc7-933b-3c1657477de8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
