// Dragnet [Ransomware]: dragnet-ransomware-2025-2296 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: ba128574-fefa-5875-895a-82c8b6e8740d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
