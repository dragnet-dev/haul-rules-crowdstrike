// Dragnet [Ransomware]: dragnet-ransomware-2025-7848 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: fce6a64f-1a75-5af6-b1ad-fdc7b12f6ced

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
