// Dragnet [Ransomware]: dragnet-ransomware-2024-2971 — Mass File Rename (play)
// Status: experimental | Level: high | ID: c545e830-c397-565e-a4f9-93e2cd0a9f5a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
