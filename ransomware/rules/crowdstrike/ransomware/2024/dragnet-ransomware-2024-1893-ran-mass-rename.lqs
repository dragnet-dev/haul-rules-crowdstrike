// Dragnet [Ransomware]: dragnet-ransomware-2024-1893 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 1e0daa84-644f-5c1c-9b97-adf03d389760

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
