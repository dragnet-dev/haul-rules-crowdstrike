// Dragnet [Ransomware]: dragnet-ransomware-2024-3367 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: c38e4d29-0097-504c-9a86-93c8a7812e92

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
