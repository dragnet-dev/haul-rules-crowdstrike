// Dragnet [Ransomware]: dragnet-ransomware-2025-1184 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 7ec3dde2-a0ad-5d9d-9b22-9bd5d53a47a6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
