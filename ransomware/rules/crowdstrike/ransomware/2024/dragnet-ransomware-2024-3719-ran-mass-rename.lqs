// Dragnet [Ransomware]: dragnet-ransomware-2024-3719 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 5e6b1208-4337-5fc2-a2a0-d84844a43d8b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
