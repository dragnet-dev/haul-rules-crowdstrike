// Dragnet [Ransomware]: dragnet-ransomware-2024-1474 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 1ba5333f-478d-5ff2-835f-10fe1d28f082

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
