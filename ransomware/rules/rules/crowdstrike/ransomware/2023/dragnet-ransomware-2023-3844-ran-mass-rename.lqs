// Dragnet [Ransomware]: dragnet-ransomware-2023-3844 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 9cdbe76b-31b6-569f-a79e-869b93b84527

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
