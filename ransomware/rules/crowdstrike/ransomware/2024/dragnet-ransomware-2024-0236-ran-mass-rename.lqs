// Dragnet [Ransomware]: dragnet-ransomware-2024-0236 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 4f7db024-3057-5ea0-8e35-b2c166847ce3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
