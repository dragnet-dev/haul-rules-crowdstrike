// Dragnet [Ransomware]: dragnet-ransomware-2026-1246 — Mass File Rename (genesis)
// Status: stable | Level: high | ID: 5cf98161-d155-5e89-9ab4-56881dd69846

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
