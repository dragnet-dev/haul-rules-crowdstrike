// Dragnet [Ransomware]: dragnet-ransomware-2024-5744 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: f7fcf431-0472-5745-8256-24b4d846387a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
