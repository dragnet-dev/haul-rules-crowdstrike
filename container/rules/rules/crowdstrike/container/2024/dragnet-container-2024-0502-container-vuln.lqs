// Dragnet [Container]: dragnet-container-2024-0502 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: f61be366-2a4a-53d3-86c8-31c0ec737e80

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
