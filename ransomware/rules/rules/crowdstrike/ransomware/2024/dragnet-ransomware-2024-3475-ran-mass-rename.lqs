// Dragnet [Ransomware]: dragnet-ransomware-2024-3475 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 97e1d5ca-2a05-5d09-aafe-e178dc88e1c1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
