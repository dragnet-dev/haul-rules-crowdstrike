// Dragnet [Ransomware]: dragnet-ransomware-2025-3103 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 8e22e5a0-054b-57cd-8c3d-c4b48def26b5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
