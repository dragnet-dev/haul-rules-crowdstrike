// Dragnet [Ransomware]: dragnet-ransomware-2025-6178 — Mass File Rename (killsec)
// Status: deprecated | Level: high | ID: 33f1771c-1ca7-5269-b277-1cb39fbc62eb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
