// Dragnet [Ransomware]: dragnet-ransomware-2024-4597 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 891baa74-d7b8-599a-93b7-9690ccadf7b2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
