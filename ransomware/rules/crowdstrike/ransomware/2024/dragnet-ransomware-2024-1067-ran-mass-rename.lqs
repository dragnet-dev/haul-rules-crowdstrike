// Dragnet [Ransomware]: dragnet-ransomware-2024-1067 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: 7697dab9-cf6b-5c3e-a24f-2cbfc302e029

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
