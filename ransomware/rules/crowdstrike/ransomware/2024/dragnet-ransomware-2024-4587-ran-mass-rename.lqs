// Dragnet [Ransomware]: dragnet-ransomware-2024-4587 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: f9f90b53-9288-59c1-9673-4d66ec944842

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
