// Dragnet [Ransomware]: dragnet-ransomware-2023-0233 — Mass File Rename (losttrust)
// Status: deprecated | Level: high | ID: c84f3c4d-5fad-5b64-914a-15486f0b3fb5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
