// Dragnet [Ransomware]: dragnet-ransomware-2024-5729 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 9f30710a-6517-5185-8097-10db4d6e8862

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
