// Dragnet [Ransomware]: dragnet-ransomware-2025-1518 — Mass File Rename (flocker)
// Status: experimental | Level: high | ID: 995d4c38-edd9-5b9c-b26d-e9b54d0900a2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
