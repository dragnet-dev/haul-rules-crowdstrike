// Dragnet [Ransomware]: dragnet-ransomware-2025-1871 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 2074379e-7fe3-5dcc-9223-597cdab7933a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
