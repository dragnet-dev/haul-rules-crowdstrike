// Dragnet [Ransomware]: dragnet-ransomware-2024-5599 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 099faf71-4c14-58c6-8b7e-02bf23a19b19

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
