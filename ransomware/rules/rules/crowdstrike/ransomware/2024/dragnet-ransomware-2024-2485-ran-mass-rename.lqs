// Dragnet [Ransomware]: dragnet-ransomware-2024-2485 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 56fbca57-326e-54b2-9398-9c80bd121d95

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
