// Dragnet [Ransomware]: dragnet-ransomware-2021-1612 — Mass File Rename (doppelpaymer)
// Status: deprecated | Level: high | ID: f54b1901-b957-5e7d-831c-5f5c0269963d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
