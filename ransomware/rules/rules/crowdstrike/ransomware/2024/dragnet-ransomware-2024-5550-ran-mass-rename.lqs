// Dragnet [Ransomware]: dragnet-ransomware-2024-5550 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: afa15628-466a-5c49-a908-a9dc5fc92289

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
