// Dragnet [Ransomware]: dragnet-ransomware-2021-0070 — Mass File Rename (payloadbin)
// Status: deprecated | Level: high | ID: 40b36015-1ee9-51ba-b6de-1b1e0d3ebf5f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
