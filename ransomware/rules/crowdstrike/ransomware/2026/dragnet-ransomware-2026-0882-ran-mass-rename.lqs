// Dragnet [Ransomware]: dragnet-ransomware-2026-0882 — Mass File Rename (cmdorganization)
// Status: deprecated | Level: high | ID: 132481f2-da55-5189-86b7-211c8c359cb0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
