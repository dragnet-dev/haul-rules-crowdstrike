// Dragnet [Ransomware]: dragnet-ransomware-2025-5733 — Mass File Rename (blacklock)
// Status: experimental | Level: high | ID: 290421ab-815f-58b2-87d6-21f43bec9609

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
