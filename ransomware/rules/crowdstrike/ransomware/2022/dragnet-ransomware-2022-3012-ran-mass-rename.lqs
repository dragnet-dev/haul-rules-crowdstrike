// Dragnet [Ransomware]: dragnet-ransomware-2022-3012 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 92bbae80-9530-5221-8987-6c3145d78ce7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
