// Dragnet [Ransomware]: dragnet-ransomware-2025-4850 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: f5c66d07-b498-56da-99d3-26acab50cd60

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
