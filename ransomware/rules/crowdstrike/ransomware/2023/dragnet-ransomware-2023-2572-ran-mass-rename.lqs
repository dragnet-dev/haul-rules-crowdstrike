// Dragnet [Ransomware]: dragnet-ransomware-2023-2572 — Mass File Rename (knight)
// Status: experimental | Level: high | ID: abfa6b6d-6d03-516e-b5f2-9a8859914bfb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
