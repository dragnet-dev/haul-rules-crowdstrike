// Dragnet [Ransomware]: dragnet-ransomware-2025-7342 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 2cb6ea50-cf74-57ea-befe-55ba7a4d281e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
