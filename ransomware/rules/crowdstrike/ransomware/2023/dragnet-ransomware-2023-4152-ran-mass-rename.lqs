// Dragnet [Ransomware]: dragnet-ransomware-2023-4152 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 6b2b9e27-db32-5e4d-9455-3f09055134e1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
