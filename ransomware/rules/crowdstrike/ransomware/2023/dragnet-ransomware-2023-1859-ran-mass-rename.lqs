// Dragnet [Ransomware]: dragnet-ransomware-2023-1859 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 696d0999-561d-5c20-860b-58941f9dcffc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
