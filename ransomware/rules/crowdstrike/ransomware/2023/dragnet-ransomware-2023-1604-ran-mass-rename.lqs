// Dragnet [Ransomware]: dragnet-ransomware-2023-1604 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 57fb1b73-ef7f-5f6d-847c-86045a664411

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
