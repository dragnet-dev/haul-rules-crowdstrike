// Dragnet [Ransomware]: dragnet-ransomware-2023-1932 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 69756dd6-4a21-5ed0-a0e5-433603e35118

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
