// Dragnet [Ransomware]: dragnet-ransomware-2025-1203 — Mass File Rename (incransom)
// Status: test | Level: high | ID: c5cde74c-3bc1-56c6-91df-d45261536d51

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
