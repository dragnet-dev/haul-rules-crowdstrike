// Dragnet [Ransomware]: dragnet-ransomware-2025-4606 — Mass File Rename (kairos)
// Status: deprecated | Level: high | ID: dcb8d93b-75ae-5994-a9b2-688e6b0c03e5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
