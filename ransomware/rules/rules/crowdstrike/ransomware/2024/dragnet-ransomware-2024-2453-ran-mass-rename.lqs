// Dragnet [Ransomware]: dragnet-ransomware-2024-2453 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 7f51e409-32db-56b3-a558-56288cd439d2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
