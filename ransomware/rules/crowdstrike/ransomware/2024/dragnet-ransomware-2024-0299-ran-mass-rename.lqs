// Dragnet [Ransomware]: dragnet-ransomware-2024-0299 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 0897edea-fba0-54dd-819e-c51c6d5584e3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
