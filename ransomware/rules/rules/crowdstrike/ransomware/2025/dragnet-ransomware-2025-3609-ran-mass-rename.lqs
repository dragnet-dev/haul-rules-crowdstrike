// Dragnet [Ransomware]: dragnet-ransomware-2025-3609 — Mass File Rename (rhysida)
// Status: deprecated | Level: high | ID: 42087103-5f5d-530f-bea8-b50f7dd681ba

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
