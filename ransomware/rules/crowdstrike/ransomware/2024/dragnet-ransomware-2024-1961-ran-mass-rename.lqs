// Dragnet [Ransomware]: dragnet-ransomware-2024-1961 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 876322d7-87f2-58c1-a463-ef06bb1cb3a3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
