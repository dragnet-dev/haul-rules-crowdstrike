// Dragnet [Ransomware]: dragnet-ransomware-2023-3768 — Mass File Rename (threeam)
// Status: experimental | Level: high | ID: 4b8427d3-59c4-5472-9680-aa0232679243

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
