// Dragnet [Ransomware]: dragnet-ransomware-2024-3050 — Mass File Rename (darkvault)
// Status: experimental | Level: high | ID: 2fc61290-96df-5678-bb38-8f3f7d8557e9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
