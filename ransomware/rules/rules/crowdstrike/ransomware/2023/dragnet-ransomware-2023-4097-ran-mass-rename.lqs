// Dragnet [Ransomware]: dragnet-ransomware-2023-4097 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: bb26e289-a9e2-5650-a186-cc23d5cd7b0f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
