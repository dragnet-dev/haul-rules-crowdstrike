// Dragnet [Ransomware]: dragnet-ransomware-2024-0926 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 44449a73-8ae6-57d1-9744-566a62eb3d45

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
