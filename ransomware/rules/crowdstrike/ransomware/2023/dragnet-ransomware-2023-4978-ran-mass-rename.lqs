// Dragnet [Ransomware]: dragnet-ransomware-2023-4978 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 181a2aa1-cd1f-5ed5-a91e-070ecefeaa07

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
