// Dragnet [Ransomware]: dragnet-ransomware-2025-0270 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: a04ca788-392f-5b63-b50e-b20d3da96347

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
