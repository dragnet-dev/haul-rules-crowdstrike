// Dragnet [Ransomware]: dragnet-ransomware-2023-2182 — Mass File Rename (noescape)
// Status: experimental | Level: high | ID: 73f697aa-290c-55be-93f7-323036192648

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
