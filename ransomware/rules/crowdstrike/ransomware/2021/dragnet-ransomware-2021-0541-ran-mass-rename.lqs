// Dragnet [Ransomware]: dragnet-ransomware-2021-0541 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: d504f41f-395a-51a6-90ba-3212c1cd5244

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
