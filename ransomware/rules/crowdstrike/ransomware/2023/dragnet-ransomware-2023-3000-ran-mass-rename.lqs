// Dragnet [Ransomware]: dragnet-ransomware-2023-3000 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 7d1df107-3c32-5f0c-a998-9ddc6d8271fa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
