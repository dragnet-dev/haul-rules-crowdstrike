// Dragnet [Ransomware]: dragnet-ransomware-2024-2804 — Mass File Rename (ElDorado)
// Status: deprecated | Level: high | ID: c7f69e97-07e6-576e-bdc7-2e03384e8c30

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
