// Dragnet [Ransomware]: dragnet-ransomware-2023-0673 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 7ec68796-a61e-5c46-8fee-83738a325503

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
