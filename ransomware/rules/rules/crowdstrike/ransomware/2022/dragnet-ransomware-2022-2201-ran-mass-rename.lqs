// Dragnet [Ransomware]: dragnet-ransomware-2022-2201 — Mass File Rename (karakurt)
// Status: experimental | Level: high | ID: 85b6e67a-39d0-569f-aab7-ca3204ab6f44

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
