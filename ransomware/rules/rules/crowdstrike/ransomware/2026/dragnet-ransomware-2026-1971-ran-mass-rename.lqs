// Dragnet [Ransomware]: dragnet-ransomware-2026-1971 — Mass File Rename (lockbit5)
// Status: stable | Level: high | ID: 13ada5a0-2633-520c-b4ae-bb891df1084d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
