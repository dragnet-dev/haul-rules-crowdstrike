// Dragnet [Ransomware]: dragnet-ransomware-2025-4692 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 04b86af3-27a3-5d1c-8d15-32df4b475304

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
