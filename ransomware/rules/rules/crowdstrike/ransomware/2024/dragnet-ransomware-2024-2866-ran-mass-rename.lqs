// Dragnet [Ransomware]: dragnet-ransomware-2024-2866 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 8082f5ba-b1ac-5833-bd25-01d8314c2164

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
