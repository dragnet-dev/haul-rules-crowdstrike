// Dragnet [Container]: dragnet-container-2026-1990 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: acfc68d2-8ca9-56df-a5cd-ed12d16c4d45

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
