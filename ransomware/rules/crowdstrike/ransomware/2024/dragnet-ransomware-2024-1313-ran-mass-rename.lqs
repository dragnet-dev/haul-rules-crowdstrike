// Dragnet [Ransomware]: dragnet-ransomware-2024-1313 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: e059507b-4fc2-5e3a-bed7-e0c06d54eef9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
