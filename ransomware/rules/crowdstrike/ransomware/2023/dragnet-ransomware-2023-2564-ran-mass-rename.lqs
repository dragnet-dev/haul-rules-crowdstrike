// Dragnet [Ransomware]: dragnet-ransomware-2023-2564 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 928ed897-88f5-59b6-b917-e94991d7268f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
