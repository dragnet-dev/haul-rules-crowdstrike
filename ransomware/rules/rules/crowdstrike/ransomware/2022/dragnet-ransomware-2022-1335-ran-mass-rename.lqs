// Dragnet [Ransomware]: dragnet-ransomware-2022-1335 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 590f8754-2d23-5df9-97c4-fcef09caa459

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
