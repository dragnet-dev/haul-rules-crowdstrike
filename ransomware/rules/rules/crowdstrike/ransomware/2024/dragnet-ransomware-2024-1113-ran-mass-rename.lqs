// Dragnet [Ransomware]: dragnet-ransomware-2024-1113 — Mass File Rename (meow)
// Status: experimental | Level: high | ID: f03b0e15-eff4-53b9-b3fc-487954116a95

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
