// Dragnet [Ransomware]: dragnet-ransomware-2024-3840 — Mass File Rename (dragonransomware)
// Status: experimental | Level: high | ID: d7081843-059a-5b2b-afb8-6513ba126614

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
