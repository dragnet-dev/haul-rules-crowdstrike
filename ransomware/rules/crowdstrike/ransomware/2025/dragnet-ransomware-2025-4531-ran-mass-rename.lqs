// Dragnet [Ransomware]: dragnet-ransomware-2025-4531 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 0edc8740-024f-5097-9e9c-cf91b0f082b4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
