// Dragnet [Container]: dragnet-container-2025-0172 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 364dea19-197f-5932-ade8-423a4ad4d60d

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
