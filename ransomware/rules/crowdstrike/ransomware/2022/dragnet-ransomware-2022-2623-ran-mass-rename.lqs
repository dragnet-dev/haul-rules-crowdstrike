// Dragnet [Ransomware]: dragnet-ransomware-2022-2623 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 66a07fa6-2df7-597b-8fd9-c3632242bdd9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
