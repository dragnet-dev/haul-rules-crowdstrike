// Dragnet [Ransomware]: dragnet-ransomware-2024-2502 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 62f4e170-35fe-5f4d-8efa-0682dd439c48

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
