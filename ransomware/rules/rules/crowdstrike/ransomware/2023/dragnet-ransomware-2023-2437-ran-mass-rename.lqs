// Dragnet [Ransomware]: dragnet-ransomware-2023-2437 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: dcf4f3fc-7942-55b8-a2fb-79393ac4d6e9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
