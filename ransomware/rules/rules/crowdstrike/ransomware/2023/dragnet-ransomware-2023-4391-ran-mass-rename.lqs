// Dragnet [Ransomware]: dragnet-ransomware-2023-4391 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: 39bfa9f5-b2d6-5ef5-a8c7-22fa1092f563

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
