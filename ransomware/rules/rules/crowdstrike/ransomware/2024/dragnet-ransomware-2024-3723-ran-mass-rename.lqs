// Dragnet [Ransomware]: dragnet-ransomware-2024-3723 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: e4782c9a-5dd5-50c8-8c2e-4af048b0e6f9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
