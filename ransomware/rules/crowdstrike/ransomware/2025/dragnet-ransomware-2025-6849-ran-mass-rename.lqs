// Dragnet [Ransomware]: dragnet-ransomware-2025-6849 — Mass File Rename (arcusmedia)
// Status: experimental | Level: high | ID: c4a6aebe-2cbe-57db-83e9-b0b77bbc55a6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
