// Dragnet [Ransomware]: dragnet-ransomware-2025-0545 — Mass File Rename (play)
// Status: experimental | Level: high | ID: d580300c-6969-50fe-8769-01a503363d74

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
