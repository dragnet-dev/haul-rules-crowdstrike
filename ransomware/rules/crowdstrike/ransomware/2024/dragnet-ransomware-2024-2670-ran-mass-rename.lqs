// Dragnet [Ransomware]: dragnet-ransomware-2024-2670 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: c7e2b4b3-4544-5491-b786-01f66aac79ff

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
