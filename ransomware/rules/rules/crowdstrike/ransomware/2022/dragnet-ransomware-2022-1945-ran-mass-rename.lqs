// Dragnet [Ransomware]: dragnet-ransomware-2022-1945 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 2eb62d3f-e099-5923-9469-6376d21c8a75

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
