// Dragnet [Ransomware]: dragnet-ransomware-2025-5893 — Mass File Rename (coinbasecartel)
// Status: test | Level: high | ID: 8520a068-abee-5b83-b0b8-f6a0c9ec48eb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
