// Dragnet [Ransomware]: dragnet-ransomware-2021-1154 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 34ee2e6a-6ddc-59f3-ad1d-7dffdb772da2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
