// Dragnet [Ransomware]: dragnet-ransomware-2024-4724 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: 53644e66-7ea8-5d6d-889b-a9c6f392bc45

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
