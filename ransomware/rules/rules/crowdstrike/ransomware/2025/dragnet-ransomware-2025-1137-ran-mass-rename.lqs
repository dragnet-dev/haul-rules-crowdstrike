// Dragnet [Ransomware]: dragnet-ransomware-2025-1137 — Mass File Rename (direwolf)
// Status: experimental | Level: high | ID: dfed2ab7-2893-565f-9ab6-43de6ffa2dc8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
