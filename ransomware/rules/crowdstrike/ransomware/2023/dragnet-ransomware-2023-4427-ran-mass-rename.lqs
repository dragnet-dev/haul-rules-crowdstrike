// Dragnet [Ransomware]: dragnet-ransomware-2023-4427 — Mass File Rename (cactus)
// Status: deprecated | Level: high | ID: c4183843-96aa-52a1-ad13-e69d1e71f6e9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
