// Dragnet [Ransomware]: dragnet-ransomware-2025-6764 — Mass File Rename (lockbit5)
// Status: test | Level: high | ID: 1fbaac2a-d326-5295-a741-5e055486f610

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
