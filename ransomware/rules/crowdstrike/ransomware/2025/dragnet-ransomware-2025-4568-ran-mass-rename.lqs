// Dragnet [Ransomware]: dragnet-ransomware-2025-4568 — Mass File Rename (monti)
// Status: experimental | Level: high | ID: f0cb69ed-345c-5515-84b3-8cee63fda8ab

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
