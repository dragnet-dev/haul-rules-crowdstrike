// Dragnet [Ransomware]: dragnet-ransomware-2025-2485 — Mass File Rename (thegentlemen)
// Status: experimental | Level: high | ID: 6725ef58-5ead-5a90-8be7-d584f3f5d61d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
