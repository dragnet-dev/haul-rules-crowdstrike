// Dragnet [Ransomware]: dragnet-ransomware-2025-2856 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 0c368528-5f71-58da-8d92-a1e555819b08

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
