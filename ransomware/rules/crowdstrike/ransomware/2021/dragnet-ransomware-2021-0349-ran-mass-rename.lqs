// Dragnet [Ransomware]: dragnet-ransomware-2021-0349 — Mass File Rename (spook)
// Status: deprecated | Level: high | ID: b975bd34-912a-519e-8b85-d3713566c084

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
