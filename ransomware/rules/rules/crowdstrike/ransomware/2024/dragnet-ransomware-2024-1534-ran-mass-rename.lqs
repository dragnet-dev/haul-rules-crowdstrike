// Dragnet [Ransomware]: dragnet-ransomware-2024-1534 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: da4998f8-0c94-598e-8acd-04d086611e78

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
