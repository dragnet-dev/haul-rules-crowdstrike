// Dragnet [Ransomware]: dragnet-ransomware-2023-0773 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 40938472-cafe-578b-b872-52aa5463c507

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
