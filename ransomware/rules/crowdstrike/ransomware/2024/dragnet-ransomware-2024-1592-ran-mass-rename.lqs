// Dragnet [Ransomware]: dragnet-ransomware-2024-1592 — Mass File Rename (threeam)
// Status: experimental | Level: high | ID: a53485f6-86b3-58ee-b4f6-fc9fcb778821

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
