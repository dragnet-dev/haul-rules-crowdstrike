// Dragnet [Ransomware]: dragnet-ransomware-2023-1345 — Mass File Rename (monti)
// Status: experimental | Level: high | ID: 302d56f4-e20a-527f-9223-31a73250eac5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
