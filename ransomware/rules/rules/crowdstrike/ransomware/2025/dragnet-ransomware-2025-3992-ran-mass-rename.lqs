// Dragnet [Ransomware]: dragnet-ransomware-2025-3992 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 3d0d576f-4b70-5472-ac4d-a7df079e6415

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
