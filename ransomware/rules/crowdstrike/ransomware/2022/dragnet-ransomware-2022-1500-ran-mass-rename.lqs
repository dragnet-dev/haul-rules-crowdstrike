// Dragnet [Ransomware]: dragnet-ransomware-2022-1500 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 09ddb54e-a3eb-50fe-a215-b9b843fe8189

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
