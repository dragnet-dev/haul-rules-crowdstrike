// Dragnet [Ransomware]: dragnet-ransomware-2023-0817 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 67a32953-42fb-5bde-833b-8456b5e59ccb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
