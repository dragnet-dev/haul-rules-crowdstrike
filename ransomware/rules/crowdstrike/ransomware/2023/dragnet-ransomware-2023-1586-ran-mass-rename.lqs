// Dragnet [Ransomware]: dragnet-ransomware-2023-1586 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 3e403edd-5549-5311-b5cc-9e806dc836a0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
