// Dragnet [Ransomware]: dragnet-ransomware-2022-2091 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 09ba41ad-c911-5161-a7ba-3c9addefde56

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
