// Dragnet [Ransomware]: dragnet-ransomware-2023-5369 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: f28bef01-b069-5c9b-8223-24931a34732d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
