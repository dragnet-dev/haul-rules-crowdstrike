// Dragnet [Ransomware]: dragnet-ransomware-2022-0417 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 9d3d4a4c-a26b-533e-b719-7fb651137c2d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
