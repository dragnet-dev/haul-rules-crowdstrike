// Dragnet [Ransomware]: dragnet-ransomware-2023-0060 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 46594c67-2467-5924-8c14-a1e7a210253f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
