// Dragnet [Ransomware]: dragnet-ransomware-2025-1957 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 23c27988-3890-59e9-8dd3-6a689a08c20d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
