// Dragnet [Ransomware]: dragnet-ransomware-2022-1264 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 9774066d-e582-5cb2-9087-6ee6c22437ad

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
