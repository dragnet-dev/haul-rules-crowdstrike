// Dragnet [Ransomware]: dragnet-ransomware-2024-2589 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 52504a36-c8fc-5016-a384-845552dae630

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
