// Dragnet [Ransomware]: dragnet-ransomware-2025-1882 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: fcf18933-a155-5d78-99ad-c827eb8bd2f3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
