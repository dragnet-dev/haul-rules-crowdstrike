// Dragnet [Ransomware]: dragnet-ransomware-2025-3933 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 883731c4-a023-5e22-8405-08e1d368f582

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
