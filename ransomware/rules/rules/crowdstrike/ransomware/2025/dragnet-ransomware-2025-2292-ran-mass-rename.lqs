// Dragnet [Ransomware]: dragnet-ransomware-2025-2292 — Mass File Rename (weyhro)
// Status: experimental | Level: high | ID: 1e96498a-5110-55e1-b404-61f3533fced3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
