// Dragnet [Ransomware]: dragnet-ransomware-2023-1862 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: e5856936-0ed2-59f7-a939-b64a6e6d52a2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
