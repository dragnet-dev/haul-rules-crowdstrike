// Dragnet [Container]: dragnet-container-2024-1451 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 45a8375c-52b6-5ee1-857c-b6e6088eeb14

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:8* OR ImageFileName = *debian:9* OR ImageFileName = *ubuntu:16.04* OR ImageFileName = *ubuntu:16.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
