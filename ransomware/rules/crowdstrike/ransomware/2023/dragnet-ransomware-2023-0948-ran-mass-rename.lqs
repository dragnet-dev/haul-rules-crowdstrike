// Dragnet [Ransomware]: dragnet-ransomware-2023-0948 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 00bc33fd-ddbd-5edb-8599-90a2eb970539

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
