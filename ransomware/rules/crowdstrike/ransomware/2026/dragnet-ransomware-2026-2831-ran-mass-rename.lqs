// Dragnet [Ransomware]: dragnet-ransomware-2026-2831 — Mass File Rename (dragonforce)
// Status: test | Level: high | ID: fe7dda72-4a83-59d9-a336-cff80d5f4e97

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
