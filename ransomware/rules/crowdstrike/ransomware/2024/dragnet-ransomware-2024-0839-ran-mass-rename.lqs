// Dragnet [Ransomware]: dragnet-ransomware-2024-0839 — Mass File Rename (arcusmedia)
// Status: experimental | Level: high | ID: d3a7b1ad-6372-50f8-83fc-e52229b83c4a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
