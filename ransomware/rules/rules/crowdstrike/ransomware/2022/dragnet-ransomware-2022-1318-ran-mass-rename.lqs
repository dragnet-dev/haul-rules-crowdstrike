// Dragnet [Ransomware]: dragnet-ransomware-2022-1318 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 5cca5778-3ff0-57f6-a5de-ce1fae64ff4d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
