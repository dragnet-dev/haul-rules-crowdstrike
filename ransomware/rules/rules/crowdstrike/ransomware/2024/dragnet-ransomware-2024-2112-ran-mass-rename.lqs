// Dragnet [Ransomware]: dragnet-ransomware-2024-2112 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 33f58be4-6f34-53f3-9022-aea72a7b2a2c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
