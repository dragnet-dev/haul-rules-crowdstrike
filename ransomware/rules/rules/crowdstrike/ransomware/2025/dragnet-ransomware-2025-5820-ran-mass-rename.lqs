// Dragnet [Ransomware]: dragnet-ransomware-2025-5820 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 9682eed8-74bb-597d-a5f4-f5e79fbf6a6f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
