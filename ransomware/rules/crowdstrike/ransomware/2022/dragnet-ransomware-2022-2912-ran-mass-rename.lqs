// Dragnet [Ransomware]: dragnet-ransomware-2022-2912 — Mass File Rename (alphv)
// Status: deprecated | Level: high | ID: 22d7527d-a82e-52d6-b903-e06bcc704b7c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
