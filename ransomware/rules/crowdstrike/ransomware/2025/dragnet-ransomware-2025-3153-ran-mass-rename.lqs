// Dragnet [Ransomware]: dragnet-ransomware-2025-3153 — Mass File Rename (worldleaks)
// Status: experimental | Level: high | ID: 20a148ed-756f-5142-ae0c-6f6aa0a37131

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
