// Dragnet [Ransomware]: dragnet-ransomware-2023-4832 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: b1377d66-cc49-5d75-ab06-1613cd8a8774

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
