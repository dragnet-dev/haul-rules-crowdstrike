// Dragnet [Ransomware]: dragnet-ransomware-2025-4002 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: cc52c576-52f0-533a-9a17-14f8afa02658

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
