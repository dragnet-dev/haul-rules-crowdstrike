// Dragnet [Ransomware]: dragnet-ransomware-2024-3700 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 92761c90-38c1-5ae9-b247-59c3c3823dab

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
