// Dragnet [Ransomware]: dragnet-ransomware-2024-4397 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 5f5a8ac5-86e0-5135-89ee-a0f962410026

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
