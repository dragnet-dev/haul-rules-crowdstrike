// Dragnet [Ransomware]: dragnet-ransomware-2025-4084 — Mass File Rename (sinobi)
// Status: experimental | Level: high | ID: 7767944c-0678-5ff4-8076-458ef1c529f1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
