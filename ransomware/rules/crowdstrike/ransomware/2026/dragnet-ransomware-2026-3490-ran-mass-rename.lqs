// Dragnet [Ransomware]: dragnet-ransomware-2026-3490 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 26ad87d5-67ed-5ba3-989e-6f6a488dddc4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
