// Dragnet [Ransomware]: dragnet-ransomware-2025-2967 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: ddecd9ed-09f5-506e-b190-9f33d27b67de

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
