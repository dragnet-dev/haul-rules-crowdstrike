// Dragnet [Ransomware]: dragnet-ransomware-2025-6923 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 8727e083-e132-5ced-96df-5eeab7a71945

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
