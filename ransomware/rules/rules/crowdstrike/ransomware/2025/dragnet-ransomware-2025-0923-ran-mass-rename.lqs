// Dragnet [Ransomware]: dragnet-ransomware-2025-0923 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 0dd1ea30-f342-5330-b22c-834739701fc3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
