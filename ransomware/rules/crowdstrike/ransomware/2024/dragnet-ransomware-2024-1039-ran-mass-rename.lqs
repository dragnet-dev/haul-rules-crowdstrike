// Dragnet [Ransomware]: dragnet-ransomware-2024-1039 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 4f0fa75e-75b9-56b5-8325-a1588955ae71

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
