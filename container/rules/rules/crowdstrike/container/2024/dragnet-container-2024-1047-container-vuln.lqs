// Dragnet [Container]: dragnet-container-2024-1047 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: bb26c446-3a22-54a3-bfd6-bddf2de0fc55

#event_simpleName=*
| (ImageFileName = *chainguard:* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *ubuntu:18.04-ESM* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
