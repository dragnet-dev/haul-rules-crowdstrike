// Dragnet [Container]: dragnet-container-2024-0470 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 2012953f-3a43-50a2-809d-6f0edc94553e

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
