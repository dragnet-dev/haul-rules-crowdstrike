// Dragnet [Ransomware]: dragnet-ransomware-2021-0177 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: e3c9c823-c774-52d2-a2c4-2ffe3e32bfd3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
