// Dragnet [Ransomware]: dragnet-ransomware-2025-3909 — Mass File Rename (J)
// Status: experimental | Level: high | ID: 487ace7f-a9bc-551b-8878-7d4a34903cda

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
