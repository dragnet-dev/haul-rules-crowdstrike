// Dragnet [Ransomware]: dragnet-ransomware-2023-4507 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 559f094a-1045-5936-8923-802eb66fdbc7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
