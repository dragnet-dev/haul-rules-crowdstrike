// Dragnet [Ransomware]: dragnet-ransomware-2023-4210 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 1f5c71af-f356-5291-a3e2-c1d338dffda8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
