// Dragnet [Container]: dragnet-container-2024-1141 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 1c248b08-d33a-5958-828c-f6c16d775fe0

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:9*)
| table([timestamp, ComputerName])
| limit(1000)
