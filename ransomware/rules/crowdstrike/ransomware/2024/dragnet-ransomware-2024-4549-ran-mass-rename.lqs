// Dragnet [Ransomware]: dragnet-ransomware-2024-4549 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 534e69f6-3438-5fab-84b6-2ccd186d6fe2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
