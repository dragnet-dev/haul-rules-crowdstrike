// Dragnet [Ransomware]: dragnet-ransomware-2022-0820 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: e90479e2-8954-5fa1-95b5-d7dbcde2ac24

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
