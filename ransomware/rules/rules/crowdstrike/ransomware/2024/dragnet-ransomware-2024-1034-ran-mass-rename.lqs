// Dragnet [Ransomware]: dragnet-ransomware-2024-1034 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 1719c6ee-3e5c-5608-9094-6d6fb1921751

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
