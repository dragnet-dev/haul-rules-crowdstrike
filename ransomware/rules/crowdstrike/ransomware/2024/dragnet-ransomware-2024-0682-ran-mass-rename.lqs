// Dragnet [Ransomware]: dragnet-ransomware-2024-0682 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 67e61a79-5562-5cce-8f47-aa91c49cc36a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
