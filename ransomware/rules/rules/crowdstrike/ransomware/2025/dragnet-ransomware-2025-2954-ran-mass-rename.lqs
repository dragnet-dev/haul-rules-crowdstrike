// Dragnet [Ransomware]: dragnet-ransomware-2025-2954 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: b5264178-2b64-5350-a8a7-2fb7d43c7122

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
