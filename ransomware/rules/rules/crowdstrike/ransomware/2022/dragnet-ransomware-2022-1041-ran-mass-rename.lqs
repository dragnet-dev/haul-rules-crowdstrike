// Dragnet [Ransomware]: dragnet-ransomware-2022-1041 — Mass File Rename (alphv)
// Status: deprecated | Level: high | ID: 71675702-aaea-539a-84ec-a7b141ef3a60

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
