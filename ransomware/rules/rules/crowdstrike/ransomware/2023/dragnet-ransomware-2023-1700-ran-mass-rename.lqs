// Dragnet [Ransomware]: dragnet-ransomware-2023-1700 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 61760e5e-33f1-59dc-a174-eb374347be38

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
