// Dragnet [Ransomware]: dragnet-ransomware-2025-5872 — Mass File Rename (ransomhouse)
// Status: experimental | Level: high | ID: ef5dc003-3597-59a3-a3d5-d101e2c74257

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
