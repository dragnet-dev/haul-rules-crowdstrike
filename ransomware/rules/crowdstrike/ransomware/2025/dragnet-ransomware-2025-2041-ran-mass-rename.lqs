// Dragnet [Ransomware]: dragnet-ransomware-2025-2041 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 379b9136-3aaf-5a0f-88d6-41e3b395aee8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
