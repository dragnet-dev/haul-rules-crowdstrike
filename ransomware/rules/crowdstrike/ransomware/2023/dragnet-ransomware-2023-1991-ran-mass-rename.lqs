// Dragnet [Ransomware]: dragnet-ransomware-2023-1991 — Mass File Rename (siegedsec)
// Status: experimental | Level: high | ID: 5d83c5d7-c049-5e6e-9385-c4c4b5ab586e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
