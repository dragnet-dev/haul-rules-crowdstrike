// Dragnet [Ransomware]: dragnet-ransomware-2024-0571 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: 1b2ef5cb-39d0-5165-b363-d65e18b72b40

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
