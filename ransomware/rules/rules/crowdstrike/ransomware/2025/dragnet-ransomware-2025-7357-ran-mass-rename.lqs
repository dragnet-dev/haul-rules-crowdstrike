// Dragnet [Ransomware]: dragnet-ransomware-2025-7357 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 9b976bae-2a1a-534f-bd07-fcb4a5aac8e4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
