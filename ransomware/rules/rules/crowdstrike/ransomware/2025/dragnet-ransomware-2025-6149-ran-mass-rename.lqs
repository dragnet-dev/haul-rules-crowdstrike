// Dragnet [Ransomware]: dragnet-ransomware-2025-6149 — Mass File Rename (lockbit5)
// Status: experimental | Level: high | ID: dd72c284-4294-5356-937e-f3c0cb2e7a8c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
