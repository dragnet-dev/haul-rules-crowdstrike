// Dragnet [Container]: dragnet-container-2024-0453 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: c94c329f-7c78-5129-97a0-31e1ac2d5894

#event_simpleName=*
| (ImageFileName = *debian:7* OR ImageFileName = *debian:8* OR ImageFileName = *ubuntu:14.04* OR ImageFileName = *ubuntu:14.04-ESM* OR ImageFileName = *ubuntu:16.04* OR ImageFileName = *ubuntu:16.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
