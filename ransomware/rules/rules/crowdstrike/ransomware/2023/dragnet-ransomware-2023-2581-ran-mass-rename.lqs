// Dragnet [Ransomware]: dragnet-ransomware-2023-2581 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: ca31827e-ede0-5f90-b67d-1bb40342a51d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
