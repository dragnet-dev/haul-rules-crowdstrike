// Dragnet [Ransomware]: dragnet-ransomware-2023-3997 — Mass File Rename (toufan)
// Status: deprecated | Level: high | ID: 69017442-707c-5cac-ad97-d20b24d47443

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
