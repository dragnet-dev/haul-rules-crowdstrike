// Dragnet [Ransomware]: dragnet-ransomware-2024-3178 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 761fe7c3-92e4-559a-bea1-221ca4684166

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
