// Dragnet [Ransomware]: dragnet-ransomware-2026-3021 — Mass File Rename (lockbit5)
// Status: stable | Level: high | ID: bb0c9322-387a-51b7-a455-e46ef41188c5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
