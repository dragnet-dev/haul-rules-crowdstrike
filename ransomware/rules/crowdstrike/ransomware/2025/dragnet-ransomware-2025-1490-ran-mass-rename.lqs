// Dragnet [Ransomware]: dragnet-ransomware-2025-1490 — Mass File Rename (threeam)
// Status: experimental | Level: high | ID: 76fc4a62-747e-538a-ac6b-5132aaf46612

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
