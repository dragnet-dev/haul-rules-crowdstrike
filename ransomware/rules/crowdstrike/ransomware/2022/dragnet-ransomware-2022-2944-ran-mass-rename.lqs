// Dragnet [Ransomware]: dragnet-ransomware-2022-2944 — Mass File Rename (cuba)
// Status: deprecated | Level: high | ID: e9375436-0ea3-5813-a769-84adc2bd7fed

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
