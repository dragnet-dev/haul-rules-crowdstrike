// Dragnet [Ransomware]: dragnet-ransomware-2022-0939 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: d149336b-8e73-5e16-a41c-92f5a68a4442

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
