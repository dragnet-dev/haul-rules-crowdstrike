// Dragnet [Ransomware]: dragnet-ransomware-2024-1391 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: f4d776d5-eb98-50f9-bae8-2859a61f362b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
