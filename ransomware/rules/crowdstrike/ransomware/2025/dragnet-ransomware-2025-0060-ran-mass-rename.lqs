// Dragnet [Ransomware]: dragnet-ransomware-2025-0060 — Mass File Rename (warlock)
// Status: deprecated | Level: high | ID: 5b0d5130-a033-5548-97ff-372dcded70c0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
