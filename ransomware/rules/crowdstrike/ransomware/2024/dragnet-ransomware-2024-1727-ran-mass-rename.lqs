// Dragnet [Ransomware]: dragnet-ransomware-2024-1727 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: fb24fa00-6fed-5d1e-ad7c-78756a0e48c6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
