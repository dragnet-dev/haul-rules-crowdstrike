// Dragnet [Ransomware]: dragnet-ransomware-2025-1101 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 834fb83a-8f49-52e6-be82-c5d6c042071f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
