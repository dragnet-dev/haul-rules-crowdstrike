// Dragnet [Ransomware]: dragnet-ransomware-2024-2211 — Mass File Rename (handala)
// Status: experimental | Level: high | ID: 19584364-1cc9-5515-a49d-8132f5746b8d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
