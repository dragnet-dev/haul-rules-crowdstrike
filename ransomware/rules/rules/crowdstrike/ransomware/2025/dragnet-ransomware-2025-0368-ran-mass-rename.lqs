// Dragnet [Ransomware]: dragnet-ransomware-2025-0368 — Mass File Rename (nova)
// Status: experimental | Level: high | ID: dc42c6ab-514b-59af-b7d5-20b3d372b602

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
