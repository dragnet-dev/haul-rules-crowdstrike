// Dragnet [Ransomware]: dragnet-ransomware-2024-3221 — Mass File Rename (spacebears)
// Status: experimental | Level: high | ID: 804ad539-4235-55d2-b72d-778ded7a5411

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
