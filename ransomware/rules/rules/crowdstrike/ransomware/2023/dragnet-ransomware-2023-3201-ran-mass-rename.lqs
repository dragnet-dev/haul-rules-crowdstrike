// Dragnet [Ransomware]: dragnet-ransomware-2023-3201 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 326bf331-1bdd-574e-ac6c-ca2457cdedbc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
