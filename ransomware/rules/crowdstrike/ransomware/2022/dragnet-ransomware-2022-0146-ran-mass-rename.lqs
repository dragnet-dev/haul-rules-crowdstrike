// Dragnet [Ransomware]: dragnet-ransomware-2022-0146 — Mass File Rename (revil)
// Status: deprecated | Level: high | ID: 933addb1-6ac6-5fac-962d-65dd1671ab63

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
