// Dragnet [Ransomware]: dragnet-ransomware-2025-2742 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 236115e9-3449-530b-ab20-2ae2079b6bb8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
