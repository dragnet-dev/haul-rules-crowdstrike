// Dragnet [Ransomware]: dragnet-ransomware-2023-2687 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: e5813216-ea04-5e7e-823c-4367c9e57833

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
