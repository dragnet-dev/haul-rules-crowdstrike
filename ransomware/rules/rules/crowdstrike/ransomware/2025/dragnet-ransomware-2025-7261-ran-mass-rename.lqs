// Dragnet [Ransomware]: dragnet-ransomware-2025-7261 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: dc878ee1-8aa5-5d0b-b6aa-64ecbcaa87a0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
