// Dragnet [Ransomware]: dragnet-ransomware-2022-2083 — Mass File Rename (medusalocker)
// Status: deprecated | Level: high | ID: f2fe4ae8-8676-5dd3-a0e6-bb29eb4cb7e2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
