// Dragnet [Ransomware]: dragnet-ransomware-2022-0023 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: d409a4de-2025-5ce2-b208-c8e3d704b5fe

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
