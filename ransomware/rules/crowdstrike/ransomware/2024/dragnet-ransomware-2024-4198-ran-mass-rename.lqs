// Dragnet [Ransomware]: dragnet-ransomware-2024-4198 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: a32acd05-944f-5580-a021-f3427cf7786f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
