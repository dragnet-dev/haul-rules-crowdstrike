// Dragnet [Ransomware]: dragnet-ransomware-2023-2992 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: be362cab-aafd-5618-b3e5-eb179e288d6f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
