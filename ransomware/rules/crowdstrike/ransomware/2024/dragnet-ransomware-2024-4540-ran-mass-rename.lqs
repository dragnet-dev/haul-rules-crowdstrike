// Dragnet [Ransomware]: dragnet-ransomware-2024-4540 — Mass File Rename (alphalocker)
// Status: experimental | Level: high | ID: 2dd3e741-bb30-5d14-9999-fe5ce56e4a12

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
