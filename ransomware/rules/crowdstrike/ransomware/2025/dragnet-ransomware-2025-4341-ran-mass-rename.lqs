// Dragnet [Ransomware]: dragnet-ransomware-2025-4341 — Mass File Rename (sinobi)
// Status: experimental | Level: high | ID: cca0d784-d7b0-5bbd-8f7e-d5d31caf9d77

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
