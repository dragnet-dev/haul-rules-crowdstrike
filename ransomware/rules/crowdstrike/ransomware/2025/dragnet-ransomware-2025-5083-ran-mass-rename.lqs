// Dragnet [Ransomware]: dragnet-ransomware-2025-5083 — Mass File Rename (monti)
// Status: experimental | Level: high | ID: 95998780-913d-522a-985e-9df43d0d7cbb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
