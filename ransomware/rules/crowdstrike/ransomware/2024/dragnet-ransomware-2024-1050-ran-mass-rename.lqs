// Dragnet [Ransomware]: dragnet-ransomware-2024-1050 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: d5927f82-31fd-56c4-81ec-3d8cf3f7b3d6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
