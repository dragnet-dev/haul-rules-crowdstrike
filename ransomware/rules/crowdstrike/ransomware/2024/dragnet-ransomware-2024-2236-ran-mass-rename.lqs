// Dragnet [Ransomware]: dragnet-ransomware-2024-2236 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 849fee17-3df3-5ea2-93ee-a41cafa757eb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
