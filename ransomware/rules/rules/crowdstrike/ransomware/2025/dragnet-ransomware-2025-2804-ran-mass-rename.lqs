// Dragnet [Ransomware]: dragnet-ransomware-2025-2804 — Mass File Rename (frag)
// Status: deprecated | Level: high | ID: 67d56445-6eb0-55e8-b9f2-34e6ce068e39

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
