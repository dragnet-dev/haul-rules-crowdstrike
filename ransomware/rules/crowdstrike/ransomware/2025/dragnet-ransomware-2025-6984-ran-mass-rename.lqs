// Dragnet [Ransomware]: dragnet-ransomware-2025-6984 — Mass File Rename (securotrop)
// Status: test | Level: high | ID: 552452ba-531d-5f86-aedb-5c9c0b7c28d2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
