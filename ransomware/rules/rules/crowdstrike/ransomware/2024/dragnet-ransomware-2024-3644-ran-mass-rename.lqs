// Dragnet [Ransomware]: dragnet-ransomware-2024-3644 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 0388a118-a92f-5ba7-bf95-3d0c7edae75f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
