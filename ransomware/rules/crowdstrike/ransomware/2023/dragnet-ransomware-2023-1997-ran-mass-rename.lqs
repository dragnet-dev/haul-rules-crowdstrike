// Dragnet [Ransomware]: dragnet-ransomware-2023-1997 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: db99749c-1d97-550e-a007-78b76363cf2c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
