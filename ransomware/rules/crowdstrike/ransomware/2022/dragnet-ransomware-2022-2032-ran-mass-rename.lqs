// Dragnet [Ransomware]: dragnet-ransomware-2022-2032 — Mass File Rename (cuba)
// Status: deprecated | Level: high | ID: a094e5d4-0e37-5f12-88e8-e2dba7e4226c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
