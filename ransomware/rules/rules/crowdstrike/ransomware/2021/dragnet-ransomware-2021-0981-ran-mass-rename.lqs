// Dragnet [Ransomware]: dragnet-ransomware-2021-0981 — Mass File Rename (spook)
// Status: deprecated | Level: high | ID: c9c5933e-d0f7-5586-88d4-ef1a7b94b737

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
