// Dragnet [Ransomware]: dragnet-ransomware-2024-3883 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 82ac041e-7368-5b82-8fef-d79fcda41e1c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
