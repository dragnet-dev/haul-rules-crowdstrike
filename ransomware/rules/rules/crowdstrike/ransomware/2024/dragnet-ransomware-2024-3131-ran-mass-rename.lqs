// Dragnet [Ransomware]: dragnet-ransomware-2024-3131 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: 3746c04b-4791-5998-988d-c45ea180a1b1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
