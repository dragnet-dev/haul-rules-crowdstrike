// Dragnet [Ransomware]: dragnet-ransomware-2023-3154 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 4652431a-3de3-5d3f-8b85-7fbe86103e7b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
