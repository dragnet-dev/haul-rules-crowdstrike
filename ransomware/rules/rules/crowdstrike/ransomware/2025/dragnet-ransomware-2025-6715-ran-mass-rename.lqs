// Dragnet [Ransomware]: dragnet-ransomware-2025-6715 — Mass File Rename (datacarry)
// Status: deprecated | Level: high | ID: 60915d7e-c0f1-5f26-94bb-c3cd04ec887a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
