// Dragnet [Ransomware]: dragnet-ransomware-2023-4103 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: bb660849-4587-537d-be2e-f037b3610da2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
