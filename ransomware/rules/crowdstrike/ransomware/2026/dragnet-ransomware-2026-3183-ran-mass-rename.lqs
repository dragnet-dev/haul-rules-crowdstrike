// Dragnet [Ransomware]: dragnet-ransomware-2026-3183 — Mass File Rename (coinbasecartel)
// Status: stable | Level: high | ID: fd1efcfd-88e3-5646-bb1e-d4b5c5b01913

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
