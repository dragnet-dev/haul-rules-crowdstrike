// Dragnet [Ransomware]: dragnet-ransomware-2022-0790 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 6910fa7a-34eb-5961-9cd9-57f85fba3abe

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
