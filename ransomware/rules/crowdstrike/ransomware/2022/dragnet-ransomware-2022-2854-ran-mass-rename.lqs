// Dragnet [Ransomware]: dragnet-ransomware-2022-2854 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: f9aac553-8630-5cd4-82b6-73e2ca207ae7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
