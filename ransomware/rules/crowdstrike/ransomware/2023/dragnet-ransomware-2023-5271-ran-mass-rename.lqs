// Dragnet [Ransomware]: dragnet-ransomware-2023-5271 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 83e097c7-3db4-5ef2-91d1-1f480fbf4c03

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
