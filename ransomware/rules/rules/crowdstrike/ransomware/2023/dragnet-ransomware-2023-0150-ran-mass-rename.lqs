// Dragnet [Ransomware]: dragnet-ransomware-2023-0150 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 960a6c03-4581-5d02-a7e2-458a25c56f35

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
