// Dragnet [Ransomware]: dragnet-ransomware-2023-2174 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: df05702d-dc2b-559f-a172-93d7ac0932f4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
