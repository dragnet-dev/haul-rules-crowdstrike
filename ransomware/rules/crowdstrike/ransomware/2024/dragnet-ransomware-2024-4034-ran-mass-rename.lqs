// Dragnet [Ransomware]: dragnet-ransomware-2024-4034 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 11805c24-6f12-557e-a7d7-83c8cc1ce678

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
