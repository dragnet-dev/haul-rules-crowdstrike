// Dragnet [Ransomware]: dragnet-ransomware-2024-0986 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: d803e0e3-15ac-598b-8496-bd386c26f377

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
