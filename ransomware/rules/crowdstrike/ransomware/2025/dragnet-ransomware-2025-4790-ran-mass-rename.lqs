// Dragnet [Ransomware]: dragnet-ransomware-2025-4790 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 77634723-d26a-5fbb-abc9-3d3748d00d46

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
