// Dragnet [Ransomware]: dragnet-ransomware-2024-1792 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 32a7e6ec-ce41-5cfc-9fb6-a56e5f67d3f2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
