// Dragnet [Ransomware]: dragnet-ransomware-2021-1627 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: e5340291-730f-5bf5-82ca-31b2715025c5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
