// Dragnet [Ransomware]: dragnet-ransomware-2024-1222 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 30ad5294-40c9-510a-8815-b44284d31c36

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
