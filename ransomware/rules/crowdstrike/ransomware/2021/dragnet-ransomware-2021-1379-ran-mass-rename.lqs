// Dragnet [Ransomware]: dragnet-ransomware-2021-1379 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 1e9afca7-8f30-59a4-a863-7385ce8e58c3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
