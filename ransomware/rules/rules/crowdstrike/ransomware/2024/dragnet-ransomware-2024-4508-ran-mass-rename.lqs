// Dragnet [Ransomware]: dragnet-ransomware-2024-4508 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: ae6373b5-0cfc-5cc7-87c2-227a9a646943

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
