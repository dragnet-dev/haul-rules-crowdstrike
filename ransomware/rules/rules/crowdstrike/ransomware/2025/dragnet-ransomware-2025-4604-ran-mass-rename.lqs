// Dragnet [Ransomware]: dragnet-ransomware-2025-4604 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: fe8de60e-8e40-5532-9b56-627da0e6389a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
