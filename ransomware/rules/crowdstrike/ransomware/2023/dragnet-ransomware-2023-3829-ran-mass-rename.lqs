// Dragnet [Ransomware]: dragnet-ransomware-2023-3829 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 08b04bba-9de5-5424-9aff-068cbd2c2749

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
