// Dragnet [Ransomware]: dragnet-ransomware-2025-3166 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: e81b39d5-5d74-54bd-859c-dc801eb339fa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
