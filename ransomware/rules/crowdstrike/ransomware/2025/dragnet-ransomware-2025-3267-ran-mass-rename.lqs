// Dragnet [Ransomware]: dragnet-ransomware-2025-3267 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: b681d456-ba60-50ba-a43c-6a6e760b90c9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
