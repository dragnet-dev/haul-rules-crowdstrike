// Dragnet [Container]: dragnet-container-2026-1343 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 5b28b671-2bbd-5566-ba6a-6e18f56c258a

#event_simpleName=*
| (ImageFileName = *amazonlinux:2023* OR ImageFileName = *chainguard:* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *ubuntu:24.10* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
