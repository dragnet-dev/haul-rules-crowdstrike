// Dragnet [Ransomware]: dragnet-ransomware-2025-1926 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: bf81639d-0b05-5a1a-9489-c3312f6700e9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
