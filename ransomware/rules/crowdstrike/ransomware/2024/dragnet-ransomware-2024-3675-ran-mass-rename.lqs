// Dragnet [Ransomware]: dragnet-ransomware-2024-3675 — Mass File Rename (abyss)
// Status: deprecated | Level: high | ID: 6d6b38bd-1268-5036-85a2-a6cdbd85134c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
