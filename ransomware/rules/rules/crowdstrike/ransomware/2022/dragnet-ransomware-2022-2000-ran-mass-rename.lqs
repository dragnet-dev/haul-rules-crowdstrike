// Dragnet [Ransomware]: dragnet-ransomware-2022-2000 — Mass File Rename (lv)
// Status: deprecated | Level: high | ID: 98b96349-5ecc-5c28-93b0-8e942fbd699f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
