// Dragnet [Ransomware]: dragnet-ransomware-2024-2638 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 3d2f85b3-e6b5-5cdf-a79e-b816d52c5b88

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
