// Dragnet [Ransomware]: dragnet-ransomware-2025-7646 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 9e1de40e-b3bf-567c-8e32-95c88a394eb6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
