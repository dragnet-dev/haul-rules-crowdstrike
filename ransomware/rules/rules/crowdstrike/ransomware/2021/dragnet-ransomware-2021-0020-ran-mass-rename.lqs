// Dragnet [Ransomware]: dragnet-ransomware-2021-0020 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: a005ea44-3ff2-5897-bfcf-044b29eb16a2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
