// Dragnet [Ransomware]: dragnet-ransomware-2024-0974 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: c74ba9cb-821f-55c2-8045-847a7b59f67d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
