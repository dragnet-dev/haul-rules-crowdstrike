// Dragnet [Container]: dragnet-container-2024-0358 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: c729f0d9-3cd8-5aab-be83-002379e0aa8a

#event_simpleName=*
| (ImageFileName = *amazonlinux:2023* OR ImageFileName = *oraclelinux:7* OR ImageFileName = *oraclelinux:8* OR ImageFileName = *redhat/ubi9:*)
| table([timestamp, ComputerName])
| limit(1000)
