// Dragnet [Ransomware]: dragnet-ransomware-2022-3022 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 5ae9a129-bf54-5d9b-b800-cc5f4bef2abf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
