// Dragnet [Ransomware]: dragnet-ransomware-2023-4562 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 7013293b-73f5-5d16-828b-2ca493de2b09

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
