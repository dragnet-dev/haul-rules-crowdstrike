// Dragnet [Ransomware]: dragnet-ransomware-2024-2537 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: d3c2a71a-6e5b-52c2-a3cb-3461f28118a0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
