// Dragnet [Ransomware]: dragnet-ransomware-2025-1649 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: dc6e9f68-e1f3-5549-80d5-e1177d293087

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
