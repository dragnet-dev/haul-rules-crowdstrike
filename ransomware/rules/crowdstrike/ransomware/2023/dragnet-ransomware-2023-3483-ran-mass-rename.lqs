// Dragnet [Ransomware]: dragnet-ransomware-2023-3483 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 3c18b422-4c7d-5ce6-b2ab-419d61979643

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
