// Dragnet [Ransomware]: dragnet-ransomware-2024-0881 — Mass File Rename (underground)
// Status: experimental | Level: high | ID: e7b33d9e-9181-5881-8a8c-2d26638cd3d0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
