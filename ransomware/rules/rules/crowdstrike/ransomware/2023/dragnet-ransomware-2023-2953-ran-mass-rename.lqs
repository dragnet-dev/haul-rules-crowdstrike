// Dragnet [Ransomware]: dragnet-ransomware-2023-2953 — Mass File Rename (rhysida)
// Status: experimental | Level: high | ID: a073c966-1146-58d6-ac43-eb9cc5b4fa23

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
