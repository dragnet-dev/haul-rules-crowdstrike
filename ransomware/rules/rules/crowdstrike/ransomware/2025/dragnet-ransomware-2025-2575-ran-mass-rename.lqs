// Dragnet [Ransomware]: dragnet-ransomware-2025-2575 — Mass File Rename (chaos)
// Status: experimental | Level: high | ID: ee57e991-e8d1-5701-81d0-5bb52ae71fdc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
