// Dragnet [Ransomware]: dragnet-ransomware-2025-7195 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 614a5d41-af67-528a-85aa-31a0a3b71dc2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
