// Dragnet [Container]: dragnet-container-2026-1207 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: ff51685a-5c56-5438-995a-cdcfd9238baa

#event_simpleName=*
| (ImageFileName = *alpine edge:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *redhat/ubi9:*)
| table([timestamp, ComputerName])
| limit(1000)
