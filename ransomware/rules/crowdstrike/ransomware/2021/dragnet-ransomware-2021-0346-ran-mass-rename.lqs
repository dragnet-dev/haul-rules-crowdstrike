// Dragnet [Ransomware]: dragnet-ransomware-2021-0346 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 431f5976-7e22-5b86-b368-0c55357cf625

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
