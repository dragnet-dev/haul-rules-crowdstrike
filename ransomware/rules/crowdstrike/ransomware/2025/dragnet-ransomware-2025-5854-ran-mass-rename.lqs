// Dragnet [Ransomware]: dragnet-ransomware-2025-5854 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 3c0385df-16ea-55ce-a24b-062ab849efd9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
