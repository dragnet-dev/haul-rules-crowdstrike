// Dragnet [Ransomware]: dragnet-ransomware-2025-6927 — Mass File Rename (direwolf)
// Status: experimental | Level: high | ID: cda92b4b-8fcb-56e4-ad10-c05a82630d4a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
