// Dragnet [Ransomware]: dragnet-ransomware-2024-5362 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: dfaf8c32-b141-5d4d-a0bd-eacff9fe6e22

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
