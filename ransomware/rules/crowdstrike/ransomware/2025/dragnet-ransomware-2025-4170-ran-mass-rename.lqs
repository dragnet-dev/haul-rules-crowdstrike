// Dragnet [Ransomware]: dragnet-ransomware-2025-4170 — Mass File Rename (play)
// Status: experimental | Level: high | ID: c00fb3ad-f410-5cd9-8437-ca2be9ce0e1d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
