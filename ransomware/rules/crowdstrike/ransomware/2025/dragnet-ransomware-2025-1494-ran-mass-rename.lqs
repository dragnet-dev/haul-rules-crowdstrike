// Dragnet [Ransomware]: dragnet-ransomware-2025-1494 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: ebf6896c-827b-527a-9650-c1a30a1320bb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
