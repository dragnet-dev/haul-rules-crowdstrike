// Dragnet [Ransomware]: dragnet-ransomware-2022-2615 — Mass File Rename (onyx)
// Status: deprecated | Level: high | ID: 9936920c-7543-589d-89d1-a830e3e561b9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
