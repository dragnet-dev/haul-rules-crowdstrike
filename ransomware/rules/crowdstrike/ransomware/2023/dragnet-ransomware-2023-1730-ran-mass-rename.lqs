// Dragnet [Ransomware]: dragnet-ransomware-2023-1730 — Mass File Rename (losttrust)
// Status: deprecated | Level: high | ID: 10aec8fc-17d3-50b3-8313-fddf4745e81a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
