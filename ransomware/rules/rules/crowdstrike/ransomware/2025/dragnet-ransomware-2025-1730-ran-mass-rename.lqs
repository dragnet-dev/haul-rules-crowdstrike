// Dragnet [Ransomware]: dragnet-ransomware-2025-1730 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: f9cfc3a9-6947-50d7-87f9-f8e348acc36e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
