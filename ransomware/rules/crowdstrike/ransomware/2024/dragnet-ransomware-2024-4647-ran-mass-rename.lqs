// Dragnet [Ransomware]: dragnet-ransomware-2024-4647 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: 6f8b1c3b-e5ee-5915-b1e9-afe2cfbb13b2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
