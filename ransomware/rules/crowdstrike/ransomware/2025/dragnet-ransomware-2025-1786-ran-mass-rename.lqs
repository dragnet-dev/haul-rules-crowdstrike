// Dragnet [Ransomware]: dragnet-ransomware-2025-1786 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 0bb15781-9485-5128-8520-c784e2777c35

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
