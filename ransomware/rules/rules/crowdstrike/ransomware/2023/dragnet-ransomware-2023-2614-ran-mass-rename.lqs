// Dragnet [Ransomware]: dragnet-ransomware-2023-2614 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 36d937df-f038-5124-bb32-dcde7707a7a9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
