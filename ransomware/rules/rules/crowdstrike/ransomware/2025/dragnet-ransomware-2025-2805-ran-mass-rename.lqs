// Dragnet [Ransomware]: dragnet-ransomware-2025-2805 — Mass File Rename (play)
// Status: experimental | Level: high | ID: b7cdfcc4-c311-52cd-a6bc-cd2aa7f48144

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
