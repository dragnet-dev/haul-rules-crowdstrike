// Dragnet [Ransomware]: dragnet-ransomware-2024-2509 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 8f46b088-a95f-539b-9fb5-8c37605bf957

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
