// Dragnet [Ransomware]: dragnet-ransomware-2026-1049 — Mass File Rename (thegentlemen)
// Status: stable | Level: high | ID: 5b7745c1-eeb5-5e7b-afcc-1ec562f451f2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
