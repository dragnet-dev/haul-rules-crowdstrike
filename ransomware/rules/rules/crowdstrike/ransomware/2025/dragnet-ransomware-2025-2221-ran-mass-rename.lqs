// Dragnet [Ransomware]: dragnet-ransomware-2025-2221 — Mass File Rename (spacebears)
// Status: test | Level: high | ID: f32a946d-e949-5157-a9fa-1247ed16a29b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
