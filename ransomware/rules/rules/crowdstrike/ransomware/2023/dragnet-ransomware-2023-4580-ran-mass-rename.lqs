// Dragnet [Ransomware]: dragnet-ransomware-2023-4580 — Mass File Rename (toufan)
// Status: deprecated | Level: high | ID: 9c2a008e-b882-5580-b93c-7a07e99c7c6c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
