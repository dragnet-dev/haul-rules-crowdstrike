// Dragnet [Ransomware]: dragnet-ransomware-2025-5046 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: c38d9148-1442-57c7-a393-bb340c305801

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
