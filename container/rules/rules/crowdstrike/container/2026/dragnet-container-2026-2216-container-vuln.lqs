// Dragnet [Container]: dragnet-container-2026-2216 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 24a1e058-6432-5e48-9234-dd6acdb7a1df

#event_simpleName=*
| (ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *ubuntu:12.04*)
| table([timestamp, ComputerName])
| limit(1000)
