// Dragnet [Container]: dragnet-container-2024-1008 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: cc1145ed-be25-536d-a37c-33a98fb3b120

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:8* OR ImageFileName = *debian:9* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:18.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
