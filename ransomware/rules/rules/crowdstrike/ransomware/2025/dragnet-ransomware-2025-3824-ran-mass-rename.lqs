// Dragnet [Ransomware]: dragnet-ransomware-2025-3824 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 59be9795-98af-5039-8524-2204f9248b64

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
