// Dragnet [Ransomware]: dragnet-ransomware-2025-5752 — Mass File Rename (direwolf)
// Status: experimental | Level: high | ID: 5ee8601c-c8a4-5cc0-a127-3770f291d85a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
