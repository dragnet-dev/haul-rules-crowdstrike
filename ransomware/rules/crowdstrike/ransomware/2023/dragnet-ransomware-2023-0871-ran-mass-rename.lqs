// Dragnet [Ransomware]: dragnet-ransomware-2023-0871 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: f551c233-4536-5c4e-8e0f-6eec53612740

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
