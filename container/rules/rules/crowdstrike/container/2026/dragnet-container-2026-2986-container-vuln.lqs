// Dragnet [Container]: dragnet-container-2026-2986 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 4048d1f7-d68e-5cdd-9960-9e1ef6d6d46e

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
