// Dragnet [Ransomware]: dragnet-ransomware-2022-1555 — Mass File Rename (vicesociety)
// Status: deprecated | Level: high | ID: 4b7f916f-e023-58f0-ad4c-fbeaabbea5d0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
