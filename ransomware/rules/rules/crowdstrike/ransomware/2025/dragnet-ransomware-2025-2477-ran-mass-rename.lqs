// Dragnet [Ransomware]: dragnet-ransomware-2025-2477 — Mass File Rename (thegentlemen)
// Status: experimental | Level: high | ID: b646515e-bfa6-5dc9-ba49-7214119acd02

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
