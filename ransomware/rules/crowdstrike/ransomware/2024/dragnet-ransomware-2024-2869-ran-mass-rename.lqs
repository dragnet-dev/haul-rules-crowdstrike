// Dragnet [Ransomware]: dragnet-ransomware-2024-2869 — Mass File Rename (darkvault)
// Status: experimental | Level: high | ID: e3acbd9d-af0a-5268-bfd2-3d3462a5547b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
