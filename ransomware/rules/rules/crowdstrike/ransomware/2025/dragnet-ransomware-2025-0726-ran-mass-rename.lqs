// Dragnet [Ransomware]: dragnet-ransomware-2025-0726 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: ca17625b-027a-53af-8fef-ef35d11d6f21

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
