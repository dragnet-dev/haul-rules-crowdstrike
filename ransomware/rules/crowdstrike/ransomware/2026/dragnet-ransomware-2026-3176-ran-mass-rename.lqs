// Dragnet [Ransomware]: dragnet-ransomware-2026-3176 — Mass File Rename (sinobi)
// Status: stable | Level: high | ID: 74721388-3528-5178-a02c-d056077bd8e8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
