// Dragnet [Ransomware]: dragnet-ransomware-2024-2237 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: b75c432f-744e-5f43-af0c-070087c02e44

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
