// Dragnet [Ransomware]: dragnet-ransomware-2022-1544 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 9999f27b-2359-5dfa-a212-0721370ec8c5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
