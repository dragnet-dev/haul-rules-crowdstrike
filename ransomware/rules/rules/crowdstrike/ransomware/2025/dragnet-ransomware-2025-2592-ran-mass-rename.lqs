// Dragnet [Ransomware]: dragnet-ransomware-2025-2592 — Mass File Rename (rhysida)
// Status: experimental | Level: high | ID: db504c58-1849-5de2-8810-a4939614fa79

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
