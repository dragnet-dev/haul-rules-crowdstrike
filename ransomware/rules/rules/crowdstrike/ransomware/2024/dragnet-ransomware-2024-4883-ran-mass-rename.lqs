// Dragnet [Ransomware]: dragnet-ransomware-2024-4883 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: d65b0d94-8fed-5a3e-9164-534a409c532d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
