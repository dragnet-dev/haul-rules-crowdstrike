// Dragnet [Ransomware]: dragnet-ransomware-2021-1416 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: f6d42331-46ea-5222-92c3-33bce8cb39de

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
