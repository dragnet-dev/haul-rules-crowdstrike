// Dragnet [Ransomware]: dragnet-ransomware-2024-3717 — Mass File Rename (blackout)
// Status: experimental | Level: high | ID: 98954096-afef-58a1-b53c-5bd1834b81aa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
