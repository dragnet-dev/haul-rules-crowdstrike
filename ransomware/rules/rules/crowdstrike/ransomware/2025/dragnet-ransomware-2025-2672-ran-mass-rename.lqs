// Dragnet [Ransomware]: dragnet-ransomware-2025-2672 — Mass File Rename (IMNCrew)
// Status: experimental | Level: high | ID: cdac1e00-04e6-5ee3-9cb9-b37e2f3e59df

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
