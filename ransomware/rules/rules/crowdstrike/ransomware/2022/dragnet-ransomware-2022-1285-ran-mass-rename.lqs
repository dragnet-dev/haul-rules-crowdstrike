// Dragnet [Ransomware]: dragnet-ransomware-2022-1285 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 8f0837a9-d1c7-5ca1-ac21-b9563b18653a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
