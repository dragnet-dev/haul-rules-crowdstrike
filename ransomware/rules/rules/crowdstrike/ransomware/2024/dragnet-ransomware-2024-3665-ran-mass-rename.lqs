// Dragnet [Ransomware]: dragnet-ransomware-2024-3665 — Mass File Rename (dragonransomware)
// Status: experimental | Level: high | ID: 481ac9f0-9f7e-5f44-99fc-c10012496046

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
