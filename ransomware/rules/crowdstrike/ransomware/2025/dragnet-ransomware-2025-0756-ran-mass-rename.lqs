// Dragnet [Ransomware]: dragnet-ransomware-2025-0756 — Mass File Rename (SilentRansomGroup)
// Status: deprecated | Level: high | ID: 4d0d1d49-9402-5cd1-83ee-5177a4c0eab4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
