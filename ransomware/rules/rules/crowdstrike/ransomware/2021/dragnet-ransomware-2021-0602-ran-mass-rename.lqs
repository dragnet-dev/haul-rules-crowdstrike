// Dragnet [Ransomware]: dragnet-ransomware-2021-0602 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: fecbf384-bab5-50c4-89ab-769a4638f438

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
