// Dragnet [Ransomware]: dragnet-ransomware-2026-1500 — Mass File Rename (payoutsking)
// Status: deprecated | Level: high | ID: 2c1e8cd2-17bf-50b6-90a3-b0d510428d8a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
