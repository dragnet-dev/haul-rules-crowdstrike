// Dragnet [Ransomware]: dragnet-ransomware-2022-1756 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 06b5aba9-cfa3-56cb-aa9a-b329a81213b3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
