// Dragnet [Container]: dragnet-container-2026-1571 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: f9ae4074-af67-567f-83c4-7670b2a89e5f

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6*)
| table([timestamp, ComputerName])
| limit(1000)
