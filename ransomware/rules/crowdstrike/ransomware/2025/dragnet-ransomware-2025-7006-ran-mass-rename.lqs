// Dragnet [Ransomware]: dragnet-ransomware-2025-7006 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: d89267cc-c0e9-5657-8791-664f74c51c4d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
