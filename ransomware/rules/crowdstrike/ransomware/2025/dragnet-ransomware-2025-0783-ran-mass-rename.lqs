// Dragnet [Ransomware]: dragnet-ransomware-2025-0783 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: 0a8ea5c1-e23f-59f1-bef2-8e0850169ec3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
