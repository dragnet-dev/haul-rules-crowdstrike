// Dragnet [Ransomware]: dragnet-ransomware-2022-0775 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: e494a021-24f6-549a-aaa0-90cfe2e395f5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
