// Dragnet [Ransomware]: dragnet-ransomware-2025-0496 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: d34f0385-3a7d-5372-aec8-f9ae683ff9b6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
