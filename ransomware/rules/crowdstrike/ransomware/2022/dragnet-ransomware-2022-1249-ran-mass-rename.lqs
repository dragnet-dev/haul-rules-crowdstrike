// Dragnet [Ransomware]: dragnet-ransomware-2022-1249 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 465c0aa3-fcdb-5d50-b15b-06bed75b042f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
