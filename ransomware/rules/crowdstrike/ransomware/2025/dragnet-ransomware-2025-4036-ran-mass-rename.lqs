// Dragnet [Ransomware]: dragnet-ransomware-2025-4036 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 52471f04-f2f4-5c20-91f4-0197822254d1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
