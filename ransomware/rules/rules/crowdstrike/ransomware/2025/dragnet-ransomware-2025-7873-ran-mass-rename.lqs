// Dragnet [Ransomware]: dragnet-ransomware-2025-7873 — Mass File Rename (hellcat)
// Status: deprecated | Level: high | ID: c913fa10-223a-5c8c-a604-c6c412236f7a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
