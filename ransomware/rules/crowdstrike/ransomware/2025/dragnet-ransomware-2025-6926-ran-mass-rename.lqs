// Dragnet [Ransomware]: dragnet-ransomware-2025-6926 — Mass File Rename (lockbit5)
// Status: experimental | Level: high | ID: 105a4b6e-db98-57eb-b5a3-612bb75b9273

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
