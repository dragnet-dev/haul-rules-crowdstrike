// Dragnet [Ransomware]: dragnet-ransomware-2025-5720 — Mass File Rename (SilentRansomGroup)
// Status: deprecated | Level: high | ID: 0cda78ad-f726-5e55-99e0-8fa7dab0469c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
