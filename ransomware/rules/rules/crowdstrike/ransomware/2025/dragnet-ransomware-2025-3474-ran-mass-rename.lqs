// Dragnet [Ransomware]: dragnet-ransomware-2025-3474 — Mass File Rename (cicada3301)
// Status: experimental | Level: high | ID: addcd5b7-b6e3-5241-a5df-7490e80feba2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
