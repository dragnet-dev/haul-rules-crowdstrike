// Dragnet [Ransomware]: dragnet-ransomware-2024-4164 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 8ece30e7-091b-586a-a961-cbb8f63df35a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
