// Dragnet [Ransomware]: dragnet-ransomware-2022-0022 — Mass File Rename (everest)
// Status: deprecated | Level: high | ID: 4e250322-98c6-51a5-8ce3-cec6348e2dcb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
