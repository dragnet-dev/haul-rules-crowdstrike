// Dragnet [Ransomware]: dragnet-ransomware-2023-0416 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 73131799-c3cc-5275-8507-c0bc643f0d29

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
