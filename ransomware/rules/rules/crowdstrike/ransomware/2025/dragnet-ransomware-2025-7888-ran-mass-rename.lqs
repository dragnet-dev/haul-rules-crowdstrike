// Dragnet [Ransomware]: dragnet-ransomware-2025-7888 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 24de5a18-bf19-5f5c-aa94-1ee6cd77eb74

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
