// Dragnet [Ransomware]: dragnet-ransomware-2024-3055 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: 4473b26c-4148-57ab-ae5c-9827b7334838

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
