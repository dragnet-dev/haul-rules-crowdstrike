// Dragnet [Ransomware]: dragnet-ransomware-2023-4485 — Mass File Rename (qilin)
// Status: deprecated | Level: high | ID: c2300eac-014e-5088-a86b-f260bdebb46c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
