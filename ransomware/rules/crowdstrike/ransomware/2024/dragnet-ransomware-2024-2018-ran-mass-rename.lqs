// Dragnet [Ransomware]: dragnet-ransomware-2024-2018 — Mass File Rename (threeam)
// Status: experimental | Level: high | ID: 5825791d-a012-5a10-97bb-be53ec65852c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
