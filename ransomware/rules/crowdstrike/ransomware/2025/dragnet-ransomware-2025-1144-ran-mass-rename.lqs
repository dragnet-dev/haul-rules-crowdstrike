// Dragnet [Ransomware]: dragnet-ransomware-2025-1144 — Mass File Rename (play)
// Status: experimental | Level: high | ID: d3c6677d-df00-5e19-a11d-541ae85f6bbf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
