// Dragnet [Ransomware]: dragnet-ransomware-2025-7268 — Mass File Rename (beast)
// Status: experimental | Level: high | ID: 799536c7-37df-5e8f-8223-8cc5f2bab5bf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
