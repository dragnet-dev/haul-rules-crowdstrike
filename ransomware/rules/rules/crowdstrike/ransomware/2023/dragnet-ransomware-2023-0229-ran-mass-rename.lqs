// Dragnet [Ransomware]: dragnet-ransomware-2023-0229 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: 477f7e15-48c3-57f4-b3b1-65975385dc45

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
