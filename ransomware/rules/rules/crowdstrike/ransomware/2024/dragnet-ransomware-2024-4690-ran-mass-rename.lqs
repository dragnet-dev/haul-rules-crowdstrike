// Dragnet [Ransomware]: dragnet-ransomware-2024-4690 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 26e439ca-1d27-5f8a-8e14-213d9618cd18

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
