// Dragnet [Ransomware]: dragnet-ransomware-2024-5974 — Mass File Rename (cloak)
// Status: deprecated | Level: high | ID: fa36cd6c-6873-5ed1-b648-2212c1168fd0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
