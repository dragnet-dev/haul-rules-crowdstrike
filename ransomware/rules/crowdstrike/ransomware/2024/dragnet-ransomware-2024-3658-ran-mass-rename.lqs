// Dragnet [Ransomware]: dragnet-ransomware-2024-3658 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 64c788a6-3f82-56d5-ab8e-43cc65c0eb2c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
