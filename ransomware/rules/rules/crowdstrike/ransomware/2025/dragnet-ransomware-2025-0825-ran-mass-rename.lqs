// Dragnet [Ransomware]: dragnet-ransomware-2025-0825 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: f56c1aa6-5aba-5f7e-83fc-fac38fbce417

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
