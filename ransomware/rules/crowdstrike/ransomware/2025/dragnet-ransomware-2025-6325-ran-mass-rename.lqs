// Dragnet [Ransomware]: dragnet-ransomware-2025-6325 — Mass File Rename (pear)
// Status: experimental | Level: high | ID: 3c43eb29-076f-5b31-93e0-3f18ff92e3d8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
