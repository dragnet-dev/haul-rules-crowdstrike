// Dragnet [Ransomware]: dragnet-ransomware-2024-5134 — Mass File Rename (play)
// Status: experimental | Level: high | ID: a9046500-0b7d-5661-9d67-355fe1576757

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
