// Dragnet [Container]: dragnet-container-2026-2533 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: ed0e8856-9791-549f-b2de-f15ff956d015

#event_simpleName=*
| (ImageFileName = *debian:7* OR ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *oraclelinux:7* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:14.04*)
| table([timestamp, ComputerName])
| limit(1000)
