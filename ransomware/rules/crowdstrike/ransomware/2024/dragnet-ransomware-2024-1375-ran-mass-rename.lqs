// Dragnet [Ransomware]: dragnet-ransomware-2024-1375 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 54ef0ca4-2034-55bf-b354-337ae8933a13

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
