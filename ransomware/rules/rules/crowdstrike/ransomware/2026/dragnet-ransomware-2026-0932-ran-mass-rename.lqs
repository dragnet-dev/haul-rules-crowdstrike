// Dragnet [Ransomware]: dragnet-ransomware-2026-0932 — Mass File Rename (dragonforce)
// Status: stable | Level: high | ID: 4a6cd01c-0e5b-5f01-946c-43cb68902cb7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
