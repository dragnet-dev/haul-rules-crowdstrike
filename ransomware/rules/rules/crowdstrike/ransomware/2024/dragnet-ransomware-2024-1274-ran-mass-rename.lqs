// Dragnet [Ransomware]: dragnet-ransomware-2024-1274 — Mass File Rename (cloak)
// Status: deprecated | Level: high | ID: f8eba23c-f2e6-5399-bc00-4c99f1165ef4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
