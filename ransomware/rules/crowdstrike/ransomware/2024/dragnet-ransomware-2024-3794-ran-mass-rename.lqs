// Dragnet [Ransomware]: dragnet-ransomware-2024-3794 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: 6567836b-18f4-54a5-937d-bb183000c61b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
