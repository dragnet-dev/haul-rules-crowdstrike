// Dragnet [Ransomware]: dragnet-ransomware-2025-1528 — Mass File Rename (handala)
// Status: experimental | Level: high | ID: 7dfd7817-8191-5ba8-97aa-f64e715be0c8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
