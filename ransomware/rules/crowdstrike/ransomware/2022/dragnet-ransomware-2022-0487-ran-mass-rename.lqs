// Dragnet [Ransomware]: dragnet-ransomware-2022-0487 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: eb6175b1-e2d2-5562-8172-68b80a7ee119

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
