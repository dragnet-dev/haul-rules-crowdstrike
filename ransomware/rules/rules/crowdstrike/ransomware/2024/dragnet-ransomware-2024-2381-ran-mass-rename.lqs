// Dragnet [Ransomware]: dragnet-ransomware-2024-2381 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 20e466d7-787c-5798-a69b-7d86de78d81a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
