// Dragnet [Ransomware]: dragnet-ransomware-2024-1110 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: f63ccd04-c58c-5d02-a493-894a3246804a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
