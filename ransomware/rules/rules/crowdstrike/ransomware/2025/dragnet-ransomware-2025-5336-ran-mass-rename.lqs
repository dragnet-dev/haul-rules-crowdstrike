// Dragnet [Ransomware]: dragnet-ransomware-2025-5336 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 2ab1f7a4-9ad7-57d4-9aa5-3d12d97787d6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
