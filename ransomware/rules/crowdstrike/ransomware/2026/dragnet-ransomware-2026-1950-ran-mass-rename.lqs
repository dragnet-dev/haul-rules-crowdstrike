// Dragnet [Ransomware]: dragnet-ransomware-2026-1950 — Mass File Rename (incransom)
// Status: stable | Level: high | ID: 88fbaecc-288c-5b61-869f-fee77cebbd4b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
