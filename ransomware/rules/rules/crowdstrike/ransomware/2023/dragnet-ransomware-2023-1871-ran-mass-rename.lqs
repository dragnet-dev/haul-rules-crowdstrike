// Dragnet [Ransomware]: dragnet-ransomware-2023-1871 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: d475b64e-0c0f-5140-9bb4-05e9ef4f4ded

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
