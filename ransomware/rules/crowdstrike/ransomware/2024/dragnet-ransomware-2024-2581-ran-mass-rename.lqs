// Dragnet [Ransomware]: dragnet-ransomware-2024-2581 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: e649227f-a3e0-5401-a03a-01c373996885

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
