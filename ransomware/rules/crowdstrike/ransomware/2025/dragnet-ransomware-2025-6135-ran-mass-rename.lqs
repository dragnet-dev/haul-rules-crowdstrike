// Dragnet [Ransomware]: dragnet-ransomware-2025-6135 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 602e3ff3-c1ed-5ad3-a5b5-416c1ad6066f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
