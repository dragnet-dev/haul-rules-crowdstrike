// Dragnet [Ransomware]: dragnet-ransomware-2025-5142 — Mass File Rename (embargo)
// Status: experimental | Level: high | ID: 532bf9cd-8985-5da4-950b-22ed0f05c971

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
