// Dragnet [Ransomware]: dragnet-ransomware-2023-0324 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: bda114e3-af2f-5755-870b-b2a87d2170a7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
