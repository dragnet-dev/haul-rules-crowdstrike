// Dragnet [Ransomware]: dragnet-ransomware-2024-0204 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: f4b62ed3-9b90-56c9-807f-0ce4fde4a03f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
