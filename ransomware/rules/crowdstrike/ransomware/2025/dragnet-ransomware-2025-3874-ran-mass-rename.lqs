// Dragnet [Ransomware]: dragnet-ransomware-2025-3874 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 1d461ece-8c81-5216-bd62-109ee8fcf346

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
