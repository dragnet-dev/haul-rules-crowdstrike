// Dragnet [Ransomware]: dragnet-ransomware-2021-0632 — Mass File Rename (blackmatter)
// Status: deprecated | Level: high | ID: f38b26a8-abf3-5023-a998-547a2b2dabc6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
