// Dragnet [Ransomware]: dragnet-ransomware-2023-3867 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 450544a7-da5a-561d-b01a-56d8feffee84

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
