// Dragnet [Ransomware]: dragnet-ransomware-2023-4716 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: db5df424-0980-570f-b489-21c14b502ff3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
