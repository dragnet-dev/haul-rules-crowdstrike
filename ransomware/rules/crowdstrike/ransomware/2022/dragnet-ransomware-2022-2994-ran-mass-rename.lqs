// Dragnet [Ransomware]: dragnet-ransomware-2022-2994 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 61d14348-d1fc-5c02-b30a-d42a7382ccb1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
