// Dragnet [Ransomware]: dragnet-ransomware-2021-1132 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 4cb7d42e-1e56-597c-808f-c7c8f691fdc9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
