// Dragnet [Ransomware]: dragnet-ransomware-2024-5809 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 5e324eaf-0202-594e-a6bf-76eed71db228

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
