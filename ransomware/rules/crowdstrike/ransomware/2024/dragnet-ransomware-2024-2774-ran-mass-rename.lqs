// Dragnet [Ransomware]: dragnet-ransomware-2024-2774 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 27ba5747-18d5-58ce-9c76-a43cbbebbd74

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
