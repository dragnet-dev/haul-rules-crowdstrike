// Dragnet [Ransomware]: dragnet-ransomware-2025-1880 — Mass File Rename (d4rk4rmy)
// Status: experimental | Level: high | ID: 748b7b86-5b85-5cc0-9520-da86cbc45af3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
