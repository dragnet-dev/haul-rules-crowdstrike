// Dragnet [Ransomware]: dragnet-ransomware-2025-3203 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: c8b27994-3b0a-5692-a625-f44663784621

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
