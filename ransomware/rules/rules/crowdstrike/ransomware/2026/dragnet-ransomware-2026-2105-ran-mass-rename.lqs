// Dragnet [Ransomware]: dragnet-ransomware-2026-2105 — Mass File Rename (killsec)
// Status: deprecated | Level: high | ID: f2ff6eb0-cb8c-55fa-ada7-a64e93204be9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
