// Dragnet [Container]: dragnet-container-2026-2655 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: c8278c4f-2ac2-507c-ac90-6cfb7d1a33a0

#event_simpleName=*
| (ImageFileName = *alpine:3.24* OR ImageFileName = *alpine edge:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
