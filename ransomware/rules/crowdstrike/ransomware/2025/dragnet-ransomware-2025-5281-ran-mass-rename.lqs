// Dragnet [Ransomware]: dragnet-ransomware-2025-5281 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: a35ddefc-8281-5f89-92c4-4a916887a6f7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
