// Dragnet [Container]: dragnet-container-2026-0930 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: e8125b4e-fa04-55a3-8a95-53331c3c503f

#event_simpleName=*
| (ImageFileName = *amazonlinux:1* OR ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10* OR ImageFileName = *ubuntu:13.04* OR ImageFileName = *ubuntu:13.10*)
| table([timestamp, ComputerName])
| limit(1000)
