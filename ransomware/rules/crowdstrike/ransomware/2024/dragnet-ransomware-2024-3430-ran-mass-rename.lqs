// Dragnet [Ransomware]: dragnet-ransomware-2024-3430 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: a3f8983f-1aeb-5598-b628-547efd839679

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
