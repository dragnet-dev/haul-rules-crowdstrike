// Dragnet [Ransomware]: dragnet-ransomware-2023-0602 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 3ed34f09-7093-5351-acee-dbdf9f782b66

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
