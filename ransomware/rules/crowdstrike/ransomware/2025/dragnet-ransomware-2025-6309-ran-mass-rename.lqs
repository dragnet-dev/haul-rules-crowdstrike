// Dragnet [Ransomware]: dragnet-ransomware-2025-6309 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: cbb93422-678a-5c88-81c2-a03485dc6bb0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
