// Dragnet [Ransomware]: dragnet-ransomware-2022-2547 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 466caafe-920a-5e72-82c5-44908c1001eb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
