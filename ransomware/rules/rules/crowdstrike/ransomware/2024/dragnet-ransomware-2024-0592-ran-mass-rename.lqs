// Dragnet [Ransomware]: dragnet-ransomware-2024-0592 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 62efecb3-4a8e-5450-ad2c-53f64725ef8b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
