// Dragnet [Ransomware]: dragnet-ransomware-2023-1846 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: c4aa4b29-2253-5e13-8ec5-3c330f9fa694

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
