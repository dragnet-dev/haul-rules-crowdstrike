// Dragnet [Ransomware]: dragnet-ransomware-2024-3291 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: f5e8b3d8-b7a7-597f-829b-e290eea0d5d3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
