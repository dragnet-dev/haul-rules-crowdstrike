// Dragnet [Ransomware]: dragnet-ransomware-2025-3948 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 9414f275-4b3b-58aa-ac7b-98300a2dc29c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
