// Dragnet [Ransomware]: dragnet-ransomware-2025-4221 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: 0b0adbfd-a0fc-57d9-9dfb-9bd8ed1368c5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
