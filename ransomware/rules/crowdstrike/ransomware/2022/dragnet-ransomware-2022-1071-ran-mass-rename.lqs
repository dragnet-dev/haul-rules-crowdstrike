// Dragnet [Ransomware]: dragnet-ransomware-2022-1071 — Mass File Rename (sabbath)
// Status: deprecated | Level: high | ID: 3a618169-89de-59c3-8e58-53f5320f2f66

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
