// Dragnet [Ransomware]: dragnet-ransomware-2026-2151 — Mass File Rename (incransom)
// Status: stable | Level: high | ID: 1e0ee472-2b34-5007-88b6-17ba8fa7c18e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
