// Dragnet [Ransomware]: dragnet-ransomware-2025-0980 — Mass File Rename (nova)
// Status: experimental | Level: high | ID: 12ea48b0-b9cc-53a2-90c0-223b497acced

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
