// Dragnet [Ransomware]: dragnet-ransomware-2025-4573 — Mass File Rename (abyss)
// Status: deprecated | Level: high | ID: 008dc557-0365-507f-b9ab-1e4751664105

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
