// Dragnet [Ransomware]: dragnet-ransomware-2024-5460 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 070eaf61-645e-5e1a-97e5-2ebff3f57032

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
