// Dragnet [Ransomware]: dragnet-ransomware-2024-5825 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 122efcd6-ac6a-5e61-9ee6-29b2c421e8cf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
