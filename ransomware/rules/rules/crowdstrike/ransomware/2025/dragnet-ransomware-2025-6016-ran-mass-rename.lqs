// Dragnet [Ransomware]: dragnet-ransomware-2025-6016 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 6d2076b7-f08f-586d-ba83-96fa88b73210

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
