// Dragnet [Ransomware]: dragnet-ransomware-2024-1697 — Mass File Rename (vanirgroup)
// Status: deprecated | Level: high | ID: 64c6a0f6-2a76-5f75-b267-fda9f92f26cf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
