// Dragnet [Ransomware]: dragnet-ransomware-2023-3632 — Mass File Rename (monti)
// Status: experimental | Level: high | ID: 4c831189-8f4d-5d59-980d-7855f303b0ac

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
