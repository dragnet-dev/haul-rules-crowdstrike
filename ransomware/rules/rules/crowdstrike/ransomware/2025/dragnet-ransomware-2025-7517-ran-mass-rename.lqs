// Dragnet [Ransomware]: dragnet-ransomware-2025-7517 — Mass File Rename (play)
// Status: experimental | Level: high | ID: f72c9584-441a-5498-b77d-2e1339e807bd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
