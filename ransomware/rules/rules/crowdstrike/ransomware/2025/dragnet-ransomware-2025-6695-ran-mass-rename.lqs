// Dragnet [Ransomware]: dragnet-ransomware-2025-6695 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 25c6b838-bcc0-56a0-b5b4-4e908d74ce52

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
