// Dragnet [Container]: dragnet-container-2026-2899 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 23b3f30c-877d-5077-847e-6bbf98913de2

#event_simpleName=*
| (ImageFileName = *debian:7* OR ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *oraclelinux:7* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:13.10* OR ImageFileName = *ubuntu:14.04*)
| table([timestamp, ComputerName])
| limit(1000)
