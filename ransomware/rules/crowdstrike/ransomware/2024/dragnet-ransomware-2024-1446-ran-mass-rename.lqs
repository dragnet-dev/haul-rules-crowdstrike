// Dragnet [Ransomware]: dragnet-ransomware-2024-1446 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: f6d69e23-d5b7-5fa4-a456-9f2aedfaf00b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
