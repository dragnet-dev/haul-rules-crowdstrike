// Dragnet [Ransomware]: dragnet-ransomware-2025-0694 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 5fe8f11b-f6cb-526d-a083-47503961d068

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
