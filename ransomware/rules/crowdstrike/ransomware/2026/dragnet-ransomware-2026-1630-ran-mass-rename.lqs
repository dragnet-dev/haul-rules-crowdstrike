// Dragnet [Ransomware]: dragnet-ransomware-2026-1630 — Mass File Rename (incransom)
// Status: stable | Level: high | ID: 1b08010a-6235-59eb-bfcc-4b37ab1d0df2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
