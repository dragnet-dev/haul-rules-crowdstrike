// Dragnet [Ransomware]: dragnet-ransomware-2026-0441 — Mass File Rename (direwolf)
// Status: test | Level: high | ID: b07ae0dd-eba0-5594-9be5-edb117e5031a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
