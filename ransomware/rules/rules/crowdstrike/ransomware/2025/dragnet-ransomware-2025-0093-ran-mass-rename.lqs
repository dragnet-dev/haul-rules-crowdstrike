// Dragnet [Ransomware]: dragnet-ransomware-2025-0093 — Mass File Rename (play)
// Status: experimental | Level: high | ID: a11becc3-5fa2-5da9-910a-82efe149d97c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
