// Dragnet [Container]: dragnet-container-2026-1918 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 884f3818-4c32-5aa7-943e-9611b5c524c3

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:7* OR ImageFileName = *debian:8* OR ImageFileName = *debian:9*)
| table([timestamp, ComputerName])
| limit(1000)
