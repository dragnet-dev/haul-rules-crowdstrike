// Dragnet [Ransomware]: dragnet-ransomware-2022-0569 — Mass File Rename (sabbath)
// Status: deprecated | Level: high | ID: 5d1daf0d-ba20-5fb0-8793-335e8d9a1fbe

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
