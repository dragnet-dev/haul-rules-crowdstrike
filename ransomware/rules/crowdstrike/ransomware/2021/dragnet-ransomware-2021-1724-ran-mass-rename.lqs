// Dragnet [Ransomware]: dragnet-ransomware-2021-1724 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 73a12308-5c93-5759-a247-ef78e3e80f2c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
