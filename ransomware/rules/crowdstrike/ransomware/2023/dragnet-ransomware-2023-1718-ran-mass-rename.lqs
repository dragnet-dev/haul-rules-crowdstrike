// Dragnet [Ransomware]: dragnet-ransomware-2023-1718 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: 8591234c-040d-5c55-8e48-0b680a44d454

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
