// Dragnet [Ransomware]: dragnet-ransomware-2024-2659 — Mass File Rename (meow)
// Status: experimental | Level: high | ID: e738e13c-71c6-5d80-b1cb-e6d98f480b21

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
