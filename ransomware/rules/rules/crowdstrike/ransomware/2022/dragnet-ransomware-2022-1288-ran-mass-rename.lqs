// Dragnet [Ransomware]: dragnet-ransomware-2022-1288 — Mass File Rename (revil)
// Status: deprecated | Level: high | ID: f26b1787-f079-59b8-a9b4-a07b9bc6ff6e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
