// Dragnet [Ransomware]: dragnet-ransomware-2021-0418 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 182ca099-1ccf-554a-86e7-e39aa5c80aba

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
