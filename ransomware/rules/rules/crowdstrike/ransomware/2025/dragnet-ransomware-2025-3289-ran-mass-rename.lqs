// Dragnet [Ransomware]: dragnet-ransomware-2025-3289 — Mass File Rename (SilentRansomGroup)
// Status: deprecated | Level: high | ID: 5d60c753-0803-5618-8db6-dfe6df9f2d45

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
