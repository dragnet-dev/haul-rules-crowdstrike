// Dragnet [Ransomware]: dragnet-ransomware-2025-2670 — Mass File Rename (J)
// Status: experimental | Level: high | ID: ec2a4858-a918-595a-b130-312a65f52315

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
