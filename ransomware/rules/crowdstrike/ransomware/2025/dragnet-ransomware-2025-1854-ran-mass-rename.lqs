// Dragnet [Ransomware]: dragnet-ransomware-2025-1854 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 55e36714-a6b6-5dba-a96f-0c7c42bc99d1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
