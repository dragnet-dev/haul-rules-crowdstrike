// Dragnet [Ransomware]: dragnet-ransomware-2022-1683 — Mass File Rename (la_piovra)
// Status: experimental | Level: high | ID: bf210bed-cc6c-5142-b058-0d02bed4b162

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
