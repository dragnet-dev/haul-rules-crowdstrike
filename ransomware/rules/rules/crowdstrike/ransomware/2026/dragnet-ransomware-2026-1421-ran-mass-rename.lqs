// Dragnet [Ransomware]: dragnet-ransomware-2026-1421 — Mass File Rename (shinyhunters)
// Status: deprecated | Level: high | ID: 88ce847e-2e2d-56e9-a74e-e5f948b06259

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
