// Dragnet [Ransomware]: dragnet-ransomware-2024-1829 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: eeed9335-8282-5b83-aedc-b079c650c6ba

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
