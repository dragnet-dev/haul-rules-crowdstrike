// Dragnet [Ransomware]: dragnet-ransomware-2023-3746 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 775d1d24-f73a-572c-8340-ba3db2087c18

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
