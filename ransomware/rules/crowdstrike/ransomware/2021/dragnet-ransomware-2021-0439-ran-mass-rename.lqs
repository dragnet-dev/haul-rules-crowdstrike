// Dragnet [Ransomware]: dragnet-ransomware-2021-0439 — Mass File Rename (lapsus$)
// Status: deprecated | Level: high | ID: ea26c485-c12a-5912-ae4f-563cae95e58f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
