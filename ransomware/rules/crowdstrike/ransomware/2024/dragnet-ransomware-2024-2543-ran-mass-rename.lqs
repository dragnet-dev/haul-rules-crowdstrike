// Dragnet [Ransomware]: dragnet-ransomware-2024-2543 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: f760bd54-3fcf-5b35-9436-7ac78dfff417

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
