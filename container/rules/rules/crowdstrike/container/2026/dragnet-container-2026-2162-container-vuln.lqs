// Dragnet [Container]: dragnet-container-2026-2162 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: f2a76e52-3053-5d18-858b-72f71f9e3efc

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:7* OR ImageFileName = *debian:8* OR ImageFileName = *debian:9* OR ImageFileName = *redhat/ubi9:*)
| table([timestamp, ComputerName])
| limit(1000)
