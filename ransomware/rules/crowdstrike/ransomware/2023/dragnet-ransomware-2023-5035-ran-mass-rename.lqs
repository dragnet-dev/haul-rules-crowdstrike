// Dragnet [Ransomware]: dragnet-ransomware-2023-5035 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: d735746d-c865-5391-8728-e5e685e618f0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
