// Dragnet [Ransomware]: dragnet-ransomware-2026-2338 — Mass File Rename (shinyhunters)
// Status: deprecated | Level: high | ID: c4a5abf5-242c-526e-b461-02011c167646

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
