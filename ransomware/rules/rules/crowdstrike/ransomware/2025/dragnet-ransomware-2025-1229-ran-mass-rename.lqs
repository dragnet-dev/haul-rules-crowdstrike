// Dragnet [Ransomware]: dragnet-ransomware-2025-1229 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 02528cdd-bc00-51b0-b9de-f5f1483eadd2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
