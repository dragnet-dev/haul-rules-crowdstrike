// Dragnet [Ransomware]: dragnet-ransomware-2025-2778 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 515a953a-09ef-5770-8f05-30a635effcf8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
