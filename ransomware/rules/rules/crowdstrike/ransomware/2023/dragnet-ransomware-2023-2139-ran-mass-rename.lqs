// Dragnet [Ransomware]: dragnet-ransomware-2023-2139 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 0341e288-0d64-51af-8d67-1f4e713b4cec

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
