// Dragnet [Ransomware]: dragnet-ransomware-2026-1682 — Mass File Rename (AuditTeam)
// Status: stable | Level: high | ID: 8f1d0e33-83a2-56bd-b49e-cda461372e06

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
