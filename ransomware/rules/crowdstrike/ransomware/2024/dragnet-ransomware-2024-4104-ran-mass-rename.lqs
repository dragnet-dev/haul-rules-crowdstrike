// Dragnet [Ransomware]: dragnet-ransomware-2024-4104 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: cd475c9e-a5b8-57cc-8128-7eae9436d2af

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
