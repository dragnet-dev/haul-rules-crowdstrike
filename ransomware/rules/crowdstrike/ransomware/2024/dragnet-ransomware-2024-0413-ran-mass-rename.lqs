// Dragnet [Ransomware]: dragnet-ransomware-2024-0413 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 4e66d7df-47ad-5868-afa0-363c290ef358

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
