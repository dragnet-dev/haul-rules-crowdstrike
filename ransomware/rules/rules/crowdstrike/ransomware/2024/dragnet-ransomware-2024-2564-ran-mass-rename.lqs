// Dragnet [Ransomware]: dragnet-ransomware-2024-2564 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 0be6ab38-5833-579c-937f-f5786ccc7d5b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
