// Dragnet [Ransomware]: dragnet-ransomware-2023-1528 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: c8170515-1fb6-5656-85ce-3a2decc9bffe

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
