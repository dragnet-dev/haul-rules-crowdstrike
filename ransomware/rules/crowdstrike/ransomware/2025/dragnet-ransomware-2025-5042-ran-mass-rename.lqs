// Dragnet [Ransomware]: dragnet-ransomware-2025-5042 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 4907a52a-c4e6-5432-9540-0798ae28e98d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
