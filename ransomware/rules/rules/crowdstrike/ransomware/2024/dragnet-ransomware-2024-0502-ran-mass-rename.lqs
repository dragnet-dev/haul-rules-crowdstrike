// Dragnet [Ransomware]: dragnet-ransomware-2024-0502 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 2f7fd6e4-426b-5565-b927-3499ee81eac1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
