// Dragnet [Ransomware]: dragnet-ransomware-2023-2112 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 0686af19-9668-5f9e-8de4-b0231d7f035e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
