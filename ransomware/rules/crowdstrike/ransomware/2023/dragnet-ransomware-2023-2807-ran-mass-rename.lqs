// Dragnet [Ransomware]: dragnet-ransomware-2023-2807 — Mass File Rename (malas)
// Status: experimental | Level: high | ID: 163b852a-3071-513b-b3eb-a90507ed06e5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
