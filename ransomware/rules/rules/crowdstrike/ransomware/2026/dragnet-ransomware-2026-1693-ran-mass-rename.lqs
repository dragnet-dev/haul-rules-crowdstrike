// Dragnet [Ransomware]: dragnet-ransomware-2026-1693 — Mass File Rename (safepay)
// Status: stable | Level: high | ID: b42d8fc4-1017-5d16-819d-da148e6b28cd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
