// Dragnet [Ransomware]: dragnet-ransomware-2024-5236 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 2c5e6138-a8c2-59a2-a1d9-9b421b5a66a4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
