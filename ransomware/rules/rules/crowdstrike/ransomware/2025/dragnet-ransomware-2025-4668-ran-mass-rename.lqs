// Dragnet [Ransomware]: dragnet-ransomware-2025-4668 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: b43960af-1497-5361-9548-86673e398f7c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
