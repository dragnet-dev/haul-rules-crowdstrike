// Dragnet [Ransomware]: dragnet-ransomware-2024-5525 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: ad76a8ca-ce43-5f88-ad7b-5fc80d6b003f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
