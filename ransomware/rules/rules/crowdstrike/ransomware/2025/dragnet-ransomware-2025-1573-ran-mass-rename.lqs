// Dragnet [Ransomware]: dragnet-ransomware-2025-1573 — Mass File Rename (VanHelsing)
// Status: experimental | Level: high | ID: c4843870-2205-575d-b7ff-feb7bc9c3577

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
