// Dragnet [Container]: dragnet-container-2026-1143 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 0ee0abc0-77e7-535a-9627-7fe98bfc8a4b

#event_simpleName=*
| (ImageFileName = *almalinux:8* OR ImageFileName = *chainguard:* OR ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:8* OR ImageFileName = *debian:9* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:16.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
