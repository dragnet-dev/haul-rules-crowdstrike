// Dragnet [Ransomware]: dragnet-ransomware-2026-3449 — Mass File Rename (payload)
// Status: stable | Level: high | ID: 61fa5d94-8646-5933-8c85-d786cab615af

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
