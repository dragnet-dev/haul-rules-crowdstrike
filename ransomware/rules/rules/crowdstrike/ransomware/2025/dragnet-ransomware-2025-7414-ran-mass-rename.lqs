// Dragnet [Ransomware]: dragnet-ransomware-2025-7414 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 773a2d85-bc38-5aa0-84db-976b026b96f2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
