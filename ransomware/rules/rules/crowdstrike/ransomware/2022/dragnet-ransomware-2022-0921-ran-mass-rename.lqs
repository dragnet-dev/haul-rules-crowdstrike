// Dragnet [Ransomware]: dragnet-ransomware-2022-0921 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 95d358ba-e120-5086-b463-5b8c4bcec232

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
