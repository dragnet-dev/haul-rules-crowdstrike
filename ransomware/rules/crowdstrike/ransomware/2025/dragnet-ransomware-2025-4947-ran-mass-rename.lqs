// Dragnet [Ransomware]: dragnet-ransomware-2025-4947 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 4589f254-a013-5718-ba4c-fe027bcfd6f2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
