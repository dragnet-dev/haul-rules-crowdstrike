// Dragnet [Ransomware]: dragnet-ransomware-2022-1247 — Mass File Rename (royal)
// Status: deprecated | Level: high | ID: 9b450db6-ca5e-5e04-a0de-e7eda31402b4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
