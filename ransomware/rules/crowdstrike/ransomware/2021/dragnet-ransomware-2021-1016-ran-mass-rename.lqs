// Dragnet [Ransomware]: dragnet-ransomware-2021-1016 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 89141c76-d7d2-5029-ac72-93672f6cedd4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
