// Dragnet [Ransomware]: dragnet-ransomware-2023-1146 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 875a2c11-8b2e-5bd5-9a68-915098c6d7a0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
