// Dragnet [Ransomware]: dragnet-ransomware-2024-1809 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: ccfd688c-c3d6-5812-9975-743d601b6471

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
