// Dragnet [Ransomware]: dragnet-ransomware-2021-0467 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 83fb679a-0747-518f-8519-4659f3954086

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
