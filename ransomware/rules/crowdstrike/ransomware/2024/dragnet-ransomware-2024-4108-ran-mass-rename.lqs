// Dragnet [Ransomware]: dragnet-ransomware-2024-4108 — Mass File Rename (interlock)
// Status: experimental | Level: high | ID: 50037b66-169a-5252-80e2-6585cc146320

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
