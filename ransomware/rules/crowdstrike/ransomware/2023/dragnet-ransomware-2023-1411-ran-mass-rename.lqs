// Dragnet [Ransomware]: dragnet-ransomware-2023-1411 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 35c3ae54-6c06-575a-a397-94557e88aa46

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
