// Dragnet [Ransomware]: dragnet-ransomware-2023-2314 — Mass File Rename (stormous)
// Status: experimental | Level: high | ID: a090c78d-a994-5575-ab53-54a2fd988188

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
