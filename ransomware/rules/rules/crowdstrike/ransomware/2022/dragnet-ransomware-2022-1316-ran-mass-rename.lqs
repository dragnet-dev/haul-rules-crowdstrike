// Dragnet [Ransomware]: dragnet-ransomware-2022-1316 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: bb2bd25c-9d32-546e-a8cf-15e847edc149

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
