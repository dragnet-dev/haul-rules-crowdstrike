// Dragnet [Ransomware]: dragnet-ransomware-2022-2065 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 26c60b1a-2bc8-5963-bca3-91fb8a287618

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
