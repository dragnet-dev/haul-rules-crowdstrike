// Dragnet [Ransomware]: dragnet-ransomware-2023-3297 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: 38704200-3c5a-5b8b-99a0-a71d335b1d2e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
