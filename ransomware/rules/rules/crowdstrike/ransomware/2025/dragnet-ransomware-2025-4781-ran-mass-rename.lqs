// Dragnet [Ransomware]: dragnet-ransomware-2025-4781 — Mass File Rename (arcusmedia)
// Status: experimental | Level: high | ID: e8656fa8-aa52-5e16-9991-2afa42c554e7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
