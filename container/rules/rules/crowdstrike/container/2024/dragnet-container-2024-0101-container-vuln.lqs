// Dragnet [Container]: dragnet-container-2024-0101 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 441d1502-b5b9-5849-b7b6-6a671846144e

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:9* OR ImageFileName = *photon os:3.0* OR ImageFileName = *ubuntu:16.04* OR ImageFileName = *ubuntu:18.04* OR ImageFileName = *ubuntu:19.04* OR ImageFileName = *ubuntu:19.10*)
| table([timestamp, ComputerName])
| limit(1000)
