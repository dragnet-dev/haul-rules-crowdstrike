// Dragnet [Ransomware]: dragnet-ransomware-2025-4744 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: c23cb67b-a36b-55c1-9562-563774c3c407

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
