// Dragnet [Ransomware]: dragnet-ransomware-2024-2555 — Mass File Rename (apt73)
// Status: experimental | Level: high | ID: 0ae09d6a-b946-5b37-b75e-8e3584e72f44

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
