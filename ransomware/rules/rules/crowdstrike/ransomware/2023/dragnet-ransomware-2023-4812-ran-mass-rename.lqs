// Dragnet [Ransomware]: dragnet-ransomware-2023-4812 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 43e89ff0-59d4-5237-b9fb-0f8d3c9f5c06

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
