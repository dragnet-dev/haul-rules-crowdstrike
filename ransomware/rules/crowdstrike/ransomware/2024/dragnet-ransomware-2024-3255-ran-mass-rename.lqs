// Dragnet [Ransomware]: dragnet-ransomware-2024-3255 — Mass File Rename (dragonransomware)
// Status: experimental | Level: high | ID: ad3f2e7f-3580-53da-baef-7ff094c43ce7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
