// Dragnet [Ransomware]: dragnet-ransomware-2024-3207 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 3886b69d-18ac-54ad-98cf-e6d69400433c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
