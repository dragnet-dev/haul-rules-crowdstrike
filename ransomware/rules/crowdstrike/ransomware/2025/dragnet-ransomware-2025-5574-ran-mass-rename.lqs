// Dragnet [Ransomware]: dragnet-ransomware-2025-5574 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: ffef8346-c9a1-5727-a86a-5d080848e697

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
