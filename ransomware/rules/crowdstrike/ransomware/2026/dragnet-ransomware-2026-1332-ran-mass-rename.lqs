// Dragnet [Ransomware]: dragnet-ransomware-2026-1332 — Mass File Rename (incransom)
// Status: stable | Level: high | ID: 3edfd865-90b2-5a57-bde9-3050be6864d2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
