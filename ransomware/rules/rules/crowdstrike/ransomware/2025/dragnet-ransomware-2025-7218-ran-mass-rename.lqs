// Dragnet [Ransomware]: dragnet-ransomware-2025-7218 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: b4e768f2-ee11-5ce4-96f8-6548c7952bdf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
