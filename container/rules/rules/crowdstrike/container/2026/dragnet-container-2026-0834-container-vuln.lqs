// Dragnet [Container]: dragnet-container-2026-0834 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: cd7c908e-5d67-590a-817e-0afe48e121ab

#event_simpleName=*
| (ImageFileName = *amazonlinux:1* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *oraclelinux:7*)
| table([timestamp, ComputerName])
| limit(1000)
