// Dragnet [Ransomware]: dragnet-ransomware-2025-3486 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: d4483393-d82e-5d3b-be4c-a891cec543a9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
