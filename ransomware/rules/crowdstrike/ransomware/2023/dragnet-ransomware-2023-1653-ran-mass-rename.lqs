// Dragnet [Ransomware]: dragnet-ransomware-2023-1653 — Mass File Rename (play)
// Status: experimental | Level: high | ID: cc3d5d50-8d28-53d0-9467-560bbcd1f6ab

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
