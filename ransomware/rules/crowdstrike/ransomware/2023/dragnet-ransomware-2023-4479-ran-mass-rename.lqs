// Dragnet [Ransomware]: dragnet-ransomware-2023-4479 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 71071b88-b597-55b2-8082-908d189d49b8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
