// Dragnet [Ransomware]: dragnet-ransomware-2024-1262 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: b4a958f1-f178-5fd5-854c-583c5af022c5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
