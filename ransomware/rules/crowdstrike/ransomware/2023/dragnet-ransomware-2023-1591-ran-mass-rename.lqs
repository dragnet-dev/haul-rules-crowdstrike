// Dragnet [Ransomware]: dragnet-ransomware-2023-1591 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 95ea6c94-0d79-5cdb-be7c-7dbf732ea499

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
