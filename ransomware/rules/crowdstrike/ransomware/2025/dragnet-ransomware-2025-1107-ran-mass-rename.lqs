// Dragnet [Ransomware]: dragnet-ransomware-2025-1107 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: ba7da7e2-052d-55aa-b50d-4646e2091a28

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
