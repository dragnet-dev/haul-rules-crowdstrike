// Dragnet [Ransomware]: dragnet-ransomware-2022-2233 — Mass File Rename (medusalocker)
// Status: deprecated | Level: high | ID: b7730f2d-2164-5c7a-815c-616c528d7cd0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
