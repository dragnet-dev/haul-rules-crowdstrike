// Dragnet [Ransomware]: dragnet-ransomware-2025-7328 — Mass File Rename (skira)
// Status: experimental | Level: high | ID: 8090578c-54b3-5ff8-a380-e30183be84a1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
