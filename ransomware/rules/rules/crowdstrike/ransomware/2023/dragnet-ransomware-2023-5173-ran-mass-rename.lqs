// Dragnet [Ransomware]: dragnet-ransomware-2023-5173 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 11250818-c59b-5dd4-bc7b-3ad7611fb6bf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
