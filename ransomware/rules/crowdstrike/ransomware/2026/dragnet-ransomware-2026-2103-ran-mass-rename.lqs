// Dragnet [Ransomware]: dragnet-ransomware-2026-2103 — Mass File Rename (shinyhunters)
// Status: deprecated | Level: high | ID: 8b0a7259-d875-5251-9657-2ee8d33b432c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
