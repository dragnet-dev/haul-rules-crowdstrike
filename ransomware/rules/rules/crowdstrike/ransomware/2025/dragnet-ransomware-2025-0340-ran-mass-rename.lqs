// Dragnet [Ransomware]: dragnet-ransomware-2025-0340 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 572d10ad-5a8a-5308-ab40-44b8bcc103e4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
