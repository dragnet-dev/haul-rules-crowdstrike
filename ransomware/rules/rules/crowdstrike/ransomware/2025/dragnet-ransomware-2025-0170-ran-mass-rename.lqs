// Dragnet [Ransomware]: dragnet-ransomware-2025-0170 — Mass File Rename (nova)
// Status: experimental | Level: high | ID: 97dab59c-971f-512b-a7f1-b7032acdf6b1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
