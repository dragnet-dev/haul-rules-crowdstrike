// Dragnet [Ransomware]: dragnet-ransomware-2026-1066 — Mass File Rename (thegentlemen)
// Status: stable | Level: high | ID: cc421b26-2c0c-5b17-8f73-ccb7fa1f2a8a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
