// Dragnet [Container]: dragnet-container-2026-0639 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 3e53fcee-607c-5994-af99-86788c567263

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
