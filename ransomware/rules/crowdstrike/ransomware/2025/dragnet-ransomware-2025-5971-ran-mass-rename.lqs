// Dragnet [Ransomware]: dragnet-ransomware-2025-5971 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: 0e909616-47ed-5d9a-a16e-6600eea3d9b6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
