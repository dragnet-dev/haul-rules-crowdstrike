// Dragnet [Ransomware]: dragnet-ransomware-2024-0437 — Mass File Rename (meow)
// Status: experimental | Level: high | ID: 731ba154-5062-5dd7-a105-0cdf0b0e740c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
