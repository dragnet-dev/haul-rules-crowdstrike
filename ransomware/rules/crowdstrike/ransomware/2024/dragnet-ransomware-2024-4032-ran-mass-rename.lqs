// Dragnet [Ransomware]: dragnet-ransomware-2024-4032 — Mass File Rename (play)
// Status: experimental | Level: high | ID: c402ce1e-4294-5e17-a4a3-13c14cef0c24

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
