// Dragnet [Ransomware]: dragnet-ransomware-2024-2583 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: e721fd7e-702b-5228-9810-dd55c55bcfb7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
