// Dragnet [Ransomware]: dragnet-ransomware-2024-1882 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 50fea117-6c42-50fb-b996-0dfd11eddf8e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
