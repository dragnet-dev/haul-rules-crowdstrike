// Dragnet [Ransomware]: dragnet-ransomware-2023-3706 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: dfa2eae1-c675-5315-b557-57600f6ecc01

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
