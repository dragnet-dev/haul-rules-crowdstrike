// Dragnet [Ransomware]: dragnet-ransomware-2026-1554 — Mass File Rename (genesis)
// Status: stable | Level: high | ID: 882bd649-81ca-587a-b205-fed5ce59e383

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
