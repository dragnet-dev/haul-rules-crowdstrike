// Dragnet [Ransomware]: dragnet-ransomware-2022-0959 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 95c1913d-c719-52b3-8b9f-063cd226126a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
