// Dragnet [Ransomware]: dragnet-ransomware-2025-3059 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 69b5c683-a1ad-5d3e-a0b5-77a865f3eccc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
