// Dragnet [Ransomware]: dragnet-ransomware-2024-1702 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 99c4818d-72dc-5697-a33e-52824dfaf4f8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
