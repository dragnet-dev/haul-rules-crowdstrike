// Dragnet [Ransomware]: dragnet-ransomware-2024-5298 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 4ca869f5-b132-5648-a7c2-775493ae2e95

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
