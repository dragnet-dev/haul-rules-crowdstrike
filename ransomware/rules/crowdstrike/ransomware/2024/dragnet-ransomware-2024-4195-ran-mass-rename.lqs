// Dragnet [Ransomware]: dragnet-ransomware-2024-4195 — Mass File Rename (blacklock)
// Status: experimental | Level: high | ID: c5929429-06bc-50e3-a4bf-b191e04392c1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
