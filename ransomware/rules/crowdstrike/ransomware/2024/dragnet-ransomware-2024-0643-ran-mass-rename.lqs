// Dragnet [Ransomware]: dragnet-ransomware-2024-0643 — Mass File Rename (handala)
// Status: experimental | Level: high | ID: 5bdb7272-a21b-5fba-a723-0e4b7f773faf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
