// Dragnet [Ransomware]: dragnet-ransomware-2024-4563 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: ebdc8e04-55c3-50ec-9634-e1cf42e1021c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
