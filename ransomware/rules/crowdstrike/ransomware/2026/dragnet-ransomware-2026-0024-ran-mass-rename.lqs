// Dragnet [Ransomware]: dragnet-ransomware-2026-0024 — Mass File Rename (incransom)
// Status: stable | Level: high | ID: 43356159-ea2f-553e-8eef-6bc0a583eadd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
