// Dragnet [Ransomware]: dragnet-ransomware-2025-1442 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 42f6c836-2712-5573-972f-a2d598f89aed

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
