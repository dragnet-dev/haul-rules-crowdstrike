// Dragnet [Ransomware]: dragnet-ransomware-2024-3516 — Mass File Rename (flocker)
// Status: experimental | Level: high | ID: 2f046258-9117-54ba-84f8-34355a145cff

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
