// Dragnet [Ransomware]: dragnet-ransomware-2025-4634 — Mass File Rename (interlock)
// Status: experimental | Level: high | ID: b992a736-5fbe-536c-a917-8528dca513ff

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
