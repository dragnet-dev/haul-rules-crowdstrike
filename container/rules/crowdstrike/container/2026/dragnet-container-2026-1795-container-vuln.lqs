// Dragnet [Container]: dragnet-container-2026-1795 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 5318cdfb-7600-5f7d-af04-97e3218eff20

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
