// Dragnet [Ransomware]: dragnet-ransomware-2026-1200 — Mass File Rename (incransom)
// Status: stable | Level: high | ID: 190483df-ff81-5046-b9fc-f250d17b0354

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
