// Dragnet [Ransomware]: dragnet-ransomware-2023-2958 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 9860a902-d821-542b-8987-db33c3d02a0e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
