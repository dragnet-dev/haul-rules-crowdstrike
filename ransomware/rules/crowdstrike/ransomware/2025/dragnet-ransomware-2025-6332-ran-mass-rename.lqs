// Dragnet [Ransomware]: dragnet-ransomware-2025-6332 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: 3e6b5ed2-3ec4-5334-9bc3-f29d461d75f7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
