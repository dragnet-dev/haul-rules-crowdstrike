// Dragnet [Ransomware]: dragnet-ransomware-2023-2022 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 35a38491-1777-5e76-9d11-f5494449d4c3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
