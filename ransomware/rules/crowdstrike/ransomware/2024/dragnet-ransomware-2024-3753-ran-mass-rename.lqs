// Dragnet [Ransomware]: dragnet-ransomware-2024-3753 — Mass File Rename (handala)
// Status: experimental | Level: high | ID: 6e3ddae1-0ae2-505c-94b6-1554a208b3a0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
