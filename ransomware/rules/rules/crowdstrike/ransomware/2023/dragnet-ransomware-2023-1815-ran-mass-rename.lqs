// Dragnet [Ransomware]: dragnet-ransomware-2023-1815 — Mass File Rename (snatch)
// Status: experimental | Level: high | ID: d6e52e77-1e9a-58c4-85a5-64ccac2878d3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
