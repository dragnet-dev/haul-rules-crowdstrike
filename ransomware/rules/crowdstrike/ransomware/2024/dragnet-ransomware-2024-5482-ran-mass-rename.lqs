// Dragnet [Ransomware]: dragnet-ransomware-2024-5482 — Mass File Rename (abyss)
// Status: deprecated | Level: high | ID: c72956de-4880-5800-bcd0-69c78ad58326

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
