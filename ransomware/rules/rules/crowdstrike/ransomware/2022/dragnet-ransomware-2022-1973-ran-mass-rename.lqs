// Dragnet [Ransomware]: dragnet-ransomware-2022-1973 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 097bd89d-de1d-5c19-868d-e57089193231

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
