// Dragnet [Ransomware]: dragnet-ransomware-2025-4609 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 9f7f78f4-a3c7-52df-b0a0-d0cd54bcf9ec

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
