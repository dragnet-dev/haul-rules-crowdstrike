// Dragnet [Ransomware]: dragnet-ransomware-2024-0708 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 48483411-6f46-5cc5-8143-84f940f567db

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
