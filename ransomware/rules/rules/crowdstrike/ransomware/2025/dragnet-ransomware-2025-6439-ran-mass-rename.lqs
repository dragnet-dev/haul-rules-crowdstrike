// Dragnet [Ransomware]: dragnet-ransomware-2025-6439 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 4209cc4c-12dd-5ca2-bac2-456198381a65

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
