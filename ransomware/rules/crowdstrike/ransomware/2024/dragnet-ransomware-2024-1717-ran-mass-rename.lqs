// Dragnet [Ransomware]: dragnet-ransomware-2024-1717 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 63528697-e6c8-584e-aa4a-5f50bcf97adf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
