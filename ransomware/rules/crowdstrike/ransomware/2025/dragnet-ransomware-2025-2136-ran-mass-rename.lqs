// Dragnet [Ransomware]: dragnet-ransomware-2025-2136 — Mass File Rename (sinobi)
// Status: experimental | Level: high | ID: 97a1d3a2-a037-5d66-b18f-ec1cc57358a6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
