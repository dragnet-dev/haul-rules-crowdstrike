// Dragnet [Ransomware]: dragnet-ransomware-2022-1954 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 29692536-f656-56fd-ba6b-4e4fa0eb03e4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
