// Dragnet [Ransomware]: dragnet-ransomware-2025-0633 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 56185d7b-1759-5923-8f7a-3a68cb2d8fce

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
