// Dragnet [Ransomware]: dragnet-ransomware-2025-1327 — Mass File Rename (coinbasecartel)
// Status: experimental | Level: high | ID: ebb54d78-288c-54ac-9784-5198a96b3f1e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
