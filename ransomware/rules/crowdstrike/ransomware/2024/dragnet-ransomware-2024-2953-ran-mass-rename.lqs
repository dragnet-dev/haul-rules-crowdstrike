// Dragnet [Ransomware]: dragnet-ransomware-2024-2953 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 2df7195a-09f2-5302-8486-d33327db5291

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
