// Dragnet [Ransomware]: dragnet-ransomware-2025-2396 — Mass File Rename (thegentlemen)
// Status: experimental | Level: high | ID: 14b03259-1dcf-5cb3-b3a9-87dd0ff02ccf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
