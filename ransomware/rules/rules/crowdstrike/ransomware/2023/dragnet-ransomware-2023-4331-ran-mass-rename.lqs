// Dragnet [Ransomware]: dragnet-ransomware-2023-4331 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: c5b1c822-306a-5d16-82a1-47e8aff2d833

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
