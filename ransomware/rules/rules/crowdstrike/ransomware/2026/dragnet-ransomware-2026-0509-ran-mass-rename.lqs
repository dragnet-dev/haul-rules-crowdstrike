// Dragnet [Ransomware]: dragnet-ransomware-2026-0509 — Mass File Rename (fulcrumsec)
// Status: stable | Level: high | ID: 67f0c10e-9814-50e2-b67b-29b2df40f8fd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
