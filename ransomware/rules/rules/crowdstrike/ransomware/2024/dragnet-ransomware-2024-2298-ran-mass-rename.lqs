// Dragnet [Ransomware]: dragnet-ransomware-2024-2298 — Mass File Rename (spacebears)
// Status: experimental | Level: high | ID: 191b9662-85e4-56bb-af78-aaf870360d2f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
