// Dragnet [Ransomware]: dragnet-ransomware-2022-1508 — Mass File Rename (medusalocker)
// Status: deprecated | Level: high | ID: cbd1eb92-2afd-50a2-a328-1505eb0e66be

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
