// Dragnet [Ransomware]: dragnet-ransomware-2026-2739 — Mass File Rename (handala)
// Status: stable | Level: high | ID: e1243ef3-fbc8-5b3c-a559-a785b89a1e88

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
