// Dragnet [Ransomware]: dragnet-ransomware-2026-2922 — Mass File Rename (SilentRansomGroup)
// Status: deprecated | Level: high | ID: 76962573-ca2f-5cfa-8811-1886af1ec956

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
