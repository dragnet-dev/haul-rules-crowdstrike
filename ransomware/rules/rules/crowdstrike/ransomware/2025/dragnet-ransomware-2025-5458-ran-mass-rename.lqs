// Dragnet [Ransomware]: dragnet-ransomware-2025-5458 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: 327154fa-92f5-59db-bfc2-2fae68bd6871

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
