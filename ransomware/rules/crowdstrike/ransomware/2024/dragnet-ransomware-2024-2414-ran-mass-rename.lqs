// Dragnet [Ransomware]: dragnet-ransomware-2024-2414 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 9821fe0c-7470-5acd-9070-b67529650429

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
