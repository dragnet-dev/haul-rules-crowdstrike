// Dragnet [Ransomware]: dragnet-ransomware-2023-3729 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 66428b92-2e1f-502b-bb65-d7bab64a943a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
