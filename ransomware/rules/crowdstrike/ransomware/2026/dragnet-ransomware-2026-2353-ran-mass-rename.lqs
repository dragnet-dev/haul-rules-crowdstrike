// Dragnet [Ransomware]: dragnet-ransomware-2026-2353 — Mass File Rename (ransomexx)
// Status: stable | Level: high | ID: 94d3bf43-5be0-5002-984a-8b45e28a2f11

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
