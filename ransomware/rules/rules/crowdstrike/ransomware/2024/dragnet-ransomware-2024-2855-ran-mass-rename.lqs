// Dragnet [Ransomware]: dragnet-ransomware-2024-2855 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 4621a502-3401-5fcf-b196-662e3ef22867

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
