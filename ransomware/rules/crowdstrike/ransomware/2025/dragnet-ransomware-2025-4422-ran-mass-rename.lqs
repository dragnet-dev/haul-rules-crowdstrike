// Dragnet [Ransomware]: dragnet-ransomware-2025-4422 — Mass File Rename (handala)
// Status: experimental | Level: high | ID: dad8a09d-ed0d-5d33-ab59-e9f0184987a3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
