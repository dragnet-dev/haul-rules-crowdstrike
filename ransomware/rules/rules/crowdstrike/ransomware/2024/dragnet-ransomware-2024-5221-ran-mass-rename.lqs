// Dragnet [Ransomware]: dragnet-ransomware-2024-5221 — Mass File Rename (rhysida)
// Status: experimental | Level: high | ID: 281d4836-52ba-5885-9dce-6ee605e1b36e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
