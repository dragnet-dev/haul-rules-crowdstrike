// Dragnet [Ransomware]: dragnet-ransomware-2025-0875 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: a7a01616-333f-5743-9d09-13a6061b1860

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
