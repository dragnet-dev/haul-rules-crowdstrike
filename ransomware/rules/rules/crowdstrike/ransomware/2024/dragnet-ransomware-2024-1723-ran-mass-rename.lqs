// Dragnet [Ransomware]: dragnet-ransomware-2024-1723 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 2a7ea901-ba99-51a8-9f06-177183154997

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
