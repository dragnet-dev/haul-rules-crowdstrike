// Dragnet [Ransomware]: dragnet-ransomware-2023-1806 — Mass File Rename (noescape)
// Status: experimental | Level: high | ID: c620a942-8309-55df-9ba6-54c115002f5b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
