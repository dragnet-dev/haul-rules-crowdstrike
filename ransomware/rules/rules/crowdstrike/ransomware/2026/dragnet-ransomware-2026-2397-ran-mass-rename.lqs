// Dragnet [Ransomware]: dragnet-ransomware-2026-2397 — Mass File Rename (interlock)
// Status: stable | Level: high | ID: 5e3cf91e-797b-5e0d-9f74-12bb70cfa079

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
