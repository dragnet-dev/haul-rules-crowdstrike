// Dragnet [Ransomware]: dragnet-ransomware-2024-3914 — Mass File Rename (threeam)
// Status: experimental | Level: high | ID: b504236d-6d8b-56ba-afe2-207102913c99

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
