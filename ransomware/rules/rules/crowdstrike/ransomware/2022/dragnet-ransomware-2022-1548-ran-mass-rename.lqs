// Dragnet [Ransomware]: dragnet-ransomware-2022-1548 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 64d5e6fa-8b91-5daa-b145-461c68f36e49

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
