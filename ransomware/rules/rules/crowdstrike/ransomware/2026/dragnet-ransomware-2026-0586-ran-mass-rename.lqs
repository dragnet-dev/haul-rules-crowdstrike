// Dragnet [Ransomware]: dragnet-ransomware-2026-0586 — Mass File Rename (ransomhouse)
// Status: test | Level: high | ID: 7def73c3-783c-590d-a1c6-9c9cc3944b73

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
