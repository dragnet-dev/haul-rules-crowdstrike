// Dragnet [Ransomware]: dragnet-ransomware-2025-3530 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 19fcf1bd-7949-5617-8bee-29bbf0a60eb7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
