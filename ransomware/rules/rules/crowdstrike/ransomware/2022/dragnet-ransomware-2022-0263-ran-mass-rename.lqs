// Dragnet [Ransomware]: dragnet-ransomware-2022-0263 — Mass File Rename (avoslocker)
// Status: deprecated | Level: high | ID: b4df61af-8b17-56d9-b964-937dfa1f7578

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
