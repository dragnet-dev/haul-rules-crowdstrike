// Dragnet [Ransomware]: dragnet-ransomware-2024-5267 — Mass File Rename (play)
// Status: experimental | Level: high | ID: e9b4ea73-97e9-5bf5-8412-1381d0e87a23

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
