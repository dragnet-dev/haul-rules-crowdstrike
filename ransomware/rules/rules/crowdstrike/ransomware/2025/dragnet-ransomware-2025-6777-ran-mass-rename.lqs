// Dragnet [Ransomware]: dragnet-ransomware-2025-6777 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: c28ebfdb-a14d-5097-9454-645bc59d61db

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
