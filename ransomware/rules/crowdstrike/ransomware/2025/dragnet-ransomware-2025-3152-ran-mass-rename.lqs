// Dragnet [Ransomware]: dragnet-ransomware-2025-3152 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 111cb01f-0487-5c34-a6cd-972c9dde2a51

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
