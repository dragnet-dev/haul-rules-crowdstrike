// Dragnet [Ransomware]: dragnet-ransomware-2025-7919 — Mass File Rename (J)
// Status: experimental | Level: high | ID: 77ae6024-a006-570b-be82-59b3fa4e0c81

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
