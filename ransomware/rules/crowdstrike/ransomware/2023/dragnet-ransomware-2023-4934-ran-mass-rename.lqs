// Dragnet [Ransomware]: dragnet-ransomware-2023-4934 — Mass File Rename (toufan)
// Status: deprecated | Level: high | ID: c188e99d-9755-5b5c-8d86-1e49a6a3d9f5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
