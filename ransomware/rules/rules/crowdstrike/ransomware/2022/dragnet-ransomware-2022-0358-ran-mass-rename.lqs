// Dragnet [Ransomware]: dragnet-ransomware-2022-0358 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 90b72bb3-ec51-5fb4-994e-f32e66ff318e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
