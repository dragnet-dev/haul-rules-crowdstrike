// Dragnet [Ransomware]: dragnet-ransomware-2024-2425 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 83d82292-b2ac-5c4d-a16e-732bd4782003

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
