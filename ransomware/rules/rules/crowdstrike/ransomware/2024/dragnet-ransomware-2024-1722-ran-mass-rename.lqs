// Dragnet [Ransomware]: dragnet-ransomware-2024-1722 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 290ce861-1f32-5add-aa05-746d7c0e7118

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
