// Dragnet [Ransomware]: dragnet-ransomware-2025-2442 — Mass File Rename (thegentlemen)
// Status: test | Level: high | ID: dd1d7403-6a0f-5a90-8f86-6ebddc996b31

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
