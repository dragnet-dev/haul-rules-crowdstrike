// Dragnet [Ransomware]: dragnet-ransomware-2024-4441 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: f4558d1e-663f-5f35-9d3a-fafbec149214

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
