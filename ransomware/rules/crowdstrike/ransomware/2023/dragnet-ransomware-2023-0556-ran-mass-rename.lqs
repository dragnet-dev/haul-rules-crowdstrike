// Dragnet [Ransomware]: dragnet-ransomware-2023-0556 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: d1a9bd1b-98aa-555d-bdbc-ef27464ac20d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
