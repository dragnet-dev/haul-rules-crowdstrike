// Dragnet [Ransomware]: dragnet-ransomware-2023-3107 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: a68fff11-2875-53c6-be95-0f2ffdfcda8c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
