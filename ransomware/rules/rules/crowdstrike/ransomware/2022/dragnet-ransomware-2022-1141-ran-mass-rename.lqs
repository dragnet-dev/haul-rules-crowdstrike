// Dragnet [Ransomware]: dragnet-ransomware-2022-1141 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 48ee9a1d-43bc-51f2-a7ea-b283776e2956

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
