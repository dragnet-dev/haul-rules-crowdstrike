// Dragnet [Ransomware]: dragnet-ransomware-2025-7877 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: e7553730-b47d-5ba6-9015-9f5a9a00032f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
