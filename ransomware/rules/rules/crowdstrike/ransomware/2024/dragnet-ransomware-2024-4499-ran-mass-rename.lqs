// Dragnet [Ransomware]: dragnet-ransomware-2024-4499 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 33489ee4-53ea-580f-8311-7c2501f3d5ca

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
