// Dragnet [Ransomware]: dragnet-ransomware-2024-4963 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 76ab46ac-d58f-5f14-abb8-16ce9572546b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
