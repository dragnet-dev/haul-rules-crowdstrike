// Dragnet [Ransomware]: dragnet-ransomware-2023-0352 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 189e6007-25a6-5296-9850-9720ed735adf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
