// Dragnet [Ransomware]: dragnet-ransomware-2023-4255 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 35998cbc-814c-548e-9345-504381828c46

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
