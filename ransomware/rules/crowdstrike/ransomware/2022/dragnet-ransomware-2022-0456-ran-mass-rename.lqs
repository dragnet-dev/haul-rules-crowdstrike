// Dragnet [Ransomware]: dragnet-ransomware-2022-0456 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 614cfa19-33c1-5988-832c-6294991d1e10

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
