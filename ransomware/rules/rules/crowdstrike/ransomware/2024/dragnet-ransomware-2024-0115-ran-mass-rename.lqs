// Dragnet [Ransomware]: dragnet-ransomware-2024-0115 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 274ebac7-b601-521a-b9e9-16b80032a1e6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
