// Dragnet [Container]: dragnet-container-2026-3160 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 50ce25c6-8c34-5192-a827-a705cdb39eba

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:5*)
| table([timestamp, ComputerName])
| limit(1000)
