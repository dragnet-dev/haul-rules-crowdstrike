// Dragnet [Ransomware]: dragnet-ransomware-2025-3025 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 717627e0-d341-593c-ac07-4db7f69286be

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
