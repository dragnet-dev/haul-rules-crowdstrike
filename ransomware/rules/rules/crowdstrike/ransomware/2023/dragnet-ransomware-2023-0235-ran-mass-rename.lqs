// Dragnet [Ransomware]: dragnet-ransomware-2023-0235 — Mass File Rename (rhysida)
// Status: deprecated | Level: high | ID: 0b26058b-5ad6-571d-a282-31f01e43d989

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
