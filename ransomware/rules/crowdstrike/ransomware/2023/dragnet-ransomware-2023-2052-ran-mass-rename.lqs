// Dragnet [Ransomware]: dragnet-ransomware-2023-2052 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: d8a9d68e-3a82-59e1-9bbb-c76853ba077d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
