// Dragnet [Ransomware]: dragnet-ransomware-2025-7037 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: d7f762f6-0f41-535e-952b-2651b73ee852

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
