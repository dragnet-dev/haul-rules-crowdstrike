// Dragnet [Ransomware]: dragnet-ransomware-2024-5517 — Mass File Rename (blacklock)
// Status: experimental | Level: high | ID: 669f2037-33d1-5ddb-ac83-3f0ff18f7a65

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
