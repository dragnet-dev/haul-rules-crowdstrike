// Dragnet [Ransomware]: dragnet-ransomware-2025-2816 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 05c46118-afc8-56e4-ba55-a30cfb51ac32

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
