// Dragnet [Ransomware]: dragnet-ransomware-2026-3174 — Mass File Rename (cmdorganization)
// Status: deprecated | Level: high | ID: 257965e8-bcf6-5add-ad6e-e12324821629

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
