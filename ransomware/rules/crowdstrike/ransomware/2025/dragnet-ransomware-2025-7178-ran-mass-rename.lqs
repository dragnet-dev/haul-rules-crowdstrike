// Dragnet [Ransomware]: dragnet-ransomware-2025-7178 — Mass File Rename (play)
// Status: experimental | Level: high | ID: a2924a16-af3c-52f1-ada7-daa79b5b20f0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
