// Dragnet [Ransomware]: dragnet-ransomware-2024-0714 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: 1b3a83f7-7f19-5821-8d00-c6ee4a9d9e15

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
