// Dragnet [Ransomware]: dragnet-ransomware-2025-5089 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 31203278-97ea-5315-a892-eb7168d66d96

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
