// Dragnet [Ransomware]: dragnet-ransomware-2021-1751 — Mass File Rename (lv)
// Status: deprecated | Level: high | ID: cd8f73ce-bdb6-5c2d-9690-433dd5bc4655

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
