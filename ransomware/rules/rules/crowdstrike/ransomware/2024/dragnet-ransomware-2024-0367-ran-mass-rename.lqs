// Dragnet [Ransomware]: dragnet-ransomware-2024-0367 — Mass File Rename (SilentRansomGroup)
// Status: deprecated | Level: high | ID: 9de5ec21-df0d-50b7-8608-9f543fbb1491

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
