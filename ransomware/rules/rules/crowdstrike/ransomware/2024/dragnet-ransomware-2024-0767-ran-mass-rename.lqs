// Dragnet [Ransomware]: dragnet-ransomware-2024-0767 — Mass File Rename (cloak)
// Status: deprecated | Level: high | ID: 99e95854-7b3e-5ae4-b95b-a1dcd652d73b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
