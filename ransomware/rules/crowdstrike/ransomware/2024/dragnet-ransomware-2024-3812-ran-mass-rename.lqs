// Dragnet [Ransomware]: dragnet-ransomware-2024-3812 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 4bbba3ed-4897-57c0-8bd7-5d932adb9c68

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
