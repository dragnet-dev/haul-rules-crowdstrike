// Dragnet [Ransomware]: dragnet-ransomware-2025-2049 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: eb72d786-4ad7-5181-a94d-982e1748d0f8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
