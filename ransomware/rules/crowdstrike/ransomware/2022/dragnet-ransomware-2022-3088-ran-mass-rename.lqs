// Dragnet [Ransomware]: dragnet-ransomware-2022-3088 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 4e46376e-1e4e-5234-acd9-81bb6b558216

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
