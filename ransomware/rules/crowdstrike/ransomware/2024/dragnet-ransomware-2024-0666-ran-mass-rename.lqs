// Dragnet [Ransomware]: dragnet-ransomware-2024-0666 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: 2ab0b958-78ef-5e51-802e-e3b6cb437df6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
