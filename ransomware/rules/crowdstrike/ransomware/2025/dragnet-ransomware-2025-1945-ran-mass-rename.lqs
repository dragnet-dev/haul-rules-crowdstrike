// Dragnet [Ransomware]: dragnet-ransomware-2025-1945 — Mass File Rename (handala)
// Status: experimental | Level: high | ID: ded06b90-79b7-5595-8926-c453dda1a662

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
