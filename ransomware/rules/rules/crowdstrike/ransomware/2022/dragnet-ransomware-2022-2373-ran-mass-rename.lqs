// Dragnet [Ransomware]: dragnet-ransomware-2022-2373 — Mass File Rename (ransomhouse)
// Status: deprecated | Level: high | ID: e22788c2-4ce3-56af-befd-9d47f4101645

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
