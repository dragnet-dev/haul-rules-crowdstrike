// Dragnet [Ransomware]: dragnet-ransomware-2025-0828 — Mass File Rename (nova)
// Status: experimental | Level: high | ID: 2826804d-ec2d-5710-9ba1-e15beb86e0a4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
