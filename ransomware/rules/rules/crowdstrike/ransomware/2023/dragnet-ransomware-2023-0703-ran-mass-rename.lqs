// Dragnet [Ransomware]: dragnet-ransomware-2023-0703 — Mass File Rename (qilin)
// Status: deprecated | Level: high | ID: b7e87e65-8b0f-5114-8e1b-5d91b7cd6ebf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
