// Dragnet [Ransomware]: dragnet-ransomware-2025-2397 — Mass File Rename (thegentlemen)
// Status: experimental | Level: high | ID: 5510f8f9-4240-5a08-b33f-cd49f6fcd7f7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
