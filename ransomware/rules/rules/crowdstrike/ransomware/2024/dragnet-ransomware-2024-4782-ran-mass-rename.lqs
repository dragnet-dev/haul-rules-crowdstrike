// Dragnet [Ransomware]: dragnet-ransomware-2024-4782 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: af5f60c6-4f52-551c-8d07-86b891c5fd15

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
