// Dragnet [Ransomware]: dragnet-ransomware-2025-7405 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: d60637d0-607b-5f48-a141-0219dce67d13

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
