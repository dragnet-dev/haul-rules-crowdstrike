// Dragnet [Container]: dragnet-container-2026-1917 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 16dae525-26a8-5195-878b-526d35fe175b

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:8*)
| table([timestamp, ComputerName])
| limit(1000)
