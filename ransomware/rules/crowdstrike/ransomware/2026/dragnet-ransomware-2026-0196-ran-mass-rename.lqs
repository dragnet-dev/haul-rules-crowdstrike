// Dragnet [Ransomware]: dragnet-ransomware-2026-0196 — Mass File Rename (dragonforce)
// Status: stable | Level: high | ID: a0b67ee9-095d-5b51-804a-27b203676106

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
