// Dragnet [Ransomware]: dragnet-ransomware-2024-5439 — Mass File Rename (monti)
// Status: experimental | Level: high | ID: 9d232f3d-a7aa-557e-8089-43516816c004

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
