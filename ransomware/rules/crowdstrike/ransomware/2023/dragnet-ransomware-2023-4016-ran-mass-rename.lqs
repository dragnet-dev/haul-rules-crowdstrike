// Dragnet [Ransomware]: dragnet-ransomware-2023-4016 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: ece346f0-3f80-5edb-ae39-8cf942304e99

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
