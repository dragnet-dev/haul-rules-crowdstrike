// Dragnet [Ransomware]: dragnet-ransomware-2024-5390 — Mass File Rename (cloak)
// Status: deprecated | Level: high | ID: 3c852445-36c3-5727-8082-2735b9e1731f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
