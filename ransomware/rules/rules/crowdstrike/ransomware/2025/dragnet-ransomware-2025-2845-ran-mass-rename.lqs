// Dragnet [Ransomware]: dragnet-ransomware-2025-2845 — Mass File Rename (sinobi)
// Status: experimental | Level: high | ID: 0b1ee674-aa3e-5404-9e23-9e4c24da5fe3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
