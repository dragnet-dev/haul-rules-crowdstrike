// Dragnet [Container]: dragnet-container-2026-1515 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: e5501ffe-54aa-5dd7-a759-3c81b4ed010d

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:9* OR ImageFileName = *ubuntu:17.04*)
| table([timestamp, ComputerName])
| limit(1000)
