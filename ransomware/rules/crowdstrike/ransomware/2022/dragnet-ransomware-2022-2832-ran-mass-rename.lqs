// Dragnet [Ransomware]: dragnet-ransomware-2022-2832 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 223e890b-5a1b-5224-b351-1473a4042f9d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
