// Dragnet [Container]: dragnet-container-2024-0076 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 8aeb06e1-aab7-5769-b2de-bc2f1173973a

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:8* OR ImageFileName = *debian:9* OR ImageFileName = *ubuntu:16.04* OR ImageFileName = *ubuntu:16.04-ESM* OR ImageFileName = *ubuntu:18.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
