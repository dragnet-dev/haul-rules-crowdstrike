// Dragnet [Ransomware]: dragnet-ransomware-2021-0180 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 669980a8-305c-544e-b00b-bb120ee55c2f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
