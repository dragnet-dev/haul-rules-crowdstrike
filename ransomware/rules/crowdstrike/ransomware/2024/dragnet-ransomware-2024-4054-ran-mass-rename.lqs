// Dragnet [Ransomware]: dragnet-ransomware-2024-4054 — Mass File Rename (BrainCipher)
// Status: experimental | Level: high | ID: ff11ff55-ca8f-5e7a-ad9c-d5bf18eed51d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
