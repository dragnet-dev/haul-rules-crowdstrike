// Dragnet [Ransomware]: dragnet-ransomware-2021-0443 — Mass File Rename (midas)
// Status: deprecated | Level: high | ID: 02898ab5-37c1-50ad-85a4-f86e5434ad63

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
