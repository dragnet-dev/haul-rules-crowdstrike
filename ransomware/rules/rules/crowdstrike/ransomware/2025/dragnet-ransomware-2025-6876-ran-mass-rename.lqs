// Dragnet [Ransomware]: dragnet-ransomware-2025-6876 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: c492a051-d493-580e-b114-af5e7bd07232

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
