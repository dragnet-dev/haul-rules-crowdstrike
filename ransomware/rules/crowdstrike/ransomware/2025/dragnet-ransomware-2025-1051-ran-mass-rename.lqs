// Dragnet [Ransomware]: dragnet-ransomware-2025-1051 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 5f0469a3-8461-565d-91ff-8ab22e287634

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
