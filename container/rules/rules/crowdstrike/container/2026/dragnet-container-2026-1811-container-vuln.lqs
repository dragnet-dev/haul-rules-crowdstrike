// Dragnet [Container]: dragnet-container-2026-1811 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 44ced0fd-6fef-5660-9c1a-2069348be49d

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
