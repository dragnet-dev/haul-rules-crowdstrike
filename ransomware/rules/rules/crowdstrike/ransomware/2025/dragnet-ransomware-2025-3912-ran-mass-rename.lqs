// Dragnet [Ransomware]: dragnet-ransomware-2025-3912 — Mass File Rename (devman)
// Status: experimental | Level: high | ID: 0e481ce4-3af1-5614-96fd-1cf04bb02a92

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
