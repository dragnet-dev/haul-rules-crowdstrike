// Dragnet [Ransomware]: dragnet-ransomware-2024-5799 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 2dc3e09f-8635-5d59-84c5-dd0fce5edfdb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
