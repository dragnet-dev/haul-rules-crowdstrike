// Dragnet [Ransomware]: dragnet-ransomware-2023-1570 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: e2c733ee-96cc-5cd8-a26a-488af92d0f99

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
