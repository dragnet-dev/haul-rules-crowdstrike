// Dragnet [Ransomware]: dragnet-ransomware-2026-3367 — Mass File Rename (incransom)
// Status: test | Level: high | ID: 3a9d6eda-72c8-58e7-b54e-28bc5a2df8a4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
