// Dragnet [Ransomware]: dragnet-ransomware-2024-2242 — Mass File Rename (spacebears)
// Status: experimental | Level: high | ID: 8d4f23d7-f1a7-57b7-95e0-3e6d0a27950f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
