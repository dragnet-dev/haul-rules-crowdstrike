// Dragnet [Ransomware]: dragnet-ransomware-2022-3079 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 88b834f8-048f-5456-8f19-be1df6d25a1c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
