// Dragnet [Ransomware]: dragnet-ransomware-2024-5253 — Mass File Rename (ransomhouse)
// Status: experimental | Level: high | ID: 57eef5a4-3ea4-5114-93be-63b13dda06d2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
