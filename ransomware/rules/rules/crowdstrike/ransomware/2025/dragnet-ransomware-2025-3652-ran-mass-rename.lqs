// Dragnet [Ransomware]: dragnet-ransomware-2025-3652 — Mass File Rename (SilentRansomGroup)
// Status: deprecated | Level: high | ID: 7632f6fc-109f-5316-9ea6-0f5b656fc90b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
