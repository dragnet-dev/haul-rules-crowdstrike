// Dragnet [Ransomware]: dragnet-ransomware-2025-1454 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: c579f54e-c4b2-52c7-9f2e-42c227e33de6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
