// Dragnet [Ransomware]: dragnet-ransomware-2023-5182 — Mass File Rename (play)
// Status: experimental | Level: high | ID: cecfbf7f-03d8-5dca-82ed-1f225281bfe3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
