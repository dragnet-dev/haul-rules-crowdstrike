// Dragnet [Ransomware]: dragnet-ransomware-2021-1120 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 785e56eb-f3dd-5493-b1ef-43f46a168993

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
