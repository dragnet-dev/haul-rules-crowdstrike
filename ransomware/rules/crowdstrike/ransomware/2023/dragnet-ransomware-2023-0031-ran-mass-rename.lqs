// Dragnet [Ransomware]: dragnet-ransomware-2023-0031 — Mass File Rename (werewolves)
// Status: experimental | Level: high | ID: 3223e849-a924-50b3-aacb-bef7d19022c9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
