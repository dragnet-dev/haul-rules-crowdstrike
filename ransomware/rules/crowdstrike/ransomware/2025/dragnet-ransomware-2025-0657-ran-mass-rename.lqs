// Dragnet [Ransomware]: dragnet-ransomware-2025-0657 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 80e90fc3-9557-589d-9ffe-6ef8b11e15ea

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
