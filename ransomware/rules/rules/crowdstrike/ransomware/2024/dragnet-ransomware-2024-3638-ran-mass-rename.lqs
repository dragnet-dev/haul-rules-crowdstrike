// Dragnet [Ransomware]: dragnet-ransomware-2024-3638 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 90ed92a4-e99f-5aa7-a196-cb24d8477f86

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
