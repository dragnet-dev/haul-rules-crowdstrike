// Dragnet [Ransomware]: dragnet-ransomware-2024-5388 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 641139a2-2446-5f1f-a357-e448a10f20da

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
