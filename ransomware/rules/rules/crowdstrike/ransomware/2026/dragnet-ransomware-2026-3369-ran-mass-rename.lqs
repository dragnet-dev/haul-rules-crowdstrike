// Dragnet [Ransomware]: dragnet-ransomware-2026-3369 — Mass File Rename (aurora)
// Status: stable | Level: high | ID: 2d375d55-e097-5da4-92fa-32a45ee88fb5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
