// Dragnet [Ransomware]: dragnet-ransomware-2023-2310 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: ea664fca-8cb6-539d-80ce-8c039ae36b9b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
