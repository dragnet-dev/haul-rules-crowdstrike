// Dragnet [Ransomware]: dragnet-ransomware-2024-0517 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 0c96ea1b-eb1e-570c-b7b5-f5bde3ddffde

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
