// Dragnet [Ransomware]: dragnet-ransomware-2022-0517 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: d1792e65-112d-5aeb-a299-2c4a2dd9dab2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
