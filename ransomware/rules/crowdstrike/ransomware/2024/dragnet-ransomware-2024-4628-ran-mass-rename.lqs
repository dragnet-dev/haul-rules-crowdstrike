// Dragnet [Ransomware]: dragnet-ransomware-2024-4628 — Mass File Rename (helldown)
// Status: experimental | Level: high | ID: a703be60-bc8e-512c-a148-f0756cc11f59

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
