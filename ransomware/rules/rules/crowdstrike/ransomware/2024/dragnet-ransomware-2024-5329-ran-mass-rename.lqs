// Dragnet [Ransomware]: dragnet-ransomware-2024-5329 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 37f6b15e-f25e-5406-ad07-ac2f43977c42

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
