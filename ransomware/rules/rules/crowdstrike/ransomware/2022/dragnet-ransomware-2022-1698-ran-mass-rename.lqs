// Dragnet [Ransomware]: dragnet-ransomware-2022-1698 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 6492381e-4c20-5bf0-854f-d6d559cd4c77

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
