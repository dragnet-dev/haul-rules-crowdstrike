// Dragnet [Ransomware]: dragnet-ransomware-2022-0200 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: ce7427ef-7bb4-5e16-89c4-09ab5bb614f3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
