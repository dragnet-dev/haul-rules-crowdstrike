// Dragnet [Ransomware]: dragnet-ransomware-2021-0847 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 8b71638d-2563-50b0-afe1-9b33ffeecc9f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
