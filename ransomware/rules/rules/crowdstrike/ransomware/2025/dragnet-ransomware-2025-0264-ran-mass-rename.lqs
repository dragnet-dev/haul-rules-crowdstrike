// Dragnet [Ransomware]: dragnet-ransomware-2025-0264 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: 6137205e-24c4-57c6-9277-76bf629a235e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
