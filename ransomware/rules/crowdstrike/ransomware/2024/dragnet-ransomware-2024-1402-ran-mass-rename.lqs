// Dragnet [Ransomware]: dragnet-ransomware-2024-1402 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 0d0d151e-5f29-58c5-b4e0-63ca00ffa016

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
