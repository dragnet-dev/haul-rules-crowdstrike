// Dragnet [Ransomware]: dragnet-ransomware-2025-1088 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: f5502b9f-5c42-5022-b454-2bbbeb4b40a8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
