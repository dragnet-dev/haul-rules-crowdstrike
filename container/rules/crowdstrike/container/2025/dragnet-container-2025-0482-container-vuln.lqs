// Dragnet [Container]: dragnet-container-2025-0482 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 43d9d036-b22d-5132-b447-c4763687aa45

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
