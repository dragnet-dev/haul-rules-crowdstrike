// Dragnet [Ransomware]: dragnet-ransomware-2024-3529 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: 53fa90de-cbac-5591-be7c-d9b0a74a3412

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
