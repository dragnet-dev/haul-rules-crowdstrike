// Dragnet [Ransomware]: dragnet-ransomware-2024-0720 — Mass File Rename (spacebears)
// Status: experimental | Level: high | ID: 83d9e517-a96d-5c32-8c25-24e7856f934a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
