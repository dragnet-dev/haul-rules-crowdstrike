// Dragnet [Ransomware]: dragnet-ransomware-2023-2919 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: 18e2b19e-bcda-5c34-b94b-2436fe8e0b41

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
