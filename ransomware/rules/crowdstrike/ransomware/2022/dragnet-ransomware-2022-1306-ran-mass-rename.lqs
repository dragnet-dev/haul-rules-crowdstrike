// Dragnet [Ransomware]: dragnet-ransomware-2022-1306 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 76d83d18-b2d5-53d7-a69c-a1272687644d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
