// Dragnet [Ransomware]: dragnet-ransomware-2022-1350 — Mass File Rename (vicesociety)
// Status: deprecated | Level: high | ID: 596cc969-f52a-582c-91c7-1513a354d9be

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
