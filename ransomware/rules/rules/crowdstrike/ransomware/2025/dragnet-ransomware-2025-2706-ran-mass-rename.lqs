// Dragnet [Ransomware]: dragnet-ransomware-2025-2706 — Mass File Rename (devman)
// Status: deprecated | Level: high | ID: 36093d3a-285e-5e81-bf05-73b90e81c240

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
