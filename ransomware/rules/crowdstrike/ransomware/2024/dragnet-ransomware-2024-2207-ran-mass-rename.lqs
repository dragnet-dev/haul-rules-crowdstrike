// Dragnet [Ransomware]: dragnet-ransomware-2024-2207 — Mass File Rename (ransomhouse)
// Status: experimental | Level: high | ID: 2e43b0a7-a97d-50e1-933e-f321107c0ce7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
