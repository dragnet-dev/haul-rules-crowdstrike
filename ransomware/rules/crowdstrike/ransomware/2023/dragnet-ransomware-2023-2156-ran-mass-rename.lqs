// Dragnet [Ransomware]: dragnet-ransomware-2023-2156 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 7067396b-a8cc-5893-9189-163967f9a719

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
