// Dragnet [Ransomware]: dragnet-ransomware-2024-5612 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: c027e470-8924-5228-928d-439dc5933998

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
