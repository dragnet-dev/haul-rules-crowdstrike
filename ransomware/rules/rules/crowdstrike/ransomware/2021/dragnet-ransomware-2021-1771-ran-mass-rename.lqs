// Dragnet [Ransomware]: dragnet-ransomware-2021-1771 — Mass File Rename (revil)
// Status: deprecated | Level: high | ID: 600b28c7-7492-52ba-9384-5c35d84f9271

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
