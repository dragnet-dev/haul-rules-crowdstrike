// Dragnet [Ransomware]: dragnet-ransomware-2023-1853 — Mass File Rename (play)
// Status: experimental | Level: high | ID: b760571b-25ea-5c68-94ae-1550b678bcb5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
