// Dragnet [Ransomware]: dragnet-ransomware-2025-7887 — Mass File Rename (J)
// Status: experimental | Level: high | ID: a7f61bda-a822-52bb-8567-9b6b8994d574

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
