// Dragnet [Ransomware]: dragnet-ransomware-2025-2163 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 43962c18-2490-5d0f-b27e-bd8ed1170f8b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
