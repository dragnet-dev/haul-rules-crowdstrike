// Dragnet [Ransomware]: dragnet-ransomware-2022-0510 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 0f5e55ff-ac50-5308-9125-0e6a38b804db

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
