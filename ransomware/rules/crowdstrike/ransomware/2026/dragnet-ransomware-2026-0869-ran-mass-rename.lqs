// Dragnet [Ransomware]: dragnet-ransomware-2026-0869 — Mass File Rename (incransom)
// Status: test | Level: high | ID: 631cb748-a219-5684-8efb-9e668a298a66

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
