// Dragnet [Ransomware]: dragnet-ransomware-2025-2288 — Mass File Rename (interlock)
// Status: experimental | Level: high | ID: 8bfe2290-5b51-558e-8dc3-e50aade9a45d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
