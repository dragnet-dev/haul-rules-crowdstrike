// Dragnet [Ransomware]: dragnet-ransomware-2024-1752 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: e6fe95a5-de8b-5b2d-9d0c-01552ab84409

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
