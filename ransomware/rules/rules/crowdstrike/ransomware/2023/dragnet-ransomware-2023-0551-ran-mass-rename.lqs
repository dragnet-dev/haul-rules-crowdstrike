// Dragnet [Ransomware]: dragnet-ransomware-2023-0551 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: e5f89f56-12d8-5e87-828d-3d32169acfc4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
