// Dragnet [Container]: dragnet-container-2024-1359 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: acc4f2e0-0114-5803-aec2-bfec64f7a519

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:8* OR ImageFileName = *debian:9*)
| table([timestamp, ComputerName])
| limit(1000)
