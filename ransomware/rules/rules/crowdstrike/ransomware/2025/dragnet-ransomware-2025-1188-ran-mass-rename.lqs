// Dragnet [Ransomware]: dragnet-ransomware-2025-1188 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 15365f11-0433-5848-a39c-ccb9779f081a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
