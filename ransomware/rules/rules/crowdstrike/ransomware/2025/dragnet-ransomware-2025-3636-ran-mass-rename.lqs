// Dragnet [Ransomware]: dragnet-ransomware-2025-3636 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 534fa33f-a6a9-5ebd-90a3-6817a7946830

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
