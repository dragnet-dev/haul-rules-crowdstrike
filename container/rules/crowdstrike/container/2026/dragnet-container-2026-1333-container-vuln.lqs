// Dragnet [Container]: dragnet-container-2026-1333 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: d1d6c433-7379-5bc9-b8ee-61210e593342

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10*)
| table([timestamp, ComputerName])
| limit(1000)
