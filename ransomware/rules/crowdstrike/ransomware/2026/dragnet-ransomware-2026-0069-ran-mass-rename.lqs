// Dragnet [Ransomware]: dragnet-ransomware-2026-0069 — Mass File Rename (SilentRansomGroup)
// Status: deprecated | Level: high | ID: 447b12bb-cddc-55c9-af1a-c1e26861a2e7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
