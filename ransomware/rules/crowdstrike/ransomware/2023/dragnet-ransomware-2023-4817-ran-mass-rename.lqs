// Dragnet [Ransomware]: dragnet-ransomware-2023-4817 — Mass File Rename (monti)
// Status: experimental | Level: high | ID: f8257abe-b89a-516f-ab03-cf71f8998144

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
