// Dragnet [Ransomware]: dragnet-ransomware-2025-7881 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: ccec43d9-99c3-514f-870e-159236a21240

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
