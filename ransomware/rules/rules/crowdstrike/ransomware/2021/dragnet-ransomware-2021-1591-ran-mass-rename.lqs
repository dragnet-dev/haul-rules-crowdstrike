// Dragnet [Ransomware]: dragnet-ransomware-2021-1591 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 13da2de9-a311-5188-bc66-9d015aad030f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
