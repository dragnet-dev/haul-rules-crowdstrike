// Dragnet [Ransomware]: dragnet-ransomware-2025-4239 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: fd830fa5-2180-5c0b-bdc3-f129c3106b37

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
