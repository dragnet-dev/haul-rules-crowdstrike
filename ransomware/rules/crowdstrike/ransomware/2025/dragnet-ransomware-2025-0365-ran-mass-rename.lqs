// Dragnet [Ransomware]: dragnet-ransomware-2025-0365 — Mass File Rename (play)
// Status: experimental | Level: high | ID: b1956731-a929-55f2-a5f6-7fc727bdbbf8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
