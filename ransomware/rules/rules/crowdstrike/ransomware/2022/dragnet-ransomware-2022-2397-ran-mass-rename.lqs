// Dragnet [Ransomware]: dragnet-ransomware-2022-2397 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 3068e1ab-0750-514c-9a6e-30c02d0710f1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
