// Dragnet [Ransomware]: dragnet-ransomware-2021-0544 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 60d767fa-5935-58df-bb3d-7f126199aefb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
