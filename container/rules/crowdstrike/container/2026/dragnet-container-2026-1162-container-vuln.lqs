// Dragnet [Container]: dragnet-container-2026-1162 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: c375f2db-63a7-5a0c-98bb-0b65c876a845

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:8*)
| table([timestamp, ComputerName])
| limit(1000)
