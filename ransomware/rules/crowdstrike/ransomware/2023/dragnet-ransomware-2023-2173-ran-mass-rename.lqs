// Dragnet [Ransomware]: dragnet-ransomware-2023-2173 — Mass File Rename (stormous)
// Status: experimental | Level: high | ID: bfc93b22-2673-531b-a7c7-65f853ff9190

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
