// Dragnet [Ransomware]: dragnet-ransomware-2025-3123 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 268b32c1-41a3-5e33-8244-96236507a3ea

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
