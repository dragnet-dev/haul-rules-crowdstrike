// Dragnet [Ransomware]: dragnet-ransomware-2025-4448 — Mass File Rename (J)
// Status: experimental | Level: high | ID: b1b454a7-d0f3-5739-925a-b845adc77608

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
