// Dragnet [Ransomware]: dragnet-ransomware-2023-2749 — Mass File Rename (malas)
// Status: experimental | Level: high | ID: 28655eab-0f56-56ac-8aaf-00a4f24bf40f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
