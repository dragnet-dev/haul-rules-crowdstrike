// Dragnet [Ransomware]: dragnet-ransomware-2022-0669 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 07a50d63-8701-5348-8bd5-d4dab275340d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
