// Dragnet [Ransomware]: dragnet-ransomware-2023-3292 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: fd2b30a2-2f87-5371-9326-bf2f85d7c5b7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
