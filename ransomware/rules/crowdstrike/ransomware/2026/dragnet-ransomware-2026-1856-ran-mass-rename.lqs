// Dragnet [Ransomware]: dragnet-ransomware-2026-1856 — Mass File Rename (dragonforce)
// Status: stable | Level: high | ID: 1004632b-be8e-57ac-b03e-62422055154b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
