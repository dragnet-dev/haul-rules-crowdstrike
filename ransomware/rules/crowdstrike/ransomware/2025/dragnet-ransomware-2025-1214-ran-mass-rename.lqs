// Dragnet [Ransomware]: dragnet-ransomware-2025-1214 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: cc21e854-961a-5ffb-a84e-b5f235dd1adf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
