// Dragnet [Ransomware]: dragnet-ransomware-2025-0290 — Mass File Rename (apos)
// Status: experimental | Level: high | ID: 8d9c87cd-81a1-52b6-baa8-6472510b7bed

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
