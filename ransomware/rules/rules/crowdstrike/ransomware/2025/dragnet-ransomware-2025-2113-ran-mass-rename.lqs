// Dragnet [Ransomware]: dragnet-ransomware-2025-2113 — Mass File Rename (nightspire)
// Status: deprecated | Level: high | ID: b404df6a-61cf-5840-97ee-01c2c8e8b03e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
