// Dragnet [Ransomware]: dragnet-ransomware-2025-3822 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 5bccf56d-4ac0-5692-b66b-fab1dedc655f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
