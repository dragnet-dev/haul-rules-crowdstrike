// Dragnet [Ransomware]: dragnet-ransomware-2025-4459 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 00078a8e-2d20-56c6-b18b-793d42d2d975

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
