// Dragnet [Ransomware]: dragnet-ransomware-2024-3721 — Mass File Rename (handala)
// Status: experimental | Level: high | ID: 44f7e0b3-2405-56fc-ae29-6725b086c1c3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
