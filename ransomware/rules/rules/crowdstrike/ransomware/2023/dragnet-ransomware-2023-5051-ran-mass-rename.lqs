// Dragnet [Ransomware]: dragnet-ransomware-2023-5051 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 2c229057-ee3a-5edb-ac1f-1c6f13b40e60

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
