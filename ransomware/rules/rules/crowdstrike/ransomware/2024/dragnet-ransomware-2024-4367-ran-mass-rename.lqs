// Dragnet [Ransomware]: dragnet-ransomware-2024-4367 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: a777d874-8324-523e-8f1a-c927067b460b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
