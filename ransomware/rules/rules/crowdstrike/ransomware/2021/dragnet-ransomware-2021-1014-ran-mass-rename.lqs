// Dragnet [Ransomware]: dragnet-ransomware-2021-1014 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: a9e016ff-896b-5e96-a546-226cb987b6ef

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
