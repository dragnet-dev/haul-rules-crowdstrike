// Dragnet [Ransomware]: dragnet-ransomware-2022-1405 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 94e9fc80-0640-58be-9f98-54baba10df54

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
