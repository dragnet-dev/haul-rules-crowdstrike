// Dragnet [Ransomware]: dragnet-ransomware-2026-0319 — Mass File Rename (dragonforce)
// Status: test | Level: high | ID: 4572ffc3-5861-5bcc-a5b7-f54f3023d01b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
