// Dragnet [Ransomware]: dragnet-ransomware-2022-0574 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: b998aa70-5969-58ce-9a04-f8ede2fb7c2d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
