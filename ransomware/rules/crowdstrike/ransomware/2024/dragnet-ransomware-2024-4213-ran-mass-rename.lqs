// Dragnet [Ransomware]: dragnet-ransomware-2024-4213 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: e73ecb7c-a0b2-5192-91b0-d1de671e25a0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
