// Dragnet [Ransomware]: dragnet-ransomware-2026-2166 — Mass File Rename (exitium)
// Status: stable | Level: high | ID: 2c5a4f2d-8003-5feb-bf34-5d2f7ec6d99f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
