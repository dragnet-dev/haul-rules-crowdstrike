// Dragnet [Ransomware]: dragnet-ransomware-2020-0034 — Mass File Rename (ryuk)
// Status: deprecated | Level: high | ID: 54f89da8-228f-58d8-b54d-1a13f9f8b8c9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
