// Dragnet [Container]: dragnet-container-2025-0080 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 8825b2be-69ab-55c2-9a42-cad7c9818100

#event_simpleName=*
| (ImageFileName = *azure linux:3.0* OR ImageFileName = *chainguard:* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
