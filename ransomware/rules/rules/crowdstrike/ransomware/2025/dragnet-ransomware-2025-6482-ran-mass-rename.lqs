// Dragnet [Ransomware]: dragnet-ransomware-2025-6482 — Mass File Rename (devman)
// Status: experimental | Level: high | ID: ff8694cd-0fd4-5fb6-a541-689fee48b60f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
