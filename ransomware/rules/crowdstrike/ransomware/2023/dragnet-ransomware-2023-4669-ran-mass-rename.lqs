// Dragnet [Ransomware]: dragnet-ransomware-2023-4669 — Mass File Rename (play)
// Status: experimental | Level: high | ID: f83a480e-9551-51a3-96fb-e95a3e425c69

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
