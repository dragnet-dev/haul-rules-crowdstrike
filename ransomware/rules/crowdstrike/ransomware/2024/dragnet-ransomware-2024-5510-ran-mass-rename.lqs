// Dragnet [Ransomware]: dragnet-ransomware-2024-5510 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 3eea642b-ccd5-5d23-99ba-e451cc6a4e57

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
