// Dragnet [Ransomware]: dragnet-ransomware-2025-5312 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: b827c072-9634-55f8-bbfa-6d2568b7909b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
