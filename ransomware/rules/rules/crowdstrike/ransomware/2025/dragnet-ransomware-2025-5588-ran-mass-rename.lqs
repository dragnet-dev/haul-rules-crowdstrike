// Dragnet [Ransomware]: dragnet-ransomware-2025-5588 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 230f91ee-c790-5266-8ef3-6d985b0b61f6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
