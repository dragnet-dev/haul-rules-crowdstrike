// Dragnet [Ransomware]: dragnet-ransomware-2024-0859 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 0e4775d2-2506-505a-81f9-f0e0e3315054

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
