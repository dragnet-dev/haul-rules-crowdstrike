// Dragnet [Ransomware]: dragnet-ransomware-2025-2152 — Mass File Rename (killsec)
// Status: deprecated | Level: high | ID: 055be4db-7498-552a-b2b3-2d17b4bfe639

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
