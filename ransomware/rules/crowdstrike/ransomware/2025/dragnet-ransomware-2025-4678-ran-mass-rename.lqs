// Dragnet [Ransomware]: dragnet-ransomware-2025-4678 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 6daa395f-a351-5b2f-ae15-8b25853b1892

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
