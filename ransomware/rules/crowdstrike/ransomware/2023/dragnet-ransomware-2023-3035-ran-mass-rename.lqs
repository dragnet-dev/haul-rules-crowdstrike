// Dragnet [Ransomware]: dragnet-ransomware-2023-3035 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: b021389b-3b8b-523e-bea7-58e7539b9502

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
