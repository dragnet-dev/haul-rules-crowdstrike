// Dragnet [Ransomware]: dragnet-ransomware-2025-4612 — Mass File Rename (play)
// Status: experimental | Level: high | ID: b652ff37-321a-5cea-933b-7e96e5aedfb6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
