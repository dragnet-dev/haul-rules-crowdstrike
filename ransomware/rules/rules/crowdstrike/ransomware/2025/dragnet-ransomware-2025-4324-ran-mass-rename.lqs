// Dragnet [Ransomware]: dragnet-ransomware-2025-4324 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 29279e0c-dcba-5fb6-81ef-708bd49ee27c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
