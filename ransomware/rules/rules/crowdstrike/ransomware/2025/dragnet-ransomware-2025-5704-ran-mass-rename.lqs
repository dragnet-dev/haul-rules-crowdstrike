// Dragnet [Ransomware]: dragnet-ransomware-2025-5704 — Mass File Rename (sarcoma)
// Status: deprecated | Level: high | ID: 214e0c7d-3c87-591b-97d4-c72f6b786ee2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
