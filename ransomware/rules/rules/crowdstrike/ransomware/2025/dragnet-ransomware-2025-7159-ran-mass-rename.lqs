// Dragnet [Ransomware]: dragnet-ransomware-2025-7159 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 89ac65cd-7027-594d-a078-a08651fd0e31

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
