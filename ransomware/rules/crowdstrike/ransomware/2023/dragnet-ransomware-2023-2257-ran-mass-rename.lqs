// Dragnet [Ransomware]: dragnet-ransomware-2023-2257 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 4c1905ab-81e9-5069-a973-94549c00ba07

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
