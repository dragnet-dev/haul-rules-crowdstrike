// Dragnet [Ransomware]: dragnet-ransomware-2024-2294 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 4eb53193-1bf0-5895-afe8-ba0280dc78ca

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
