// Dragnet [Ransomware]: dragnet-ransomware-2022-0954 — Mass File Rename (quantum)
// Status: deprecated | Level: high | ID: 8e6924c1-7058-58c5-a5ac-c0379e513199

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
