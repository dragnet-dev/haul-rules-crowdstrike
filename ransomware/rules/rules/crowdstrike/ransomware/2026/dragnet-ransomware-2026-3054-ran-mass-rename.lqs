// Dragnet [Ransomware]: dragnet-ransomware-2026-3054 — Mass File Rename (incransom)
// Status: test | Level: high | ID: 9eef5557-bc22-51a4-9127-a5164ce169e5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
