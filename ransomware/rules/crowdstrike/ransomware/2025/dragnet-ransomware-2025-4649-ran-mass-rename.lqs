// Dragnet [Ransomware]: dragnet-ransomware-2025-4649 — Mass File Rename (lockbit5)
// Status: experimental | Level: high | ID: bb02d575-1131-5cc8-82d1-3f6227d67a0f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
