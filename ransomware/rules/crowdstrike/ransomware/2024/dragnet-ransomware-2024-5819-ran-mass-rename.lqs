// Dragnet [Ransomware]: dragnet-ransomware-2024-5819 — Mass File Rename (dragonransomware)
// Status: experimental | Level: high | ID: 99b1482c-6400-5377-97b2-7d7144e6f4b6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
