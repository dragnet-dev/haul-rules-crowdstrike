// Dragnet [Ransomware]: dragnet-ransomware-2024-1071 — Mass File Rename (ElDorado)
// Status: deprecated | Level: high | ID: f495c806-cf51-586e-908d-6ef5a5031129

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
