// Dragnet [Ransomware]: dragnet-ransomware-2023-3186 — Mass File Rename (toufan)
// Status: deprecated | Level: high | ID: 973184e3-2297-55eb-96bf-b518a92dec9d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
