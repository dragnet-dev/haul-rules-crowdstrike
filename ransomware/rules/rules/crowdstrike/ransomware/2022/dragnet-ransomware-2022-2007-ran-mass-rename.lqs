// Dragnet [Ransomware]: dragnet-ransomware-2022-2007 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 679e15df-f0d1-5f2a-b4a6-1f222d23aaf4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
