// Dragnet [Ransomware]: dragnet-ransomware-2022-2575 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 6c80c7bc-cd55-5941-ad91-1e69c5882096

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
