// Dragnet [Ransomware]: dragnet-ransomware-2024-5095 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: 6d6fa1e0-9b43-5912-8308-93d2af205a7a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
