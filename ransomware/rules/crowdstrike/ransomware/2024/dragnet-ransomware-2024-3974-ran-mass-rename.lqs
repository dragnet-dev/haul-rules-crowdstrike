// Dragnet [Ransomware]: dragnet-ransomware-2024-3974 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 1ca03148-5450-5901-be67-07a6a70e97b8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
