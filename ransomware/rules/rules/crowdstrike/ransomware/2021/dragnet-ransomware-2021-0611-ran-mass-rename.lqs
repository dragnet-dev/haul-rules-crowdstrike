// Dragnet [Ransomware]: dragnet-ransomware-2021-0611 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 1e682c1b-feef-59e0-85d7-1decb65c934a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
