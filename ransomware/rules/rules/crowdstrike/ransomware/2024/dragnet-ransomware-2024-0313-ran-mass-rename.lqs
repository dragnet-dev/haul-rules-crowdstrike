// Dragnet [Ransomware]: dragnet-ransomware-2024-0313 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 1dffe4a4-dc15-5a1a-8757-eb03a1882b2f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
