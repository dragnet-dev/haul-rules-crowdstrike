// Dragnet [Ransomware]: dragnet-ransomware-2024-1811 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: c77220c9-7f2c-5e46-9fd9-f704dfd73b72

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
