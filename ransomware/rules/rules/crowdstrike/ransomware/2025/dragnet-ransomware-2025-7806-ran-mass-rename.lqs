// Dragnet [Ransomware]: dragnet-ransomware-2025-7806 — Mass File Rename (sinobi)
// Status: experimental | Level: high | ID: 7e38e32c-e928-58b9-ac85-c245e5ecf975

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
