// Dragnet [Ransomware]: dragnet-ransomware-2024-4774 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 9bd3513c-ca87-5eab-ab62-7341e7d50071

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
