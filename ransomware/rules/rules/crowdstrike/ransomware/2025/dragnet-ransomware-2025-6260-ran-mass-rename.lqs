// Dragnet [Ransomware]: dragnet-ransomware-2025-6260 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: 509a12cd-eb76-5b67-b94b-b22740291e11

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
