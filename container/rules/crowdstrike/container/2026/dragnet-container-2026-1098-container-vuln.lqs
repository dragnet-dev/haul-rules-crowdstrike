// Dragnet [Container]: dragnet-container-2026-1098 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: f31c4f16-d583-5377-80cf-6f3fba441850

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:7*)
| table([timestamp, ComputerName])
| limit(1000)
