// Dragnet [Ransomware]: dragnet-ransomware-2024-2676 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: cfbbd6db-cb52-582b-bb59-5ceab17b2caf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
