// Dragnet [Ransomware]: dragnet-ransomware-2022-1950 — Mass File Rename (lv)
// Status: deprecated | Level: high | ID: 64c8f3da-98aa-5e23-a6b8-7e8434276544

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
