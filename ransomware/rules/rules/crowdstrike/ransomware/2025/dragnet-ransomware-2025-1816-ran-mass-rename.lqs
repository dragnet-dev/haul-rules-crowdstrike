// Dragnet [Ransomware]: dragnet-ransomware-2025-1816 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 49374ad2-a0c7-5e6a-8f17-d149c54844c3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
