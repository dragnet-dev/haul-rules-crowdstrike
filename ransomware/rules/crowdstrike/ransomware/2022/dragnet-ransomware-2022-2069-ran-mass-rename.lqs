// Dragnet [Ransomware]: dragnet-ransomware-2022-2069 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: b6ebb79d-bbbf-5e24-9ed3-14b34a153df1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
