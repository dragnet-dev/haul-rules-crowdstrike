// Dragnet [Ransomware]: dragnet-ransomware-2025-2920 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 974b4f16-eead-5834-9c4e-ef7c3d25dd6c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
