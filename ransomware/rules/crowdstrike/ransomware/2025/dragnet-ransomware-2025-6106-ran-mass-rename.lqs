// Dragnet [Ransomware]: dragnet-ransomware-2025-6106 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 67bb8cc4-7567-54e1-84db-79e4af92c994

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
