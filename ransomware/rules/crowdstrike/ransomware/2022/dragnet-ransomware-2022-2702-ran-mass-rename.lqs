// Dragnet [Ransomware]: dragnet-ransomware-2022-2702 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: bef086f2-57a2-527f-9629-1d341d10bea9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
