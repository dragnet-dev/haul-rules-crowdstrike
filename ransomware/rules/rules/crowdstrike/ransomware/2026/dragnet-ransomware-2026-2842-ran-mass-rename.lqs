// Dragnet [Ransomware]: dragnet-ransomware-2026-2842 — Mass File Rename (worldleaks)
// Status: stable | Level: high | ID: 9a7d6b20-0dde-56cb-a093-11b8f6eec0cb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
