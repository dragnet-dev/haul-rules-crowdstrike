// Dragnet [Ransomware]: dragnet-ransomware-2026-1585 — Mass File Rename (aurora)
// Status: stable | Level: high | ID: 64e18a83-8ca9-55dd-bb21-f7653735a608

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
