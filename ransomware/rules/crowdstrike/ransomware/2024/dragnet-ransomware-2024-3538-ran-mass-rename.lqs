// Dragnet [Ransomware]: dragnet-ransomware-2024-3538 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: 413fcbe1-698a-5d10-bb5b-ddda3c5c7211

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
