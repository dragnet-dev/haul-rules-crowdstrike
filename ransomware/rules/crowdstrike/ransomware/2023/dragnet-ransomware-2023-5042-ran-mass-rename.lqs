// Dragnet [Ransomware]: dragnet-ransomware-2023-5042 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 822e2eda-32cc-582d-8182-9b36e490ff30

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
