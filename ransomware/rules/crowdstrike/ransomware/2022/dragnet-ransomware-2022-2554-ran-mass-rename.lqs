// Dragnet [Ransomware]: dragnet-ransomware-2022-2554 — Mass File Rename (lv)
// Status: deprecated | Level: high | ID: 16356645-6e71-5d1e-8a29-f77743d3d58a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
