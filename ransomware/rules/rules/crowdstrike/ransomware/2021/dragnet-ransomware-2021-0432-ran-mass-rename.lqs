// Dragnet [Ransomware]: dragnet-ransomware-2021-0432 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 9da19bc0-7148-50ac-9443-845988036565

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
