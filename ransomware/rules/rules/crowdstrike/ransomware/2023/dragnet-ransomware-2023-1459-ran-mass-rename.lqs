// Dragnet [Ransomware]: dragnet-ransomware-2023-1459 — Mass File Rename (nokoyawa)
// Status: experimental | Level: high | ID: e95c433b-2d9f-5e32-a13e-65bcdf6b3676

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
