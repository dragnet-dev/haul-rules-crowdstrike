// Dragnet [Ransomware]: dragnet-ransomware-2025-6640 — Mass File Rename (worldleaks)
// Status: experimental | Level: high | ID: cc888975-7567-5cb3-a084-968835d7dd6f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
