// Dragnet [Ransomware]: dragnet-ransomware-2022-1436 — Mass File Rename (royal)
// Status: deprecated | Level: high | ID: 2d1aa33b-d094-5f59-8edf-c3c8cde21a20

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
