// Dragnet [Ransomware]: dragnet-ransomware-2020-0044 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: df963303-ba1e-54ac-b92e-9cf26fa9988d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
