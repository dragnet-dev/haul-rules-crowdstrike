// Dragnet [Ransomware]: dragnet-ransomware-2026-1978 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 721e4f63-be9d-5b98-b6c6-bef7dcebb449

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
