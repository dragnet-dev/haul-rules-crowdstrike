// Dragnet [Ransomware]: dragnet-ransomware-2026-2975 — Mass File Rename (incransom)
// Status: stable | Level: high | ID: 3498af42-0ea7-5f27-8aef-539a91c73956

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
