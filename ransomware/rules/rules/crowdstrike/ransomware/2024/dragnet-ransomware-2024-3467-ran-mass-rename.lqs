// Dragnet [Ransomware]: dragnet-ransomware-2024-3467 — Mass File Rename (chort)
// Status: experimental | Level: high | ID: 4ed59647-b7f4-5819-8a81-7156a68c7494

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
