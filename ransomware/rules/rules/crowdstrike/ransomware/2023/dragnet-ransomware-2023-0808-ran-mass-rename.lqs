// Dragnet [Ransomware]: dragnet-ransomware-2023-0808 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 2520eaf5-acb8-50b8-b470-40d241173de5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
