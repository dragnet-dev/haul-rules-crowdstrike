// Dragnet [Ransomware]: dragnet-ransomware-2024-1231 — Mass File Rename (alphalocker)
// Status: experimental | Level: high | ID: 380116c8-3400-5722-9c82-0b06e6ee6249

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
