// Dragnet [Ransomware]: dragnet-ransomware-2024-5917 — Mass File Rename (meow)
// Status: experimental | Level: high | ID: 375401b0-d753-5a51-a807-93f93abd9bef

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
