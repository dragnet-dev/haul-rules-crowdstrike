// Dragnet [Ransomware]: dragnet-ransomware-2025-0509 — Mass File Rename (rhysida)
// Status: experimental | Level: high | ID: c460bfed-8421-5315-852c-bbb21aaba892

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
