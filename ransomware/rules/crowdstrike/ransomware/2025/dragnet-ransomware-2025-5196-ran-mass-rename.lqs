// Dragnet [Ransomware]: dragnet-ransomware-2025-5196 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: 6a27bdd5-8d80-5fdc-a7c6-62f3f76b207e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
