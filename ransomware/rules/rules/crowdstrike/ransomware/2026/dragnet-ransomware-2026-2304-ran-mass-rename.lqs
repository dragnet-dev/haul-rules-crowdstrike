// Dragnet [Ransomware]: dragnet-ransomware-2026-2304 — Mass File Rename (spacebears)
// Status: stable | Level: high | ID: 1be9986f-9f41-5562-bf4a-35220f79e96b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
