// Dragnet [Ransomware]: dragnet-ransomware-2025-2983 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 24ec7ea0-9264-5b67-a0da-451f32f83f50

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
