// Dragnet [Ransomware]: dragnet-ransomware-2023-4706 — Mass File Rename (noescape)
// Status: experimental | Level: high | ID: a82acac3-1a4b-542a-bd36-5fd2633f99ce

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
