// Dragnet [Ransomware]: dragnet-ransomware-2023-1727 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 817abde5-216e-5015-a266-4eefaeaa842c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
