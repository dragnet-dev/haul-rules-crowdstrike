// Dragnet [Ransomware]: dragnet-ransomware-2025-5032 — Mass File Rename (lockbit5)
// Status: test | Level: high | ID: 589c542a-c41e-52b4-9b49-10b29e640d97

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
