// Dragnet [Ransomware]: dragnet-ransomware-2021-1140 — Mass File Rename (mountlocker)
// Status: deprecated | Level: high | ID: 640722b9-d996-5805-a9ad-71d46487c7b0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
