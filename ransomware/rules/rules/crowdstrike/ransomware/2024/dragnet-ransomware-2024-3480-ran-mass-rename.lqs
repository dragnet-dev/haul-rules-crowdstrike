// Dragnet [Ransomware]: dragnet-ransomware-2024-3480 — Mass File Rename (safepay)
// Status: deprecated | Level: high | ID: 5895183d-d712-59cd-ae80-64efe535062e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
