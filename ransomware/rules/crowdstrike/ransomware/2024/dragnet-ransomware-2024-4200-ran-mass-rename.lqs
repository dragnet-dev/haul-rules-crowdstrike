// Dragnet [Ransomware]: dragnet-ransomware-2024-4200 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 08a9dafa-144f-5506-8a7e-4b9c06954977

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
