// Dragnet [Ransomware]: dragnet-ransomware-2023-1535 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 65d3b2af-ade7-57e5-be9b-80364735f018

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
