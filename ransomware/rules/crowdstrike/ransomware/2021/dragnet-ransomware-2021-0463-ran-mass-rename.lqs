// Dragnet [Ransomware]: dragnet-ransomware-2021-0463 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 6e6c8b6a-0b6d-516d-b279-fef784607343

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
