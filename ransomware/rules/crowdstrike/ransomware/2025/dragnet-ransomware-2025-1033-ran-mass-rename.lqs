// Dragnet [Ransomware]: dragnet-ransomware-2025-1033 — Mass File Rename (ransomhouse)
// Status: experimental | Level: high | ID: 6990f761-6165-5903-bcc8-af8cacefa1b9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
