// Dragnet [Ransomware]: dragnet-ransomware-2022-0372 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 264f6f8f-7366-59f6-a8f9-6e7a3b86848d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
