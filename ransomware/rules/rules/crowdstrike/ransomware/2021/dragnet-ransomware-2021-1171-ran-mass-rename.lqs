// Dragnet [Ransomware]: dragnet-ransomware-2021-1171 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 57fd226d-11e4-5b23-9df1-d1b1d60b7b83

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
