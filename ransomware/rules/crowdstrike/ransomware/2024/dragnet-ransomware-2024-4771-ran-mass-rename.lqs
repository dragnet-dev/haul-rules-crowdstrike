// Dragnet [Ransomware]: dragnet-ransomware-2024-4771 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: e811aee2-f25c-5ccc-8753-cd41001d8eb3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
