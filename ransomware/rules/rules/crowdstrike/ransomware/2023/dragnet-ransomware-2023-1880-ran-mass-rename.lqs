// Dragnet [Ransomware]: dragnet-ransomware-2023-1880 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 13a3d37b-cf67-546e-a44d-f3c665b5cacd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
