// Dragnet [Ransomware]: dragnet-ransomware-2025-4962 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: b51fe5eb-b56a-55c0-8b57-1ba2eda7b929

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
