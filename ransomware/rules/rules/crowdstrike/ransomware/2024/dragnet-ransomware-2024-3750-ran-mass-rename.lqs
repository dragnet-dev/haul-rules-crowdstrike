// Dragnet [Ransomware]: dragnet-ransomware-2024-3750 — Mass File Rename (ElDorado)
// Status: experimental | Level: high | ID: 27e5cb2a-1b65-5980-84e4-9421da907974

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
