// Dragnet [Ransomware]: dragnet-ransomware-2025-2677 — Mass File Rename (dragonforce)
// Status: test | Level: high | ID: d9018351-16f2-5363-a961-6b4471206304

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
