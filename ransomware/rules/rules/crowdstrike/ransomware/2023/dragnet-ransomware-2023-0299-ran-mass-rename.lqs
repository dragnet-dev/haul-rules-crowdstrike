// Dragnet [Ransomware]: dragnet-ransomware-2023-0299 — Mass File Rename (ransomed)
// Status: deprecated | Level: high | ID: 3504d1a3-48b6-5bd5-8e5b-c1213464bcd3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
