// Dragnet [Ransomware]: dragnet-ransomware-2025-1022 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 154754d5-c74d-5d02-9821-f0bfa865b3a7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
