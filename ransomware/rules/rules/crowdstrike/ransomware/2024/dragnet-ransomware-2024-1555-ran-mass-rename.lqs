// Dragnet [Ransomware]: dragnet-ransomware-2024-1555 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: f6e6257f-1778-5c37-8b08-361ea3b0ddc9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
