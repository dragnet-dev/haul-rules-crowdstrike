// Dragnet [Ransomware]: dragnet-ransomware-2025-0054 — Mass File Rename (worldleaks)
// Status: experimental | Level: high | ID: 70786853-76e6-57ac-8704-206e611ca3f3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
