// Dragnet [Ransomware]: dragnet-ransomware-2023-2736 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 9b9dbf65-4aa0-569c-ac8c-a59726177b0a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
