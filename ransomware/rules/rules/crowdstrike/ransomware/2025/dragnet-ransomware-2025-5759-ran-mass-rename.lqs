// Dragnet [Ransomware]: dragnet-ransomware-2025-5759 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: 8f5ca046-0d50-5913-920b-4aac1cdf73f5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
