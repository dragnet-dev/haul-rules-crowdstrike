// Dragnet [Ransomware]: dragnet-ransomware-2024-4558 — Mass File Rename (trigona)
// Status: experimental | Level: high | ID: a8dad952-ecae-533d-aa5f-2ca8c8a90e1d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
