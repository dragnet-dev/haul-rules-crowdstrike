// Dragnet [Ransomware]: dragnet-ransomware-2023-1803 — Mass File Rename (medusalocker)
// Status: experimental | Level: high | ID: fcc0fdc8-a87d-57de-b9f8-1e507d7a8ff7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
