// Dragnet [Ransomware]: dragnet-ransomware-2025-2107 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 07528e71-89ec-5a27-bdcb-38180194d305

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
