// Dragnet [Ransomware]: dragnet-ransomware-2021-1270 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 3d02825c-e045-5768-9063-3ede9f17eac4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
