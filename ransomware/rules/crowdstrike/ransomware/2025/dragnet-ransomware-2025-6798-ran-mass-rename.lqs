// Dragnet [Ransomware]: dragnet-ransomware-2025-6798 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 7eabb8d6-6452-55b5-a57e-488f94f00317

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
