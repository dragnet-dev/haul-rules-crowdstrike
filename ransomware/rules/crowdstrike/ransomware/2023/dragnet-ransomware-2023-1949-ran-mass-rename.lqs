// Dragnet [Ransomware]: dragnet-ransomware-2023-1949 — Mass File Rename (nokoyawa)
// Status: experimental | Level: high | ID: 33f4a084-f2a4-5038-a14c-7db516d39ca3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
