// Dragnet [Ransomware]: dragnet-ransomware-2023-3097 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 6feb27df-8ffd-5e4c-aa2a-5432af268616

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
