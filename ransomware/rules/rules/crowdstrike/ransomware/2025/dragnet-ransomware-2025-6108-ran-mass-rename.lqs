// Dragnet [Ransomware]: dragnet-ransomware-2025-6108 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: 4ff8433b-4170-5d4e-a008-736089ef4230

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
