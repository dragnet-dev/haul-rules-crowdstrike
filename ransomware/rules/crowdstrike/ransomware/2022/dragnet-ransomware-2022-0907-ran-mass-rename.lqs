// Dragnet [Ransomware]: dragnet-ransomware-2022-0907 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 24dd5463-2a5f-5f03-94f4-81b61dd7a138

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
