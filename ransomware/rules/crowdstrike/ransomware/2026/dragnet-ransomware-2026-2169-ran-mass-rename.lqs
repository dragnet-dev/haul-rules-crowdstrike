// Dragnet [Ransomware]: dragnet-ransomware-2026-2169 — Mass File Rename (safepay)
// Status: stable | Level: high | ID: e4f766b8-65f9-518f-b2ee-af09f2d10b93

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
