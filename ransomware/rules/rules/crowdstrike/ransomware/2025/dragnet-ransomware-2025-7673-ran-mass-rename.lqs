// Dragnet [Ransomware]: dragnet-ransomware-2025-7673 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 5404f518-2f68-5d09-b628-810aa6b1cbe9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
