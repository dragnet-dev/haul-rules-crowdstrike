// Dragnet [Ransomware]: dragnet-ransomware-2020-0160 — Mass File Rename (doppelpaymer)
// Status: deprecated | Level: high | ID: 632337fc-c091-53cc-80a6-12e0d8e835a7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
