// Dragnet [Ransomware]: dragnet-ransomware-2025-7241 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 226aabb9-14f0-51c4-b63e-cbe7e4dae6fb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
