// Dragnet [Ransomware]: dragnet-ransomware-2023-3587 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 0a4fcc53-7e6d-5990-aa41-c1b06b07c07b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
