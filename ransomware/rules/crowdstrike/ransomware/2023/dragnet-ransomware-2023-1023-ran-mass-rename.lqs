// Dragnet [Ransomware]: dragnet-ransomware-2023-1023 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: c1832d1b-9579-51cb-81c0-b7f2af446071

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
