// Dragnet [Ransomware]: dragnet-ransomware-2021-1757 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: e6cfc70d-c15f-5cab-b419-4089db3de148

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
