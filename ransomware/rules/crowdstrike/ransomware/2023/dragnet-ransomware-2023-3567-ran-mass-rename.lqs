// Dragnet [Ransomware]: dragnet-ransomware-2023-3567 — Mass File Rename (qilin)
// Status: deprecated | Level: high | ID: d375b7d6-6581-5d61-a9c1-f924ae38f64e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
