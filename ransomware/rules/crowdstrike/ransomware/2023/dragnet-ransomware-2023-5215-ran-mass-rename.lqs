// Dragnet [Ransomware]: dragnet-ransomware-2023-5215 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: aae08315-a1e9-545e-84f3-8b4a397a30d5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
