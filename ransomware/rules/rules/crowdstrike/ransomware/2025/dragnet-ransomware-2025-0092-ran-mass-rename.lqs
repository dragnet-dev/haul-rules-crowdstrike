// Dragnet [Ransomware]: dragnet-ransomware-2025-0092 — Mass File Rename (kryptos)
// Status: deprecated | Level: high | ID: 4e2e013d-61f9-5378-bf17-e8a291a8c08a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
