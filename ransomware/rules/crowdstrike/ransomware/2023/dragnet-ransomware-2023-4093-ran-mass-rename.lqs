// Dragnet [Ransomware]: dragnet-ransomware-2023-4093 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 4e3e8cd7-f65e-544c-b91e-7d6817fa4fb3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
