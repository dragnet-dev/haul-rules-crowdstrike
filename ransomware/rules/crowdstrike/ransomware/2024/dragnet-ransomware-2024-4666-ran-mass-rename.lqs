// Dragnet [Ransomware]: dragnet-ransomware-2024-4666 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 37565240-2053-57bf-8a2c-6ea06367975e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
