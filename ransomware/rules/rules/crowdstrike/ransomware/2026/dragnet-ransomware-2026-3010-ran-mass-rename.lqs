// Dragnet [Ransomware]: dragnet-ransomware-2026-3010 — Mass File Rename (shinyhunters)
// Status: deprecated | Level: high | ID: 3d5300d7-597b-58a4-9f63-cd4233c30486

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
