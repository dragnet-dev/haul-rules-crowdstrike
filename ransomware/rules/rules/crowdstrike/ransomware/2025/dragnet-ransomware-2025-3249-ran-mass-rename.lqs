// Dragnet [Ransomware]: dragnet-ransomware-2025-3249 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: 7f837e48-385f-5007-80f2-f7032ab299ef

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
