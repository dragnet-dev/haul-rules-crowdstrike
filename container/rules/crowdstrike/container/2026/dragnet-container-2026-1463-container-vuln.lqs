// Dragnet [Container]: dragnet-container-2026-1463 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: e7564073-3664-5262-a006-db946ed6e0cc

#event_simpleName=*
| (ImageFileName = *chainguard:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
