// Dragnet [Ransomware]: dragnet-ransomware-2025-6628 — Mass File Rename (spacebears)
// Status: experimental | Level: high | ID: 25458fba-e250-512c-a1fe-d13621b2e6e0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
