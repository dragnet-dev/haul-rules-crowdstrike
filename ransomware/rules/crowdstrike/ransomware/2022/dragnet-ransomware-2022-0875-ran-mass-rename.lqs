// Dragnet [Ransomware]: dragnet-ransomware-2022-0875 — Mass File Rename (everest)
// Status: deprecated | Level: high | ID: f89fb8c4-7e6a-5c84-a7fd-ddcc383e4faf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
