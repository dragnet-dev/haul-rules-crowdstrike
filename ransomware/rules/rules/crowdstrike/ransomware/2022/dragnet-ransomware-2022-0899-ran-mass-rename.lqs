// Dragnet [Ransomware]: dragnet-ransomware-2022-0899 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 011b154a-45a2-5500-a23a-407d359b0a89

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
