// Dragnet [Ransomware]: dragnet-ransomware-2023-0977 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 93e2fb32-1c6a-57f6-b43c-529e0de9a492

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
