// Dragnet [Ransomware]: dragnet-ransomware-2024-2672 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 8e8c59c1-3361-5045-98f4-5cd78eabc234

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
