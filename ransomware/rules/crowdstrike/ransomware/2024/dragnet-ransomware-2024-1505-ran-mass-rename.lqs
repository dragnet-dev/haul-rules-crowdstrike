// Dragnet [Ransomware]: dragnet-ransomware-2024-1505 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 0d95bc31-fd4d-51b2-b046-ed9d6ed7b356

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
