// Dragnet [Ransomware]: dragnet-ransomware-2024-5156 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: d04498ba-f3d7-55c2-a228-4fa4562a75c3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
