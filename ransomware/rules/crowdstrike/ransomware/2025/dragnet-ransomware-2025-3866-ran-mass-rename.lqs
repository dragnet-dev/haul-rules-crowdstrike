// Dragnet [Ransomware]: dragnet-ransomware-2025-3866 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: eca926be-7f8d-5ef0-950a-a4fd14554ef0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
