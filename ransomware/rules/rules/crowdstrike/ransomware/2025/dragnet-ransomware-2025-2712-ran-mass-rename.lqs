// Dragnet [Ransomware]: dragnet-ransomware-2025-2712 — Mass File Rename (worldleaks)
// Status: experimental | Level: high | ID: f9bced39-94f1-5a9d-8468-8d57a2ffbf8a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
