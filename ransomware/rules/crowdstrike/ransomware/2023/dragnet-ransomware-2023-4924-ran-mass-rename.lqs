// Dragnet [Ransomware]: dragnet-ransomware-2023-4924 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: c7e36d33-df0f-5810-82da-ef95f7ec4053

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
