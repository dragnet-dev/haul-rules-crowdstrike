// Dragnet [Ransomware]: dragnet-ransomware-2025-2137 — Mass File Rename (coinbasecartel)
// Status: test | Level: high | ID: 9c080e52-45d2-596c-860c-487c0388d374

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
