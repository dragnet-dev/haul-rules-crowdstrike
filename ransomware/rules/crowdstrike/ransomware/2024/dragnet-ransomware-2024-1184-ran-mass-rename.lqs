// Dragnet [Ransomware]: dragnet-ransomware-2024-1184 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: 04aee40b-68b3-53fc-b28b-e910c960493c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
