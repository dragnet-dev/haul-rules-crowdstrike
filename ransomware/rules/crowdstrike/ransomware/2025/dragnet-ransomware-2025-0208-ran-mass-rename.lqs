// Dragnet [Ransomware]: dragnet-ransomware-2025-0208 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: e96886bf-fd0d-53f4-8dd9-8ba29319f041

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
