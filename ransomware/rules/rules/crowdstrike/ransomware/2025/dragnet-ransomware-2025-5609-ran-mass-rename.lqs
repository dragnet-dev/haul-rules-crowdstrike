// Dragnet [Ransomware]: dragnet-ransomware-2025-5609 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 4c3eb5c3-30bf-524a-a2af-fe228bc3248e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
