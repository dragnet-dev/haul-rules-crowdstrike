// Dragnet [Ransomware]: dragnet-ransomware-2024-5721 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 4435055c-0f78-5fda-a107-f897289d7efb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
