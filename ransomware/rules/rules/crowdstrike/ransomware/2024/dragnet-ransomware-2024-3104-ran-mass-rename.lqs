// Dragnet [Ransomware]: dragnet-ransomware-2024-3104 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 68aa408c-10e6-5fcf-93c4-60555c5dc17d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
