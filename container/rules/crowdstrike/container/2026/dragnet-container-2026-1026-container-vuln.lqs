// Dragnet [Container]: dragnet-container-2026-1026 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 437aaa66-5258-5d87-8375-0145365ee838

#event_simpleName=*
| (ImageFileName = *chainguard:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
