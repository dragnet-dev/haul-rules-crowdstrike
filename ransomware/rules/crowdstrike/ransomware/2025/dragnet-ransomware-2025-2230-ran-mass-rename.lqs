// Dragnet [Ransomware]: dragnet-ransomware-2025-2230 — Mass File Rename (medusalocker)
// Status: experimental | Level: high | ID: aeb3302f-896e-5604-812a-facdd96736d2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
