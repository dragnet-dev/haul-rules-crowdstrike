// Status: deprecated | Level: critical | ID: 20c63fb3-cd23-5126-8c76-e3a1613cdbac

#event_simpleName=*
| (ImageFileName = *debian:7* OR ImageFileName = *debian:8* OR ImageFileName = *ubuntu:14.04* OR ImageFileName = *ubuntu:15.04* OR ImageFileName = *ubuntu:15.10* OR ImageFileName = *ubuntu:16.04* OR ImageFileName = *ubuntu:16.04-ESM* OR ImageFileName = *ubuntu:16.10* OR ImageFileName = *ubuntu:17.04* OR ImageFileName = *ubuntu:17.10* OR ImageFileName = *ubuntu:18.04* OR ImageFileName = *ubuntu:18.10*)
| table([timestamp, ComputerName])
| limit(1000)
