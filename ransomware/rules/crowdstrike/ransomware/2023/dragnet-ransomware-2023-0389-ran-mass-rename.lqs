// Dragnet [Ransomware]: dragnet-ransomware-2023-0389 — Mass File Rename (play)
// Status: experimental | Level: high | ID: ee049e3d-bdf0-5175-b1a2-e762f2e09c47

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
