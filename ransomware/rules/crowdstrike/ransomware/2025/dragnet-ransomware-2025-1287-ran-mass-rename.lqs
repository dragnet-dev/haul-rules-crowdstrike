// Dragnet [Ransomware]: dragnet-ransomware-2025-1287 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: 699b68fd-d353-59a2-9108-2bab4d370f09

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
