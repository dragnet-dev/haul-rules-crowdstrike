// Dragnet [Ransomware]: dragnet-ransomware-2023-1145 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 8d2e8f5f-036f-5f5b-b469-0f11f3baf0e5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
