// Dragnet [Ransomware]: dragnet-ransomware-2025-7053 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: c116fe05-cfb8-5983-a74a-dfaff65a76ff

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
