// Dragnet [Ransomware]: dragnet-ransomware-2022-0750 — Mass File Rename (blackbasta)
// Status: deprecated | Level: high | ID: e907d1ec-4253-51c8-9614-57802b2a9f3a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
