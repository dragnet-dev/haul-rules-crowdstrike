// Dragnet [Ransomware]: dragnet-ransomware-2025-3571 — Mass File Rename (rhysida)
// Status: deprecated | Level: high | ID: 0fec95a7-626e-5f2c-8bef-c4ce13684e48

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
