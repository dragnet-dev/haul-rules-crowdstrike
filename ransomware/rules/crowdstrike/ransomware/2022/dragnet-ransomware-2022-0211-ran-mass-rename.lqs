// Dragnet [Ransomware]: dragnet-ransomware-2022-0211 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: e0fd3db1-1e2c-5cfb-bc7f-bd7c67114bc0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
