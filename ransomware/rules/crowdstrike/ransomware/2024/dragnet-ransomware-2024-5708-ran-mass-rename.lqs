// Dragnet [Ransomware]: dragnet-ransomware-2024-5708 — Mass File Rename (apt73)
// Status: experimental | Level: high | ID: 7d09d63f-12ad-56be-b384-96168c987936

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
