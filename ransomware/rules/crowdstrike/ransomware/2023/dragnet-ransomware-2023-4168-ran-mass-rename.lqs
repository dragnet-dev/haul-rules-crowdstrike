// Dragnet [Ransomware]: dragnet-ransomware-2023-4168 — Mass File Rename (noescape)
// Status: experimental | Level: high | ID: 74674d33-d348-5ee7-8d6d-beaa5ee27c06

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
