// Dragnet [Ransomware]: dragnet-ransomware-2024-1344 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 5c6171c7-8518-54d1-b582-f37395d5d8ae

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
