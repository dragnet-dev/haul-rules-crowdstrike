// Dragnet [Ransomware]: dragnet-ransomware-2025-6270 — Mass File Rename (payoutsking)
// Status: experimental | Level: high | ID: 11ee3503-b4c0-5f1f-b24a-dc9d96e09396

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
