// Dragnet [Ransomware]: dragnet-ransomware-2024-1111 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: cbee16ae-9540-5fe1-93d0-825c2ed8aab1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
