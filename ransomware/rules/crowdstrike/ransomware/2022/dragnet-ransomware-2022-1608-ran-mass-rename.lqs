// Dragnet [Ransomware]: dragnet-ransomware-2022-1608 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: b136a503-b04f-5614-84b5-a32e5f131507

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
