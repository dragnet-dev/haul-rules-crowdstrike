// Dragnet [Ransomware]: dragnet-ransomware-2025-2236 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 92415f81-d69a-519a-8679-b8a48b32316b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
