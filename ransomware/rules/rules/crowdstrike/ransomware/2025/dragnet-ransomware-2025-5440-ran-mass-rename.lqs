// Dragnet [Ransomware]: dragnet-ransomware-2025-5440 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: df8b12d2-b23c-5c6f-a306-88afc6d55f7c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
