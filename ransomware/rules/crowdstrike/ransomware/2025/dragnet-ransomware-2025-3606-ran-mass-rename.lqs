// Dragnet [Ransomware]: dragnet-ransomware-2025-3606 — Mass File Rename (beast)
// Status: experimental | Level: high | ID: bcb8c274-92d6-5217-9245-5b20ba8d2fe1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
