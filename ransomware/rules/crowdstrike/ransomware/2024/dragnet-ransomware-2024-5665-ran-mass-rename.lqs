// Dragnet [Ransomware]: dragnet-ransomware-2024-5665 — Mass File Rename (redransomware)
// Status: deprecated | Level: high | ID: 73de85e9-f386-50db-9fba-57769ced244a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
