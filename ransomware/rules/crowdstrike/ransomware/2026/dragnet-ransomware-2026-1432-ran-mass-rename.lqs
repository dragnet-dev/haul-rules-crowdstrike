// Dragnet [Ransomware]: dragnet-ransomware-2026-1432 — Mass File Rename (nightspire)
// Status: deprecated | Level: high | ID: 22f9834d-ade3-508a-9985-ad686fd67388

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
