// Dragnet [Ransomware]: dragnet-ransomware-2025-2997 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 7d01edfc-08fd-5031-83e2-7ffcacf75f5d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
