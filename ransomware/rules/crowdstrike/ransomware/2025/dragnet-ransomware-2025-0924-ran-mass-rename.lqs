// Dragnet [Ransomware]: dragnet-ransomware-2025-0924 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 6d8084de-ba26-5a72-9e4b-554551a8528c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
