// Dragnet [Ransomware]: dragnet-ransomware-2025-4755 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 04329f02-5942-5b69-b497-d08f66f82004

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
