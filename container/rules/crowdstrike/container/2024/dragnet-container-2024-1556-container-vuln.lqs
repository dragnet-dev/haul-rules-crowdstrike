// Dragnet [Container]: dragnet-container-2024-1556 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 5191359d-6665-5973-ae7b-51b70c31408b

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:7*)
| table([timestamp, ComputerName])
| limit(1000)
