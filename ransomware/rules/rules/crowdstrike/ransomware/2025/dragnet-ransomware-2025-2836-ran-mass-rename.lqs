// Dragnet [Ransomware]: dragnet-ransomware-2025-2836 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: ec48bf00-9c26-564e-b297-4916f6b8ecc5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
