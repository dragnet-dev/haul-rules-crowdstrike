// Dragnet [Ransomware]: dragnet-ransomware-2021-0026 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 370852be-f807-5e41-b08d-46dd8ee0cee5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
