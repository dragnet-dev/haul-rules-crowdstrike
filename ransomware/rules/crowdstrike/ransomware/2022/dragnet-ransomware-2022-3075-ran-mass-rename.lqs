// Dragnet [Ransomware]: dragnet-ransomware-2022-3075 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 957d2b16-2497-5563-8596-dd6609608139

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
