// Dragnet [Ransomware]: dragnet-ransomware-2024-0677 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: ceac6d0c-c325-5dd0-a39a-74acce94549a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
