// Dragnet [Ransomware]: dragnet-ransomware-2020-0193 — Mass File Rename (hades)
// Status: deprecated | Level: high | ID: 938555e2-fcef-553a-ad77-d56039cc5710

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
