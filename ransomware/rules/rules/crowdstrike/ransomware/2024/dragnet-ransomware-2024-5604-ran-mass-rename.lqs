// Dragnet [Ransomware]: dragnet-ransomware-2024-5604 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 766c405f-8e9d-5756-ac39-15b769ef4081

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
