// Dragnet [Ransomware]: dragnet-ransomware-2025-6524 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: b370453e-f40e-55a2-96fc-1b8f5b1883f7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
