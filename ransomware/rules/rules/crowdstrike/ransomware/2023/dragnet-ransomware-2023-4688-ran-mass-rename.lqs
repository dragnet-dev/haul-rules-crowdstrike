// Dragnet [Ransomware]: dragnet-ransomware-2023-4688 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 84b954af-8d10-5901-9eb2-9ed954efbfaf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
