// Dragnet [Ransomware]: dragnet-ransomware-2025-2142 — Mass File Rename (worldleaks)
// Status: experimental | Level: high | ID: 6bd49762-356e-55f4-a62c-bafe7d05c48a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
