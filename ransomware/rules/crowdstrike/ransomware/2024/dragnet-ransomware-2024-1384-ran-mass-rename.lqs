// Dragnet [Ransomware]: dragnet-ransomware-2024-1384 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 49849bb6-5bfe-5e5c-a03c-3f98af7b252f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
