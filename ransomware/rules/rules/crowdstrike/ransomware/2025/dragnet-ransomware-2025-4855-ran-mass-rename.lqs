// Dragnet [Ransomware]: dragnet-ransomware-2025-4855 — Mass File Rename (IMNCrew)
// Status: experimental | Level: high | ID: 66b873d4-8940-52e1-b905-21b9ddbd1712

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
