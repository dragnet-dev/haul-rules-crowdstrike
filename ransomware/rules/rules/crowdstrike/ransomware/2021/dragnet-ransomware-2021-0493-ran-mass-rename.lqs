// Dragnet [Ransomware]: dragnet-ransomware-2021-0493 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 5f5a4afb-01cc-5c6f-a50b-af32b3965944

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
