// Dragnet [Ransomware]: dragnet-ransomware-2025-0781 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 17c4e063-e5e4-5f8a-9edd-732b69454dd9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
