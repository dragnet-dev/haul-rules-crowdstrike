// Dragnet [Ransomware]: dragnet-ransomware-2024-2172 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 3ee9958b-5529-52b0-abc1-a044e152efe9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
