// Dragnet [Ransomware]: dragnet-ransomware-2025-3504 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 8e469a78-9f0f-5f16-9819-2d2fb5e8640d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
