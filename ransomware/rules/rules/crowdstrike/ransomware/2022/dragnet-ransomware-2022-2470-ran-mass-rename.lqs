// Dragnet [Ransomware]: dragnet-ransomware-2022-2470 — Mass File Rename (everest)
// Status: deprecated | Level: high | ID: a57ec344-0a3a-5390-98b4-9432c833b594

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
