// Dragnet [Ransomware]: dragnet-ransomware-2022-0793 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 2e562d01-9857-51ae-87e7-f86d226b2ffd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
