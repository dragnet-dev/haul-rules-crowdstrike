// Dragnet [Ransomware]: dragnet-ransomware-2023-3909 — Mass File Rename (royal)
// Status: deprecated | Level: high | ID: 8c018cf4-84f8-5d6e-916e-1da3aaa15ae6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
