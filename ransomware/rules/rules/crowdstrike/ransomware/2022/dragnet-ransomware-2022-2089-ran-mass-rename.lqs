// Dragnet [Ransomware]: dragnet-ransomware-2022-2089 — Mass File Rename (play)
// Status: deprecated | Level: high | ID: 321957a4-dcc5-530c-b70c-021c2d6dc6aa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
