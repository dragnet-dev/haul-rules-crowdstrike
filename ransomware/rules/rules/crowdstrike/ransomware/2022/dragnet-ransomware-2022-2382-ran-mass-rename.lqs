// Dragnet [Ransomware]: dragnet-ransomware-2022-2382 — Mass File Rename (blackbasta)
// Status: deprecated | Level: high | ID: 82884ea7-0ae6-5505-90ec-2af29948d20b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
