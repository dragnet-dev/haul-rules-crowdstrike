// Dragnet [Ransomware]: dragnet-ransomware-2023-5356 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: a66b9952-1136-5874-861f-d785e76ee68e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
