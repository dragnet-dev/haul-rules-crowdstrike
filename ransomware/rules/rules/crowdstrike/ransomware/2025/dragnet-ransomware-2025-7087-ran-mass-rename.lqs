// Dragnet [Ransomware]: dragnet-ransomware-2025-7087 — Mass File Rename (worldleaks)
// Status: test | Level: high | ID: 87b6876e-ab50-5f93-84bc-f3f0dce2c93d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
