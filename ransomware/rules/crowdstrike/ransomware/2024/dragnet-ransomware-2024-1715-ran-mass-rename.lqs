// Dragnet [Ransomware]: dragnet-ransomware-2024-1715 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 3e6297db-2856-54cc-8849-b8a2d22c7c1d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
