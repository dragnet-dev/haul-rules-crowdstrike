// Dragnet [Ransomware]: dragnet-ransomware-2021-1152 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: f5c71ea7-5baa-5f37-b3f6-5299d8eef655

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
