// Dragnet [Ransomware]: dragnet-ransomware-2021-0578 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: b031031a-4adf-50f0-b610-7de3a15a088d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
