// Dragnet [Container]: dragnet-container-2026-0447 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 9c8043cb-482f-56c3-9705-e25ab7d3de58

#event_simpleName=*
| (ImageFileName = *oraclelinux:6* OR ImageFileName = *photon os:4.0* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10*)
| table([timestamp, ComputerName])
| limit(1000)
