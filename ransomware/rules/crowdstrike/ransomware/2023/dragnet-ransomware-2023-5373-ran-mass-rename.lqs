// Dragnet [Ransomware]: dragnet-ransomware-2023-5373 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 582fc2fc-3190-5aff-9e0a-c4074ff51db6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
