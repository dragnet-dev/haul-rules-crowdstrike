// Dragnet [Ransomware]: dragnet-ransomware-2022-1735 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 814a0f67-60da-560a-bcec-40ac27ea0943

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
