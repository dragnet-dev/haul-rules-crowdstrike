// Dragnet [Ransomware]: dragnet-ransomware-2023-5368 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: ba5b0fc3-b04d-5d1b-8763-ae046359c248

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
