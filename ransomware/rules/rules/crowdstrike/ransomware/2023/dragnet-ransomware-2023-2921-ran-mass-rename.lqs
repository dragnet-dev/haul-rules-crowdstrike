// Dragnet [Ransomware]: dragnet-ransomware-2023-2921 — Mass File Rename (play)
// Status: experimental | Level: high | ID: ba9627cf-e7bc-5dce-a5be-0ac3c5ff0bd5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
