// Dragnet [Ransomware]: dragnet-ransomware-2022-1659 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 53182f7f-2600-5669-9ceb-3a0a1544a70b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
