// Dragnet [Ransomware]: dragnet-ransomware-2024-0164 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: c11343fb-d312-57ee-ad80-b013a0e910db

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
