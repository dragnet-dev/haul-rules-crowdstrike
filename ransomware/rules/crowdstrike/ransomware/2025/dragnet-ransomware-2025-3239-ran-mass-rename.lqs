// Dragnet [Ransomware]: dragnet-ransomware-2025-3239 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 3066a165-00f1-58bb-960d-4941c957174b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
