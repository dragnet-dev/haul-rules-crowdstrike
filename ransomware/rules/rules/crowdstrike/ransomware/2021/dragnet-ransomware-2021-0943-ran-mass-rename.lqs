// Dragnet [Ransomware]: dragnet-ransomware-2021-0943 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 1660e557-8e8e-5f35-8557-4a420ffbed31

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
