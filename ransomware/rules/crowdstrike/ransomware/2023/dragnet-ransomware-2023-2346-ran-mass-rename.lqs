// Dragnet [Ransomware]: dragnet-ransomware-2023-2346 — Mass File Rename (stormous)
// Status: deprecated | Level: high | ID: fcb5f854-7fbe-56e4-8f37-4807070f81e6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
