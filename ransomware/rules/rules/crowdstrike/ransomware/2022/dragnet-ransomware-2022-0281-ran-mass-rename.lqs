// Dragnet [Ransomware]: dragnet-ransomware-2022-0281 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: ceb8a89f-09ca-5711-a3f9-bc3cb513dae3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
