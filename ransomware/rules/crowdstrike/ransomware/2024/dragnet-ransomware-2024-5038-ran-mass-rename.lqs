// Dragnet [Ransomware]: dragnet-ransomware-2024-5038 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: 15115b29-fbb0-5a5d-9b9a-12317bd7b7f0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
