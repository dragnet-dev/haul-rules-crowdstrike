// Dragnet [Ransomware]: dragnet-ransomware-2024-5957 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: defe6990-4a5a-56e7-91e8-8a7ca95a4edb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
