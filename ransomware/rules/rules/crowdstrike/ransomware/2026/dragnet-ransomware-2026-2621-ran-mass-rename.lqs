// Dragnet [Ransomware]: dragnet-ransomware-2026-2621 — Mass File Rename (lockbit5)
// Status: stable | Level: high | ID: f83c590b-62ff-56c0-a24e-0f0bf75dfc34

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
