// Dragnet [Ransomware]: dragnet-ransomware-2025-3958 — Mass File Rename (tridentlocker)
// Status: experimental | Level: high | ID: 8e0dd3d6-b9ef-5ab4-9a5b-268536114ea8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
