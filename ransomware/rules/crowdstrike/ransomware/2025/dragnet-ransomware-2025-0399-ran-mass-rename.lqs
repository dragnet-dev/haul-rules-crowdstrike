// Dragnet [Ransomware]: dragnet-ransomware-2025-0399 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 4cea630c-0678-565b-a1a9-b11bab9c89a5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
