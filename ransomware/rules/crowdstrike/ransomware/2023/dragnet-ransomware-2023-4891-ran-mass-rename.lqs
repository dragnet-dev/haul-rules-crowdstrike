// Dragnet [Ransomware]: dragnet-ransomware-2023-4891 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: 2292772d-e6e2-56d1-9a26-fe912a05a929

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
