// Dragnet [Ransomware]: dragnet-ransomware-2025-3720 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 93b5b2cd-5ecf-5718-8ad2-47d95503ddac

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
