// Dragnet [Ransomware]: dragnet-ransomware-2024-3790 — Mass File Rename (arcusmedia)
// Status: experimental | Level: high | ID: e10ef04e-ecee-565b-ad0d-618894ff852b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
