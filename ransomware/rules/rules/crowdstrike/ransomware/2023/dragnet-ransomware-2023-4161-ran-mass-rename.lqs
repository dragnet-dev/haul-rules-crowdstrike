// Dragnet [Ransomware]: dragnet-ransomware-2023-4161 — Mass File Rename (rhysida)
// Status: deprecated | Level: high | ID: d58a4146-0592-540b-87bb-41b3f5dabcc7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
