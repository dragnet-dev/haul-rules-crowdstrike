// Dragnet [Ransomware]: dragnet-ransomware-2025-2417 — Mass File Rename (thegentlemen)
// Status: experimental | Level: high | ID: 77ef0052-38f1-5b92-97e2-112d7eaaa64a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
