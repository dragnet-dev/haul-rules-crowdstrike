// Dragnet [Ransomware]: dragnet-ransomware-2025-4729 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 48ba82da-51c5-5618-ad5e-900f4405dbbc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
