// Dragnet [Ransomware]: dragnet-ransomware-2025-4829 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 09933a98-4a05-5935-8e7b-ddc19d4d7d9d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
