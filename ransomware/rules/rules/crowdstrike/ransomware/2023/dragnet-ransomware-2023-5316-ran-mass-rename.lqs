// Dragnet [Ransomware]: dragnet-ransomware-2023-5316 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 69b75744-063a-5255-827c-adf5f7b2f473

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
