// Dragnet [Ransomware]: dragnet-ransomware-2024-4567 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 7401ce9f-4756-5559-8b8c-9ff7c6d6f4a2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
