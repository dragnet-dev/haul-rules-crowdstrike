// Dragnet [Ransomware]: dragnet-ransomware-2023-2073 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: 85762b22-8f64-598c-86c7-8540164e7703

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
