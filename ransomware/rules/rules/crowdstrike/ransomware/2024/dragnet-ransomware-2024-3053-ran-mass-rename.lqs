// Dragnet [Ransomware]: dragnet-ransomware-2024-3053 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: ba5ec61d-cc87-5f2c-a7c2-a8b15cdc1d63

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
