// Dragnet [Ransomware]: dragnet-ransomware-2021-0976 — Mass File Rename (lv)
// Status: deprecated | Level: high | ID: 9903760d-787d-53ed-a8b8-2ee5e9d46225

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
