// Dragnet [Ransomware]: dragnet-ransomware-2025-7903 — Mass File Rename (global)
// Status: deprecated | Level: high | ID: e066b356-b1fd-530c-ad09-2ffd3ec66840

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
