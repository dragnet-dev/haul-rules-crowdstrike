// Dragnet [Ransomware]: dragnet-ransomware-2025-0911 — Mass File Rename (arcusmedia)
// Status: experimental | Level: high | ID: 997a10af-4d49-5121-a4b7-4a31e4fda4dd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
