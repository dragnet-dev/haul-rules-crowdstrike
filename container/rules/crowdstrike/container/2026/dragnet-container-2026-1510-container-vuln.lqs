// Dragnet [Container]: dragnet-container-2026-1510 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: eaaa16ed-b531-5c7c-b8df-0f6b701d7ad4

#event_simpleName=*
| (ImageFileName = *amazonlinux:1* OR ImageFileName = *chainguard:* OR ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *ubuntu:12.04*)
| table([timestamp, ComputerName])
| limit(1000)
