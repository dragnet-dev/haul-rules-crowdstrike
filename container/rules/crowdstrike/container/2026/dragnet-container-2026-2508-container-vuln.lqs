// Dragnet [Container]: dragnet-container-2026-2508 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 92b15337-7f31-5c5d-a225-ea058b5289c7

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:5*)
| table([timestamp, ComputerName])
| limit(1000)
