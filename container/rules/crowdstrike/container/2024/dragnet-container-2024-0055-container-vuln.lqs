// Dragnet [Container]: dragnet-container-2024-0055 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 29db495e-a1a6-5853-a155-a94ced620401

#event_simpleName=*
| (ImageFileName = *cbl-mariner:1.0* OR ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:9* OR ImageFileName = *photon os:1.0* OR ImageFileName = *photon os:2.0* OR ImageFileName = *photon os:3.0* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:18.04-ESM* OR ImageFileName = *ubuntu:20.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
