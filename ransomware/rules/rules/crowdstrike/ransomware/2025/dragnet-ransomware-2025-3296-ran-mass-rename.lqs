// Dragnet [Ransomware]: dragnet-ransomware-2025-3296 — Mass File Rename (nightspire)
// Status: deprecated | Level: high | ID: c9cf32f1-1ed6-5c1c-9a75-edda99652481

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
