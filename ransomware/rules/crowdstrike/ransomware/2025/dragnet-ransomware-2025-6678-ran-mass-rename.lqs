// Dragnet [Ransomware]: dragnet-ransomware-2025-6678 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 3cfcfb29-96e3-5861-b608-b4ed6adc943a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
