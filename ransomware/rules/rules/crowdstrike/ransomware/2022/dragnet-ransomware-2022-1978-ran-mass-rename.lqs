// Dragnet [Ransomware]: dragnet-ransomware-2022-1978 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 74c10ccf-b8ed-5cd6-81fc-348d2117ef72

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
