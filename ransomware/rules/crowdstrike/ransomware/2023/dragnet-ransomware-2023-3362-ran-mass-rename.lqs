// Dragnet [Ransomware]: dragnet-ransomware-2023-3362 — Mass File Rename (raworld)
// Status: experimental | Level: high | ID: be188d8f-8832-59a5-94e9-093c2637007d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
