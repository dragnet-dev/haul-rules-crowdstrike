// Dragnet [Ransomware]: dragnet-ransomware-2025-3809 — Mass File Rename (datacarry)
// Status: deprecated | Level: high | ID: 51634d96-b730-5fd1-b086-6e1a8ed29b85

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
