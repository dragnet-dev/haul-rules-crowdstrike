// Dragnet [Container]: dragnet-container-2026-0445 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: db557e46-740a-545d-83c9-85e7ebf7e45f

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:5*)
| table([timestamp, ComputerName])
| limit(1000)
