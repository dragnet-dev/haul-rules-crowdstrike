// Dragnet [Ransomware]: dragnet-ransomware-2021-0262 — Mass File Rename (darkleakmarket)
// Status: deprecated | Level: high | ID: 8c257c5b-6e43-5ebc-8ff3-92e1de616f7e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
