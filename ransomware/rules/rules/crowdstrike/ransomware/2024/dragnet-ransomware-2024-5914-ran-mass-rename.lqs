// Dragnet [Ransomware]: dragnet-ransomware-2024-5914 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 53754f28-5771-57fa-9f3d-a68ed580fd5b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
