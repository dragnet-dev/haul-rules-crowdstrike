// Dragnet [Ransomware]: dragnet-ransomware-2024-3226 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: 0cd07e8d-e825-537f-a9df-1161f267f176

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
