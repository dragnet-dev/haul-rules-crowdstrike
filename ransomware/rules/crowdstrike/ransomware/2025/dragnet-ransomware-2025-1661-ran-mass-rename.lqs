// Dragnet [Ransomware]: dragnet-ransomware-2025-1661 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: 9407ff2e-a3fb-57e5-b3f7-cf344b42de40

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
