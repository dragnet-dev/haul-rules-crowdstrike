// Dragnet [Ransomware]: dragnet-ransomware-2025-6995 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 9fa3a8dd-9633-5536-9982-76fb701e2377

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
