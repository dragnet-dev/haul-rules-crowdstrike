// Dragnet [Ransomware]: dragnet-ransomware-2025-7355 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 71b808c4-3783-5b7a-a5e3-466b5876a1ea

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
