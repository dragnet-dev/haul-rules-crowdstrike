// Dragnet [Ransomware]: dragnet-ransomware-2025-4214 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 8c3b5fe1-6f7d-51f5-9779-4b83d292b68e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
