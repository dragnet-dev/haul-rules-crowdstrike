// Dragnet [Ransomware]: dragnet-ransomware-2024-4444 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 596e27dc-e9d9-53f2-a0c1-06f207763817

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
