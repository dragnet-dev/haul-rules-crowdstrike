// Dragnet [Ransomware]: dragnet-ransomware-2024-1630 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 999bef0a-c150-5d46-b6b5-73cfbb889391

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
