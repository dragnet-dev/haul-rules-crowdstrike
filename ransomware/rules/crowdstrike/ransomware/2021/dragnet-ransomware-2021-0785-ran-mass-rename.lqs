// Dragnet [Ransomware]: dragnet-ransomware-2021-0785 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: e0bd6bc9-20f8-57ca-9854-ec9bc3639ef9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
