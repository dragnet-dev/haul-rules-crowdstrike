// Dragnet [Ransomware]: dragnet-ransomware-2024-0492 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 78a48a07-8cb6-5cb9-bee0-6f2163a39c1e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
