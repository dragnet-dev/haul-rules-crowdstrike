// Dragnet [Ransomware]: dragnet-ransomware-2025-0467 — Mass File Rename (obscura)
// Status: experimental | Level: high | ID: f603557c-b5fe-5a8f-b60a-12577e610559

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
