// Dragnet [Ransomware]: dragnet-ransomware-2024-0174 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: 22c47b31-ce44-5dba-b7fd-40e729760fd0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
