// Dragnet [Ransomware]: dragnet-ransomware-2026-2552 — Mass File Rename (krybit)
// Status: stable | Level: high | ID: 36e09055-0c91-5ce5-a031-ac326744a906

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
