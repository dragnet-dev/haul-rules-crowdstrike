// Dragnet [Ransomware]: dragnet-ransomware-2023-2336 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 26ec0bdb-f147-5821-b035-9f055af52a37

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
