// Dragnet [Ransomware]: dragnet-ransomware-2024-2950 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 9ad76507-c8ca-5ea7-9948-886673513b6e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
