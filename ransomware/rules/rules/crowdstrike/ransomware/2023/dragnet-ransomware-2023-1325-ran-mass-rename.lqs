// Dragnet [Ransomware]: dragnet-ransomware-2023-1325 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 2386ce50-3f01-5778-8453-493375586931

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
