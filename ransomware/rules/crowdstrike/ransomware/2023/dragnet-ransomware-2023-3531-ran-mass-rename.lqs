// Dragnet [Ransomware]: dragnet-ransomware-2023-3531 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 94f6b41d-c7b3-5037-a149-4b31472c0fb3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
