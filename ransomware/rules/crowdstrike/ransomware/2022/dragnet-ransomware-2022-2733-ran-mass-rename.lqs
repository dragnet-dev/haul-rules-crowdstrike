// Dragnet [Ransomware]: dragnet-ransomware-2022-2733 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: c5ea3d8e-60d1-57ae-be5f-941de1b7bff0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
