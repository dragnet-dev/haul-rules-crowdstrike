// Dragnet [Ransomware]: dragnet-ransomware-2026-1628 — Mass File Rename (dragonforce)
// Status: stable | Level: high | ID: 7304e9fb-66fe-5709-a3c4-8c5e4401b0f8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
