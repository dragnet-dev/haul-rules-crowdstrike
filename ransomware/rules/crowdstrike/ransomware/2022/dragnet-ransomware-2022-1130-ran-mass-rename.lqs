// Dragnet [Ransomware]: dragnet-ransomware-2022-1130 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: fd39917a-a5f3-50db-b234-bb813cf55e42

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
