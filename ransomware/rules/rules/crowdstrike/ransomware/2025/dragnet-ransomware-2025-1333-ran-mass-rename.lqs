// Dragnet [Ransomware]: dragnet-ransomware-2025-1333 — Mass File Rename (blackshrantac)
// Status: test | Level: high | ID: faf178dd-da3a-5487-9cca-409ecf326bc8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
