// Dragnet [Ransomware]: dragnet-ransomware-2021-0848 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: b8afd53a-1ce5-5742-b2ed-8c4df1231d3c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
