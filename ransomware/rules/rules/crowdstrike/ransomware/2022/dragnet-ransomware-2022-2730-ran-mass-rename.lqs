// Dragnet [Ransomware]: dragnet-ransomware-2022-2730 — Mass File Rename (karakurt)
// Status: deprecated | Level: high | ID: fe00419e-3c60-520c-93bf-4c355d8b3a08

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
