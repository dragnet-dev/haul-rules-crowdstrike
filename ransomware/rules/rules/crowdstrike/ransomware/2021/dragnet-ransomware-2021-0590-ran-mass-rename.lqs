// Dragnet [Ransomware]: dragnet-ransomware-2021-0590 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: b2f29449-e022-5542-8b67-33fe5253d2cc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
