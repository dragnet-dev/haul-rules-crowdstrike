// Dragnet [Ransomware]: dragnet-ransomware-2024-0295 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: cc4cebf4-4871-5c1f-b266-3f9a736fd6f3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
