// Dragnet [Ransomware]: dragnet-ransomware-2025-3128 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: d6d8e79a-90f3-56ff-8117-b36febfadbb1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
