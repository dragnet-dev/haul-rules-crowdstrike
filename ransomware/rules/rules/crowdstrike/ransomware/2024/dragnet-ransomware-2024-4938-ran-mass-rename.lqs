// Dragnet [Ransomware]: dragnet-ransomware-2024-4938 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: b5aba506-4590-5dff-971a-11e74f95f980

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
