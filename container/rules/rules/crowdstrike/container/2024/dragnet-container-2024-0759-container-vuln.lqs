// Status: deprecated | Level: critical | ID: 6d9be5fe-227a-5160-a9f0-d75f3515e96a

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *ubuntu:18.04-ESM*)
