// Dragnet [Ransomware]: dragnet-ransomware-2024-1148 — Mass File Rename (ransomhouse)
// Status: experimental | Level: high | ID: 329b6774-fa4b-515e-8e0f-ff73e1c4dc1d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
