// Dragnet [Ransomware]: dragnet-ransomware-2024-1596 — Mass File Rename (stormous)
// Status: deprecated | Level: high | ID: 7a781656-8222-5ad6-bc69-863b95ff5f27

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
