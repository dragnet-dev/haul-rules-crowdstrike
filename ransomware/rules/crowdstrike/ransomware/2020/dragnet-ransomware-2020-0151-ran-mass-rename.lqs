// Dragnet [Ransomware]: dragnet-ransomware-2020-0151 — Mass File Rename (revil)
// Status: deprecated | Level: high | ID: cb71bb61-7d66-5e8e-8058-8962a7ff1544

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
