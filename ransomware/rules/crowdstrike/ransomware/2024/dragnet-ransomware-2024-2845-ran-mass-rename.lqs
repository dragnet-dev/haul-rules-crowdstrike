// Dragnet [Ransomware]: dragnet-ransomware-2024-2845 — Mass File Rename (meow)
// Status: experimental | Level: high | ID: 540677a5-1c3c-55bd-987a-cc3d04831f33

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
