// Dragnet [Ransomware]: dragnet-ransomware-2022-0290 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 76d6f46c-3137-5663-a710-a8a48752b99b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
