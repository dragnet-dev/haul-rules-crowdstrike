// Dragnet [Ransomware]: dragnet-ransomware-2023-0533 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 1aee3b28-9f5f-511c-83f9-e98a36577672

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
