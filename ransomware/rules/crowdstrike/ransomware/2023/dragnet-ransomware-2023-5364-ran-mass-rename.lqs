// Dragnet [Ransomware]: dragnet-ransomware-2023-5364 — Mass File Rename (ransomexx)
// Status: experimental | Level: high | ID: 3dd5231b-f81a-5e48-9d96-10704e32ffc0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
