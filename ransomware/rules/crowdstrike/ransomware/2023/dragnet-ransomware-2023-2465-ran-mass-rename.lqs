// Dragnet [Ransomware]: dragnet-ransomware-2023-2465 — Mass File Rename (noescape)
// Status: experimental | Level: high | ID: b7eb6672-0992-5285-81ef-59a341c2971f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
