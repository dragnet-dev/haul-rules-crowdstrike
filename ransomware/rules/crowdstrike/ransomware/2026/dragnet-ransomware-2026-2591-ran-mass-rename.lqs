// Dragnet [Ransomware]: dragnet-ransomware-2026-2591 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: e81381b8-bc83-5de8-8620-2115ec252133

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
