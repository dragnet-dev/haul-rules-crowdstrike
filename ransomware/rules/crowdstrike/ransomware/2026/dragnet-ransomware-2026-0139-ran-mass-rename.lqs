// Dragnet [Ransomware]: dragnet-ransomware-2026-0139 — Mass File Rename (nightspire)
// Status: deprecated | Level: high | ID: 3869e581-f52d-5989-91f7-a7e618fcd93c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
