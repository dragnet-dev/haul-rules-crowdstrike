// Dragnet [Ransomware]: dragnet-ransomware-2024-5085 — Mass File Rename (meow)
// Status: experimental | Level: high | ID: 8166d598-4007-5c81-a892-780c706aa513

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
