// Dragnet [Ransomware]: dragnet-ransomware-2024-4818 — Mass File Rename (raworld)
// Status: experimental | Level: high | ID: 219519fd-c123-54bc-b085-e1b705ffe956

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
