// Dragnet [Ransomware]: dragnet-ransomware-2025-1883 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 98d2391e-324c-509f-8e22-80344d97a445

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
