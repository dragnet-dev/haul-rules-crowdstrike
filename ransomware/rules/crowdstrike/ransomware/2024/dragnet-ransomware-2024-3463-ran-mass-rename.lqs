// Dragnet [Ransomware]: dragnet-ransomware-2024-3463 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: 5aac77ad-b018-5595-8f5f-a41ed7ab8c87

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
