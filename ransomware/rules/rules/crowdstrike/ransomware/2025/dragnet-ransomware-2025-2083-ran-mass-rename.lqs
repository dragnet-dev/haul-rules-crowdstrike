// Dragnet [Ransomware]: dragnet-ransomware-2025-2083 — Mass File Rename (dragonforce)
// Status: test | Level: high | ID: 1740eeea-6689-5e91-8453-72df193863f6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
