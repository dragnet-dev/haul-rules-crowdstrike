// Dragnet [Container]: dragnet-container-2026-0243 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: a84c5a3e-2083-577e-93ce-0e55cfe44d4c

#event_simpleName=*
| (ImageFileName = *debian:9* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:16.04-ESM* OR ImageFileName = *ubuntu:18.04* OR ImageFileName = *ubuntu:18.04-ESM* OR ImageFileName = *ubuntu:20.04* OR ImageFileName = *ubuntu:20.04-ESM* OR ImageFileName = *ubuntu:21.10*)
| table([timestamp, ComputerName])
| limit(1000)
