// Dragnet [Ransomware]: dragnet-ransomware-2024-3659 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 6fea98ab-70d3-553c-9f62-524a5b7f86cf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
