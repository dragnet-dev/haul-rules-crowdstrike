// Dragnet [Ransomware]: dragnet-ransomware-2024-4204 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: cf15d98f-cf7a-5fb3-aa06-8377d7443ec1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
