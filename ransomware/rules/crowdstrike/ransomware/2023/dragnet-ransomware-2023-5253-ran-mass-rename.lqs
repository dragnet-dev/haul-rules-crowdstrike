// Dragnet [Ransomware]: dragnet-ransomware-2023-5253 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 45e517e4-42be-507f-9fa4-2ddd8a9fbd3f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
