// Dragnet [Ransomware]: dragnet-ransomware-2025-0033 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: e2afe262-153a-55cb-85c9-48d7eeb1d320

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
