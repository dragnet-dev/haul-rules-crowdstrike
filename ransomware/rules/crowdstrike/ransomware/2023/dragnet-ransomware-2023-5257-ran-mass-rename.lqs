// Dragnet [Ransomware]: dragnet-ransomware-2023-5257 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 0b224e49-b9db-5f13-9b56-9049eddd3eb9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
