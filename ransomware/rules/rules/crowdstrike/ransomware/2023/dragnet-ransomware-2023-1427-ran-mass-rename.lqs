// Dragnet [Ransomware]: dragnet-ransomware-2023-1427 — Mass File Rename (losttrust)
// Status: deprecated | Level: high | ID: d8854454-672b-5290-8051-45f4927fb52f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
