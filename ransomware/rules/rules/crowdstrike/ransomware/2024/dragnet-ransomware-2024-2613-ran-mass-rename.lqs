// Dragnet [Ransomware]: dragnet-ransomware-2024-2613 — Mass File Rename (frag)
// Status: deprecated | Level: high | ID: 5ffed1d7-9810-578d-8e6d-59fdc1699370

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
