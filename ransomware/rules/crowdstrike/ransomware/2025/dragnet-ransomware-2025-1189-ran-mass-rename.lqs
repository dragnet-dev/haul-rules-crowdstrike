// Dragnet [Ransomware]: dragnet-ransomware-2025-1189 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: 7629ab73-b4bd-52fd-b074-a3ae164008d9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
