// Dragnet [Ransomware]: dragnet-ransomware-2025-4623 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: 683a99b5-daf1-538c-86ab-5e830b4bbd2a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
