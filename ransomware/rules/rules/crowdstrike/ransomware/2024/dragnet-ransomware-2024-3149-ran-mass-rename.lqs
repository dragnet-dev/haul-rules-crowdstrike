// Dragnet [Ransomware]: dragnet-ransomware-2024-3149 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: f89f24f8-d020-5d8d-9d88-d0cf90e06c92

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
