// Dragnet [Ransomware]: dragnet-ransomware-2025-0937 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 48703a59-df7a-5262-abf7-d57976a628d0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
