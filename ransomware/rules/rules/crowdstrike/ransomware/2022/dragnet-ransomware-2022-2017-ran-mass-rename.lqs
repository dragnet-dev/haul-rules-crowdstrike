// Dragnet [Ransomware]: dragnet-ransomware-2022-2017 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 468d655d-f298-505a-907e-d6f2bfd1ee75

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
