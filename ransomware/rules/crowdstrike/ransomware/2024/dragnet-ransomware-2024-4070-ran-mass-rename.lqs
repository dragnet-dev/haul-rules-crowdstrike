// Dragnet [Ransomware]: dragnet-ransomware-2024-4070 — Mass File Rename (insane)
// Status: experimental | Level: high | ID: 18382f8c-38bf-5774-929d-9a90a88599bb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
