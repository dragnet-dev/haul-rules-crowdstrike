// Dragnet [Ransomware]: dragnet-ransomware-2024-1553 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: fd3d9b8c-fc88-5afa-bcb1-03ba896e9a9d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
