// Dragnet [Ransomware]: dragnet-ransomware-2025-1830 — Mass File Rename (play)
// Status: experimental | Level: high | ID: ab81110b-1051-55cc-8470-5a2c6383a22c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
