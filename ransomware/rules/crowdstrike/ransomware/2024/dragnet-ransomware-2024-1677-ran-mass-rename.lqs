// Dragnet [Ransomware]: dragnet-ransomware-2024-1677 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 8eabdaac-3d7b-587c-a568-35b80d9f415d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
