// Dragnet [Ransomware]: dragnet-ransomware-2024-0840 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 48498257-fa32-5f0e-9f59-95d658841b88

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
