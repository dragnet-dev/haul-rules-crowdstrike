// Dragnet [Ransomware]: dragnet-ransomware-2025-0456 — Mass File Rename (nightspire)
// Status: deprecated | Level: high | ID: 069a4683-4c3e-5501-9452-5486f3b09ae3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
