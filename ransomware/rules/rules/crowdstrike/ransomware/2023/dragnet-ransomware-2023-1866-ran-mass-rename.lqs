// Dragnet [Ransomware]: dragnet-ransomware-2023-1866 — Mass File Rename (trigona)
// Status: deprecated | Level: high | ID: 6ee3a489-50f7-557f-bde9-eab790cde47c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
