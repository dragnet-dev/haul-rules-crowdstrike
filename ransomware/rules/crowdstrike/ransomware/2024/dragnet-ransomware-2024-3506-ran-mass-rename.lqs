// Dragnet [Ransomware]: dragnet-ransomware-2024-3506 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 082d340d-9270-5817-a6a2-ebd160099d8a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
