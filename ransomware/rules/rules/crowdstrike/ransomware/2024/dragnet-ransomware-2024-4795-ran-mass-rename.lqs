// Dragnet [Ransomware]: dragnet-ransomware-2024-4795 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 5470b37d-1b18-56ef-a18f-0ce9b1207ce0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
