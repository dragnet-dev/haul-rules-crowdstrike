// Dragnet [Ransomware]: dragnet-ransomware-2025-2861 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 0c236893-9695-5b25-94cf-ee4053ffd838

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
