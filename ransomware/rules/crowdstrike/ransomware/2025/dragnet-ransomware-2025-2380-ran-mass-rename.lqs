// Dragnet [Ransomware]: dragnet-ransomware-2025-2380 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: b0d0ec83-29c8-56a5-8200-9a44f17c44f8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
