// Dragnet [Ransomware]: dragnet-ransomware-2023-2140 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 90d10784-b22d-5ce2-b575-8c5c5189c9cc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
