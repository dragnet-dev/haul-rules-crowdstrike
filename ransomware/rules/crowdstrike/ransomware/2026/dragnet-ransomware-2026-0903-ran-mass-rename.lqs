// Dragnet [Ransomware]: dragnet-ransomware-2026-0903 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: c73c88f5-e75f-56bc-a3c9-50f4c1c0cadb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
