// Dragnet [Ransomware]: dragnet-ransomware-2023-4753 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: e9c49008-d76d-5ab3-a4ba-255bc8744aeb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
