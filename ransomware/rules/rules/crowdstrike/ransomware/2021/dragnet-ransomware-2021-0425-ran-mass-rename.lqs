// Dragnet [Ransomware]: dragnet-ransomware-2021-0425 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 7300f589-e2d4-5d1a-94a9-a340c3c39dd4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
