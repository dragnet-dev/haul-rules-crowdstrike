// Dragnet [Ransomware]: dragnet-ransomware-2025-2088 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 5d293c05-a9d7-5d60-9907-7d8583ecd33d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
