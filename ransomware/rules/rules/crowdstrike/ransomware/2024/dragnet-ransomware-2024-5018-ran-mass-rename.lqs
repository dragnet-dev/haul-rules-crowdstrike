// Dragnet [Ransomware]: dragnet-ransomware-2024-5018 — Mass File Rename (ciphbit)
// Status: deprecated | Level: high | ID: 39afc647-b0e2-53ba-a978-2b28d3e732d7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
