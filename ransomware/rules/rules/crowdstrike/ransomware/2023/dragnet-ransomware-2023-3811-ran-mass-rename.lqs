// Dragnet [Ransomware]: dragnet-ransomware-2023-3811 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 96f4a2b4-8e37-52b4-8595-061df822069b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
