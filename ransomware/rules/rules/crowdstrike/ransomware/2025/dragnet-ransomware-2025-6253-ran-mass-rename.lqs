// Dragnet [Ransomware]: dragnet-ransomware-2025-6253 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: fd9e900a-a0e0-50de-9460-064730bdb10f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
