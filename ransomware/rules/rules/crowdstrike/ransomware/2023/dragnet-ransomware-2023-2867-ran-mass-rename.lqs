// Dragnet [Ransomware]: dragnet-ransomware-2023-2867 — Mass File Rename (malas)
// Status: experimental | Level: high | ID: 74f55552-5902-586e-94c5-dc869b1c90e8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
