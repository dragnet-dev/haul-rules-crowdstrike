// Dragnet [Ransomware]: dragnet-ransomware-2024-5860 — Mass File Rename (monti)
// Status: experimental | Level: high | ID: 8adbf50e-6343-54d7-91d2-d777dbcc39f3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
