// Dragnet [Ransomware]: dragnet-ransomware-2024-0966 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 22db32c4-f8b8-525f-9051-bc756fb9acc0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
