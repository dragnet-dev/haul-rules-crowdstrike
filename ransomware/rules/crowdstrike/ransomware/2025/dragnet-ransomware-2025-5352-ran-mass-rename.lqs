// Dragnet [Ransomware]: dragnet-ransomware-2025-5352 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 62e5d5e2-25f0-5fec-a764-e8871480e12b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
