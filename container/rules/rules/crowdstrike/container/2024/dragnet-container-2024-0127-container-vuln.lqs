// Dragnet [Container]: dragnet-container-2024-0127 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 12d72e9b-bd8a-5595-b668-67778361c657

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
