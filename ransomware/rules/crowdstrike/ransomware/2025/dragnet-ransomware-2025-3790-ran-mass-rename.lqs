// Dragnet [Ransomware]: dragnet-ransomware-2025-3790 — Mass File Rename (worldleaks)
// Status: experimental | Level: high | ID: d07423ca-47ac-5b3a-a640-7688263ac2c5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
