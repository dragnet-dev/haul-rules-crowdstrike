// Dragnet [Ransomware]: dragnet-ransomware-2023-4893 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 585feeac-4ac2-5c40-8019-3c57f3b60ebe

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
