// Dragnet [Ransomware]: dragnet-ransomware-2023-2329 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 48ea2467-3a18-5d62-8d16-0f5a224990d6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
