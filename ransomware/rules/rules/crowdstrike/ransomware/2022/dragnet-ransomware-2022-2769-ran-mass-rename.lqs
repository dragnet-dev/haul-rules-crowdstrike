// Dragnet [Ransomware]: dragnet-ransomware-2022-2769 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: f6fe788c-32ef-5d85-8c02-aac6bfeb91cb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
