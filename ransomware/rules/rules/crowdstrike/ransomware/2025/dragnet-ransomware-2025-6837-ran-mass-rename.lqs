// Dragnet [Ransomware]: dragnet-ransomware-2025-6837 — Mass File Rename (play)
// Status: experimental | Level: high | ID: ccd9bbfd-670e-5a24-9e7d-05ebe91d90e1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
