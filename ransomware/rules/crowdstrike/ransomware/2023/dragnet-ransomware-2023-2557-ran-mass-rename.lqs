// Dragnet [Ransomware]: dragnet-ransomware-2023-2557 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 0935180e-c233-586a-9dc6-6805fa4968c0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
