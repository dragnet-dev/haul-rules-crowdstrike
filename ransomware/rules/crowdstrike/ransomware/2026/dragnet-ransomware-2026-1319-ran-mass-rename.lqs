// Dragnet [Ransomware]: dragnet-ransomware-2026-1319 — Mass File Rename (worldleaks)
// Status: stable | Level: high | ID: c4cc93a3-b39d-587b-be1f-6a4e140cd90d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
