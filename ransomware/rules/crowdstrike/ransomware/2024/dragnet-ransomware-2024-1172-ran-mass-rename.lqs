// Dragnet [Ransomware]: dragnet-ransomware-2024-1172 — Mass File Rename (raworld)
// Status: experimental | Level: high | ID: f52cfa8d-b304-5cc3-9f07-80caa0b463e8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
