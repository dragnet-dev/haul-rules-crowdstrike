// Dragnet [Ransomware]: dragnet-ransomware-2022-0322 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 7349104f-0eb2-5fcd-bc5e-4bce724b782e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
