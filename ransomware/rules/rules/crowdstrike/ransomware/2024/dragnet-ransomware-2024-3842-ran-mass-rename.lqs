// Dragnet [Ransomware]: dragnet-ransomware-2024-3842 — Mass File Rename (donutleaks)
// Status: experimental | Level: high | ID: 3e9eeb80-837c-54a8-9e1f-f111d66e5c63

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
