// Dragnet [Ransomware]: dragnet-ransomware-2024-1443 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: df42939e-f4c3-5c9d-9e11-a4646ae6299b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
