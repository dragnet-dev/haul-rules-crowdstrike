// Dragnet [Ransomware]: dragnet-ransomware-2024-2114 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 78e84047-1e9e-5222-8396-b8907d9ff56b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
