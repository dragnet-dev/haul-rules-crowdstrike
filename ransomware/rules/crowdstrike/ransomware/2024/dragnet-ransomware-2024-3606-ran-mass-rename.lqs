// Dragnet [Ransomware]: dragnet-ransomware-2024-3606 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 5710a467-bded-581e-801b-26826a66bc57

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
