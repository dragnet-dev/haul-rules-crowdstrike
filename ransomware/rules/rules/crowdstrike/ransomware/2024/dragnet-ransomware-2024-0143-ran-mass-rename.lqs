// Dragnet [Ransomware]: dragnet-ransomware-2024-0143 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 4f8c7c03-7d73-572c-9c0c-d1845fbe8da8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
