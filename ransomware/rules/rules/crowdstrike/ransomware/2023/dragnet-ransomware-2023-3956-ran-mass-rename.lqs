// Dragnet [Ransomware]: dragnet-ransomware-2023-3956 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 11be1b6d-8c30-594a-84f7-7e9bc4d0363c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
