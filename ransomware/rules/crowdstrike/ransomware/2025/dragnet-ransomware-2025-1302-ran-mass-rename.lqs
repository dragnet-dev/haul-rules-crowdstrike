// Dragnet [Ransomware]: dragnet-ransomware-2025-1302 — Mass File Rename (dragonforce)
// Status: test | Level: high | ID: 9a8938a1-0a00-5bbc-969d-ea138ba99e0c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
