// Dragnet [Ransomware]: dragnet-ransomware-2026-1074 — Mass File Rename (thegentlemen)
// Status: test | Level: high | ID: 0844bf27-a485-5253-b6b2-3b2a8d4f357e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
