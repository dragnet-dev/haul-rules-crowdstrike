// Dragnet [Ransomware]: dragnet-ransomware-2025-4483 — Mass File Rename (anubis)
// Status: experimental | Level: high | ID: 433d4537-21bc-5ba1-ade9-5442d34678fd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
