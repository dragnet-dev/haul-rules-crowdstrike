// Dragnet [Ransomware]: dragnet-ransomware-2026-0010 — Mass File Rename (blacknevas)
// Status: stable | Level: high | ID: e5f9ad45-164d-58f7-a87f-4dd761f91855

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
