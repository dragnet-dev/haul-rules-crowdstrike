// Dragnet [Ransomware]: dragnet-ransomware-2024-0235 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: f2a2ad0e-544e-5166-a428-827438cfb1fe

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
