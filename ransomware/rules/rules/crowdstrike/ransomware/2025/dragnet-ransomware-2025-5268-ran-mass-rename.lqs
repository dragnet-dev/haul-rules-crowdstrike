// Dragnet [Ransomware]: dragnet-ransomware-2025-5268 — Mass File Rename (payoutsking)
// Status: deprecated | Level: high | ID: 39050e68-81fd-52a7-9709-838bc0215013

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
