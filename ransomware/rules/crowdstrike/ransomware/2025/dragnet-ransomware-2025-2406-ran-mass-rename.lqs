// Dragnet [Ransomware]: dragnet-ransomware-2025-2406 — Mass File Rename (thegentlemen)
// Status: experimental | Level: high | ID: d3933112-0161-5ace-89a0-fca57592ff45

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
