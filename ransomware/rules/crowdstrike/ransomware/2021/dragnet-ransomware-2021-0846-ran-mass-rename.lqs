// Dragnet [Ransomware]: dragnet-ransomware-2021-0846 — Mass File Rename (spook)
// Status: deprecated | Level: high | ID: 917f8511-cd11-5b75-aa3b-11966bdfd31a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
