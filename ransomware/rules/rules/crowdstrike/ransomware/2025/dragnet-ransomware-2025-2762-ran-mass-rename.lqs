// Dragnet [Ransomware]: dragnet-ransomware-2025-2762 — Mass File Rename (ransomhouse)
// Status: experimental | Level: high | ID: 34a1b395-5f35-54bf-98b9-bd4758b1f522

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
