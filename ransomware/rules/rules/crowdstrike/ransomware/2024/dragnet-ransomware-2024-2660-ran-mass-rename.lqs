// Dragnet [Ransomware]: dragnet-ransomware-2024-2660 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: 621fd157-f276-5d6d-93d1-10236e01e331

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
