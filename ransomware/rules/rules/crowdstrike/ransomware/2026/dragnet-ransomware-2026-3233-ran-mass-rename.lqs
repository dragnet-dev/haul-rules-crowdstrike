// Dragnet [Ransomware]: dragnet-ransomware-2026-3233 — Mass File Rename (incransom)
// Status: stable | Level: high | ID: 11f31055-cef1-5ec2-beae-f6b755690d6a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
