// Dragnet [Ransomware]: dragnet-ransomware-2022-1693 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 1998c9d4-518c-55db-b838-c1da0c4f3dab

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
