// Dragnet [Ransomware]: dragnet-ransomware-2026-3259 — Mass File Rename (nightspire)
// Status: deprecated | Level: high | ID: fc86792a-4bc6-5ba1-bdbe-5d4ceb179596

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
