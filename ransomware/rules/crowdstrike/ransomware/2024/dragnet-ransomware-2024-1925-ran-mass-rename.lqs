// Dragnet [Ransomware]: dragnet-ransomware-2024-1925 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 007b37df-8b47-52fe-a8d8-240fd60e71db

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
