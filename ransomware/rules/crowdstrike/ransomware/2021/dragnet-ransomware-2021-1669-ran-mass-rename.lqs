// Dragnet [Ransomware]: dragnet-ransomware-2021-1669 — Mass File Rename (marketo)
// Status: deprecated | Level: high | ID: 8c9cce90-d6d9-5107-9422-4e48c671b82c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
