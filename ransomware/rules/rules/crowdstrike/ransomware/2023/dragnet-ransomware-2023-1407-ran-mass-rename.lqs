// Dragnet [Ransomware]: dragnet-ransomware-2023-1407 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 511ffa45-0635-5dc7-bcc8-f07df2ac94f0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
