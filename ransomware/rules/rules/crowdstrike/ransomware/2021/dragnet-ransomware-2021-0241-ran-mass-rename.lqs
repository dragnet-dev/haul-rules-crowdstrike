// Dragnet [Ransomware]: dragnet-ransomware-2021-0241 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 69df58de-f5fe-5254-ab10-5fd52b93e2ed

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
