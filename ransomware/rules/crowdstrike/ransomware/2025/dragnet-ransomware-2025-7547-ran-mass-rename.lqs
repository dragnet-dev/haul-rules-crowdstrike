// Dragnet [Ransomware]: dragnet-ransomware-2025-7547 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: e489d151-3dde-5ebb-9552-b0b644485346

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
