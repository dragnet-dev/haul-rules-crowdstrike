// Dragnet [Ransomware]: dragnet-ransomware-2023-4609 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 94d146ae-35ac-519e-a945-b8084c90882c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
