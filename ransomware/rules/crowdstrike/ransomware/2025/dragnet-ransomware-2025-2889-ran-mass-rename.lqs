// Dragnet [Ransomware]: dragnet-ransomware-2025-2889 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: dc5d69d9-24be-58a5-89e0-5026179eed9b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
