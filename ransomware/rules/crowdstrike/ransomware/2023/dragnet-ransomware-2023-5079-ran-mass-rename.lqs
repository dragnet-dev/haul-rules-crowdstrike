// Dragnet [Ransomware]: dragnet-ransomware-2023-5079 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 3ef1faa1-c51d-5aee-abf1-af827cdfb819

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
