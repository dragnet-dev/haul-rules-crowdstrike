// Dragnet [Ransomware]: dragnet-ransomware-2026-2469 — Mass File Rename (ALP-001)
// Status: stable | Level: high | ID: 8b6d9f1a-0547-5339-9c4c-6279d1d02907

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
