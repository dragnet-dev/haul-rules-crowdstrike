// Dragnet [Ransomware]: dragnet-ransomware-2025-1344 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 92574bf1-f8b6-53c3-9425-1ea46d8f2abd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
