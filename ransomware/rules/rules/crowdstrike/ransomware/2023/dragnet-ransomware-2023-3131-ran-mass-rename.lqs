// Dragnet [Ransomware]: dragnet-ransomware-2023-3131 — Mass File Rename (snatch)
// Status: experimental | Level: high | ID: a19d4dc6-19f7-5c33-9fa5-e9319b7b642f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
