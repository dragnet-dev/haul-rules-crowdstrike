// Dragnet [Ransomware]: dragnet-ransomware-2023-2369 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: e18b2567-f398-5d1c-a051-2dc99f7c7e2c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
