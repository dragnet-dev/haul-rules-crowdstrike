// Dragnet [Ransomware]: dragnet-ransomware-2025-7565 — Mass File Rename (nova)
// Status: experimental | Level: high | ID: eee81a6a-2526-5819-88d5-6b6eb6f570a1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
