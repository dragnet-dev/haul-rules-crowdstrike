// Dragnet [Ransomware]: dragnet-ransomware-2025-0378 — Mass File Rename (devman)
// Status: experimental | Level: high | ID: e68a05eb-8ea4-5cd5-be0d-0b8cf9428dc0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
