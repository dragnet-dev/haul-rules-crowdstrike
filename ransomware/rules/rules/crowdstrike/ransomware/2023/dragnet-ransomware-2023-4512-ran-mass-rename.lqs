// Dragnet [Ransomware]: dragnet-ransomware-2023-4512 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 4d68b7eb-5788-51ec-926a-9530d4491645

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
