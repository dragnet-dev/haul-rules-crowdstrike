// Dragnet [Ransomware]: dragnet-ransomware-2023-2499 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 64573df2-1202-515a-80ae-c39afcef5476

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
