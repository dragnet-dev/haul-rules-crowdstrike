// Dragnet [Ransomware]: dragnet-ransomware-2023-0812 — Mass File Rename (raworld)
// Status: experimental | Level: high | ID: 25fd3fc1-2753-5035-886b-06430be971d0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
