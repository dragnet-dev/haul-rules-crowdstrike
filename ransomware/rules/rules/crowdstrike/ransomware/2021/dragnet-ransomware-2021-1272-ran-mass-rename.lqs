// Dragnet [Ransomware]: dragnet-ransomware-2021-1272 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: d1eaa8fb-813f-5aac-986c-2f2edf4b7073

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
