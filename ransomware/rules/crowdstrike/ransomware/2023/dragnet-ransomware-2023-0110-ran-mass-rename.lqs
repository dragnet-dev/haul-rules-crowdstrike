// Dragnet [Ransomware]: dragnet-ransomware-2023-0110 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 529aa9ab-dc3e-5ded-b093-813c98a313bf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
