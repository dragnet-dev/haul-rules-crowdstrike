// Dragnet [Ransomware]: dragnet-ransomware-2024-2812 — Mass File Rename (cloak)
// Status: deprecated | Level: high | ID: 1da6ee63-7250-5f9e-9f0a-03aafd0049e5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
