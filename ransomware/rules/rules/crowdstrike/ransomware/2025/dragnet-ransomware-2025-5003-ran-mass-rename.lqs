// Dragnet [Ransomware]: dragnet-ransomware-2025-5003 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 55cff3f3-2326-50b5-9267-85d7ab3af002

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
