// Dragnet [Ransomware]: dragnet-ransomware-2023-4551 — Mass File Rename (moneymessage)
// Status: deprecated | Level: high | ID: 91fc912a-ddd4-51d7-80d6-f9929c9618d7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
