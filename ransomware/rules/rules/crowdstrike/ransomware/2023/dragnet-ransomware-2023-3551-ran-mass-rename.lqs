// Dragnet [Ransomware]: dragnet-ransomware-2023-3551 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 55ad7adc-aedc-55a2-b666-ca254b2a3b13

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
