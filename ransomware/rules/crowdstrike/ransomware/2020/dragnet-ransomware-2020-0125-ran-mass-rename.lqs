// Dragnet [Ransomware]: dragnet-ransomware-2020-0125 — Mass File Rename (ransomexx)
// Status: deprecated | Level: high | ID: cb65a96c-3bd6-5e8d-b6c6-0b59931521d7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
