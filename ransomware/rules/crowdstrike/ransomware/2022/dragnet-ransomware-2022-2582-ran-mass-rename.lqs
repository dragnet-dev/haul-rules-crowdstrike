// Dragnet [Ransomware]: dragnet-ransomware-2022-2582 — Mass File Rename (cuba)
// Status: deprecated | Level: high | ID: 331849f6-9d62-5625-bb41-973356ba14d7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
