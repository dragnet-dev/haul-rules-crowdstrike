// Dragnet [Ransomware]: dragnet-ransomware-2024-0512 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 3b7531f1-6742-58d6-91df-c4a9f0b885de

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
