// Dragnet [Container]: dragnet-container-2025-0151 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 7b203a94-2845-59df-8a04-a1034d54fa9c

#event_simpleName=*
| (ImageFileName = *almalinux:9* OR ImageFileName = *amazonlinux:2* OR ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *oraclelinux:9* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:18.04-ESM* OR ImageFileName = *ubuntu:20.04* OR ImageFileName = *ubuntu:20.04-ESM* OR ImageFileName = *ubuntu:22.04* OR ImageFileName = *ubuntu:23.04* OR ImageFileName = *ubuntu:23.10*)
| table([timestamp, ComputerName])
| limit(1000)
