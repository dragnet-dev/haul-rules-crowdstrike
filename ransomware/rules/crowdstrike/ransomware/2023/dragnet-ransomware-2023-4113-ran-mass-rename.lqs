// Dragnet [Ransomware]: dragnet-ransomware-2023-4113 — Mass File Rename (royal)
// Status: experimental | Level: high | ID: d58047ac-4572-5618-a5c4-a1e60d018c43

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
