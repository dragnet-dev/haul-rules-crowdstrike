// Dragnet [Ransomware]: dragnet-ransomware-2025-7868 — Mass File Rename (J)
// Status: experimental | Level: high | ID: 48ffefe9-2277-5bc2-9132-25020929d6d7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
