// Dragnet [Ransomware]: dragnet-ransomware-2025-7778 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: ba68a415-f4b1-5f43-9a4d-ba941faffe22

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
