// Dragnet [Ransomware]: dragnet-ransomware-2025-6015 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: 03dbf74b-fa4c-564a-97dc-08f2d5922473

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
