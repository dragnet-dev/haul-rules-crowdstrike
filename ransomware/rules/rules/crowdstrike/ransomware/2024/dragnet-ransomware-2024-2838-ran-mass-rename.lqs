// Dragnet [Ransomware]: dragnet-ransomware-2024-2838 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: b486f93b-3388-5840-ab7a-d3e1e6d1fe76

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
