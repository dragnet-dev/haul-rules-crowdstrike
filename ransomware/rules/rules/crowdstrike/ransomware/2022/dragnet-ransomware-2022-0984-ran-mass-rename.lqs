// Dragnet [Ransomware]: dragnet-ransomware-2022-0984 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 39430896-fc0b-59eb-a265-59ab8dcc747b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
