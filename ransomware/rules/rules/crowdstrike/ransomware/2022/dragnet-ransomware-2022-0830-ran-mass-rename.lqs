// Dragnet [Ransomware]: dragnet-ransomware-2022-0830 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: e62aec86-860e-56c7-b3b9-1a11bb6bd9cb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
