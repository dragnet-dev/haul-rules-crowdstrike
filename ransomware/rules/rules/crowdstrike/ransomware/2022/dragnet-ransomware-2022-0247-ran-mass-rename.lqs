// Dragnet [Ransomware]: dragnet-ransomware-2022-0247 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 169653a3-74ad-5b8e-9546-c0b9066f8297

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
