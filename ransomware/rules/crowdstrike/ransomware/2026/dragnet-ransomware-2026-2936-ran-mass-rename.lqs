// Dragnet [Ransomware]: dragnet-ransomware-2026-2936 — Mass File Rename (payload)
// Status: stable | Level: high | ID: bb6209d9-0772-5f84-8714-4c91b85541f9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
