// Dragnet [Ransomware]: dragnet-ransomware-2024-5350 — Mass File Rename (handala)
// Status: experimental | Level: high | ID: ba378d18-e4ae-5129-ab9d-319299984cef

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
