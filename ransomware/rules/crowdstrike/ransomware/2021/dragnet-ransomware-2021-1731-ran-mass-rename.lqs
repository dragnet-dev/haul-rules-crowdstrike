// Dragnet [Ransomware]: dragnet-ransomware-2021-1731 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 2911d0be-90a8-5e25-84f3-5c807288f6ae

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
