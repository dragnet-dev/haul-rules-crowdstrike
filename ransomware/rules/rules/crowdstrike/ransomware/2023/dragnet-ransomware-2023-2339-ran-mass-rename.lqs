// Dragnet [Ransomware]: dragnet-ransomware-2023-2339 — Mass File Rename (knight)
// Status: experimental | Level: high | ID: a27a3acf-69b0-5c40-9189-dde60fd3431e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
