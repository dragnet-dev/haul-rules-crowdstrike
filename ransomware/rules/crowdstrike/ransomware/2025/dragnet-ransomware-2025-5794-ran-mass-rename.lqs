// Dragnet [Ransomware]: dragnet-ransomware-2025-5794 — Mass File Rename (nova)
// Status: experimental | Level: high | ID: 89262e45-4cae-5096-9da9-22ba47cf9c20

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
