// Dragnet [Ransomware]: dragnet-ransomware-2024-4290 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 39070077-36db-5904-b6c1-1b66fb4d24b7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
