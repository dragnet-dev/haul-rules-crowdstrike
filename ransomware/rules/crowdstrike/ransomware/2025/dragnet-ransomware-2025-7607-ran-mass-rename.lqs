// Dragnet [Ransomware]: dragnet-ransomware-2025-7607 — Mass File Rename (flocker)
// Status: experimental | Level: high | ID: 721f2515-5deb-57f4-bf93-6608c02363fd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
