// Dragnet [Ransomware]: dragnet-ransomware-2022-1553 — Mass File Rename (medusalocker)
// Status: deprecated | Level: high | ID: d3d9d5ec-7dde-5fc9-9320-053dba66b2bd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
