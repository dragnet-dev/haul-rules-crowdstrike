// Dragnet [Ransomware]: dragnet-ransomware-2024-4956 — Mass File Rename (play)
// Status: experimental | Level: high | ID: b32eaf23-4f98-5ce4-9ab3-aebaaf504f1f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
