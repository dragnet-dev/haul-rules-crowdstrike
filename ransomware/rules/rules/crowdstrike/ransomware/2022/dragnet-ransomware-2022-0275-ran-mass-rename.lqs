// Dragnet [Ransomware]: dragnet-ransomware-2022-0275 — Mass File Rename (alphv)
// Status: deprecated | Level: high | ID: 0653cc0b-b750-5ace-a1f0-83895defdc8d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
