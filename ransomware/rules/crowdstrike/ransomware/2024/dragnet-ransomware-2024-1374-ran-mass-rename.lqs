// Dragnet [Ransomware]: dragnet-ransomware-2024-1374 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 49851d9b-6b0e-583a-ad5e-ba5148b1fc3e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
