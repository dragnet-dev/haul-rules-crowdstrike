// Dragnet [Ransomware]: dragnet-ransomware-2024-4000 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: f942c566-de4b-5a57-8952-17d1ae7701cd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
