// Dragnet [Container]: dragnet-container-2026-0016 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 8536d230-b9e7-5036-aa5d-aa2c015fd6df

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:8* OR ImageFileName = *ubuntu:16.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
