// Dragnet [Container]: dragnet-container-2024-1180 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 573284e6-f5ea-549b-9173-f7328bf8c3dd

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:9*)
| table([timestamp, ComputerName])
| limit(1000)
