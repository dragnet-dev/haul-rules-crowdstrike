// Dragnet [Ransomware]: dragnet-ransomware-2025-1511 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 6696237c-34c8-57bb-8ee2-37c3deac8d6d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
