// Dragnet [Ransomware]: dragnet-ransomware-2023-4448 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 4b9a9e82-6349-5c90-9ff2-f1086707cf8e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
