// Dragnet [Ransomware]: dragnet-ransomware-2024-4402 — Mass File Rename (raworld)
// Status: experimental | Level: high | ID: 5bc50d50-dfd7-5cb8-a0bc-0ae158bc8048

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
