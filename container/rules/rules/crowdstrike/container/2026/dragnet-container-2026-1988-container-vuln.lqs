// Dragnet [Container]: dragnet-container-2026-1988 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 2a4fd195-8899-5de2-85b9-18b05bd8aafc

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:7* OR ImageFileName = *debian:8*)
| table([timestamp, ComputerName])
| limit(1000)
