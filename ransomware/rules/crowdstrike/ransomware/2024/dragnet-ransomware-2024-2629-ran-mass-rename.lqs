// Dragnet [Ransomware]: dragnet-ransomware-2024-2629 — Mass File Rename (spacebears)
// Status: experimental | Level: high | ID: 15534963-0430-52c6-a9e8-798ff2ebe599

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
