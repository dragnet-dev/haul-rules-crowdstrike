// Dragnet [Ransomware]: dragnet-ransomware-2025-5411 — Mass File Rename (arcusmedia)
// Status: experimental | Level: high | ID: b9cfcb47-83fc-517c-b0ec-d23714e0e445

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
