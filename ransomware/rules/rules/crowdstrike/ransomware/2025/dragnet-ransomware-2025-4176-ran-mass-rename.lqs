// Dragnet [Ransomware]: dragnet-ransomware-2025-4176 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 1333e3c5-0e2e-5ec7-af67-7cb19a26d4a6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
