// Dragnet [Ransomware]: dragnet-ransomware-2024-1529 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: b4d82818-e022-50ee-8d3a-ae63d4fec5fe

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
