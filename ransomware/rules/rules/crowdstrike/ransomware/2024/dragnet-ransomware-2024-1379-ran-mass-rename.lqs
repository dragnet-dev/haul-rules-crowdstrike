// Dragnet [Ransomware]: dragnet-ransomware-2024-1379 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: e9839114-f80e-59d2-b3da-8e95a5551c4e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
