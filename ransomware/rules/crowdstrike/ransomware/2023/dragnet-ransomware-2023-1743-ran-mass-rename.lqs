// Dragnet [Ransomware]: dragnet-ransomware-2023-1743 — Mass File Rename (play)
// Status: experimental | Level: high | ID: cd557a10-9170-598b-8bc9-94ab5bb9a80a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
