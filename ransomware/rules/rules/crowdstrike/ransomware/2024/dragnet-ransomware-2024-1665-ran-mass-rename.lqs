// Dragnet [Ransomware]: dragnet-ransomware-2024-1665 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 95141602-fd0f-5126-8ee7-9d58762d7aff

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
