// Dragnet [Ransomware]: dragnet-ransomware-2024-4068 — Mass File Rename (ElDorado)
// Status: deprecated | Level: high | ID: 2c4a1e84-8add-5e0c-8de8-222dae973bdc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
