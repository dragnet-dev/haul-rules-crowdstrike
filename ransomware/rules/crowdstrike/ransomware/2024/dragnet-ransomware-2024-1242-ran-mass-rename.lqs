// Dragnet [Ransomware]: dragnet-ransomware-2024-1242 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 31a62bf9-f5c2-5fad-bd2d-d247eddd6fb7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
