// Dragnet [Ransomware]: dragnet-ransomware-2024-4730 — Mass File Rename (arcusmedia)
// Status: experimental | Level: high | ID: c137b256-8c00-5ce6-8a48-1b089adab1f9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
