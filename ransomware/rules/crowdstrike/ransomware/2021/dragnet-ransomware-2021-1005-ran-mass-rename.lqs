// Dragnet [Ransomware]: dragnet-ransomware-2021-1005 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: e479daff-8855-585f-be59-579ab2131110

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
