// Dragnet [Ransomware]: dragnet-ransomware-2024-0151 — Mass File Rename (play)
// Status: experimental | Level: high | ID: a8efe7c0-57ef-54af-9130-9ed118a9e43c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
