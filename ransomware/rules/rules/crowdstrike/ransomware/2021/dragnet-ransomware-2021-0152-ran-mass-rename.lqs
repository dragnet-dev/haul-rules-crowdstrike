// Dragnet [Ransomware]: dragnet-ransomware-2021-0152 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 376f7112-0ada-5b83-af3f-d9e9602e4cc5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
