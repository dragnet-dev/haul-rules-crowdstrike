// Dragnet [Ransomware]: dragnet-ransomware-2024-2906 — Mass File Rename (redransomware)
// Status: deprecated | Level: high | ID: 8d199d19-00a9-5e67-bb20-a19856ded365

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
