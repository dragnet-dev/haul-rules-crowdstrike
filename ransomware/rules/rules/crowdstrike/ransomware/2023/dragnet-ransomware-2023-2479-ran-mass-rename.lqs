// Dragnet [Ransomware]: dragnet-ransomware-2023-2479 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 8c9f6151-c8ef-5384-8de4-e1a3c22ebe43

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
