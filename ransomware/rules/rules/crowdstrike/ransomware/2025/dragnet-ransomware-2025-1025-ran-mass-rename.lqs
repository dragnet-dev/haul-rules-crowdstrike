// Dragnet [Ransomware]: dragnet-ransomware-2025-1025 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: 59d0b12f-05de-5e0b-a329-01e9bba8b23c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
