// Dragnet [Ransomware]: dragnet-ransomware-2021-0162 — Mass File Rename (ryuk)
// Status: deprecated | Level: high | ID: badcf3cf-e34f-5a75-bc01-b44c77207cd5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
