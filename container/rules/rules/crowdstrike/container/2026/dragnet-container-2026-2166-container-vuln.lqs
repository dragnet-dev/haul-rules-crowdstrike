// Dragnet [Container]: dragnet-container-2026-2166 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 49889619-2f95-50e9-81c2-5b5d9967afaf

#event_simpleName=*
| (ImageFileName = *amazonlinux:1* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6*)
| table([timestamp, ComputerName])
| limit(1000)
