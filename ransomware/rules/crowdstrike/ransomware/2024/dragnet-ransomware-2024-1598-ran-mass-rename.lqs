// Dragnet [Ransomware]: dragnet-ransomware-2024-1598 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: ac05f746-534b-5398-844b-b96955924eb8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
