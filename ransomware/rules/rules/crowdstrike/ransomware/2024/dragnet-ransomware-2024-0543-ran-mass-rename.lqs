// Dragnet [Ransomware]: dragnet-ransomware-2024-0543 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: afff4f5e-6f46-5774-9af9-8531fe090512

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
