// Dragnet [Ransomware]: dragnet-ransomware-2021-0591 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 71b729a5-7bbd-55f7-826c-38f07fa0e1e2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
