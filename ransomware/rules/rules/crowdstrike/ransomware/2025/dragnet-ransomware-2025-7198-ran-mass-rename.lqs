// Dragnet [Ransomware]: dragnet-ransomware-2025-7198 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 392a3953-ce16-5bd4-9ade-672084016770

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
