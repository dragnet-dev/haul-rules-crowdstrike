// Dragnet [Ransomware]: dragnet-ransomware-2024-6017 — Mass File Rename (blacklock)
// Status: experimental | Level: high | ID: debd1cb5-6d6d-530a-b4a5-42e23f570215

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
