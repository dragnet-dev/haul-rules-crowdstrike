// Dragnet [Ransomware]: dragnet-ransomware-2024-2831 — Mass File Rename (play)
// Status: experimental | Level: high | ID: d8459e66-d22c-50a5-aaa8-e557c5680def

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
