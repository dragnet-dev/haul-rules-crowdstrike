// Dragnet [Ransomware]: dragnet-ransomware-2025-5628 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 12b3d1e4-c5a0-550b-946b-fbe7a309dcef

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
