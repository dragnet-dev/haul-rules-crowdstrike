// Dragnet [Ransomware]: dragnet-ransomware-2022-0006 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: af9ebee4-2f6f-56c1-9fd9-865e9873b205

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
