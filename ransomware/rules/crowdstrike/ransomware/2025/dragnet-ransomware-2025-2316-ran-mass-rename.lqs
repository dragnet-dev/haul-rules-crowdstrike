// Dragnet [Ransomware]: dragnet-ransomware-2025-2316 — Mass File Rename (blackshrantac)
// Status: experimental | Level: high | ID: 65013343-076e-5ad7-82df-a7985455b772

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
