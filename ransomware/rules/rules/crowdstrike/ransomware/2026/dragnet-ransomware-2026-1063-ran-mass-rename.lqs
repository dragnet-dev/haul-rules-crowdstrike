// Dragnet [Ransomware]: dragnet-ransomware-2026-1063 — Mass File Rename (thegentlemen)
// Status: stable | Level: high | ID: 28f6db35-225d-52ba-b2f2-22a3c3fbc41f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
