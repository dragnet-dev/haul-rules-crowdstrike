// Dragnet [Ransomware]: dragnet-ransomware-2022-2528 — Mass File Rename (play)
// Status: deprecated | Level: high | ID: 8c6e33cc-047e-5a3d-8475-ed0cc1bc01ac

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
