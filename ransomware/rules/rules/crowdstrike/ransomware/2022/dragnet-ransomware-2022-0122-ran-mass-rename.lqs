// Dragnet [Ransomware]: dragnet-ransomware-2022-0122 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: ad032cda-d10e-56e7-a92a-708081a3f2ba

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
