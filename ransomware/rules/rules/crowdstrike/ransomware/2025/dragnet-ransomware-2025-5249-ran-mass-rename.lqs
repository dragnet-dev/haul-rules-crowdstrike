// Dragnet [Ransomware]: dragnet-ransomware-2025-5249 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 3d2a7fb7-1ddf-5a69-baab-f77b37b1b8f9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
