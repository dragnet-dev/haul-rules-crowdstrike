// Dragnet [Ransomware]: dragnet-ransomware-2021-0258 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 33812ad2-cdef-507e-8777-c187ab68a2b4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
