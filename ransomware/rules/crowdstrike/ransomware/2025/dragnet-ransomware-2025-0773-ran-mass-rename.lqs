// Dragnet [Ransomware]: dragnet-ransomware-2025-0773 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 4157f8b8-5995-5f6f-8457-1d68546ade05

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
