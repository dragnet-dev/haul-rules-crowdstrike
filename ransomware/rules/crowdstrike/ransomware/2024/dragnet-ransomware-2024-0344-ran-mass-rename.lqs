// Dragnet [Ransomware]: dragnet-ransomware-2024-0344 — Mass File Rename (raworld)
// Status: experimental | Level: high | ID: 262ad2c4-7930-5ae2-ad04-e65f74854e8b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
