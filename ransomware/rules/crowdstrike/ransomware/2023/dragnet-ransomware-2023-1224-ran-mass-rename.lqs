// Dragnet [Ransomware]: dragnet-ransomware-2023-1224 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: e42aa4e2-b56e-5bf4-81b4-82f887a61bc3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
