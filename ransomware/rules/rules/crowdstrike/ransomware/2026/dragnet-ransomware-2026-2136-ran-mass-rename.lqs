// Dragnet [Ransomware]: dragnet-ransomware-2026-2136 — Mass File Rename (worldleaks)
// Status: test | Level: high | ID: af16b942-bee3-584d-a94b-6b46a17c8b2e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
