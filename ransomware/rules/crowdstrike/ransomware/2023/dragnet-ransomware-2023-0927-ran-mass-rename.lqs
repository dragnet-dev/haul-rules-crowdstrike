// Dragnet [Ransomware]: dragnet-ransomware-2023-0927 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 8a227045-75e7-5072-8dc7-f5afcd228674

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
