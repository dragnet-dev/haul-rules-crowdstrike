// Dragnet [Ransomware]: dragnet-ransomware-2025-6102 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 19179602-32bb-576a-925f-160e9e36723d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
