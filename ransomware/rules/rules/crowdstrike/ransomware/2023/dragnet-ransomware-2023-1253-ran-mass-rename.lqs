// Dragnet [Ransomware]: dragnet-ransomware-2023-1253 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 8516c4d9-f976-53f5-968d-f71c74983f02

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
