// Dragnet [Ransomware]: dragnet-ransomware-2023-1426 — Mass File Rename (ragnarlocker)
// Status: experimental | Level: high | ID: fdd72ae2-d475-5706-8a93-afc9abbd2e2e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
