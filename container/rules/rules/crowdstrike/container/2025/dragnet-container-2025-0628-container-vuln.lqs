// Dragnet [Container]: dragnet-container-2025-0628 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: a413c780-8c0d-53de-b07f-4ed0f02997fe

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
