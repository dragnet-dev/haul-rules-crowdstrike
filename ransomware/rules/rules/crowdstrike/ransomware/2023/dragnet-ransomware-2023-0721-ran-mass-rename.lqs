// Dragnet [Ransomware]: dragnet-ransomware-2023-0721 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: d2ecf25e-2ddb-5c95-b16f-a989135b2da4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
