// Dragnet [Ransomware]: dragnet-ransomware-2023-3151 — Mass File Rename (raworld)
// Status: experimental | Level: high | ID: f2d1bf5f-89b9-56ee-87a7-ee5243d32375

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
