// Dragnet [Container]: dragnet-container-2026-0246 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 91350f95-7cda-5dad-a79f-54eba72d25bb

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:8* OR ImageFileName = *oraclelinux:7* OR ImageFileName = *ubuntu:14.04* OR ImageFileName = *ubuntu:14.04-ESM* OR ImageFileName = *ubuntu:15.10*)
| table([timestamp, ComputerName])
| limit(1000)
