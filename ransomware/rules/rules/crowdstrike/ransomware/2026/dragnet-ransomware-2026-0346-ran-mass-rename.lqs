// Dragnet [Ransomware]: dragnet-ransomware-2026-0346 — Mass File Rename (dragonforce)
// Status: stable | Level: high | ID: 87cb8003-feb2-58d8-99b8-548a31584249

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
