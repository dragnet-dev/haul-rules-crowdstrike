// Dragnet [Ransomware]: dragnet-ransomware-2023-3597 — Mass File Rename (play)
// Status: experimental | Level: high | ID: b1ead000-2b7d-51ff-af59-98237ccd5a51

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
