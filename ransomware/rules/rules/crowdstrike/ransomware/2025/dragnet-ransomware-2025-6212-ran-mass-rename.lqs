// Dragnet [Ransomware]: dragnet-ransomware-2025-6212 — Mass File Rename (kairos)
// Status: experimental | Level: high | ID: 86e0502a-8e40-56c6-bc99-79089bd7ff11

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
