// Dragnet [Ransomware]: dragnet-ransomware-2024-0131 — Mass File Rename (cloak)
// Status: experimental | Level: high | ID: 6ea94ead-0378-57ae-a863-33d9e7ba7445

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
