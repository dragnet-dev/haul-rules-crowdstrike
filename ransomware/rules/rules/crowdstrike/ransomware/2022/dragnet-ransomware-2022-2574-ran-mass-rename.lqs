// Dragnet [Ransomware]: dragnet-ransomware-2022-2574 — Mass File Rename (lv)
// Status: deprecated | Level: high | ID: 8efeec8b-001d-57a4-9fc5-415543bc2991

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
