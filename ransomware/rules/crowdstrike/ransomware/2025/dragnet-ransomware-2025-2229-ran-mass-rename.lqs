// Dragnet [Ransomware]: dragnet-ransomware-2025-2229 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: 59986c4e-f9e7-5f9c-a433-5538b44a40f8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
