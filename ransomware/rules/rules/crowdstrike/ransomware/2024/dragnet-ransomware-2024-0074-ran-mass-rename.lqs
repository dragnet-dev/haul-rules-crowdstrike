// Dragnet [Ransomware]: dragnet-ransomware-2024-0074 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: def07088-5d3a-5de6-bc55-562618c2c5b3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
