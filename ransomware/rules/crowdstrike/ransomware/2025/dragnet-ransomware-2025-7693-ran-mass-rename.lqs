// Dragnet [Ransomware]: dragnet-ransomware-2025-7693 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 695f9144-35bf-5f6e-ab9e-aa0973f59266

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
