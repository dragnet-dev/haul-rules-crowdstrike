// Dragnet [Ransomware]: dragnet-ransomware-2023-0819 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 6e514b50-5edb-53f4-9e4d-74b964ae83d1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
