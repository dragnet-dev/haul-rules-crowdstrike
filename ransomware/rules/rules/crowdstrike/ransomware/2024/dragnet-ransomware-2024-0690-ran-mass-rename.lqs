// Dragnet [Ransomware]: dragnet-ransomware-2024-0690 — Mass File Rename (play)
// Status: experimental | Level: high | ID: db7069fa-6308-5a4b-bf50-5ae76dbc22af

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
