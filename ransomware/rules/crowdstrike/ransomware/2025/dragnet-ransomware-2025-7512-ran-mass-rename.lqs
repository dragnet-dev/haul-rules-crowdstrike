// Dragnet [Ransomware]: dragnet-ransomware-2025-7512 — Mass File Rename (blackshrantac)
// Status: experimental | Level: high | ID: ce388c88-0c62-5ea0-bfc3-d26272affe91

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
