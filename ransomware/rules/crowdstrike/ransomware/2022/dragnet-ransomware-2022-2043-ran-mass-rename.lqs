// Dragnet [Ransomware]: dragnet-ransomware-2022-2043 — Mass File Rename (onyx)
// Status: deprecated | Level: high | ID: 4f0e0d99-72f9-5f7b-bbd4-9cdf18a1fcf5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
