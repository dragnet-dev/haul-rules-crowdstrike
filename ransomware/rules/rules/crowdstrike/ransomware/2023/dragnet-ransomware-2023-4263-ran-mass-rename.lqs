// Dragnet [Ransomware]: dragnet-ransomware-2023-4263 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 9f2a8d0c-486b-5b6d-b1c4-12cc0163e49f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
