// Dragnet [Ransomware]: dragnet-ransomware-2023-3568 — Mass File Rename (nokoyawa)
// Status: experimental | Level: high | ID: af94e05b-52d9-59e2-869c-4a3927d3300a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
