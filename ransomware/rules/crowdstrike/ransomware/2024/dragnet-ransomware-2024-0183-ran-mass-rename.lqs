// Dragnet [Ransomware]: dragnet-ransomware-2024-0183 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: c187cd56-f98f-5788-ab51-eefde950911d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
