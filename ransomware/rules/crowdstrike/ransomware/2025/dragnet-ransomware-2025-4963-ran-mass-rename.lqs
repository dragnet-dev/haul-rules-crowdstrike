// Dragnet [Ransomware]: dragnet-ransomware-2025-4963 — Mass File Rename (warlock)
// Status: deprecated | Level: high | ID: 223868f2-05a5-58c3-8875-8896cc229b27

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
