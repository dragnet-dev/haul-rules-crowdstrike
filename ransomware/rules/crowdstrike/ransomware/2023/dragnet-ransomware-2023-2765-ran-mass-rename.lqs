// Dragnet [Ransomware]: dragnet-ransomware-2023-2765 — Mass File Rename (malas)
// Status: experimental | Level: high | ID: 652f8175-6261-578d-81bd-6001ccfe44e6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
