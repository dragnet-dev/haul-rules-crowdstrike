// Dragnet [Ransomware]: dragnet-ransomware-2024-1530 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: c8418d2e-f15e-5ac8-bbd6-90abb189d754

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
