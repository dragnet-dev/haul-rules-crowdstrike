// Dragnet [Ransomware]: dragnet-ransomware-2023-2980 — Mass File Rename (stormous)
// Status: experimental | Level: high | ID: 431f7287-37d0-544b-a873-75af2c3cfdec

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
