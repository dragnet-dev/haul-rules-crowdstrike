// Dragnet [Ransomware]: dragnet-ransomware-2022-2186 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: f54cfc92-cb40-5016-b27b-5f7c1b117c6e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
