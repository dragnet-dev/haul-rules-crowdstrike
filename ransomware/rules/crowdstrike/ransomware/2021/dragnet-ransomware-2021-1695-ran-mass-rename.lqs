// Dragnet [Ransomware]: dragnet-ransomware-2021-1695 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 25a0b8d0-f985-5577-a34a-4fa40ab68ca4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
