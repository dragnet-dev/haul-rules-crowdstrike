// Dragnet [Ransomware]: dragnet-ransomware-2025-3174 — Mass File Rename (worldleaks)
// Status: experimental | Level: high | ID: e1729443-4ab5-5a6d-8e46-9491d4ba9aa9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
