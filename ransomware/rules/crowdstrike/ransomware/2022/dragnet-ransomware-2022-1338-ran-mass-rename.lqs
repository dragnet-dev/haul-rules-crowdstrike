// Dragnet [Ransomware]: dragnet-ransomware-2022-1338 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: b965b340-0e13-5ee3-97e5-5b6be261f9eb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
