// Dragnet [Ransomware]: dragnet-ransomware-2025-0226 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 30c30baa-7380-5849-acf7-34f1c5867056

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
