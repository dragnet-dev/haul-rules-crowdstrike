// Dragnet [Ransomware]: dragnet-ransomware-2024-5613 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 4bd3e40d-c57c-5de4-8df7-ad5f8a30ba19

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
