// Dragnet [Ransomware]: dragnet-ransomware-2025-2098 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 1531516f-d5ea-551a-bd53-977635250aad

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
