// Dragnet [Container]: dragnet-container-2024-1362 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 74380f31-1149-5d55-b57f-23722b9f0302

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:8* OR ImageFileName = *debian:9*)
| table([timestamp, ComputerName])
| limit(1000)
