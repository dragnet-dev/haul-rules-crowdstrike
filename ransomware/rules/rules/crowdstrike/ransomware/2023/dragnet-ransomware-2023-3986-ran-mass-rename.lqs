// Dragnet [Ransomware]: dragnet-ransomware-2023-3986 — Mass File Rename (royal)
// Status: deprecated | Level: high | ID: 48754344-1631-549f-978e-3067ddf13253

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
