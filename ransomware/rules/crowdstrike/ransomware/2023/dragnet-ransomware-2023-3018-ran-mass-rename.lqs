// Dragnet [Ransomware]: dragnet-ransomware-2023-3018 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 6438b38e-eaaf-583e-9025-5bfb21b78f29

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
