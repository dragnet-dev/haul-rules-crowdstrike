// Dragnet [Ransomware]: dragnet-ransomware-2021-0167 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 55b25b35-0910-5903-9125-acdd2b33b831

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
