// Dragnet [Container]: dragnet-container-2025-0545 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 970bba4e-09c0-5674-b3a4-14429623dee9

#event_simpleName=*
| (ImageFileName = *almalinux:8* OR ImageFileName = *almalinux:9* OR ImageFileName = *amazonlinux:2* OR ImageFileName = *amazonlinux:2023* OR ImageFileName = *azure linux:3.0* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:7* OR ImageFileName = *oraclelinux:8* OR ImageFileName = *oraclelinux:9* OR ImageFileName = *photon os:4.0* OR ImageFileName = *photon os:5.0* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:22.04* OR ImageFileName = *ubuntu:24.04* OR ImageFileName = *ubuntu:25.04*)
| table([timestamp, ComputerName])
| limit(1000)
