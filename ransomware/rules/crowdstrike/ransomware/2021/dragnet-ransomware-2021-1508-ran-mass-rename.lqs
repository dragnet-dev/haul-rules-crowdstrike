// Dragnet [Ransomware]: dragnet-ransomware-2021-1508 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 4abfdbbc-6436-504b-a0e4-53361a61b793

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
