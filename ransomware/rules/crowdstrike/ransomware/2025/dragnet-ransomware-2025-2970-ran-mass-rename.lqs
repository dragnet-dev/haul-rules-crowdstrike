// Dragnet [Ransomware]: dragnet-ransomware-2025-2970 — Mass File Rename (anubis)
// Status: experimental | Level: high | ID: daf6dd50-0930-5b8a-89c7-729a337d08e8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
