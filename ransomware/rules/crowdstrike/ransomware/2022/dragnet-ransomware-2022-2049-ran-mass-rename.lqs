// Dragnet [Ransomware]: dragnet-ransomware-2022-2049 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: dbe60f93-b026-5cb4-b61d-ca03093698ea

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
