// Dragnet [Ransomware]: dragnet-ransomware-2023-1251 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 5ac2ac15-c3b2-5bc7-8183-9b5222f36154

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
