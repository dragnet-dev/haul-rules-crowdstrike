// Dragnet [Ransomware]: dragnet-ransomware-2024-5364 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: f6d07937-8b22-549d-8043-3ff484ec372d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
