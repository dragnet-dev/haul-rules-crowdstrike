// Dragnet [Ransomware]: dragnet-ransomware-2023-4133 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 86747fab-13cc-56a5-980e-b5b3f7784b6c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
