// Dragnet [Ransomware]: dragnet-ransomware-2022-0104 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 2b1419aa-fa02-5469-b187-726e9cebf1df

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
