// Dragnet [Ransomware]: dragnet-ransomware-2025-1124 — Mass File Rename (termite)
// Status: experimental | Level: high | ID: e7112abe-52ea-563a-8038-3828759c871d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
