// Dragnet [Ransomware]: dragnet-ransomware-2021-0343 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: e2f95945-ef0d-5368-9ad5-f892648cebae

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
