// Dragnet [Ransomware]: dragnet-ransomware-2026-3163 — Mass File Rename (vect)
// Status: deprecated | Level: high | ID: 284d0e06-828f-5a19-b99a-58bfb8f454f8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
