// Dragnet [Ransomware]: dragnet-ransomware-2026-3112 — Mass File Rename (handala)
// Status: stable | Level: high | ID: cc3d27bf-4cb3-5f32-9465-9d88dd533d3c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
