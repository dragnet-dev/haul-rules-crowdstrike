// Dragnet [Ransomware]: dragnet-ransomware-2025-2132 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: 50377cb4-ba31-5ade-b643-5aec6aef4aa2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
