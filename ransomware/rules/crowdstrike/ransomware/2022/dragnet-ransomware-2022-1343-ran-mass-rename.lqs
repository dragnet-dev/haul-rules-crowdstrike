// Dragnet [Ransomware]: dragnet-ransomware-2022-1343 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: b34e2c21-fba7-56ee-8ced-5ee2ca47f23d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
