// Dragnet [Ransomware]: dragnet-ransomware-2022-0806 — Mass File Rename (blackbasta)
// Status: deprecated | Level: high | ID: e3a3bbaa-9dc3-5f94-9d24-0023dfa3a5e5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
