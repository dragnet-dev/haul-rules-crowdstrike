// Dragnet [Ransomware]: dragnet-ransomware-2025-3871 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: fa5ed318-16a3-5085-8873-a45d5066eaa2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
