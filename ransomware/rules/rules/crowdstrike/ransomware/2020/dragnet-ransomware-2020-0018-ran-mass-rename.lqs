// Dragnet [Ransomware]: dragnet-ransomware-2020-0018 — Mass File Rename (lockbit)
// Status: deprecated | Level: high | ID: 242dc1b2-9cbb-5dbd-b6e2-7408b361b17b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
