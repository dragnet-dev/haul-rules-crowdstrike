// Dragnet [Ransomware]: dragnet-ransomware-2024-3499 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: f6dab49f-bd09-578e-923e-d7ef6191c9dd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
