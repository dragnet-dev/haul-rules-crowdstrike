// Dragnet [Ransomware]: dragnet-ransomware-2023-3244 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: cab02803-b792-5953-85fc-3ffa89ab842b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
