// Dragnet [Ransomware]: dragnet-ransomware-2025-7584 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: b3e537c6-d6cc-5d78-8511-ecb1df4e8ca6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
