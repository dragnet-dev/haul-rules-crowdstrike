// Dragnet [Ransomware]: dragnet-ransomware-2025-2275 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 4edb60e2-5373-51da-90cc-b9d0e67e0918

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
