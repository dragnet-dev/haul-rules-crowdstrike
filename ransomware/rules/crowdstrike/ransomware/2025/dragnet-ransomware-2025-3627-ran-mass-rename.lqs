// Dragnet [Ransomware]: dragnet-ransomware-2025-3627 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 0fed1c5f-68d6-51c5-b677-45b7bf23a790

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
