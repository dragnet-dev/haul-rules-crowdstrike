// Dragnet [Ransomware]: dragnet-ransomware-2025-2619 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 26ca4533-0328-50a5-8724-a9fe3f9e74de

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
