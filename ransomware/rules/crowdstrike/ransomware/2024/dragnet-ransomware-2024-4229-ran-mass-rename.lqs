// Dragnet [Ransomware]: dragnet-ransomware-2024-4229 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 1e0c033b-ae1c-5e59-b284-95bfb43d670d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
