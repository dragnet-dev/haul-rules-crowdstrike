// Dragnet [Ransomware]: dragnet-ransomware-2025-3858 — Mass File Rename (lockbit5)
// Status: test | Level: high | ID: 0c782605-760a-5e79-aa50-8affc23f86f3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
