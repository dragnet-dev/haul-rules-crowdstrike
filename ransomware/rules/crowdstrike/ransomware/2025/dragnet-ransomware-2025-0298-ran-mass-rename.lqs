// Dragnet [Ransomware]: dragnet-ransomware-2025-0298 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: bff50172-e399-510b-adeb-da2808d0ec8c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
