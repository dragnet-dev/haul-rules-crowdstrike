// Dragnet [Ransomware]: dragnet-ransomware-2023-4201 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 7ceec51e-7ef8-5fcb-bd45-b7ecfd137561

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
