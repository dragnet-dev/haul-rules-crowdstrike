// Dragnet [Ransomware]: dragnet-ransomware-2021-0564 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 56c50293-a9e7-5bdb-a141-53ffe2d2254e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
