// Dragnet [Ransomware]: dragnet-ransomware-2024-4923 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 2328eba3-4464-528c-ab19-3a0e81f4233e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
