// Dragnet [Ransomware]: dragnet-ransomware-2022-0430 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 0066ecad-5e19-5498-b809-89efb2b71a97

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
