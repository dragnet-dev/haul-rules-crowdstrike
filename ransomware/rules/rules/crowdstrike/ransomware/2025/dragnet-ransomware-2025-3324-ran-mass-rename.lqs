// Dragnet [Ransomware]: dragnet-ransomware-2025-3324 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 41dfcfa2-88ea-56ff-8a1b-ee33ccc656d7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
