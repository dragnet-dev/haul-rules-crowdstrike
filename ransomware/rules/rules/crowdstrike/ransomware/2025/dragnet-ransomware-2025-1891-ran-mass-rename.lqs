// Dragnet [Ransomware]: dragnet-ransomware-2025-1891 — Mass File Rename (sinobi)
// Status: experimental | Level: high | ID: 6cc6d0c3-4060-5829-9049-71fe7523a07f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
