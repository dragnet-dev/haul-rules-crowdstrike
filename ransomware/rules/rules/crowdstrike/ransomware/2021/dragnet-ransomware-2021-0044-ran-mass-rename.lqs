// Dragnet [Ransomware]: dragnet-ransomware-2021-0044 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 6cd2178b-59be-51ec-aa61-003bfd8d7d2a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
