// Dragnet [Ransomware]: dragnet-ransomware-2024-0575 — Mass File Rename (stormous)
// Status: deprecated | Level: high | ID: 465e23c7-41f1-500e-a2e4-9ad817c7458d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
