// Dragnet [Ransomware]: dragnet-ransomware-2025-6429 — Mass File Rename (skira)
// Status: experimental | Level: high | ID: 0e117c78-054c-5dbb-a5e0-08c002bb1608

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
