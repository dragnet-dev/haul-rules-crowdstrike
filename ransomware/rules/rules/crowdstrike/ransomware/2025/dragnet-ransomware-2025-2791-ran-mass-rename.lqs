// Dragnet [Ransomware]: dragnet-ransomware-2025-2791 — Mass File Rename (BrainCipher)
// Status: experimental | Level: high | ID: 266f2e29-788a-5bed-8e68-a2ec2b063d77

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
