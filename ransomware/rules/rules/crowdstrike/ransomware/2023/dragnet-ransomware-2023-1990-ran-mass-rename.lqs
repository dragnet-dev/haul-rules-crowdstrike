// Dragnet [Ransomware]: dragnet-ransomware-2023-1990 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 31675439-86a5-508f-864c-8834722506ba

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
