// Dragnet [Ransomware]: dragnet-ransomware-2024-2398 — Mass File Rename (meow)
// Status: experimental | Level: high | ID: 2cd98259-9bbb-5162-b112-26c34277a8b3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
