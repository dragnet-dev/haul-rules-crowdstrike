// Dragnet [Container]: dragnet-container-2024-0965 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 2ecd55e9-0932-5e17-a9a2-caaa80baf047

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:9*)
| table([timestamp, ComputerName])
| limit(1000)
