// Dragnet [Ransomware]: dragnet-ransomware-2026-0235 — Mass File Rename (dragonforce)
// Status: stable | Level: high | ID: c5ad8f65-1167-576c-a1cd-e5ad97eeb1c7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
