// Dragnet [Container]: dragnet-container-2026-2555 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 1bd4d88e-87c6-539c-8100-2d63b1280071

#event_simpleName=*
| (ImageFileName = *chainguard:* OR ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10*)
| table([timestamp, ComputerName])
| limit(1000)
