// Dragnet [Ransomware]: dragnet-ransomware-2024-0661 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: e9100396-bb2d-5799-99c5-6fa5d2caae6f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
