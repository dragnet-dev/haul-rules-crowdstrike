// Dragnet [Ransomware]: dragnet-ransomware-2023-3243 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 332a5cea-94a1-5513-a37a-8683c2c7463e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
