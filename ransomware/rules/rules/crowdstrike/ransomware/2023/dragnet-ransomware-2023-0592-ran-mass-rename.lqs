// Dragnet [Ransomware]: dragnet-ransomware-2023-0592 — Mass File Rename (ransomed)
// Status: deprecated | Level: high | ID: 8edc4ed5-1ac9-5494-8e44-d394326a60b7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
