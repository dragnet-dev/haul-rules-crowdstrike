// Dragnet [Ransomware]: dragnet-ransomware-2024-5547 — Mass File Rename (abyss)
// Status: deprecated | Level: high | ID: 4e03fc28-3040-5129-b040-b04a5ff1b5e5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
