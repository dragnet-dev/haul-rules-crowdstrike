// Dragnet [Ransomware]: dragnet-ransomware-2024-3982 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 976d1166-e9fd-5bb2-a86f-79dc70b04c58

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
