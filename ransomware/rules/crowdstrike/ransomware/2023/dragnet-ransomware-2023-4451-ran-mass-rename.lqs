// Dragnet [Ransomware]: dragnet-ransomware-2023-4451 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 0d741fec-0aff-5bce-a7ae-510d637a9e7f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
