// Dragnet [Ransomware]: dragnet-ransomware-2022-2793 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 1721a4d6-039e-5642-a3c1-cf67738c42de

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
