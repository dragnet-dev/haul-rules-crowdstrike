// Dragnet [Ransomware]: dragnet-ransomware-2025-0877 — Mass File Rename (sinobi)
// Status: experimental | Level: high | ID: 3920663e-b58f-5f6c-b125-c3ceeb2cdd65

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
