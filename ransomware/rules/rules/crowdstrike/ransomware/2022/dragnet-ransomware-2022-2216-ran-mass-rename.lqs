// Dragnet [Ransomware]: dragnet-ransomware-2022-2216 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 0db1ade0-0dda-5215-ab2a-59fbc08e4f6b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
