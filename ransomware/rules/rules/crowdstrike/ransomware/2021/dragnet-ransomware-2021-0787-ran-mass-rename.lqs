// Dragnet [Ransomware]: dragnet-ransomware-2021-0787 — Mass File Rename (groove)
// Status: deprecated | Level: high | ID: 72704f37-4290-5369-ba30-d859ff0c86e0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
