// Dragnet [Ransomware]: dragnet-ransomware-2025-1443 — Mass File Rename (global)
// Status: deprecated | Level: high | ID: 8fcd0c1f-7e97-57c8-b005-74d42ce438a6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
