// Dragnet [Ransomware]: dragnet-ransomware-2023-4286 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 4ec1285f-70ae-56dc-9628-172298834151

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
