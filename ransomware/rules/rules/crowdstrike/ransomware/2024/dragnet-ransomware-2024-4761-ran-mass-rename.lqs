// Dragnet [Ransomware]: dragnet-ransomware-2024-4761 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: f254db87-c95a-5d3a-afbb-03f3f2228aba

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
