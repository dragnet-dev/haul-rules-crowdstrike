// Dragnet [Ransomware]: dragnet-ransomware-2022-0762 — Mass File Rename (royal)
// Status: deprecated | Level: high | ID: f782b7bb-22e7-58d1-9665-76d9dd2caf13

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
