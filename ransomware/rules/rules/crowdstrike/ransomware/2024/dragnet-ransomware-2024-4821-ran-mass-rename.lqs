// Dragnet [Ransomware]: dragnet-ransomware-2024-4821 — Mass File Rename (spacebears)
// Status: experimental | Level: high | ID: 67fa9ec3-34c8-59ea-ba6a-2766d9075de4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
