// Dragnet [Ransomware]: dragnet-ransomware-2021-0043 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 67e37b67-3b64-5b5a-a39f-e927fccd1322

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
