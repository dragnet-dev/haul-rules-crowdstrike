// Dragnet [Ransomware]: dragnet-ransomware-2025-2374 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: ed12a98d-43c3-54a9-a01c-b485161bc0f6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
