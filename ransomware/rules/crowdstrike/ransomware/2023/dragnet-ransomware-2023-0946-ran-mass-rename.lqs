// Dragnet [Ransomware]: dragnet-ransomware-2023-0946 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 33c93528-07c0-5020-9121-4c2bf7ed1f73

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
