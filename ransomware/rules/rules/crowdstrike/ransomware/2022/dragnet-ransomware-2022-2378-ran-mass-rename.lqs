// Dragnet [Ransomware]: dragnet-ransomware-2022-2378 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: fbfd8113-5644-564b-9018-aa6ca2e7ba16

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
