// Dragnet [Ransomware]: dragnet-ransomware-2025-2436 — Mass File Rename (thegentlemen)
// Status: experimental | Level: high | ID: dfb739d4-876e-5179-be7d-bef016c2bc15

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
