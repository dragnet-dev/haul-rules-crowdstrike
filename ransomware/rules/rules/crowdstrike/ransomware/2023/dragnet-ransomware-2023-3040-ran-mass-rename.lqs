// Dragnet [Ransomware]: dragnet-ransomware-2023-3040 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 4cbe301a-eea9-5991-a3fa-1b7181436de8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
