// Dragnet [Ransomware]: dragnet-ransomware-2023-1823 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: ac21201c-3660-57ec-8a3e-4adce2ba6af5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
