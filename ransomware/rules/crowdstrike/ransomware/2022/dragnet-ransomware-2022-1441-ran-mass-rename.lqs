// Dragnet [Ransomware]: dragnet-ransomware-2022-1441 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 49714b93-2986-5ecf-9600-2b5aa40fca34

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
