// Dragnet [Container]: dragnet-container-2026-2206 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 1cf660cd-72a1-5ab6-946d-b41df9535e99

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:5*)
| table([timestamp, ComputerName])
| limit(1000)
