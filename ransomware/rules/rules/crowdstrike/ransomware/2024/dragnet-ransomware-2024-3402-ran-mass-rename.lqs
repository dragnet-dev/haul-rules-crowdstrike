// Dragnet [Ransomware]: dragnet-ransomware-2024-3402 — Mass File Rename (raworld)
// Status: experimental | Level: high | ID: 88a52bf7-65fb-5a6b-b6d5-512c65e54c1d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
