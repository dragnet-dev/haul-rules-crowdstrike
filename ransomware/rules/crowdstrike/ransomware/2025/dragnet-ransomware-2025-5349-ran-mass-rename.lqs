// Dragnet [Ransomware]: dragnet-ransomware-2025-5349 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 403d33f0-818e-5eff-a108-5cb9fcb2b42c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
