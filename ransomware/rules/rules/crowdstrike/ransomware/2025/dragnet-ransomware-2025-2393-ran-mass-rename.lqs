// Dragnet [Ransomware]: dragnet-ransomware-2025-2393 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: a0790d46-80a0-5ea8-aff3-09cad8d492b2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
