// Dragnet [Ransomware]: dragnet-ransomware-2025-6528 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: d28854a4-0482-5e35-be68-1cfd23a69faf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
