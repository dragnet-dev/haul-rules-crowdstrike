// Dragnet [Ransomware]: dragnet-ransomware-2025-5182 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 5f5c3876-31d0-5ba8-bd6f-f1247bd16c55

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
