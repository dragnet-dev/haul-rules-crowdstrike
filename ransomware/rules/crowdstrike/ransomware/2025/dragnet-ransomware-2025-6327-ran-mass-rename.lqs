// Dragnet [Ransomware]: dragnet-ransomware-2025-6327 — Mass File Rename (genesis)
// Status: experimental | Level: high | ID: c336354d-239c-5db9-ae84-11cf70267c7d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
