// Dragnet [Ransomware]: dragnet-ransomware-2025-2885 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: 3b9bad4d-6561-5c5e-bdfc-320052c2387c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
