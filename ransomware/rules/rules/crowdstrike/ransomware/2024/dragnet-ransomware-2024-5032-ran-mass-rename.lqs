// Dragnet [Ransomware]: dragnet-ransomware-2024-5032 — Mass File Rename (ransomexx)
// Status: experimental | Level: high | ID: 5f459518-ea9b-5917-ae4e-5bce9c1f2f2e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
