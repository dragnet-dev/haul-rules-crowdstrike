// Dragnet [Ransomware]: dragnet-ransomware-2022-3130 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 08b9591d-c1b1-5a06-9882-99b8b139cd40

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
