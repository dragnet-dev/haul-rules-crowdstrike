// Dragnet [Ransomware]: dragnet-ransomware-2022-1113 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: f66cf8be-8aec-5220-9ed9-9825e4b65cff

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
