// Dragnet [Ransomware]: dragnet-ransomware-2020-0028 — Mass File Rename (ragnarlocker)
// Status: deprecated | Level: high | ID: 645ca5be-b574-5663-85d6-1a9a696779f9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
