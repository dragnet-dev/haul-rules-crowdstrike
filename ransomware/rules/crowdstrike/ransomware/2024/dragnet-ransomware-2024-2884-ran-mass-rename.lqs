// Dragnet [Ransomware]: dragnet-ransomware-2024-2884 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 2a84d002-6b78-5bfa-8919-62fc92b9a30e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
