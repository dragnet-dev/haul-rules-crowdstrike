// Dragnet [Ransomware]: dragnet-ransomware-2021-1457 — Mass File Rename (avaddon)
// Status: deprecated | Level: high | ID: 696b4678-29e9-5162-bdd1-453232963753

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
