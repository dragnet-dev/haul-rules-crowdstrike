// Dragnet [Ransomware]: dragnet-ransomware-2024-4872 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 519e22bb-bb96-530d-bf9a-adbdcfac75ef

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
