// Dragnet [Ransomware]: dragnet-ransomware-2024-3439 — Mass File Rename (meow)
// Status: experimental | Level: high | ID: 0e759a5e-d9ea-5032-977b-ecc38453ca33

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
