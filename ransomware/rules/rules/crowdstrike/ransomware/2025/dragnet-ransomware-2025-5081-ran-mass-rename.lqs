// Dragnet [Ransomware]: dragnet-ransomware-2025-5081 — Mass File Rename (warlock)
// Status: deprecated | Level: high | ID: 81ea4f61-168c-5642-8b1c-591d567b6f73

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
