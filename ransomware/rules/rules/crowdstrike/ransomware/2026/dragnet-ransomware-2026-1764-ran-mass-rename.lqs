// Dragnet [Ransomware]: dragnet-ransomware-2026-1764 — Mass File Rename (embargo)
// Status: stable | Level: high | ID: f9ef0f0b-01a4-58a3-96e7-1ea9989e2636

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
