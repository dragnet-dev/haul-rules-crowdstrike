// Dragnet [Ransomware]: dragnet-ransomware-2023-2142 — Mass File Rename (losttrust)
// Status: deprecated | Level: high | ID: 0389d48d-fbdb-510e-9ce4-7a34e7e86ee3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
