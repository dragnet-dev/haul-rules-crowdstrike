// Dragnet [Ransomware]: dragnet-ransomware-2025-2984 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 8ca09554-ab49-546a-b099-65ab2bca0ede

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
