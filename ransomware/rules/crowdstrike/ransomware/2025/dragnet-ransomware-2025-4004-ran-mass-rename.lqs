// Dragnet [Ransomware]: dragnet-ransomware-2025-4004 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 0965516a-2885-5871-bd16-a3217efc2d8b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
