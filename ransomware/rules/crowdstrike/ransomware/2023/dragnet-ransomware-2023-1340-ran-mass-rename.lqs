// Dragnet [Ransomware]: dragnet-ransomware-2023-1340 — Mass File Rename (monti)
// Status: experimental | Level: high | ID: 98b4a441-b537-5230-952d-83238f946bf4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
