// Dragnet [Container]: dragnet-container-2026-0890 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: d3c9e9b9-92ac-53e6-92e9-789e604e969a

#event_simpleName=*
| (ImageFileName = *amazonlinux:1* OR ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10* OR ImageFileName = *ubuntu:13.04*)
| table([timestamp, ComputerName])
| limit(1000)
