// Dragnet [Ransomware]: dragnet-ransomware-2021-1344 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 62e1f8e7-921e-53f2-bd8c-2c37444c1f3d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
