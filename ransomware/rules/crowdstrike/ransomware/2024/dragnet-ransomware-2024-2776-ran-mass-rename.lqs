// Dragnet [Ransomware]: dragnet-ransomware-2024-2776 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 7afc26d1-7e5f-5ab0-a203-6d5bff3dab4a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
