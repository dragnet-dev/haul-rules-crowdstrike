// Dragnet [Ransomware]: dragnet-ransomware-2023-4629 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 30f84291-0df0-560d-ae32-08786eae7f7a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
