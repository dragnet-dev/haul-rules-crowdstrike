// Dragnet [Ransomware]: dragnet-ransomware-2025-0976 — Mass File Rename (blackshrantac)
// Status: experimental | Level: high | ID: 88364bfb-3531-5c65-96e3-692d0dd12df0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
