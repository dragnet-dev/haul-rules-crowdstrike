// Dragnet [Ransomware]: dragnet-ransomware-2025-5173 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 4e5560c9-508b-5a71-a0bf-9b4dcc3747f2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
