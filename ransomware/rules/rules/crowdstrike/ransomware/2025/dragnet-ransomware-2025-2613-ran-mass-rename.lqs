// Dragnet [Ransomware]: dragnet-ransomware-2025-2613 — Mass File Rename (interlock)
// Status: experimental | Level: high | ID: 1918aa3e-862b-53c3-918b-4c0a7262c329

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
