// Dragnet [Ransomware]: dragnet-ransomware-2025-6384 — Mass File Rename (play)
// Status: experimental | Level: high | ID: b8096f5d-72c6-563f-9328-b303d08f6b4a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
