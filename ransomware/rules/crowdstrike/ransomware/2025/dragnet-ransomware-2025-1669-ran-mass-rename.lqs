// Dragnet [Ransomware]: dragnet-ransomware-2025-1669 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 5ce36771-eae5-507a-8897-7fd3e2b38553

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
