// Dragnet [Ransomware]: dragnet-ransomware-2024-3589 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 03211aec-404c-5487-a6f6-594985593664

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
