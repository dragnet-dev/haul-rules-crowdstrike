// Dragnet [Ransomware]: dragnet-ransomware-2026-1075 — Mass File Rename (thegentlemen)
// Status: stable | Level: high | ID: 36622c9d-f8c4-5d96-aa47-408ec9284014

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
