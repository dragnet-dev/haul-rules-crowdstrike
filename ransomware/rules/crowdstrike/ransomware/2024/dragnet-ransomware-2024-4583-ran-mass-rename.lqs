// Dragnet [Ransomware]: dragnet-ransomware-2024-4583 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 2b5dbc4c-2637-5ca6-81a3-a95edf96da2e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
