// Dragnet [Ransomware]: dragnet-ransomware-2024-5008 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 5b0f518e-ee7f-5b3b-aa33-6c1aae938c0c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
