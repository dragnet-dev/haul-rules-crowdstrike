// Dragnet [Ransomware]: dragnet-ransomware-2024-5345 — Mass File Rename (arcusmedia)
// Status: experimental | Level: high | ID: 65a374ff-bb7b-56bc-81e2-e8386666dcf7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
