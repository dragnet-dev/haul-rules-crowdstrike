// Dragnet [Ransomware]: dragnet-ransomware-2024-3749 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: d0604ab1-5174-59c9-b6c6-736681bcfdcc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
