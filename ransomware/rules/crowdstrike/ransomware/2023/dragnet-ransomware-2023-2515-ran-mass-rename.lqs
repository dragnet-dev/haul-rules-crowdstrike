// Dragnet [Ransomware]: dragnet-ransomware-2023-2515 — Mass File Rename (qilin)
// Status: deprecated | Level: high | ID: a08b7c3e-6a0c-568e-8d41-a032d00126a9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
