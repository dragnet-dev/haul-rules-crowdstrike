// Dragnet [Container]: dragnet-container-2024-0263 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 0d86b82d-1448-59f7-903a-54bdbf1490cf

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
