// Dragnet [Ransomware]: dragnet-ransomware-2025-0662 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 2b7414ef-9251-5f4c-8ff0-4dac639624ee

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
