// Dragnet [Ransomware]: dragnet-ransomware-2022-0161 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: acdcc9e4-7264-5024-ae4f-c81327856e3b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
