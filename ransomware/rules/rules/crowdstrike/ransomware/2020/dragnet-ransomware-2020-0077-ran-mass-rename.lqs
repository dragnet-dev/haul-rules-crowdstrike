// Dragnet [Ransomware]: dragnet-ransomware-2020-0077 — Mass File Rename (doppelpaymer)
// Status: deprecated | Level: high | ID: dd19605b-35f2-5611-b274-0f2c15af794e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
