// Dragnet [Ransomware]: dragnet-ransomware-2025-4699 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 40a60677-96f6-5e89-8e74-18c676339abf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
