// Dragnet [Ransomware]: dragnet-ransomware-2022-2627 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 7c11a935-5a48-5b6b-8836-ed8b6bc27707

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
