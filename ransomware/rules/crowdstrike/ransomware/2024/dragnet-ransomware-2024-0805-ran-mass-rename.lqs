// Dragnet [Ransomware]: dragnet-ransomware-2024-0805 — Mass File Rename (handala)
// Status: experimental | Level: high | ID: 403736a1-fd6c-5c2d-840a-01ab0da6d8fa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
