// Dragnet [Ransomware]: dragnet-ransomware-2025-3378 — Mass File Rename (anubis)
// Status: experimental | Level: high | ID: 41bec84a-01d9-5fe8-bad3-7996d0c1f9e4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
