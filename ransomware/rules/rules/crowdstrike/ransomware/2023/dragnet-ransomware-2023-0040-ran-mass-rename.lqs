// Dragnet [Ransomware]: dragnet-ransomware-2023-0040 — Mass File Rename (toufan)
// Status: deprecated | Level: high | ID: c56de6dc-915b-51a7-9310-569eca488a83

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
