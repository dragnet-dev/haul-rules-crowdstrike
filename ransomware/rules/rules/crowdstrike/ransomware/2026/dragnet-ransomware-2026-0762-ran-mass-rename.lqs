// Dragnet [Ransomware]: dragnet-ransomware-2026-0762 — Mass File Rename (SilentRansomGroup)
// Status: deprecated | Level: high | ID: 6f225afd-6caa-5027-b57d-2f7ee67bcd5b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
