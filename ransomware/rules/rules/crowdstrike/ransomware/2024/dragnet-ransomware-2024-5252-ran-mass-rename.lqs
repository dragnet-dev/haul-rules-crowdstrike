// Dragnet [Ransomware]: dragnet-ransomware-2024-5252 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 617c16a6-bbae-52e3-8d27-30197332a4e6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
