// Dragnet [Ransomware]: dragnet-ransomware-2024-5289 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: 2a86926e-da97-5d21-bca9-44d21c4ddc57

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
