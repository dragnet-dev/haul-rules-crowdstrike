// Dragnet [Ransomware]: dragnet-ransomware-2024-3107 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: bd93181b-8fb5-5a2a-9d96-d095f2f4643b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
