// Dragnet [Ransomware]: dragnet-ransomware-2021-0221 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: f8b97ab3-1a2c-537b-ad42-b70f9422438f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
