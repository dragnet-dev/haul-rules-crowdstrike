// Dragnet [Ransomware]: dragnet-ransomware-2024-4222 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: a25de24c-8923-5e04-a92a-679c4fb2f93a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
