// Dragnet [Ransomware]: dragnet-ransomware-2025-3113 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 7cecce71-7e97-527d-84b9-bea5541d9924

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
