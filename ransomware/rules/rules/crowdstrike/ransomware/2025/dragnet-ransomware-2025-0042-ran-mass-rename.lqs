// Dragnet [Ransomware]: dragnet-ransomware-2025-0042 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: d2ad639c-e21d-5eb9-9ab7-fff286631250

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
