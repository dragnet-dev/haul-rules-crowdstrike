// Dragnet [Ransomware]: dragnet-ransomware-2025-1865 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: cf1baa7d-c7c7-557e-b645-2ce0a20f8751

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
