// Dragnet [Ransomware]: dragnet-ransomware-2024-5322 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: a208e7ca-2708-51c6-92c6-2b37768de529

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
