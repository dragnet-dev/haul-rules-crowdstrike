// Dragnet [Ransomware]: dragnet-ransomware-2024-0024 — Mass File Rename (stormous)
// Status: deprecated | Level: high | ID: a7e881ae-2e6d-537e-9e65-de3e98a61ece

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
