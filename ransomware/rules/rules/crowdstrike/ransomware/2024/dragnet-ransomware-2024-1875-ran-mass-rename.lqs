// Dragnet [Ransomware]: dragnet-ransomware-2024-1875 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: a0347ca5-776a-5763-8b39-7c12a29a0ca9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
