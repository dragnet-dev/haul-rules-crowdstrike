// Dragnet [Ransomware]: dragnet-ransomware-2023-5120 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 79652c54-e746-594f-a9f1-ad26870c5be2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
