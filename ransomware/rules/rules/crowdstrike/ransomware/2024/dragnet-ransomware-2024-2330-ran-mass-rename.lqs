// Dragnet [Ransomware]: dragnet-ransomware-2024-2330 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 1473363b-8f3d-58d4-a389-dc9cad1adf7c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
