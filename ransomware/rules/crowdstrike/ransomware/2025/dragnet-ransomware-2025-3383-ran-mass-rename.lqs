// Dragnet [Ransomware]: dragnet-ransomware-2025-3383 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: 5bfcef63-0408-5447-a218-5af9ff940df2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
