// Dragnet [Ransomware]: dragnet-ransomware-2021-0335 — Mass File Rename (avaddon)
// Status: deprecated | Level: high | ID: 4d0e504b-c3b3-5cf0-b5b9-351dbf643801

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
