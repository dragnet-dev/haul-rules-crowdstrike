// Dragnet [Ransomware]: dragnet-ransomware-2026-2745 — Mass File Rename (lockbit5)
// Status: stable | Level: high | ID: 4bdd2d1d-802c-5864-9e47-74ae3007d07e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
