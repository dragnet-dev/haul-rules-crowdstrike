// Dragnet [Ransomware]: dragnet-ransomware-2021-0382 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: a56dea57-acd5-5410-a028-6a7f5acffac1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
