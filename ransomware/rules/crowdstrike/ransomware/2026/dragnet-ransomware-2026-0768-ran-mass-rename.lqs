// Dragnet [Ransomware]: dragnet-ransomware-2026-0768 — Mass File Rename (dragonforce)
// Status: stable | Level: high | ID: e298e8b0-be8a-5146-8114-1170d842991e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
