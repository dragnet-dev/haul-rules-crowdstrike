// Dragnet [Ransomware]: dragnet-ransomware-2025-6383 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: e57f9a4a-1f85-5a72-bf32-9baa0bb26aa6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
