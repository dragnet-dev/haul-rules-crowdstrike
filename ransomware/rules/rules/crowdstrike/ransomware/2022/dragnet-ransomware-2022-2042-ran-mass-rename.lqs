// Dragnet [Ransomware]: dragnet-ransomware-2022-2042 — Mass File Rename (revil)
// Status: deprecated | Level: high | ID: fe2f6946-74ae-5e05-9711-979f27796da9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
