// Dragnet [Ransomware]: dragnet-ransomware-2024-0580 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 155cca05-f048-53ac-bb64-0f98c58262fe

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
