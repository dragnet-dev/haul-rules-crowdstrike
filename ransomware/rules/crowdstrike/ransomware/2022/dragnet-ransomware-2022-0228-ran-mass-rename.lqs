// Dragnet [Ransomware]: dragnet-ransomware-2022-0228 — Mass File Rename (vicesociety)
// Status: deprecated | Level: high | ID: de969657-5755-57a3-99a8-962258e9967c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
