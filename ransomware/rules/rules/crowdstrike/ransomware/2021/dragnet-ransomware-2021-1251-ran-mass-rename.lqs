// Dragnet [Ransomware]: dragnet-ransomware-2021-1251 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 435d9f4f-71b9-5d8e-a903-fa96be780389

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
