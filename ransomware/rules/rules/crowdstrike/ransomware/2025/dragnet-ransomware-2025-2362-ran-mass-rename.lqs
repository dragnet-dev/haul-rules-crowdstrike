// Dragnet [Ransomware]: dragnet-ransomware-2025-2362 — Mass File Rename (securotrop)
// Status: experimental | Level: high | ID: 977ac55d-9e37-51d8-9a41-46c5d6458c19

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
