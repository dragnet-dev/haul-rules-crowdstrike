// Dragnet [Ransomware]: dragnet-ransomware-2022-2910 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: dedf3fb9-6380-5dea-8f89-d6fce180624e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
