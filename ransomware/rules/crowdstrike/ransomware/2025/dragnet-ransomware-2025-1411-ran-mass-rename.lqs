// Dragnet [Ransomware]: dragnet-ransomware-2025-1411 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: b09e4653-ea2d-50fc-877a-ea032fe3a8b9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
