// Dragnet [Ransomware]: dragnet-ransomware-2023-0228 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: abcacefb-2735-5745-8edf-ec27bc34cb88

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
