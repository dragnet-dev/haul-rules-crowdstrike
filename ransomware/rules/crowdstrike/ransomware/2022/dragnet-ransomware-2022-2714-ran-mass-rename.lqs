// Dragnet [Ransomware]: dragnet-ransomware-2022-2714 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 2801ba1c-6e86-533b-8cde-385b12368c8d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
