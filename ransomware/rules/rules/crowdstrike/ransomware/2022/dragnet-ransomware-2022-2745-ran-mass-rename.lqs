// Dragnet [Ransomware]: dragnet-ransomware-2022-2745 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 956f19b8-6aa3-5965-a79c-2f8df1f13ccb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
