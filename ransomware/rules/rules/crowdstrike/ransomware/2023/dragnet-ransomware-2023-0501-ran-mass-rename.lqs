// Dragnet [Ransomware]: dragnet-ransomware-2023-0501 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 944b9b78-11ae-58c1-80cf-f0bbd807ec4c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
