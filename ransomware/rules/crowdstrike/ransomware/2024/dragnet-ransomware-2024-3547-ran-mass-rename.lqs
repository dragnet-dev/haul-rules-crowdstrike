// Dragnet [Ransomware]: dragnet-ransomware-2024-3547 — Mass File Rename (cicada3301)
// Status: experimental | Level: high | ID: 1b8d90cc-87c3-5ece-a36c-5ccb3002dbbd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
