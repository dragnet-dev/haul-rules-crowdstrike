// Dragnet [Ransomware]: dragnet-ransomware-2025-4021 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: 2ce4209c-885c-5ecd-afcc-fd21c44b8571

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
