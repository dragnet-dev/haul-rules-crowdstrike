// Dragnet [Ransomware]: dragnet-ransomware-2025-3692 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 8f2fc74d-bcd0-5e65-a14c-38b958ea886d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
