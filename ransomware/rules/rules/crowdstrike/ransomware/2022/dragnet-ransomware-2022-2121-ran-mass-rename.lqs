// Dragnet [Ransomware]: dragnet-ransomware-2022-2121 — Mass File Rename (snatch)
// Status: deprecated | Level: high | ID: a5cb8c95-a2fb-5471-b555-5f42f30aeea3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
