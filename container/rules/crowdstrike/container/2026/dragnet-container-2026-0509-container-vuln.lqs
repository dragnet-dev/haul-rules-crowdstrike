// Dragnet [Container]: dragnet-container-2026-0509 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 97a53979-3ac9-5232-8db2-2e42c54707e6

#event_simpleName=*
| (ImageFileName = *amazonlinux:1* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:5* OR ImageFileName = *redhat/ubi9:*)
| table([timestamp, ComputerName])
| limit(1000)
