// Dragnet [Ransomware]: dragnet-ransomware-2024-4801 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 93479e42-9ef0-5a9b-b1f5-315bc21b700c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
