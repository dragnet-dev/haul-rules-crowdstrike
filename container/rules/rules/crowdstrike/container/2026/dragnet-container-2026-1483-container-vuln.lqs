// Dragnet [Container]: dragnet-container-2026-1483 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 5963c52d-a2aa-5ecb-9183-0e53d55fcb86

#event_simpleName=*
| (ImageFileName = *azure linux:3.0* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
