// Dragnet [Container]: dragnet-container-2024-0997 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 2cbca022-4be9-58c0-8d0a-5422ed8515eb

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
