// Dragnet [Ransomware]: dragnet-ransomware-2021-0780 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 5436b41d-c3b0-5fe8-8e40-f8d760832b85

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
