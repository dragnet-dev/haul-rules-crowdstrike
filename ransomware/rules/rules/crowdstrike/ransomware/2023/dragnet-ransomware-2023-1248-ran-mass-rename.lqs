// Dragnet [Ransomware]: dragnet-ransomware-2023-1248 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 639984e0-12b9-563a-b1be-b22d76bd6a88

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
