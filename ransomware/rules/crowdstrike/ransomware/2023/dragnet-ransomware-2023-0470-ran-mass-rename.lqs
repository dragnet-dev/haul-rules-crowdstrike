// Dragnet [Ransomware]: dragnet-ransomware-2023-0470 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 4b2cec70-a359-5c04-aa40-d63ad51c711a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
