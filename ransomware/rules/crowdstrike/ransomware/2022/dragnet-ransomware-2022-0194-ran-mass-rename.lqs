// Dragnet [Ransomware]: dragnet-ransomware-2022-0194 — Mass File Rename (leaktheanalyst)
// Status: deprecated | Level: high | ID: ea06e745-9711-5f89-bbc5-8c44742803b2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
