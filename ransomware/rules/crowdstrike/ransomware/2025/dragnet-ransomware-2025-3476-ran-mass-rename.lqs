// Dragnet [Ransomware]: dragnet-ransomware-2025-3476 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 26b6e98c-5f93-5ec9-ae3a-3c06558bff1b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
