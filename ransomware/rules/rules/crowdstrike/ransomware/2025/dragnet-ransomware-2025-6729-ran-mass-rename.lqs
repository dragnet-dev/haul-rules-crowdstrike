// Dragnet [Ransomware]: dragnet-ransomware-2025-6729 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: d510bab0-b562-5bdf-bc6f-343ef3a0afae

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
