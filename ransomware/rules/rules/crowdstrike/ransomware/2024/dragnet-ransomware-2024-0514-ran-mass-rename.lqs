// Dragnet [Ransomware]: dragnet-ransomware-2024-0514 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 356647dc-e856-57f2-a79c-e474d0f80890

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
