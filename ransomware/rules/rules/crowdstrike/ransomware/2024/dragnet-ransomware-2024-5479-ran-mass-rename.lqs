// Dragnet [Ransomware]: dragnet-ransomware-2024-5479 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 2d29c6cd-bdca-5a5c-8b83-f5b590fd07bc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
