// Dragnet [Ransomware]: dragnet-ransomware-2025-5657 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: ae64e0f2-9a8d-56ac-9321-1257b525e43f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
