// Dragnet [Ransomware]: dragnet-ransomware-2023-1112 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 3d9c9e05-6518-5a5e-976c-398c82e00625

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
