// Dragnet [Ransomware]: dragnet-ransomware-2026-1898 — Mass File Rename (incransom)
// Status: test | Level: high | ID: 158b2c00-c8af-5c6c-9996-3a0f0899c731

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
