// Dragnet [Ransomware]: dragnet-ransomware-2023-3650 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 1daa2025-5137-5872-a7ea-0c81cc54d8a6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
