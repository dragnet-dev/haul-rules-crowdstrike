// Dragnet [Ransomware]: dragnet-ransomware-2025-1769 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 9ec1e955-4a1a-5bf3-8920-54de3cf4dd05

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
