// Dragnet [Container]: dragnet-container-2026-3015 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 218baa03-458d-56ab-acbd-d1ac9b446ff8

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
