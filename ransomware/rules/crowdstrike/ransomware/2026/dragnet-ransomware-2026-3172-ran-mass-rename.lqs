// Dragnet [Ransomware]: dragnet-ransomware-2026-3172 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: ac788408-4e3d-5b44-a4a4-ae7dec6929a5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
