// Dragnet [Ransomware]: dragnet-ransomware-2025-5426 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: a7986c6d-7c80-5aac-b3cb-777aa2908131

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
