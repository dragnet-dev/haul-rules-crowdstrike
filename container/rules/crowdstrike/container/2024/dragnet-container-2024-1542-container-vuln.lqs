// Dragnet [Container]: dragnet-container-2024-1542 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 8cd58d83-c2d3-5f22-9afe-cd9b55942a6f

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:9*)
| table([timestamp, ComputerName])
| limit(1000)
