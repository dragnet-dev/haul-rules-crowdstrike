// Dragnet [Ransomware]: dragnet-ransomware-2025-3821 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 30b81f31-400a-56a5-ba53-a60460f1efdf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
