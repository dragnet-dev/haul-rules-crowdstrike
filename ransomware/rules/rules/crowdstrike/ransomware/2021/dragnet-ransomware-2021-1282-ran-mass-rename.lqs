// Dragnet [Ransomware]: dragnet-ransomware-2021-1282 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 6c411c1a-d2a2-59b5-ab58-2b4be1429af4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
