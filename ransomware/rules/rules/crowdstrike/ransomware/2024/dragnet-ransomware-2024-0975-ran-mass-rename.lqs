// Dragnet [Ransomware]: dragnet-ransomware-2024-0975 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 42892011-31fc-5351-8a49-bd611e8ed91b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
