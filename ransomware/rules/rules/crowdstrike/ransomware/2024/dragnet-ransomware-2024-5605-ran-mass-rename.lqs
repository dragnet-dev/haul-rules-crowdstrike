// Dragnet [Ransomware]: dragnet-ransomware-2024-5605 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 7ec43952-0bd8-594d-b4d6-f0a010f29fb2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
