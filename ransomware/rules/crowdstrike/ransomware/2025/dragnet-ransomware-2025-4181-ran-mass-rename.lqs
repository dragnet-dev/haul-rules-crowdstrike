// Dragnet [Ransomware]: dragnet-ransomware-2025-4181 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 694bd413-fe4c-50bf-908d-b9dce3ba011b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
