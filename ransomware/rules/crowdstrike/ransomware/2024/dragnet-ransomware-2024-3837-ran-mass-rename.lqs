// Dragnet [Ransomware]: dragnet-ransomware-2024-3837 — Mass File Rename (raworld)
// Status: experimental | Level: high | ID: 9ffa94c8-a89a-50c1-9ad2-532647d6a8b2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
