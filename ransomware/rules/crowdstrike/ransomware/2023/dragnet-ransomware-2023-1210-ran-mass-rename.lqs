// Dragnet [Ransomware]: dragnet-ransomware-2023-1210 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 9452fecd-eb91-5fc6-845e-7e207e3985ad

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
