// Dragnet [Ransomware]: dragnet-ransomware-2026-0350 — Mass File Rename (safepay)
// Status: stable | Level: high | ID: 221d1ec0-87e7-5fcf-97ae-78cf9fb78545

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
