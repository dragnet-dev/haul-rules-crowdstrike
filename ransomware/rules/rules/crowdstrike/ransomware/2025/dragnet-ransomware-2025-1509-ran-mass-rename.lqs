// Dragnet [Ransomware]: dragnet-ransomware-2025-1509 — Mass File Rename (dragonforce)
// Status: test | Level: high | ID: f5677160-9c8c-5b29-9384-3166d66b3009

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
