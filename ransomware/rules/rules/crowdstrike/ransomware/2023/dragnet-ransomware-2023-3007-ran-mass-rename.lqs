// Dragnet [Ransomware]: dragnet-ransomware-2023-3007 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: d7eb8c67-5bf1-5391-b5f7-eb7a4509e91e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
