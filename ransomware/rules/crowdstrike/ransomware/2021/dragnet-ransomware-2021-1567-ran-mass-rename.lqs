// Dragnet [Ransomware]: dragnet-ransomware-2021-1567 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: d807f081-37f5-5f60-8537-23eed181fe61

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
