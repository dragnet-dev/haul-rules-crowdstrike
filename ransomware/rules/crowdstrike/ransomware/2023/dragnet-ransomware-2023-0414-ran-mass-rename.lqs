// Dragnet [Ransomware]: dragnet-ransomware-2023-0414 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 82d22338-ed52-5d24-812c-c8544c3d2928

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
