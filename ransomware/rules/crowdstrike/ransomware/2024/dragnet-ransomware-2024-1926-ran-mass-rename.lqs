// Dragnet [Ransomware]: dragnet-ransomware-2024-1926 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 16c982b5-313f-5f57-a5b1-7b011ebf47ac

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
