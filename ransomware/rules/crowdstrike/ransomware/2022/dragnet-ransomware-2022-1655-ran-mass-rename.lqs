// Dragnet [Ransomware]: dragnet-ransomware-2022-1655 — Mass File Rename (everest)
// Status: deprecated | Level: high | ID: 4fe9dc7c-d2e3-590d-bfdf-dff79038ee2e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
