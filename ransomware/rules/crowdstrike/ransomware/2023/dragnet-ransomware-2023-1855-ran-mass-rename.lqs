// Dragnet [Ransomware]: dragnet-ransomware-2023-1855 — Mass File Rename (ransomed)
// Status: experimental | Level: high | ID: 97644cd5-352c-5803-bd9b-f04f33b7ce13

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
