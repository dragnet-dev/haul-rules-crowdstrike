// Dragnet [Ransomware]: dragnet-ransomware-2024-5326 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: a2763213-6973-5b73-928c-319b021253c4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
