// Dragnet [Ransomware]: dragnet-ransomware-2024-2266 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 40fe2e60-ee90-593c-9d3d-fa1aa90cb48e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
