// Dragnet [Ransomware]: dragnet-ransomware-2025-4333 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 6e6bd417-9ad5-5abe-af44-4649f3bd059a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
