// Dragnet [Container]: dragnet-container-2025-0070 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 534ca1dc-7029-51b4-98b4-91f4ad8a9e8d

#event_simpleName=*
| (ImageFileName = *almalinux:8* OR ImageFileName = *alpine:3.18* OR ImageFileName = *alpine:3.19* OR ImageFileName = *alpine:3.20* OR ImageFileName = *alpine:3.21* OR ImageFileName = *alpine:3.22* OR ImageFileName = *alpine:3.23* OR ImageFileName = *alpine edge:* OR ImageFileName = *chainguard:* OR ImageFileName = *oraclelinux:8* OR ImageFileName = *photon os:5.0* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
