// Dragnet [Ransomware]: dragnet-ransomware-2023-4445 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 381de06a-4baf-540d-ac05-bdae9e25e5a1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
