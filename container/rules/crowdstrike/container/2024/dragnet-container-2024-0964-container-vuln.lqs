// Dragnet [Container]: dragnet-container-2024-0964 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 49b1d48b-0878-5e07-9486-9bccfbc71cfa

#event_simpleName=*
| (ImageFileName = *almalinux:9* OR ImageFileName = *cbl-mariner:2.0* OR ImageFileName = *debian:10* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:9* OR ImageFileName = *ubuntu:16.04-ESM* OR ImageFileName = *ubuntu:18.04-ESM* OR ImageFileName = *ubuntu:20.04* OR ImageFileName = *ubuntu:20.04-ESM* OR ImageFileName = *ubuntu:22.04* OR ImageFileName = *ubuntu:23.04*)
| table([timestamp, ComputerName])
| limit(1000)
