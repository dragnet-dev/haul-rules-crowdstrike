// Dragnet [Ransomware]: dragnet-ransomware-2022-1476 — Mass File Rename (redalert)
// Status: deprecated | Level: high | ID: 1cb576c1-9a11-5a1d-a7a8-655ea1143314

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
