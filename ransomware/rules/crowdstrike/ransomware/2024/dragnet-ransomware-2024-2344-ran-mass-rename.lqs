// Dragnet [Ransomware]: dragnet-ransomware-2024-2344 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 6298a90f-c16c-5f64-aeb4-8ce326efff72

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
