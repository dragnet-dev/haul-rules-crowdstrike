// Dragnet [Ransomware]: dragnet-ransomware-2025-1497 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 1013b54a-551c-5183-99a4-1370adb9269a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
