// Dragnet [Ransomware]: dragnet-ransomware-2023-4350 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 7895a700-b098-5591-a879-f910dd38d871

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
