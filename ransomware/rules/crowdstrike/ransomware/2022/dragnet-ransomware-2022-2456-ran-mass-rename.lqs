// Dragnet [Ransomware]: dragnet-ransomware-2022-2456 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: dea95b55-05fb-530c-a4b7-657002871659

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
