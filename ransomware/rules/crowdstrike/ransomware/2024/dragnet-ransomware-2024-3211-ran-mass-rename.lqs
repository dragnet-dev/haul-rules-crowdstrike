// Dragnet [Ransomware]: dragnet-ransomware-2024-3211 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: b5d86aeb-daf8-5797-b880-bd370720ace0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
