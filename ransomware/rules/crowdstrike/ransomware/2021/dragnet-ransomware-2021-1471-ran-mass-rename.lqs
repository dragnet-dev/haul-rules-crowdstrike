// Dragnet [Ransomware]: dragnet-ransomware-2021-1471 — Mass File Rename (vicesociety)
// Status: deprecated | Level: high | ID: 70688863-aa56-5ad7-bea2-cc1814de6dfb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
