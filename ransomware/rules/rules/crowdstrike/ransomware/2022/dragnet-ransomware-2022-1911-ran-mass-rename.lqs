// Dragnet [Ransomware]: dragnet-ransomware-2022-1911 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: a6695ecc-1bb9-52c2-8f19-abf299917bec

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
