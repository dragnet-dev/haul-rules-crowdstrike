// Dragnet [Ransomware]: dragnet-ransomware-2024-5840 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: 6d378c48-cd9c-520b-9a91-8fbe86ba01e9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
