// Dragnet [Ransomware]: dragnet-ransomware-2023-2024 — Mass File Rename (royal)
// Status: experimental | Level: high | ID: 38b8f955-611a-5328-b47e-4f6aebf23cfa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
