// Dragnet [Ransomware]: dragnet-ransomware-2025-1898 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 893ce11c-f7a4-5932-93f4-4215c012f17b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
