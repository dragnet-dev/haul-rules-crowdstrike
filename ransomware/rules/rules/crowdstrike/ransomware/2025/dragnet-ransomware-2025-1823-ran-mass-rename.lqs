// Dragnet [Ransomware]: dragnet-ransomware-2025-1823 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 4f7921e2-c4ad-57d0-a785-3d080ab2f0cb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
