// Dragnet [Ransomware]: dragnet-ransomware-2022-3039 — Mass File Rename (icefire)
// Status: deprecated | Level: high | ID: 8907b0b0-f191-5932-afa2-10182b3242a8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
