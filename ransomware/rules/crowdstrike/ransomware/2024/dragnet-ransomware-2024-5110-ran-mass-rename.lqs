// Dragnet [Ransomware]: dragnet-ransomware-2024-5110 — Mass File Rename (spacebears)
// Status: experimental | Level: high | ID: da63755e-4608-5810-ba9a-24da9227370a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
