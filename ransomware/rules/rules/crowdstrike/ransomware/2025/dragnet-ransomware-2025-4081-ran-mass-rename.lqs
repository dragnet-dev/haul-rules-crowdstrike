// Dragnet [Ransomware]: dragnet-ransomware-2025-4081 — Mass File Rename (J)
// Status: experimental | Level: high | ID: 7f966e4e-7336-5a3a-84ca-30094860df12

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
