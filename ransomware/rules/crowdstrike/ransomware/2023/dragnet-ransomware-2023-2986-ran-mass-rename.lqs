// Dragnet [Ransomware]: dragnet-ransomware-2023-2986 — Mass File Rename (play)
// Status: experimental | Level: high | ID: e3cc6a50-322c-5769-b991-fe7ef86b1ac4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
