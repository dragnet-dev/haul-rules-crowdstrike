// Dragnet [Ransomware]: dragnet-ransomware-2023-5011 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 4388bebd-b3d2-5035-bac8-e40ef4aad51b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
