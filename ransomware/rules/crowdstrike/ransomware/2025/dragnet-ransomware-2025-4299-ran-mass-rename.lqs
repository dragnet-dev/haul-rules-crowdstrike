// Dragnet [Ransomware]: dragnet-ransomware-2025-4299 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 05b33018-b18b-5a17-bbd9-1a5c21ac3a6f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
