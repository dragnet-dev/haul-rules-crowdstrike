// Dragnet [Ransomware]: dragnet-ransomware-2024-3771 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: f88d5534-da8f-519a-82be-65812180fd79

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
