// Dragnet [Ransomware]: dragnet-ransomware-2020-0026 — Mass File Rename (revil)
// Status: deprecated | Level: high | ID: 7b702ced-0fcf-5c87-8b4a-de164ef6e33e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
