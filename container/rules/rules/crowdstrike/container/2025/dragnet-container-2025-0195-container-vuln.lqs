// Dragnet [Container]: dragnet-container-2025-0195 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: e02d58dd-68c4-5d6b-8985-b2a42752e992

#event_simpleName=*
| (ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *ubuntu:22.04* OR ImageFileName = *ubuntu:24.04* OR ImageFileName = *ubuntu:25.04* OR ImageFileName = *ubuntu:25.10* OR ImageFileName = *ubuntu:26.04*)
| table([timestamp, ComputerName])
| limit(1000)
