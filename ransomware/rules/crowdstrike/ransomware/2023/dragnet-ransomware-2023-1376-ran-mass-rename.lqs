// Dragnet [Ransomware]: dragnet-ransomware-2023-1376 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: fcf97860-6ef1-5c20-b564-b97be5f6aa42

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
