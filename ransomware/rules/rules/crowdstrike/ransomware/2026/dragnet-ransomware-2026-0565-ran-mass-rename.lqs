// Dragnet [Ransomware]: dragnet-ransomware-2026-0565 — Mass File Rename (incransom)
// Status: stable | Level: high | ID: ac71a259-db4f-59b2-967d-38800906d713

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
