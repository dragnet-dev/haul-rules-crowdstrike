// Dragnet [Ransomware]: dragnet-ransomware-2024-5566 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 8a9ac8b3-0bfa-59d9-ad32-e82d4664ba90

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
