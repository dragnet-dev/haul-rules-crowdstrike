// Dragnet [Ransomware]: dragnet-ransomware-2024-5000 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 3b056e11-1f07-5266-b18e-02261c509ec9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
