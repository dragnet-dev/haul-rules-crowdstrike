// Dragnet [Ransomware]: dragnet-ransomware-2024-2917 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 6ba28bfa-04a6-5944-85c9-105b2cf6c004

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
