// Dragnet [Ransomware]: dragnet-ransomware-2025-4585 — Mass File Rename (worldleaks)
// Status: experimental | Level: high | ID: 17cc478a-1c8c-590f-b0e1-fd61395d0393

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
