// Dragnet [Ransomware]: dragnet-ransomware-2025-6575 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 6a651616-7dd6-5374-9a33-527d1be7e8a4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
