// Dragnet [Ransomware]: dragnet-ransomware-2024-2417 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: f2900303-f6b0-55da-84fc-6e8f5d531beb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
