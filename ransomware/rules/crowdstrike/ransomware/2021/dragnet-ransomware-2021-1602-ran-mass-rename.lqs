// Dragnet [Ransomware]: dragnet-ransomware-2021-1602 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 25e7f2d4-1ddd-53fa-a46f-a5dc252f1e51

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
