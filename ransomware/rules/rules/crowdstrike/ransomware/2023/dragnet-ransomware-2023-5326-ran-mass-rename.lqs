// Dragnet [Ransomware]: dragnet-ransomware-2023-5326 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: a6d5ff12-69ab-564f-9d97-d7327da54569

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
