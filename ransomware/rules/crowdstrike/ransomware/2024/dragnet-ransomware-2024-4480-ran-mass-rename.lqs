// Dragnet [Ransomware]: dragnet-ransomware-2024-4480 — Mass File Rename (safepay)
// Status: deprecated | Level: high | ID: a258ccf0-c7c2-57db-a106-fae5b2b20cff

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
