// Dragnet [Ransomware]: dragnet-ransomware-2023-1356 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: d430c630-c6be-51d0-a5b3-2067766abaee

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
