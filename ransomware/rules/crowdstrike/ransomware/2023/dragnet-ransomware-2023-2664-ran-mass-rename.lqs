// Dragnet [Ransomware]: dragnet-ransomware-2023-2664 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: e9926804-f3ed-5adb-95af-8120d1acb977

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
