// Dragnet [Ransomware]: dragnet-ransomware-2025-6966 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 20e80e21-f90c-5609-9101-36414f2dbb9a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
