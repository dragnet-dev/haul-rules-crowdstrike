// Dragnet [Ransomware]: dragnet-ransomware-2024-2463 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: d461a4c8-a1cb-5526-aec3-17ebeac74dbc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
