// Dragnet [Ransomware]: dragnet-ransomware-2025-3719 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: ea0d7cb8-e5f0-53d9-9f23-d9c84f8c78f2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
