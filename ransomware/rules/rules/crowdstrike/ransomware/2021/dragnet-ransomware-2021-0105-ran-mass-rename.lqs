// Dragnet [Ransomware]: dragnet-ransomware-2021-0105 — Mass File Rename (avaddon)
// Status: deprecated | Level: high | ID: 0c6bfd4f-708d-5833-b653-5b9b7deb2a06

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
