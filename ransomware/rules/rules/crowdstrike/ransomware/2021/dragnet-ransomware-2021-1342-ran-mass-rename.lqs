// Dragnet [Ransomware]: dragnet-ransomware-2021-1342 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 9d93e177-3588-59f7-a531-51b97b126eb0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
