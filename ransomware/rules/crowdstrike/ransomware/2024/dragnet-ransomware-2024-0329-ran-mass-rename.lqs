// Dragnet [Ransomware]: dragnet-ransomware-2024-0329 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: d4c61931-0865-5b2f-a766-94f20d2a150b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
