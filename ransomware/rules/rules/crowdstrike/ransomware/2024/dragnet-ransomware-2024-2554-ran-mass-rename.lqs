// Dragnet [Ransomware]: dragnet-ransomware-2024-2554 — Mass File Rename (cicada3301)
// Status: experimental | Level: high | ID: 9824fa23-cddf-562f-98d6-21dc8738841c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
