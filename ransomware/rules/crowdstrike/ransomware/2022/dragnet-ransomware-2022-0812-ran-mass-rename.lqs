// Dragnet [Ransomware]: dragnet-ransomware-2022-0812 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 57c364a7-1a53-57fe-94d6-8654579e1abd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
