// Dragnet [Ransomware]: dragnet-ransomware-2022-1083 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: e1e0ebeb-8a36-5eac-9878-659d57165776

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
