// Dragnet [Ransomware]: dragnet-ransomware-2023-3004 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: c0783796-9362-5c9f-9751-66924f01ffc8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
