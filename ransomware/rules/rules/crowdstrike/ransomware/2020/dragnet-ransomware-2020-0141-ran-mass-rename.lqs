// Dragnet [Ransomware]: dragnet-ransomware-2020-0141 — Mass File Rename (ransomexx)
// Status: deprecated | Level: high | ID: 09f51a91-ac08-564a-be71-9746e85c4b93

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
