// Dragnet [Ransomware]: dragnet-ransomware-2023-0875 — Mass File Rename (play)
// Status: experimental | Level: high | ID: e30dfec7-7801-52e1-9637-a8e221903b29

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
