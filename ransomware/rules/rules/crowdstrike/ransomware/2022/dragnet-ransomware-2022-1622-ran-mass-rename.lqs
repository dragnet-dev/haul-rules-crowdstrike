// Dragnet [Ransomware]: dragnet-ransomware-2022-1622 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: f5b31a15-1572-52bd-abed-b24a11aa2e4e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
