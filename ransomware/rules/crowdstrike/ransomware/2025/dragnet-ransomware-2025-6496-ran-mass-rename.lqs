// Dragnet [Ransomware]: dragnet-ransomware-2025-6496 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: a32f2783-1e4e-5eac-9110-703876ead821

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
