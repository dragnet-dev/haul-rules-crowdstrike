// Dragnet [Ransomware]: dragnet-ransomware-2023-1296 — Mass File Rename (werewolves)
// Status: experimental | Level: high | ID: 2cf827c9-6dc9-5607-830f-46a925b5fc01

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
