// Dragnet [Container]: dragnet-container-2026-1359 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 307e7ccb-fdbc-5151-8735-2b18795f6654

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:7* OR ImageFileName = *debian:8* OR ImageFileName = *redhat/ubi9:*)
| table([timestamp, ComputerName])
| limit(1000)
