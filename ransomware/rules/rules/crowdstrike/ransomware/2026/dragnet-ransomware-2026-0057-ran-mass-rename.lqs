// Dragnet [Ransomware]: dragnet-ransomware-2026-0057 — Mass File Rename (fulcrumsec)
// Status: stable | Level: high | ID: ffe9cf9b-66f2-59d4-b52b-62512895ccca

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
