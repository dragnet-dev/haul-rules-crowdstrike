// Dragnet [Ransomware]: dragnet-ransomware-2024-5984 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 450a1440-33ce-52a7-bfed-34d95369cab6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
