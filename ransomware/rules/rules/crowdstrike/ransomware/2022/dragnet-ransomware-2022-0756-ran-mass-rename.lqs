// Dragnet [Ransomware]: dragnet-ransomware-2022-0756 — Mass File Rename (royal)
// Status: deprecated | Level: high | ID: 9f3b9048-1906-5a6d-b177-0293318fa8d1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
