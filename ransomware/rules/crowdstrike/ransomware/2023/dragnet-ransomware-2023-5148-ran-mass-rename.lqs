// Dragnet [Ransomware]: dragnet-ransomware-2023-5148 — Mass File Rename (cactus)
// Status: deprecated | Level: high | ID: aa6ec755-789f-55b5-9ca6-7aad8788a9b2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
