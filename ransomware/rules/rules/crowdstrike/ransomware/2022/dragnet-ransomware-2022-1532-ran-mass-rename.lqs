// Dragnet [Ransomware]: dragnet-ransomware-2022-1532 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 1283bc10-3bf6-59ce-a8e4-a4344b7e0d6b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
