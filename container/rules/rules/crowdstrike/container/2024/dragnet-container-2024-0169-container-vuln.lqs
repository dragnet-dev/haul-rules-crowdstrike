// Dragnet [Container]: dragnet-container-2024-0169 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 79584e2f-88f6-58a7-a807-8e45d98db8e3

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
