// Dragnet [Ransomware]: dragnet-ransomware-2020-0106 — Mass File Rename (ragnarlocker)
// Status: deprecated | Level: high | ID: 61ef8aa3-bee9-5ae4-a6e5-a718545ad0b7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
