// Dragnet [Ransomware]: dragnet-ransomware-2024-5624 — Mass File Rename (spacebears)
// Status: experimental | Level: high | ID: 95977282-a5cd-570c-8f4f-0e883d28dc9c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
