// Dragnet [Ransomware]: dragnet-ransomware-2022-2416 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 412c63ff-c776-5d35-8990-3e33e17b05f1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
