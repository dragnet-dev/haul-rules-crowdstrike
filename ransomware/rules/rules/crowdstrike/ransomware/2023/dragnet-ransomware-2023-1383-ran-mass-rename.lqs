// Dragnet [Ransomware]: dragnet-ransomware-2023-1383 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 35887af0-ca90-5e92-a5b1-f3c66d77023c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
