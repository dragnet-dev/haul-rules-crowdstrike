// Dragnet [Ransomware]: dragnet-ransomware-2026-1163 — Mass File Rename (thegentlemen)
// Status: stable | Level: high | ID: 28219a5a-c609-503f-ac8b-10e3bf0829c3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
