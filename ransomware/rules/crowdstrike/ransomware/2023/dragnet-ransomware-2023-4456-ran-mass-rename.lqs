// Dragnet [Ransomware]: dragnet-ransomware-2023-4456 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 62c7466e-2823-524e-be46-fe2e9c49ea02

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
