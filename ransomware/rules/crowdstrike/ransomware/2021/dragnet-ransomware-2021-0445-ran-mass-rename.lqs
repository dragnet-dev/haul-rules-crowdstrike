// Dragnet [Ransomware]: dragnet-ransomware-2021-0445 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 83f3904f-2f00-5a5f-a993-2cfc95a4ccce

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
