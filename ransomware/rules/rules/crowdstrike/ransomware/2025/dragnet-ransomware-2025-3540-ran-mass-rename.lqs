// Dragnet [Ransomware]: dragnet-ransomware-2025-3540 — Mass File Rename (spacebears)
// Status: experimental | Level: high | ID: 3e71e31d-1ec3-5e3e-8764-99b1576d5b4b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
