// Dragnet [Ransomware]: dragnet-ransomware-2024-2524 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: b5030e44-9c2e-50ac-8664-4b1ed78df66b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
