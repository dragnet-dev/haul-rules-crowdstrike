// Dragnet [Ransomware]: dragnet-ransomware-2020-0247 — Mass File Rename (netwalker)
// Status: deprecated | Level: high | ID: 9741a0ff-b192-5ad7-b960-2c85106270e9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
