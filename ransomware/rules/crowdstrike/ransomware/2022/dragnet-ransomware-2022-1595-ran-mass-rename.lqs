// Dragnet [Ransomware]: dragnet-ransomware-2022-1595 — Mass File Rename (vicesociety)
// Status: deprecated | Level: high | ID: 63c777f2-f683-5f5f-abdb-ae83adee4bfb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
