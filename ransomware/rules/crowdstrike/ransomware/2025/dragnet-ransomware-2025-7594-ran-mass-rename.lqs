// Dragnet [Ransomware]: dragnet-ransomware-2025-7594 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: c4888bec-a5c1-526d-9b95-c48bd52f672f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
