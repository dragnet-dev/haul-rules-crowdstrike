// Dragnet [Ransomware]: dragnet-ransomware-2025-4804 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 1cdc063b-5a59-5b50-8a04-ba2c9d212788

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
