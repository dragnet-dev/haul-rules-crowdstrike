// Dragnet [Ransomware]: dragnet-ransomware-2024-6010 — Mass File Rename (cicada3301)
// Status: experimental | Level: high | ID: f82105a6-a289-5b1d-a8ef-acfd95b3f35d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
