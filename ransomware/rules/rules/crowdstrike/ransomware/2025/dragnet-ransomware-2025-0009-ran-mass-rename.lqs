// Dragnet [Ransomware]: dragnet-ransomware-2025-0009 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 6f605361-a0e4-54fc-a3d2-a8366f705d55

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
