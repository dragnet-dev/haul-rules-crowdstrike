// Dragnet [Ransomware]: dragnet-ransomware-2025-4428 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 907c33a7-3ec6-523d-baf0-38a49dca246a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
