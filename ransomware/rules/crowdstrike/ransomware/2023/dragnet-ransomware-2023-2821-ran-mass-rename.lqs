// Dragnet [Ransomware]: dragnet-ransomware-2023-2821 — Mass File Rename (malas)
// Status: experimental | Level: high | ID: 229c386c-8608-5847-8abe-e94590ea28ec

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
