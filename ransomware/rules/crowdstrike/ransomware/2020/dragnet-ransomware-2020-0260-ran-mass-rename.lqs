// Dragnet [Ransomware]: dragnet-ransomware-2020-0260 — Mass File Rename (netwalker)
// Status: deprecated | Level: high | ID: cf7a0859-ff96-5e80-8b49-3cff9980d2a0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
