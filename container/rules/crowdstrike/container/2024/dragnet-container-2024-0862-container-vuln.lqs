// Dragnet [Container]: dragnet-container-2024-0862 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 19358cd4-d21a-5dad-9ee2-293a5e60598f

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:9*)
| table([timestamp, ComputerName])
| limit(1000)
