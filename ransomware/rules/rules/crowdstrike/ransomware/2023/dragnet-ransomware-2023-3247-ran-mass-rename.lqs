// Dragnet [Ransomware]: dragnet-ransomware-2023-3247 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 328c7442-5335-50bd-8ff8-85829990cb76

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
