// Dragnet [Container]: dragnet-container-2026-2656 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: b77a2fea-6347-532d-9d44-5d64126b29d5

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
