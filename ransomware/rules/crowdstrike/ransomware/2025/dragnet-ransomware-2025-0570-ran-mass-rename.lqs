// Dragnet [Ransomware]: dragnet-ransomware-2025-0570 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: 33b7df47-98ef-51d6-bf31-2cab15186583

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
