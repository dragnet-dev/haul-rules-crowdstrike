// Dragnet [Ransomware]: dragnet-ransomware-2026-2613 — Mass File Rename (handala)
// Status: stable | Level: high | ID: 8c0c2ae2-cb1d-56f7-a84e-6826451d8986

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
