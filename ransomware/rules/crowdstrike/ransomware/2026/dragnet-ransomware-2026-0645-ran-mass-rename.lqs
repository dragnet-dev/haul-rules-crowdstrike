// Dragnet [Ransomware]: dragnet-ransomware-2026-0645 — Mass File Rename (dragonforce)
// Status: test | Level: high | ID: 5858b95a-68af-5cfa-96d2-134d0c83a19e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
