// Dragnet [Ransomware]: dragnet-ransomware-2024-0304 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 6a675a6e-e1a9-56e5-ab23-1ac5e5a6357f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
