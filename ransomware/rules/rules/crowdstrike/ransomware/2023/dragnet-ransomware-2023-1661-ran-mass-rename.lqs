// Dragnet [Ransomware]: dragnet-ransomware-2023-1661 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 2263b399-ca07-57ab-8c74-ec0790205d3f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
