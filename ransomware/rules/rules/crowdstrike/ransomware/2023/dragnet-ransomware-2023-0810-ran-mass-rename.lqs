// Dragnet [Ransomware]: dragnet-ransomware-2023-0810 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 4c93d334-e286-5d30-846c-52729a22c908

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
