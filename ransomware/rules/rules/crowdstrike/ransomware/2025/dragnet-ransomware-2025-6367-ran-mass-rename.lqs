// Dragnet [Ransomware]: dragnet-ransomware-2025-6367 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: 07901bda-6b97-57b5-b833-cc0f05200d2e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
