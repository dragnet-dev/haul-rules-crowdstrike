// Dragnet [Ransomware]: dragnet-ransomware-2022-1456 — Mass File Rename (vicesociety)
// Status: deprecated | Level: high | ID: 9c7984a8-26c1-517f-8c95-452d4280590c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
