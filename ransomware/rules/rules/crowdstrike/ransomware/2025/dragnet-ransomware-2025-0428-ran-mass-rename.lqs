// Dragnet [Ransomware]: dragnet-ransomware-2025-0428 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 5085b970-5bf8-5e56-95c4-5420c609c17f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
