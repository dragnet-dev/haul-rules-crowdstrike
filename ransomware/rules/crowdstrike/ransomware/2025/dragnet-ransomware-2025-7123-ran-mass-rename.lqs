// Dragnet [Ransomware]: dragnet-ransomware-2025-7123 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: bd48e52b-fc04-5d7f-b3b8-61c3f6a9a12a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
