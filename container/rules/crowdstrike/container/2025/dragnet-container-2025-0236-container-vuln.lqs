// Dragnet [Container]: dragnet-container-2025-0236 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: a8b4423c-9e5c-5c3c-ba13-37517a2b464d

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *redhat/ubi9:*)
| table([timestamp, ComputerName])
| limit(1000)
