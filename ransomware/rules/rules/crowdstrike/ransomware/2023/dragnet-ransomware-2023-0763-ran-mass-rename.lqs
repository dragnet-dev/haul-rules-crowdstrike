// Dragnet [Ransomware]: dragnet-ransomware-2023-0763 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 124346f4-dd97-5299-8ebe-3684d2d8fe36

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
