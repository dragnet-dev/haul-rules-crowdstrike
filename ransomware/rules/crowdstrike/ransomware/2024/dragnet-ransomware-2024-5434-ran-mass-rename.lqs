// Dragnet [Ransomware]: dragnet-ransomware-2024-5434 — Mass File Rename (meow)
// Status: experimental | Level: high | ID: 75ba941c-7a55-5320-9b70-2fbd3ef137c2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
