// Dragnet [Ransomware]: dragnet-ransomware-2025-0652 — Mass File Rename (alphalocker)
// Status: experimental | Level: high | ID: bc0f17c4-4d82-5299-9ab6-2459426624f0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
