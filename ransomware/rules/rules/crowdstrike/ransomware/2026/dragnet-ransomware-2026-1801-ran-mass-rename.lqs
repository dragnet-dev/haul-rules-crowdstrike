// Dragnet [Ransomware]: dragnet-ransomware-2026-1801 — Mass File Rename (medusalocker)
// Status: stable | Level: high | ID: d97b978b-ba19-5bee-b571-1fff6451f71f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
