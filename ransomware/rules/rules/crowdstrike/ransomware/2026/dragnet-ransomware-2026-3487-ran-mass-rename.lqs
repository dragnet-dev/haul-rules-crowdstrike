// Dragnet [Ransomware]: dragnet-ransomware-2026-3487 — Mass File Rename (lockbit5)
// Status: stable | Level: high | ID: bb6c6e85-435f-53c9-bc1b-5c6eadb681e1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
