// Dragnet [Ransomware]: dragnet-ransomware-2024-2333 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: e8e900bd-23d1-5eb5-81e5-fc43af04fb10

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
