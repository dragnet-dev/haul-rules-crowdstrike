// Dragnet [Ransomware]: dragnet-ransomware-2025-0379 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 3aa94dac-b3fc-511e-b825-04cc1b33d3e9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
