// Dragnet [Ransomware]: dragnet-ransomware-2025-0626 — Mass File Rename (coinbasecartel)
// Status: experimental | Level: high | ID: aa97bf10-4c0f-5e50-8852-f410a4eeaa0e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
