// Dragnet [Ransomware]: dragnet-ransomware-2025-5136 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: 3256c0e9-585d-56ec-a8c1-8d905183949f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
