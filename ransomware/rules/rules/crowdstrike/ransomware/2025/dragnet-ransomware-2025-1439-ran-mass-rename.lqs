// Dragnet [Ransomware]: dragnet-ransomware-2025-1439 — Mass File Rename (coinbasecartel)
// Status: experimental | Level: high | ID: 34b27797-886d-58f3-b201-037e2b88b837

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
