// Dragnet [Ransomware]: dragnet-ransomware-2023-3940 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 7cb9567f-3c6a-5a0e-9778-7e5a57fb2af1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
