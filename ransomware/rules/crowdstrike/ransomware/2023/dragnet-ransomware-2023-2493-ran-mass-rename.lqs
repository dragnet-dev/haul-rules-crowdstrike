// Dragnet [Ransomware]: dragnet-ransomware-2023-2493 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 548b0221-72dd-5518-85cf-272c69851601

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
