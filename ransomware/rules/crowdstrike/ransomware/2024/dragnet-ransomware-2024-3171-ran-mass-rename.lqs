// Dragnet [Ransomware]: dragnet-ransomware-2024-3171 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: b47bde12-2c2a-51b5-9eb6-183ef9dd8596

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
