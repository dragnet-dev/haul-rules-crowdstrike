// Dragnet [Ransomware]: dragnet-ransomware-2025-3327 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: a738d392-5b7c-50d7-a21e-0e438bcf801f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
