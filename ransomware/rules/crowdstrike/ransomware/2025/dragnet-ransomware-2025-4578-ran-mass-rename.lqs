// Dragnet [Ransomware]: dragnet-ransomware-2025-4578 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: b96ae71a-80e4-5316-b3d6-4617e46dd6e6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
