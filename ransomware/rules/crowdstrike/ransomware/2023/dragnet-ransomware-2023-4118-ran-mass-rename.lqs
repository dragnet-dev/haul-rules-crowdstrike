// Dragnet [Ransomware]: dragnet-ransomware-2023-4118 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 0bd2eafa-4475-5d18-9324-3cfc53440f29

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
