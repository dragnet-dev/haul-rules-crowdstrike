// Dragnet [Ransomware]: dragnet-ransomware-2024-0075 — Mass File Rename (alphalocker)
// Status: experimental | Level: high | ID: 7ef97c0f-7b23-5df9-883c-d4e74c18d775

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
