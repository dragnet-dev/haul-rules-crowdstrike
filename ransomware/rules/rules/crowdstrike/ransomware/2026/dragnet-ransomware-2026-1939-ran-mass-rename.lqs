// Dragnet [Ransomware]: dragnet-ransomware-2026-1939 — Mass File Rename (sinobi)
// Status: stable | Level: high | ID: 28afc2ba-1f85-5546-8917-d825196629c6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
