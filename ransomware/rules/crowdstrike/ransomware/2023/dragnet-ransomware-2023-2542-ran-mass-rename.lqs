// Dragnet [Ransomware]: dragnet-ransomware-2023-2542 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 3bac2229-d3a7-5c4b-99b6-a755ffd847b9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
