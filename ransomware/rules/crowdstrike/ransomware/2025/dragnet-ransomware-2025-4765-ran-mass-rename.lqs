// Dragnet [Ransomware]: dragnet-ransomware-2025-4765 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 45f30cbd-1785-5495-88c4-c144dc579b7c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
