// Dragnet [Ransomware]: dragnet-ransomware-2023-3076 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: fee647dd-94dd-5b8c-b89b-aa2736b62882

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
