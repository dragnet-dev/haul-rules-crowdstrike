// Dragnet [Ransomware]: dragnet-ransomware-2025-2698 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 0851ef91-bf39-524a-ba9c-37b1533c4d71

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
