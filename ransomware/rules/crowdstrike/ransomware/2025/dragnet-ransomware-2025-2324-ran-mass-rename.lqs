// Dragnet [Ransomware]: dragnet-ransomware-2025-2324 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: 356ce65a-9747-52b3-b836-368c96857e99

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
