// Dragnet [Ransomware]: dragnet-ransomware-2023-3303 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 12881804-5e39-5bcf-aad7-cf03d669adf9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
