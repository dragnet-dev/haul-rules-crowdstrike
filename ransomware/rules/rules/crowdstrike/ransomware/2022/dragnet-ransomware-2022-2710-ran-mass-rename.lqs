// Dragnet [Ransomware]: dragnet-ransomware-2022-2710 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: b5f35310-e3d9-59d6-bd17-21ea84da324a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
