// Dragnet [Ransomware]: dragnet-ransomware-2024-3365 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: dc14906b-27c8-576d-b15b-45a349fbec8f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
