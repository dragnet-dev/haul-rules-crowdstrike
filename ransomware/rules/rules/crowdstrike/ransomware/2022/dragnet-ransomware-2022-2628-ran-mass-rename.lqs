// Dragnet [Ransomware]: dragnet-ransomware-2022-2628 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: f6e0dcd0-7015-5c3c-8e41-3bae1fd3afdf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
