// Dragnet [Ransomware]: dragnet-ransomware-2024-4514 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 553b558d-718d-530c-9f46-fb013cec1c18

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
