// Dragnet [Ransomware]: dragnet-ransomware-2024-1846 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 993f6d0c-a846-52bc-a192-9d399d22c70a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
