// Dragnet [Ransomware]: dragnet-ransomware-2023-1985 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: aabf0b19-6e4e-559a-a0c7-87a636a3bb18

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
