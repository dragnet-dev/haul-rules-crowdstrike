// Dragnet [Ransomware]: dragnet-ransomware-2024-4041 — Mass File Rename (stormous)
// Status: deprecated | Level: high | ID: 2e1310da-15ed-57c3-a1a2-d7fb45db08e2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
