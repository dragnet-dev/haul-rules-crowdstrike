// Dragnet [Ransomware]: dragnet-ransomware-2023-0055 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 69ffc4a5-0545-5654-a59e-f1dad2fe768c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
