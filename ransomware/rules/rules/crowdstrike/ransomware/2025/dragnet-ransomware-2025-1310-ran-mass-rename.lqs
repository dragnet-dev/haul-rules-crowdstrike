// Dragnet [Ransomware]: dragnet-ransomware-2025-1310 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 98eb64b0-2872-571d-b464-680d9417542c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
