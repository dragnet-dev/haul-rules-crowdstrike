// Dragnet [Ransomware]: dragnet-ransomware-2023-3747 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 5f1f06c1-9068-5eaf-8cb2-ee836268a313

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
