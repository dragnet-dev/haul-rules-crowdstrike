// Dragnet [Ransomware]: dragnet-ransomware-2025-4696 — Mass File Rename (devman)
// Status: experimental | Level: high | ID: a4ea6a59-73d9-57fe-92fc-93a4cda9cfcb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
