// Dragnet [Ransomware]: dragnet-ransomware-2022-1936 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: 01863196-339c-5c41-a74a-baf3d0d7b3ed

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
