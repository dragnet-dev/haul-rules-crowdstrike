// Dragnet [Ransomware]: dragnet-ransomware-2022-0741 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 2f5cf0c5-8f19-51a7-bfff-46fb9bd73e8b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
