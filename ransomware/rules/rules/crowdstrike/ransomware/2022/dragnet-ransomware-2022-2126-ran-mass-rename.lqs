// Dragnet [Ransomware]: dragnet-ransomware-2022-2126 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 25762777-3a97-5218-9feb-20f25c3a5a23

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
