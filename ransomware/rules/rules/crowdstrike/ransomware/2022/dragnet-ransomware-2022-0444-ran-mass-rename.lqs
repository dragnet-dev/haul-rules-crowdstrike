// Dragnet [Ransomware]: dragnet-ransomware-2022-0444 — Mass File Rename (ransomhouse)
// Status: deprecated | Level: high | ID: 21157f30-2181-5a26-afb9-b6fc099f54d7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
