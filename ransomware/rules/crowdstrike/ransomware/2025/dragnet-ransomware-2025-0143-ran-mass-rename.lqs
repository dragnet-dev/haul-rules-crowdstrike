// Dragnet [Ransomware]: dragnet-ransomware-2025-0143 — Mass File Rename (ransomhouse)
// Status: experimental | Level: high | ID: a492435f-fb51-5c64-b0ba-822029160c3a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
