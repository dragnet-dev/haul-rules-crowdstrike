// Dragnet [Container]: dragnet-container-2025-0612 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: c89b63e0-3edd-5299-b505-660f6132761d

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *redhat/ubi9:*)
| table([timestamp, ComputerName])
| limit(1000)
