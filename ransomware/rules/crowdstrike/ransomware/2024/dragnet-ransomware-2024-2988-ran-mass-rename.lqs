// Dragnet [Ransomware]: dragnet-ransomware-2024-2988 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 0e150f17-60da-5054-9eb5-b33393a43cb0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
