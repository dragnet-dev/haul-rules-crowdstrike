// Dragnet [Ransomware]: dragnet-ransomware-2025-1273 — Mass File Rename (shinyhunters)
// Status: experimental | Level: high | ID: 76c75d37-2266-5981-8124-bbbeffc80ed7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
