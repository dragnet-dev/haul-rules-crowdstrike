// Dragnet [Ransomware]: dragnet-ransomware-2025-1992 — Mass File Rename (ransomhouse)
// Status: experimental | Level: high | ID: 3f6439dd-f85b-5063-9102-020ae9384967

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
