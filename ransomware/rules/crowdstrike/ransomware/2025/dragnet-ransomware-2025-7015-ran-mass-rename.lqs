// Dragnet [Ransomware]: dragnet-ransomware-2025-7015 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 31210407-6f89-5bfb-8da4-fbd05515d7a8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
