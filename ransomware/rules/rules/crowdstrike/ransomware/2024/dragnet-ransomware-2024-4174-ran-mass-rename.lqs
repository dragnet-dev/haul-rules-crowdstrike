// Dragnet [Ransomware]: dragnet-ransomware-2024-4174 — Mass File Rename (handala)
// Status: experimental | Level: high | ID: 0bbdef07-c1cb-5c12-a19a-8f0d60943c67

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
