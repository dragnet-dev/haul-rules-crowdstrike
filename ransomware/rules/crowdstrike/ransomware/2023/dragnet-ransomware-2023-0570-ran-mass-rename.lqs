// Dragnet [Ransomware]: dragnet-ransomware-2023-0570 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: e4d8a33d-e58d-5170-a8b4-a33f95853f92

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
