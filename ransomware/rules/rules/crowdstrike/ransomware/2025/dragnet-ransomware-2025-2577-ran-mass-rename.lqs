// Dragnet [Ransomware]: dragnet-ransomware-2025-2577 — Mass File Rename (interlock)
// Status: experimental | Level: high | ID: 15d30eaf-9fea-5e93-8b8b-6d599d1f03b0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
