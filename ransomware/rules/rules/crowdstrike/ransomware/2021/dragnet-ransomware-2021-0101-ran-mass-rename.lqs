// Dragnet [Ransomware]: dragnet-ransomware-2021-0101 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 6aa16afe-e757-5088-8d4e-687c9683572a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
