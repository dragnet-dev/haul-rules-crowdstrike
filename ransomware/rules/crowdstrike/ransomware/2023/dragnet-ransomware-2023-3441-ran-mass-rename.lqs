// Dragnet [Ransomware]: dragnet-ransomware-2023-3441 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 6d6f9f9a-33ad-5f1d-803c-9d160d7e20f0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
