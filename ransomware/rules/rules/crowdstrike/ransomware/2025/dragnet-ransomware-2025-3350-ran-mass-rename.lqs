// Dragnet [Ransomware]: dragnet-ransomware-2025-3350 — Mass File Rename (warlock)
// Status: deprecated | Level: high | ID: d443160b-e3c7-5cc8-9d24-74da4a41fcab

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
