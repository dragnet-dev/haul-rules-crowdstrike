// Dragnet [Ransomware]: dragnet-ransomware-2024-0908 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 789171c2-3f36-5d5e-a1bb-45955a410dbb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
