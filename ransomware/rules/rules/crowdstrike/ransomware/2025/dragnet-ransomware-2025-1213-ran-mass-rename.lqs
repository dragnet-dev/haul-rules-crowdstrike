// Dragnet [Ransomware]: dragnet-ransomware-2025-1213 — Mass File Rename (lockbit5)
// Status: test | Level: high | ID: 84b9a133-b5c0-5e19-918e-b206caa3ac30

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
