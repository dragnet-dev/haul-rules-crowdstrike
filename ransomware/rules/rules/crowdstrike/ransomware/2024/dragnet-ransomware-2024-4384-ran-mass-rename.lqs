// Dragnet [Ransomware]: dragnet-ransomware-2024-4384 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 94698ec9-ad20-5dca-8f43-08eb54afcd63

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
