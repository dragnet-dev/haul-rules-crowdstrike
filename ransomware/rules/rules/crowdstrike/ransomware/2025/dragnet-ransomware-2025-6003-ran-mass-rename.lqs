// Dragnet [Ransomware]: dragnet-ransomware-2025-6003 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: fae1d1a9-d7aa-55d3-ad81-f25e40c848ba

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
