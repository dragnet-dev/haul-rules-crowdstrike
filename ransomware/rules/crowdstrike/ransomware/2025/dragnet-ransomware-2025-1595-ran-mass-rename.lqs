// Dragnet [Ransomware]: dragnet-ransomware-2025-1595 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 205ec401-6d21-50d8-a932-6f1db53133ff

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
