// Dragnet [Ransomware]: dragnet-ransomware-2025-3794 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 4289fe43-f55e-5194-b8a3-a8cfb32df81a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
