// Dragnet [Ransomware]: dragnet-ransomware-2023-1001 — Mass File Rename (royal)
// Status: experimental | Level: high | ID: 96e1e7bb-90f7-547f-a806-ace9244461f2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
