// Dragnet [Ransomware]: dragnet-ransomware-2024-4652 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: 5936d6c9-edab-54a7-9c02-57298964e4f8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
