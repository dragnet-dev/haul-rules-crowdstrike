// Dragnet [Ransomware]: dragnet-ransomware-2024-5915 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: 44e49f57-b8bd-5989-8661-1f5921edf9e7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
