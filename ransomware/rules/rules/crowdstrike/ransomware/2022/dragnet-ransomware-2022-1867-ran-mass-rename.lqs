// Dragnet [Ransomware]: dragnet-ransomware-2022-1867 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 903bbadf-0402-535f-a3e8-59d9039bf8d2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
