// Dragnet [Ransomware]: dragnet-ransomware-2023-5223 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 0a52af4f-2579-50f7-9109-584f4bb1dd86

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
