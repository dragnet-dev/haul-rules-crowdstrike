// Dragnet [Ransomware]: dragnet-ransomware-2025-4936 — Mass File Rename (coinbasecartel)
// Status: experimental | Level: high | ID: 61a37e17-26b6-56e3-b93f-144a3eb6fe64

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
