// Dragnet [Ransomware]: dragnet-ransomware-2022-2602 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: a330044f-fc43-5931-95b5-4c0ceeba0359

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
