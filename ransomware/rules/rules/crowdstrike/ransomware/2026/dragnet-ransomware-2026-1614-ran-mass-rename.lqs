// Dragnet [Ransomware]: dragnet-ransomware-2026-1614 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 6cf8d55e-784b-5f06-be53-2d881d1f3a59

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
