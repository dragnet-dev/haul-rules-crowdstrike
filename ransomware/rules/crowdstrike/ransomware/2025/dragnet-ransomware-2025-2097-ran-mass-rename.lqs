// Dragnet [Ransomware]: dragnet-ransomware-2025-2097 — Mass File Rename (beast)
// Status: experimental | Level: high | ID: a80ce01a-7c01-52b3-9f7e-3575695834b3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
