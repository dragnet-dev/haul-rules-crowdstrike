// Dragnet [Ransomware]: dragnet-ransomware-2023-0309 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 65de6fec-e7b4-56eb-a0ed-46dfd4b66883

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
