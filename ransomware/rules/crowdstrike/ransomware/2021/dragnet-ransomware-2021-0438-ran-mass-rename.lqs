// Dragnet [Ransomware]: dragnet-ransomware-2021-0438 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 271e873c-471d-502a-9341-8671157575e0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
