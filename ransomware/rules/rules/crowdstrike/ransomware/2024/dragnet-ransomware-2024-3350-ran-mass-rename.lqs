// Dragnet [Ransomware]: dragnet-ransomware-2024-3350 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 0acde931-28d8-5646-b297-17301d1dcf34

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
