// Dragnet [Ransomware]: dragnet-ransomware-2023-0155 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 473307be-e7ca-5832-9163-78fc68d7e58e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
