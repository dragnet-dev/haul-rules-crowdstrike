// Dragnet [Ransomware]: dragnet-ransomware-2022-2622 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 52332ca6-0d79-57f0-bd9f-b14695af5446

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
