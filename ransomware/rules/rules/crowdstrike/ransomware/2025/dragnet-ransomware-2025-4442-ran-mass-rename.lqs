// Dragnet [Ransomware]: dragnet-ransomware-2025-4442 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 8d191ee8-7202-5453-b4c8-965f507646b9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
