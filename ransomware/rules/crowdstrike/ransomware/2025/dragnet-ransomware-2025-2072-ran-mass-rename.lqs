// Dragnet [Ransomware]: dragnet-ransomware-2025-2072 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: f4a03884-dc37-5886-898d-bb1f56b60f16

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
