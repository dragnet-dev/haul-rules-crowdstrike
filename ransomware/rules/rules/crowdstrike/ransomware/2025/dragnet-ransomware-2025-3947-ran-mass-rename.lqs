// Dragnet [Ransomware]: dragnet-ransomware-2025-3947 — Mass File Rename (direwolf)
// Status: experimental | Level: high | ID: 6c21270c-3307-5a2f-9cd8-67a187856c80

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
