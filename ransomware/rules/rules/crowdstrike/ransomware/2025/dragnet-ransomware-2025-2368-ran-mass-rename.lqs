// Dragnet [Ransomware]: dragnet-ransomware-2025-2368 — Mass File Rename (satanlockv2)
// Status: experimental | Level: high | ID: b0b1428a-6f12-58d4-92ba-a19d9fa5b1c8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
