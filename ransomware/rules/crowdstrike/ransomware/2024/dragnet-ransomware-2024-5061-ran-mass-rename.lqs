// Dragnet [Ransomware]: dragnet-ransomware-2024-5061 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 95dbd878-9a11-55e7-b6cb-a0b8497ad9ac

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
