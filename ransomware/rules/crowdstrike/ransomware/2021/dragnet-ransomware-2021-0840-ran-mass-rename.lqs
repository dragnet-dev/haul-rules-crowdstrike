// Dragnet [Ransomware]: dragnet-ransomware-2021-0840 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 883aea06-6d80-5b62-bbfc-96fe73ece154

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
