// Dragnet [Ransomware]: dragnet-ransomware-2025-3844 — Mass File Rename (nightspire)
// Status: deprecated | Level: high | ID: 2551ca79-face-5277-8170-1f505f783f3e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
