// Dragnet [Ransomware]: dragnet-ransomware-2023-0243 — Mass File Rename (mallox)
// Status: experimental | Level: high | ID: 50bacc8a-18d6-5673-8e2f-f6665e3f47f6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
