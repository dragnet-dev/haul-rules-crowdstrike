// Dragnet [Ransomware]: dragnet-ransomware-2023-4879 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 30c97012-822b-5d81-92bf-e7384e4ca1cf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
