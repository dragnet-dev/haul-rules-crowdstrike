// Dragnet [Ransomware]: dragnet-ransomware-2022-0341 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 762785aa-c3cb-5372-b5a3-c2fa3e5b53bd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
