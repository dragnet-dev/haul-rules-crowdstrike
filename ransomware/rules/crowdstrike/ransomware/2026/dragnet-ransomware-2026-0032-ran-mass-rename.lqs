// Dragnet [Ransomware]: dragnet-ransomware-2026-0032 — Mass File Rename (nightspire)
// Status: deprecated | Level: high | ID: 34d3853d-763d-55f0-9715-d2a3c4150f3c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
