// Dragnet [Container]: dragnet-container-2024-0032 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: b8a72203-8940-533b-b0bc-d43620e01ecf

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
