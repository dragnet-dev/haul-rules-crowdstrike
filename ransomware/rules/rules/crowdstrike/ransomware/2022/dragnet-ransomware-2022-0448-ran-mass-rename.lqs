// Dragnet [Ransomware]: dragnet-ransomware-2022-0448 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: f20ea0fa-6535-5bcc-a1f4-8aae34d9c809

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
