// Dragnet [Ransomware]: dragnet-ransomware-2025-5798 — Mass File Rename (sinobi)
// Status: experimental | Level: high | ID: 0598f546-24d4-523e-8027-776202ffaf6b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
