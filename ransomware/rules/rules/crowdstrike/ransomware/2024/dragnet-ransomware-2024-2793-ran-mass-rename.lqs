// Dragnet [Ransomware]: dragnet-ransomware-2024-2793 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: 034c0ecc-0b8f-5689-b8da-5197e902ec92

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
