// Dragnet [Ransomware]: dragnet-ransomware-2022-1789 — Mass File Rename (blackbasta)
// Status: deprecated | Level: high | ID: bd8a41f4-e97b-516e-988f-7a2b78c62500

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
