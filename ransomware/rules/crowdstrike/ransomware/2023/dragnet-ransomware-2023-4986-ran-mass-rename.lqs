// Dragnet [Ransomware]: dragnet-ransomware-2023-4986 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: d636e9d2-80ba-5e3a-b7b0-a5f551d9a18f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
