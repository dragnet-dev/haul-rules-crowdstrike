// Dragnet [Ransomware]: dragnet-ransomware-2024-3514 — Mass File Rename (flocker)
// Status: experimental | Level: high | ID: 531645ae-9d03-50fd-ba5f-e2b5ff1146a9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
