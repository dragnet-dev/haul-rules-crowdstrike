// Dragnet [Ransomware]: dragnet-ransomware-2025-5396 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: 2c848115-c382-533b-8fab-f2c67d7d1525

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
