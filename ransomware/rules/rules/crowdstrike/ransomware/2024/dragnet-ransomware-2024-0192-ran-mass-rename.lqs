// Dragnet [Ransomware]: dragnet-ransomware-2024-0192 — Mass File Rename (raworld)
// Status: experimental | Level: high | ID: 92fd95a1-4653-586c-a5b7-ea24a1463748

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
