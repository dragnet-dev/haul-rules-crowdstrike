// Dragnet [Ransomware]: dragnet-ransomware-2024-5548 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: bd9a092c-6365-5275-bb4d-d3deae9de9af

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
