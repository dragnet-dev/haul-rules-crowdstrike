// Dragnet [Ransomware]: dragnet-ransomware-2024-0140 — Mass File Rename (metaencryptor)
// Status: experimental | Level: high | ID: 4453c899-0de4-55cc-a29f-12065d28c1c4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
