// Dragnet [Ransomware]: dragnet-ransomware-2025-4857 — Mass File Rename (IMNCrew)
// Status: experimental | Level: high | ID: a48d1b27-8fc2-5a3c-af2a-06bc7e332762

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
