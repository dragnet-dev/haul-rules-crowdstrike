// Dragnet [Ransomware]: dragnet-ransomware-2024-1101 — Mass File Rename (blacklock)
// Status: experimental | Level: high | ID: 6f270d15-56c9-57ff-8925-eda2cdbb58a8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
