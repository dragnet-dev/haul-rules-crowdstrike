// Dragnet [Ransomware]: dragnet-ransomware-2024-2139 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 86438dc9-36af-54ef-ae94-509aaed6c6ef

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
