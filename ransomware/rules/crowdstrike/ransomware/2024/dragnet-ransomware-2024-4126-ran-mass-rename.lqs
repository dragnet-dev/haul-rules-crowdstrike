// Dragnet [Ransomware]: dragnet-ransomware-2024-4126 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 82bf0fdd-0958-5557-bac2-199a2eddf901

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
