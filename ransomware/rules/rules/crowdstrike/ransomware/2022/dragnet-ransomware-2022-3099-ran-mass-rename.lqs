// Dragnet [Ransomware]: dragnet-ransomware-2022-3099 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: c4d6f9ca-bcf6-518a-af4d-1ba98a0345cf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
