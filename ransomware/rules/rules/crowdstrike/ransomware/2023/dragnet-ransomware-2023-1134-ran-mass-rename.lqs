// Dragnet [Ransomware]: dragnet-ransomware-2023-1134 — Mass File Rename (raznatovic)
// Status: experimental | Level: high | ID: b6014c49-a08a-5a50-8ad4-90e5e84a462c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
