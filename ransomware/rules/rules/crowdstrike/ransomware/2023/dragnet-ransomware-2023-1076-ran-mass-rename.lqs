// Dragnet [Ransomware]: dragnet-ransomware-2023-1076 — Mass File Rename (royal)
// Status: experimental | Level: high | ID: 97916363-4099-5235-ac88-802930c6a978

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
