// Dragnet [Ransomware]: dragnet-ransomware-2025-4938 — Mass File Rename (arcusmedia)
// Status: experimental | Level: high | ID: 82dbd3dc-88c3-55b6-9b0f-addd252c8da0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
