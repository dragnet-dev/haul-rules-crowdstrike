// Dragnet [Ransomware]: dragnet-ransomware-2021-0056 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: e0a1885b-7993-5db6-b31a-1808e4af5081

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
