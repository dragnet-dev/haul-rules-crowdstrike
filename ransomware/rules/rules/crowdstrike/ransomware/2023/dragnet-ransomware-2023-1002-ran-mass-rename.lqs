// Dragnet [Ransomware]: dragnet-ransomware-2023-1002 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: ec400917-ad47-5839-8256-89df4797da1e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
