// Dragnet [Ransomware]: dragnet-ransomware-2025-5103 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 6be561e1-e876-53fb-b806-a70808cdcf7a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
