// Dragnet [Ransomware]: dragnet-ransomware-2022-1671 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 86b4f3b5-ee05-5bc4-a7c8-6c10a63924eb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
