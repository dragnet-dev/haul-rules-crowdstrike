// Dragnet [Ransomware]: dragnet-ransomware-2024-3259 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 6af6713e-20f9-5198-8308-1b854670db81

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
