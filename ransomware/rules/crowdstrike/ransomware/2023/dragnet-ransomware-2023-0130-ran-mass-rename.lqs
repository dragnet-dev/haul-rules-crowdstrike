// Dragnet [Ransomware]: dragnet-ransomware-2023-0130 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 41feabef-9c61-52a5-ac8b-5841d01dea52

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
