// Dragnet [Ransomware]: dragnet-ransomware-2025-1291 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 02dd7e27-3c0f-5f9e-9878-71c1d23f8221

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
