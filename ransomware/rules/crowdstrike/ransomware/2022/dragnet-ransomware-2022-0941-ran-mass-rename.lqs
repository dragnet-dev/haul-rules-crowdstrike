// Dragnet [Ransomware]: dragnet-ransomware-2022-0941 — Mass File Rename (ragnarlocker)
// Status: deprecated | Level: high | ID: ac2d6801-0ff2-5e19-9610-e35146a61f09

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
