// Dragnet [Ransomware]: dragnet-ransomware-2025-5373 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: ff89a3d3-1b9d-5cd9-9c05-75dfe9f3af17

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
