// Dragnet [Ransomware]: dragnet-ransomware-2023-0126 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 1e4b693a-7a03-5454-b831-dd9e4f6b8f4f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
