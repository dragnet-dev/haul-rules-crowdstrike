// Dragnet [Ransomware]: dragnet-ransomware-2023-1904 — Mass File Rename (snatch)
// Status: experimental | Level: high | ID: 5846b11d-901f-50e5-bd6a-4fefc787a222

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
