// Dragnet [Ransomware]: dragnet-ransomware-2023-1995 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 98c0a42f-4ed8-5e90-9649-40107777d386

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
