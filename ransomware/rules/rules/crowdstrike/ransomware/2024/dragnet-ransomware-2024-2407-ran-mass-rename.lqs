// Dragnet [Ransomware]: dragnet-ransomware-2024-2407 — Mass File Rename (raworld)
// Status: experimental | Level: high | ID: c2f58af6-5e81-5502-9adf-820a2ab75b11

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
