// Dragnet [Ransomware]: dragnet-ransomware-2024-1548 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 691d901f-6ae5-5051-baf2-909aeb399663

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
