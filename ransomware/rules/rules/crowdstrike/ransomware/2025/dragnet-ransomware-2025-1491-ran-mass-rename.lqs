// Dragnet [Ransomware]: dragnet-ransomware-2025-1491 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 80b8ff2d-6276-5fa8-a3ad-8f51219ecfb4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
