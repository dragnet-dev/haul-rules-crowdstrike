// Dragnet [Ransomware]: dragnet-ransomware-2022-0521 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 4212b45a-3446-5fce-8709-8726cef1ea1f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
