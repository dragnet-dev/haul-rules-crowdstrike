// Dragnet [Ransomware]: dragnet-ransomware-2022-2996 — Mass File Rename (cheers)
// Status: deprecated | Level: high | ID: 4c449244-d9d0-5949-9b88-98e2c01e5d1f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
