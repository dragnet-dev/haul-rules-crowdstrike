// Dragnet [Ransomware]: dragnet-ransomware-2025-6916 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: e9cfa6ed-d4e9-57ab-b0dd-dc9dedf415f9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
