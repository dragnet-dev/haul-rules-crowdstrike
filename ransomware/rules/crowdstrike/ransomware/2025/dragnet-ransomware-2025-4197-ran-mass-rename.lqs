// Dragnet [Ransomware]: dragnet-ransomware-2025-4197 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: 1d9bea6d-abb2-5017-8591-c567b72ad7ad

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
