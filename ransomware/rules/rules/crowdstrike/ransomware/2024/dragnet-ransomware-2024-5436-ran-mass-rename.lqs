// Dragnet [Ransomware]: dragnet-ransomware-2024-5436 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 18a36e80-141e-5a6f-aff7-7a0174310081

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
