// Dragnet [Ransomware]: dragnet-ransomware-2025-3435 — Mass File Rename (ransomhouse)
// Status: experimental | Level: high | ID: f1e9c978-d267-5173-9c43-47d9d7f5092f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
