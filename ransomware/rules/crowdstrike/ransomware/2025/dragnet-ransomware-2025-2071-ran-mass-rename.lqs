// Dragnet [Ransomware]: dragnet-ransomware-2025-2071 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: af3f02f9-0d18-519b-8f70-834e181ee6a8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
