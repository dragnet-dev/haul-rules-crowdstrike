// Dragnet [Ransomware]: dragnet-ransomware-2025-4682 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 5545e7a8-35e8-5422-b7ba-cb4426899a06

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
