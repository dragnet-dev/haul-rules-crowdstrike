// Dragnet [Ransomware]: dragnet-ransomware-2023-1124 — Mass File Rename (vicesociety)
// Status: experimental | Level: high | ID: c61bd0fb-a707-52c8-858f-835c88175bbc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
