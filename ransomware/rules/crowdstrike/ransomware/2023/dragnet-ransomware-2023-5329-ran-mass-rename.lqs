// Dragnet [Ransomware]: dragnet-ransomware-2023-5329 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: b42f2acd-d350-5484-be69-644f9208136b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
