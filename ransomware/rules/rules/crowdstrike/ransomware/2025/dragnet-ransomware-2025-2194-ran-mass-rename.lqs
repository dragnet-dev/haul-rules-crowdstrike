// Dragnet [Ransomware]: dragnet-ransomware-2025-2194 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 478e0945-0c47-5aea-a887-2998244eef75

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
