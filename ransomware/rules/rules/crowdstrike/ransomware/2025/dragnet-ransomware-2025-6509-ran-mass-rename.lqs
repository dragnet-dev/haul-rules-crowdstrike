// Dragnet [Ransomware]: dragnet-ransomware-2025-6509 — Mass File Rename (abyss)
// Status: deprecated | Level: high | ID: 99611410-9788-5911-83dc-403d2e07ad75

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
