// Dragnet [Ransomware]: dragnet-ransomware-2024-3826 — Mass File Rename (stormous)
// Status: deprecated | Level: high | ID: dd29693f-01e7-5867-aec8-2f0eaab2d2dd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
