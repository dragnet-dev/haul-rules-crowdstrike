// Dragnet [Ransomware]: dragnet-ransomware-2023-1964 — Mass File Rename (royal)
// Status: experimental | Level: high | ID: b4e5079c-6417-589b-a616-068e16317e7e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
