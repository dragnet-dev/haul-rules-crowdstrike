// Dragnet [Ransomware]: dragnet-ransomware-2022-1926 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 581b61af-52ad-5568-8f72-41062cf05efb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
