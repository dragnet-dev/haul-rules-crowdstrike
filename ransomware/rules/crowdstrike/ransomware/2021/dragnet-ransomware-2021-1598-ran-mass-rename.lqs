// Dragnet [Ransomware]: dragnet-ransomware-2021-1598 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: d3418901-83d9-54ca-a4d2-4c27f775730c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
