// Dragnet [Ransomware]: dragnet-ransomware-2021-1060 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 3014921b-a575-5f7b-8fd1-443dd3511bb3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
