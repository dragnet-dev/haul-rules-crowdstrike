// Dragnet [Ransomware]: dragnet-ransomware-2021-0014 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 44359acd-b4ca-573d-b2b4-4b0ba7a47341

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
