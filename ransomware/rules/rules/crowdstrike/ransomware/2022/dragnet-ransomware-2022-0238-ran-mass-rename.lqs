// Dragnet [Ransomware]: dragnet-ransomware-2022-0238 — Mass File Rename (leaktheanalyst)
// Status: deprecated | Level: high | ID: 5c0f9bd9-5e98-5059-96db-3291345192b1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
