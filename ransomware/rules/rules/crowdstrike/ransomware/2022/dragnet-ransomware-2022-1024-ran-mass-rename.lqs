// Dragnet [Ransomware]: dragnet-ransomware-2022-1024 — Mass File Rename (everest)
// Status: deprecated | Level: high | ID: fa90156a-8280-5d7b-8367-d2efa228f282

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
