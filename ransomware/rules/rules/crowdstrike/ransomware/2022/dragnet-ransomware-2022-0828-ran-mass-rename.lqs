// Dragnet [Ransomware]: dragnet-ransomware-2022-0828 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 302465c0-8e74-5c2f-8238-aff150ffdb39

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
