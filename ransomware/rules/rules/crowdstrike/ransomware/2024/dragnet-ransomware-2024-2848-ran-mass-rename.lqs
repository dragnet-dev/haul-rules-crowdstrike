// Dragnet [Ransomware]: dragnet-ransomware-2024-2848 — Mass File Rename (cicada3301)
// Status: experimental | Level: high | ID: eb2e0515-76c0-5495-9557-17bd4d065341

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
