// Dragnet [Ransomware]: dragnet-ransomware-2024-3672 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: d08e51f9-28af-5201-b883-55e48ce15a47

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
