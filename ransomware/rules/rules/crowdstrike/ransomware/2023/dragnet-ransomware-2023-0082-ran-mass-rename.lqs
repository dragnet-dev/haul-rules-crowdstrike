// Dragnet [Ransomware]: dragnet-ransomware-2023-0082 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 059798bb-f979-5a5f-b5a5-899cc1a33ecc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
