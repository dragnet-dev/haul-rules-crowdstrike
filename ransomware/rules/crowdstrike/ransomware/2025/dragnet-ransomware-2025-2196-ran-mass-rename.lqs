// Dragnet [Ransomware]: dragnet-ransomware-2025-2196 — Mass File Rename (genesis)
// Status: experimental | Level: high | ID: f8194bca-1197-552e-9925-08af58809140

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
