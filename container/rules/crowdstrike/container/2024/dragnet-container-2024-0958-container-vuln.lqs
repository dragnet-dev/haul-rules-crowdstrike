// Dragnet [Container]: dragnet-container-2024-0958 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 75b0f2b0-f0b4-5610-8285-d84e352a7601

#event_simpleName=*
| (ImageFileName = *amazonlinux:2* OR ImageFileName = *amazonlinux:2023* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:20.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
