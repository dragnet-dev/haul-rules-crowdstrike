// Dragnet [Ransomware]: dragnet-ransomware-2022-0088 — Mass File Rename (cuba)
// Status: deprecated | Level: high | ID: 06d4a3b3-04f8-55ab-bd88-0ec29bc0ddbd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
