// Dragnet [Ransomware]: dragnet-ransomware-2024-1855 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 7190035a-8068-5604-80f0-5f2b99d8003b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
