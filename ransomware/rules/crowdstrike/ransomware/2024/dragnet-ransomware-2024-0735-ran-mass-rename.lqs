// Dragnet [Ransomware]: dragnet-ransomware-2024-0735 — Mass File Rename (apt73)
// Status: experimental | Level: high | ID: be355be9-a02f-5fd9-a29a-9378f1c0ba00

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
