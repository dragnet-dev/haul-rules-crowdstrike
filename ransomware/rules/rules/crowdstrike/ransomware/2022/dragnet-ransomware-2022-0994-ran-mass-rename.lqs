// Dragnet [Ransomware]: dragnet-ransomware-2022-0994 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: e30b73f0-c5d3-5fe6-a4ff-9838b68b7245

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
