// Dragnet [Ransomware]: dragnet-ransomware-2026-1846 — Mass File Rename (dragonforce)
// Status: stable | Level: high | ID: ee5f7a31-da35-5c35-81cd-3f9aac84e064

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
