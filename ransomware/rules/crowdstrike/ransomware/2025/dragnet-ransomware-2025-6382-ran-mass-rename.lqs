// Dragnet [Ransomware]: dragnet-ransomware-2025-6382 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: bd99723c-1633-5fa5-8039-6d97e46d8043

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
