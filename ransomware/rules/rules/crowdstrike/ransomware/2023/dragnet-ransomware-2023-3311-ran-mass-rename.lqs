// Dragnet [Ransomware]: dragnet-ransomware-2023-3311 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 13aceda9-9e7a-5804-8dbc-fce0adf6442a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
