// Dragnet [Ransomware]: dragnet-ransomware-2023-2128 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 968c5be3-6b7a-5e23-a2ba-8d97a7e72163

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
