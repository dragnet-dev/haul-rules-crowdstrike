// Dragnet [Ransomware]: dragnet-ransomware-2025-7005 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: de70d42c-d0dc-5176-8422-833fbb10f0c3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
