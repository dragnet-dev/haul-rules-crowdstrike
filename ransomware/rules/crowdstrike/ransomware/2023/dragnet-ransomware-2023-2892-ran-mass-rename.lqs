// Dragnet [Ransomware]: dragnet-ransomware-2023-2892 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 72974613-3766-52ca-afcb-ae83f5429480

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
