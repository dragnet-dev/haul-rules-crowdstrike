// Dragnet [Ransomware]: dragnet-ransomware-2024-0036 — Mass File Rename (alphalocker)
// Status: experimental | Level: high | ID: 31f6f21c-8cd8-5080-bfa4-7b74bd2f55c5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
