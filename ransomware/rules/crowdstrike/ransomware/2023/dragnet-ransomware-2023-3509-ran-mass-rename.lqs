// Dragnet [Ransomware]: dragnet-ransomware-2023-3509 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: c529a942-e1b3-50f9-9a47-a56276cbc514

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
