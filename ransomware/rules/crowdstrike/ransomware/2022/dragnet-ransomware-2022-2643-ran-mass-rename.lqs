// Dragnet [Ransomware]: dragnet-ransomware-2022-2643 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: fdad1ec2-07b6-55fe-90ce-c98ad09bc3fc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
