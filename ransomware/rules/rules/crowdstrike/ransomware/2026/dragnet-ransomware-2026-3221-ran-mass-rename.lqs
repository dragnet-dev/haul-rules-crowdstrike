// Dragnet [Ransomware]: dragnet-ransomware-2026-3221 — Mass File Rename (lockbit5)
// Status: test | Level: high | ID: 53f76b74-0c2d-5100-bc17-9d57fd2a8b3a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
