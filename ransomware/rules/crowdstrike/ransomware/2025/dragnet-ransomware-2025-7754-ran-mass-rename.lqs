// Dragnet [Ransomware]: dragnet-ransomware-2025-7754 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 03553731-fa8f-5939-ad5d-d81a7f52426d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
