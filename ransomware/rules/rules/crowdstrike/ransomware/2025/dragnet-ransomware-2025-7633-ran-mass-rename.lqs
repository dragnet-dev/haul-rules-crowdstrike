// Dragnet [Ransomware]: dragnet-ransomware-2025-7633 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: a4369d30-3a5b-5492-9270-769477d9de55

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
