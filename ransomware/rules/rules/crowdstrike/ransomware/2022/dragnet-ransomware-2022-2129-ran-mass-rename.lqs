// Dragnet [Ransomware]: dragnet-ransomware-2022-2129 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 3c601ae4-be44-5fa4-a0c0-0ee3542f285a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
