// Dragnet [Ransomware]: dragnet-ransomware-2022-1981 — Mass File Rename (karakurt)
// Status: experimental | Level: high | ID: 7b47463e-0cc0-55b5-a6a8-cc8baa81c7f7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
