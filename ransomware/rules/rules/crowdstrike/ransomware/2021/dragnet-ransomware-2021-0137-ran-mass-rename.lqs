// Dragnet [Ransomware]: dragnet-ransomware-2021-0137 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 200509a3-66a1-59a3-a8e2-8d20074c6df2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
