// Dragnet [Ransomware]: dragnet-ransomware-2025-7484 — Mass File Rename (direwolf)
// Status: test | Level: high | ID: 35d637b4-dabb-5f78-9b04-89ffb466aef0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
