// Dragnet [Ransomware]: dragnet-ransomware-2024-0386 — Mass File Rename (safepay)
// Status: deprecated | Level: high | ID: 7c01ac8a-7d6c-5f76-9d50-4d75ed4e2415

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
