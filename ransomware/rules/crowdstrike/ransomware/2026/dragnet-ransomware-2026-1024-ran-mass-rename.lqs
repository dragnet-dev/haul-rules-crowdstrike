// Dragnet [Ransomware]: dragnet-ransomware-2026-1024 — Mass File Rename (thegentlemen)
// Status: test | Level: high | ID: a53550b8-33e2-5d53-a17c-830b5b34486d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
