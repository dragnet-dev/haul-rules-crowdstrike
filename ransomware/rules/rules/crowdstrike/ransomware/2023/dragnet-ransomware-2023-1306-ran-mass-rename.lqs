// Dragnet [Ransomware]: dragnet-ransomware-2023-1306 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: b742685e-c5ad-5c11-863a-f5735f1ab2e5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
