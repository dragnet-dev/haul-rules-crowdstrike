// Dragnet [Ransomware]: dragnet-ransomware-2025-1886 — Mass File Rename (radar)
// Status: experimental | Level: high | ID: d6b54d33-577e-5924-b8d1-881ffe28150b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
