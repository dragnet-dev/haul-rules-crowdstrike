// Dragnet [Container]: dragnet-container-2024-1075 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 47c00416-b107-5b1d-9e3c-de9d0af9430d

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:9* OR ImageFileName = *ubuntu:18.04*)
| table([timestamp, ComputerName])
| limit(1000)
