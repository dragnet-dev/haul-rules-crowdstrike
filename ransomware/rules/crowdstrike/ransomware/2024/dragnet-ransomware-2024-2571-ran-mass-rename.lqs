// Dragnet [Ransomware]: dragnet-ransomware-2024-2571 — Mass File Rename (meow)
// Status: experimental | Level: high | ID: 4582cbca-f456-52c8-8160-a6aa20ba97d0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
