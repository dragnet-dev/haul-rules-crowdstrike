// Dragnet [Ransomware]: dragnet-ransomware-2022-2288 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: c729fba9-0d38-5bef-acd0-6c9da9ccf32c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
