// Dragnet [Ransomware]: dragnet-ransomware-2023-0641 — Mass File Rename (play)
// Status: deprecated | Level: high | ID: 8cd5d5e7-91be-521c-9912-9861ceab2609

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
