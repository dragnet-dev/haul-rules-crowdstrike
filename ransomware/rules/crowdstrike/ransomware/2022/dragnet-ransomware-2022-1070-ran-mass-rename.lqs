// Dragnet [Ransomware]: dragnet-ransomware-2022-1070 — Mass File Rename (cuba)
// Status: deprecated | Level: high | ID: a3c25227-964f-542f-95a8-80f11bbde7e5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
