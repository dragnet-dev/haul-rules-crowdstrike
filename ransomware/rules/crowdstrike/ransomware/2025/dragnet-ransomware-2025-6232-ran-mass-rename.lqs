// Dragnet [Ransomware]: dragnet-ransomware-2025-6232 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 0a6926dc-f80f-5e1d-972e-7217c1fd565a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
