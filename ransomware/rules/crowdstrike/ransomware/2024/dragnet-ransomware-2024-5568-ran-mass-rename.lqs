// Dragnet [Ransomware]: dragnet-ransomware-2024-5568 — Mass File Rename (play)
// Status: experimental | Level: high | ID: a481b5e8-3cd4-5e01-b0c6-b8d7f5d52136

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
