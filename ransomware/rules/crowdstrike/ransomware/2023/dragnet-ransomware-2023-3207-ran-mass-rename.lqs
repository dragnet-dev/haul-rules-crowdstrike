// Dragnet [Ransomware]: dragnet-ransomware-2023-3207 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 771e206c-d1b0-52dd-9c85-0325a622fa56

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
