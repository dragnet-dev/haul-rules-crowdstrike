// Dragnet [Ransomware]: dragnet-ransomware-2023-0484 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: dc8f8157-dc93-554e-a12e-fa542e112352

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
