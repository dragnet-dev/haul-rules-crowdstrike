// Dragnet [Ransomware]: dragnet-ransomware-2023-3437 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 72c2d973-ce69-5a7d-8c2f-9894f94ebb3b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
