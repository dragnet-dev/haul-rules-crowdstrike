// Dragnet [Ransomware]: dragnet-ransomware-2025-7155 — Mass File Rename (lockbit5)
// Status: test | Level: high | ID: 0b10662d-1639-5d0e-96bf-707931945e32

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
