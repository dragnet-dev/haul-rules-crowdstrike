// Dragnet [Ransomware]: dragnet-ransomware-2024-0667 — Mass File Rename (helldown)
// Status: experimental | Level: high | ID: ded5483e-00c0-56b1-80f8-eff1793492bb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
