// Dragnet [Ransomware]: dragnet-ransomware-2025-1392 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: baeed41d-0f7d-51fd-8047-8f4012ec1ec6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
