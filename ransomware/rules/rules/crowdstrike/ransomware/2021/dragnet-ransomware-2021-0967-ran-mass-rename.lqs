// Dragnet [Ransomware]: dragnet-ransomware-2021-0967 — Mass File Rename (mountlocker)
// Status: deprecated | Level: high | ID: 94f6cd37-306e-525c-a49d-f00dd4d13b5f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
