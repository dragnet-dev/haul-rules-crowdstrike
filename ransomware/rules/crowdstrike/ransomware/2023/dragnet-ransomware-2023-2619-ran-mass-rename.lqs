// Dragnet [Ransomware]: dragnet-ransomware-2023-2619 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 6e0e183e-b327-538b-a74d-c101743f3f4e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
