// Dragnet [Ransomware]: dragnet-ransomware-2024-0531 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: d2eb60de-b1ee-5658-be0d-c1206daa2aa0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
