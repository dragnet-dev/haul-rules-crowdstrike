// Dragnet [Ransomware]: dragnet-ransomware-2024-2751 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: fb4dfd62-d1a8-5218-9c17-a4fc275ca3fd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
