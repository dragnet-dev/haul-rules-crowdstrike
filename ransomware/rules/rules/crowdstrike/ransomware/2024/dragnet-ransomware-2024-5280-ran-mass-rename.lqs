// Dragnet [Ransomware]: dragnet-ransomware-2024-5280 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 17f25e6d-c605-570c-96eb-334b5be719d2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
