// Dragnet [Ransomware]: dragnet-ransomware-2023-0821 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 8db0a782-a039-5d38-8753-89cdbddc161d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
