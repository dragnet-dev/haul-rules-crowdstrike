// Dragnet [Ransomware]: dragnet-ransomware-2022-2325 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 550682e6-7643-58b8-b8ae-c9d431f14b87

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
