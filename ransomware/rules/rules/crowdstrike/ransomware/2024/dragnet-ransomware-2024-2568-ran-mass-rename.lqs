// Dragnet [Ransomware]: dragnet-ransomware-2024-2568 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 06a17455-00dd-5eec-a219-30e132041625

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
