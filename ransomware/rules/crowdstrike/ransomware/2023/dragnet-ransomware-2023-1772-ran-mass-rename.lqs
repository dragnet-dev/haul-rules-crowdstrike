// Dragnet [Ransomware]: dragnet-ransomware-2023-1772 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 2a5eebff-f171-53d3-bb94-080d00230a89

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
