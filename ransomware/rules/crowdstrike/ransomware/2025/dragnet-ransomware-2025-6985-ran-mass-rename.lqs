// Dragnet [Ransomware]: dragnet-ransomware-2025-6985 — Mass File Rename (securotrop)
// Status: test | Level: high | ID: c11a7a1b-c134-5e27-9cad-8ee18f85b2d9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
