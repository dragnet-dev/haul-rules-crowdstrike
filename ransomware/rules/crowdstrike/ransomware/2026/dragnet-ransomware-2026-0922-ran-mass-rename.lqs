// Dragnet [Ransomware]: dragnet-ransomware-2026-0922 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 5044a15e-c03b-5f9a-99e4-61761a34f9a2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
