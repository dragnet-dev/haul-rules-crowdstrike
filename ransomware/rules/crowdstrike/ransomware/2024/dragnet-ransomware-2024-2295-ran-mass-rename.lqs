// Dragnet [Ransomware]: dragnet-ransomware-2024-2295 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: d92a2656-83ef-530b-b421-d8b0dd5d3130

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
