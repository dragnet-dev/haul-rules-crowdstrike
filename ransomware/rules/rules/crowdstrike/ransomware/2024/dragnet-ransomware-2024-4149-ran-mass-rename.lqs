// Dragnet [Ransomware]: dragnet-ransomware-2024-4149 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: b3a9b867-83c2-5aa9-9581-1f446b7b91ff

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
