// Dragnet [Ransomware]: dragnet-ransomware-2025-6913 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: fbd5c0c2-3828-55c3-8e6b-eac05086afa3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
