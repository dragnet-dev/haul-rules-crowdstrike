// Dragnet [Ransomware]: dragnet-ransomware-2025-7824 — Mass File Rename (lockbit5)
// Status: experimental | Level: high | ID: b5cda4e9-8c13-5a13-9f37-67fcc79a6053

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
