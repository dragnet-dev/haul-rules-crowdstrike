// Dragnet [Ransomware]: dragnet-ransomware-2023-1902 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 2710586e-a0bc-5fbe-af8c-91db4ce908a2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
