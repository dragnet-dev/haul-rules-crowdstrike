// Dragnet [Ransomware]: dragnet-ransomware-2022-2551 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 0a4b269e-bff5-505a-b884-236cbd93cef3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
