// Dragnet [Ransomware]: dragnet-ransomware-2022-1334 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 50f9bd4a-0bb3-5a9b-a75d-02ea1395d8fc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
