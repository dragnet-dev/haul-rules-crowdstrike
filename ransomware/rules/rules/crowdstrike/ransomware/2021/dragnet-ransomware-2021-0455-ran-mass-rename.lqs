// Dragnet [Ransomware]: dragnet-ransomware-2021-0455 — Mass File Rename (avoslocker)
// Status: deprecated | Level: high | ID: 371dac8e-8e52-5fa4-b2f8-2bc9a33e728f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
