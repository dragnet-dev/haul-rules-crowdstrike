// Dragnet [Ransomware]: dragnet-ransomware-2023-0450 — Mass File Rename (werewolves)
// Status: experimental | Level: high | ID: ca154d55-ad12-581f-9709-9cef5dc74596

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
