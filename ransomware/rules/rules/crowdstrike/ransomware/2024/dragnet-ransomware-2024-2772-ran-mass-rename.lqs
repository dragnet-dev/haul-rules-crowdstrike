// Dragnet [Ransomware]: dragnet-ransomware-2024-2772 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 6da4a90b-00fd-5fec-a45a-effa0af2608d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
