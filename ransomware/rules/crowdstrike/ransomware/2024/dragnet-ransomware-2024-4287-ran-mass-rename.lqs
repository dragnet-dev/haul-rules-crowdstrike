// Dragnet [Ransomware]: dragnet-ransomware-2024-4287 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: ab549b64-036d-54bb-96e5-a36d5a09e464

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
