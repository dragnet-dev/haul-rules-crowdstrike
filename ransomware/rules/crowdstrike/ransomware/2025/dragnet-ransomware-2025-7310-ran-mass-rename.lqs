// Dragnet [Ransomware]: dragnet-ransomware-2025-7310 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 6433d993-536d-5070-b1f8-dc9c48f1edc2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
