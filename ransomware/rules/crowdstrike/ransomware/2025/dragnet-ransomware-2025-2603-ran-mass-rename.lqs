// Dragnet [Ransomware]: dragnet-ransomware-2025-2603 — Mass File Rename (interlock)
// Status: experimental | Level: high | ID: 5ea7fa3b-4885-5da8-ab3a-c75d59b61011

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
