// Dragnet [Ransomware]: dragnet-ransomware-2023-4537 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: eb40aa09-6005-5134-b50e-309f08f67fa0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
