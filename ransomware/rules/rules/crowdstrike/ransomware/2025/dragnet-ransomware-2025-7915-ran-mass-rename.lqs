// Dragnet [Ransomware]: dragnet-ransomware-2025-7915 — Mass File Rename (devman)
// Status: experimental | Level: high | ID: 504cb107-77c1-5d19-a3ac-c199bdd34982

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
