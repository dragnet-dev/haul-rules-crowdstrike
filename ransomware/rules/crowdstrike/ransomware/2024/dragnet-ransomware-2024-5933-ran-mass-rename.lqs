// Dragnet [Ransomware]: dragnet-ransomware-2024-5933 — Mass File Rename (raworld)
// Status: experimental | Level: high | ID: eb1130b0-5098-5ef3-ba85-290ec5210c1c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
