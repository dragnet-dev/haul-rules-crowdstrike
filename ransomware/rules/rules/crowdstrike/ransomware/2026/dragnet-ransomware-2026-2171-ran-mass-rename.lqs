// Dragnet [Ransomware]: dragnet-ransomware-2026-2171 — Mass File Rename (dragonforce)
// Status: stable | Level: high | ID: 84a5f160-4115-5bc2-b112-bb3aed5d7047

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
