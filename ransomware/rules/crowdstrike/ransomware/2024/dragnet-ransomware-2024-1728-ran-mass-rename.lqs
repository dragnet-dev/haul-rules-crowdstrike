// Dragnet [Ransomware]: dragnet-ransomware-2024-1728 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 889ac5b7-d475-5dd8-8a0d-05170f236e40

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
