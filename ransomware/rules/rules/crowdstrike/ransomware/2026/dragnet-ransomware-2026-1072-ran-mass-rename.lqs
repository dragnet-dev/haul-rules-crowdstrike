// Dragnet [Ransomware]: dragnet-ransomware-2026-1072 — Mass File Rename (thegentlemen)
// Status: test | Level: high | ID: b985494a-0e06-5f0b-ba23-776c35b9d6cb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
