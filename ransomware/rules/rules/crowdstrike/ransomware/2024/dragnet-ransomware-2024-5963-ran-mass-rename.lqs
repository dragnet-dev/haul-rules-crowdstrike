// Dragnet [Ransomware]: dragnet-ransomware-2024-5963 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: f180a958-d301-53b6-bb5b-eacbff0c3ca3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
