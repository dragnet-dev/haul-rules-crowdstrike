// Dragnet [Ransomware]: dragnet-ransomware-2021-0051 — Mass File Rename (robinhood)
// Status: deprecated | Level: high | ID: e32e937c-9497-5602-a59b-5307213b3f90

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
