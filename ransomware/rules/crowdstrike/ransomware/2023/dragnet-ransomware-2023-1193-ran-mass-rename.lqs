// Dragnet [Ransomware]: dragnet-ransomware-2023-1193 — Mass File Rename (knight)
// Status: experimental | Level: high | ID: 5dd28cf6-2d11-5ba5-8d5f-3e9b5149d8fd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
