// Dragnet [Ransomware]: dragnet-ransomware-2025-6034 — Mass File Rename (J)
// Status: experimental | Level: high | ID: c343f1e8-081a-5049-a5b0-2fefd891a35f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
