// Dragnet [Ransomware]: dragnet-ransomware-2022-1129 — Mass File Rename (onyx)
// Status: deprecated | Level: high | ID: d9a07361-672a-5a4b-a80c-e8ffc1f25f43

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
