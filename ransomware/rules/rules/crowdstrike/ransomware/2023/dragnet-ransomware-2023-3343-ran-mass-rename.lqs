// Dragnet [Ransomware]: dragnet-ransomware-2023-3343 — Mass File Rename (ransomhouse)
// Status: experimental | Level: high | ID: 5dabb048-872e-5bb5-84d8-01a72108a049

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
