// Dragnet [Ransomware]: dragnet-ransomware-2025-0802 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: f8d5f821-0095-5678-940c-d051bfee4446

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
