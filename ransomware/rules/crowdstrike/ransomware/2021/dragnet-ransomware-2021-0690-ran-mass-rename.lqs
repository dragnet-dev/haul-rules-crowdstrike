// Dragnet [Ransomware]: dragnet-ransomware-2021-0690 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 9175e5bc-91e4-5bfa-98bb-094b04d99c26

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
