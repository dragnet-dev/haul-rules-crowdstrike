// Dragnet [Ransomware]: dragnet-ransomware-2026-1562 — Mass File Rename (dragonforce)
// Status: stable | Level: high | ID: d66b1557-709b-5ac5-87e9-c761d1fdf02e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
