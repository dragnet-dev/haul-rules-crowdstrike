// Dragnet [Ransomware]: dragnet-ransomware-2023-3114 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 10fc3d14-073c-5f0e-9809-0c470c00c6fa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
