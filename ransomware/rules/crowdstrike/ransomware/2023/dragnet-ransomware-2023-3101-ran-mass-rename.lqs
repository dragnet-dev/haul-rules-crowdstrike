// Dragnet [Ransomware]: dragnet-ransomware-2023-3101 — Mass File Rename (raworld)
// Status: experimental | Level: high | ID: 50d48ed9-b914-5fb6-8847-92e9001cd0dc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
