// Dragnet [Ransomware]: dragnet-ransomware-2024-0934 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: 5ba74d50-3fbe-5a48-9af5-bed67782f87c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
