// Dragnet [Ransomware]: dragnet-ransomware-2022-2255 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 287d5b9e-aa3b-5bfd-ae3a-0f5144f87d6f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
