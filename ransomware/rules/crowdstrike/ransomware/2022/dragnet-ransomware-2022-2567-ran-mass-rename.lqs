// Dragnet [Ransomware]: dragnet-ransomware-2022-2567 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 573fb7ae-6a8f-5ab9-82fd-6ffda5d4b6db

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
