// Dragnet [Ransomware]: dragnet-ransomware-2025-5741 — Mass File Rename (direwolf)
// Status: experimental | Level: high | ID: a4dc7cf8-3602-597b-9792-65c58d6a12e0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
