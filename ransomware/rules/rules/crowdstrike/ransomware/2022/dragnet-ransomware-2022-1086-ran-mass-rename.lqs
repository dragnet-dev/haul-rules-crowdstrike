// Dragnet [Ransomware]: dragnet-ransomware-2022-1086 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 9fd38f00-c580-5d81-a6b7-c39f7b982527

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
