// Dragnet [Ransomware]: dragnet-ransomware-2023-0968 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 58dea4c3-2623-570c-838e-1770ce366a3f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
