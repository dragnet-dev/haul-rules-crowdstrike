// Dragnet [Ransomware]: dragnet-ransomware-2026-2109 — Mass File Rename (shinyhunters)
// Status: deprecated | Level: high | ID: c7dd9c3c-56ef-5fa7-b908-2f3cc2a66ef6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
