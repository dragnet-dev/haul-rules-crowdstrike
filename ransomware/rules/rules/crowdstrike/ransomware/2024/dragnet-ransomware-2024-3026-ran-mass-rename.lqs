// Dragnet [Ransomware]: dragnet-ransomware-2024-3026 — Mass File Rename (arcusmedia)
// Status: experimental | Level: high | ID: 082b9666-b837-56bc-9e39-842e48d42ad7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
