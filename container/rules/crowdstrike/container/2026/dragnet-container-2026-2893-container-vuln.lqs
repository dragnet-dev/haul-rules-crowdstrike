// Dragnet [Container]: dragnet-container-2026-2893 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 0f82fbef-6493-56ff-bf46-47456446bea8

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6*)
| table([timestamp, ComputerName])
| limit(1000)
