// Dragnet [Ransomware]: dragnet-ransomware-2026-2421 — Mass File Rename (payload)
// Status: stable | Level: high | ID: c8f7d576-5faa-5cd1-b47e-a8d93c1d7d42

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
