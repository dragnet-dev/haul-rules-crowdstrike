// Dragnet [Ransomware]: dragnet-ransomware-2025-1734 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: 9919dd80-5d3c-5746-87ff-785dcd3fa211

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
