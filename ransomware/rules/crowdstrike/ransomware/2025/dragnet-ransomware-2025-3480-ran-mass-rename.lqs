// Dragnet [Ransomware]: dragnet-ransomware-2025-3480 — Mass File Rename (spacebears)
// Status: experimental | Level: high | ID: eeebf978-607c-5f59-98a9-f13ade363b22

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
