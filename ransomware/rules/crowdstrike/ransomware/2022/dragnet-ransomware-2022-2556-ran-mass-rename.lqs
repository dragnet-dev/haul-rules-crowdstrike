// Dragnet [Ransomware]: dragnet-ransomware-2022-2556 — Mass File Rename (sabbath)
// Status: deprecated | Level: high | ID: 11f51d48-8ed1-5515-a757-a04c12db81f3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
