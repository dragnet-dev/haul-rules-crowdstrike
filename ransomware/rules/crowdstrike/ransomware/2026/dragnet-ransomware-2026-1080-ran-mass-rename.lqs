// Dragnet [Ransomware]: dragnet-ransomware-2026-1080 — Mass File Rename (thegentlemen)
// Status: test | Level: high | ID: 8c26e2b0-bd4c-54bb-8b7f-0afd0698d3f4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
