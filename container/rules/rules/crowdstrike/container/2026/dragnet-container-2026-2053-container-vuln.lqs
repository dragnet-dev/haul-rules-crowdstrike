// Dragnet [Container]: dragnet-container-2026-2053 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 106e599a-b461-5a79-807d-37c60912c5bf

#event_simpleName=*
| (ImageFileName = *alpine edge:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
