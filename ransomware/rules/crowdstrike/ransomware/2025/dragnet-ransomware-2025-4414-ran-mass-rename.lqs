// Dragnet [Ransomware]: dragnet-ransomware-2025-4414 — Mass File Rename (cloak)
// Status: deprecated | Level: high | ID: 00ee1873-c72b-5e9e-b238-cdbf1fc32a0d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
