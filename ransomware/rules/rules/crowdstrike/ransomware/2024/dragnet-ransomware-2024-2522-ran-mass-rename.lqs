// Dragnet [Ransomware]: dragnet-ransomware-2024-2522 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 4ea1533e-cc55-5410-a612-134d66e102f8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
