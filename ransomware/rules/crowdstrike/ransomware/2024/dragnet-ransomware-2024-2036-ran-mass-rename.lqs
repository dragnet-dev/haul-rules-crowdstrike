// Dragnet [Ransomware]: dragnet-ransomware-2024-2036 — Mass File Rename (handala)
// Status: experimental | Level: high | ID: 778b2373-d4f7-53e5-967d-84049f421b10

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
