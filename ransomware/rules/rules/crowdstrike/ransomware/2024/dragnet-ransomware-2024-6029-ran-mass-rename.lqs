// Dragnet [Ransomware]: dragnet-ransomware-2024-6029 — Mass File Rename (qilin)
// Status: deprecated | Level: high | ID: 37d8d5b7-d6d9-5b2b-a052-6f9e3303c5cf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
