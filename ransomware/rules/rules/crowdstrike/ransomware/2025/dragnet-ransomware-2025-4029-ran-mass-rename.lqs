// Dragnet [Ransomware]: dragnet-ransomware-2025-4029 — Mass File Rename (shinyhunters)
// Status: experimental | Level: high | ID: 6a6b9146-dae0-59d3-873e-571e2a90635e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
