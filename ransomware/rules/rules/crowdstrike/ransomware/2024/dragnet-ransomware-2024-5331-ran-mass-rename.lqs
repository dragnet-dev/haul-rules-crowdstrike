// Dragnet [Ransomware]: dragnet-ransomware-2024-5331 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 9e73847e-1adc-5590-ae18-e750542a2f04

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
