// Dragnet [Container]: dragnet-container-2025-0113 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 55c11873-b91a-5ab2-858d-00470a9bbe47

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:8* OR ImageFileName = *debian:9*)
| table([timestamp, ComputerName])
| limit(1000)
