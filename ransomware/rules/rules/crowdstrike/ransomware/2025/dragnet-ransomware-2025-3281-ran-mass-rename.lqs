// Dragnet [Ransomware]: dragnet-ransomware-2025-3281 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: dad62346-3002-55eb-991d-035ce98bda15

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
