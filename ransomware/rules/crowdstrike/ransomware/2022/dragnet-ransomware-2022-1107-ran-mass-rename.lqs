// Dragnet [Ransomware]: dragnet-ransomware-2022-1107 — Mass File Rename (blackbasta)
// Status: deprecated | Level: high | ID: a0efed87-9fe9-55d0-acd6-c6c11ae3c8bb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
