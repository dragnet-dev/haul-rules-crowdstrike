// Dragnet [Ransomware]: dragnet-ransomware-2025-7804 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 7c08787c-7464-5620-b1d3-05bd77251e1d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
