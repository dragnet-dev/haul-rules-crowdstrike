// Dragnet [Ransomware]: dragnet-ransomware-2023-0839 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 0186a046-922d-5f21-92f2-6b5397b3fec4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
