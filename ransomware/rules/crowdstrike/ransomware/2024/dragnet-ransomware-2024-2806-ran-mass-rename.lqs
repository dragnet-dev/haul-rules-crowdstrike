// Dragnet [Ransomware]: dragnet-ransomware-2024-2806 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 99795f14-80dd-5891-90af-f2ed8b77f5d9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
