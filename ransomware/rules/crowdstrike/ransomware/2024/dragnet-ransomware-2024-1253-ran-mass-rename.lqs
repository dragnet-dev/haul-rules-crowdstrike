// Dragnet [Ransomware]: dragnet-ransomware-2024-1253 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: c5b0f33c-9ac1-5b34-9802-44a2aa0a75d0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
