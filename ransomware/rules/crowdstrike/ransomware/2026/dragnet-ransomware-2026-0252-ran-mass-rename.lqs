// Dragnet [Ransomware]: dragnet-ransomware-2026-0252 — Mass File Rename (everest)
// Status: stable | Level: high | ID: 8cccdb8e-9509-5b45-b109-76a5be842afd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
