// Dragnet [Ransomware]: dragnet-ransomware-2024-1502 — Mass File Rename (sarcoma)
// Status: deprecated | Level: high | ID: 727f3ed8-72d9-5dbb-8aa0-470d16e712de

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
