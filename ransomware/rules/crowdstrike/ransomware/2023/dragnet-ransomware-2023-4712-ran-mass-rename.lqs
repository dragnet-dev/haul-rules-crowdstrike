// Dragnet [Ransomware]: dragnet-ransomware-2023-4712 — Mass File Rename (cloak)
// Status: deprecated | Level: high | ID: 92fdfbda-ca8d-5a5d-9cf5-d14f6bf91853

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
