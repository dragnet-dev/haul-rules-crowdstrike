// Dragnet [Ransomware]: dragnet-ransomware-2025-1465 — Mass File Rename (nightspire)
// Status: deprecated | Level: high | ID: f02e5b70-7250-5748-9324-68ebb241688f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
