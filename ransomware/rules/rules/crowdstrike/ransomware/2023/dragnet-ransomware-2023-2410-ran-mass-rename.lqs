// Dragnet [Ransomware]: dragnet-ransomware-2023-2410 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: d68c5c3d-fe72-5c42-bfeb-85a5cbfe472d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
