// Dragnet [Ransomware]: dragnet-ransomware-2025-0405 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: e8d9148b-ee92-5409-90ef-cac97bffce93

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
