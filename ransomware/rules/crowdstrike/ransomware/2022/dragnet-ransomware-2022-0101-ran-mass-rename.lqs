// Dragnet [Ransomware]: dragnet-ransomware-2022-0101 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: e34b3379-e6c8-546b-8fff-c5635e46f667

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
