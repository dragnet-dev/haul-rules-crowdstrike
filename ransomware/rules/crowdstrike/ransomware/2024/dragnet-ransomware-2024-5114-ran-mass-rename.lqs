// Dragnet [Ransomware]: dragnet-ransomware-2024-5114 — Mass File Rename (cloak)
// Status: deprecated | Level: high | ID: 040f3986-8a62-5a2a-8e21-972e2140ef01

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
