// Dragnet [Ransomware]: dragnet-ransomware-2026-1228 — Mass File Rename (handala)
// Status: stable | Level: high | ID: 42157bc4-6a9e-54ae-b840-704993c2d919

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
