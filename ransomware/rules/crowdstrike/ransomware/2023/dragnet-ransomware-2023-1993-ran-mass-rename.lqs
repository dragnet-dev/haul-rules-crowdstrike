// Dragnet [Ransomware]: dragnet-ransomware-2023-1993 — Mass File Rename (play)
// Status: experimental | Level: high | ID: c9714dbc-83ef-5cfe-98c2-8273983d4dbe

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
