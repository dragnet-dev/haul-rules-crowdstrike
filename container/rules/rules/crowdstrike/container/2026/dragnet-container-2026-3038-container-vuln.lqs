// Dragnet [Container]: dragnet-container-2026-3038 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 6457bd00-269c-5238-9fef-970d27e0567b

#event_simpleName=*
| (ImageFileName = *debian:7* OR ImageFileName = *debian:8* OR ImageFileName = *debian:9* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:14.04* OR ImageFileName = *ubuntu:14.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
