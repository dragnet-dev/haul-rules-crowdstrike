// Dragnet [Ransomware]: dragnet-ransomware-2024-5181 — Mass File Rename (dragonforce)
// Status: deprecated | Level: high | ID: a53bdd3c-526c-574f-8305-32d532750498

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
