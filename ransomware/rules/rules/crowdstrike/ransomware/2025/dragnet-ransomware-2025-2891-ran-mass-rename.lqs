// Dragnet [Ransomware]: dragnet-ransomware-2025-2891 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 85e43dc1-02fd-5b77-9a5e-ddd5c9bc70bf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
