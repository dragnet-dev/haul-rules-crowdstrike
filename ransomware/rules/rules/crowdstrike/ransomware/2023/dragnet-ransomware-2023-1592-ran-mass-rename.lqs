// Dragnet [Ransomware]: dragnet-ransomware-2023-1592 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: bb849b80-d073-5b2c-9ff2-447374930a6b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
