// Dragnet [Ransomware]: dragnet-ransomware-2025-0819 — Mass File Rename (J)
// Status: experimental | Level: high | ID: f179518a-8146-51ac-b1aa-d17c00427503

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
