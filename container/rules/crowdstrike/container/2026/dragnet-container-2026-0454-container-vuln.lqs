// Dragnet [Container]: dragnet-container-2026-0454 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 2e139dd9-96ab-5a2c-93c3-feae35235ee4

#event_simpleName=*
| (ImageFileName = *debian:7* OR ImageFileName = *debian:8* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:14.04* OR ImageFileName = *ubuntu:14.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
