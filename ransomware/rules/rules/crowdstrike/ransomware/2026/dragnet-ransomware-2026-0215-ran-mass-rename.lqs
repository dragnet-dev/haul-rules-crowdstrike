// Dragnet [Ransomware]: dragnet-ransomware-2026-0215 — Mass File Rename (ransomhouse)
// Status: stable | Level: high | ID: 08f48cef-cf33-5f6b-809a-1074c1780847

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
