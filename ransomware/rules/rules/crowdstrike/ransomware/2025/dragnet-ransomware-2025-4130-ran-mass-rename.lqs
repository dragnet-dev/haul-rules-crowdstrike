// Dragnet [Ransomware]: dragnet-ransomware-2025-4130 — Mass File Rename (alphalocker)
// Status: experimental | Level: high | ID: 9f783d34-c031-55c3-b7a5-600d88b61d9f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
