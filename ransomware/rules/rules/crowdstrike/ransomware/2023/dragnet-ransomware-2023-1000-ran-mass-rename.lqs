// Dragnet [Ransomware]: dragnet-ransomware-2023-1000 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 69d8a0ce-debe-5a41-9c91-4e1c0eac2967

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
