// Dragnet [Ransomware]: dragnet-ransomware-2025-2688 — Mass File Rename (datacarry)
// Status: deprecated | Level: high | ID: 588ba839-fa89-5a38-a7c9-0c9159c4a381

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
