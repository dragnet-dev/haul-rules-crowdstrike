// Dragnet [Ransomware]: dragnet-ransomware-2025-0384 — Mass File Rename (ciphbit)
// Status: deprecated | Level: high | ID: 3f91573e-b12b-5a84-a321-de3b3bc3679e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
