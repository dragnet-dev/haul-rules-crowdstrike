// Dragnet [Ransomware]: dragnet-ransomware-2021-0236 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 837ca8a0-2e26-5f94-9ee6-30a02577e94c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
