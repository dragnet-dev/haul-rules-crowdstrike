// Dragnet [Ransomware]: dragnet-ransomware-2024-5578 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 27e94c8c-ccca-5fb6-9ac4-b04acac0a0db

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
