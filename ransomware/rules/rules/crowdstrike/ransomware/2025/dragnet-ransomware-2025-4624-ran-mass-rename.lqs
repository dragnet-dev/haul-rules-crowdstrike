// Dragnet [Ransomware]: dragnet-ransomware-2025-4624 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 641ada1e-e432-50ad-a2ba-ae42329e8757

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
