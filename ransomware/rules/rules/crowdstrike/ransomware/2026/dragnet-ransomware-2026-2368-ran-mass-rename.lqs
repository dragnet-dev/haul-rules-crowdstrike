// Dragnet [Ransomware]: dragnet-ransomware-2026-2368 — Mass File Rename (sinobi)
// Status: stable | Level: high | ID: 6e24d14b-b040-5746-bd6f-2dcd413bf7be

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
