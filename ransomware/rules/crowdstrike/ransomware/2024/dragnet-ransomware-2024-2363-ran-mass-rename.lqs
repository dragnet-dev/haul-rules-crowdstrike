// Dragnet [Ransomware]: dragnet-ransomware-2024-2363 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 954fc7b2-c90e-5831-bc3e-4250f0223112

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
