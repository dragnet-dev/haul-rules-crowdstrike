// Dragnet [Ransomware]: dragnet-ransomware-2026-0155 — Mass File Rename (SilentRansomGroup)
// Status: deprecated | Level: high | ID: 88c6066a-d161-57fe-8fd6-8c5120d14ef6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
