// Dragnet [Ransomware]: dragnet-ransomware-2024-3642 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: b83bdb35-46da-5d96-b74d-19ce3020399d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
