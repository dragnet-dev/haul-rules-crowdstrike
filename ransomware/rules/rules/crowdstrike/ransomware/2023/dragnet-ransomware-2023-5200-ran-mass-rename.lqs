// Dragnet [Ransomware]: dragnet-ransomware-2023-5200 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: c9b9d158-4a2f-5097-9969-50d5fdfbaf5b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
