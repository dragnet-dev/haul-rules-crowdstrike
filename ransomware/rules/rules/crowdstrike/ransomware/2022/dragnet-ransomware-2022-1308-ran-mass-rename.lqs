// Dragnet [Ransomware]: dragnet-ransomware-2022-1308 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: fd249fa2-0289-563c-bf27-90c824d4824b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
