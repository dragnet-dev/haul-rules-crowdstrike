// Dragnet [Ransomware]: dragnet-ransomware-2025-4443 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: fd234671-3791-596c-8081-a02e8f99eb6b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
