// Dragnet [Ransomware]: dragnet-ransomware-2024-5826 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 41062279-a7a6-5e23-8531-1fb5f2365fff

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
