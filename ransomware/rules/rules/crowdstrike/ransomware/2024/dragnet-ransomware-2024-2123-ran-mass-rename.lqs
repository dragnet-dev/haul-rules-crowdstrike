// Dragnet [Ransomware]: dragnet-ransomware-2024-2123 — Mass File Rename (meow)
// Status: experimental | Level: high | ID: 187ffcab-1fcc-5650-8240-a271f773b4fd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
