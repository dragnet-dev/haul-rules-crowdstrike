// Dragnet [Ransomware]: dragnet-ransomware-2021-0224 — Mass File Rename (revil)
// Status: deprecated | Level: high | ID: 3b34fce8-b558-5d93-aecf-2eb203f25146

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
