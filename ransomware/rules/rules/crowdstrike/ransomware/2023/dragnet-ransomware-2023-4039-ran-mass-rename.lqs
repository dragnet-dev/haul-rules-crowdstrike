// Dragnet [Ransomware]: dragnet-ransomware-2023-4039 — Mass File Rename (play)
// Status: experimental | Level: high | ID: b7596eb3-bb8c-54bc-83f0-27104ed45802

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
