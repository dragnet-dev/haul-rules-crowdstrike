// Dragnet [Ransomware]: dragnet-ransomware-2022-0294 — Mass File Rename (cuba)
// Status: deprecated | Level: high | ID: a9eafcf9-cc0e-5ef6-a91e-571509305ddb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
