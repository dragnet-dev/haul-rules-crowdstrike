// Dragnet [Ransomware]: dragnet-ransomware-2020-0232 — Mass File Rename (doppelpaymer)
// Status: deprecated | Level: high | ID: 82c25eb8-2431-56ac-a681-4bda568ca5c8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
