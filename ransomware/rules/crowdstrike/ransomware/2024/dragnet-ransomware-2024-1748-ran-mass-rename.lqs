// Dragnet [Ransomware]: dragnet-ransomware-2024-1748 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 33c3063f-c325-522d-91f8-77712e632252

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
