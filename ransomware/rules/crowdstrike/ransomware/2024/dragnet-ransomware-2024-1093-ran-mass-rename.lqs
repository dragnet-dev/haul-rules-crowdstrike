// Dragnet [Ransomware]: dragnet-ransomware-2024-1093 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: ea185725-9e69-5adc-b0ec-7269bfb3d82d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
