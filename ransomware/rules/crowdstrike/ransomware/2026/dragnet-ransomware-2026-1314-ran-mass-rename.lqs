// Dragnet [Ransomware]: dragnet-ransomware-2026-1314 — Mass File Rename (worldleaks)
// Status: stable | Level: high | ID: 7f8574f3-783d-5573-a838-d46cfbb4b0c1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
