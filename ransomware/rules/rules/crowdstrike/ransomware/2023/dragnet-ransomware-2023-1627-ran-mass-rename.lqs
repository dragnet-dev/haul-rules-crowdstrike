// Dragnet [Ransomware]: dragnet-ransomware-2023-1627 — Mass File Rename (ransomexx)
// Status: experimental | Level: high | ID: 2807bff2-3d1b-590c-b1a0-9448f8807ab0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
