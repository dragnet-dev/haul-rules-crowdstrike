// Dragnet [Ransomware]: dragnet-ransomware-2024-1902 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: a498241b-7eaa-5be2-8422-4ecc852957a8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
