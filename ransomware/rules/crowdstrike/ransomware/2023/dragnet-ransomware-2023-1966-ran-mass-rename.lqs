// Dragnet [Ransomware]: dragnet-ransomware-2023-1966 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: dcccfdf2-d638-5632-a4c9-d0a56b929b68

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
