// Dragnet [Ransomware]: dragnet-ransomware-2025-2554 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: 14dcde82-b03e-5889-bddf-c73603f7e3fa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
