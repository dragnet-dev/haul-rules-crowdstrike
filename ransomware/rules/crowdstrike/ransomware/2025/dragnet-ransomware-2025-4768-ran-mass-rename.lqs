// Dragnet [Ransomware]: dragnet-ransomware-2025-4768 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 28d49a0c-8cee-58aa-b846-89db67fdcecd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
