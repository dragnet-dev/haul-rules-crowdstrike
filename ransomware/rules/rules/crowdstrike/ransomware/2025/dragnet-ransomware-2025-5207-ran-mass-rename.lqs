// Dragnet [Ransomware]: dragnet-ransomware-2025-5207 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 801c676c-42c4-59a9-9d13-92a7cba4008a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
