// Dragnet [Ransomware]: dragnet-ransomware-2026-2213 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 6c4d8257-3b85-520a-9109-8b24a3c67b2b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
