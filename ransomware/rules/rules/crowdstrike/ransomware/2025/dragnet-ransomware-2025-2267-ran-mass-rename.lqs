// Dragnet [Ransomware]: dragnet-ransomware-2025-2267 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 347fe6ac-c5c4-549f-a17c-a8f9be4328a6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
