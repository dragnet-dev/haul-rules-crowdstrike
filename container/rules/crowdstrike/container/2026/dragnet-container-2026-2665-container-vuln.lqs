// Dragnet [Container]: dragnet-container-2026-2665 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: c3b1a244-1dd4-5700-b7ba-164a7b577922

#event_simpleName=*
| (ImageFileName = *amazonlinux:1* OR ImageFileName = *amazonlinux:2* OR ImageFileName = *debian:7* OR ImageFileName = *debian:8* OR ImageFileName = *debian:9* OR ImageFileName = *photon os:2.0* OR ImageFileName = *redhat/ubi9:*)
| table([timestamp, ComputerName])
| limit(1000)
