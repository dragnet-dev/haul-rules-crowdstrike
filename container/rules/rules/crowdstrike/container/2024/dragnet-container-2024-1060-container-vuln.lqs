// Dragnet [Container]: dragnet-container-2024-1060 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 234121c3-2276-5d5a-b55b-c7de3752aab1

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *ubuntu:18.04* OR ImageFileName = *ubuntu:18.04-ESM* OR ImageFileName = *ubuntu:18.10* OR ImageFileName = *ubuntu:19.04*)
| table([timestamp, ComputerName])
| limit(1000)
