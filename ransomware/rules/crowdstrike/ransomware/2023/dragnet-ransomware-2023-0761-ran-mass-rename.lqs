// Dragnet [Ransomware]: dragnet-ransomware-2023-0761 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 0da23976-9394-5fe3-985c-46bb9b6cb333

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
