// Dragnet [Ransomware]: dragnet-ransomware-2023-2755 — Mass File Rename (malas)
// Status: experimental | Level: high | ID: e989355b-c064-55c2-8462-094eacd1629e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
