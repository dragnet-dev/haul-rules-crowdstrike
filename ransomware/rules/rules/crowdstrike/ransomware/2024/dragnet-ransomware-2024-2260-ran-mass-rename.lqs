// Dragnet [Ransomware]: dragnet-ransomware-2024-2260 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: 97c947d1-807c-5b6b-96c2-44653f502b0e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
