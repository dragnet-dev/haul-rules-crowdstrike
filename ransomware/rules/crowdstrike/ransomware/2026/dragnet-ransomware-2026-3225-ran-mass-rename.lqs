// Dragnet [Ransomware]: dragnet-ransomware-2026-3225 — Mass File Rename (cipherforce)
// Status: stable | Level: high | ID: aad05ca6-f0aa-51ba-a8b6-f78852cf84b4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
