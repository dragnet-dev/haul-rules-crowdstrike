// Dragnet [Container]: dragnet-container-2024-0758 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 87a85255-3166-5ea7-a7ad-caa5db4a422f

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:20.04-ESM* OR ImageFileName = *ubuntu:22.04* OR ImageFileName = *ubuntu:23.04* OR ImageFileName = *ubuntu:23.10* OR ImageFileName = *ubuntu:24.04* OR ImageFileName = *ubuntu:24.10* OR ImageFileName = *ubuntu:25.04* OR ImageFileName = *ubuntu:25.10* OR ImageFileName = *ubuntu:26.04*)
| table([timestamp, ComputerName])
| limit(1000)
