// Dragnet [Ransomware]: dragnet-ransomware-2021-0291 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 7ef639ce-0cfd-5248-b7ea-1adf9f76df01

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
