// Dragnet [Ransomware]: dragnet-ransomware-2023-1694 — Mass File Rename (noescape)
// Status: experimental | Level: high | ID: 9f9a0dd0-56d5-511d-9581-8414cda499ef

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
