// Dragnet [Ransomware]: dragnet-ransomware-2022-1536 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: a38ad745-5f17-5e88-bd91-d2ff7b7eba0e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
