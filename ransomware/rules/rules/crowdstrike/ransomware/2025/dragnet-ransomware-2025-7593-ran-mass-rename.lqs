// Dragnet [Ransomware]: dragnet-ransomware-2025-7593 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: c8669231-c907-5c61-81b5-dc92ac9941f6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
