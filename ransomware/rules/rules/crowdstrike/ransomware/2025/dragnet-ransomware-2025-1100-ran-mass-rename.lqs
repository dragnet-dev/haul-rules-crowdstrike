// Dragnet [Ransomware]: dragnet-ransomware-2025-1100 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 34099f03-eb34-59a4-a0d0-251f525cd311

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
