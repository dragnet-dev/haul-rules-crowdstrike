// Dragnet [Ransomware]: dragnet-ransomware-2024-3641 — Mass File Rename (ransomhouse)
// Status: experimental | Level: high | ID: 1bcba2ce-e125-551d-abb8-619dd8fe21f0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
