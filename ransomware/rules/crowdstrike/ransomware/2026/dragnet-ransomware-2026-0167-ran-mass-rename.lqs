// Dragnet [Ransomware]: dragnet-ransomware-2026-0167 — Mass File Rename (lockbit5)
// Status: stable | Level: high | ID: b6193a56-40bc-5ccd-83bd-d9d969cfed7a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
