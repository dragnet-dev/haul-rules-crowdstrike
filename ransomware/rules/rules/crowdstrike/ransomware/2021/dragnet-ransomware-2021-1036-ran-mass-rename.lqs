// Dragnet [Ransomware]: dragnet-ransomware-2021-1036 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: ac2aeb2d-07e0-509c-9fa4-3b08f32f9ee0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
