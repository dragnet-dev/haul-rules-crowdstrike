// Dragnet [Ransomware]: dragnet-ransomware-2022-0852 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 2a6582f1-34b9-535d-b719-31c4d30767e8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
