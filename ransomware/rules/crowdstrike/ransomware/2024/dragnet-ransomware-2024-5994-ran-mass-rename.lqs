// Dragnet [Ransomware]: dragnet-ransomware-2024-5994 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: e76cd486-2e9f-589d-91b9-9041a804f3f1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
