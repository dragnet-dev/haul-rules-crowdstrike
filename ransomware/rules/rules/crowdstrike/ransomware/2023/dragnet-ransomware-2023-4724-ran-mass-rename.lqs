// Dragnet [Ransomware]: dragnet-ransomware-2023-4724 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 7454bde7-c403-52f7-931c-3456964d4786

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
