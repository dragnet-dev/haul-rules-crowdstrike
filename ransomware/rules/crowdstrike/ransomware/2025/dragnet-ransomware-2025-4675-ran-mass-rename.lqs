// Dragnet [Ransomware]: dragnet-ransomware-2025-4675 — Mass File Rename (lockbit5)
// Status: test | Level: high | ID: 4454e94d-8bf9-52a3-a72b-b53044362f0b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
