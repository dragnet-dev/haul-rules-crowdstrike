// Dragnet [Ransomware]: dragnet-ransomware-2025-0322 — Mass File Rename (dragonforce)
// Status: test | Level: high | ID: cd4adf4d-bf23-512f-9203-9a7726112ad4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
