// Dragnet [Ransomware]: dragnet-ransomware-2026-1621 — Mass File Rename (embargo)
// Status: stable | Level: high | ID: 58e5378d-1561-5afe-a525-9c952f96df53

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
