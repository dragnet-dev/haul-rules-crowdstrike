// Dragnet [Ransomware]: dragnet-ransomware-2023-4169 — Mass File Rename (noescape)
// Status: experimental | Level: high | ID: 30b6c4bf-c89e-501a-81c6-5997265b2258

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
