// Dragnet [Ransomware]: dragnet-ransomware-2020-0228 — Mass File Rename (revil)
// Status: deprecated | Level: high | ID: be3c5e85-e34a-51fa-b912-80e82a5fda22

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
