// Dragnet [Ransomware]: dragnet-ransomware-2025-4495 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: 4950a269-fc3b-599c-a94a-bcb0009529ee

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
