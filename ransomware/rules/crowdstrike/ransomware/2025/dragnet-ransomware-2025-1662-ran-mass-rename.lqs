// Dragnet [Ransomware]: dragnet-ransomware-2025-1662 — Mass File Rename (play)
// Status: experimental | Level: high | ID: fb30c47c-015a-51af-806d-693464815ebb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
