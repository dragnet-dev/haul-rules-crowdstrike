// Dragnet [Ransomware]: dragnet-ransomware-2026-0666 — Mass File Rename (fulcrumsec)
// Status: stable | Level: high | ID: 5710f757-ca3d-56eb-ac31-cd4c741077e9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
