// Dragnet [Ransomware]: dragnet-ransomware-2025-0731 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 1119cbb2-d361-56f8-939d-0518aec012a8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
