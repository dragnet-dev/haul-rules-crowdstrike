// Dragnet [Container]: dragnet-container-2026-2701 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 169aee82-70a3-5ab5-ac6e-dc66f7fb5b6c

#event_simpleName=*
| (ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10* OR ImageFileName = *ubuntu:13.04* OR ImageFileName = *ubuntu:13.10*)
| table([timestamp, ComputerName])
| limit(1000)
