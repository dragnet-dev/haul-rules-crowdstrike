// Dragnet [Ransomware]: dragnet-ransomware-2024-3913 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: cb75d3b8-e3bd-5248-b66b-5bc427bf0635

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
