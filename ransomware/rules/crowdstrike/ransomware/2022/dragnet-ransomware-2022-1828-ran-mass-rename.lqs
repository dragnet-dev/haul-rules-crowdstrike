// Dragnet [Ransomware]: dragnet-ransomware-2022-1828 — Mass File Rename (avoslocker)
// Status: deprecated | Level: high | ID: 91546384-bb40-5a84-9897-bf27296f8241

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
