// Dragnet [Ransomware]: dragnet-ransomware-2025-6739 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: 1533a47c-8c1a-5202-96ac-55d5bc064dd8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
