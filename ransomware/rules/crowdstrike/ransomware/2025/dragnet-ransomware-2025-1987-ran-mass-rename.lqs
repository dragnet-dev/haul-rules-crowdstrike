// Dragnet [Ransomware]: dragnet-ransomware-2025-1987 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: ac35dab3-39a5-5e09-a837-5b0e627aeae2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
