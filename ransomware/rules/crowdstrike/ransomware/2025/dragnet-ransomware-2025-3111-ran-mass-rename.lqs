// Dragnet [Ransomware]: dragnet-ransomware-2025-3111 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: cf577136-60cd-52f3-bf3f-a3f6420c728b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
