// Dragnet [Ransomware]: dragnet-ransomware-2022-0406 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 0c60092f-f9e3-5928-9b55-e1d232af9400

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
