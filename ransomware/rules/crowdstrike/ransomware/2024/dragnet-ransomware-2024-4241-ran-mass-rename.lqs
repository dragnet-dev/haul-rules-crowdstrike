// Dragnet [Ransomware]: dragnet-ransomware-2024-4241 — Mass File Rename (abyss)
// Status: deprecated | Level: high | ID: ef93c690-871a-509c-a710-57dc2e5a97dc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
