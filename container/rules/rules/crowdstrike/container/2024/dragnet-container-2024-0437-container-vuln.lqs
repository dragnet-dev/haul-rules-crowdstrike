| (ImageFileName = *alpine:3.10* OR ImageFileName = *alpine:3.11* OR ImageFileName = *alpine:3.12* OR ImageFileName = *alpine:3.13* OR ImageFileName = *alpine:3.14* OR ImageFileName = *alpine:3.15* OR ImageFileName = *alpine:3.16* OR ImageFileName = *alpine:3.7* OR ImageFileName = *alpine:3.8* OR ImageFileName = *alpine:3.9* OR ImageFileName = *chainguard:* OR ImageFileName = *redhat/ubi9:*)
