// Dragnet [Ransomware]: dragnet-ransomware-2025-4044 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: ccd60b76-54e2-5b30-9ed6-9b995fba4054

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
