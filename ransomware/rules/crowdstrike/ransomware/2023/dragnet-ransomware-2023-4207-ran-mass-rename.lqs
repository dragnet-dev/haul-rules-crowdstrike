// Dragnet [Ransomware]: dragnet-ransomware-2023-4207 — Mass File Rename (royal)
// Status: experimental | Level: high | ID: 9c96af44-7e5e-5a9e-b7fb-4d49569a3d3f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
