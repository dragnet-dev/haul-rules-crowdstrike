// Dragnet [Ransomware]: dragnet-ransomware-2023-3667 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 9bbc1b22-453f-50ea-bc12-a38f09da829c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
