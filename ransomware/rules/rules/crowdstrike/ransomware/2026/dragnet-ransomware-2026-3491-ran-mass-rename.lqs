// Dragnet [Ransomware]: dragnet-ransomware-2026-3491 — Mass File Rename (lapsus$)
// Status: deprecated | Level: high | ID: ee38087a-bef8-56c2-b470-40ea7d2ecc63

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
