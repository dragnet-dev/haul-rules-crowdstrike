// Dragnet [Ransomware]: dragnet-ransomware-2025-7319 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: ebca574c-45c8-5ae5-b7c0-af6f60af4d94

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
