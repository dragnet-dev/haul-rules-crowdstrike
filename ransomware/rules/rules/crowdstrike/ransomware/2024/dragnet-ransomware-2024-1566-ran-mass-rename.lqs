// Dragnet [Ransomware]: dragnet-ransomware-2024-1566 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: f5c3016f-cbc8-5aeb-a440-5ed16ee5facc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
