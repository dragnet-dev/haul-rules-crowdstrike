// Dragnet [Ransomware]: dragnet-ransomware-2024-3730 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: dc37ecde-b793-5d2d-ac3c-af13128a4492

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
