// Dragnet [Ransomware]: dragnet-ransomware-2024-3060 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 98444569-5ae2-5ddb-8840-d136b5df3e15

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
