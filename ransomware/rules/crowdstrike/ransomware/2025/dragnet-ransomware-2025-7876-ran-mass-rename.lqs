// Dragnet [Ransomware]: dragnet-ransomware-2025-7876 — Mass File Rename (kairos)
// Status: experimental | Level: high | ID: b2faba8a-9fdf-5a10-9152-10177aae85cf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
