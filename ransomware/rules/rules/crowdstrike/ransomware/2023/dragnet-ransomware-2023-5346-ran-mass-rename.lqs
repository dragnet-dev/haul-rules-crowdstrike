// Dragnet [Ransomware]: dragnet-ransomware-2023-5346 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 6e66e867-bc6b-574c-a5d5-608a0a7332c9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
