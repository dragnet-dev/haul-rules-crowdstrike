// Dragnet [Ransomware]: dragnet-ransomware-2023-1211 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 5554b9fe-9c43-522a-a373-00405c1923a8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
