// Dragnet [Ransomware]: dragnet-ransomware-2025-4637 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 717efe90-90d0-5bc9-bbb5-5c38ab152662

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
