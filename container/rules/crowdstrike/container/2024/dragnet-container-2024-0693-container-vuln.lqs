// Dragnet [Container]: dragnet-container-2024-0693 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 47fe6e9c-8c9c-5a1f-84ec-66de4db4e652

#event_simpleName=*
| (ImageFileName = *almalinux:8* OR ImageFileName = *almalinux:9* OR ImageFileName = *alpine:3.19* OR ImageFileName = *alpine:3.20* OR ImageFileName = *amazonlinux:2023* OR ImageFileName = *chainguard:* OR ImageFileName = *oraclelinux:8* OR ImageFileName = *oraclelinux:9* OR ImageFileName = *photon os:3.0* OR ImageFileName = *photon os:4.0* OR ImageFileName = *photon os:5.0* OR ImageFileName = *ubuntu:22.04* OR ImageFileName = *ubuntu:23.04* OR ImageFileName = *ubuntu:23.10* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
