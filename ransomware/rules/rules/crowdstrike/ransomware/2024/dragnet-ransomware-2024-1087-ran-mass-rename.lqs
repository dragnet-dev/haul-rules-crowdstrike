// Dragnet [Ransomware]: dragnet-ransomware-2024-1087 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: e99e5de2-9db7-5596-804c-d3bb749e4f73

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
