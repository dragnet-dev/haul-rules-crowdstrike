// Dragnet [Ransomware]: dragnet-ransomware-2023-0043 — Mass File Rename (losttrust)
// Status: deprecated | Level: high | ID: 1c679c80-1e19-5e4c-bf0b-de5e49b25a48

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
