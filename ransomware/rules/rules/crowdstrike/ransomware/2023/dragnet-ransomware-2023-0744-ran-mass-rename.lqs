// Dragnet [Ransomware]: dragnet-ransomware-2023-0744 — Mass File Rename (noescape)
// Status: experimental | Level: high | ID: b9207819-5a65-5579-b790-a205bc74d466

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
