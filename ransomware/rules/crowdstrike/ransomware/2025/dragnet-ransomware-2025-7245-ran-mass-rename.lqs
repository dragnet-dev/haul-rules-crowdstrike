// Dragnet [Ransomware]: dragnet-ransomware-2025-7245 — Mass File Rename (ransomhouse)
// Status: experimental | Level: high | ID: 18f2e3f9-98a3-5b5d-9916-399d812d1a0c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
