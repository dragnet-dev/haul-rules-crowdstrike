// Dragnet [Ransomware]: dragnet-ransomware-2024-1601 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: eca1daf1-7293-588d-9ed5-4156a9399afc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
