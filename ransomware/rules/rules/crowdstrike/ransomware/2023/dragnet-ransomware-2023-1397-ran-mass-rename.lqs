// Dragnet [Ransomware]: dragnet-ransomware-2023-1397 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 3f4bc99f-b365-5f8b-978a-07a3fc1b2a46

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
