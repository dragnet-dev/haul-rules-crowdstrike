// Dragnet [Ransomware]: dragnet-ransomware-2025-2874 — Mass File Rename (securotrop)
// Status: experimental | Level: high | ID: 63ee6f01-f1f8-5cfa-b5d3-95bec7680747

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
