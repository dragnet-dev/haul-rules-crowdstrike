// Dragnet [Ransomware]: dragnet-ransomware-2024-2232 — Mass File Rename (threeam)
// Status: experimental | Level: high | ID: 03b3bbfb-0dba-57b1-aff6-18a8dbfca693

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
