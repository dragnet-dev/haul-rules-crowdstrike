// Dragnet [Ransomware]: dragnet-ransomware-2023-0520 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: c418cfb3-8eea-5b48-a9cd-f7f67750dc4d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
