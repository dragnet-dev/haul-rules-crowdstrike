// Dragnet [Ransomware]: dragnet-ransomware-2023-1958 — Mass File Rename (toufan)
// Status: deprecated | Level: high | ID: 0d31d327-f599-5890-bfcb-663c43222b55

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
