// Dragnet [Ransomware]: dragnet-ransomware-2024-4453 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 0119da9b-d8e7-5636-b7c2-d0c02df002ba

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
