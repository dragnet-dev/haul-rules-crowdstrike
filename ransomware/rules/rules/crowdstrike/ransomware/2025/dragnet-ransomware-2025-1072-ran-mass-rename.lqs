// Dragnet [Ransomware]: dragnet-ransomware-2025-1072 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: fa0baf3b-d423-5a8e-9de6-14c9462d6fae

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
