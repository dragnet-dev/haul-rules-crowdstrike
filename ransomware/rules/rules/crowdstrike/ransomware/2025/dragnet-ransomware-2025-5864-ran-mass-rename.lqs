// Dragnet [Ransomware]: dragnet-ransomware-2025-5864 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 8bf75af8-8863-529f-9a26-0ca3a0c85036

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
