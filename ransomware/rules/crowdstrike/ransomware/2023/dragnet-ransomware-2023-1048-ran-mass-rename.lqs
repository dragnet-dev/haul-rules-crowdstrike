// Dragnet [Ransomware]: dragnet-ransomware-2023-1048 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 93ef48f3-d1a1-55d2-821c-869439db8d3f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
