// Dragnet [Ransomware]: dragnet-ransomware-2022-3072 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 6bb2171e-2dce-5f81-b58a-b0919b63cf2b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
