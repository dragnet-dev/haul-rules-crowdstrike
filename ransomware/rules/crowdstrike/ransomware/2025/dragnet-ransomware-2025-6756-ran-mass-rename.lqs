// Dragnet [Ransomware]: dragnet-ransomware-2025-6756 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 88be1eea-7d4f-5df8-a805-fedca263f92f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
