// Dragnet [Ransomware]: dragnet-ransomware-2026-0644 — Mass File Rename (dragonforce)
// Status: test | Level: high | ID: 13233749-0fe2-55be-b4da-833ad12dede8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
