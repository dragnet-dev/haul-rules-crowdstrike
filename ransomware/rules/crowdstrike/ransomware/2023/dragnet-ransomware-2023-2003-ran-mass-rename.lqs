// Dragnet [Ransomware]: dragnet-ransomware-2023-2003 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 797a9f56-3393-5186-8afd-38d1fa8ff6dc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
