// Dragnet [Ransomware]: dragnet-ransomware-2025-7875 — Mass File Rename (nitrogen)
// Status: experimental | Level: high | ID: c936b64f-c145-5734-927d-58025e5145f7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
