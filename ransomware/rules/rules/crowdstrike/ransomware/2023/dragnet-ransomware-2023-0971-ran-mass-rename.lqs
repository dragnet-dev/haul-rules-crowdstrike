// Dragnet [Ransomware]: dragnet-ransomware-2023-0971 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: ba9a905d-5cbe-54e5-b0ac-7e7126be3e5b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
