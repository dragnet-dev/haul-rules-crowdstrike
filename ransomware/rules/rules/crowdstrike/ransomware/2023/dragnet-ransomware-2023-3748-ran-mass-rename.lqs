// Dragnet [Ransomware]: dragnet-ransomware-2023-3748 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: e6f5a6d3-2374-5b6a-9eca-215ee8c106f7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
