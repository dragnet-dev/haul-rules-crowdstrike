// Dragnet [Ransomware]: dragnet-ransomware-2026-0054 — Mass File Rename (handala)
// Status: stable | Level: high | ID: 4c837dce-3dfc-520c-b1c7-025d3eba5ef4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
