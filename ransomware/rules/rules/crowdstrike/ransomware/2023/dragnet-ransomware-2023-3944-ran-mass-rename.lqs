// Dragnet [Ransomware]: dragnet-ransomware-2023-3944 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 93b7f765-061d-5e88-9a1f-8f667d315f39

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
