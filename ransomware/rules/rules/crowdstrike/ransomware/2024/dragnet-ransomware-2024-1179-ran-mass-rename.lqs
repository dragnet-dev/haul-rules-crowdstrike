// Dragnet [Ransomware]: dragnet-ransomware-2024-1179 — Mass File Rename (ransomexx)
// Status: experimental | Level: high | ID: e2f4560e-8702-544b-949c-18d43ea2f089

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
