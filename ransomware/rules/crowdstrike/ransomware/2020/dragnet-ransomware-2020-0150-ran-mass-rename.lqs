// Dragnet [Ransomware]: dragnet-ransomware-2020-0150 — Mass File Rename (ragnarlocker)
// Status: deprecated | Level: high | ID: 6249fe4c-521c-508b-9b35-5150cb96ff2d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
