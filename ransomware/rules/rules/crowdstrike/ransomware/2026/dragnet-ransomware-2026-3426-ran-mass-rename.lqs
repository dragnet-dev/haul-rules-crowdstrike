// Dragnet [Ransomware]: dragnet-ransomware-2026-3426 — Mass File Rename (nightspire)
// Status: deprecated | Level: high | ID: b2cb714b-8887-56b3-a0f3-b98933d6b12a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
