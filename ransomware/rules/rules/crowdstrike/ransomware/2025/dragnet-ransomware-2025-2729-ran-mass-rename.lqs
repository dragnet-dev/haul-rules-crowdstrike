// Dragnet [Ransomware]: dragnet-ransomware-2025-2729 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 244bd13a-4a1b-5182-97d6-7a880d8541d6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
