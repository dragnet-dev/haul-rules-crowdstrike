// Dragnet [Ransomware]: dragnet-ransomware-2023-2669 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 35b9a818-d14c-5d38-aeea-1945616ac4c6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
