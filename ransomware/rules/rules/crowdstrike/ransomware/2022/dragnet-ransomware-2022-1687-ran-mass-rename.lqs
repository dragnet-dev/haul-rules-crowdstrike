// Dragnet [Ransomware]: dragnet-ransomware-2022-1687 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 046142ad-b470-596d-b609-e779dfcd636a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
