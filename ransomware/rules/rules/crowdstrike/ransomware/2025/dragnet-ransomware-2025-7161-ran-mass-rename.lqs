// Dragnet [Ransomware]: dragnet-ransomware-2025-7161 — Mass File Rename (threeam)
// Status: experimental | Level: high | ID: 4b29302d-5234-5df6-a3a7-0b57a0031b88

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
