// Dragnet [Ransomware]: dragnet-ransomware-2025-0547 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 6843ce50-79eb-5979-b629-fcb130b0f667

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
