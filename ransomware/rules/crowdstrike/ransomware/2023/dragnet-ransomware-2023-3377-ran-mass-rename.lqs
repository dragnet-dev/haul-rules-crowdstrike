// Dragnet [Ransomware]: dragnet-ransomware-2023-3377 — Mass File Rename (crypto24)
// Status: deprecated | Level: high | ID: 58398e5f-1509-5703-a6c6-751bf0605155

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
