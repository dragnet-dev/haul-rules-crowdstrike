// Dragnet [Ransomware]: dragnet-ransomware-2023-4179 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 56735722-996b-5a8d-b585-96034ccc6d5a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
