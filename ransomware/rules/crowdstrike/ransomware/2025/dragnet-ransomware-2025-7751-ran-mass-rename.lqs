// Dragnet [Ransomware]: dragnet-ransomware-2025-7751 — Mass File Rename (payoutsking)
// Status: deprecated | Level: high | ID: 3264b71b-93be-5dcf-aa90-f93e27f68472

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
