// Dragnet [Ransomware]: dragnet-ransomware-2021-1233 — Mass File Rename (rook)
// Status: deprecated | Level: high | ID: 2f64e7ad-1148-5d35-a29e-3b1d16922312

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
