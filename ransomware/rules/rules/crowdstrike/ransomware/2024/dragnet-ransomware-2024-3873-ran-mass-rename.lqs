// Dragnet [Ransomware]: dragnet-ransomware-2024-3873 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 16acb2fb-f883-532a-8cca-484c0bc4f0d4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
