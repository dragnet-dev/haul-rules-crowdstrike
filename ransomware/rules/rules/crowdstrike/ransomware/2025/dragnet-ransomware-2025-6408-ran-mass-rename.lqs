// Dragnet [Ransomware]: dragnet-ransomware-2025-6408 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: a7f0778c-3eba-57a0-80c9-cdc316063cfd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
