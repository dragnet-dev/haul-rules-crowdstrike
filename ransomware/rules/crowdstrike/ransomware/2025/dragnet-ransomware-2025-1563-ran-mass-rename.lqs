// Dragnet [Ransomware]: dragnet-ransomware-2025-1563 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: 40da55f0-dc75-5f6c-a184-b8fff2ef93c9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
