// Dragnet [Ransomware]: dragnet-ransomware-2024-0631 — Mass File Rename (sarcoma)
// Status: deprecated | Level: high | ID: e3e9e568-ca7c-5717-baba-3740a6d5ea9e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
