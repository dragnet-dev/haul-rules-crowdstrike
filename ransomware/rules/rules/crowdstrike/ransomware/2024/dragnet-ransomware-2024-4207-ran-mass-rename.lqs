// Dragnet [Ransomware]: dragnet-ransomware-2024-4207 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: e350eace-ffa4-5b0e-8a7f-103a40bf86bf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
