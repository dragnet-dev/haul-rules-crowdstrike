// Dragnet [Ransomware]: dragnet-ransomware-2025-1910 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 28e2015f-f467-5164-92fd-a102147cd837

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
