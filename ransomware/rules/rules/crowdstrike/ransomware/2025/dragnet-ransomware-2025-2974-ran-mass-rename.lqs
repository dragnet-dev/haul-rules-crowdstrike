// Dragnet [Ransomware]: dragnet-ransomware-2025-2974 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 03edfce3-ba69-5a9d-9db8-c5407d44e854

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
