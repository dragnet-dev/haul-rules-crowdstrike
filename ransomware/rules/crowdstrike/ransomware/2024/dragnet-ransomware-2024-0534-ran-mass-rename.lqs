// Dragnet [Ransomware]: dragnet-ransomware-2024-0534 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 59d26d3a-287a-58e4-941f-d8bd3d3227a1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
