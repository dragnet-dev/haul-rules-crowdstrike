// Dragnet [Ransomware]: dragnet-ransomware-2024-3223 — Mass File Rename (qilin)
// Status: deprecated | Level: high | ID: 99bd13a7-f036-528f-8380-8ee11788698b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
