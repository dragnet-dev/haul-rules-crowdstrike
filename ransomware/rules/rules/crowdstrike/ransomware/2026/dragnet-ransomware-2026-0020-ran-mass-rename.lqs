// Dragnet [Ransomware]: dragnet-ransomware-2026-0020 — Mass File Rename (dragonforce)
// Status: test | Level: high | ID: ecc2ce2b-5529-5b06-bb91-599d4d8628a3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
