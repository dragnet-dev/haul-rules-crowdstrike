// Dragnet [Ransomware]: dragnet-ransomware-2023-0523 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 83bc1dd2-a90a-5aef-bdad-7e4200fa2bcc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
