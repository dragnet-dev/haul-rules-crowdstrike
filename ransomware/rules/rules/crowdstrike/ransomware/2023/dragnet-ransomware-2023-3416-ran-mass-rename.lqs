// Dragnet [Ransomware]: dragnet-ransomware-2023-3416 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 821d8ad1-4b0d-5354-81b9-4e26b1ccd315

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
