// Dragnet [Ransomware]: dragnet-ransomware-2023-0371 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 01a88a2e-1f20-55ac-900e-d178969c6b10

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
