// Dragnet [Ransomware]: dragnet-ransomware-2025-0519 — Mass File Rename (incransom)
// Status: test | Level: high | ID: a5fd8038-ebab-587c-bff1-c704cd9a4bc0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
