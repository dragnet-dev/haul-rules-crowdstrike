// Dragnet [Ransomware]: dragnet-ransomware-2023-1231 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 62f43e1a-b5f1-577f-b22d-793d8323b5e2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
