// Dragnet [Ransomware]: dragnet-ransomware-2024-1770 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 2ec7b832-5836-5708-a5ee-bb4e1a2bd1ef

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
