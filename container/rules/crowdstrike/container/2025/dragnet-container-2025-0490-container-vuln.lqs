// Dragnet [Container]: dragnet-container-2025-0490 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 47592917-ed20-5651-80f8-421e32524ab4

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
