// Dragnet [Ransomware]: dragnet-ransomware-2025-3678 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 5573aba3-9fdb-5117-9a5f-b625e51b98eb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
