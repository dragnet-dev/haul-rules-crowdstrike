// Dragnet [Ransomware]: dragnet-ransomware-2025-1142 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: b3d049bc-3375-5bd2-b26c-efd7b4fa2e0e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
