// Dragnet [Ransomware]: dragnet-ransomware-2023-5062 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 2dedfde8-f948-5b0b-834b-7d8264256968

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
