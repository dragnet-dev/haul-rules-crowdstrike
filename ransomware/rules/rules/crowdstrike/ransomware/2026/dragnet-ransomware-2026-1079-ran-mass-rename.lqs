// Dragnet [Ransomware]: dragnet-ransomware-2026-1079 — Mass File Rename (thegentlemen)
// Status: test | Level: high | ID: 98c39e1b-9ac0-501d-8e52-5b620d3954ce

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
