// Dragnet [Ransomware]: dragnet-ransomware-2024-0698 — Mass File Rename (dragonforce)
// Status: deprecated | Level: high | ID: c97ce280-5725-5078-8066-7c02a6398b3f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
