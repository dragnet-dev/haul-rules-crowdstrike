// Dragnet [Container]: dragnet-container-2026-1433 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 9361d3c3-6353-508e-951f-718d19fe3fe1

#event_simpleName=*
| (ImageFileName = *amazonlinux:1* OR ImageFileName = *debian:7* OR ImageFileName = *debian:8* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:14.04* OR ImageFileName = *ubuntu:14.04-ESM* OR ImageFileName = *ubuntu:15.10*)
| table([timestamp, ComputerName])
| limit(1000)
