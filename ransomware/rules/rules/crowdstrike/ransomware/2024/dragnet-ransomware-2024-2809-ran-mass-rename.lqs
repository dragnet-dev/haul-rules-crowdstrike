// Dragnet [Ransomware]: dragnet-ransomware-2024-2809 — Mass File Rename (SilentRansomGroup)
// Status: deprecated | Level: high | ID: 2ec4f229-ad40-50d1-ac44-ed41c5f45f51

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
