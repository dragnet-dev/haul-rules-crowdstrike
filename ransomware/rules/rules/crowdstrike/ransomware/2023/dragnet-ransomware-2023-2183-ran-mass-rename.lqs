// Dragnet [Ransomware]: dragnet-ransomware-2023-2183 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 30d5a266-30c8-51b0-9198-ab3ee25143c8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
