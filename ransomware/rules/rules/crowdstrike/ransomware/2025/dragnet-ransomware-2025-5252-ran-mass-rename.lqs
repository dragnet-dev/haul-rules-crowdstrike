// Dragnet [Ransomware]: dragnet-ransomware-2025-5252 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 93358024-4b51-5c1c-ae0c-06e66abb75a9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
