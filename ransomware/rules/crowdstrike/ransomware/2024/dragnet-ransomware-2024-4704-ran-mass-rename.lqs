// Dragnet [Ransomware]: dragnet-ransomware-2024-4704 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 5014ce02-738c-5517-bb46-da45039d8e60

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
