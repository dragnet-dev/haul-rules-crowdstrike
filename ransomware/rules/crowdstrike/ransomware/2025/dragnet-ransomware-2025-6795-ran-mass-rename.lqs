// Dragnet [Ransomware]: dragnet-ransomware-2025-6795 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 183ce0e7-5e48-5f3c-bbbd-39f0c9cd3028

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
