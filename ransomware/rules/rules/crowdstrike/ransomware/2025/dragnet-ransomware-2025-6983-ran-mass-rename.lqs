// Dragnet [Ransomware]: dragnet-ransomware-2025-6983 — Mass File Rename (securotrop)
// Status: test | Level: high | ID: 81292870-741c-5a82-8977-d3f5c89d08ed

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
