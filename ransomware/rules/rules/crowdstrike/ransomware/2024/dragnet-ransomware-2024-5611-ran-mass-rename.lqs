// Dragnet [Ransomware]: dragnet-ransomware-2024-5611 — Mass File Rename (rhysida)
// Status: deprecated | Level: high | ID: 0b9b20bb-e8cd-52b4-957b-2b7e3c704e6b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
