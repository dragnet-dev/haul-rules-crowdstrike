// Dragnet [Ransomware]: dragnet-ransomware-2026-1929 — Mass File Rename (anubis)
// Status: stable | Level: high | ID: 48dd5feb-1655-51cf-aa14-ec2cff87b677

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
