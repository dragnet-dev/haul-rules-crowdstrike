// Dragnet [Ransomware]: dragnet-ransomware-2021-0366 — Mass File Rename (ragnarlocker)
// Status: deprecated | Level: high | ID: 177a9f96-6e0d-5b12-b7e3-192d8cb4767b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
