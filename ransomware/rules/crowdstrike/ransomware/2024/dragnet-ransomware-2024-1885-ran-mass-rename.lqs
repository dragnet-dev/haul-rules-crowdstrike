// Dragnet [Ransomware]: dragnet-ransomware-2024-1885 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 0b0eb9cf-c010-5fb1-897e-3a92a7d74c1b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
