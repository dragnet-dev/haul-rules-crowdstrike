// Dragnet [Ransomware]: dragnet-ransomware-2025-1046 — Mass File Rename (anubis)
// Status: experimental | Level: high | ID: 2fc87040-0877-5b8b-a43f-d82e3fe93c06

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
