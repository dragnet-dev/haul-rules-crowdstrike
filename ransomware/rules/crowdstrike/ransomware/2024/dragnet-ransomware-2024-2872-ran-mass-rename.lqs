// Dragnet [Ransomware]: dragnet-ransomware-2024-2872 — Mass File Rename (cloak)
// Status: deprecated | Level: high | ID: 4ba502db-04bc-58af-b42f-aa725da9b31f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
