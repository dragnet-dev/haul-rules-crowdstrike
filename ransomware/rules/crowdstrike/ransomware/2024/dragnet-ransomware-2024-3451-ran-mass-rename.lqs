// Dragnet [Ransomware]: dragnet-ransomware-2024-3451 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 08880706-817b-5a8e-9f49-01d8e571dc45

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
