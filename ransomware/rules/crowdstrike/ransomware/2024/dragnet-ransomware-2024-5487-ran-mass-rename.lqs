// Dragnet [Ransomware]: dragnet-ransomware-2024-5487 — Mass File Rename (darkvault)
// Status: experimental | Level: high | ID: 450bd59c-31e1-5b3c-8653-4ef8f745d2d1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
