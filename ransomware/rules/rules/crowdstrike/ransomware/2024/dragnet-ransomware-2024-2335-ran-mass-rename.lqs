// Dragnet [Ransomware]: dragnet-ransomware-2024-2335 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 2b2d62f6-1692-5659-befa-d08687d8b20c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
