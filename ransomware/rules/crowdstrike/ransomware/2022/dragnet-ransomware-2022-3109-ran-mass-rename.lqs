// Dragnet [Ransomware]: dragnet-ransomware-2022-3109 — Mass File Rename (onyx)
// Status: deprecated | Level: high | ID: 4dd63187-9d48-5dfb-8d90-4c84184b34b3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
