// Dragnet [Ransomware]: dragnet-ransomware-2022-2792 — Mass File Rename (royal)
// Status: deprecated | Level: high | ID: 1d2de650-91f5-5b97-bf5b-880ecebd0e7b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
