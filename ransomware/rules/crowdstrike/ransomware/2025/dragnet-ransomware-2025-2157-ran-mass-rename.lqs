// Dragnet [Ransomware]: dragnet-ransomware-2025-2157 — Mass File Rename (blackshrantac)
// Status: experimental | Level: high | ID: 64e30b1f-dab3-5888-bdf1-51427aa94d0c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
