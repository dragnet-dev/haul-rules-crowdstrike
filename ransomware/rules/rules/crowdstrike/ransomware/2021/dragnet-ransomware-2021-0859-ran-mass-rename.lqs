// Dragnet [Ransomware]: dragnet-ransomware-2021-0859 — Mass File Rename (ransomexx)
// Status: deprecated | Level: high | ID: 2d971817-345e-55f5-b431-ba288c775eb7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
