// Dragnet [Ransomware]: dragnet-ransomware-2023-2941 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 186d382b-ae2c-5e76-b2f2-bb53258c5dcd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
