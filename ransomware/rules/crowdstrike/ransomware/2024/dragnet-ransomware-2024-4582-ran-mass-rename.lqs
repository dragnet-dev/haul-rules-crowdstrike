// Dragnet [Ransomware]: dragnet-ransomware-2024-4582 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 76cf1809-9350-5e27-aaec-169868f33eb5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
