// Dragnet [Ransomware]: dragnet-ransomware-2024-3152 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: e8e3effc-d0bb-5a70-bf50-facd15b74c48

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
