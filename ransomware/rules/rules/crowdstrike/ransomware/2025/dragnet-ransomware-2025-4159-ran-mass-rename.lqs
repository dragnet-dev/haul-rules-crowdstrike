// Dragnet [Ransomware]: dragnet-ransomware-2025-4159 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 05e9f4d2-3776-57a1-8b82-0cce14bf5d9c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
