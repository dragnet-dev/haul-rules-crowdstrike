// Dragnet [Ransomware]: dragnet-ransomware-2022-0204 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 8419f308-1d3c-5db8-b037-1538ee41b909

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
