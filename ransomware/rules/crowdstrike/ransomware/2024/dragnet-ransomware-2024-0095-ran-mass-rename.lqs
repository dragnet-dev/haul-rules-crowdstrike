// Dragnet [Ransomware]: dragnet-ransomware-2024-0095 — Mass File Rename (handala)
// Status: experimental | Level: high | ID: d23a4c17-8952-5618-b0d1-059ff0a09134

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
