// Dragnet [Ransomware]: dragnet-ransomware-2025-3519 — Mass File Rename (hellcat)
// Status: deprecated | Level: high | ID: d46b5ca7-5aea-5c01-905e-149c97c6a0c9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
