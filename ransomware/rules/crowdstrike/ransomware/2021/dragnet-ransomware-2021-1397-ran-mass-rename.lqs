// Dragnet [Ransomware]: dragnet-ransomware-2021-1397 — Mass File Rename (blackmatter)
// Status: deprecated | Level: high | ID: fd863dd0-b451-5309-8302-809f629c048e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
