// Dragnet [Ransomware]: dragnet-ransomware-2024-3256 — Mass File Rename (cloak)
// Status: deprecated | Level: high | ID: 4405eece-0be4-58f1-8405-974dec019af3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
