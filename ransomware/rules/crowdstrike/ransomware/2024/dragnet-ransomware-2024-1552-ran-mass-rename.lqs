// Dragnet [Ransomware]: dragnet-ransomware-2024-1552 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: 5532f78b-787c-5647-acde-dec83c8ce56e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
