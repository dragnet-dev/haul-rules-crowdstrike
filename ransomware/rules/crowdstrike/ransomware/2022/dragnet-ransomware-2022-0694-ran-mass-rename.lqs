// Dragnet [Ransomware]: dragnet-ransomware-2022-0694 — Mass File Rename (royal)
// Status: deprecated | Level: high | ID: b34b5be2-aaa1-58d8-b979-76fec382714d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
