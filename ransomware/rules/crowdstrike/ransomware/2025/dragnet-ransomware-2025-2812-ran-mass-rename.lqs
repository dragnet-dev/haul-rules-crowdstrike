// Dragnet [Ransomware]: dragnet-ransomware-2025-2812 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 37e5870d-f98a-5002-88d8-4ca35b29d411

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
