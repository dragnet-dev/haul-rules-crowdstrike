// Dragnet [Container]: dragnet-container-2026-2473 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: fc17beb7-edf3-5ee3-876a-0cb9bbafd1e8

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
