// Dragnet [Ransomware]: dragnet-ransomware-2025-2559 — Mass File Rename (worldleaks)
// Status: experimental | Level: high | ID: 473419a9-cef2-5a22-9aab-37fbf40dac2a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
