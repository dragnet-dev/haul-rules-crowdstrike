// Dragnet [Ransomware]: dragnet-ransomware-2023-2532 — Mass File Rename (rhysida)
// Status: experimental | Level: high | ID: 51dc32d0-4360-52b1-bebc-1aeb8f0dced1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
