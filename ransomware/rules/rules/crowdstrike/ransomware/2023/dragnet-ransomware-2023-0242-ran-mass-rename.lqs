// Dragnet [Ransomware]: dragnet-ransomware-2023-0242 — Mass File Rename (ransomhouse)
// Status: experimental | Level: high | ID: dfee11d1-6e2a-5a2a-816d-9cce9084c177

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
