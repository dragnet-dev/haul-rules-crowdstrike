// Dragnet [Ransomware]: dragnet-ransomware-2024-5126 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: 667e985d-8813-5251-afe5-4b9f39aa30e3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
