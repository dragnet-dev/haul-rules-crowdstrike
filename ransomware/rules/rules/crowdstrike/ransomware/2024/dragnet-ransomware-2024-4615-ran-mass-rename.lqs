// Dragnet [Ransomware]: dragnet-ransomware-2024-4615 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: b1b169d9-da18-5c37-8c31-7c509a6d64e7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
