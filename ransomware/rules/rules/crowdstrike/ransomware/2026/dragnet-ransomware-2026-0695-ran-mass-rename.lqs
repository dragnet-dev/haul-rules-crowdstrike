// Dragnet [Ransomware]: dragnet-ransomware-2026-0695 — Mass File Rename (payoutsking)
// Status: deprecated | Level: high | ID: 62cbbd02-47b2-5c86-8e84-c1b70b859b83

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
