// Dragnet [Ransomware]: dragnet-ransomware-2023-2401 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 92feb044-81b0-501d-b8ff-94c12066035d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
