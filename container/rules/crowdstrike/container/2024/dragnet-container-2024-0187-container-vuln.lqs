// Dragnet [Container]: dragnet-container-2024-0187 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 7aad3b46-2c44-5eb6-a46a-6adb2320d3f4

#event_simpleName=*
| (ImageFileName = *amazonlinux:2023* OR ImageFileName = *oraclelinux:7* OR ImageFileName = *oraclelinux:8* OR ImageFileName = *redhat/ubi9:*)
| table([timestamp, ComputerName])
| limit(1000)
