// Dragnet [Ransomware]: dragnet-ransomware-2025-7483 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: f5117f8b-1e59-5b63-ab5b-4dbe4881149e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
