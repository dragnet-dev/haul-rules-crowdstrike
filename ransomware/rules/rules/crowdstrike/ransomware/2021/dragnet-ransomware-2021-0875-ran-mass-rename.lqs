// Dragnet [Ransomware]: dragnet-ransomware-2021-0875 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 88a99629-b34c-5a77-a4b6-0cf78d9f69e7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
