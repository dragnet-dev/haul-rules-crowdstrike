// Dragnet [Ransomware]: dragnet-ransomware-2026-0362 — Mass File Rename (worldleaks)
// Status: test | Level: high | ID: e6daa7b9-0ac0-5a9d-b77c-21ed7cadeb57

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
