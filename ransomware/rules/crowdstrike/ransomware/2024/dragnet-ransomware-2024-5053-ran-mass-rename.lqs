// Dragnet [Ransomware]: dragnet-ransomware-2024-5053 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 8ed387e6-05f8-5e41-a539-49e3c5fc54af

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
