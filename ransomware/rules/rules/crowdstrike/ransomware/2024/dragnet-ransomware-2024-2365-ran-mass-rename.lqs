// Dragnet [Ransomware]: dragnet-ransomware-2024-2365 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: 4752e894-b828-5e5e-909a-095e3f40830a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
