// Dragnet [Ransomware]: dragnet-ransomware-2022-1479 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: a91392d2-b92f-5a02-94e1-9e355a14a3b8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
