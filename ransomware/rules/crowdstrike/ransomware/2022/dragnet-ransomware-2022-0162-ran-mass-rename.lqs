// Dragnet [Ransomware]: dragnet-ransomware-2022-0162 — Mass File Rename (snatch)
// Status: deprecated | Level: high | ID: 0a58b345-e2e8-5023-8069-c4cb982459d0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
