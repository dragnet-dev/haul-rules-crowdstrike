// Dragnet [Ransomware]: dragnet-ransomware-2025-5318 — Mass File Rename (shinyhunters)
// Status: experimental | Level: high | ID: 9302e090-e166-57e3-8288-3b7ed1d0b03c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
