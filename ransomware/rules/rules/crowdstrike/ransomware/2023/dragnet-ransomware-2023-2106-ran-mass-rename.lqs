// Dragnet [Ransomware]: dragnet-ransomware-2023-2106 — Mass File Rename (nokoyawa)
// Status: experimental | Level: high | ID: d938ec81-d759-55f7-bc52-0058add5f4da

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
