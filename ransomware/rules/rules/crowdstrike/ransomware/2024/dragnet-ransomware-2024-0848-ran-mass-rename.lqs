// Dragnet [Ransomware]: dragnet-ransomware-2024-0848 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 77283ca4-bc80-5a42-8f1c-d22cb5562a98

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
