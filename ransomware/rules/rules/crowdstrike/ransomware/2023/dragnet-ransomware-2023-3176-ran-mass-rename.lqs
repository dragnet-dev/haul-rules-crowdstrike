// Dragnet [Ransomware]: dragnet-ransomware-2023-3176 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: ff0d99bb-6db8-5aad-ad06-17463c41d464

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
