// Dragnet [Ransomware]: dragnet-ransomware-2022-2136 — Mass File Rename (kelvinsecurity)
// Status: deprecated | Level: high | ID: 7bea811e-a397-5fb5-bf2a-08d5b7e5dfb4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
