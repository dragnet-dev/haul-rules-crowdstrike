// Dragnet [Ransomware]: dragnet-ransomware-2023-3937 — Mass File Rename (snatch)
// Status: experimental | Level: high | ID: 7819611e-8d50-55fa-92a5-80cc3e6a10b3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
