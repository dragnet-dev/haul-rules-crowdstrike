// Dragnet [Ransomware]: dragnet-ransomware-2024-4839 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: d320d80d-a474-58aa-b498-e39d70022bcd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
