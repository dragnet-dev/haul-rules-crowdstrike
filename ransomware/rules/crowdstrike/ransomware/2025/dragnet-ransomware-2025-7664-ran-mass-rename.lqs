// Dragnet [Ransomware]: dragnet-ransomware-2025-7664 — Mass File Rename (apos)
// Status: deprecated | Level: high | ID: 9f749a12-569f-5aee-be3b-57aca80e51bb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
