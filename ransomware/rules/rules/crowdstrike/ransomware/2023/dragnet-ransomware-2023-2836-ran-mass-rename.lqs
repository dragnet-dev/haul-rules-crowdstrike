// Dragnet [Ransomware]: dragnet-ransomware-2023-2836 — Mass File Rename (malas)
// Status: experimental | Level: high | ID: cee908de-873b-5a07-a6bc-ca7c0418f8a2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
