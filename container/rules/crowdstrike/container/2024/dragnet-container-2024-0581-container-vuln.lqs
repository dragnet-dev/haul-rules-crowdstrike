// Dragnet [Container]: dragnet-container-2024-0581 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: bbf69fde-4e8e-5327-bee0-ecd2a8b65b36

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:9*)
| table([timestamp, ComputerName])
| limit(1000)
