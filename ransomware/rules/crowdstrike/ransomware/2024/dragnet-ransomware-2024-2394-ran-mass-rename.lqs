// Dragnet [Ransomware]: dragnet-ransomware-2024-2394 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: 3ac72d04-4115-554f-8f9b-2de2bfff4b19

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
