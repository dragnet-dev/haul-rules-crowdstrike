// Dragnet [Ransomware]: dragnet-ransomware-2021-0798 — Mass File Rename (ragnarlocker)
// Status: deprecated | Level: high | ID: ec525420-e36a-5fd2-a2a4-e7d006ed9606

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
