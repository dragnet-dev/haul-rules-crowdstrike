// Dragnet [Ransomware]: dragnet-ransomware-2024-3489 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: a0457e50-54bc-5ea5-af2f-532cfcca8f40

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
