// Dragnet [Ransomware]: dragnet-ransomware-2021-1424 — Mass File Rename (ragnarlocker)
// Status: deprecated | Level: high | ID: 24518232-dfe5-5674-b963-07b645a23377

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
