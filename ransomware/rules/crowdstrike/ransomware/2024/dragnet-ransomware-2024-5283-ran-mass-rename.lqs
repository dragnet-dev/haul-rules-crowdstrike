// Dragnet [Ransomware]: dragnet-ransomware-2024-5283 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 147cb2a0-68e5-566e-83a9-6f11567c99c1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
