// Dragnet [Ransomware]: dragnet-ransomware-2024-1873 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: 01a7a651-e453-549d-895f-7e7d65ee2053

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
