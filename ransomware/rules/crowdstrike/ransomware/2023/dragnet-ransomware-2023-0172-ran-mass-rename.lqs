// Dragnet [Ransomware]: dragnet-ransomware-2023-0172 — Mass File Rename (noescape)
// Status: experimental | Level: high | ID: 4010975a-d521-5f0d-a04f-d19b6b465762

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
