// Dragnet [Ransomware]: dragnet-ransomware-2022-2787 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: 59fa2805-da15-5194-97e2-cd86570057ad

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
