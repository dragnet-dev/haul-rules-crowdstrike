// Dragnet [Ransomware]: dragnet-ransomware-2025-7065 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 0748017f-8adb-5612-8dcb-b3536a0a17ff

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
