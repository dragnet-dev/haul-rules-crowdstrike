// Dragnet [Ransomware]: dragnet-ransomware-2023-1317 — Mass File Rename (werewolves)
// Status: experimental | Level: high | ID: 94152435-5dc6-5220-87d2-905ea0cb0ba3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
