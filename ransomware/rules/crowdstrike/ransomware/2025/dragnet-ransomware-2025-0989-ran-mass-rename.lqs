// Dragnet [Ransomware]: dragnet-ransomware-2025-0989 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 1d493bac-eb9f-5669-90ba-6f30fa8dff67

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
