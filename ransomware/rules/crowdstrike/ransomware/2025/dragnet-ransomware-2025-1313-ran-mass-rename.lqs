// Dragnet [Ransomware]: dragnet-ransomware-2025-1313 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 3729b5a8-7424-5ea6-a54f-1df82db816eb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
