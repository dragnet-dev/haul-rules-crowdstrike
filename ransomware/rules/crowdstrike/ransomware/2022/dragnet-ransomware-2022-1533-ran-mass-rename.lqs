// Dragnet [Ransomware]: dragnet-ransomware-2022-1533 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 8196e527-e824-5168-aa12-359d720b05d2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
