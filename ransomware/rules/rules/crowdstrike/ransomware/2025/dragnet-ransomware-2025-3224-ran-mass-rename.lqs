// Dragnet [Ransomware]: dragnet-ransomware-2025-3224 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 4ced7fbd-b162-5b58-a328-02081a32eb8d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
