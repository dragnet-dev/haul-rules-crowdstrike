// Dragnet [Ransomware]: dragnet-ransomware-2022-0136 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: f982e1bf-040d-50f6-bbe9-9e5c476b1f55

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
