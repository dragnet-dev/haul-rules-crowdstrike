// Dragnet [Ransomware]: dragnet-ransomware-2025-5200 — Mass File Rename (worldleaks)
// Status: experimental | Level: high | ID: 22c68ac7-314c-5efc-bd21-8747830d45ac

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
