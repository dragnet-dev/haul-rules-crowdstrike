// Dragnet [Ransomware]: dragnet-ransomware-2021-1418 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 96f5a31e-a8e3-5b56-a75b-1f59cfc2d1a6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
