// Dragnet [Ransomware]: dragnet-ransomware-2024-0932 — Mass File Rename (stormous)
// Status: deprecated | Level: high | ID: 70c6ce9a-2e2e-5ee7-a4cb-27b697c5be88

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
