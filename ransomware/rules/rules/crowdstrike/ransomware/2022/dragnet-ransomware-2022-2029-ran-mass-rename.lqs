// Dragnet [Ransomware]: dragnet-ransomware-2022-2029 — Mass File Rename (shaoleaks)
// Status: deprecated | Level: high | ID: 1ba1d6e3-f432-5387-a824-c2f54dc2497c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
