// Dragnet [Ransomware]: dragnet-ransomware-2025-1485 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 80d59655-49d3-5ae8-89e7-64600a4792aa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
