// Dragnet [Ransomware]: dragnet-ransomware-2023-0115 — Mass File Rename (knight)
// Status: experimental | Level: high | ID: 88a681a8-4f92-529a-9145-a914f96762f7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
