// Dragnet [Ransomware]: dragnet-ransomware-2023-2058 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 27da479b-37df-59ad-a254-77df355e83a4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
