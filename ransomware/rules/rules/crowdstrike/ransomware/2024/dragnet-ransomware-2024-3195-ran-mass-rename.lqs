// Dragnet [Ransomware]: dragnet-ransomware-2024-3195 — Mass File Rename (redransomware)
// Status: deprecated | Level: high | ID: 5274dd99-506d-5976-a741-f91bffa52fce

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
