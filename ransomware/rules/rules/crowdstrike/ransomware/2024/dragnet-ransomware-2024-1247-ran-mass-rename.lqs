// Dragnet [Ransomware]: dragnet-ransomware-2024-1247 — Mass File Rename (dragonransomware)
// Status: experimental | Level: high | ID: 3829877a-beee-5f13-893f-2de4d7a4943f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
