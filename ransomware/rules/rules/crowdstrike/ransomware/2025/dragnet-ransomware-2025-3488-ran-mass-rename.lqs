// Dragnet [Ransomware]: dragnet-ransomware-2025-3488 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 3d6f7d60-69c0-5b06-8d2c-94ee023a75c8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
