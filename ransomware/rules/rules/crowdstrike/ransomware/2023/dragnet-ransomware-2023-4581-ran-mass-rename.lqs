// Dragnet [Ransomware]: dragnet-ransomware-2023-4581 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: d12cd000-da29-5b0d-8264-7847f0e4a020

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
