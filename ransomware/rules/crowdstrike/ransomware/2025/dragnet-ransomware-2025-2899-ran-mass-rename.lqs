// Dragnet [Ransomware]: dragnet-ransomware-2025-2899 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 57bc73d0-64d5-544c-b4b4-33adbdfb834c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
