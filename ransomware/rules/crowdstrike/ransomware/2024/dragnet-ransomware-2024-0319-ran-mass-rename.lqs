// Dragnet [Ransomware]: dragnet-ransomware-2024-0319 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: a2aff17a-8b12-55d7-af1d-17069d0330f0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
