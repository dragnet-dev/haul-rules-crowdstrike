// Dragnet [Ransomware]: dragnet-ransomware-2026-2551 — Mass File Rename (worldleaks)
// Status: stable | Level: high | ID: 8ecfebd6-eb63-5dd2-9c5a-8e2d77be9bd8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
