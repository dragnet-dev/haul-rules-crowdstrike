// Dragnet [Ransomware]: dragnet-ransomware-2025-5572 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: da93fe0f-be20-59d9-90bc-1d60635a433a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
