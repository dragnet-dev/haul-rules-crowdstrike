// Dragnet [Ransomware]: dragnet-ransomware-2024-5542 — Mass File Rename (frag)
// Status: deprecated | Level: high | ID: ed2d296d-7801-5f6a-bbec-cae936ffe0d1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
