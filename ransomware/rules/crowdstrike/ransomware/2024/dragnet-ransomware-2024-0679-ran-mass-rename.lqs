// Dragnet [Ransomware]: dragnet-ransomware-2024-0679 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: e9925478-3f5c-5c41-9362-5e01b7c64571

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
