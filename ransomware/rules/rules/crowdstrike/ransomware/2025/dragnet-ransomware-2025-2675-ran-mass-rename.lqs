// Dragnet [Ransomware]: dragnet-ransomware-2025-2675 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: db7e66fc-e5fc-5908-a8bb-e40e3c50a621

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
