// Dragnet [Ransomware]: dragnet-ransomware-2025-1897 — Mass File Rename (devman)
// Status: experimental | Level: high | ID: d68f48bd-7eb4-526c-aa9f-0007ce2f3355

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
