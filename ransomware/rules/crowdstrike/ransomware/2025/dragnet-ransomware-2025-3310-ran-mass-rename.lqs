// Dragnet [Ransomware]: dragnet-ransomware-2025-3310 — Mass File Rename (play)
// Status: experimental | Level: high | ID: ddf78981-29bd-524a-96b5-0b32be005f05

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
