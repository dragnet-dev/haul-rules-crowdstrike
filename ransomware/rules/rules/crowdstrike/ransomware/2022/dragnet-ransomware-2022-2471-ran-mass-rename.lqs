// Dragnet [Ransomware]: dragnet-ransomware-2022-2471 — Mass File Rename (blackbasta)
// Status: deprecated | Level: high | ID: 2f9a4114-6bfa-5296-85c2-b9b68345c5a9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
