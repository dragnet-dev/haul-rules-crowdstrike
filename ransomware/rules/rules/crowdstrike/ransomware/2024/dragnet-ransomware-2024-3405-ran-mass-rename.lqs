// Dragnet [Ransomware]: dragnet-ransomware-2024-3405 — Mass File Rename (play)
// Status: experimental | Level: high | ID: e6157efd-b1ae-51e1-90e0-e9a2fab49eee

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
