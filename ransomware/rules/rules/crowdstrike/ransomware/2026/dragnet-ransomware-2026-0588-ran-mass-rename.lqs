// Dragnet [Ransomware]: dragnet-ransomware-2026-0588 — Mass File Rename (dragonforce)
// Status: stable | Level: high | ID: 363ad510-6399-547e-a602-1621533e3ac3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
