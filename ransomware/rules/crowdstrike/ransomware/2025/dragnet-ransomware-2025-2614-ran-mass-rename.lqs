// Dragnet [Ransomware]: dragnet-ransomware-2025-2614 — Mass File Rename (cephalus)
// Status: experimental | Level: high | ID: 2ff2bf32-1f20-5a03-a33d-5e91ba7dbb93

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
