// Dragnet [Ransomware]: dragnet-ransomware-2025-0227 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 46971dbb-06d1-5701-87a0-1c26b1ba867b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
