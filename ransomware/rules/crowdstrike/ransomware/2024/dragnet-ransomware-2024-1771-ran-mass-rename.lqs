// Dragnet [Ransomware]: dragnet-ransomware-2024-1771 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: faa8eb83-9832-5d04-8cd5-52b4fa03f844

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
