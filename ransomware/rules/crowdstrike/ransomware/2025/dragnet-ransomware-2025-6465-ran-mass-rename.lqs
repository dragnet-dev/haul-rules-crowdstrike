// Dragnet [Ransomware]: dragnet-ransomware-2025-6465 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: e103581f-190b-593a-94e7-373186c66df8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
