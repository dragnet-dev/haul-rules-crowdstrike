// Dragnet [Ransomware]: dragnet-ransomware-2026-1065 — Mass File Rename (thegentlemen)
// Status: stable | Level: high | ID: 58ae3c47-07ad-5f1f-8148-d77ec9ed5501

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
