// Dragnet [Container]: dragnet-container-2025-0650 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: c3d3e5f1-1772-57f1-8892-48166a551c2d

#event_simpleName=*
| (ImageFileName = *almalinux:8* OR ImageFileName = *chainguard:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:8* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
