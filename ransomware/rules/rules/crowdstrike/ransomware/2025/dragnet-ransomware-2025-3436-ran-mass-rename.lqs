// Dragnet [Ransomware]: dragnet-ransomware-2025-3436 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: 79300ac5-af2e-587d-b3bb-8ce29f3273c1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
