// Dragnet [Ransomware]: dragnet-ransomware-2022-0629 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 5acdbcf6-4f77-5488-8e3c-c879d1584d39

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
