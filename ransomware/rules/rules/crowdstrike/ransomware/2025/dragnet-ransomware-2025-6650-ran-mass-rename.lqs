// Dragnet [Ransomware]: dragnet-ransomware-2025-6650 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 49710e65-20c7-5cbc-936e-4d78112dbc10

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
