// Dragnet [Ransomware]: dragnet-ransomware-2022-3021 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 3fe4f229-310b-5b4b-9db4-fe7c2f508d05

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
