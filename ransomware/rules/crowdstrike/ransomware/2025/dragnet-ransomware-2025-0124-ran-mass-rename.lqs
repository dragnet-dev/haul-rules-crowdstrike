// Dragnet [Ransomware]: dragnet-ransomware-2025-0124 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 04835725-eabd-53c4-b6c0-f79f49e611d1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
