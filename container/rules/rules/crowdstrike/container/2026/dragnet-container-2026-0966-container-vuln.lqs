// Dragnet [Container]: dragnet-container-2026-0966 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 9c8fb6fd-3cff-51db-a246-35880e9d0580

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:5*)
| table([timestamp, ComputerName])
| limit(1000)
