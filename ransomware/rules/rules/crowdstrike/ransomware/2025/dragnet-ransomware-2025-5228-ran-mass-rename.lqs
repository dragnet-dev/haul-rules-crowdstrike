// Dragnet [Ransomware]: dragnet-ransomware-2025-5228 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: dda94f68-e5dc-58f8-ab3f-2a323c23d9b4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
