// Dragnet [Ransomware]: dragnet-ransomware-2025-7456 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: c5b71d16-f035-58b6-ae9a-f1669ccd528d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
