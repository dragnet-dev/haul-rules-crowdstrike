// Dragnet [Ransomware]: dragnet-ransomware-2025-3147 — Mass File Rename (sarcoma)
// Status: deprecated | Level: high | ID: 1b82aab2-476f-5e76-872c-6d46e396298c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
