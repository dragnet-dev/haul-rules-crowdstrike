// Dragnet [Ransomware]: dragnet-ransomware-2022-1434 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: 8abc5fa3-aaf3-5d97-abb8-69ea17053eff

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
