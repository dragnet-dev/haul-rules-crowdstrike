// Dragnet [Ransomware]: dragnet-ransomware-2025-4753 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: fd0b26cc-9e98-57a3-86f6-ead6364b8462

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
