// Dragnet [Ransomware]: dragnet-ransomware-2025-2377 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: aaa642df-ecdd-57e4-b0fa-17437237358b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
