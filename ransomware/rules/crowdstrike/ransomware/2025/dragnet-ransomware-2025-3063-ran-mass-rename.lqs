// Dragnet [Ransomware]: dragnet-ransomware-2025-3063 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: be62872d-7a18-5dce-b323-962ecc40d236

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
