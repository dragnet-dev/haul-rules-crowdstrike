// Dragnet [Container]: dragnet-container-2024-1561 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 9e7b9648-81ce-5d7a-aa9c-86897379f6eb

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
