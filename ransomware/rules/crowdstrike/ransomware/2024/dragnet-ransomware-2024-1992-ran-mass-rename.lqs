// Dragnet [Ransomware]: dragnet-ransomware-2024-1992 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 60d2cf82-c3a0-5aaa-b05c-e62d7172f639

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
