// Dragnet [Ransomware]: dragnet-ransomware-2024-3447 — Mass File Rename (dAn0n)
// Status: experimental | Level: high | ID: 084d8d47-950a-5a28-a9a6-4d749d5faa94

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
