// Dragnet [Ransomware]: dragnet-ransomware-2025-7440 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 61aa57d6-ae3e-57a7-b7af-37f1ab2c4e06

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
