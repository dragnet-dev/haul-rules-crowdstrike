// Dragnet [Ransomware]: dragnet-ransomware-2025-2218 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: b6ed4d47-43ac-53dc-9654-1bdcfb778e12

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
