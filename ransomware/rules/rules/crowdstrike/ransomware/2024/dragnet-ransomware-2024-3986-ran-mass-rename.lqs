// Dragnet [Ransomware]: dragnet-ransomware-2024-3986 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 30069a40-a9aa-54ab-88a6-35145bd86641

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
