// Dragnet [Ransomware]: dragnet-ransomware-2025-2094 — Mass File Rename (direwolf)
// Status: experimental | Level: high | ID: 988af83e-a9ea-55e9-b9bc-6195495b5dcc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
