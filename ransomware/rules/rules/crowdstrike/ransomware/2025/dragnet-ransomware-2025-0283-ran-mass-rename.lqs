// Dragnet [Ransomware]: dragnet-ransomware-2025-0283 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: 3a95e304-9ca7-50c1-9d32-e8b6b48efa81

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
