// Dragnet [Ransomware]: dragnet-ransomware-2024-3791 — Mass File Rename (dragonforce)
// Status: deprecated | Level: high | ID: 9cf346cf-1123-5cd9-b585-96e2ae532d07

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
