// Dragnet [Ransomware]: dragnet-ransomware-2024-5941 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: b89cae60-3959-5ce6-967c-ab25bf38e046

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
