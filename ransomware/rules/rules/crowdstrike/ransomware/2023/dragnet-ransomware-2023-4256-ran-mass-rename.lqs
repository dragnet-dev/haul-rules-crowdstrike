// Dragnet [Ransomware]: dragnet-ransomware-2023-4256 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: cc5bc648-d504-5aa7-bc59-57a9a8e6d98e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
