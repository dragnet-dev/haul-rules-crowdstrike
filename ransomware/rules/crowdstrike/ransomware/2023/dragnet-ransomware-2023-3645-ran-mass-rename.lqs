// Dragnet [Ransomware]: dragnet-ransomware-2023-3645 — Mass File Rename (ransomhouse)
// Status: experimental | Level: high | ID: 345c5626-54c5-5ba1-afea-f718d1fd7180

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
