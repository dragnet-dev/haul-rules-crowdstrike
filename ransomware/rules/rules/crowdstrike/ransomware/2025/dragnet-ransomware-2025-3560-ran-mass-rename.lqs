// Dragnet [Ransomware]: dragnet-ransomware-2025-3560 — Mass File Rename (nightspire)
// Status: deprecated | Level: high | ID: 759e5efc-93e9-58ad-bd7a-d2aa73ed0402

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
