// Dragnet [Container]: dragnet-container-2026-2494 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 0422c915-06cb-52f8-bb23-55627391fdfc

#event_simpleName=*
| (ImageFileName = *amazonlinux:1* OR ImageFileName = *chainguard:* OR ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10*)
| table([timestamp, ComputerName])
| limit(1000)
