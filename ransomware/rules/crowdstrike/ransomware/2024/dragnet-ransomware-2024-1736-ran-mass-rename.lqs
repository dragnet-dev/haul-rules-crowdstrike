// Dragnet [Ransomware]: dragnet-ransomware-2024-1736 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: ec5402e0-8ef7-5317-9ebf-616375768f4d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
