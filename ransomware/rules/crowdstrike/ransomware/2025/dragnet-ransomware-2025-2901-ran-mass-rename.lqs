// Dragnet [Ransomware]: dragnet-ransomware-2025-2901 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 69cc6bdb-7e3d-58b7-b521-e33d20ed8398

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
