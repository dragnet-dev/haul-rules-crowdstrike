// Dragnet [Container]: dragnet-container-2025-0709 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 8e20b19d-b6ca-5115-a2c7-35539ff222a0

#event_simpleName=*
| (ImageFileName = *amazonlinux:2* OR ImageFileName = *chainguard:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:20.04-ESM* OR ImageFileName = *ubuntu:22.04* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
