// Dragnet [Container]: dragnet-container-2026-3118 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: dfac7d75-5a4b-53ef-8cea-5b1c0e7749ed

#event_simpleName=*
| (ImageFileName = *almalinux:10* OR ImageFileName = *almalinux:8* OR ImageFileName = *almalinux:9* OR ImageFileName = *amazonlinux:2023* OR ImageFileName = *chainguard:* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:8* OR ImageFileName = *oraclelinux:9* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
