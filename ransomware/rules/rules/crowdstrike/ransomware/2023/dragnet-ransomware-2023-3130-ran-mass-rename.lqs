// Dragnet [Ransomware]: dragnet-ransomware-2023-3130 — Mass File Rename (toufan)
// Status: deprecated | Level: high | ID: fe5465fe-211a-5de7-97f9-a841cd113326

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
