// Dragnet [Container]: dragnet-container-2024-0331 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 71da2d15-34f1-5f0c-b5a8-3752e403616c

#event_simpleName=*
| (ImageFileName = *almalinux:8* OR ImageFileName = *almalinux:9* OR ImageFileName = *alpine:3.18* OR ImageFileName = *alpine:3.19* OR ImageFileName = *alpine:3.20* OR ImageFileName = *amazonlinux:2023* OR ImageFileName = *oraclelinux:8* OR ImageFileName = *oraclelinux:9* OR ImageFileName = *photon os:4.0* OR ImageFileName = *photon os:5.0* OR ImageFileName = *ubuntu:22.04* OR ImageFileName = *ubuntu:23.04* OR ImageFileName = *ubuntu:23.10*)
| table([timestamp, ComputerName])
| limit(1000)
