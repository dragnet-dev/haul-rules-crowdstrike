// Dragnet [Ransomware]: dragnet-ransomware-2023-1839 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 6b26c70b-96a4-504d-82a8-c7dcbd575266

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
