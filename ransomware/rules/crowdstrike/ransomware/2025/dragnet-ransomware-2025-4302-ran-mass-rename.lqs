// Dragnet [Ransomware]: dragnet-ransomware-2025-4302 — Mass File Rename (shinyhunters)
// Status: experimental | Level: high | ID: 4f097d8d-aae2-5a99-b5d8-e29db42f3b6f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
