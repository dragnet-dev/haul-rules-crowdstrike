// Dragnet [Ransomware]: dragnet-ransomware-2020-0057 — Mass File Rename (maze)
// Status: deprecated | Level: high | ID: 85c40f35-44f5-5799-b033-3317d090c20b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
