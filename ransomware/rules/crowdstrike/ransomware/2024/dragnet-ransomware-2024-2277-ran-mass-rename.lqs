// Dragnet [Ransomware]: dragnet-ransomware-2024-2277 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 9eac0420-465f-564d-8e5d-3e090733f6cf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
