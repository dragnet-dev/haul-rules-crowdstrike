// Dragnet [Ransomware]: dragnet-ransomware-2024-5094 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: 15c3ba99-0ea4-56da-ae14-3f3d8277c1b0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
