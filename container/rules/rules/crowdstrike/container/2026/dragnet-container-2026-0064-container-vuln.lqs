// Dragnet [Container]: dragnet-container-2026-0064 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 5f4e9968-0d84-5fe8-a70b-6c4b4e75dd41

#event_simpleName=*
| (ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10* OR ImageFileName = *ubuntu:13.04* OR ImageFileName = *ubuntu:13.10*)
| table([timestamp, ComputerName])
| limit(1000)
