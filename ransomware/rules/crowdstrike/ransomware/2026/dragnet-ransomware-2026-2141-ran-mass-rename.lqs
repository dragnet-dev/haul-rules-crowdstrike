// Dragnet [Ransomware]: dragnet-ransomware-2026-2141 — Mass File Rename (everest)
// Status: stable | Level: high | ID: 53edefb7-41da-55c1-a41f-a3603be3a043

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
