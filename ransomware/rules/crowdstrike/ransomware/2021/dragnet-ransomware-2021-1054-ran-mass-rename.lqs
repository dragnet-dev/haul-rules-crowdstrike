// Dragnet [Ransomware]: dragnet-ransomware-2021-1054 — Mass File Rename (snatch)
// Status: deprecated | Level: high | ID: a2f27fdc-421e-5391-93c9-29b8f1e4c696

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
