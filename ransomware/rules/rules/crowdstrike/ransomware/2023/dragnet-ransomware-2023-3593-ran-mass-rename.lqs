// Dragnet [Ransomware]: dragnet-ransomware-2023-3593 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: d0c06da6-6542-55ba-a178-ba0efbebd292

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
