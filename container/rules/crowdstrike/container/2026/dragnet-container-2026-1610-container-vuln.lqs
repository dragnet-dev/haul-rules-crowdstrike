// Dragnet [Container]: dragnet-container-2026-1610 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 2299a920-39ae-5286-b20f-2311e1736681

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
