// Dragnet [Ransomware]: dragnet-ransomware-2025-1170 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: 9c54390b-090b-54fc-8e15-275670d53fef

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
