// Dragnet [Ransomware]: dragnet-ransomware-2025-4164 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: 37fc46e2-0622-5bda-819d-db0d7509d892

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
