// Dragnet [Ransomware]: dragnet-ransomware-2024-4513 — Mass File Rename (beast)
// Status: experimental | Level: high | ID: 94973eb3-4f88-536b-8970-1b1164830e34

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
