// Dragnet [Ransomware]: dragnet-ransomware-2022-0008 — Mass File Rename (karakurt)
// Status: deprecated | Level: high | ID: 971c65bd-c349-5600-9b55-0142c4fd3ff0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
