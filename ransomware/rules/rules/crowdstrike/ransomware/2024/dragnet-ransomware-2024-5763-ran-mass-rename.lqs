// Dragnet [Ransomware]: dragnet-ransomware-2024-5763 — Mass File Rename (dragonransomware)
// Status: experimental | Level: high | ID: 204d1fa0-083e-56dc-9abc-cc5fcee4b5fb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
