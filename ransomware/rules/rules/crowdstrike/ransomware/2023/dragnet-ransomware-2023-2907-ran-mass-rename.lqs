// Dragnet [Ransomware]: dragnet-ransomware-2023-2907 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 313efc13-9718-514b-ae00-c35df78346b1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
