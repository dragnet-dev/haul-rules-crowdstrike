// Dragnet [Ransomware]: dragnet-ransomware-2021-0832 — Mass File Rename (lv)
// Status: deprecated | Level: high | ID: bcf361bb-56c4-5368-a7bc-52259fc43eeb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
