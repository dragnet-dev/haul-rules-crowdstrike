// Dragnet [Ransomware]: dragnet-ransomware-2023-5150 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 21c8bd33-72a8-5850-9562-2c6e09f18c05

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
