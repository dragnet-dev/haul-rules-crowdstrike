// Dragnet [Ransomware]: dragnet-ransomware-2024-5537 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 2d8f8449-84ec-55c1-bb60-ac49e0e1e183

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
