// Dragnet [Ransomware]: dragnet-ransomware-2026-0525 — Mass File Rename (krybit)
// Status: stable | Level: high | ID: 460ffd00-58fa-5163-8e94-a8714ab9179d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
