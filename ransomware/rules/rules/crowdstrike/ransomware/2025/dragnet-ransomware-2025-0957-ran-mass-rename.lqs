// Dragnet [Ransomware]: dragnet-ransomware-2025-0957 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 8536a755-2ebf-5daf-93d4-5ba9d6b9bfc1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
