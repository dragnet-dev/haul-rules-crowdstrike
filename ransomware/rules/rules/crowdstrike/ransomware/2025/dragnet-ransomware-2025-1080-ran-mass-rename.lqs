// Dragnet [Ransomware]: dragnet-ransomware-2025-1080 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: c16898f2-4156-5af4-a861-62b358550545

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
