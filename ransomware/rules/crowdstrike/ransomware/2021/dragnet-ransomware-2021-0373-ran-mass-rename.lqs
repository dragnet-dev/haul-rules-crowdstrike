// Dragnet [Ransomware]: dragnet-ransomware-2021-0373 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 82f4db73-91b7-50c1-b2e2-0122fdac0919

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
