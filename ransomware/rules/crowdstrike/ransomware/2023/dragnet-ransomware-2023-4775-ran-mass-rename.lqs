// Dragnet [Ransomware]: dragnet-ransomware-2023-4775 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 9477df48-4279-5678-9062-ddccbb9ee01a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
