// Dragnet [Ransomware]: dragnet-ransomware-2025-2116 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: dfe173cc-fbd6-5e4d-81ee-eff4870760ca

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
