// Dragnet [Ransomware]: dragnet-ransomware-2023-1081 — Mass File Rename (royal)
// Status: deprecated | Level: high | ID: e413dc17-172e-5bdd-bf8c-4a3931e321d4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
