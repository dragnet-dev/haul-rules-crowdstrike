// Dragnet [Container]: dragnet-container-2026-2006 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 520ab2ec-a97d-5a5d-9e4d-ed39f1e297d6

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:7*)
| table([timestamp, ComputerName])
| limit(1000)
