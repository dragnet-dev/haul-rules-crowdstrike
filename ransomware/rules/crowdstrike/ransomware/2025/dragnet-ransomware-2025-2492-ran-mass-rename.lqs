// Dragnet [Ransomware]: dragnet-ransomware-2025-2492 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 84f05075-eff5-55c8-8e25-6cce4fde4ed2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
