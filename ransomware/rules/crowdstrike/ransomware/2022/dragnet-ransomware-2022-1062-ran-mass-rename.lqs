// Dragnet [Ransomware]: dragnet-ransomware-2022-1062 — Mass File Rename (donutleaks)
// Status: experimental | Level: high | ID: c28d6f42-2fc2-5ea6-8b18-09a695e0e0f1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
