// Dragnet [Ransomware]: dragnet-ransomware-2025-4077 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: cd2caac6-f575-514f-b497-e533d072f6b6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
