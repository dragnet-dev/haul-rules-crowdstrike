// Dragnet [Ransomware]: dragnet-ransomware-2026-3296 — Mass File Rename (vect)
// Status: deprecated | Level: high | ID: 76ccb294-97c3-57de-8c96-bf945d3a26f5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
