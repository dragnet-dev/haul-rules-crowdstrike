// Dragnet [Ransomware]: dragnet-ransomware-2025-7797 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: 367e857a-a5b9-56f6-aedc-2a29857777b8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
