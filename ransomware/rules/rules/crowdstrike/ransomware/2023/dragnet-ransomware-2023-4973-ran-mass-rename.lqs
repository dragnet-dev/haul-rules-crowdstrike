// Dragnet [Ransomware]: dragnet-ransomware-2023-4973 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 3ad9b157-8bbd-54de-9f75-a3d0cc87339d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
