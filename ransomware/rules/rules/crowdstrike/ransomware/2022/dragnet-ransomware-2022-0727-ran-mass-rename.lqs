// Dragnet [Ransomware]: dragnet-ransomware-2022-0727 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: cffa0401-b5df-50f4-b411-9ba06680b2ea

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
