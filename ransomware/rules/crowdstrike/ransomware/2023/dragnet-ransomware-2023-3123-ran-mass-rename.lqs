// Dragnet [Ransomware]: dragnet-ransomware-2023-3123 — Mass File Rename (monti)
// Status: experimental | Level: high | ID: 2f2748c3-cae7-5551-83b9-7fe58cc5b1f3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
