// Dragnet [Ransomware]: dragnet-ransomware-2024-1176 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 2802d91f-eaf9-5c76-a7ee-a61339b2ed51

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
