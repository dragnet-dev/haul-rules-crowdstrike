// Dragnet [Ransomware]: dragnet-ransomware-2023-4029 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 43ef7551-8cea-5252-9e03-f0009796ea00

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
