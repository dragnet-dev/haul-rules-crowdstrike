// Dragnet [Ransomware]: dragnet-ransomware-2024-4155 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: 3fa4090d-5391-5224-a6d0-ab7d08fb48e0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
