// Dragnet [Ransomware]: dragnet-ransomware-2022-1648 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: dd602ee7-5916-591e-8eaa-73a396816361

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
