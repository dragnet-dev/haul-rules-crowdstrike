// Dragnet [Ransomware]: dragnet-ransomware-2020-0164 — Mass File Rename (netwalker)
// Status: deprecated | Level: high | ID: 32f3598d-82f5-53b8-a165-67d21d18a2a1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
