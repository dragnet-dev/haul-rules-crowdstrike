// Dragnet [Container]: dragnet-container-2026-0074 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 71d55367-b0ff-5607-8f15-a1f118a1b886

#event_simpleName=*
| (ImageFileName = *amazonlinux:1* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *ubuntu:12.04*)
| table([timestamp, ComputerName])
| limit(1000)
