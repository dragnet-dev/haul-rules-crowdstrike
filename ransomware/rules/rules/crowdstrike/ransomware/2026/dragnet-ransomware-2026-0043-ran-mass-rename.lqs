// Dragnet [Ransomware]: dragnet-ransomware-2026-0043 — Mass File Rename (coinbasecartel)
// Status: stable | Level: high | ID: 640c142a-01d9-5d5d-8f3e-6ed8b4156259

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
