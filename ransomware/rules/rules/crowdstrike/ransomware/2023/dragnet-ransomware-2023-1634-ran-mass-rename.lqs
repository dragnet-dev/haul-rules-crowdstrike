// Dragnet [Ransomware]: dragnet-ransomware-2023-1634 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: f13b985d-22c4-5f19-9f06-c9f770ee05d3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
