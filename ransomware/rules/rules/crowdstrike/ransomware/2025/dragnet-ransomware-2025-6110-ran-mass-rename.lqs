// Dragnet [Ransomware]: dragnet-ransomware-2025-6110 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 87711298-b197-5ad0-ad62-05153c00b498

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
