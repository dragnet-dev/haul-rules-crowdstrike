// Dragnet [Ransomware]: dragnet-ransomware-2025-5086 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 7bde6620-ae5b-503e-bc4b-c06d3492b426

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
