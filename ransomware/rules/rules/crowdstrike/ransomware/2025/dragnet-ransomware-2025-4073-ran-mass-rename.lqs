// Dragnet [Ransomware]: dragnet-ransomware-2025-4073 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 5dc96c6c-42ed-5fc1-86ad-9e799f493f43

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
