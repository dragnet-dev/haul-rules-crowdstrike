// Dragnet [Ransomware]: dragnet-ransomware-2024-2916 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: fe22eb18-4f29-56aa-9dd9-b70b4bd56085

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
