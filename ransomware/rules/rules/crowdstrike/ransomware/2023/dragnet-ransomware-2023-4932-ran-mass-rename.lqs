// Dragnet [Ransomware]: dragnet-ransomware-2023-4932 — Mass File Rename (ransomhouse)
// Status: deprecated | Level: high | ID: 71bce3d2-77ce-5f09-a48c-2db41a897720

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
