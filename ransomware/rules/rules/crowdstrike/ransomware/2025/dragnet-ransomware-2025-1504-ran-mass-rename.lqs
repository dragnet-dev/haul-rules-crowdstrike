// Dragnet [Ransomware]: dragnet-ransomware-2025-1504 — Mass File Rename (kazu)
// Status: deprecated | Level: high | ID: 9eddc21d-2a36-5100-849a-1ba7b43200f9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
