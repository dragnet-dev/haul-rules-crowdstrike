// Dragnet [Ransomware]: dragnet-ransomware-2023-0771 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 58d0ff6f-0478-5cd5-9fee-7b22be7a4a38

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
