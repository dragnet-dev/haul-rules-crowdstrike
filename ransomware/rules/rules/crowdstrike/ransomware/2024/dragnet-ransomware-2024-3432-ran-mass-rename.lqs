// Dragnet [Ransomware]: dragnet-ransomware-2024-3432 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 189a7647-c155-505f-8331-e6b55ef51d08

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
