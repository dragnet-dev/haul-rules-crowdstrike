// Dragnet [Ransomware]: dragnet-ransomware-2022-2777 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: adec5a23-25c4-5027-8777-e1918d9ee8a4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
