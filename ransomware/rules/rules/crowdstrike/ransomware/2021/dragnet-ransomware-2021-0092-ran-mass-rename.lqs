// Dragnet [Ransomware]: dragnet-ransomware-2021-0092 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 49484031-ee34-52d8-af90-957a42c121a5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
