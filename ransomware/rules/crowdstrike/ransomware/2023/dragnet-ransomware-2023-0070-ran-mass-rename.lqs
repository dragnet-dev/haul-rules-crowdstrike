// Dragnet [Ransomware]: dragnet-ransomware-2023-0070 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 16f60965-69cb-5022-9b18-07633fd05516

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
