// Dragnet [Ransomware]: dragnet-ransomware-2024-0010 — Mass File Rename (meow)
// Status: experimental | Level: high | ID: 1e249b37-dc22-5953-b206-9c3e562eb4f6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
