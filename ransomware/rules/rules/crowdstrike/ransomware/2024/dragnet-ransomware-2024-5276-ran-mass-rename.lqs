// Dragnet [Ransomware]: dragnet-ransomware-2024-5276 — Mass File Rename (flocker)
// Status: experimental | Level: high | ID: 53532a47-e713-5ca8-a637-26d6e5bd79ad

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
