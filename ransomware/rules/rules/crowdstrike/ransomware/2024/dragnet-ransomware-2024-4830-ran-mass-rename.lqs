// Dragnet [Ransomware]: dragnet-ransomware-2024-4830 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 97fbd08a-986b-54b0-9348-24ab4b3b5be8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
