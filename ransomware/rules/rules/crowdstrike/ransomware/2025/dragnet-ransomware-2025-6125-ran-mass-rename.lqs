// Dragnet [Ransomware]: dragnet-ransomware-2025-6125 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: f1f70cf2-401b-5eb5-8ea8-b07ddda32d6c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
