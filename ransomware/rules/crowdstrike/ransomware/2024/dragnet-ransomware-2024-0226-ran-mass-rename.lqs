// Dragnet [Ransomware]: dragnet-ransomware-2024-0226 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: 7075b831-c914-5894-b41a-376f10288c0b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
