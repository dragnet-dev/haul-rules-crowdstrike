// Dragnet [Ransomware]: dragnet-ransomware-2023-2071 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: cc237748-6796-5c70-bd36-4ef489f6d73d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
