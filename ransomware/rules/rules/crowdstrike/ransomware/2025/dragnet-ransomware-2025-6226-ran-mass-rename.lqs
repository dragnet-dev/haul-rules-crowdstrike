// Dragnet [Ransomware]: dragnet-ransomware-2025-6226 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 2be330ce-827e-5217-bf54-1cd101f1ceb4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
