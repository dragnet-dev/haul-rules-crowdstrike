// Dragnet [Ransomware]: dragnet-ransomware-2023-1917 — Mass File Rename (royal)
// Status: experimental | Level: high | ID: b979ea3a-4978-5f7d-b215-9f962e2aba64

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
