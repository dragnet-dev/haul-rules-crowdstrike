// Dragnet [Ransomware]: dragnet-ransomware-2022-0316 — Mass File Rename (lv)
// Status: deprecated | Level: high | ID: a872ebeb-4b4e-5977-8fc7-cec4f19471d3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
