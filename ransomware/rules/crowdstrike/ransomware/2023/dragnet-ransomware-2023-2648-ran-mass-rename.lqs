// Dragnet [Ransomware]: dragnet-ransomware-2023-2648 — Mass File Rename (royal)
// Status: experimental | Level: high | ID: 356ed9ee-603b-5938-a43d-10675e29e4d1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
