// Dragnet [Ransomware]: dragnet-ransomware-2025-3442 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 1acb951e-9895-5192-a2b8-69e9777154a4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
