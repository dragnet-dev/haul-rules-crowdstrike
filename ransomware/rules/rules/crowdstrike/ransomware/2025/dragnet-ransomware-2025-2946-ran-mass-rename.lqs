// Dragnet [Ransomware]: dragnet-ransomware-2025-2946 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 5fa0f3f3-4cec-578d-8997-4f2068179f42

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
