// Dragnet [Ransomware]: dragnet-ransomware-2023-0829 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 21685d0a-2240-5aeb-b7fc-07516e91b7d8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
