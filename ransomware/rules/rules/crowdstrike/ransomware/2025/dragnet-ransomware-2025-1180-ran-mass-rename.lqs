// Dragnet [Ransomware]: dragnet-ransomware-2025-1180 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 7de914f4-a724-55f5-b3d5-5047c51279b2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
