// Dragnet [Ransomware]: dragnet-ransomware-2024-5170 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 72699e22-b508-54d2-ba5d-78521d6909fa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
