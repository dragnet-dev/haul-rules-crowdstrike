// Dragnet [Ransomware]: dragnet-ransomware-2025-3446 — Mass File Rename (nightspire)
// Status: deprecated | Level: high | ID: 2afc48d0-c452-5ae9-8724-240051edf7cc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
