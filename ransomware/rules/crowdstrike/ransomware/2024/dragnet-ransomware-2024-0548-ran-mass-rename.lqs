// Dragnet [Ransomware]: dragnet-ransomware-2024-0548 — Mass File Rename (cloak)
// Status: deprecated | Level: high | ID: 69745f02-65b7-5351-b64d-943493888629

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
