// Dragnet [Ransomware]: dragnet-ransomware-2025-0544 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 3f57de65-5947-5bc9-8283-0aaffcc1ff33

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
