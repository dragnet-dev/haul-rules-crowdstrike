// Dragnet [Ransomware]: dragnet-ransomware-2025-3880 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: bfdb1d98-4890-531e-8aee-043c415a452e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
