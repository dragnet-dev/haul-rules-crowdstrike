// Dragnet [Ransomware]: dragnet-ransomware-2023-0720 — Mass File Rename (threeam)
// Status: experimental | Level: high | ID: 669d5340-e496-5bc6-a916-338af832b9f1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
