// Dragnet [Ransomware]: dragnet-ransomware-2025-1954 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 4aab5bf4-fb4f-54bf-bac1-b970fd286904

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
