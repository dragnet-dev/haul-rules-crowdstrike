// Dragnet [Ransomware]: dragnet-ransomware-2024-4633 — Mass File Rename (qiulong)
// Status: experimental | Level: high | ID: c9b102aa-384d-515a-825c-088f7b84ecbc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
