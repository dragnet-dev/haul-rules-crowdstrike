// Dragnet [Ransomware]: dragnet-ransomware-2025-5844 — Mass File Rename (gunra)
// Status: experimental | Level: high | ID: d6638954-1036-52e6-957a-a8740d9dda93

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
