// Dragnet [Ransomware]: dragnet-ransomware-2026-1343 — Mass File Rename (incransom)
// Status: test | Level: high | ID: d629e968-2c3a-5798-a275-fd883e2c2611

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
