// Dragnet [Ransomware]: dragnet-ransomware-2025-7131 — Mass File Rename (rhysida)
// Status: deprecated | Level: high | ID: 31e739fa-879f-595b-95b5-41ab34bf0361

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
