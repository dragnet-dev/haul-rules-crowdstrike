// Dragnet [Ransomware]: dragnet-ransomware-2022-1998 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 77754852-162c-52dc-a1ef-c1d4f5d63930

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
