// Dragnet [Ransomware]: dragnet-ransomware-2021-1144 — Mass File Rename (ragnarlocker)
// Status: deprecated | Level: high | ID: 95a6fb01-af6d-523c-a672-6776f5c2cdcf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
