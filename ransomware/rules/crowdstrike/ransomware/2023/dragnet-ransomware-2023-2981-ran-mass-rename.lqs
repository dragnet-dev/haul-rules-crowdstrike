// Dragnet [Ransomware]: dragnet-ransomware-2023-2981 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 19589a18-8695-5841-b8ca-70768fa7df8a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
