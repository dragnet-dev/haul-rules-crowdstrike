// Dragnet [Ransomware]: dragnet-ransomware-2025-3653 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 2c77cbf5-fd58-58ed-be2d-06f99ff2d3ff

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
