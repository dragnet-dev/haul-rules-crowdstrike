// Dragnet [Ransomware]: dragnet-ransomware-2021-1186 — Mass File Rename (azroteam)
// Status: deprecated | Level: high | ID: da4e5905-cec4-545d-917e-dada503add24

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
