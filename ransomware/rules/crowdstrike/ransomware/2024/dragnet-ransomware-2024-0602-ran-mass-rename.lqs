// Dragnet [Ransomware]: dragnet-ransomware-2024-0602 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 20a8e644-1063-52b2-9a36-491291316086

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
