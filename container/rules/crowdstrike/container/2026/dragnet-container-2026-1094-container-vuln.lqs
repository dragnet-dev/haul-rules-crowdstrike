// Dragnet [Container]: dragnet-container-2026-1094 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: e3cb9779-39f9-54c2-a3c6-43b3b6bd8ea9

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:5*)
| table([timestamp, ComputerName])
| limit(1000)
