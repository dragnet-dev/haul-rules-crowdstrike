// Dragnet [Ransomware]: dragnet-ransomware-2024-1219 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 8cfbac18-4a1b-5449-8fbb-5a0fb260ecfd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
