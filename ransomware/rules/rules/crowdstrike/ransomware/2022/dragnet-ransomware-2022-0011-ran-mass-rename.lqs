// Dragnet [Ransomware]: dragnet-ransomware-2022-0011 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 1abb6e29-deff-523c-ac49-0347b10dc4ad

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
