// Dragnet [Ransomware]: dragnet-ransomware-2022-1300 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 9a6419d6-2808-5190-83ad-b88e945a76d2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
