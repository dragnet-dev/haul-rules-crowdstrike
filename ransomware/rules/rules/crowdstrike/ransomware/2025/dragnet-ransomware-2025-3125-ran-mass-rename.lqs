// Dragnet [Ransomware]: dragnet-ransomware-2025-3125 — Mass File Rename (apt73)
// Status: experimental | Level: high | ID: d3d7adfa-9d28-59d9-b8fd-168cce10d976

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
