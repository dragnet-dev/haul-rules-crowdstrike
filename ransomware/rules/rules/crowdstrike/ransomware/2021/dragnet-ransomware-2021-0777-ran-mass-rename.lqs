// Dragnet [Ransomware]: dragnet-ransomware-2021-0777 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 3986918d-c9c0-5742-be06-682a3e0a442e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
