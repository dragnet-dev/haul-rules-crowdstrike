// Dragnet [Ransomware]: dragnet-ransomware-2025-5612 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 3cbb19f7-d352-5935-8b77-dddf0ee91714

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
