// Dragnet [Ransomware]: dragnet-ransomware-2025-4590 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: fe5fb19a-6317-5339-b14e-f9f4e09994e3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
