// Dragnet [Container]: dragnet-container-2024-0385 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: de291df1-37b7-5f65-ab39-b4c9d2829e9f

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:8* OR ImageFileName = *debian:9*)
| table([timestamp, ComputerName])
| limit(1000)
