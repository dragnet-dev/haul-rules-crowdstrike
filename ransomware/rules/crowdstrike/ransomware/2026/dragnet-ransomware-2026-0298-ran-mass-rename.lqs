// Dragnet [Ransomware]: dragnet-ransomware-2026-0298 — Mass File Rename (incransom)
// Status: stable | Level: high | ID: e88cd00e-554f-5147-af4c-637674ae79b4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
