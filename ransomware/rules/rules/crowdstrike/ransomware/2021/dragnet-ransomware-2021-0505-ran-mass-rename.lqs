// Dragnet [Ransomware]: dragnet-ransomware-2021-0505 — Mass File Rename (snatch)
// Status: deprecated | Level: high | ID: 287281bb-73ff-58dc-8cc0-ad6920e613ce

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
