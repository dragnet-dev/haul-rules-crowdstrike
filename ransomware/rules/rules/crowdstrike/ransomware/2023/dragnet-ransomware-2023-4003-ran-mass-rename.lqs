// Dragnet [Ransomware]: dragnet-ransomware-2023-4003 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 4f61c2f0-47c1-596c-ba2b-3f38912b5977

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
