// Dragnet [Ransomware]: dragnet-ransomware-2021-0279 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: e373e03e-44eb-51e3-bffa-b21b20c43f7e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
