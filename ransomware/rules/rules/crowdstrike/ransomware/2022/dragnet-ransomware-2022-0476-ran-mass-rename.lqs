// Dragnet [Ransomware]: dragnet-ransomware-2022-0476 — Mass File Rename (redalert)
// Status: deprecated | Level: high | ID: 3175fc23-3e6c-5288-9672-ef7ca5d57888

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
