// Dragnet [Ransomware]: dragnet-ransomware-2021-1579 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: ae25fc06-a39d-5836-9756-7b404241d12d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
