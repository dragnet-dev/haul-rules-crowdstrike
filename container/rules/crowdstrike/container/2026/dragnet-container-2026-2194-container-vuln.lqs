// Dragnet [Container]: dragnet-container-2026-2194 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: be64cff6-5d3d-5542-964d-9e5f5b2d27c6

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:5*)
| table([timestamp, ComputerName])
| limit(1000)
