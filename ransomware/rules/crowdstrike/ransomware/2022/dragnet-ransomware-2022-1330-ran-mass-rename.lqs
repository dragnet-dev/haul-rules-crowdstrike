// Dragnet [Ransomware]: dragnet-ransomware-2022-1330 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: eb525296-3953-56eb-adf4-9f8a062d0179

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
