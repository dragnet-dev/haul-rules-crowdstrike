// Dragnet [Ransomware]: dragnet-ransomware-2022-1194 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 2e80b564-dcc1-5b70-af18-155236249572

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
