// Dragnet [Ransomware]: dragnet-ransomware-2023-0263 — Mass File Rename (play)
// Status: deprecated | Level: high | ID: a3fa6492-0d9b-5f0b-b961-d8cab77d360c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
