// Dragnet [Ransomware]: dragnet-ransomware-2024-0680 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: ddb8b0a5-c028-58c2-a146-297e07a1bedd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
