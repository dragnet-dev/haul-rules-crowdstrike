// Dragnet [Ransomware]: dragnet-ransomware-2024-3197 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: c5e67c50-ad2b-52ba-804a-e6f50b96b510

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
