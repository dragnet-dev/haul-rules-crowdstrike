// Dragnet [Ransomware]: dragnet-ransomware-2025-0820 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: e2fd943f-cb3e-5994-b656-cd5a9fe281d7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
