// Dragnet [Ransomware]: dragnet-ransomware-2024-0084 — Mass File Rename (datacarry)
// Status: deprecated | Level: high | ID: ad8da767-153d-5599-abe0-a45babdd01d4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
