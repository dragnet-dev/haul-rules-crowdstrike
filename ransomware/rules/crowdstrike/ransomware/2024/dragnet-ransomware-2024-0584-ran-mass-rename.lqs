// Dragnet [Ransomware]: dragnet-ransomware-2024-0584 — Mass File Rename (handala)
// Status: experimental | Level: high | ID: 86e2aaab-2fd9-53ba-b10c-5c807897c826

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
