// Dragnet [Ransomware]: dragnet-ransomware-2023-4605 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: c5171b80-a46c-5a30-ae2f-be5b6d3d7773

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
