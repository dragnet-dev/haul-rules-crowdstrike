// Dragnet [Ransomware]: dragnet-ransomware-2024-1145 — Mass File Rename (medusalocker)
// Status: experimental | Level: high | ID: 56e3d843-6b29-5dfb-826d-3556234bad59

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
