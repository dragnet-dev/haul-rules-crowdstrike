// Dragnet [Ransomware]: dragnet-ransomware-2023-1829 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: f9ff8465-efe8-553c-b4f7-1524e813f8de

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
