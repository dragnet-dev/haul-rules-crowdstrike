// Dragnet [Ransomware]: dragnet-ransomware-2025-0005 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: 2ea3af99-d28c-5a65-9fe2-1a9e64e4b157

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
