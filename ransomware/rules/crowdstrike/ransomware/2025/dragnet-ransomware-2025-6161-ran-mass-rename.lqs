// Dragnet [Ransomware]: dragnet-ransomware-2025-6161 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: f1bf3d32-e320-56db-9fb9-aadcb1d2210d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
