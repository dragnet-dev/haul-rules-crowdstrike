// Dragnet [Ransomware]: dragnet-ransomware-2025-2089 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 1f6e4f3c-1d8b-59f8-8ec6-1751519a669b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
