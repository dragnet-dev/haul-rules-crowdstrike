// Dragnet [Ransomware]: dragnet-ransomware-2022-0253 — Mass File Rename (vicesociety)
// Status: deprecated | Level: high | ID: c6b15022-12bd-5b78-8968-b4f32432db71

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
