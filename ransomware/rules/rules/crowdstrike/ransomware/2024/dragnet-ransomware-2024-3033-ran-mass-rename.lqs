// Dragnet [Ransomware]: dragnet-ransomware-2024-3033 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 202bb484-9b41-5587-b4a7-8177a3cee3fe

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
