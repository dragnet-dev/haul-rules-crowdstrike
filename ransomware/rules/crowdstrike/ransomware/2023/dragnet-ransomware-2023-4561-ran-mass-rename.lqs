// Dragnet [Ransomware]: dragnet-ransomware-2023-4561 — Mass File Rename (losttrust)
// Status: deprecated | Level: high | ID: d98e49d0-31aa-5b5e-b323-08f68321a925

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
