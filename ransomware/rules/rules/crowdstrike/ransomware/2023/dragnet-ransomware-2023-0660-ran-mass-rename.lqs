// Dragnet [Ransomware]: dragnet-ransomware-2023-0660 — Mass File Rename (play)
// Status: deprecated | Level: high | ID: ab312585-4f83-56d0-9766-26b618881118

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
