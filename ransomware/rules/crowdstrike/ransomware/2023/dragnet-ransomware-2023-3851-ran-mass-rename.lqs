// Dragnet [Ransomware]: dragnet-ransomware-2023-3851 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 8e22beeb-6a71-5439-a2a9-58d03a195b98

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
