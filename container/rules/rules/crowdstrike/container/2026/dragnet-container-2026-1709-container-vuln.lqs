// Dragnet [Container]: dragnet-container-2026-1709 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 24de1387-8e46-5d2b-9628-6ec8d5a6328c

#event_simpleName=*
| (ImageFileName = *amazonlinux:2* OR ImageFileName = *amazonlinux:2023* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
