// Dragnet [Ransomware]: dragnet-ransomware-2024-2455 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 094d27a9-6a6d-5f85-b170-675d6792e445

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
