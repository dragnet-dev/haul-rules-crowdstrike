// Dragnet [Ransomware]: dragnet-ransomware-2025-5292 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 281f1ecd-142d-5518-bc03-34e3954f221d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
