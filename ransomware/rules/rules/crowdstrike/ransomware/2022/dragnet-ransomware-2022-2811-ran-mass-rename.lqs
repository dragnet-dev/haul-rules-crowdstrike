// Dragnet [Ransomware]: dragnet-ransomware-2022-2811 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 5961e6eb-9f30-5a20-b878-6666f9ac3fd0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
