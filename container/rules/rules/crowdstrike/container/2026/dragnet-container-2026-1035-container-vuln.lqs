// Dragnet [Container]: dragnet-container-2026-1035 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 0caf01cd-a0e2-51ab-ac15-7eabe431972b

#event_simpleName=*
| (ImageFileName = *amazonlinux:2* OR ImageFileName = *amazonlinux:2023* OR ImageFileName = *chainguard:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:7* OR ImageFileName = *photon os:4.0* OR ImageFileName = *photon os:5.0* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:16.04-ESM* OR ImageFileName = *ubuntu:18.04-ESM* OR ImageFileName = *ubuntu:20.04-ESM* OR ImageFileName = *ubuntu:22.04* OR ImageFileName = *ubuntu:24.04* OR ImageFileName = *ubuntu:25.10*)
| table([timestamp, ComputerName])
| limit(1000)
