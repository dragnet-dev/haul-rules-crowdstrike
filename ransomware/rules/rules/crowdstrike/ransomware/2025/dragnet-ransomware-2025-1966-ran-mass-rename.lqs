// Dragnet [Ransomware]: dragnet-ransomware-2025-1966 — Mass File Rename (lockbit5)
// Status: test | Level: high | ID: 696ffcb3-ed74-53b4-a982-a35191ffaeb6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
