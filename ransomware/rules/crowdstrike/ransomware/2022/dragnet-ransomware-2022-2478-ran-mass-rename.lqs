// Dragnet [Ransomware]: dragnet-ransomware-2022-2478 — Mass File Rename (mindware)
// Status: deprecated | Level: high | ID: 885fc575-cd0c-5cac-98ee-e5633b93fe7c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
