// Dragnet [Ransomware]: dragnet-ransomware-2024-5817 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: b1a12191-4bc4-5746-827c-6f486ba9d9f7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
