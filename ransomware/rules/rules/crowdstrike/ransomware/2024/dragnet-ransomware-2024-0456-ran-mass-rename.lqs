// Dragnet [Ransomware]: dragnet-ransomware-2024-0456 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 707e9104-880b-57c4-8c40-ef366797f17e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
