// Dragnet [Ransomware]: dragnet-ransomware-2021-1546 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 994dbbb7-4122-5b24-a317-878564ec14a1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
