// Dragnet [Ransomware]: dragnet-ransomware-2026-0181 — Mass File Rename (AiLock)
// Status: deprecated | Level: high | ID: acf7859e-9d7f-50d0-a2c9-5d9f8cba9fd7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
