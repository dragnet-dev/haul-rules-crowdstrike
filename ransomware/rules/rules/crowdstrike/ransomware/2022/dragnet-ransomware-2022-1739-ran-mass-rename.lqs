// Dragnet [Ransomware]: dragnet-ransomware-2022-1739 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 1bd4186c-dd50-5b81-9a83-3a58e6c72ede

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
