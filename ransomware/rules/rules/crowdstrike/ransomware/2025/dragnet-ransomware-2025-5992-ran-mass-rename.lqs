// Dragnet [Ransomware]: dragnet-ransomware-2025-5992 — Mass File Rename (insomnia)
// Status: test | Level: high | ID: 452582d2-184f-5f9a-baf7-3445eee7dcf5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
