// Dragnet [Ransomware]: dragnet-ransomware-2022-0308 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 39feb32b-a0ed-58de-a14d-ce3110ae4d85

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
