// Dragnet [Ransomware]: dragnet-ransomware-2023-1482 — Mass File Rename (monti)
// Status: experimental | Level: high | ID: adfc1c66-610d-53f3-86f9-3feeec51b3ca

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
