// Dragnet [Ransomware]: dragnet-ransomware-2023-2546 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 43b7b661-e501-52c4-b20b-377eadd34abe

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
