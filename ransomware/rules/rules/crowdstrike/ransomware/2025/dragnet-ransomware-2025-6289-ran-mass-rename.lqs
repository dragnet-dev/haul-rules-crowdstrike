// Dragnet [Ransomware]: dragnet-ransomware-2025-6289 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 66a25502-0d45-5717-b23c-b6ed2000f869

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
