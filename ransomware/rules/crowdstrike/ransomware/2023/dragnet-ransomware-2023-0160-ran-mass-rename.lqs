// Dragnet [Ransomware]: dragnet-ransomware-2023-0160 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 0be71650-8df9-5e11-9053-4a25f13dbd41

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
