// Dragnet [Ransomware]: dragnet-ransomware-2025-6145 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 1b3483cc-08fb-55ba-923d-4ca362a1db72

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
