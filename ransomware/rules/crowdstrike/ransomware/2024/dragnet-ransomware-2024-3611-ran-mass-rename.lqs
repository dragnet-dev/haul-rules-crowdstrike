// Dragnet [Ransomware]: dragnet-ransomware-2024-3611 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 8735f11d-78de-56cc-bc3e-6cab7fe2a88f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
