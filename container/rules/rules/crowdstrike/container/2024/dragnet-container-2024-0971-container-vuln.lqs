// Dragnet [Container]: dragnet-container-2024-0971 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 91e00ef2-e32f-56b5-971f-a1719ed6a4d4

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:8* OR ImageFileName = *debian:9* OR ImageFileName = *ubuntu:18.04-ESM* OR ImageFileName = *ubuntu:20.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
