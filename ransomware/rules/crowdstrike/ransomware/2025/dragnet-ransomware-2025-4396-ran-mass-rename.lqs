// Dragnet [Ransomware]: dragnet-ransomware-2025-4396 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 960a55b3-e423-5a70-8645-b7f8e314027d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
