// Dragnet [Ransomware]: dragnet-ransomware-2023-0842 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 2770f6e1-bec7-5c6a-9d1c-0c6831c61118

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
