// Dragnet [Ransomware]: dragnet-ransomware-2023-1455 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 02c5b1c3-ad7e-5afb-ad88-09e6bb5b58ac

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
