// Dragnet [Ransomware]: dragnet-ransomware-2024-4418 — Mass File Rename (raworld)
// Status: experimental | Level: high | ID: 99d5bd3f-3472-5cd6-a357-8be89904d9ae

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
