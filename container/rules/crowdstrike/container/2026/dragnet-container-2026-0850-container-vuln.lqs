// Dragnet [Container]: dragnet-container-2026-0850 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 8c0d64dc-cf3e-5c8f-b31e-b753d1165424

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
