// Dragnet [Ransomware]: dragnet-ransomware-2023-5074 — Mass File Rename (rancoz)
// Status: experimental | Level: high | ID: f968d1b6-4c74-59e9-8370-65faf099ee61

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
