// Dragnet [Ransomware]: dragnet-ransomware-2024-4619 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 6174afb7-9a1d-5951-a075-4cc8c002534c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
