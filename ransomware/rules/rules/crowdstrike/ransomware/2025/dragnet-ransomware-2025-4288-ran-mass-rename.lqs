// Dragnet [Ransomware]: dragnet-ransomware-2025-4288 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: f8005008-af0e-5151-9f2f-836ff76aae85

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
