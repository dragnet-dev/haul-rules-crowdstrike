// Dragnet [Ransomware]: dragnet-ransomware-2022-0013 — Mass File Rename (lorenz)
// Status: experimental | Level: high | ID: 94254278-fcaf-56fb-9ac5-06eec0b2b23a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
