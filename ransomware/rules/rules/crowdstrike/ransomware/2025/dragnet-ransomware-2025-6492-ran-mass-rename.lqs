// Dragnet [Ransomware]: dragnet-ransomware-2025-6492 — Mass File Rename (beast)
// Status: experimental | Level: high | ID: df94e49a-6be8-5f5a-8cc7-64d68a342f32

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
