// Dragnet [Ransomware]: dragnet-ransomware-2022-2645 — Mass File Rename (everest)
// Status: deprecated | Level: high | ID: 4da2f49a-5cd1-5067-8f3b-453521798808

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
