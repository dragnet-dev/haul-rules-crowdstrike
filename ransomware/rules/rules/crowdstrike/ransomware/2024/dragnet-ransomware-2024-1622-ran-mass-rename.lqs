// Dragnet [Ransomware]: dragnet-ransomware-2024-1622 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: ab0fe3c6-e716-5765-aeff-8a148e1b18b6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
