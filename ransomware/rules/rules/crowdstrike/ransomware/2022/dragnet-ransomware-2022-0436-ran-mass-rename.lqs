// Dragnet [Ransomware]: dragnet-ransomware-2022-0436 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: ed0863d1-037a-50f4-aece-fd22e1a8add1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
