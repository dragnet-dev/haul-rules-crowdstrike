// Dragnet [Ransomware]: dragnet-ransomware-2024-1295 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 8da1f2a9-f4ce-563c-aafb-df234b362201

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
