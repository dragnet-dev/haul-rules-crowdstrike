// Dragnet [Ransomware]: dragnet-ransomware-2025-6895 — Mass File Rename (alphalocker)
// Status: experimental | Level: high | ID: ef64bfe6-d6a1-58a6-b08c-ce84e61650f4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
