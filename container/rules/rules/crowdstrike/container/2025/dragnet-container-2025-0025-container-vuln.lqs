// Dragnet [Container]: dragnet-container-2025-0025 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: f83858c8-e22f-5e1b-baf6-e1c9ae6277e0

#event_simpleName=*
| (ImageFileName = *alpine:3.4* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:7* OR ImageFileName = *debian:8* OR ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *oraclelinux:7* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:14.04* OR ImageFileName = *ubuntu:16.04* OR ImageFileName = *ubuntu:16.10*)
| table([timestamp, ComputerName])
| limit(1000)
