// Dragnet [Ransomware]: dragnet-ransomware-2025-6686 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 377cf28d-6f33-503d-a4f1-7d6e7e93d0fc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
