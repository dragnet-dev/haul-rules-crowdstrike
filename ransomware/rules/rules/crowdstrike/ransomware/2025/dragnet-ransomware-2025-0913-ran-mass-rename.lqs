// Dragnet [Ransomware]: dragnet-ransomware-2025-0913 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: f8ca7172-dc96-5a34-b19d-2ace7ad94058

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
