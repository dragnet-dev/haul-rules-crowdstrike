// Dragnet [Container]: dragnet-container-2024-1079 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 6131dd21-2b6c-5a04-9fa9-cb7982c9336a

#event_simpleName=*
| (ImageFileName = *alpine:3.17* OR ImageFileName = *alpine:3.18* OR ImageFileName = *alpine:3.19* OR ImageFileName = *alpine:3.20* OR ImageFileName = *alpine:3.21* OR ImageFileName = *alpine:3.22* OR ImageFileName = *alpine:3.23* OR ImageFileName = *alpine edge:* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
