// Dragnet [Ransomware]: dragnet-ransomware-2025-2572 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 68f15c23-928e-54d6-b417-6a4e4f04e835

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
