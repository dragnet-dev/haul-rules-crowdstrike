// Dragnet [Ransomware]: dragnet-ransomware-2026-3478 — Mass File Rename (lockbit5)
// Status: stable | Level: high | ID: db56b87d-eecc-5e1e-bbf0-5d7c32770b55

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
