// Dragnet [Ransomware]: dragnet-ransomware-2025-2641 — Mass File Rename (minteye)
// Status: deprecated | Level: high | ID: fbf25bbc-e968-5dff-942b-4f29092ebdab

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
