// Dragnet [Ransomware]: dragnet-ransomware-2021-0574 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: c7746932-5337-55e2-845a-616d6f1c1896

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
