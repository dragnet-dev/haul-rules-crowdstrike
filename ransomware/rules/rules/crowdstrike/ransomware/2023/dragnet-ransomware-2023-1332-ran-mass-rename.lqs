// Dragnet [Ransomware]: dragnet-ransomware-2023-1332 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: b75022bb-e350-5712-adcb-5571c90fa3fe

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
