// Dragnet [Ransomware]: dragnet-ransomware-2025-5435 — Mass File Rename (rhysida)
// Status: deprecated | Level: high | ID: 89e16261-ac83-5720-a879-46c5bdd1f815

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
