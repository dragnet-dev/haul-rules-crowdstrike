// Dragnet [Ransomware]: dragnet-ransomware-2023-1695 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 3824fd8c-c9aa-5b29-9676-a414a8e8fe4f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
