// Dragnet [Ransomware]: dragnet-ransomware-2021-1693 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 1dc3667a-0118-51e4-99e9-d3020dc8703b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
