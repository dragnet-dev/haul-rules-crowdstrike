// Dragnet [Ransomware]: dragnet-ransomware-2024-0262 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: ccb59cca-0fa2-538d-803e-ae4d465f68b8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
