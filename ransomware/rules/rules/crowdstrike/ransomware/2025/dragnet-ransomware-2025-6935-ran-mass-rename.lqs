// Dragnet [Ransomware]: dragnet-ransomware-2025-6935 — Mass File Rename (spacebears)
// Status: experimental | Level: high | ID: 0f114a9c-83df-532e-9b13-52832df6e87a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
