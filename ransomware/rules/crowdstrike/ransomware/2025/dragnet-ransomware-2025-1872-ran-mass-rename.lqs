// Dragnet [Ransomware]: dragnet-ransomware-2025-1872 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 6a00da97-b539-5c13-8ac0-2edd3754b9a0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
