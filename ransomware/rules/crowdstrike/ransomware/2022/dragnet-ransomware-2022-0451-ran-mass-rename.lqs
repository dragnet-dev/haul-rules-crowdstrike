// Dragnet [Ransomware]: dragnet-ransomware-2022-0451 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 85bfcbc0-4d58-54ec-8fe8-866685bf6ab9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
