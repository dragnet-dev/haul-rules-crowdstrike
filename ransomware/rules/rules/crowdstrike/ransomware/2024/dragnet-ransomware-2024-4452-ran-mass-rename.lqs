// Dragnet [Ransomware]: dragnet-ransomware-2024-4452 — Mass File Rename (ransomhouse)
// Status: experimental | Level: high | ID: b1a3d5c2-013e-590c-a2ed-200762851a1c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
