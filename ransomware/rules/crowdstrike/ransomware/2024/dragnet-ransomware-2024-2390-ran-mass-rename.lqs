// Dragnet [Ransomware]: dragnet-ransomware-2024-2390 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: 36ba11e9-66d4-501d-a15a-bd886b448289

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
