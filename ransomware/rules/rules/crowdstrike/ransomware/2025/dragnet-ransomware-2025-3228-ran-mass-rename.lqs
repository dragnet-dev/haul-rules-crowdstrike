// Dragnet [Ransomware]: dragnet-ransomware-2025-3228 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: c4edc311-647d-5d65-8ec5-6dbea5a22440

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
