// Dragnet [Ransomware]: dragnet-ransomware-2023-0209 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: f640a218-74a8-514c-a88b-22072170ff6d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
