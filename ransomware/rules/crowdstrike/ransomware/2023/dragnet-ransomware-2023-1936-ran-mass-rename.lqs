// Dragnet [Ransomware]: dragnet-ransomware-2023-1936 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: c43df809-a525-5702-8413-a0544f05018b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
