// Dragnet [Ransomware]: dragnet-ransomware-2025-5026 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 24f723f7-db05-50bf-b9fb-f54b0b062233

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
