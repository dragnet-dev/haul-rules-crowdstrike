// Dragnet [Ransomware]: dragnet-ransomware-2025-6113 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: fb90731d-e745-50ad-871c-c4fd6c799840

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
