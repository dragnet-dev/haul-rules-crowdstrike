// Dragnet [Ransomware]: dragnet-ransomware-2023-5349 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 9301ed17-972f-5891-be96-0f0a6442bf84

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
