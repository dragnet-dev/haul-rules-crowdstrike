// Dragnet [Ransomware]: dragnet-ransomware-2025-6668 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 9673bcd2-1950-575c-9f6d-4c270f0ddf54

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
