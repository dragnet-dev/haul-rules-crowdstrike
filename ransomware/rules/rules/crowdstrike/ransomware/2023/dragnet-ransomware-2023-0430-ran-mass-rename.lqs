// Dragnet [Ransomware]: dragnet-ransomware-2023-0430 — Mass File Rename (dragonforce)
// Status: deprecated | Level: high | ID: a5e6c977-6599-53e6-8c7e-6a588c0afec6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
