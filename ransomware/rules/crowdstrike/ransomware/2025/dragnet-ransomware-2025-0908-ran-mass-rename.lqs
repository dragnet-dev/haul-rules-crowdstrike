// Dragnet [Ransomware]: dragnet-ransomware-2025-0908 — Mass File Rename (sinobi)
// Status: experimental | Level: high | ID: 0ab63a64-0da6-5dd7-ac86-3800cb4088de

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
