// Dragnet [Ransomware]: dragnet-ransomware-2023-3069 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 20933f50-6eae-54cc-a0aa-37e33b0c482d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
