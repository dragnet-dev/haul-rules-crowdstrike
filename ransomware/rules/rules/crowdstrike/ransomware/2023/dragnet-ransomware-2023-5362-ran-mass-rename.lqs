// Dragnet [Ransomware]: dragnet-ransomware-2023-5362 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 3892aa5d-15b1-52ae-8821-0f37c9d44fe3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
