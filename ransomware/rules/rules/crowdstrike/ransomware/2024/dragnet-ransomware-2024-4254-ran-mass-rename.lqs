// Dragnet [Ransomware]: dragnet-ransomware-2024-4254 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: fa2220e9-26cd-57f9-a1ce-6588ad81af0f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
