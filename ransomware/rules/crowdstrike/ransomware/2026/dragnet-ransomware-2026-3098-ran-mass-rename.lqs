// Dragnet [Ransomware]: dragnet-ransomware-2026-3098 — Mass File Rename (securotrop)
// Status: stable | Level: high | ID: f488c4f8-e7f4-57b2-aae9-4e0d0afd1ab9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
