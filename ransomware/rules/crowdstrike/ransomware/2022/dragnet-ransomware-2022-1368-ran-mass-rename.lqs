// Dragnet [Ransomware]: dragnet-ransomware-2022-1368 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: c052094f-c1cc-586a-af2e-6917354474c9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
