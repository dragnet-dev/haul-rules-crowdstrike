// Dragnet [Ransomware]: dragnet-ransomware-2022-2207 — Mass File Rename (quantum)
// Status: deprecated | Level: high | ID: 433c911d-e0da-5591-a71b-88febb4d713c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
