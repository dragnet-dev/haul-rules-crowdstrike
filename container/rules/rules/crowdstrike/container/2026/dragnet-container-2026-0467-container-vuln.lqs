// Dragnet [Container]: dragnet-container-2026-0467 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 22d8b997-3659-5a0e-83d0-5bac0a2d92ca

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
