// Dragnet [Ransomware]: dragnet-ransomware-2021-1028 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: ccbffdd5-5c6e-54ce-8c37-664fcebec05c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
