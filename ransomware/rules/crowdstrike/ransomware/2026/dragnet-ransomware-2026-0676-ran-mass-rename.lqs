// Dragnet [Ransomware]: dragnet-ransomware-2026-0676 — Mass File Rename (lockbit5)
// Status: stable | Level: high | ID: df540418-0711-5371-8cc5-a830c6f34b08

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
