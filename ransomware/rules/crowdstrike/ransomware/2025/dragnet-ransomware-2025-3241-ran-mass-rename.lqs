// Dragnet [Ransomware]: dragnet-ransomware-2025-3241 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: fc028f3b-8a7c-5a3c-9bf5-994260791baf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
