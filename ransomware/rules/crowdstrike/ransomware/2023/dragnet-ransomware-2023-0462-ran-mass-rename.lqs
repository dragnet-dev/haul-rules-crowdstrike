// Dragnet [Ransomware]: dragnet-ransomware-2023-0462 — Mass File Rename (noescape)
// Status: experimental | Level: high | ID: 51fcce23-1116-5c03-a4c6-741482cbd966

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
