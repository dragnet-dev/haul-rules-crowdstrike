// Dragnet [Ransomware]: dragnet-ransomware-2024-2486 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 9c00a14a-5a07-5969-b9db-2084943886ef

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
