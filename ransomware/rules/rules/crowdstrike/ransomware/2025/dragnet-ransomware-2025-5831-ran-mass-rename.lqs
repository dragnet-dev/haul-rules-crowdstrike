// Dragnet [Ransomware]: dragnet-ransomware-2025-5831 — Mass File Rename (rhysida)
// Status: experimental | Level: high | ID: bc303cad-0156-5236-bec4-8357127b25a1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
