// Dragnet [Ransomware]: dragnet-ransomware-2024-4834 — Mass File Rename (qilin)
// Status: deprecated | Level: high | ID: df9d1322-6726-5160-88ae-d12401e1eb11

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
