// Dragnet [Ransomware]: dragnet-ransomware-2024-3094 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: 3dc8a238-39c9-517a-91f5-0934161734a6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
