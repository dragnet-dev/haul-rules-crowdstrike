// Dragnet [Ransomware]: dragnet-ransomware-2026-3401 — Mass File Rename (lamashtu)
// Status: stable | Level: high | ID: b39478b8-2e58-56d1-91e4-349c06e5c9f9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
