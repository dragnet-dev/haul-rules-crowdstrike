// Dragnet [Ransomware]: dragnet-ransomware-2023-3863 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 490fcb6c-4104-53d3-a78e-2af4b5b32337

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
