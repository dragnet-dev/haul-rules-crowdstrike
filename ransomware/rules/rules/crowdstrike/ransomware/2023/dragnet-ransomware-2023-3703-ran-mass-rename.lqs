// Dragnet [Ransomware]: dragnet-ransomware-2023-3703 — Mass File Rename (medusa)
// Status: deprecated | Level: high | ID: 72a6f751-475d-5c09-8c68-88b42bfc35be

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
