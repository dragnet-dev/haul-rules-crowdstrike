// Dragnet [Ransomware]: dragnet-ransomware-2025-4101 — Mass File Rename (moneymessage)
// Status: experimental | Level: high | ID: 93861f8d-c0dd-579c-a38d-cb2c314ededc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
