// Dragnet [Container]: dragnet-container-2025-0139 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: cee715e1-c1de-5961-bd7b-a28a24090dc0

#event_simpleName=*
| (ImageFileName = *almalinux:8* OR ImageFileName = *almalinux:9* OR ImageFileName = *alpine:3.20* OR ImageFileName = *alpine:3.21* OR ImageFileName = *alpine:3.22* OR ImageFileName = *alpine:3.23* OR ImageFileName = *alpine edge:* OR ImageFileName = *amazonlinux:2023* OR ImageFileName = *chainguard:* OR ImageFileName = *oraclelinux:8* OR ImageFileName = *oraclelinux:9* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:22.04* OR ImageFileName = *ubuntu:24.04* OR ImageFileName = *ubuntu:25.04* OR ImageFileName = *ubuntu:25.10* OR ImageFileName = *ubuntu:26.04* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
