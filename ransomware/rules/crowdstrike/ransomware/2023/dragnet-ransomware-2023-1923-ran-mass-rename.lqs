// Dragnet [Ransomware]: dragnet-ransomware-2023-1923 — Mass File Rename (rhysida)
// Status: experimental | Level: high | ID: 62d1fbc6-010a-5665-beab-bc9fdcd57357

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
