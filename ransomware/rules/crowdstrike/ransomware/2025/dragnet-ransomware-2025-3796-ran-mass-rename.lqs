// Dragnet [Ransomware]: dragnet-ransomware-2025-3796 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 9a89f8b6-c871-5739-822e-47f4f07d2070

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
