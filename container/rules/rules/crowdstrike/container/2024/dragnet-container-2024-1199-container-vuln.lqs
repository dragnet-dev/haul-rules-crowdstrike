// Dragnet [Container]: dragnet-container-2024-1199 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 07930702-e9f2-58e8-9b35-1fca97c12997

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *redhat/ubi9:*)
| table([timestamp, ComputerName])
| limit(1000)
