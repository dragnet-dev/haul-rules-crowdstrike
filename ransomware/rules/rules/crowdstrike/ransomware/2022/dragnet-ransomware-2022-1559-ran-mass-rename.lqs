// Dragnet [Ransomware]: dragnet-ransomware-2022-1559 — Mass File Rename (cuba)
// Status: deprecated | Level: high | ID: 0a4bde30-6447-56e4-a59f-123bd87775ae

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
