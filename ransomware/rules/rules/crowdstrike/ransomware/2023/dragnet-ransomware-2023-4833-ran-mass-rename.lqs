// Dragnet [Ransomware]: dragnet-ransomware-2023-4833 — Mass File Rename (play)
// Status: experimental | Level: high | ID: df5d2827-1817-5e4e-a3d0-dd9858576e2e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
