// Dragnet [Ransomware]: dragnet-ransomware-2024-0817 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 9005cdfa-3a25-5df9-8893-7bb47a9e5c49

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
