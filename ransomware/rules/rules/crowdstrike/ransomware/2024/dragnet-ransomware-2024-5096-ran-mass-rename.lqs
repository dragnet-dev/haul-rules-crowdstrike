// Dragnet [Ransomware]: dragnet-ransomware-2024-5096 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: f4c6d84b-ed58-5ed6-9739-bdae85c7b145

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
