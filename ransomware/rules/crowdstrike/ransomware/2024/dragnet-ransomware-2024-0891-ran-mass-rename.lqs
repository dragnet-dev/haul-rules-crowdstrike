// Dragnet [Ransomware]: dragnet-ransomware-2024-0891 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: fd1210ce-d902-5571-9b8a-e9689fe35bc4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
