// Dragnet [Ransomware]: dragnet-ransomware-2025-5563 — Mass File Rename (blacknevas)
// Status: experimental | Level: high | ID: 79591df1-7165-5e71-bb88-c28d00ada941

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
