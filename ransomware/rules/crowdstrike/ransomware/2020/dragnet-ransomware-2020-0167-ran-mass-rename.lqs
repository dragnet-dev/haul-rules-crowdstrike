// Dragnet [Ransomware]: dragnet-ransomware-2020-0167 — Mass File Rename (netwalker)
// Status: deprecated | Level: high | ID: 107264ac-50ef-5d07-9978-c5784f9a9e6b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
