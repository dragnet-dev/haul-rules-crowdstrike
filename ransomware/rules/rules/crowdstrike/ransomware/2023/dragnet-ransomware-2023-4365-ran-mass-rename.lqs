// Dragnet [Ransomware]: dragnet-ransomware-2023-4365 — Mass File Rename (rhysida)
// Status: experimental | Level: high | ID: ae458707-9ff6-5c50-be0e-b1f5242e2a50

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
