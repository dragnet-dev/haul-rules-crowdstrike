// Dragnet [Ransomware]: dragnet-ransomware-2025-5460 — Mass File Rename (devman)
// Status: experimental | Level: high | ID: 6055627a-0da0-5f0d-a9bb-06812259252e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
