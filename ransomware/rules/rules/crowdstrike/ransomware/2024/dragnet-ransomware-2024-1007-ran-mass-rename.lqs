// Dragnet [Ransomware]: dragnet-ransomware-2024-1007 — Mass File Rename (sarcoma)
// Status: deprecated | Level: high | ID: 36209316-5863-53c0-984c-e392694f92cb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
