// Dragnet [Ransomware]: dragnet-ransomware-2025-5012 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 92b72d95-dfa3-504c-890f-a99dc2e61605

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
