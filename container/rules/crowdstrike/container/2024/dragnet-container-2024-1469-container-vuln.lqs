// Dragnet [Container]: dragnet-container-2024-1469 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: d31aacff-9631-55c1-b1df-3f6c0be8e0d8

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:8* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:14.04* OR ImageFileName = *ubuntu:14.04-ESM* OR ImageFileName = *ubuntu:16.04* OR ImageFileName = *ubuntu:16.04-ESM* OR ImageFileName = *ubuntu:18.04* OR ImageFileName = *ubuntu:18.04-ESM* OR ImageFileName = *ubuntu:18.10*)
| table([timestamp, ComputerName])
| limit(1000)
