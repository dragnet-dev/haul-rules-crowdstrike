// Dragnet [Ransomware]: dragnet-ransomware-2022-2757 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 8a9b40d2-7ae0-55c6-9f0f-8239974bcc8e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
