// Dragnet [Container]: dragnet-container-2025-0287 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: cae5b825-c374-5125-8fc0-2dd7b049294a

#event_simpleName=*
| (ImageFileName = *amazonlinux:2* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
