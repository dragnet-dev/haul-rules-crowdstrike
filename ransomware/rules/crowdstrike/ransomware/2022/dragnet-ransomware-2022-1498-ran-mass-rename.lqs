// Dragnet [Ransomware]: dragnet-ransomware-2022-1498 — Mass File Rename (royal)
// Status: deprecated | Level: high | ID: 737cd6e7-676a-55d5-ab21-5ba09f55ec61

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
