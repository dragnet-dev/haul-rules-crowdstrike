// Dragnet [Container]: dragnet-container-2026-0671 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 14f34f90-ad4f-5adc-86bd-8c2df8be1c10

#event_simpleName=*
| (ImageFileName = *alpine edge:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
