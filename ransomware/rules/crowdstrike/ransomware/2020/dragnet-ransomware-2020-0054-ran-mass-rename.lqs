// Dragnet [Ransomware]: dragnet-ransomware-2020-0054 — Mass File Rename (netwalker)
// Status: deprecated | Level: high | ID: a1884836-ed65-5489-8fa8-dc12d7876e4b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
