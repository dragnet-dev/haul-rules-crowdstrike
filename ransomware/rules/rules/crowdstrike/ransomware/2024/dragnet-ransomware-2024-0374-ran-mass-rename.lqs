// Dragnet [Ransomware]: dragnet-ransomware-2024-0374 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: c692672a-6443-5a00-b30c-63a4eb1c2416

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
