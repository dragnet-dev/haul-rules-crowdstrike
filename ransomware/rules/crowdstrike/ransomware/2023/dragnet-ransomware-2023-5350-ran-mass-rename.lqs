// Dragnet [Ransomware]: dragnet-ransomware-2023-5350 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 6c909c0c-c5ca-530e-8b3f-a0d44d7f1aa0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
