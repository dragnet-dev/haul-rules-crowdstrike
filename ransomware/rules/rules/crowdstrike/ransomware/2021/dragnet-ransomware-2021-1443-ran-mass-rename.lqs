// Dragnet [Ransomware]: dragnet-ransomware-2021-1443 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: ec8f0922-b718-5711-8832-c1e938e4de70

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
