// Dragnet [Ransomware]: dragnet-ransomware-2025-6586 — Mass File Rename (stormous)
// Status: deprecated | Level: high | ID: ee4b0208-e44a-5115-949e-b474a3804c24

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
