// Dragnet [Ransomware]: dragnet-ransomware-2024-3841 — Mass File Rename (qilin)
// Status: deprecated | Level: high | ID: f406253d-9932-57e4-b961-b4fa2b6b6d98

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
