// Dragnet [Ransomware]: dragnet-ransomware-2023-3577 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 481c9b3e-307a-50cb-a2d3-3cccc2491cac

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
