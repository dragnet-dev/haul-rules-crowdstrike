// Dragnet [Ransomware]: dragnet-ransomware-2023-4397 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: ad19fe9c-719e-5e9d-a40b-843d917c1866

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
