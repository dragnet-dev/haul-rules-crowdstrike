// Dragnet [Ransomware]: dragnet-ransomware-2024-3352 — Mass File Rename (BrainCipher)
// Status: experimental | Level: high | ID: baa0ffc9-10e8-5e00-8b8d-c124a75c8eac

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
