// Dragnet [Ransomware]: dragnet-ransomware-2022-2999 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 70737265-2d05-5851-8f38-c0df1350dbac

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
