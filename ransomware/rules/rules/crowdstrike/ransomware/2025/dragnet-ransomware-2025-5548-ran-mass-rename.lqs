// Dragnet [Ransomware]: dragnet-ransomware-2025-5548 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 08067435-c822-5416-8fd8-66cbe1788209

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
