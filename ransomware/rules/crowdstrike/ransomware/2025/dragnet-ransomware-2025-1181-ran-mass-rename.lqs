// Dragnet [Ransomware]: dragnet-ransomware-2025-1181 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: af3ee118-52e3-5d3c-b6e3-5b32292c745e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
