// Dragnet [Ransomware]: dragnet-ransomware-2025-2329 — Mass File Rename (play)
// Status: experimental | Level: high | ID: e543c003-968b-5346-a9ca-234e4f391a76

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
