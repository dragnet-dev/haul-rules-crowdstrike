// Dragnet [Ransomware]: dragnet-ransomware-2024-5592 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 1d9d2761-67f1-5c3e-986b-2364a84fe391

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
