// Dragnet [Ransomware]: dragnet-ransomware-2025-4614 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: f7607c06-c869-5365-b8d1-c9b005fa6cac

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
