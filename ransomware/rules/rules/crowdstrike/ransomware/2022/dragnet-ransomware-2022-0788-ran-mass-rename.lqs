// Dragnet [Ransomware]: dragnet-ransomware-2022-0788 — Mass File Rename (donutleaks)
// Status: deprecated | Level: high | ID: c88d71f2-fd01-5199-8e32-78b3ef9decd4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
