// Dragnet [Ransomware]: dragnet-ransomware-2024-4596 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 4ec731a4-8773-53ac-8998-3b109d58773c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
