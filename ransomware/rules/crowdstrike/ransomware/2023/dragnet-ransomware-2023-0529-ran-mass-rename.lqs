// Dragnet [Ransomware]: dragnet-ransomware-2023-0529 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: a04c0149-57c1-50de-b308-3405cdabb484

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
