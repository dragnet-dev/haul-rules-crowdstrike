// Dragnet [Ransomware]: dragnet-ransomware-2024-2781 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 2aad3146-2d38-553d-ad59-68760fc8bf76

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
