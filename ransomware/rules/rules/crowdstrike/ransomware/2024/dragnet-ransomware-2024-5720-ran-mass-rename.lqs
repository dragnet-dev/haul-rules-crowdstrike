// Dragnet [Ransomware]: dragnet-ransomware-2024-5720 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: c037f689-80ea-5409-aeda-9890d8a5e2b2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
