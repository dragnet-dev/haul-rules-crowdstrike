// Dragnet [Ransomware]: dragnet-ransomware-2025-5467 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: d28df94e-f9d2-5bcd-a4b5-2be9b088c5da

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
