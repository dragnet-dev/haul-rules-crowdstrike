// Dragnet [Ransomware]: dragnet-ransomware-2024-5171 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 5a8ce20c-aafa-5f74-ac21-0a2c3cac9b2c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
