// Dragnet [Ransomware]: dragnet-ransomware-2024-3978 — Mass File Rename (rhysida)
// Status: deprecated | Level: high | ID: 7eacf9d8-84ed-5fe9-b5fa-f3fc830d5ea2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
