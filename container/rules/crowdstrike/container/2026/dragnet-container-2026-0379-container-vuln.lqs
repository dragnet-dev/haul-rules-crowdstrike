// Dragnet [Container]: dragnet-container-2026-0379 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: db3f0566-ba13-5494-b5c8-10d57cb1465f

#event_simpleName=*
| (ImageFileName = *alpine:3.3* OR ImageFileName = *amazonlinux:1* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:7* OR ImageFileName = *debian:8* OR ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.04-ESM* OR ImageFileName = *ubuntu:14.04* OR ImageFileName = *ubuntu:14.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
