// Dragnet [Ransomware]: dragnet-ransomware-2022-1058 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 6a6a5a67-9dfc-51c5-b261-caf0ed877386

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
