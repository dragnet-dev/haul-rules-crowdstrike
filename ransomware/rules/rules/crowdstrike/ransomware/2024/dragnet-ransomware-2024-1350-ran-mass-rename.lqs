// Dragnet [Ransomware]: dragnet-ransomware-2024-1350 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: f5b3fd4c-1c85-5625-a0b3-cb8dde125223

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
