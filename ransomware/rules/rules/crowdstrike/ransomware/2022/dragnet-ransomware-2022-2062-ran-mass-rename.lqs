// Dragnet [Ransomware]: dragnet-ransomware-2022-2062 — Mass File Rename (royal)
// Status: deprecated | Level: high | ID: a7599c9e-05ef-5d5f-bc53-a2f027c130a6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
