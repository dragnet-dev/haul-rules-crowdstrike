// Dragnet [Ransomware]: dragnet-ransomware-2021-0628 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: b193c91c-8981-5997-98b7-f43da65be413

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
