// Dragnet [Ransomware]: dragnet-ransomware-2025-1464 — Mass File Rename (shinyhunters)
// Status: experimental | Level: high | ID: c759bb47-c67a-5e4c-b9c0-46b524a1079f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
