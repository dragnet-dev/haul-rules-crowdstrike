// Dragnet [Ransomware]: dragnet-ransomware-2024-0415 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 01a83061-830e-500b-a94f-580bd9f3b350

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
