// Dragnet [Ransomware]: dragnet-ransomware-2023-2341 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: fd41d4a3-fd60-55bf-a2ec-316c32e95df6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
