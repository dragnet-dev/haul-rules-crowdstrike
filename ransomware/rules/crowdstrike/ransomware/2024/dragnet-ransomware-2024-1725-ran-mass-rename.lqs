// Dragnet [Ransomware]: dragnet-ransomware-2024-1725 — Mass File Rename (ransomhouse)
// Status: experimental | Level: high | ID: ec7d8fb0-97a9-511e-a664-2c62ac90c3d7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
