// Dragnet [Ransomware]: dragnet-ransomware-2023-5052 — Mass File Rename (qilin)
// Status: deprecated | Level: high | ID: bc6746dd-df8b-5808-8929-9e16ed52952e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
