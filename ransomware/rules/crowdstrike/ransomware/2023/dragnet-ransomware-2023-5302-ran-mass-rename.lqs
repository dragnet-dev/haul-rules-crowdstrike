// Dragnet [Ransomware]: dragnet-ransomware-2023-5302 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 78909379-4ccf-53be-b7b4-4b38c0cc68be

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
