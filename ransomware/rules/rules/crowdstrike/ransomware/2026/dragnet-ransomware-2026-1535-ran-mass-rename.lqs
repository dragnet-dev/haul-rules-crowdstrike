// Dragnet [Ransomware]: dragnet-ransomware-2026-1535 — Mass File Rename (payoutsking)
// Status: test | Level: high | ID: 05413b30-8c59-5e77-a3fc-4c0dd3c5298d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
