// Dragnet [Ransomware]: dragnet-ransomware-2021-1677 — Mass File Rename (midas)
// Status: deprecated | Level: high | ID: 94410dd4-745f-5d5b-a10d-a1b075b1da90

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
