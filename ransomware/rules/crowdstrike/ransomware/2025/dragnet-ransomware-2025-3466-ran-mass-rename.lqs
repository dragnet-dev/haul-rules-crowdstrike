// Dragnet [Ransomware]: dragnet-ransomware-2025-3466 — Mass File Rename (nightspire)
// Status: experimental | Level: high | ID: 59dbc98f-11b9-51d7-bdd7-4c84b71041f1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
