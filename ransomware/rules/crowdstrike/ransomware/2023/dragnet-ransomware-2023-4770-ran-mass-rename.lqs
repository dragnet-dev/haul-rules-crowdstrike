// Dragnet [Ransomware]: dragnet-ransomware-2023-4770 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 3e8d65f0-be8b-56cc-98f8-39e066586064

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
