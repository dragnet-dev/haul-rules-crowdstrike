// Dragnet [Ransomware]: dragnet-ransomware-2024-4695 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 0d57a812-b2e4-52b3-93d8-1ee905d6006a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
