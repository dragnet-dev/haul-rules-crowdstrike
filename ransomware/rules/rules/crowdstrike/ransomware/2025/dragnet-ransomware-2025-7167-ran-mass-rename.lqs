// Dragnet [Ransomware]: dragnet-ransomware-2025-7167 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: b2bfac50-9226-53d0-b91c-2f6f84777d44

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
