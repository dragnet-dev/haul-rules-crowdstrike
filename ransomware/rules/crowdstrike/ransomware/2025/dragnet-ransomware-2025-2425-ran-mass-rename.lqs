// Dragnet [Ransomware]: dragnet-ransomware-2025-2425 — Mass File Rename (thegentlemen)
// Status: experimental | Level: high | ID: d057aa84-fe7d-5435-bb01-76ff6a279aaf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
