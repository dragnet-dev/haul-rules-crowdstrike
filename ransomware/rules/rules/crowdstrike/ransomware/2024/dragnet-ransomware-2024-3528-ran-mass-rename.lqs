// Dragnet [Ransomware]: dragnet-ransomware-2024-3528 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: d3b50e55-58b0-5075-956c-8398dd03a259

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
