// Dragnet [Ransomware]: dragnet-ransomware-2025-6612 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 1c003422-6183-525a-8b39-91327be1c6c9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
