// Dragnet [Ransomware]: dragnet-ransomware-2025-2759 — Mass File Rename (shinyhunters)
// Status: experimental | Level: high | ID: 21db30cc-cff0-58c1-8558-4a3b199f7c0d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
