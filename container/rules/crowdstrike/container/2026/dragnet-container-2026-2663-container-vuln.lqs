// Dragnet [Container]: dragnet-container-2026-2663 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 8c0c9b15-024c-592c-a692-9f9d326fda50

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:5*)
| table([timestamp, ComputerName])
| limit(1000)
