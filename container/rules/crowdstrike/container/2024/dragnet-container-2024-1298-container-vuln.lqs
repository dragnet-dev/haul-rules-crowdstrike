// Dragnet [Container]: dragnet-container-2024-1298 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: ace81025-b1ad-5fcf-b538-3cc8828d6bea

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:7* OR ImageFileName = *debian:8*)
| table([timestamp, ComputerName])
| limit(1000)
