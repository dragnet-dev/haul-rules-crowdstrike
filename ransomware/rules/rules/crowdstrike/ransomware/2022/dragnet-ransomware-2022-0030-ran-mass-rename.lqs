// Dragnet [Ransomware]: dragnet-ransomware-2022-0030 — Mass File Rename (vicesociety)
// Status: deprecated | Level: high | ID: 8af90309-4f04-53b7-b123-ebce2d80131a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
