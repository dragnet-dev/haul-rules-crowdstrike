// Dragnet [Ransomware]: dragnet-ransomware-2025-5870 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 540f3533-e353-52ff-b60b-a8b63eeb00ce

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
