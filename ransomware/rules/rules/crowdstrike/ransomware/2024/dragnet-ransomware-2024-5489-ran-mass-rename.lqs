// Dragnet [Ransomware]: dragnet-ransomware-2024-5489 — Mass File Rename (play)
// Status: experimental | Level: high | ID: da6e3b8e-7416-55df-bbe8-d3f8f6fefa6b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
