// Dragnet [Ransomware]: dragnet-ransomware-2021-1721 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: bcf5598e-9332-5db0-b58f-29a8cc8aa7a9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
