// Dragnet [Ransomware]: dragnet-ransomware-2025-7147 — Mass File Rename (spacebears)
// Status: experimental | Level: high | ID: 913cf9be-6c2c-5e79-968a-08242ad46c99

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
