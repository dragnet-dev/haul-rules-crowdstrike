// Dragnet [Ransomware]: dragnet-ransomware-2023-0553 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 60c7082b-7470-50f9-8bca-a914b744a7c8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
