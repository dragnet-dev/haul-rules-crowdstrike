// Dragnet [Ransomware]: dragnet-ransomware-2024-5338 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: ab4ff8b1-db4f-5c1e-9606-a71c9b316f0e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
