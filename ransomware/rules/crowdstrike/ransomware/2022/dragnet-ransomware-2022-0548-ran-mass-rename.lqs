// Dragnet [Ransomware]: dragnet-ransomware-2022-0548 — Mass File Rename (vicesociety)
// Status: deprecated | Level: high | ID: b0e97099-2a38-51c7-a8f8-ee2c7c618037

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
