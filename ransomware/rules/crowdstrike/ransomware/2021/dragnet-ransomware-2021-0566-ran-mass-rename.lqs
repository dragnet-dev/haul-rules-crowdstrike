// Dragnet [Ransomware]: dragnet-ransomware-2021-0566 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: d4d44a66-0958-5375-b79f-e99ecf4c3b85

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
