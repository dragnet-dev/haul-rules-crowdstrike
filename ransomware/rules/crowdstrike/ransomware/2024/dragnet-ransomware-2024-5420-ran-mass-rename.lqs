// Dragnet [Ransomware]: dragnet-ransomware-2024-5420 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: f2bdc447-dc65-5209-ae57-3dcd9860f47a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
