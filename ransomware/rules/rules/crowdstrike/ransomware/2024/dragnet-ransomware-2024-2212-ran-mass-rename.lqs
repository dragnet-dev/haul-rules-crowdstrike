// Dragnet [Ransomware]: dragnet-ransomware-2024-2212 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: a10d2a0a-ee10-561c-9a03-20bb23536ab9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
