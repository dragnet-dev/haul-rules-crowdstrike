// Dragnet [Container]: dragnet-container-2026-0807 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: a3f0b77b-d441-5275-887d-1c25a8c9c794

#event_simpleName=*
| (ImageFileName = *amazonlinux:1* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:7* OR ImageFileName = *redhat/ubi9:*)
| table([timestamp, ComputerName])
| limit(1000)
