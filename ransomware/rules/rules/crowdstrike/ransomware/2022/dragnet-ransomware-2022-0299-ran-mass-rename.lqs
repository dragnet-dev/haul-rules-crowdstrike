// Dragnet [Ransomware]: dragnet-ransomware-2022-0299 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: e08ec69e-2441-5d15-a34c-0d8ae5f8ec09

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
