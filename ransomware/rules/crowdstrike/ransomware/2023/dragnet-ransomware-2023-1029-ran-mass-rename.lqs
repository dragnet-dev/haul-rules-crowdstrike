// Dragnet [Ransomware]: dragnet-ransomware-2023-1029 — Mass File Rename (noescape)
// Status: experimental | Level: high | ID: bdf7ace3-701f-5759-af64-567a85f3b571

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
