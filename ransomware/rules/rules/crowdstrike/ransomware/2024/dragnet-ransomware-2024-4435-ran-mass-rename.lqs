// Dragnet [Ransomware]: dragnet-ransomware-2024-4435 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: ae6e0555-8c1a-5828-b391-02cb53902338

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
