// Dragnet [Container]: dragnet-container-2024-1165 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: a0faa6e6-35cb-59a3-8cb7-5f169c8c41a8

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:9*)
| table([timestamp, ComputerName])
| limit(1000)
