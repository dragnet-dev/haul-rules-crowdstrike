// Dragnet [Ransomware]: dragnet-ransomware-2023-0638 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: fbf5cdc5-da35-505f-8b08-16a149d910a4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
