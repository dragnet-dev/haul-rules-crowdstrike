// Dragnet [Ransomware]: dragnet-ransomware-2023-0490 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: f751a0d3-a200-5c4e-9655-82186117e528

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
