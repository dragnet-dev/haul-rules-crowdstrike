// Dragnet [Ransomware]: dragnet-ransomware-2025-6908 — Mass File Rename (tengu)
// Status: experimental | Level: high | ID: e033e36d-f467-521c-b831-b16dc2d68ee9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
