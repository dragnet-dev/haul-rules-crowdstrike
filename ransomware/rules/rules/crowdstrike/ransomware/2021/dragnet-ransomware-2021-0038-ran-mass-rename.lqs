// Dragnet [Ransomware]: dragnet-ransomware-2021-0038 — Mass File Rename (blackmatter)
// Status: deprecated | Level: high | ID: 88d7679e-60af-5af6-a547-321777b16356

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
