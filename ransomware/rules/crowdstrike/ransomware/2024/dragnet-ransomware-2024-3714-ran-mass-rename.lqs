// Dragnet [Ransomware]: dragnet-ransomware-2024-3714 — Mass File Rename (monti)
// Status: experimental | Level: high | ID: ff165b0a-ee54-5d49-b3f0-323a0c8ff836

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
