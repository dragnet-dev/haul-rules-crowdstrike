// Dragnet [Ransomware]: dragnet-ransomware-2025-6783 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 21cc12e1-32d5-5818-9aab-df3d928330e5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
