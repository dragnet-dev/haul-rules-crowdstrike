// Dragnet [Ransomware]: dragnet-ransomware-2024-3360 — Mass File Rename (argonauts)
// Status: experimental | Level: high | ID: 58f21591-907d-538a-be72-3e77f5f3745e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
