// Dragnet [Ransomware]: dragnet-ransomware-2025-6057 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 1b2151ec-4f37-569c-85c1-9054b77a6edf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
