// Dragnet [Ransomware]: dragnet-ransomware-2025-3959 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 0841c22e-8a0c-514b-a5bf-530c0edd572a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
