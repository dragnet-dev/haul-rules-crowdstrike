// Dragnet [Ransomware]: dragnet-ransomware-2024-1152 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 77e97bbf-3eb7-503d-aa25-d557d2fc860d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
