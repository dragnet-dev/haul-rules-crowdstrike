// Dragnet [Ransomware]: dragnet-ransomware-2024-2574 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 794d594c-ccd6-5f2a-b649-c386cb5b53f3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
