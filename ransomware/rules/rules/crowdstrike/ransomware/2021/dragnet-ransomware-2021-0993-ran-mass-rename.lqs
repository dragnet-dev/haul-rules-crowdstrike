// Dragnet [Ransomware]: dragnet-ransomware-2021-0993 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 0bbe2af4-181d-5de0-ad76-e4dd0bbb4437

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
