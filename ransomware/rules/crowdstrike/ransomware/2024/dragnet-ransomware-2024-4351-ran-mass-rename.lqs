// Dragnet [Ransomware]: dragnet-ransomware-2024-4351 — Mass File Rename (rhysida)
// Status: deprecated | Level: high | ID: b1bfceb5-8d7b-55e2-b320-c73fafd63465

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
