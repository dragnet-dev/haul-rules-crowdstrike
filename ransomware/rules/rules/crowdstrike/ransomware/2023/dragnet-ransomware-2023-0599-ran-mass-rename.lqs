// Dragnet [Ransomware]: dragnet-ransomware-2023-0599 — Mass File Rename (threeam)
// Status: experimental | Level: high | ID: 9b789749-e9a3-586c-a57c-3a56a66348a7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
