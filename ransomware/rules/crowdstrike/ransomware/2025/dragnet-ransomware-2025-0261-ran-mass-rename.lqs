// Dragnet [Ransomware]: dragnet-ransomware-2025-0261 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 323d9a65-c38b-5d5f-9bae-559922b2ed54

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
