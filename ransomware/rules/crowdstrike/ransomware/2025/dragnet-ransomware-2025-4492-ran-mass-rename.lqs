// Dragnet [Ransomware]: dragnet-ransomware-2025-4492 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: 4a7f99c2-1ff8-5da2-bd68-a61e59326d2d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
