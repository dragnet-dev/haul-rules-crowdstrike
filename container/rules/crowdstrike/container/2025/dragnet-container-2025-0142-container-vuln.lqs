// Dragnet [Container]: dragnet-container-2025-0142 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: c184f2cf-ce2a-51fe-9e12-fc1eb0e76ff6

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
