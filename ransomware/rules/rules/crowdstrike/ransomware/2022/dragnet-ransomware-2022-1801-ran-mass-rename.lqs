// Dragnet [Ransomware]: dragnet-ransomware-2022-1801 — Mass File Rename (unsafe)
// Status: deprecated | Level: high | ID: d3409420-2a6c-5afe-841e-59ba785ea633

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
