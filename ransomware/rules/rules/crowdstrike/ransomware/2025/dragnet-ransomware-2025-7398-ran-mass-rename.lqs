// Dragnet [Ransomware]: dragnet-ransomware-2025-7398 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: efbcc479-8b0a-569f-8525-4ab3b70c5f69

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
