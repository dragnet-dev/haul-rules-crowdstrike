// Dragnet [Ransomware]: dragnet-ransomware-2023-4385 — Mass File Rename (metaencryptor)
// Status: experimental | Level: high | ID: 0d7a2f28-3d90-5915-bd60-d62e8dd1cbf1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
