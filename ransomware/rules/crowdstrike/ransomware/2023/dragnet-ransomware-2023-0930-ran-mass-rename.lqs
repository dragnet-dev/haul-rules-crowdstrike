// Dragnet [Ransomware]: dragnet-ransomware-2023-0930 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: b83ef14f-d34c-5566-9200-ec873c30ae33

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
