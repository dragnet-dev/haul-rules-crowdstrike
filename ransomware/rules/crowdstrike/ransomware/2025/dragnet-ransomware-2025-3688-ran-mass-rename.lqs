// Dragnet [Ransomware]: dragnet-ransomware-2025-3688 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: b8ed459b-0026-54d7-b23d-4c3af9aabeb6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
