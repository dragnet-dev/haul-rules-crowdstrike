// Dragnet [Ransomware]: dragnet-ransomware-2023-2280 — Mass File Rename (noescape)
// Status: experimental | Level: high | ID: df346176-43b3-507a-ae44-f3c67af1c470

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
