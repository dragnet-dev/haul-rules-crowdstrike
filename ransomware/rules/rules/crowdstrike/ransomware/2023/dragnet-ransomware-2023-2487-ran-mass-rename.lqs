// Dragnet [Ransomware]: dragnet-ransomware-2023-2487 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 7e3d48fb-5a10-58a7-a966-23fb52644c36

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
