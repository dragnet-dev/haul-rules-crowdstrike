// Dragnet [Ransomware]: dragnet-ransomware-2024-2933 — Mass File Rename (darkvault)
// Status: experimental | Level: high | ID: 17fd6820-2b6d-59f2-8774-8d40a7e68452

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
