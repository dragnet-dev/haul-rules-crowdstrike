// Dragnet [Ransomware]: dragnet-ransomware-2022-1044 — Mass File Rename (medusalocker)
// Status: deprecated | Level: high | ID: 4e2475aa-b955-5c6f-a4ae-c6ab8d595fb4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
