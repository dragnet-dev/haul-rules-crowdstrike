// Dragnet [Ransomware]: dragnet-ransomware-2023-2704 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 268d7012-ed35-5710-aad2-bf1acadb3a8a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
