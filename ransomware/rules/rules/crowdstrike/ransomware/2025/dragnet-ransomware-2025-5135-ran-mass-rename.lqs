// Dragnet [Ransomware]: dragnet-ransomware-2025-5135 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 7f75c729-38e2-5613-9e0d-2bd2ca54fdb8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
