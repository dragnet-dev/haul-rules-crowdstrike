// Dragnet [Ransomware]: dragnet-ransomware-2025-3132 — Mass File Rename (handala)
// Status: experimental | Level: high | ID: e8b78672-aac9-55ff-a1ec-d630bff88d96

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
