// Dragnet [Ransomware]: dragnet-ransomware-2023-2629 — Mass File Rename (raworld)
// Status: experimental | Level: high | ID: f9ee56be-b980-50ff-9d18-9d321d41559c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
