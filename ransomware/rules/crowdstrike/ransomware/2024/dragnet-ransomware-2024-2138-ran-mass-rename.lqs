// Dragnet [Ransomware]: dragnet-ransomware-2024-2138 — Mass File Rename (apt73)
// Status: experimental | Level: high | ID: a5d80d54-cff3-56f3-b0a7-3482373f4a6c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
