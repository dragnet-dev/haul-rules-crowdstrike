// Dragnet [Ransomware]: dragnet-ransomware-2024-1644 — Mass File Rename (apos)
// Status: experimental | Level: high | ID: 87d69966-3d6b-5600-8bba-936b094320ca

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
