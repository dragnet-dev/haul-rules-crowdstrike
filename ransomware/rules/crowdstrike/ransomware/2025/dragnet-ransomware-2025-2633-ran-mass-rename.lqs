// Dragnet [Ransomware]: dragnet-ransomware-2025-2633 — Mass File Rename (play)
// Status: experimental | Level: high | ID: aebced13-8195-5af7-b2c9-adb60d25a4b6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
