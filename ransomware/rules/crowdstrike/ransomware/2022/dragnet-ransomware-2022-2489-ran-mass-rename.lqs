// Dragnet [Ransomware]: dragnet-ransomware-2022-2489 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 85faacfb-cd1a-54eb-9a37-b633e2f19a29

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
