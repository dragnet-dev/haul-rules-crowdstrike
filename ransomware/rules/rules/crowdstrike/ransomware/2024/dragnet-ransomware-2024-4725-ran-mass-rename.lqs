// Dragnet [Ransomware]: dragnet-ransomware-2024-4725 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: beb2f076-7fa1-5e4e-a58c-c21f333281bc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
