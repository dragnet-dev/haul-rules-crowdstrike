// Dragnet [Ransomware]: dragnet-ransomware-2025-0039 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: f6b3527e-1323-5ca2-a6a3-7f5f7a08454c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
