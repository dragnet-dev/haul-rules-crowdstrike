// Dragnet [Ransomware]: dragnet-ransomware-2024-0298 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 563aac92-26bd-5604-bc80-0e8c7aa42959

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
