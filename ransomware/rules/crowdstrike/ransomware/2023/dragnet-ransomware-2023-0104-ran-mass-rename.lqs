// Dragnet [Ransomware]: dragnet-ransomware-2023-0104 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 9d9e97db-5310-5606-a5b3-373f2edcf95d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
