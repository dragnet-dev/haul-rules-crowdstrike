// Dragnet [Ransomware]: dragnet-ransomware-2026-0178 — Mass File Rename (rhysida)
// Status: deprecated | Level: high | ID: b96b5516-7707-5dac-b5d4-a8b9637c7875

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
