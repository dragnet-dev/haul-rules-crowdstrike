// Dragnet [Ransomware]: dragnet-ransomware-2023-0429 — Mass File Rename (darkpower)
// Status: experimental | Level: high | ID: f127f294-e7dc-533c-aaf2-52e767bfb6ca

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
