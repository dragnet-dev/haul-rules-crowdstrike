// Dragnet [Ransomware]: dragnet-ransomware-2025-1074 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: f77493da-077b-5fac-a3ac-2c6412b73898

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
