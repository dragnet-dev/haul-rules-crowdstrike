// Dragnet [Ransomware]: dragnet-ransomware-2021-1055 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: d79cc7a2-c600-59c7-862f-a1f4e5054ac2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
