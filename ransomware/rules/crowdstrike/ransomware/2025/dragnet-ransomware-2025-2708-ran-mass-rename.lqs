// Dragnet [Ransomware]: dragnet-ransomware-2025-2708 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: e69c1e54-650a-54b1-ab3e-11a5139a92b7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
