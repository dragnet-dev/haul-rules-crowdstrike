// Dragnet [Ransomware]: dragnet-ransomware-2022-1206 — Mass File Rename (cuba)
// Status: deprecated | Level: high | ID: 466cb278-7484-547f-bbd2-740b294f20de

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
