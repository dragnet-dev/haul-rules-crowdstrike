// Dragnet [Ransomware]: dragnet-ransomware-2025-6001 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: fb4193f3-d9cc-5e80-8bd9-54163ed37ccf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
