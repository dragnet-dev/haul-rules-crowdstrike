// Dragnet [Ransomware]: dragnet-ransomware-2025-2886 — Mass File Rename (medusa)
// Status: deprecated | Level: high | ID: 0ede9629-4a21-59e6-a6e2-56f2bee3a583

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
