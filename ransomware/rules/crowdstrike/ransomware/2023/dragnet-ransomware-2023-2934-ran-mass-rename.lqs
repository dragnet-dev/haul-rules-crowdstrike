// Dragnet [Ransomware]: dragnet-ransomware-2023-2934 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 54fb7cb5-85d5-5ee2-93c9-fadf6bddb2fe

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
