// Dragnet [Ransomware]: dragnet-ransomware-2022-1658 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 749f9093-734b-59eb-a46c-9c0716a21f85

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
