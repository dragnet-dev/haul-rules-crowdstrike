// Dragnet [Ransomware]: dragnet-ransomware-2025-4318 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: c3b6fb6a-6d9f-52e2-a53d-a8ec7ad9dd0e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
