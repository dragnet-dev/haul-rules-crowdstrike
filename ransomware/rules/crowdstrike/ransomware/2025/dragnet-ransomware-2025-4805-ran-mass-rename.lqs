// Dragnet [Ransomware]: dragnet-ransomware-2025-4805 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: bb38437a-eabf-5d86-8524-f82ce19c6101

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
