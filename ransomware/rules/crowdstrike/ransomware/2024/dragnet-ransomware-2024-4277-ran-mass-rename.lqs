// Dragnet [Ransomware]: dragnet-ransomware-2024-4277 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: f9133b3e-7537-52b5-bc40-29b12b5e6364

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
