// Dragnet [Ransomware]: dragnet-ransomware-2022-2183 — Mass File Rename (blackbasta)
// Status: deprecated | Level: high | ID: ca445925-0f0b-542a-9d00-5ee9db8d751c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
