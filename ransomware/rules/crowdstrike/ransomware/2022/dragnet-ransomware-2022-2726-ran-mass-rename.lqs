// Dragnet [Ransomware]: dragnet-ransomware-2022-2726 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: ea4c04ff-9d0e-5263-99b6-20dc90b484bf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
