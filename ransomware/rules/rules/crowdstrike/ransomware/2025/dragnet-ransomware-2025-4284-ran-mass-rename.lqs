// Dragnet [Ransomware]: dragnet-ransomware-2025-4284 — Mass File Rename (crypto24)
// Status: deprecated | Level: high | ID: 55d768a7-1270-5baf-85c0-8ca1e3c8d11f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
