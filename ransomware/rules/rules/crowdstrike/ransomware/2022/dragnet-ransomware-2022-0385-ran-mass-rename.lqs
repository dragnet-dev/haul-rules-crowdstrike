// Dragnet [Ransomware]: dragnet-ransomware-2022-0385 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 75336a7f-a265-5ec6-b294-023e3195c8d3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
