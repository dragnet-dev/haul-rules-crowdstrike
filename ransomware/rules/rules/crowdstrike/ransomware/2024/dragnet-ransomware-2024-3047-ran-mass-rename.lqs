// Dragnet [Ransomware]: dragnet-ransomware-2024-3047 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: c2ea85ee-2faa-5213-a27f-5a56c1db2e95

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
