// Dragnet [Ransomware]: dragnet-ransomware-2026-1017 — Mass File Rename (thegentlemen)
// Status: test | Level: high | ID: f8f55ebb-f14f-5b02-bd8e-25bcfb63e10e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
