// Dragnet [Ransomware]: dragnet-ransomware-2021-1743 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: f0aba7f6-5592-5d52-8362-48429c6fe2e4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
