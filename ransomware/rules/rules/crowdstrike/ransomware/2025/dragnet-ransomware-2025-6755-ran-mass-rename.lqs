// Dragnet [Ransomware]: dragnet-ransomware-2025-6755 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 7319193e-4fb8-52bb-92ad-8fd97a051338

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
