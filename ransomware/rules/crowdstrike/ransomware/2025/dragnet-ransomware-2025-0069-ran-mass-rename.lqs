// Dragnet [Ransomware]: dragnet-ransomware-2025-0069 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: ead0dd6d-1b62-55be-bda9-2e7be9bd4164

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
