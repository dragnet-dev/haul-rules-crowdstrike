// Dragnet [Ransomware]: dragnet-ransomware-2020-0236 — Mass File Rename (ragnarlocker)
// Status: deprecated | Level: high | ID: bc9af1d9-a4c1-546e-8768-f8cd79eecad9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
