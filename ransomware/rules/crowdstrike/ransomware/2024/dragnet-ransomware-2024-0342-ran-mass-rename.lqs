// Dragnet [Ransomware]: dragnet-ransomware-2024-0342 — Mass File Rename (rhysida)
// Status: deprecated | Level: high | ID: 1e6c0b1a-70ac-5d77-b6b6-a416d1973e6b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
