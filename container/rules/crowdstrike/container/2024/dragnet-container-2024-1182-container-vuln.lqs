// Dragnet [Container]: dragnet-container-2024-1182 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: c99d3e3b-4b95-5cc0-b6f1-d244621d6284

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:9* OR ImageFileName = *redhat/ubi9:*)
| table([timestamp, ComputerName])
| limit(1000)
