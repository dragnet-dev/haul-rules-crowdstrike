// Dragnet [Ransomware]: dragnet-ransomware-2021-0065 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: cbd0240e-0571-58cf-9166-01ec8fd0a3ad

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
