// Dragnet [Ransomware]: dragnet-ransomware-2022-0342 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 103ebe61-0e6b-5788-b037-a87302e252bb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
