// Dragnet [Ransomware]: dragnet-ransomware-2022-1644 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 68f25852-4f8a-578c-aa18-d4ec168bedd9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
