// Dragnet [Ransomware]: dragnet-ransomware-2025-5930 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: b835a9fc-a594-529b-ba8d-002592159058

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
