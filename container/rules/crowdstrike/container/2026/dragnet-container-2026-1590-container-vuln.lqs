// Dragnet [Container]: dragnet-container-2026-1590 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: e45c455b-8082-5635-94bb-9f5ae5146471

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:7* OR ImageFileName = *debian:8*)
| table([timestamp, ComputerName])
| limit(1000)
