// Dragnet [Ransomware]: dragnet-ransomware-2024-4224 — Mass File Rename (meow)
// Status: experimental | Level: high | ID: 7d03bd71-e757-53c3-aeb4-ab2ae7e3cfe6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
