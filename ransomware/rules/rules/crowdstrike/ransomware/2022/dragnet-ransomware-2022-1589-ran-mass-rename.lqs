// Dragnet [Ransomware]: dragnet-ransomware-2022-1589 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 313487dd-3c26-58f5-93f5-c386227858c1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
