// Dragnet [Ransomware]: dragnet-ransomware-2024-2168 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 45be0c57-77fa-503b-a68d-89c0a9bb0e23

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
