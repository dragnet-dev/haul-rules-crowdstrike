// Dragnet [Ransomware]: dragnet-ransomware-2026-2093 — Mass File Rename (dragonforce)
// Status: stable | Level: high | ID: 516753ea-0eb2-52e5-b200-46bfab95e200

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
