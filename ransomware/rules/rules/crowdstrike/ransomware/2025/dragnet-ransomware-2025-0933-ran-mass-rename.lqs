// Dragnet [Ransomware]: dragnet-ransomware-2025-0933 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 9b9d7354-303b-5644-b394-4019fc466367

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
