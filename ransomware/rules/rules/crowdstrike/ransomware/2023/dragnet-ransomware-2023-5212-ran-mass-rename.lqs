// Dragnet [Ransomware]: dragnet-ransomware-2023-5212 — Mass File Rename (play)
// Status: experimental | Level: high | ID: b7e1f931-46d6-5fa5-bcc6-ea217bf73082

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
