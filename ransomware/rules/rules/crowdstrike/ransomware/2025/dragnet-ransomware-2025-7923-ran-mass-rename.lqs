// Dragnet [Ransomware]: dragnet-ransomware-2025-7923 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: 6fca72c7-af93-5318-9fcb-62124e0c9c1b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
