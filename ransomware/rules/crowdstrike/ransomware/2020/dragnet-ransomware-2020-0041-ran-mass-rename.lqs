// Dragnet [Ransomware]: dragnet-ransomware-2020-0041 — Mass File Rename (maze)
// Status: deprecated | Level: high | ID: e61eaadc-d894-58d3-90a6-af51ed311141

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
