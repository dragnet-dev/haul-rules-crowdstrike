// Dragnet [Ransomware]: dragnet-ransomware-2021-1362 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: fd53c0bf-e855-5c32-ad97-0fbd7c391836

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
