// Dragnet [Container]: dragnet-container-2024-0019 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 35eb7dd2-29ce-551b-be24-5e99a669c029

#event_simpleName=*
| (ImageFileName = *ubuntu:14.04* OR ImageFileName = *ubuntu:16.04* OR ImageFileName = *ubuntu:16.04-ESM* OR ImageFileName = *ubuntu:18.04* OR ImageFileName = *ubuntu:18.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
