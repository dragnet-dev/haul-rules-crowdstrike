// Dragnet [Container]: dragnet-container-2025-0031 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: c784d0ef-749a-5aeb-84a5-b2af0ec3c36a

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
