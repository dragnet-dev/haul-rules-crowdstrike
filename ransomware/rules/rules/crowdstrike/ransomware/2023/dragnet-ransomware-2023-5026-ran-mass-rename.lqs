// Dragnet [Ransomware]: dragnet-ransomware-2023-5026 — Mass File Rename (noescape)
// Status: experimental | Level: high | ID: 6305bc18-a6cd-5716-9a85-274a2ec7bc0e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
