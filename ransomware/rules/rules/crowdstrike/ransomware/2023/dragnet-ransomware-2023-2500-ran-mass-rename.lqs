// Dragnet [Ransomware]: dragnet-ransomware-2023-2500 — Mass File Rename (werewolves)
// Status: experimental | Level: high | ID: 10aae31c-2998-533d-9ad0-5d3c3e0e3651

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
