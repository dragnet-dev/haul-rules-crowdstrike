// Dragnet [Ransomware]: dragnet-ransomware-2023-0752 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 854ee448-a0fb-5fbe-b54a-56eae18f83fd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
