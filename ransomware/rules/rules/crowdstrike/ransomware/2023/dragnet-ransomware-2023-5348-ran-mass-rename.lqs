// Dragnet [Ransomware]: dragnet-ransomware-2023-5348 — Mass File Rename (meow)
// Status: experimental | Level: high | ID: 25364441-4e89-573d-81cd-41dd9395fcd0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
