// Dragnet [Ransomware]: dragnet-ransomware-2025-6977 — Mass File Rename (securotrop)
// Status: experimental | Level: high | ID: c6f2a352-a004-58d0-8e4a-a41a3d5a4c50

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
