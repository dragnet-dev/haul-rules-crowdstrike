// Dragnet [Ransomware]: dragnet-ransomware-2026-0667 — Mass File Rename (sicarii)
// Status: deprecated | Level: high | ID: 1f8c5d7e-f3e1-5a0a-84ba-43e4ac64d60c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
