// Dragnet [Ransomware]: dragnet-ransomware-2022-0904 — Mass File Rename (lv)
// Status: deprecated | Level: high | ID: 0f2f1505-91c4-587f-ae1d-67ba6e191446

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
