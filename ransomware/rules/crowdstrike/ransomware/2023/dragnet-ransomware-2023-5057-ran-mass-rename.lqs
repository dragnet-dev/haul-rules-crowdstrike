// Dragnet [Ransomware]: dragnet-ransomware-2023-5057 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 3104d183-e80e-5747-ad6f-d086c4fa035f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
