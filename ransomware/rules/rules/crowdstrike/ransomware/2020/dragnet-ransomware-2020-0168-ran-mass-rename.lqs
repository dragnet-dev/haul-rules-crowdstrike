// Dragnet [Ransomware]: dragnet-ransomware-2020-0168 — Mass File Rename (maze)
// Status: deprecated | Level: high | ID: 416df1f2-c659-5190-8001-11f441fce9b1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
