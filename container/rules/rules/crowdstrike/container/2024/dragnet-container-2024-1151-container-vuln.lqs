// Dragnet [Container]: dragnet-container-2024-1151 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 56ef0fea-d1ba-56a2-846f-088283a9dc67

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:7* OR ImageFileName = *debian:8* OR ImageFileName = *debian:9* OR ImageFileName = *ubuntu:14.04* OR ImageFileName = *ubuntu:14.04-ESM* OR ImageFileName = *ubuntu:16.04* OR ImageFileName = *ubuntu:16.04-ESM* OR ImageFileName = *ubuntu:17.04*)
| table([timestamp, ComputerName])
| limit(1000)
