// Dragnet [Ransomware]: dragnet-ransomware-2024-2873 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: e611bfbf-f3e5-51a8-89ed-f9c7aba1377e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
