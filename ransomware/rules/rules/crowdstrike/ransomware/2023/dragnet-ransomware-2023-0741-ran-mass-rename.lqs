// Dragnet [Ransomware]: dragnet-ransomware-2023-0741 — Mass File Rename (siegedsec)
// Status: deprecated | Level: high | ID: 20258785-8ed5-5d91-85c0-cb000d0f8f4d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
