// Dragnet [Ransomware]: dragnet-ransomware-2022-1005 — Mass File Rename (midas)
// Status: deprecated | Level: high | ID: 03248bb7-f77f-5088-86d1-01398068fa46

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
