// Dragnet [Ransomware]: dragnet-ransomware-2024-4293 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 12aa025b-bffb-527b-8d42-2e7e7c10e73b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
