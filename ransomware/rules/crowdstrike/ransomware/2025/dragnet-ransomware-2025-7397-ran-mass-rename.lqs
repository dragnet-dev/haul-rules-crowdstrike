// Dragnet [Ransomware]: dragnet-ransomware-2025-7397 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 4979fad2-307d-5cfc-b2e3-438d7e206b48

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
