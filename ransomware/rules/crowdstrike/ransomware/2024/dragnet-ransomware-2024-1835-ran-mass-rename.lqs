// Dragnet [Ransomware]: dragnet-ransomware-2024-1835 — Mass File Rename (ElDorado)
// Status: deprecated | Level: high | ID: ebe34c73-bb2e-5cd0-87cb-4e71110458e7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
