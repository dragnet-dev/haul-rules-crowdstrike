// Dragnet [Ransomware]: dragnet-ransomware-2025-0690 — Mass File Rename (weyhro)
// Status: experimental | Level: high | ID: cc2edb99-84db-5436-982c-88432ea73c6f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
