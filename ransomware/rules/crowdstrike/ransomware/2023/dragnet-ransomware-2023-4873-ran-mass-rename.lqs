// Dragnet [Ransomware]: dragnet-ransomware-2023-4873 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: ee77c5e1-8a64-5bf8-bb7b-dc7b5424641b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
