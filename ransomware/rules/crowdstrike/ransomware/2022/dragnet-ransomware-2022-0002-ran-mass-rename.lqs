// Dragnet [Ransomware]: dragnet-ransomware-2022-0002 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: c9beb818-d2fb-55e3-a0c4-c0dcabffc202

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
