// Dragnet [Ransomware]: dragnet-ransomware-2025-7402 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 2ab7d431-6f8e-57af-bb49-c82c57cb7a8c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
