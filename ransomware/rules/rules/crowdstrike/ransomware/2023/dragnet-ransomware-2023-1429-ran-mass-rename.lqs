// Dragnet [Ransomware]: dragnet-ransomware-2023-1429 — Mass File Rename (metaencryptor)
// Status: experimental | Level: high | ID: 149ee317-b0d7-5ddf-8e81-dcef10775e3b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
