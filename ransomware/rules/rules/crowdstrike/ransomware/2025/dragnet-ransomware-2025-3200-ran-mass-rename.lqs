// Dragnet [Ransomware]: dragnet-ransomware-2025-3200 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: 7eae4df1-0c09-50c0-9a11-7a45fc00c22e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
