// Dragnet [Ransomware]: dragnet-ransomware-2022-1424 — Mass File Rename (stormous)
// Status: deprecated | Level: high | ID: c01c6da4-df83-5a94-b062-6aff08f3a1d5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
