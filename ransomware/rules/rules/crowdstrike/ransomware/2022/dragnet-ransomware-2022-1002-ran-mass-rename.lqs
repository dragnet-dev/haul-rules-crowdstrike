// Dragnet [Ransomware]: dragnet-ransomware-2022-1002 — Mass File Rename (blackbasta)
// Status: deprecated | Level: high | ID: 07edab9a-0217-5200-88af-fa427371e3df

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
