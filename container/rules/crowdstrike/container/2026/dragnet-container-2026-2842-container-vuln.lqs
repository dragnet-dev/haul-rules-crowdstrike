// Dragnet [Container]: dragnet-container-2026-2842 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 7ff20654-8eba-5b9d-ad32-c247aa33cfa8

#event_simpleName=*
| (ImageFileName = *debian:7* OR ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10* OR ImageFileName = *ubuntu:13.04*)
| table([timestamp, ComputerName])
| limit(1000)
