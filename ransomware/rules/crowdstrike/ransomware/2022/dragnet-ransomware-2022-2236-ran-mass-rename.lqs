// Dragnet [Ransomware]: dragnet-ransomware-2022-2236 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 8d12ad38-6781-59e8-9c33-dd888b5ef99d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
