// Dragnet [Ransomware]: dragnet-ransomware-2022-0733 — Mass File Rename (suncrypt)
// Status: deprecated | Level: high | ID: 5bdd0cdd-c4a2-5cd6-a678-33faa3a548c8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
