// Dragnet [Ransomware]: dragnet-ransomware-2025-1158 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: 76f0b4a6-09ba-5289-adaa-26632bfb1c78

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
