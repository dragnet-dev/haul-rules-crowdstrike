// Dragnet [Ransomware]: dragnet-ransomware-2025-4296 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 642d6f4c-2d60-53e7-bd7d-f720964ec711

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
