// Dragnet [Ransomware]: dragnet-ransomware-2025-2125 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: a0bfecee-d2b0-5b3e-9611-9beea063b8f0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
