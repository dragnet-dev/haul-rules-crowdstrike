// Dragnet [Ransomware]: dragnet-ransomware-2024-1310 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 531fe82a-9c6d-5d62-a039-aa460b5cc4b2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
