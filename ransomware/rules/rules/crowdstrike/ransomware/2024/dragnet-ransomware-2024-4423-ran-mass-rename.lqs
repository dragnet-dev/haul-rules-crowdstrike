// Dragnet [Ransomware]: dragnet-ransomware-2024-4423 — Mass File Rename (raworld)
// Status: experimental | Level: high | ID: 6b5b07f2-d85b-5502-bd70-47945f6a3577

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
