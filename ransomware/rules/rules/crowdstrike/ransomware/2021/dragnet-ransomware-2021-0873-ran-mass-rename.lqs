// Dragnet [Ransomware]: dragnet-ransomware-2021-0873 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: b2e0e4ce-b612-54dc-8e57-6667691900d0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
