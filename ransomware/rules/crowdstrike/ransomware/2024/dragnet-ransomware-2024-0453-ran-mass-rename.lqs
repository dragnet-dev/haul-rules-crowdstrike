// Dragnet [Ransomware]: dragnet-ransomware-2024-0453 — Mass File Rename (ransomhouse)
// Status: experimental | Level: high | ID: c9803288-18e3-5639-9f75-4b5fe4ab674a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
