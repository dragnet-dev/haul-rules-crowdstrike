// Dragnet [Ransomware]: dragnet-ransomware-2024-5007 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 9ef631b1-d389-57cb-9c08-71f47dd98fd5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
