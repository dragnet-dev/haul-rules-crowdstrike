// Dragnet [Ransomware]: dragnet-ransomware-2024-5577 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 12d0b1da-137d-54b7-b635-1bb13faf5cbe

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
