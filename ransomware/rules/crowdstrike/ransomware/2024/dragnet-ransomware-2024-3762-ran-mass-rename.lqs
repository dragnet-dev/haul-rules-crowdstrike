// Dragnet [Ransomware]: dragnet-ransomware-2024-3762 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: c7380c4a-4c7c-5628-b79d-47ca328a7aa1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
