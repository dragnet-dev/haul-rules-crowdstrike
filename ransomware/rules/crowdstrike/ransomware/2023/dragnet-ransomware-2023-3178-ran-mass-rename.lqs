// Dragnet [Ransomware]: dragnet-ransomware-2023-3178 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: fe941bf9-8091-561d-abae-a065e0138fb2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
