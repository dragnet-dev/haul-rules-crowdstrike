// Dragnet [Ransomware]: dragnet-ransomware-2022-0017 — Mass File Rename (royal)
// Status: deprecated | Level: high | ID: 65af8b13-2885-50f9-aa51-4d102e4f1141

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
