// Dragnet [Ransomware]: dragnet-ransomware-2021-0911 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: ba90fb25-4b2a-5e00-b75c-c6f533a9d6ae

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
