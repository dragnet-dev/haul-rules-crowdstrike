// Dragnet [Ransomware]: dragnet-ransomware-2024-4904 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: cb7fdbc3-6376-52df-8cc9-7728bb238b3e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
