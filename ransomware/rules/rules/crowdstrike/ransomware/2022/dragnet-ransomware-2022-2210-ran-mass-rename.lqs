// Dragnet [Ransomware]: dragnet-ransomware-2022-2210 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 27e89217-3d3c-50f1-9e7d-40501cabbde3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
