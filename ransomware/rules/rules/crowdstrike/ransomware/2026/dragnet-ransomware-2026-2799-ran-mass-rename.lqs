// Dragnet [Ransomware]: dragnet-ransomware-2026-2799 — Mass File Rename (lockbit5)
// Status: stable | Level: high | ID: e679bf85-0949-50be-839c-559ff1b070e3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
