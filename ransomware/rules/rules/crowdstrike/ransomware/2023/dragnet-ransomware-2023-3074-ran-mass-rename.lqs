// Dragnet [Ransomware]: dragnet-ransomware-2023-3074 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 036d47ae-6c56-58d9-bfb3-34ff32ea86d0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
