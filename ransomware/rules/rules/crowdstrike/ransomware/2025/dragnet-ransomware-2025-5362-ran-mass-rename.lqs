// Dragnet [Ransomware]: dragnet-ransomware-2025-5362 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 1c9591cc-ec5d-5f8c-8dc0-afb987aac197

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
