// Dragnet [Ransomware]: dragnet-ransomware-2025-3385 — Mass File Rename (coinbasecartel)
// Status: experimental | Level: high | ID: 7df35ae7-18ee-5e0d-8c04-77c4d361cf2b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
