// Dragnet [Ransomware]: dragnet-ransomware-2023-4885 — Mass File Rename (cyclops)
// Status: deprecated | Level: high | ID: 4ab3a501-b8ab-50fd-98b6-238a4903d1a2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
