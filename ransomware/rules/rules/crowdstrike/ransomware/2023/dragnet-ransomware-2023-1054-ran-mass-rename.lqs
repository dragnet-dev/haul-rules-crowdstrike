// Dragnet [Ransomware]: dragnet-ransomware-2023-1054 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 1c95b4f5-dfba-5619-8084-acb23adcea2f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
