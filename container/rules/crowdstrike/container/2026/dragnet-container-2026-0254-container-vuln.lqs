// Dragnet [Container]: dragnet-container-2026-0254 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 71bf9909-3519-5000-83fe-3e9692389c06

#event_simpleName=*
| (ImageFileName = *alpine edge:* OR ImageFileName = *chainguard:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
