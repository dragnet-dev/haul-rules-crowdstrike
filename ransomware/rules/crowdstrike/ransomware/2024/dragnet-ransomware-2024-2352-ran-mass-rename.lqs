// Dragnet [Ransomware]: dragnet-ransomware-2024-2352 — Mass File Rename (SilentRansomGroup)
// Status: deprecated | Level: high | ID: 749be2c6-f206-5551-b28f-95873a0a2684

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
