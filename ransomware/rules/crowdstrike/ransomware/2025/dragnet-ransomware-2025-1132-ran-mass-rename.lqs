// Dragnet [Ransomware]: dragnet-ransomware-2025-1132 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: 8478916d-9d4a-5ec5-b8bd-e7f2f1a98ea1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
