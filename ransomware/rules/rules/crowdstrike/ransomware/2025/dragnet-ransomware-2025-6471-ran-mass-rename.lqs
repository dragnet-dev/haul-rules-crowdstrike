// Dragnet [Ransomware]: dragnet-ransomware-2025-6471 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 24758462-d8f4-53cf-9433-1a4b74e67682

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
