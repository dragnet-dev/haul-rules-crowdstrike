// Dragnet [Ransomware]: dragnet-ransomware-2022-1501 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: b6bdaae4-97b5-5da6-a32e-cca2cdecb6fd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
