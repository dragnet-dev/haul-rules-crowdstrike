// Dragnet [Ransomware]: dragnet-ransomware-2023-1039 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: 79034bc1-17c2-5fce-854b-45c3925ba8c4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
