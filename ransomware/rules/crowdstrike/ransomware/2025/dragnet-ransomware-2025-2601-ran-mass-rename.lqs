// Dragnet [Ransomware]: dragnet-ransomware-2025-2601 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 1c25135c-b9d9-5bb9-a9e2-32d90a4eca9e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
