// Dragnet [Ransomware]: dragnet-ransomware-2023-3608 — Mass File Rename (ragnarlocker)
// Status: experimental | Level: high | ID: 71a49d1c-34ad-58bd-abca-6271725beb82

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
