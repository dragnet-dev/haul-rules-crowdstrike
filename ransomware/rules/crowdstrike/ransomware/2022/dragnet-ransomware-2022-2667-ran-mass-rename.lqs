// Dragnet [Ransomware]: dragnet-ransomware-2022-2667 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: 1ade6096-2ce5-56f3-acb2-f25e5c712c68

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
