// Dragnet [Ransomware]: dragnet-ransomware-2024-1994 — Mass File Rename (dragonransomware)
// Status: experimental | Level: high | ID: 4053ea89-380f-5787-977c-e3aecf67f51f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
