// Dragnet [Container]: dragnet-container-2026-1722 — Vulnerable Base Image Pull
// Status: deprecated | Level: medium | ID: 988dc855-c05e-5fbc-b26b-4d12ce9e41ce

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:7* OR ImageFileName = *ubuntu:14.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
