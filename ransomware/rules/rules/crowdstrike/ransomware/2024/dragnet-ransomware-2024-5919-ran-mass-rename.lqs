// Dragnet [Ransomware]: dragnet-ransomware-2024-5919 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 912aa02a-5ef1-5acf-8304-dc492c9b8976

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
