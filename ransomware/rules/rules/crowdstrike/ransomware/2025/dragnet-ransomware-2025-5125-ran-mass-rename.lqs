// Dragnet [Ransomware]: dragnet-ransomware-2025-5125 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 4ad365ae-c810-522a-994a-5e3a111dce66

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
