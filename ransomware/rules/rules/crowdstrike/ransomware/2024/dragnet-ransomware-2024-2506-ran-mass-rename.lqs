// Dragnet [Ransomware]: dragnet-ransomware-2024-2506 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: c3249796-e74c-5d3c-87a6-c6f513a85cef

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
