// Dragnet [Ransomware]: dragnet-ransomware-2023-1667 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 268f2a24-7cb4-59c2-9bc0-76af15bdf4b3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
