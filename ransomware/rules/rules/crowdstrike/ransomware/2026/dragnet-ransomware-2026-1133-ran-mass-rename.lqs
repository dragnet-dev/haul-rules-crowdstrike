// Dragnet [Ransomware]: dragnet-ransomware-2026-1133 — Mass File Rename (thegentlemen)
// Status: stable | Level: high | ID: 1d11d440-8132-50a7-a7ae-754a78cd3a23

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
