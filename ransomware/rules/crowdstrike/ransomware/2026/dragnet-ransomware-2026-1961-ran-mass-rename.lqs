// Dragnet [Ransomware]: dragnet-ransomware-2026-1961 — Mass File Rename (shinyhunters)
// Status: deprecated | Level: high | ID: 95b19cae-5cf9-530d-b63b-98f24c8f51f0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
