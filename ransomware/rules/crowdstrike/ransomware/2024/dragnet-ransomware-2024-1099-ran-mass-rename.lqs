// Dragnet [Ransomware]: dragnet-ransomware-2024-1099 — Mass File Rename (blacklock)
// Status: experimental | Level: high | ID: a9025271-7c6d-5d1a-8bd8-060bdcb281a1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
