// Dragnet [Ransomware]: dragnet-ransomware-2022-2938 — Mass File Rename (karakurt)
// Status: experimental | Level: high | ID: 7e39bb1f-8b27-5442-96b0-495906d85597

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
