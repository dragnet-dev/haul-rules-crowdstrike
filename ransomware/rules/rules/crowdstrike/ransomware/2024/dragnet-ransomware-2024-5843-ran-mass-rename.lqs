// Dragnet [Ransomware]: dragnet-ransomware-2024-5843 — Mass File Rename (frag)
// Status: deprecated | Level: high | ID: c52ffb9a-d2c6-59b5-9df3-6d19de917383

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
