// Dragnet [Ransomware]: dragnet-ransomware-2022-1545 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 6e6c3d4a-b9db-5415-ad8f-91dccc99f87f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
