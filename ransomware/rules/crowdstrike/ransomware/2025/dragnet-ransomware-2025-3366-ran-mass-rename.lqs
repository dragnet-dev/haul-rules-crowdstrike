// Dragnet [Ransomware]: dragnet-ransomware-2025-3366 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: b3a8dffb-7b45-5c8f-a69b-91f300e77a57

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
