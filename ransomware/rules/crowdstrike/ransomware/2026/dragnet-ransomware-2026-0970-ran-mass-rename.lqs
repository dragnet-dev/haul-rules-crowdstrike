// Dragnet [Ransomware]: dragnet-ransomware-2026-0970 — Mass File Rename (incransom)
// Status: test | Level: high | ID: 6701aeac-ba18-58f1-9a4b-d595faf2270a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
