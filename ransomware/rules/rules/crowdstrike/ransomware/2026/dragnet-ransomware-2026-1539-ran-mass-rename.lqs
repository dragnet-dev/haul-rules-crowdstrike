// Dragnet [Ransomware]: dragnet-ransomware-2026-1539 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 972b4a34-d0f4-5ed1-9a80-b530bb42be34

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
