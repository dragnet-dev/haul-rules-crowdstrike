// Dragnet [Ransomware]: dragnet-ransomware-2024-4564 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: ab1b6c04-bf0b-56dc-9f10-0b19cafdf149

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
