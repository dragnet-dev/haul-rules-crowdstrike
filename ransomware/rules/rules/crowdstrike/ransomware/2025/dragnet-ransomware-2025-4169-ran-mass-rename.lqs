// Dragnet [Ransomware]: dragnet-ransomware-2025-4169 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: a487bb98-7753-5563-b20d-1670ec80123f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
