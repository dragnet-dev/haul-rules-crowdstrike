// Dragnet [Ransomware]: dragnet-ransomware-2022-1700 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 8be424c5-9854-579c-b2eb-420180ddd794

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
