// Dragnet [Ransomware]: dragnet-ransomware-2025-1190 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 6f74518d-967a-5702-8cbd-671916707a1b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
