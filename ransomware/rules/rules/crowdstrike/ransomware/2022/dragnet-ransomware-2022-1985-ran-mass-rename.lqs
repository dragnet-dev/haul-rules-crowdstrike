// Dragnet [Ransomware]: dragnet-ransomware-2022-1985 — Mass File Rename (karakurt)
// Status: experimental | Level: high | ID: 9ac3dff6-ff9c-5072-94bc-5c6147754b66

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
