// Dragnet [Ransomware]: dragnet-ransomware-2024-0834 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 9634f6ef-fc27-5919-b6e3-b3bfab7ace20

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
