// Dragnet [Ransomware]: dragnet-ransomware-2023-1984 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 525ad5b6-e5ac-5592-bb76-76abe34d00df

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
