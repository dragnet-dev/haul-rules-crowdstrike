// Dragnet [Ransomware]: dragnet-ransomware-2024-1048 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 9d0cf95c-608c-5dfd-83d9-dc8142f6ab34

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
