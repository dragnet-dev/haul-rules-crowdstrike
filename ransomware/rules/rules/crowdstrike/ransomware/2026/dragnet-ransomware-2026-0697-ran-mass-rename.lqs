// Dragnet [Ransomware]: dragnet-ransomware-2026-0697 — Mass File Rename (incransom)
// Status: stable | Level: high | ID: 1691aacf-63e6-585d-9098-9c18db9a8fe9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
