// Dragnet [Ransomware]: dragnet-ransomware-2023-3734 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 9f700d79-a825-5aeb-93c9-3bbe03c8d7ea

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
