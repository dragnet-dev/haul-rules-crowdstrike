// Dragnet [Ransomware]: dragnet-ransomware-2025-0534 — Mass File Rename (ciphbit)
// Status: deprecated | Level: high | ID: 61c18e66-96d4-59c2-a9fe-2e9385369e94

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
