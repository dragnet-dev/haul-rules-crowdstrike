// Dragnet [Ransomware]: dragnet-ransomware-2021-1485 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 58b7b6c5-4ae4-56d8-b19e-1e15ced39484

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
