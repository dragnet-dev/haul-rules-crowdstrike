// Dragnet [Ransomware]: dragnet-ransomware-2023-3383 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 2657b069-885a-57db-8bb8-39784cfb773a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
