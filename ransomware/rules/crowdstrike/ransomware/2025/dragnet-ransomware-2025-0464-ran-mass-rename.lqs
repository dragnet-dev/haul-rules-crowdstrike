// Dragnet [Ransomware]: dragnet-ransomware-2025-0464 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 3e248bb9-c0f3-527d-bed0-9eab61c187b5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
