// Dragnet [Ransomware]: dragnet-ransomware-2020-0031 — Mass File Rename (agelocker)
// Status: deprecated | Level: high | ID: 34c0d22e-2342-579f-9a52-2d721f915ddf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
