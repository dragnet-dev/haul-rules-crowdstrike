// Dragnet [Ransomware]: dragnet-ransomware-2025-2403 — Mass File Rename (thegentlemen)
// Status: experimental | Level: high | ID: cd9e38a0-849c-5977-adb9-15d94d0d7ffa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
