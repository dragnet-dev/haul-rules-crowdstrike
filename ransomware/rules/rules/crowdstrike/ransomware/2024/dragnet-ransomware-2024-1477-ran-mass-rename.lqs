// Dragnet [Ransomware]: dragnet-ransomware-2024-1477 — Mass File Rename (meow)
// Status: experimental | Level: high | ID: c32ed3d5-7376-5ffb-8c5d-16843304825a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
