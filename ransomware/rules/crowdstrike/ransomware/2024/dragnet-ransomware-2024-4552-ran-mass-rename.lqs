// Dragnet [Ransomware]: dragnet-ransomware-2024-4552 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: c4e3d6ef-b260-530f-8e93-95093efa2800

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
