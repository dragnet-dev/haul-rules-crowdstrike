// Dragnet [Ransomware]: dragnet-ransomware-2021-0891 — Mass File Rename (avaddon)
// Status: deprecated | Level: high | ID: 30de6f73-1740-5875-9cbd-586e21b2e5cf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
