// Dragnet [Ransomware]: dragnet-ransomware-2025-2951 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: c3502f6d-0795-55a3-890b-17a021c08557

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
