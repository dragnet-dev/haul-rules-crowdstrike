// Dragnet [Container]: dragnet-container-2024-1138 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: c95d271a-3aba-512b-b3c7-9c807b5654f4

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:9* OR ImageFileName = *ubuntu:18.04*)
| table([timestamp, ComputerName])
| limit(1000)
