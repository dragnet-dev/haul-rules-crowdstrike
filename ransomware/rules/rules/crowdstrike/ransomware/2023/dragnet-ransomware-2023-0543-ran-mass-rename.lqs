// Dragnet [Ransomware]: dragnet-ransomware-2023-0543 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: c3316894-864f-5b28-8ee0-0e4b9166f90f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
