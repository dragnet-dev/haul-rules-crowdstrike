// Dragnet [Ransomware]: dragnet-ransomware-2023-3921 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 96cbddab-405f-5a40-9e7d-d2e10f232a75

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
