// Dragnet [Ransomware]: dragnet-ransomware-2024-5033 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 2f9839b1-98d4-544b-8410-d2fe26160673

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
