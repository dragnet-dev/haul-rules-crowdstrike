// Dragnet [Ransomware]: dragnet-ransomware-2024-1876 — Mass File Rename (arcusmedia)
// Status: experimental | Level: high | ID: d90501fa-b6d1-5da9-94fb-878caada8cc8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
