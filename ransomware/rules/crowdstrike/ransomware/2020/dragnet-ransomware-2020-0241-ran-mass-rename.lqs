// Dragnet [Ransomware]: dragnet-ransomware-2020-0241 — Mass File Rename (nefilim)
// Status: deprecated | Level: high | ID: 31445dbd-43f0-51d1-97bb-ef67721341af

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
