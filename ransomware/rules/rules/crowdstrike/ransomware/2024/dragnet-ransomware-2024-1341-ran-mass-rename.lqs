// Dragnet [Ransomware]: dragnet-ransomware-2024-1341 — Mass File Rename (meow)
// Status: experimental | Level: high | ID: f799e28e-896f-5ad9-a37c-32e620b9283e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
