// Dragnet [Ransomware]: dragnet-ransomware-2020-0035 — Mass File Rename (revil)
// Status: deprecated | Level: high | ID: dc47e3a7-bffa-5df3-b5b0-de448d66dd96

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
