// Dragnet [Ransomware]: dragnet-ransomware-2025-1461 — Mass File Rename (incransom)
// Status: test | Level: high | ID: 8ecee835-1c5f-5f3c-abc5-c1b13682a88e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
