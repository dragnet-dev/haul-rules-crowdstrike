// Dragnet [Ransomware]: dragnet-ransomware-2022-3024 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: fb3016f6-1106-5a8d-a071-8ea3a56665c0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
