// Dragnet [Container]: dragnet-container-2026-1652 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 4bcfa4da-5540-5706-9056-43ea663fadae

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:5*)
| table([timestamp, ComputerName])
| limit(1000)
