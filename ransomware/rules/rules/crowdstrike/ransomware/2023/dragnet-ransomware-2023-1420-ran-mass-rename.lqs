// Dragnet [Ransomware]: dragnet-ransomware-2023-1420 — Mass File Rename (medusalocker)
// Status: experimental | Level: high | ID: 8fb2ea43-c2b4-5f58-be48-115f9f79a4c1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
