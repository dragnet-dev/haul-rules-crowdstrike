// Dragnet [Ransomware]: dragnet-ransomware-2024-4178 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 50f5c509-2595-58cd-a5ca-833d356726bd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
