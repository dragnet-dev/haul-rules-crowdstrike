// Dragnet [Ransomware]: dragnet-ransomware-2023-3444 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 47c9a994-804f-5168-ad54-18a093d2aeac

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
