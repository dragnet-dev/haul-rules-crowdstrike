// Dragnet [Ransomware]: dragnet-ransomware-2021-0883 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: d09b32cf-0f6d-5df9-90a9-ac7e12ab60c7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
