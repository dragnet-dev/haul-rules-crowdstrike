// Dragnet [Ransomware]: dragnet-ransomware-2021-1588 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: d6c662a4-7293-5b72-a01b-3b19e4779ebf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
