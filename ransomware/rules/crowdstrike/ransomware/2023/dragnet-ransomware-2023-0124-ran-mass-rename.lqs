// Dragnet [Ransomware]: dragnet-ransomware-2023-0124 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 5b18ca71-b963-5021-b3ec-462646167591

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
