// Dragnet [Ransomware]: dragnet-ransomware-2025-6134 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: b8e16bbb-ab56-5398-8d16-b083427d9d7e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
