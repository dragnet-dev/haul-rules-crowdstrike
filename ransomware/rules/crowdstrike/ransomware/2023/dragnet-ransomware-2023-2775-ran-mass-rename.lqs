// Dragnet [Ransomware]: dragnet-ransomware-2023-2775 — Mass File Rename (malas)
// Status: experimental | Level: high | ID: 9d308090-3edf-5371-a70e-494b8a8d66c6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
