// Dragnet [Ransomware]: dragnet-ransomware-2026-0220 — Mass File Rename (dragonforce)
// Status: stable | Level: high | ID: dab8ec93-d7e5-5eb4-8687-802f02f49811

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
