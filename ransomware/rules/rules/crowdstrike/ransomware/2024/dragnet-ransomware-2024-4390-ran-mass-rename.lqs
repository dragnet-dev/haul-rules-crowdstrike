// Dragnet [Ransomware]: dragnet-ransomware-2024-4390 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 57b5f20d-936b-5260-98f3-46e711c9f447

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
