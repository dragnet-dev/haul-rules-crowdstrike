// Dragnet [Ransomware]: dragnet-ransomware-2025-3905 — Mass File Rename (flocker)
// Status: experimental | Level: high | ID: c1f96c6b-4940-5caf-ade0-04e35b81bf82

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
