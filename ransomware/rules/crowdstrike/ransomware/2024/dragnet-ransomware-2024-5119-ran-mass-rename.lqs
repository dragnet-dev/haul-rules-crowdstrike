// Dragnet [Ransomware]: dragnet-ransomware-2024-5119 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 5bb4b57a-2e98-503f-a4e5-37d91fcecc96

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
