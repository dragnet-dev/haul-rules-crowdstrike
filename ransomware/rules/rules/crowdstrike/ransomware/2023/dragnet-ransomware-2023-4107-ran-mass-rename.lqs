// Dragnet [Ransomware]: dragnet-ransomware-2023-4107 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 5fbd15a3-4939-5d13-91da-0a0598ea9487

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
