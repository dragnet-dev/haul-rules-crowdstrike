// Dragnet [Ransomware]: dragnet-ransomware-2025-3134 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: d3e47f71-69fd-5c20-bc16-bb7aa0d1ad97

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
