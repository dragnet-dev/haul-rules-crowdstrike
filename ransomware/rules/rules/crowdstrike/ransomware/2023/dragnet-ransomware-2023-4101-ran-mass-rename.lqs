// Dragnet [Ransomware]: dragnet-ransomware-2023-4101 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 083fcb74-ac56-50e3-ac1e-bcc8fe3cb4b9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
