// Dragnet [Ransomware]: dragnet-ransomware-2022-1576 — Mass File Rename (blackbasta)
// Status: deprecated | Level: high | ID: bdd55ef2-8ac0-5110-8fff-a4e5df1766d4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
