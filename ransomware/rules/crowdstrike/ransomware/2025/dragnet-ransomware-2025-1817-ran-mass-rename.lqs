// Dragnet [Ransomware]: dragnet-ransomware-2025-1817 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 96be132a-07be-567f-8843-95288ead194c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
