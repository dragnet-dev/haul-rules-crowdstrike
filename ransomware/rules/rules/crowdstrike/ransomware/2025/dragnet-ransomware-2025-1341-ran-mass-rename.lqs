// Dragnet [Ransomware]: dragnet-ransomware-2025-1341 — Mass File Rename (sinobi)
// Status: experimental | Level: high | ID: 7388e334-0672-59c1-8592-e762036d2aa0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
