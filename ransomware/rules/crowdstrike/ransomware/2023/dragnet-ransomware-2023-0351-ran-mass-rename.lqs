// Dragnet [Ransomware]: dragnet-ransomware-2023-0351 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: dca9eb85-6939-52fd-b8e2-5a028f6d89e8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
