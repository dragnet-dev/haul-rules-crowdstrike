// Dragnet [Ransomware]: dragnet-ransomware-2025-6665 — Mass File Rename (play)
// Status: experimental | Level: high | ID: e25a14fe-5dcb-56c5-9deb-0f5456f625c1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
