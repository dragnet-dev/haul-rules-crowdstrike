// Dragnet [Ransomware]: dragnet-ransomware-2025-4367 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 91a5abae-d4f8-56fd-9263-4738252cd9f5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
