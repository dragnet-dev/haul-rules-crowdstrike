// Dragnet [Container]: dragnet-container-2026-1488 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 8a54315a-786a-53dd-a832-37ece314f0f7

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6*)
| table([timestamp, ComputerName])
| limit(1000)
