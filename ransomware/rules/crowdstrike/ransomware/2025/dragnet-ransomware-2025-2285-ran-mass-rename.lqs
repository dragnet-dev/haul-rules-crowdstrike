// Dragnet [Ransomware]: dragnet-ransomware-2025-2285 — Mass File Rename (worldleaks)
// Status: experimental | Level: high | ID: 0282aadd-f954-5a73-88e9-66ddc9c0dbb6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
