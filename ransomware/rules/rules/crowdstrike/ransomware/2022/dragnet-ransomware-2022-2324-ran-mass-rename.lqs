// Dragnet [Ransomware]: dragnet-ransomware-2022-2324 — Mass File Rename (onyx)
// Status: deprecated | Level: high | ID: a0b199c5-8547-5c5c-8357-05e1941b3433

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
