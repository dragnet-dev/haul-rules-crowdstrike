// Dragnet [Container]: dragnet-container-2024-0341 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: e10d7c73-5c9a-51f7-b041-1b32a5fcc4a4

#event_simpleName=*
| (ImageFileName = *chainguard:* OR ImageFileName = *oraclelinux:7* OR ImageFileName = *oraclelinux:8* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
