// Dragnet [Ransomware]: dragnet-ransomware-2025-4297 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: 229e891f-e7fb-5649-81a1-f06d60f5bb8a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
