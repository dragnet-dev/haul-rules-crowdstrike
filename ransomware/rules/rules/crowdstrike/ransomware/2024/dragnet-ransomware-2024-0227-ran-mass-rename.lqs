// Dragnet [Ransomware]: dragnet-ransomware-2024-0227 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: b04f596a-ccbf-5248-87e5-919913169163

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
