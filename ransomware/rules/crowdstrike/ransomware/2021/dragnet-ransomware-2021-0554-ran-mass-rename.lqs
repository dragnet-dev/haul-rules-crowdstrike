// Dragnet [Ransomware]: dragnet-ransomware-2021-0554 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 9c8717b9-7c99-5c40-b9cd-1c08efc4af16

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
