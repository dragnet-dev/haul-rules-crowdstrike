// Dragnet [Ransomware]: dragnet-ransomware-2026-2896 — Mass File Rename (kairos)
// Status: deprecated | Level: high | ID: 66b73f0a-87f3-55e4-950c-b27b692c1013

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
