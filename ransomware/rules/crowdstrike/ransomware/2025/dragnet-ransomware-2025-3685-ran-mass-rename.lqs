// Dragnet [Ransomware]: dragnet-ransomware-2025-3685 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: f5f670ac-ed41-583c-9049-9cae181b81b1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
