// Dragnet [Ransomware]: dragnet-ransomware-2025-2827 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 512a5c7d-acaf-54c1-8551-5135ee9e7bd0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
