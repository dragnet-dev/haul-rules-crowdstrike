// Dragnet [Ransomware]: dragnet-ransomware-2024-5217 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: 5c231c6a-5b78-51b0-9629-7bca54a83d8a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
