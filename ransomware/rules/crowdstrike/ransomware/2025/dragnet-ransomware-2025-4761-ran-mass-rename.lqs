// Dragnet [Ransomware]: dragnet-ransomware-2025-4761 — Mass File Rename (hellcat)
// Status: deprecated | Level: high | ID: 7d59aaa1-d800-5143-ae05-8ebfc05d68a8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
