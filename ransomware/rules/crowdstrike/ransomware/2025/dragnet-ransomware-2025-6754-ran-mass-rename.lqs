// Dragnet [Ransomware]: dragnet-ransomware-2025-6754 — Mass File Rename (kraken)
// Status: experimental | Level: high | ID: c66baf06-127e-5521-90fd-c3eb315d927a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
