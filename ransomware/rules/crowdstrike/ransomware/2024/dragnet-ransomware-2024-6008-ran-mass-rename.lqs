// Dragnet [Ransomware]: dragnet-ransomware-2024-6008 — Mass File Rename (cloak)
// Status: deprecated | Level: high | ID: 6f38e37a-8c7e-5517-a16f-5d79f4772ede

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
