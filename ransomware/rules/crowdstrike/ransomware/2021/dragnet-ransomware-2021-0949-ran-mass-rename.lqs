// Dragnet [Ransomware]: dragnet-ransomware-2021-0949 — Mass File Rename (doppelpaymer)
// Status: deprecated | Level: high | ID: 6fdcce10-1ff4-5adf-9b4d-18657b19d0a5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
