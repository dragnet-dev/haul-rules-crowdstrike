// Dragnet [Ransomware]: dragnet-ransomware-2023-3152 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: dfb1f9a8-984c-5efa-bdb8-eea241583b15

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
