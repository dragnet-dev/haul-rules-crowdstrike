// Dragnet [Ransomware]: dragnet-ransomware-2022-0502 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 09ec8d9a-0e85-531b-a287-80ac5e9dc7b1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
