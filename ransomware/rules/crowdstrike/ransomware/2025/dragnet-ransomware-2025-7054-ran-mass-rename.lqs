// Dragnet [Ransomware]: dragnet-ransomware-2025-7054 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 0a367fef-c5ed-514e-ba53-6b2f487f96ed

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
