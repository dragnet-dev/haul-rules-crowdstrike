// Dragnet [Ransomware]: dragnet-ransomware-2022-0835 — Mass File Rename (unsafe)
// Status: deprecated | Level: high | ID: b9d23ba5-29bc-5398-a488-5ac6a67ac1a3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
