// Dragnet [Ransomware]: dragnet-ransomware-2025-6552 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 79d5ccbb-5ea4-59bd-8519-cc071c1c53ff

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
