// Dragnet [Ransomware]: dragnet-ransomware-2023-3257 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 61fa0fd3-71ea-5fac-9784-887e9fd75adc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
