// Dragnet [Ransomware]: dragnet-ransomware-2024-4707 — Mass File Rename (nitrogen)
// Status: experimental | Level: high | ID: fa81a7b8-9b71-50a5-a368-d59acd3181d8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
