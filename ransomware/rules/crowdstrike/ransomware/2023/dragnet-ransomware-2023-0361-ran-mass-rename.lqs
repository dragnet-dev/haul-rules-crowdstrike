// Dragnet [Ransomware]: dragnet-ransomware-2023-0361 — Mass File Rename (noescape)
// Status: experimental | Level: high | ID: 5e03b278-c169-56f0-991d-70995e011fe8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
