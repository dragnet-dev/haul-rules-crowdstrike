// Dragnet [Ransomware]: dragnet-ransomware-2022-0278 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 4a735f64-0f3e-5b03-a1fc-b88f4eb6c65d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
