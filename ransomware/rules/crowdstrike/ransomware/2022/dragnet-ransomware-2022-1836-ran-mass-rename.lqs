// Dragnet [Ransomware]: dragnet-ransomware-2022-1836 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 80fadd7a-4c8b-537a-aa44-af4a5bac8a8b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
