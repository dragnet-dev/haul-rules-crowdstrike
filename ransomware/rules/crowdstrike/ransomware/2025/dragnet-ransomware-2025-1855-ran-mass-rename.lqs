// Dragnet [Ransomware]: dragnet-ransomware-2025-1855 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 52581d5e-9ebe-5d2d-97e9-c314e08ea260

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
