// Dragnet [Ransomware]: dragnet-ransomware-2022-1509 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 5c488c6d-6dce-5897-8329-45649c4293e4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
