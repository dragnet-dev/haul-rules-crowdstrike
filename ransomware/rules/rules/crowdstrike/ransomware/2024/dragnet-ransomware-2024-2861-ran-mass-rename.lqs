// Dragnet [Ransomware]: dragnet-ransomware-2024-2861 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: cb4dd325-bb57-55e7-a325-c114e57979f2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
