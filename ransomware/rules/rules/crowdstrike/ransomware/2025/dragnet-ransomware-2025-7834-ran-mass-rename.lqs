// Dragnet [Ransomware]: dragnet-ransomware-2025-7834 — Mass File Rename (threeam)
// Status: experimental | Level: high | ID: ff5d6bef-a1d9-5aa6-a863-61bf66842afe

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
