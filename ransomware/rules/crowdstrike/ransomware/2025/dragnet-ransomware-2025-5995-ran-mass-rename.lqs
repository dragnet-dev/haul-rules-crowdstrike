// Dragnet [Ransomware]: dragnet-ransomware-2025-5995 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: f0a7ae50-57ae-58f7-b83f-0c3b188e0c8d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
