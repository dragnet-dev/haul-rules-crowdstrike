// Dragnet [Ransomware]: dragnet-ransomware-2025-5267 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: ce767cb6-e6f7-5a49-b92a-93bc364a45e1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
