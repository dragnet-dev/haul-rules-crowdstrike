// Dragnet [Ransomware]: dragnet-ransomware-2024-3324 — Mass File Rename (qilin)
// Status: deprecated | Level: high | ID: 4edb302d-48c4-541b-b7a2-aea0a3ff0f1c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
