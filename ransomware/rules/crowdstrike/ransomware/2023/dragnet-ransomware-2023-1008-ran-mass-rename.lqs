// Dragnet [Ransomware]: dragnet-ransomware-2023-1008 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 8b023ce8-6e49-5ffe-925c-0b306ecfaffe

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
