// Dragnet [Ransomware]: dragnet-ransomware-2021-0629 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 73a1d26e-df88-5a14-97b3-e3550e4ef206

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
