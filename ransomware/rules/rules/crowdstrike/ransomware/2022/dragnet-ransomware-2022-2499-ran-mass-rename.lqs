// Dragnet [Ransomware]: dragnet-ransomware-2022-2499 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: 488a439b-84bc-5153-a02f-62970f2f19fe

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
