// Dragnet [Ransomware]: dragnet-ransomware-2025-1402 — Mass File Rename (sinobi)
// Status: experimental | Level: high | ID: 0af5946a-8e85-52bc-a65d-d691436a051e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
