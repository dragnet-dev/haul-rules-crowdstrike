// Dragnet [Ransomware]: dragnet-ransomware-2025-2852 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 47b2120d-6b16-5162-b7eb-981c32940f80

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
