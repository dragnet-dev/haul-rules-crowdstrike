// Dragnet [Ransomware]: dragnet-ransomware-2025-2428 — Mass File Rename (thegentlemen)
// Status: experimental | Level: high | ID: 24d4f6a9-6e4f-5765-b547-f5544a83cf5a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
