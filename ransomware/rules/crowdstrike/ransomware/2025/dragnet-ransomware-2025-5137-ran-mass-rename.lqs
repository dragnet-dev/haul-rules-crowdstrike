// Dragnet [Ransomware]: dragnet-ransomware-2025-5137 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: 544e6f96-549e-53cb-8ca8-c6e46ced7bbe

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
