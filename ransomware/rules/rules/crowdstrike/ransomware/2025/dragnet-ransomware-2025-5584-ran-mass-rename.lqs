// Dragnet [Ransomware]: dragnet-ransomware-2025-5584 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 7a272429-ba40-59a4-9b25-5b25c32b2474

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
