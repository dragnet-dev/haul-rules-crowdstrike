// Dragnet [Ransomware]: dragnet-ransomware-2025-6088 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: 63836678-8fb2-5ad7-ac9c-a1c325a755e8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
