// Dragnet [Ransomware]: dragnet-ransomware-2025-3240 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 5e511323-60d0-5d6f-87ef-e89aa0e4f2c5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
