// Dragnet [Ransomware]: dragnet-ransomware-2023-2537 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 700ea8f9-4745-56ad-aae7-99e0b7af73cb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
