// Dragnet [Ransomware]: dragnet-ransomware-2024-4824 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: 37b0b994-f8e2-52aa-bf5d-6eda97e6bdb0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
