// Dragnet [Ransomware]: dragnet-ransomware-2022-2158 — Mass File Rename (cuba)
// Status: deprecated | Level: high | ID: 86fdaa98-f0f2-58c6-96b9-b75203d8ad49

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
