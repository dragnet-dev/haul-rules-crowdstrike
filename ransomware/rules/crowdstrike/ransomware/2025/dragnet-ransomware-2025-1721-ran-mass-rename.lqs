// Dragnet [Ransomware]: dragnet-ransomware-2025-1721 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: ac468820-8b3a-59a8-9eaf-73df9d0d345d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
