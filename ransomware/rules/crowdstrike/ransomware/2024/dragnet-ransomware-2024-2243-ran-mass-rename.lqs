// Dragnet [Ransomware]: dragnet-ransomware-2024-2243 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: c6c865eb-6f35-5b17-8231-28498f5059af

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
