// Dragnet [Container]: dragnet-container-2026-2934 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 81de5d9c-d82a-5bb0-b98e-b0df11520f2a

#event_simpleName=*
| (ImageFileName = *chainguard:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
