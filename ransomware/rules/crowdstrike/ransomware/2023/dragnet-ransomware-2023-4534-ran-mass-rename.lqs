// Dragnet [Ransomware]: dragnet-ransomware-2023-4534 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 41f28286-9209-5dfa-ab70-95c2ac882f23

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
