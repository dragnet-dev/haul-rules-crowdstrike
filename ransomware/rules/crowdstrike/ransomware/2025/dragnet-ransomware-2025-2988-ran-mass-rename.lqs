// Dragnet [Ransomware]: dragnet-ransomware-2025-2988 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 7aaccc70-78e1-5af1-b69a-d58ee9db1fce

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
