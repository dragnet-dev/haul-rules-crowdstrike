// Dragnet [Container]: dragnet-container-2025-0382 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: ec9b256e-f15a-556e-83e3-681398e81401

#event_simpleName=*
| (ImageFileName = *almalinux:8* OR ImageFileName = *cbl-mariner:1.0* OR ImageFileName = *oraclelinux:8* OR ImageFileName = *redhat/ubi9:*)
| table([timestamp, ComputerName])
| limit(1000)
