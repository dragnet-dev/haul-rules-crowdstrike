// Dragnet [Ransomware]: dragnet-ransomware-2025-4957 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: b79cebbc-5f9d-5521-b5be-079196359e86

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
