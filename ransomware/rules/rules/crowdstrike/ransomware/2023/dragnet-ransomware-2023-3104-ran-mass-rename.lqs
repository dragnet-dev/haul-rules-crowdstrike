// Dragnet [Ransomware]: dragnet-ransomware-2023-3104 — Mass File Rename (noescape)
// Status: experimental | Level: high | ID: 4db33d25-f2e3-5fd3-9125-7baeb354a1f5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
