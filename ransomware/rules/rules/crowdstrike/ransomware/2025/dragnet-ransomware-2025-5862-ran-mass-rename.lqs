// Dragnet [Ransomware]: dragnet-ransomware-2025-5862 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 9c3cacd1-1ee6-513a-a662-f7761af64c8f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
