// Dragnet [Ransomware]: dragnet-ransomware-2025-3057 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: 6a7ed38e-68b2-5462-9789-8084f5231cea

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
