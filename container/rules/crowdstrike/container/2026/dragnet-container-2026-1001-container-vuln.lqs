// Dragnet [Container]: dragnet-container-2026-1001 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: a5528027-912c-570a-aaed-4abe385cb54c

#event_simpleName=*
| (ImageFileName = *chainguard:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
