// Dragnet [Container]: dragnet-container-2026-2538 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: ab49d62f-5b68-56fc-9ed9-7d2efb8a220d

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
