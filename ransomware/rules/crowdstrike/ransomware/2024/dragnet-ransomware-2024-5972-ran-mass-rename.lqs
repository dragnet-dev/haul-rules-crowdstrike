// Dragnet [Ransomware]: dragnet-ransomware-2024-5972 — Mass File Rename (arcusmedia)
// Status: experimental | Level: high | ID: b213ae32-c746-5ca0-9feb-f897f3697179

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
