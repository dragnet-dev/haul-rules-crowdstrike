// Dragnet [Ransomware]: dragnet-ransomware-2025-0978 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 06dc2753-587b-5243-a1da-36c374cf655e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
