// Dragnet [Ransomware]: dragnet-ransomware-2024-4811 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 4de64b1f-b8d7-59fd-bfdb-2f867fe013d0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
