// Dragnet [Container]: dragnet-container-2024-1302 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 779e9dce-5ffb-5a95-9955-b9c94036bb86

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
