// Dragnet [Ransomware]: dragnet-ransomware-2024-0869 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 9ba5c864-cbb0-59fc-a4d8-a9d87436320a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
