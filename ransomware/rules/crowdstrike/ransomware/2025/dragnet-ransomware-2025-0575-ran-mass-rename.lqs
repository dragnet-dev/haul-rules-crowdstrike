// Dragnet [Ransomware]: dragnet-ransomware-2025-0575 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 9227875e-2761-5448-bbd9-d782c5f3472a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
