// Dragnet [Ransomware]: dragnet-ransomware-2022-1238 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: 73b8ef16-3c79-5d1b-b911-09dbbae2d2e7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
