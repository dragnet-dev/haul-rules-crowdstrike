// Dragnet [Ransomware]: dragnet-ransomware-2025-0219 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: d1f67baa-f791-5485-8152-ca2f40b22696

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
