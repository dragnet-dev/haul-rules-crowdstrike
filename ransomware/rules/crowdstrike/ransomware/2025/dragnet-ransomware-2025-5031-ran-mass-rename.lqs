// Dragnet [Ransomware]: dragnet-ransomware-2025-5031 — Mass File Rename (interlock)
// Status: experimental | Level: high | ID: 5e5415b4-0ec1-5b03-91eb-2d106a2060e4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
