// Dragnet [Ransomware]: dragnet-ransomware-2025-2176 — Mass File Rename (blackshrantac)
// Status: experimental | Level: high | ID: 93aceb23-b969-55cd-9c2a-e03b22d1c5ed

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
