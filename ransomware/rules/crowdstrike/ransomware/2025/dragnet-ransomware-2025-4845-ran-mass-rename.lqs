// Dragnet [Ransomware]: dragnet-ransomware-2025-4845 — Mass File Rename (J)
// Status: experimental | Level: high | ID: 0176fe3b-7b48-5545-ae8c-0050ec0700d6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
