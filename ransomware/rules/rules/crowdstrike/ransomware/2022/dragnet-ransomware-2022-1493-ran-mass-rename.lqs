// Dragnet [Ransomware]: dragnet-ransomware-2022-1493 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 9d388a64-3a8c-5449-b256-d2e4759941dc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
