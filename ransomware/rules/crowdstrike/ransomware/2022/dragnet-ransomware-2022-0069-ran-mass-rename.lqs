// Dragnet [Ransomware]: dragnet-ransomware-2022-0069 — Mass File Rename (vicesociety)
// Status: deprecated | Level: high | ID: 9e69cb0d-3132-50ff-b8c2-4df2aa1d4c71

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
