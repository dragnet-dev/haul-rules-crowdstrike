// Dragnet [Ransomware]: dragnet-ransomware-2025-3351 — Mass File Rename (devman)
// Status: experimental | Level: high | ID: 94a9140d-c71c-541b-b3eb-f4a85b8426de

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
