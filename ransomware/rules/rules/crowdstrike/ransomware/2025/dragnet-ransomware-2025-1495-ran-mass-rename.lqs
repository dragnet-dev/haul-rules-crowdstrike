// Dragnet [Ransomware]: dragnet-ransomware-2025-1495 — Mass File Rename (sinobi)
// Status: experimental | Level: high | ID: c35e20bb-4081-520e-8910-a94f688386f0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
