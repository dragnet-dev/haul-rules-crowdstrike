// Dragnet [Ransomware]: dragnet-ransomware-2022-2897 — Mass File Rename (sabbath)
// Status: deprecated | Level: high | ID: b41b7640-40eb-5417-aec3-31d090187ca4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
