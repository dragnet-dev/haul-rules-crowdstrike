// Dragnet [Ransomware]: dragnet-ransomware-2026-2250 — Mass File Rename (dragonforce)
// Status: test | Level: high | ID: b2fc0522-90d2-5842-af17-c54ff4f16cd3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
