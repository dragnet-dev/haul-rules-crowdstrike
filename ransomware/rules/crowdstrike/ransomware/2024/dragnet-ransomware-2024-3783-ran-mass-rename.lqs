// Dragnet [Ransomware]: dragnet-ransomware-2024-3783 — Mass File Rename (dAn0n)
// Status: experimental | Level: high | ID: 92bf823e-529e-5c1b-8b3a-5536b7259712

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
