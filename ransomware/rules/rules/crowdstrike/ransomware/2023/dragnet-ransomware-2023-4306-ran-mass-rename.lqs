// Dragnet [Ransomware]: dragnet-ransomware-2023-4306 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 4b2c24f7-6995-57c3-a9f3-b19cc5bab8db

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
