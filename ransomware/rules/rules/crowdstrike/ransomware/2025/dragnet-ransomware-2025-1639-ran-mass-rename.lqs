// Dragnet [Ransomware]: dragnet-ransomware-2025-1639 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 4a545f58-81ce-55d6-ae1c-3409ec536cdd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
