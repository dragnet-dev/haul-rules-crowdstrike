// Dragnet [Ransomware]: dragnet-ransomware-2022-1915 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: a83cd098-8c24-5d6c-9103-85f1bb860d63

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
