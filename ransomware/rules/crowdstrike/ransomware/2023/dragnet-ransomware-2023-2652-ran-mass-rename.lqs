// Dragnet [Ransomware]: dragnet-ransomware-2023-2652 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: b95b158f-6c97-533c-9b2a-e2f31a402e94

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
