// Dragnet [Ransomware]: dragnet-ransomware-2024-2413 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: a4ff8264-00d8-5de4-8d5a-1960cd1ec945

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
