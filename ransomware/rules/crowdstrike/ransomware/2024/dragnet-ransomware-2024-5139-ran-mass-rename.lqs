// Dragnet [Ransomware]: dragnet-ransomware-2024-5139 — Mass File Rename (blacklock)
// Status: experimental | Level: high | ID: 1ce951a6-5598-5000-a226-56ccd54b1ab4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
