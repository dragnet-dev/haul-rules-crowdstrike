// Dragnet [Ransomware]: dragnet-ransomware-2022-2688 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 9fb83cbb-970d-539a-8b8c-d4b254c9705c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
