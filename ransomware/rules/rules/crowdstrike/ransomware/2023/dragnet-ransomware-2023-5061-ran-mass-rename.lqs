// Dragnet [Ransomware]: dragnet-ransomware-2023-5061 — Mass File Rename (play)
// Status: experimental | Level: high | ID: e6ed2755-5ce6-5c9b-947b-22f870021697

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
