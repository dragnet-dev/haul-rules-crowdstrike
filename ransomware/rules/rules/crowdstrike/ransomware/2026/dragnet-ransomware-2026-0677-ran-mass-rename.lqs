// Dragnet [Ransomware]: dragnet-ransomware-2026-0677 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 9217cde2-0c2c-54a2-a76a-d61666d4beb7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
