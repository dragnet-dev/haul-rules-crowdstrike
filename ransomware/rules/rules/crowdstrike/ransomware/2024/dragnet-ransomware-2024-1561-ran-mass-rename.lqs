// Dragnet [Ransomware]: dragnet-ransomware-2024-1561 — Mass File Rename (abyss)
// Status: deprecated | Level: high | ID: 0e9c55b6-8593-5b21-9f8a-f8b7c93ee34b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
