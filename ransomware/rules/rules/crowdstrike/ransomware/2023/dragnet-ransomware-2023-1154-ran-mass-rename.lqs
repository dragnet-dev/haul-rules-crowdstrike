// Dragnet [Ransomware]: dragnet-ransomware-2023-1154 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 247aff81-e70b-507e-86b1-739631655690

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
