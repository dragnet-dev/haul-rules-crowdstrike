// Dragnet [Ransomware]: dragnet-ransomware-2024-1774 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: c1535cf4-95a3-5397-a453-40c95ab170bc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
