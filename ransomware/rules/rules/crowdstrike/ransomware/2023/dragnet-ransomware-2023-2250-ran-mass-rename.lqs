// Dragnet [Ransomware]: dragnet-ransomware-2023-2250 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 5be48aa3-9b7e-5efa-a3b8-8ef714c74267

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
