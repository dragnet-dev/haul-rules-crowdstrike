// Dragnet [Ransomware]: dragnet-ransomware-2025-6233 — Mass File Rename (sinobi)
// Status: experimental | Level: high | ID: 4a952525-97d4-593e-96c7-fa2bc33c3b39

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
