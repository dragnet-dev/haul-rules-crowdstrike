// Dragnet [Ransomware]: dragnet-ransomware-2022-2596 — Mass File Rename (blackbasta)
// Status: deprecated | Level: high | ID: 22e6e997-4de4-5be1-bcc4-bb2089f02ce6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
