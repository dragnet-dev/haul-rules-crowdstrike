// Dragnet [Ransomware]: dragnet-ransomware-2024-1164 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: ebc2e343-3ef8-5e71-8ed8-c7f1dc09fef5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
