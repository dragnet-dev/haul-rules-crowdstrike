// Dragnet [Ransomware]: dragnet-ransomware-2025-0577 — Mass File Rename (play)
// Status: experimental | Level: high | ID: ec585b33-0c97-5aa2-ba34-2c69a0422346

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
