// Dragnet [Ransomware]: dragnet-ransomware-2022-0855 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 5d66e5f9-d39d-5bdb-aa7d-4e0440937abb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
