// Dragnet [Ransomware]: dragnet-ransomware-2022-0242 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: b269b7e8-65f2-5b8c-b30d-73c450eb70ec

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
