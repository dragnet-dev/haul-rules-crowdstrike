// Dragnet [Ransomware]: dragnet-ransomware-2025-4200 — Mass File Rename (nightspire)
// Status: experimental | Level: high | ID: 2094f384-33bb-5d68-a7f0-4c4b273bf1ff

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
