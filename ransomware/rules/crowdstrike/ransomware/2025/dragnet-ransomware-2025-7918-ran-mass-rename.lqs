// Dragnet [Ransomware]: dragnet-ransomware-2025-7918 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: a57ebbaf-6924-5864-853c-c65f22269503

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
