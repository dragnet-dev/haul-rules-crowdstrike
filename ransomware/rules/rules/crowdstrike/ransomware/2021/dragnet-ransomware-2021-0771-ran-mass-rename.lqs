// Dragnet [Ransomware]: dragnet-ransomware-2021-0771 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: be1544ec-7951-55d2-a930-63572d66a241

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
