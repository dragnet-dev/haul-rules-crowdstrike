// Dragnet [Container]: dragnet-container-2024-0639 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 5988a732-d68b-5922-99b2-4bc087f95af2

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:9*)
| table([timestamp, ComputerName])
| limit(1000)
