// Dragnet [Ransomware]: dragnet-ransomware-2024-0251 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: 4a625524-78e3-562e-899e-92fdcc491c60

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
