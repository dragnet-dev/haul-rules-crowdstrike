// Dragnet [Ransomware]: dragnet-ransomware-2025-5211 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: c82be0f3-579c-5795-8300-4eb05f96d802

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
