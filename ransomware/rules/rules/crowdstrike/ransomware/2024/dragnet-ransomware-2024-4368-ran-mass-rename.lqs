// Dragnet [Ransomware]: dragnet-ransomware-2024-4368 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 3dded492-3ee5-54c5-bfa8-f071ac096fca

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
