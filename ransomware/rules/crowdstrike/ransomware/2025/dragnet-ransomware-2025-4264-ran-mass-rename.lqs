// Dragnet [Ransomware]: dragnet-ransomware-2025-4264 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: b673509f-ec0a-5a11-898c-abbe64e06ed2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
