// Dragnet [Ransomware]: dragnet-ransomware-2025-1615 — Mass File Rename (monti)
// Status: experimental | Level: high | ID: 37253098-8229-517a-b34e-7dda40413b24

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
