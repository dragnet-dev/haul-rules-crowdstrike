// Dragnet [Ransomware]: dragnet-ransomware-2023-4618 — Mass File Rename (trigona)
// Status: experimental | Level: high | ID: 1c9c7cc5-f226-5a67-adef-b381eeb8402b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
