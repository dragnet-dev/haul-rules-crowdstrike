// Dragnet [Ransomware]: dragnet-ransomware-2020-0037 — Mass File Rename (ragnarlocker)
// Status: deprecated | Level: high | ID: 09dff63c-674d-569c-9021-8d4567d1fbd5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
