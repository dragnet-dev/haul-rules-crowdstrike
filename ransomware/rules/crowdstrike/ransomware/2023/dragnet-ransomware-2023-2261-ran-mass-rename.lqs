// Dragnet [Ransomware]: dragnet-ransomware-2023-2261 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 1d7b9b20-2914-5a6e-a840-2b3faf88020d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
