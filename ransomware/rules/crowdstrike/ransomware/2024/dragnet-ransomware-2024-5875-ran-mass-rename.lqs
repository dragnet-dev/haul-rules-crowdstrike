// Dragnet [Ransomware]: dragnet-ransomware-2024-5875 — Mass File Rename (sarcoma)
// Status: deprecated | Level: high | ID: 3624cc2f-700b-58ad-98e2-de6898c242ca

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
