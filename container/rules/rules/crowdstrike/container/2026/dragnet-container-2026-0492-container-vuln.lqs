// Dragnet [Container]: dragnet-container-2026-0492 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 6d81758b-c7e5-54d5-a372-4ed1cce5254d

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6*)
| table([timestamp, ComputerName])
| limit(1000)
