// Dragnet [Ransomware]: dragnet-ransomware-2025-6928 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 5f830f16-7108-5512-ae5f-e8a477db7ef9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
