// Dragnet [Ransomware]: dragnet-ransomware-2024-4970 — Mass File Rename (darkvault)
// Status: experimental | Level: high | ID: 2803d8af-5d29-594a-b2ab-9ddfe4d2e883

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
