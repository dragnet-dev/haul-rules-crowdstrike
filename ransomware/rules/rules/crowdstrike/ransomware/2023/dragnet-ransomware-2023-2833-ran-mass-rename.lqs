// Dragnet [Ransomware]: dragnet-ransomware-2023-2833 — Mass File Rename (malas)
// Status: experimental | Level: high | ID: f7722edd-f5d0-550c-9087-3a97f5664e7f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
