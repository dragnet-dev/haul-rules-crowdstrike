// Dragnet [Ransomware]: dragnet-ransomware-2023-0656 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 2d11fab2-d205-5769-9b0c-e5ea9fddf40a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
