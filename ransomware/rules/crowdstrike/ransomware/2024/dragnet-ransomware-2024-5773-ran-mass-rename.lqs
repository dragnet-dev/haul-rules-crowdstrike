// Dragnet [Ransomware]: dragnet-ransomware-2024-5773 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 141ac091-aa2c-5d6d-aa3a-ab2810fe9deb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
