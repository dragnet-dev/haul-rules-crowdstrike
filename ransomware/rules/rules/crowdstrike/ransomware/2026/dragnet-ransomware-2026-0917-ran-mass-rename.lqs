// Dragnet [Ransomware]: dragnet-ransomware-2026-0917 — Mass File Rename (lapsus$)
// Status: deprecated | Level: high | ID: b662b39c-2cc7-5c8a-9301-fa4e4c79b94d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
