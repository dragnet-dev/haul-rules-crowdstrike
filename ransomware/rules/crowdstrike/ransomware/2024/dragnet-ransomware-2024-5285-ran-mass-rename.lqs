// Dragnet [Ransomware]: dragnet-ransomware-2024-5285 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 3fcbc38d-b2d5-508c-95b0-4f11d4196867

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
