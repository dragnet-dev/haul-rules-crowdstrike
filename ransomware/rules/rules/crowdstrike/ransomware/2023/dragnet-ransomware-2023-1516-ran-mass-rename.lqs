// Dragnet [Ransomware]: dragnet-ransomware-2023-1516 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: a1cbfc16-6a75-5d8b-a305-e62bd5c31194

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
