// Dragnet [Ransomware]: dragnet-ransomware-2025-0507 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: af8351e7-5646-5050-9807-5cfea17f3d41

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
