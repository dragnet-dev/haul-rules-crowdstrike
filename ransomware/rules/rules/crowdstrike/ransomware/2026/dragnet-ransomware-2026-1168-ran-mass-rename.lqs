// Dragnet [Ransomware]: dragnet-ransomware-2026-1168 — Mass File Rename (thegentlemen)
// Status: stable | Level: high | ID: 5dd210ed-2e80-558c-9053-e106d0c403dc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
