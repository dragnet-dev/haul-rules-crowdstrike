// Dragnet [Ransomware]: dragnet-ransomware-2023-2563 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: beedba45-ca5b-57a5-9673-7a560d483313

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
