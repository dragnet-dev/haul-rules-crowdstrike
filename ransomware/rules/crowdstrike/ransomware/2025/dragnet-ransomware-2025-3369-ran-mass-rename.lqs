// Dragnet [Ransomware]: dragnet-ransomware-2025-3369 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: 6e27148d-3a06-5286-bc29-986f2d3c3759

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
