// Dragnet [Ransomware]: dragnet-ransomware-2024-1435 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: d1ccd05e-c046-5c1e-ac72-a149a5645594

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
