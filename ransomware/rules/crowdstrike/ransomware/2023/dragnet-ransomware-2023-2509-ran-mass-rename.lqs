// Dragnet [Ransomware]: dragnet-ransomware-2023-2509 — Mass File Rename (stormous)
// Status: experimental | Level: high | ID: 5c833034-e7ae-533e-b9aa-cd4380ea35bb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
