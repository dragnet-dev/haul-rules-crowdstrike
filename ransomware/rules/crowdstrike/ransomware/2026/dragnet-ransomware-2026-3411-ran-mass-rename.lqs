// Dragnet [Ransomware]: dragnet-ransomware-2026-3411 — Mass File Rename (dragonforce)
// Status: stable | Level: high | ID: 891afc39-3957-5082-9e57-3e3c502fefc1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
