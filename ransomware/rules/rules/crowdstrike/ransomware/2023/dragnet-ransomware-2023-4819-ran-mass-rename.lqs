// Dragnet [Ransomware]: dragnet-ransomware-2023-4819 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: c7d687d9-29c4-5bcd-8af3-3adc3b4546f2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
