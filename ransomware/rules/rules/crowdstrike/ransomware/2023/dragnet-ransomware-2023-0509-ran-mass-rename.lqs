// Dragnet [Ransomware]: dragnet-ransomware-2023-0509 — Mass File Rename (cuba)
// Status: experimental | Level: high | ID: 4555033e-7628-5651-b196-dbeaab072350

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
