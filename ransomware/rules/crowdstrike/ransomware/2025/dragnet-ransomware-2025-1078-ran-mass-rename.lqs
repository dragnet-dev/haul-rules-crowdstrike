// Dragnet [Ransomware]: dragnet-ransomware-2025-1078 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 1f44d216-0713-5917-b6c4-5f458201629d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
