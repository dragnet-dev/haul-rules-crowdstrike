// Dragnet [Ransomware]: dragnet-ransomware-2025-7450 — Mass File Rename (ralord)
// Status: experimental | Level: high | ID: e7914835-4a6d-5375-bc8a-f75f4ad150a0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
