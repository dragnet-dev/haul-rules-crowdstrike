// Dragnet [Ransomware]: dragnet-ransomware-2025-7474 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 8c993acf-cb86-59f8-8a84-3bbb76d53bd2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
