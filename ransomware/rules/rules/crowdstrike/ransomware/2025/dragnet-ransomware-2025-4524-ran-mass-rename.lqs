// Dragnet [Ransomware]: dragnet-ransomware-2025-4524 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 3327ad03-fd94-564d-b844-30f247b5ce76

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
