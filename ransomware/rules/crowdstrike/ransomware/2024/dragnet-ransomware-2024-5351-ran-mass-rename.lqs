// Dragnet [Ransomware]: dragnet-ransomware-2024-5351 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 73184415-6819-5549-a255-a787efb8a00a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
