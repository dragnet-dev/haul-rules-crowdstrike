// Dragnet [Ransomware]: dragnet-ransomware-2021-0741 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 76f578de-ecbe-572d-ae5f-13168f421a48

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
