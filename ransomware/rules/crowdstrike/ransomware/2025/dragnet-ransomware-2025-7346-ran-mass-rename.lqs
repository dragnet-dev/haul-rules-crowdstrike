// Dragnet [Ransomware]: dragnet-ransomware-2025-7346 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 99d22838-1137-5cc4-aef7-22d9a916ccf2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
