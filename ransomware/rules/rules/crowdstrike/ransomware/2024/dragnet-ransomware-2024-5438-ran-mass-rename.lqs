// Dragnet [Ransomware]: dragnet-ransomware-2024-5438 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: 064049a0-72dc-505a-961d-1cfbe3c2ea47

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
