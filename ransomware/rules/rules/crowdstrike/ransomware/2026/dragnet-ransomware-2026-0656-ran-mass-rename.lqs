// Dragnet [Ransomware]: dragnet-ransomware-2026-0656 — Mass File Rename (safepay)
// Status: stable | Level: high | ID: 029afa97-7fd3-56d1-9ba1-cb41f855cf44

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
