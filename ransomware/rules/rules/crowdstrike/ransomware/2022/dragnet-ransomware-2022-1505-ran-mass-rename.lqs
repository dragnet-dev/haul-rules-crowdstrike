// Dragnet [Ransomware]: dragnet-ransomware-2022-1505 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 4acb7a1e-b62a-5edc-833c-2de5181bebaf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
