// Dragnet [Ransomware]: dragnet-ransomware-2024-1078 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 9f9f7db3-bb64-5b7b-b821-b064f4cb2d95

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
