// Dragnet [Ransomware]: dragnet-ransomware-2024-4620 — Mass File Rename (arcusmedia)
// Status: experimental | Level: high | ID: bd65dcdd-9d94-5608-b0da-f1a11cb09775

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
