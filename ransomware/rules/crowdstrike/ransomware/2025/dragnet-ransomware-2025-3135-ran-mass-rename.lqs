// Dragnet [Ransomware]: dragnet-ransomware-2025-3135 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 1a2105a7-804e-5985-8cd7-ca5a82673c93

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
