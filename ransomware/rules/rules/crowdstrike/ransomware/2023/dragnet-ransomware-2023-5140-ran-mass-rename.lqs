// Dragnet [Ransomware]: dragnet-ransomware-2023-5140 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 1ab85285-fec8-5d49-b95e-73c640b3a169

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
