// Dragnet [Ransomware]: dragnet-ransomware-2023-0465 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 8ad00079-1ed0-59c1-a8e5-b22eaebab5df

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
