// Dragnet [Ransomware]: dragnet-ransomware-2024-5320 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: a83a533e-d2cc-5ee8-bb22-0c2b41f643b0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
