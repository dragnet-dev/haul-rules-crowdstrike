// Dragnet [Ransomware]: dragnet-ransomware-2025-6431 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: fbfc0235-d17a-5504-b5b3-84d9e0250fb0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
