// Dragnet [Ransomware]: dragnet-ransomware-2025-6801 — Mass File Rename (direwolf)
// Status: experimental | Level: high | ID: ac39ec57-1a33-54c7-9456-064f7311853e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
