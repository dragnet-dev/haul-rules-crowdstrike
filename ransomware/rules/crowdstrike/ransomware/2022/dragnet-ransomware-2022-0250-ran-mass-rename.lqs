// Dragnet [Ransomware]: dragnet-ransomware-2022-0250 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 6ea63f8a-4a54-5829-be54-efe88ba405af

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
