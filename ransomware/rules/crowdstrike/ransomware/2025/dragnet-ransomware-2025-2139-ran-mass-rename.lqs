// Dragnet [Ransomware]: dragnet-ransomware-2025-2139 — Mass File Rename (dragonforce)
// Status: test | Level: high | ID: 9eda155f-62ad-5ed7-a88c-e610c3b6e068

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
