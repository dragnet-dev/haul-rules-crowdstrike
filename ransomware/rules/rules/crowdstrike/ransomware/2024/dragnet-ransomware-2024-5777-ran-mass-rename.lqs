// Dragnet [Ransomware]: dragnet-ransomware-2024-5777 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 0de048a8-f1b5-5d60-b206-9285149a4b46

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
