// Dragnet [Ransomware]: dragnet-ransomware-2022-2426 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 676cdbc8-02b0-5a1e-924a-2367e638e820

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
