// Dragnet [Ransomware]: dragnet-ransomware-2024-3519 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 4122d30e-bdc7-543b-8fc4-abdf3df3f2a2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
