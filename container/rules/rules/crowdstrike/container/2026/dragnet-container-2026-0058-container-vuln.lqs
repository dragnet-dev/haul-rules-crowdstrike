// Dragnet [Container]: dragnet-container-2026-0058 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 21f63e53-9fb3-5a18-a589-4f90cbfaabe8

#event_simpleName=*
| (ImageFileName = *alpine edge:* OR ImageFileName = *chainguard:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *ubuntu:16.04-ESM* OR ImageFileName = *ubuntu:18.04-ESM* OR ImageFileName = *ubuntu:20.04-ESM* OR ImageFileName = *ubuntu:22.04* OR ImageFileName = *ubuntu:24.04* OR ImageFileName = *ubuntu:25.10* OR ImageFileName = *ubuntu:26.04* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
