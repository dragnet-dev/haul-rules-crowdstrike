// Dragnet [Ransomware]: dragnet-ransomware-2022-2076 — Mass File Rename (ragnarlocker)
// Status: deprecated | Level: high | ID: af05afd5-c7b5-5f7d-ab8c-44bb1b93486c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
