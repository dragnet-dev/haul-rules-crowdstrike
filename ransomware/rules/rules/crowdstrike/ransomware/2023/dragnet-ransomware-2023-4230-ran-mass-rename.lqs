// Dragnet [Ransomware]: dragnet-ransomware-2023-4230 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: b488bc25-259b-5b93-b494-c3979781d7bc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
