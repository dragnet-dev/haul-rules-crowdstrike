// Dragnet [Ransomware]: dragnet-ransomware-2021-1580 — Mass File Rename (spook)
// Status: deprecated | Level: high | ID: 31cb119d-5abe-5371-8448-398d4fc45da4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
