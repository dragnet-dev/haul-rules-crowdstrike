// Dragnet [Ransomware]: dragnet-ransomware-2023-1266 — Mass File Rename (rhysida)
// Status: experimental | Level: high | ID: 9af58fce-0001-5d31-ab65-f7417c33118e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
