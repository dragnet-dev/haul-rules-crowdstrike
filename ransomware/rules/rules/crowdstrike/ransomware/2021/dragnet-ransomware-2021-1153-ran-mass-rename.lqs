// Dragnet [Ransomware]: dragnet-ransomware-2021-1153 — Mass File Rename (suncrypt)
// Status: deprecated | Level: high | ID: b9bd26de-a151-55f3-8d5d-a32dba230e82

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
