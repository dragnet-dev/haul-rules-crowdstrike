// Dragnet [Ransomware]: dragnet-ransomware-2024-1796 — Mass File Rename (safepay)
// Status: deprecated | Level: high | ID: 0383c85f-7516-5694-b0b3-0c399a5d0ed4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
