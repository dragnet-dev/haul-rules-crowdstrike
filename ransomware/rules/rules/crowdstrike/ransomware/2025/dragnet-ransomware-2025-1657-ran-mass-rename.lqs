// Dragnet [Ransomware]: dragnet-ransomware-2025-1657 — Mass File Rename (arkana)
// Status: deprecated | Level: high | ID: 529478c2-0ce5-5e46-a065-59b589007838

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
