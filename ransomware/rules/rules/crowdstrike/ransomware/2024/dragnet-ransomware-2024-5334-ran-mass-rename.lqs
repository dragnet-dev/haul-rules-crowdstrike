// Dragnet [Ransomware]: dragnet-ransomware-2024-5334 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 0b309c80-95ae-5807-ab30-b3c4dd5a0311

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
