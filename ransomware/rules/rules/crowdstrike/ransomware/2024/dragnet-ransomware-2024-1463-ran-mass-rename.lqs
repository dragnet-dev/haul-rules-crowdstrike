// Dragnet [Ransomware]: dragnet-ransomware-2024-1463 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: a155f7ad-95e9-5e23-adac-a9bc7846b406

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
