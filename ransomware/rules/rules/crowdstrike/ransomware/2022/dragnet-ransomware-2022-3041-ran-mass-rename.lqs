// Dragnet [Ransomware]: dragnet-ransomware-2022-3041 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 6337d525-9738-5606-8cdb-d34338b55430

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
