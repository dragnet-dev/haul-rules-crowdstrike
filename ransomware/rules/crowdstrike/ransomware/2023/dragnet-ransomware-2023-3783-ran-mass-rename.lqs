// Dragnet [Ransomware]: dragnet-ransomware-2023-3783 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: c04d80b0-895c-510e-a120-bb054718fc9c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
