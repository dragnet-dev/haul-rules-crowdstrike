// Dragnet [Ransomware]: dragnet-ransomware-2025-5149 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: a8be1db8-fa73-59d3-9f65-4436e0ccc1f0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
