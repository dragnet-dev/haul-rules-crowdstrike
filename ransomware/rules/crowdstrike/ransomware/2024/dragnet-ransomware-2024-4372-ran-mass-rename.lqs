// Dragnet [Ransomware]: dragnet-ransomware-2024-4372 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: 797d50c2-f41e-5f04-bad0-840372473b8f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
