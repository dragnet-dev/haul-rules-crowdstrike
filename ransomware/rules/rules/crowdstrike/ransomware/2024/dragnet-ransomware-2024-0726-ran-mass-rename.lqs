// Dragnet [Ransomware]: dragnet-ransomware-2024-0726 — Mass File Rename (nitrogen)
// Status: experimental | Level: high | ID: d2444ce3-0cb4-53fd-be34-e611b16a7265

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
