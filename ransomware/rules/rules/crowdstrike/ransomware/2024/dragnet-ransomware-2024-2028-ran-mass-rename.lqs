// Dragnet [Ransomware]: dragnet-ransomware-2024-2028 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: d813ae69-971d-5442-bb34-33474471e416

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
