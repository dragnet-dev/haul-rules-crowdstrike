// Dragnet [Ransomware]: dragnet-ransomware-2025-2342 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 4cf2eae7-a313-5758-aa31-5ae18cba51a3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
