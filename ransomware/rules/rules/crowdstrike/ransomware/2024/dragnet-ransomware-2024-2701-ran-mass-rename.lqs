// Dragnet [Ransomware]: dragnet-ransomware-2024-2701 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 0f6d0d36-1580-5e2c-8652-f7753eeccf44

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
