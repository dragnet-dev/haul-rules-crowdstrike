// Dragnet [Ransomware]: dragnet-ransomware-2023-2905 — Mass File Rename (qilin)
// Status: deprecated | Level: high | ID: 4910fdf2-9b47-5f1f-b4bf-c7eabae4d243

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
