// Dragnet [Ransomware]: dragnet-ransomware-2026-1867 — Mass File Rename (killsec)
// Status: deprecated | Level: high | ID: 2fdd4424-b33f-53cd-9075-b41160bfd8bd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
