// Dragnet [Ransomware]: dragnet-ransomware-2024-3834 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: d86adff4-12bc-531b-95ed-1d8e8a143e38

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
