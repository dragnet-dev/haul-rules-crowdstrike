// Dragnet [Ransomware]: dragnet-ransomware-2023-3596 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: f6fe61db-348e-5808-b03b-be68595abe6a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
