// Dragnet [Ransomware]: dragnet-ransomware-2022-2775 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: d4d7de0f-1661-533b-8cf5-975c50f97b25

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
