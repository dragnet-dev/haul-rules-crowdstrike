// Dragnet [Ransomware]: dragnet-ransomware-2023-0170 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 725d1caa-e283-5f99-8ab2-9bab5996cb12

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
