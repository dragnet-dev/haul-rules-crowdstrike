// Dragnet [Ransomware]: dragnet-ransomware-2023-4495 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: e13d89bc-8ca3-5cc2-94b5-e735077001df

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
