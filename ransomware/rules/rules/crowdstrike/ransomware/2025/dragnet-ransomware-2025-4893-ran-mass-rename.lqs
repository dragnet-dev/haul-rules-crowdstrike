// Dragnet [Ransomware]: dragnet-ransomware-2025-4893 — Mass File Rename (killsec)
// Status: deprecated | Level: high | ID: ec6616fe-c7aa-51b1-ace2-5e002e6c8b2e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
