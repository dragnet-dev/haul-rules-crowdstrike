// Dragnet [Ransomware]: dragnet-ransomware-2022-1253 — Mass File Rename (darkleakmarket)
// Status: deprecated | Level: high | ID: e2a0140d-05c5-5f16-bdd4-2d2bbd5e4877

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
