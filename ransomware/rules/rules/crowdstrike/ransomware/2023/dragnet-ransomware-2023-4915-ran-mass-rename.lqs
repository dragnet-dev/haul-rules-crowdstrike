// Dragnet [Ransomware]: dragnet-ransomware-2023-4915 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 566a1b72-2dbc-50b2-bb5e-0d8d743ab529

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
