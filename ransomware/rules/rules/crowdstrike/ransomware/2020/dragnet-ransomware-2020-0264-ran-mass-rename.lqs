// Dragnet [Ransomware]: dragnet-ransomware-2020-0264 — Mass File Rename (prolock)
// Status: deprecated | Level: high | ID: 395e2bf5-effe-5394-a4ae-fb715cd1ff95

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
