// Dragnet [Ransomware]: dragnet-ransomware-2025-6626 — Mass File Rename (SilentRansomGroup)
// Status: deprecated | Level: high | ID: 28b01124-c878-5365-b749-322e3df2cb5d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
