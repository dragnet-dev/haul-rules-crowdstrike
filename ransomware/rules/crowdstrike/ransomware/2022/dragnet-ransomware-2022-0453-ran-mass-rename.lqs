// Dragnet [Ransomware]: dragnet-ransomware-2022-0453 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 0bbe62df-84fd-5c07-ad96-dfbfee69ec11

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
