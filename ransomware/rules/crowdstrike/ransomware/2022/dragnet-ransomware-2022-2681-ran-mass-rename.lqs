// Dragnet [Ransomware]: dragnet-ransomware-2022-2681 — Mass File Rename (blackbasta)
// Status: deprecated | Level: high | ID: 5e30e1d4-b352-5d65-928a-671ec5b96aa9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
