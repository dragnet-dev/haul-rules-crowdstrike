// Dragnet [Ransomware]: dragnet-ransomware-2023-2551 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: ffe013ce-3e2b-5c32-b30b-70d4db8a080c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
