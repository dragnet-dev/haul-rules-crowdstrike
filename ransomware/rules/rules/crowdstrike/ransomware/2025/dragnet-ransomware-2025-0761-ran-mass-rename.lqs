// Dragnet [Ransomware]: dragnet-ransomware-2025-0761 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: d5ecbd8d-1963-50c1-984e-e7d51ec95f7a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
