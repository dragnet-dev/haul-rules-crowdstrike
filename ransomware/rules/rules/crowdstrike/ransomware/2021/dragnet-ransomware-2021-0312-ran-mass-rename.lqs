// Dragnet [Ransomware]: dragnet-ransomware-2021-0312 — Mass File Rename (ryuk)
// Status: deprecated | Level: high | ID: b3ce3eb0-22d5-5e82-a5d6-b6b56c5a2328

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
