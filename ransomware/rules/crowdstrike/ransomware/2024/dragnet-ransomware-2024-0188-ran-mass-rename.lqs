// Dragnet [Ransomware]: dragnet-ransomware-2024-0188 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: 65851406-5e38-5a6a-9974-1a1a7b91f8eb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
