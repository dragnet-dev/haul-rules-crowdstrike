// Dragnet [Ransomware]: dragnet-ransomware-2021-1133 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 6730259c-9dd5-5269-9e90-c4573e7258cd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
