// Dragnet [Ransomware]: dragnet-ransomware-2023-4072 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 1ead14a9-f316-5e91-96f5-46d1a051a30f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
