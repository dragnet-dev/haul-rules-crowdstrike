// Dragnet [Ransomware]: dragnet-ransomware-2026-0442 — Mass File Rename (payload)
// Status: stable | Level: high | ID: 5fbc3194-7ce8-5612-8d78-b1db28e1a416

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
