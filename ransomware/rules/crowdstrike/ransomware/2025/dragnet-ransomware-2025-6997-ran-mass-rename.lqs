// Dragnet [Ransomware]: dragnet-ransomware-2025-6997 — Mass File Rename (stormous)
// Status: experimental | Level: high | ID: b033dcfa-7db2-5068-82f4-f963aecc4bfe

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
