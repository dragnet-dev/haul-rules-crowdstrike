// Dragnet [Ransomware]: dragnet-ransomware-2025-5871 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 1bc43c53-519b-54ba-a4d7-e6da55d40e54

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
