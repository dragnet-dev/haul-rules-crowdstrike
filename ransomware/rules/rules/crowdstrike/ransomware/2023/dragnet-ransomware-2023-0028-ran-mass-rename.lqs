// Dragnet [Ransomware]: dragnet-ransomware-2023-0028 — Mass File Rename (royal)
// Status: experimental | Level: high | ID: 607ae81a-20d0-5500-aa27-7852f51d8327

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
