// Dragnet [Ransomware]: dragnet-ransomware-2021-0430 — Mass File Rename (avaddon)
// Status: deprecated | Level: high | ID: 36c0ea56-64b1-5ed0-8a85-3d2cfca5eb36

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
