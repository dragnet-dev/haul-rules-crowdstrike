// Dragnet [Ransomware]: dragnet-ransomware-2024-1623 — Mass File Rename (handala)
// Status: experimental | Level: high | ID: 1cf74fbc-4db5-54b9-9acf-ae2bdf05b55e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
