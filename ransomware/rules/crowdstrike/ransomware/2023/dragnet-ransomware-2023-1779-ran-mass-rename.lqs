// Dragnet [Ransomware]: dragnet-ransomware-2023-1779 — Mass File Rename (raznatovic)
// Status: experimental | Level: high | ID: 2d121da9-a662-5686-9196-ec11728e9ae7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
