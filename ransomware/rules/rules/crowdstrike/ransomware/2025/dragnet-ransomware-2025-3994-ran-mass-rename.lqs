// Dragnet [Ransomware]: dragnet-ransomware-2025-3994 — Mass File Rename (handala)
// Status: experimental | Level: high | ID: 7debc6ee-378e-538a-8bd2-23fb54a823c9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
