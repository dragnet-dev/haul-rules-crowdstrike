// Dragnet [Ransomware]: dragnet-ransomware-2025-2638 — Mass File Rename (J)
// Status: experimental | Level: high | ID: 7e8a150f-c115-56ac-b2ae-cfc8bb1dd02f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
