// Dragnet [Ransomware]: dragnet-ransomware-2023-0468 — Mass File Rename (royal)
// Status: experimental | Level: high | ID: 1312e9b8-35c1-5efb-af40-31382e5bd43e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
