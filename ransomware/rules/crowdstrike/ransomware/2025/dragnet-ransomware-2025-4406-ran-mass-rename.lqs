// Dragnet [Ransomware]: dragnet-ransomware-2025-4406 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: a736dc50-df53-5c43-aee0-0b71bec191e7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
