// Dragnet [Ransomware]: dragnet-ransomware-2025-5636 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 13e50c03-ad81-55af-9c36-d60a02f23c38

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
