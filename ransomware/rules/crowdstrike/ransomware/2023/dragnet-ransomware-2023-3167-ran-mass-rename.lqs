// Dragnet [Ransomware]: dragnet-ransomware-2023-3167 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: ff10e672-7a3b-57b6-8c5e-bf58a9285575

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
