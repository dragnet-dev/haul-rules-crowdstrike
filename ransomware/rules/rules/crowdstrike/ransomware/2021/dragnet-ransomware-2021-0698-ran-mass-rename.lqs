// Dragnet [Ransomware]: dragnet-ransomware-2021-0698 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: af6079cb-21f2-5885-928a-ca3b66a1b5ed

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
