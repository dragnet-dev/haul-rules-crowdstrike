// Dragnet [Ransomware]: dragnet-ransomware-2024-4186 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: d72af89b-44e3-5a5c-9d7c-056951e9c732

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
