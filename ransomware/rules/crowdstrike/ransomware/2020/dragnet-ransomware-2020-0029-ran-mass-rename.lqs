// Dragnet [Ransomware]: dragnet-ransomware-2020-0029 — Mass File Rename (ragnarlocker)
// Status: deprecated | Level: high | ID: 88ef7a52-1090-596b-94df-342e0f4527c6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
