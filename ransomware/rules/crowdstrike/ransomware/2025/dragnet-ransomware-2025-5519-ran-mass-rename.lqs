// Dragnet [Ransomware]: dragnet-ransomware-2025-5519 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 16949944-9b88-505e-b4a6-b5bc378ea765

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
