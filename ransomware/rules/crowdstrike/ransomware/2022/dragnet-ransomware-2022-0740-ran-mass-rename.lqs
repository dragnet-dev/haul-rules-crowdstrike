// Dragnet [Ransomware]: dragnet-ransomware-2022-0740 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: d5e2fc4e-2250-5c43-a510-e378d3baf3a0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
