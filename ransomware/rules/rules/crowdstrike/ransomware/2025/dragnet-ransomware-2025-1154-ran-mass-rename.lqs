// Dragnet [Ransomware]: dragnet-ransomware-2025-1154 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 5edffae2-29d3-597d-acec-aae9ba49669d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
