// Dragnet [Ransomware]: dragnet-ransomware-2023-3230 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 446ba218-1038-5bd7-a87a-715c3f8ece0b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
