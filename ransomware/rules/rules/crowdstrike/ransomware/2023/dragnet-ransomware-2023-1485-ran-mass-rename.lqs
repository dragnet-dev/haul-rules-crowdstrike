// Dragnet [Ransomware]: dragnet-ransomware-2023-1485 — Mass File Rename (darkpower)
// Status: experimental | Level: high | ID: a317af8d-9d77-5392-a405-e8d2052a16b0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
