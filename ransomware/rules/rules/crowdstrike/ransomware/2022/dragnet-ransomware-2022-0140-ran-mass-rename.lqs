// Dragnet [Ransomware]: dragnet-ransomware-2022-0140 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 5fa6004f-b587-5343-b5ff-53050b424633

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
