// Dragnet [Ransomware]: dragnet-ransomware-2023-1256 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: 1b803b3d-f945-5a68-bd13-c2723b6294ed

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
