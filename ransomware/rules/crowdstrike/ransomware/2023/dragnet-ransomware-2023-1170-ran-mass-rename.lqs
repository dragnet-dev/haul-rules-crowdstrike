// Dragnet [Ransomware]: dragnet-ransomware-2023-1170 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: efb3bdc9-69fd-57da-b01e-6132c512ced2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
