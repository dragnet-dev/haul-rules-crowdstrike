// Dragnet [Container]: dragnet-container-2026-0593 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: acd765a7-3604-571e-b8dc-181692eac273

#event_simpleName=*
| (ImageFileName = *azure linux:3.0* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *redhat/ubi9:*)
| table([timestamp, ComputerName])
| limit(1000)
