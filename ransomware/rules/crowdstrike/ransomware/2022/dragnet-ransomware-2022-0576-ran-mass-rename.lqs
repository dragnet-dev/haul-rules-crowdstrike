// Dragnet [Ransomware]: dragnet-ransomware-2022-0576 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 8767ef04-d95a-5297-8100-0af6a455f980

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
