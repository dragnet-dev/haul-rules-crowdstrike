// Dragnet [Ransomware]: dragnet-ransomware-2025-4906 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: 0da4b7d0-e4d6-5ed7-b4b3-45d741f94880

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
