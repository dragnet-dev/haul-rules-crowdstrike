// Dragnet [Ransomware]: dragnet-ransomware-2023-1413 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 754ba56c-3893-5ef3-b8e8-4176e39d1c6a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
