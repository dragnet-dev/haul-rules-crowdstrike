// Dragnet [Ransomware]: dragnet-ransomware-2022-2564 — Mass File Rename (play)
// Status: deprecated | Level: high | ID: 8d09decb-24a6-5198-be9b-9d56e1957f86

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
