// Dragnet [Ransomware]: dragnet-ransomware-2023-2480 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 9580b4b3-4a73-5734-b576-09d975be5e4c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
