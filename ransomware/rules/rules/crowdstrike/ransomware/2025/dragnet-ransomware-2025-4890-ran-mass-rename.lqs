// Dragnet [Ransomware]: dragnet-ransomware-2025-4890 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 488c90bc-8c10-53bc-9376-347f061bb6db

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
