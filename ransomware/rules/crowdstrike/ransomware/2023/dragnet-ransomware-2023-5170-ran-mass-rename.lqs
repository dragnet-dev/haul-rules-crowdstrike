// Dragnet [Ransomware]: dragnet-ransomware-2023-5170 — Mass File Rename (toufan)
// Status: deprecated | Level: high | ID: ff33b1ff-cc5f-5e46-975c-84c77b553f9d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
