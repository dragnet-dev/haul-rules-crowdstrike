// Dragnet [Ransomware]: dragnet-ransomware-2024-2773 — Mass File Rename (abyss)
// Status: deprecated | Level: high | ID: caa2220d-54c8-5803-890b-cab2dd1affd5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
