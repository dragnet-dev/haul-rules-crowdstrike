// Dragnet [Ransomware]: dragnet-ransomware-2026-2692 — Mass File Rename (incransom)
// Status: stable | Level: high | ID: 425380aa-1661-5956-82f3-5d3fac1a8611

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
