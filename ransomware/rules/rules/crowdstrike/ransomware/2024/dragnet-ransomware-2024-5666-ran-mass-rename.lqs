// Dragnet [Ransomware]: dragnet-ransomware-2024-5666 — Mass File Rename (raworld)
// Status: experimental | Level: high | ID: c8323fe2-6e23-5284-b1e6-d0513614b4e7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
