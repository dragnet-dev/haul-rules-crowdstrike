// Dragnet [Ransomware]: dragnet-ransomware-2024-4307 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: b2393c72-7151-580b-be5e-985c04b82f89

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
