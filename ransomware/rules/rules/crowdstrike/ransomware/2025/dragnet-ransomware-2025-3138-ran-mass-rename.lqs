// Dragnet [Ransomware]: dragnet-ransomware-2025-3138 — Mass File Rename (play)
// Status: experimental | Level: high | ID: c5042c96-3274-5de9-83db-cca63f9e3496

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
