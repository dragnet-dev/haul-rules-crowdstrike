// Dragnet [Ransomware]: dragnet-ransomware-2024-3011 — Mass File Rename (play)
// Status: experimental | Level: high | ID: acc3fa9c-272a-5812-b50d-a8556c71c1f6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
