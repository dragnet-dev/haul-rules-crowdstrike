// Dragnet [Container]: dragnet-container-2024-0167 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 95f2eb46-ebd5-5871-aa77-c8fe5029a915

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
