// Dragnet [Ransomware]: dragnet-ransomware-2023-0617 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 103425eb-70e6-57d6-80f0-78b18771b8c9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
