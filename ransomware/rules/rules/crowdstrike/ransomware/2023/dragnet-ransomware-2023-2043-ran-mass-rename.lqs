// Dragnet [Ransomware]: dragnet-ransomware-2023-2043 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 85a58195-000a-5c29-bc3d-65658c22a452

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
