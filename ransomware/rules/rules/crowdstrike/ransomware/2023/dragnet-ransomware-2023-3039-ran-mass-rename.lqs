// Dragnet [Ransomware]: dragnet-ransomware-2023-3039 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: c8140dee-8603-5d1b-a2b8-ffd49e5fe8d4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
