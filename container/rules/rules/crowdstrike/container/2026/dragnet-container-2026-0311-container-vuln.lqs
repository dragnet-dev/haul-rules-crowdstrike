// Dragnet [Container]: dragnet-container-2026-0311 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 7e1c2b4c-6c64-532f-8ebe-3d51fc33bf9a

#event_simpleName=*
| (ImageFileName = *alpine edge:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
