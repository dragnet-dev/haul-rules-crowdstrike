// Dragnet [Ransomware]: dragnet-ransomware-2025-2699 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 2a20c354-f1c2-5a31-834a-80e99ca5c460

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
