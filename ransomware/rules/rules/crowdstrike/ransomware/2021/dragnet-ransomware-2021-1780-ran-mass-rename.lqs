// Dragnet [Ransomware]: dragnet-ransomware-2021-1780 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 030a6f5c-df96-5b10-acce-8594e3b2f577

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
