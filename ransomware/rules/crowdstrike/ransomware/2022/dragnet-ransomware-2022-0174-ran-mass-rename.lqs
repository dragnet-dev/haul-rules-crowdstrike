// Dragnet [Ransomware]: dragnet-ransomware-2022-0174 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: e4a14ec2-454b-5716-bd21-5dfae32c4939

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
