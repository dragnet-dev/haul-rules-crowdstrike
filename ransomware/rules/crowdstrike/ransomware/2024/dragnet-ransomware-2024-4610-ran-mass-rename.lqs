// Dragnet [Ransomware]: dragnet-ransomware-2024-4610 — Mass File Rename (alphalocker)
// Status: experimental | Level: high | ID: 4d8f52d2-981a-5f1f-ae8d-8180fa6bacad

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
