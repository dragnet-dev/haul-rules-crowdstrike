// Dragnet [Ransomware]: dragnet-ransomware-2021-1042 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: c20d7dd0-feda-5640-9eea-d3b45c75bc9c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
