// Dragnet [Ransomware]: dragnet-ransomware-2025-5590 — Mass File Rename (incransom)
// Status: test | Level: high | ID: 4065ecdf-49d7-598c-afed-a3f54fd7acaf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
