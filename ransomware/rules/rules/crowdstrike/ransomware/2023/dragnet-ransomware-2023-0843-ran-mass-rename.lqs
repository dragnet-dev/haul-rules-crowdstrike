// Dragnet [Ransomware]: dragnet-ransomware-2023-0843 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: c86bdc2b-d5fb-5f67-9790-4c6612012015

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
