// Dragnet [Ransomware]: dragnet-ransomware-2024-2393 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: e2f65d52-0795-5b04-b99f-ce8a3103c362

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
