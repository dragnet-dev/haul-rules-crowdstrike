// Dragnet [Ransomware]: dragnet-ransomware-2022-1151 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: ac1ea8b9-88ec-56d0-a7e4-f46d3dd105d1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
