// Dragnet [Ransomware]: dragnet-ransomware-2026-2223 — Mass File Rename (incransom)
// Status: test | Level: high | ID: f20cd4b8-df24-5c2c-8966-9d30ec5e93c2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
