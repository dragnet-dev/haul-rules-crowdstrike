// Dragnet [Ransomware]: dragnet-ransomware-2024-2360 — Mass File Rename (ransomhouse)
// Status: experimental | Level: high | ID: b0ab362f-fd6c-5ccd-afa9-650d290a7e85

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
