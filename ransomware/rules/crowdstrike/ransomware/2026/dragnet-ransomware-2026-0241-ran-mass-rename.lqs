// Dragnet [Ransomware]: dragnet-ransomware-2026-0241 — Mass File Rename (dragonforce)
// Status: stable | Level: high | ID: 478f30cc-0721-5df6-b9c6-3bffaa0200cf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
