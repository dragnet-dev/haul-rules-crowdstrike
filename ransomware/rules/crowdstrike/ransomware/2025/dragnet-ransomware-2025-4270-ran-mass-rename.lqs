// Dragnet [Ransomware]: dragnet-ransomware-2025-4270 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: d1061c26-b44c-5506-8e28-bbdcb500bcee

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
