// Dragnet [Ransomware]: dragnet-ransomware-2025-4343 — Mass File Rename (nightspire)
// Status: experimental | Level: high | ID: 97b8fedd-182e-5db3-a295-bd4799a16103

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
