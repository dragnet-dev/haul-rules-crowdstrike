// Dragnet [Ransomware]: dragnet-ransomware-2022-1229 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: a09f9405-27fd-5e9c-adba-0a7745e3730f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
