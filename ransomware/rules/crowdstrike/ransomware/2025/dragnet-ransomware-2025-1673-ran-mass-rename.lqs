// Dragnet [Ransomware]: dragnet-ransomware-2025-1673 — Mass File Rename (global)
// Status: deprecated | Level: high | ID: 2e19a8b8-d5dd-50de-a52a-46f197b23876

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
