// Dragnet [Container]: dragnet-container-2026-0572 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 7255592b-bb7f-5295-a207-22529222396f

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
