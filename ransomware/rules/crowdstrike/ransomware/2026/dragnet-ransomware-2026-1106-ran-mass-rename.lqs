// Dragnet [Ransomware]: dragnet-ransomware-2026-1106 — Mass File Rename (thegentlemen)
// Status: test | Level: high | ID: 7ce2e857-8d8f-541b-9b4b-818bb4f1dafa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
