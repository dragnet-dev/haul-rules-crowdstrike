// Dragnet [Ransomware]: dragnet-ransomware-2024-4665 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: 2493c307-a918-5d4a-81f5-09aad05e8377

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
