// Dragnet [Ransomware]: dragnet-ransomware-2024-5187 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: af1b3629-2805-5d04-be30-604e78413b02

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
