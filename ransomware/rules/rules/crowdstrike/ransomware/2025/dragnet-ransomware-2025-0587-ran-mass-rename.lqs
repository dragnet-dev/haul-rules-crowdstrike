// Dragnet [Ransomware]: dragnet-ransomware-2025-0587 — Mass File Rename (worldleaks)
// Status: experimental | Level: high | ID: b2023ac5-2ff8-5414-8480-2b472d39990c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
