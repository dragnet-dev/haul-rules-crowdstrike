// Dragnet [Ransomware]: dragnet-ransomware-2024-1401 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 2178c4c1-d4cb-5e44-8575-10ae0e401832

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
