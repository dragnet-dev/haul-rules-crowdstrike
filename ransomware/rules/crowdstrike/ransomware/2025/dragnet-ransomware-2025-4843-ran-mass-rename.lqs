// Dragnet [Ransomware]: dragnet-ransomware-2025-4843 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: 22c730cc-462f-52e5-a3a9-93a34e585e72

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
