// Dragnet [Ransomware]: dragnet-ransomware-2025-5762 — Mass File Rename (ransomhouse)
// Status: test | Level: high | ID: e90ad60e-ad57-5ce8-93eb-5bbc44b7fad5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
