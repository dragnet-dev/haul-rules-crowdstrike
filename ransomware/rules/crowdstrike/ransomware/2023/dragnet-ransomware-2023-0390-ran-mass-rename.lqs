// Dragnet [Ransomware]: dragnet-ransomware-2023-0390 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 6adceb4d-fa3f-50ce-b09d-dfae5f8e8c78

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
