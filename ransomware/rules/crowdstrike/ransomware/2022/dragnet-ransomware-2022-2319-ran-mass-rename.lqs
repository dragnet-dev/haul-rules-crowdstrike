// Dragnet [Ransomware]: dragnet-ransomware-2022-2319 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 68eb0208-7e06-5f8e-8fc8-60cefd03f021

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
