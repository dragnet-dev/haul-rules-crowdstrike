// Dragnet [Ransomware]: dragnet-ransomware-2022-2365 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 8098d43f-e204-5938-aa6f-4e67c5e6a178

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
