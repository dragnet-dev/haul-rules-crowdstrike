// Dragnet [Ransomware]: dragnet-ransomware-2024-5791 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: efe1cee0-df41-53f3-896d-d004ec1eb08c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
