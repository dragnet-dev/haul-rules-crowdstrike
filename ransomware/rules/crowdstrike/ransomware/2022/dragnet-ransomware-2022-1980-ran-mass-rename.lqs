// Dragnet [Ransomware]: dragnet-ransomware-2022-1980 — Mass File Rename (blogxx)
// Status: deprecated | Level: high | ID: e58fb93f-98c7-5b4b-9375-4868a636f3d2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
