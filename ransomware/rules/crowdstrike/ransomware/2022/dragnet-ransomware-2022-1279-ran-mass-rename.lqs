// Dragnet [Ransomware]: dragnet-ransomware-2022-1279 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: c5290ccb-4ac3-5f02-9348-8fa06778d75b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
