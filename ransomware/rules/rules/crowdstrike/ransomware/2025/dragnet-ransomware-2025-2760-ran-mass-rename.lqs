// Dragnet [Ransomware]: dragnet-ransomware-2025-2760 — Mass File Rename (killsec)
// Status: deprecated | Level: high | ID: 84426ca3-a096-5e53-b688-cba093b6223a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
