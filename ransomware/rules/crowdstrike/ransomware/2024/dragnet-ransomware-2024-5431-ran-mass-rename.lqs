// Dragnet [Ransomware]: dragnet-ransomware-2024-5431 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 69fcca18-0711-5efc-84c7-b9ce044afcd5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
