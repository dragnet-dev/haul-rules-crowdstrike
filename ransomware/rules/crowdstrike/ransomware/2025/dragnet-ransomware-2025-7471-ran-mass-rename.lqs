// Dragnet [Ransomware]: dragnet-ransomware-2025-7471 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 887a509d-f24e-5f06-adae-0ee3fe21b2cd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
