// Dragnet [Ransomware]: dragnet-ransomware-2023-3755 — Mass File Rename (royal)
// Status: experimental | Level: high | ID: c05318f2-0d48-576d-8ba0-090213c129eb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
