// Dragnet [Ransomware]: dragnet-ransomware-2023-1881 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: cb9156b5-78dc-54ae-86e9-e510ac5b5953

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
