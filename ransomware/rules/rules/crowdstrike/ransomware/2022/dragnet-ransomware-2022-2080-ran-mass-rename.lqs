// Dragnet [Ransomware]: dragnet-ransomware-2022-2080 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 018989fc-e374-5bee-9ebe-a46bae9a221a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
