// Dragnet [Ransomware]: dragnet-ransomware-2025-5239 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: d734081a-12ac-56de-a376-1e0900b10522

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
