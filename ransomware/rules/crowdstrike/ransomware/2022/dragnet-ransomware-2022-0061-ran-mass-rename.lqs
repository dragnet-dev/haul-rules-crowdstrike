// Dragnet [Ransomware]: dragnet-ransomware-2022-0061 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: b9381478-7984-5d31-b12f-2b8dac28bf9e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
