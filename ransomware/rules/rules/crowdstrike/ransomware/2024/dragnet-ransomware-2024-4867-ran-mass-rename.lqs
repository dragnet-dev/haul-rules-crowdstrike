// Dragnet [Ransomware]: dragnet-ransomware-2024-4867 — Mass File Rename (dAn0n)
// Status: experimental | Level: high | ID: fa51a42e-bae2-58a1-b277-db3b8753c9f1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
