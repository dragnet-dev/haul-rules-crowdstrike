// Dragnet [Ransomware]: dragnet-ransomware-2023-0680 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 7aa44b0e-e7cf-5505-aee3-47133a87d272

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
