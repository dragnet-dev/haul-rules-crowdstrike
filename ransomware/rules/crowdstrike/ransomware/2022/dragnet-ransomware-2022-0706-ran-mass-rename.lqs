// Dragnet [Ransomware]: dragnet-ransomware-2022-0706 — Mass File Rename (vicesociety)
// Status: deprecated | Level: high | ID: 2103a5ec-973f-5756-a5f3-264ebe6cb94b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
