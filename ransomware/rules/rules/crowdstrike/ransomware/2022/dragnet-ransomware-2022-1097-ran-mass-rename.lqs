// Dragnet [Ransomware]: dragnet-ransomware-2022-1097 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 8ac9e6ca-4f08-5379-9447-a054a3011396

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
