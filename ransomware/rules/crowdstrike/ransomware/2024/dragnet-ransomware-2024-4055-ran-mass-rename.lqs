// Dragnet [Ransomware]: dragnet-ransomware-2024-4055 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 3ba21940-36fc-5be3-a869-785b335d2cb3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
