// Dragnet [Ransomware]: dragnet-ransomware-2023-0109 — Mass File Rename (play)
// Status: experimental | Level: high | ID: c40f4dae-ba01-5695-98c8-105057362adb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
