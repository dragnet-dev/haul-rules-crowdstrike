// Dragnet [Container]: dragnet-container-2025-0554 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 498ee136-8615-56fd-9fe8-2969d775e02d

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
