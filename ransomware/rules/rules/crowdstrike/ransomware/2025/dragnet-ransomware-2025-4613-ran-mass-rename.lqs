// Dragnet [Ransomware]: dragnet-ransomware-2025-4613 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 9f7bb38f-28ba-5cc7-980b-65b6a6f481a5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
