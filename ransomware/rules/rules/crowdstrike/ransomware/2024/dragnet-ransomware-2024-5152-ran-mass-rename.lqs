// Dragnet [Ransomware]: dragnet-ransomware-2024-5152 — Mass File Rename (play)
// Status: experimental | Level: high | ID: b1160125-ae43-5ab1-9c3e-4c0e7358a86d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
