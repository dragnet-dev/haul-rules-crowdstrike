// Dragnet [Ransomware]: dragnet-ransomware-2022-3013 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 0fda933c-4612-577e-97cb-0c4c5283051d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
