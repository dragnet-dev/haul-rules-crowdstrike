// Dragnet [Ransomware]: dragnet-ransomware-2024-2735 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 873d8624-10a9-5800-bf41-c645eafda5ce

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
