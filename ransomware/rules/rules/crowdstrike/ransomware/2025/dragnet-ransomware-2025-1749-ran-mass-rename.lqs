// Dragnet [Ransomware]: dragnet-ransomware-2025-1749 — Mass File Rename (arcusmedia)
// Status: experimental | Level: high | ID: 27394e50-73ca-548a-9325-12f01b1bfa58

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
