// Dragnet [Ransomware]: dragnet-ransomware-2025-4832 — Mass File Rename (warlock)
// Status: experimental | Level: high | ID: c5084477-0a0e-5bfc-aaba-781af743e9fd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
