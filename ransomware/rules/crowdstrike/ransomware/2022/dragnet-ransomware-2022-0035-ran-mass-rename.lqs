// Dragnet [Ransomware]: dragnet-ransomware-2022-0035 — Mass File Rename (lv)
// Status: deprecated | Level: high | ID: c03f7250-8126-572e-96ce-8a0ac878f0a4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
