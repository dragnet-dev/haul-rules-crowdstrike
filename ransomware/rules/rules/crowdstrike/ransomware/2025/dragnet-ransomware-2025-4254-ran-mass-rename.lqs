// Dragnet [Ransomware]: dragnet-ransomware-2025-4254 — Mass File Rename (kairos)
// Status: experimental | Level: high | ID: e716e588-c0a7-5b2b-b738-60fb0f2660cf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
