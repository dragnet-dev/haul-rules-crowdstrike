// Dragnet [Ransomware]: dragnet-ransomware-2021-0495 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: dfe9e064-dfd1-5e29-9e51-960eef2121c9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
