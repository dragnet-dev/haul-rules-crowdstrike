// Dragnet [Ransomware]: dragnet-ransomware-2025-3709 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: adfcaa2e-d5d2-525a-bda4-ae36518c0cdc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
