// Dragnet [Ransomware]: dragnet-ransomware-2026-2537 — Mass File Rename (payoutsking)
// Status: test | Level: high | ID: 11bf9897-3786-5bfd-a080-bb100b4a1129

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
