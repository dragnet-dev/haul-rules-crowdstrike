// Dragnet [Ransomware]: dragnet-ransomware-2023-3216 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: f3e0f90e-b9a9-540f-8293-5c110efa8703

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
