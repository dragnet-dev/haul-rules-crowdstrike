// Dragnet [Ransomware]: dragnet-ransomware-2024-4593 — Mass File Rename (safepay)
// Status: deprecated | Level: high | ID: 4b34fd6e-dc63-5159-91b3-9a0edc5ecd1a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
