// Dragnet [Ransomware]: dragnet-ransomware-2025-7557 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 37d9c5e0-51fc-5dea-ad34-7b457e04614a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
