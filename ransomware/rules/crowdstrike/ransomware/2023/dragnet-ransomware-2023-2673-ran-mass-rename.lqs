// Dragnet [Ransomware]: dragnet-ransomware-2023-2673 — Mass File Rename (royal)
// Status: deprecated | Level: high | ID: 455771d3-e01b-5666-b0dc-7e1e0229271b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
