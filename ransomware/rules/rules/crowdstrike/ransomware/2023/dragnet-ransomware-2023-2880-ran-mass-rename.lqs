// Dragnet [Ransomware]: dragnet-ransomware-2023-2880 — Mass File Rename (malas)
// Status: experimental | Level: high | ID: 01f8f5f7-7aaf-5fbb-bc8d-f92cc19d26c3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
