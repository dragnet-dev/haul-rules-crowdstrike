// Dragnet [Ransomware]: dragnet-ransomware-2024-3559 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 447861ca-aca0-59c6-b142-06ef4b78617c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
