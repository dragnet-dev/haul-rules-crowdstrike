// Dragnet [Container]: dragnet-container-2026-3116 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 28cabad4-3270-5db8-8d83-9e5435c8a683

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:6*)
| table([timestamp, ComputerName])
| limit(1000)
