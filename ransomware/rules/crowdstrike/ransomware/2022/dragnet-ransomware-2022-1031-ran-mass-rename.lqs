// Dragnet [Ransomware]: dragnet-ransomware-2022-1031 — Mass File Rename (lv)
// Status: deprecated | Level: high | ID: 1d55388e-5b8a-5b01-8c01-a949903ddcd2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
