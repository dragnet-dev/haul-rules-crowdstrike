// Dragnet [Ransomware]: dragnet-ransomware-2023-5130 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: b71839dc-e6f4-595d-a890-3c6bfadbf893

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
