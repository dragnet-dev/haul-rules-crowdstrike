// Dragnet [Ransomware]: dragnet-ransomware-2025-4591 — Mass File Rename (worldleaks)
// Status: experimental | Level: high | ID: f94b16a7-6527-50e7-9eb8-e400399e0735

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
