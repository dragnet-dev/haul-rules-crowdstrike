// Dragnet [Ransomware]: dragnet-ransomware-2024-1903 — Mass File Rename (handala)
// Status: experimental | Level: high | ID: 3f80ea5d-2b65-5d29-8dca-014f260e50de

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
