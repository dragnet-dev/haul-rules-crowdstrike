// Dragnet [Container]: dragnet-container-2024-0637 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 791796eb-f3b7-5449-bb00-5d098f40ebbe

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:9* OR ImageFileName = *ubuntu:18.04*)
| table([timestamp, ComputerName])
| limit(1000)
