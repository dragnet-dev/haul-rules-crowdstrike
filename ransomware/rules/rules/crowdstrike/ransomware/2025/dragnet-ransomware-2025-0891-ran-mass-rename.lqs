// Dragnet [Ransomware]: dragnet-ransomware-2025-0891 — Mass File Rename (global)
// Status: deprecated | Level: high | ID: ea9732ae-1ead-525b-9f6b-0215aeca98ec

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
