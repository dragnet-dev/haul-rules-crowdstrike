// Dragnet [Ransomware]: dragnet-ransomware-2025-7024 — Mass File Rename (handala)
// Status: experimental | Level: high | ID: 060571db-a76d-52e2-8043-667d828e2382

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
