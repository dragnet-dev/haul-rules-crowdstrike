// Dragnet [Ransomware]: dragnet-ransomware-2024-0062 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 80821f5c-569b-55ce-866b-8cf22943e837

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
