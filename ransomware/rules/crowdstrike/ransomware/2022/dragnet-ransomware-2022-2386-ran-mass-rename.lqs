// Dragnet [Ransomware]: dragnet-ransomware-2022-2386 — Mass File Rename (avoslocker)
// Status: deprecated | Level: high | ID: d8869a7b-6617-5184-9226-81188fb266ef

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
