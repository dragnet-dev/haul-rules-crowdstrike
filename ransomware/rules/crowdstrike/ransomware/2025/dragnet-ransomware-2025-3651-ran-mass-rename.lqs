// Dragnet [Ransomware]: dragnet-ransomware-2025-3651 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: d17be7f1-e5cb-5d68-b638-3bb2d3d36833

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
