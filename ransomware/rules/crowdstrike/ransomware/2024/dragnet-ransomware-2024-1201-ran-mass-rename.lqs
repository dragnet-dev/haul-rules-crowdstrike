// Dragnet [Ransomware]: dragnet-ransomware-2024-1201 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 63d58d05-940e-561c-8fc8-27cb2fcf1270

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
