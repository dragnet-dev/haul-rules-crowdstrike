// Dragnet [Ransomware]: dragnet-ransomware-2021-1409 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: be2e49bd-8e68-5e61-a425-38a5a4f8cf0c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
