// Dragnet [Ransomware]: dragnet-ransomware-2025-2359 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: be9cd14c-3c54-585a-9795-04124958ed94

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
