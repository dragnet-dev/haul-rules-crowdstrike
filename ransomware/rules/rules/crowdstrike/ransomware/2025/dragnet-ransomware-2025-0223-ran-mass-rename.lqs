// Dragnet [Ransomware]: dragnet-ransomware-2025-0223 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: b9ca4f97-097c-519f-af6b-178c154a46f2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
