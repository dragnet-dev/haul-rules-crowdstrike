// Dragnet [Ransomware]: dragnet-ransomware-2022-3098 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: a6c32496-d5eb-5a67-9c1c-d3d48fea39db

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
