// Dragnet [Ransomware]: dragnet-ransomware-2025-2847 — Mass File Rename (sarcoma)
// Status: deprecated | Level: high | ID: ae54fcc3-1db6-584b-a795-99c5fa5f011c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
