// Dragnet [Ransomware]: dragnet-ransomware-2023-4692 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: fc647c37-3387-58bc-b256-67618d232dab

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
