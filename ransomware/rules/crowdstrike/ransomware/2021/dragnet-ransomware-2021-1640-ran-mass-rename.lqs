// Dragnet [Ransomware]: dragnet-ransomware-2021-1640 — Mass File Rename (suncrypt)
// Status: deprecated | Level: high | ID: b24ce27d-8100-5581-956c-47f56522180c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
