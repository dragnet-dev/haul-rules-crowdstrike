// Dragnet [Ransomware]: dragnet-ransomware-2025-0910 — Mass File Rename (kairos)
// Status: experimental | Level: high | ID: f781e04e-af50-526f-8f20-a9c3a4b8fc90

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
