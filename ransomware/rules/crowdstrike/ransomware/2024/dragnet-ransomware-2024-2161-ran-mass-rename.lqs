// Dragnet [Ransomware]: dragnet-ransomware-2024-2161 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 3a53efa2-60f3-5eb7-9ddc-c5a25ee0ce06

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
