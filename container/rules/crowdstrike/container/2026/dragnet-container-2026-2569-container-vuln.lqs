// Status: deprecated | Level: critical | ID: a817a8be-e070-516c-bd54-185964b64fd8

#event_simpleName=*
| (ImageFileName = *debian:7* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:14.04* OR ImageFileName = *ubuntu:14.04-ESM*)
