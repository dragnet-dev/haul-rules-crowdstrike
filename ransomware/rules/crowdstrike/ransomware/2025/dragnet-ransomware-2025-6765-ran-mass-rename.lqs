// Dragnet [Ransomware]: dragnet-ransomware-2025-6765 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: fdf5e085-7f28-5e3f-ab61-8b714407ec7c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
