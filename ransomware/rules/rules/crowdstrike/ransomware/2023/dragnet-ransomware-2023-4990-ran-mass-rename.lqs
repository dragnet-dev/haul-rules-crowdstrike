// Dragnet [Ransomware]: dragnet-ransomware-2023-4990 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 03aba8ee-8795-597d-87dc-2e639e1d9624

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
