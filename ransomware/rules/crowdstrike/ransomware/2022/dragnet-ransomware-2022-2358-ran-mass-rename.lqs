// Dragnet [Ransomware]: dragnet-ransomware-2022-2358 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: aa637eb7-d316-5e0a-86be-2a4f82ebc698

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
