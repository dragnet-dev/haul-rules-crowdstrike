// Dragnet [Ransomware]: dragnet-ransomware-2025-3981 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 957b851c-6590-5301-b09c-172e449608fb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
