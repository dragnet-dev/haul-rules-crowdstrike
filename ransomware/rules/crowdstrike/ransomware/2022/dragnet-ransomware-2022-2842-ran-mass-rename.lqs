// Dragnet [Ransomware]: dragnet-ransomware-2022-2842 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: f02c88fd-b750-5232-94f8-ea2af5b18419

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
