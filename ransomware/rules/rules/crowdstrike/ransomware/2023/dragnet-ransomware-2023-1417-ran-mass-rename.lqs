// Dragnet [Ransomware]: dragnet-ransomware-2023-1417 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 89d380e0-0d22-5929-96b7-6e6454dfb6c0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
