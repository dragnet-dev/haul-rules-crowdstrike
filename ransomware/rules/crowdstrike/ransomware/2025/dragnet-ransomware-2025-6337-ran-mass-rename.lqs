// Dragnet [Ransomware]: dragnet-ransomware-2025-6337 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 575c1360-638a-56e3-a22d-07d43f1ec08f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
