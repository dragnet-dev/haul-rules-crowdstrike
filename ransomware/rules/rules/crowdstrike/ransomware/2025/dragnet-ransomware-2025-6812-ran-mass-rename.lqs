// Dragnet [Ransomware]: dragnet-ransomware-2025-6812 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: d5e1cbc3-a4e0-55d8-84f3-9e3a41a3a603

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
