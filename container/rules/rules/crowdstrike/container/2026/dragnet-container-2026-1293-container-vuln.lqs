// Dragnet [Container]: dragnet-container-2026-1293 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 597c642c-3afe-5f64-a884-fcc9e6acd589

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:7* OR ImageFileName = *debian:8*)
| table([timestamp, ComputerName])
| limit(1000)
