// Dragnet [Ransomware]: dragnet-ransomware-2025-4356 — Mass File Rename (play)
// Status: experimental | Level: high | ID: aee56464-a765-5561-a688-422d6f0f6407

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
