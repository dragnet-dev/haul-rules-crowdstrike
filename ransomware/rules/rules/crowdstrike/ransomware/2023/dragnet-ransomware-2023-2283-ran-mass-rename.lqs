// Dragnet [Ransomware]: dragnet-ransomware-2023-2283 — Mass File Rename (toufan)
// Status: deprecated | Level: high | ID: 050008d3-1788-540d-b0d8-d59ddb92416d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
