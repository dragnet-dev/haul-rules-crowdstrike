// Dragnet [Ransomware]: dragnet-ransomware-2026-1885 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 392cdf22-433d-5504-abd7-161c97f34246

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
