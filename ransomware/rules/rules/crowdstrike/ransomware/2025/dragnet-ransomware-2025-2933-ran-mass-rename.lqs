// Dragnet [Ransomware]: dragnet-ransomware-2025-2933 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: 31fc5ff3-8292-5e4b-a77e-69ace1ab8a39

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
