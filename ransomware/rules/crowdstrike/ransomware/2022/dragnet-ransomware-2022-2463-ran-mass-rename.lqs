// Dragnet [Ransomware]: dragnet-ransomware-2022-2463 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 6ad772c7-3607-513b-94e6-ed532f5ccc5c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
