// Dragnet [Ransomware]: dragnet-ransomware-2025-7030 — Mass File Rename (arcusmedia)
// Status: experimental | Level: high | ID: 70051259-a2ce-593c-9d71-4be0cd5b1b56

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
