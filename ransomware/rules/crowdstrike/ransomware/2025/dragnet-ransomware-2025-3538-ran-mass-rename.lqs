// Dragnet [Ransomware]: dragnet-ransomware-2025-3538 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 70bd3b4d-892d-57c6-bfae-4bd273810d71

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
