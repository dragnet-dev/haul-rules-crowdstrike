// Dragnet [Ransomware]: dragnet-ransomware-2024-3633 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: 491622c8-c0ba-5eb9-b950-c54b3e0a590b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
