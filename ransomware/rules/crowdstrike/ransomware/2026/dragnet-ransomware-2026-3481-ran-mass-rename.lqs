// Dragnet [Ransomware]: dragnet-ransomware-2026-3481 — Mass File Rename (lockbit5)
// Status: stable | Level: high | ID: 7f8e35b8-707f-577d-af3c-9dd2c2935ae2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
