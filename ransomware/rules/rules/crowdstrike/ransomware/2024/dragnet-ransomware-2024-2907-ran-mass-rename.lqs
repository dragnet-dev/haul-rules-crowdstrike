// Dragnet [Ransomware]: dragnet-ransomware-2024-2907 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 325f03bf-23e6-5c90-be4b-0df3a47ef88a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
