// Dragnet [Ransomware]: dragnet-ransomware-2021-1650 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 05119e47-658d-548c-9693-586e9c03fc03

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
