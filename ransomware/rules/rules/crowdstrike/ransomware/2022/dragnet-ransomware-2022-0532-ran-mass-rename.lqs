// Dragnet [Ransomware]: dragnet-ransomware-2022-0532 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: a4e57b22-7f80-507e-b89a-5689b53e091a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
