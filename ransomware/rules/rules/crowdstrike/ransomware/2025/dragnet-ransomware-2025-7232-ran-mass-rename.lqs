// Dragnet [Ransomware]: dragnet-ransomware-2025-7232 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 33d35fc5-64dc-520a-a9de-1c2d6d352c5b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
