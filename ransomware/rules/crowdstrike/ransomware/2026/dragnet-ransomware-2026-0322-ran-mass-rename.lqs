// Dragnet [Ransomware]: dragnet-ransomware-2026-0322 — Mass File Rename (dragonforce)
// Status: stable | Level: high | ID: 068f4908-dc92-5f08-8470-1a6b1a29674d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
