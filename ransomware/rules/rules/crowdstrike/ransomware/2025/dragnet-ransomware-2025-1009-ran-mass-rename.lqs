// Dragnet [Ransomware]: dragnet-ransomware-2025-1009 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: b136e9b2-1c15-5430-9182-2d9d3f9ba0ef

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
