// Dragnet [Ransomware]: dragnet-ransomware-2022-0454 — Mass File Rename (everest)
// Status: deprecated | Level: high | ID: 0b2baa7a-0356-5d8a-a184-a71e955d28cb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
