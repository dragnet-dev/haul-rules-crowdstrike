// Dragnet [Ransomware]: dragnet-ransomware-2025-4736 — Mass File Rename (interlock)
// Status: experimental | Level: high | ID: 5003162a-b0a3-5bb0-b8c3-cfc085a18351

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
