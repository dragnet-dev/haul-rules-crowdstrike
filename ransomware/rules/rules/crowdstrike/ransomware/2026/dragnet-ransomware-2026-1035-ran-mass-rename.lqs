// Dragnet [Ransomware]: dragnet-ransomware-2026-1035 — Mass File Rename (thegentlemen)
// Status: test | Level: high | ID: fa66a80d-2dcd-57b1-b5bb-cb862a27af0d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
