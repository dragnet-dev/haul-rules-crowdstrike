// Dragnet [Ransomware]: dragnet-ransomware-2023-3446 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 4854b75b-cfae-5626-9a4c-5dc55491b352

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
