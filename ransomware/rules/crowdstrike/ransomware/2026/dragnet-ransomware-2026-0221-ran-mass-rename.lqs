// Dragnet [Ransomware]: dragnet-ransomware-2026-0221 — Mass File Rename (killsec)
// Status: deprecated | Level: high | ID: 80b0f34f-5db8-5273-bff1-12f92aaa7649

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
