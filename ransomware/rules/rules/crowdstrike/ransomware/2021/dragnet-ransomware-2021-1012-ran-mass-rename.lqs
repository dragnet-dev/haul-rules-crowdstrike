// Dragnet [Ransomware]: dragnet-ransomware-2021-1012 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 21f36bac-f683-560d-9a29-f75ab1a8e4b9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
