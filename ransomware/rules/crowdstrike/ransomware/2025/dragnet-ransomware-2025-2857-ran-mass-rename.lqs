// Dragnet [Ransomware]: dragnet-ransomware-2025-2857 — Mass File Rename (apt73)
// Status: experimental | Level: high | ID: 44627345-79a1-5bae-a024-c4986aae9c6b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
