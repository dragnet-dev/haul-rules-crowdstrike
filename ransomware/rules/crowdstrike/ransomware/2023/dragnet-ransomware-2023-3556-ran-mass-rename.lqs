// Dragnet [Ransomware]: dragnet-ransomware-2023-3556 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: cefffe39-855f-5b6d-a77d-a46eb6fb52a6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
