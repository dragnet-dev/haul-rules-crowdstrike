// Dragnet [Ransomware]: dragnet-ransomware-2024-2346 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: b5cb2523-aa07-507e-a292-13cd3221be88

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
