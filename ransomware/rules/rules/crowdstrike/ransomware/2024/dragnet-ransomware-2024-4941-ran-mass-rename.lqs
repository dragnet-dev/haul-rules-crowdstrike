// Dragnet [Ransomware]: dragnet-ransomware-2024-4941 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 51a33ced-46ec-5573-b0b1-641b87cd5f70

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
