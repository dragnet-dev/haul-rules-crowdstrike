// Dragnet [Ransomware]: dragnet-ransomware-2023-0937 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: ecf5873f-5a8c-53fe-b03e-e6c1c57b6bb7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
