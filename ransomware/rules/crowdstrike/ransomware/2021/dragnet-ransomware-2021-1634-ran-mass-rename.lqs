// Dragnet [Ransomware]: dragnet-ransomware-2021-1634 — Mass File Rename (avaddon)
// Status: deprecated | Level: high | ID: 309a8cc3-89f7-5f7f-9d34-e27dbaf37947

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
