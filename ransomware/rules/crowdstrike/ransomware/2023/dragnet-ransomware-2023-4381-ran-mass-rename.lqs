// Dragnet [Ransomware]: dragnet-ransomware-2023-4381 — Mass File Rename (play)
// Status: deprecated | Level: high | ID: ac80553d-b2d2-591c-81f8-c462eadde576

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
