// Dragnet [Ransomware]: dragnet-ransomware-2024-1690 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 4e3a43f3-de5e-5bf2-b42b-a55f13fc794c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
