// Dragnet [Ransomware]: dragnet-ransomware-2022-1571 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 35f9cca0-e026-5192-b76a-b026e6c49b3e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
