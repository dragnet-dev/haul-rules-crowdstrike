// Dragnet [Ransomware]: dragnet-ransomware-2024-0962 — Mass File Rename (darkvault)
// Status: experimental | Level: high | ID: 8234345b-c74a-5c38-95f4-42bbec5cc4e2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
