// Dragnet [Ransomware]: dragnet-ransomware-2023-1373 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 8388fcd4-092e-565e-b816-a26cdb277eda

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
