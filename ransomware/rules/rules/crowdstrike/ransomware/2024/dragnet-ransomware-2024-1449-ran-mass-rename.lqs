// Dragnet [Ransomware]: dragnet-ransomware-2024-1449 — Mass File Rename (spacebears)
// Status: experimental | Level: high | ID: b9e5dc1d-2b00-5414-a42f-3b492cc3a5f3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
