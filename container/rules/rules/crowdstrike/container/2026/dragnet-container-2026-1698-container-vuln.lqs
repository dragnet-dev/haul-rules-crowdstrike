// Dragnet [Container]: dragnet-container-2026-1698 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 0d8ebaec-1c84-5b8c-ae01-fae7cf112203

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
