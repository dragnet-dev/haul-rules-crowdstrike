// Dragnet [Ransomware]: dragnet-ransomware-2024-1381 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 11a2e9da-5fbc-5161-b73e-36a3e5d24f3c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
