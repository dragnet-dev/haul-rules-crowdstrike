// Dragnet [Ransomware]: dragnet-ransomware-2025-2256 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 68f6b361-400b-5219-8c40-9a4cfd04a214

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
