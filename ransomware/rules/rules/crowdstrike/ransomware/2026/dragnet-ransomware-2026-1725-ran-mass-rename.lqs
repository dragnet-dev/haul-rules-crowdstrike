// Dragnet [Ransomware]: dragnet-ransomware-2026-1725 — Mass File Rename (SilentRansomGroup)
// Status: deprecated | Level: high | ID: 479d3d9f-5fa4-5256-9335-dfb7bd7ae090

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
