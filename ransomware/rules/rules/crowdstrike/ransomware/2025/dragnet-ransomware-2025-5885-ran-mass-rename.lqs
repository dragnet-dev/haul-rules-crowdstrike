// Dragnet [Ransomware]: dragnet-ransomware-2025-5885 — Mass File Rename (kairos)
// Status: experimental | Level: high | ID: e7189fe1-38c5-5edf-835b-b435cee2b414

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
