// Dragnet [Ransomware]: dragnet-ransomware-2025-7829 — Mass File Rename (payoutsking)
// Status: experimental | Level: high | ID: 262a6154-ab69-5912-8533-a91121ac67fd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
