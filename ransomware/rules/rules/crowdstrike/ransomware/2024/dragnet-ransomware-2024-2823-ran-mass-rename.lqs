// Dragnet [Ransomware]: dragnet-ransomware-2024-2823 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 665d4014-f475-571d-8197-b43385065fd7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
