// Dragnet [Ransomware]: dragnet-ransomware-2024-0355 — Mass File Rename (qilin)
// Status: deprecated | Level: high | ID: 44f183ee-0569-5e0a-a196-7de378db6135

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
