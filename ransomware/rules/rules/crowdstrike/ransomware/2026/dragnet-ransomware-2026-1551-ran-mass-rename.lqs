// Dragnet [Ransomware]: dragnet-ransomware-2026-1551 — Mass File Rename (safepay)
// Status: stable | Level: high | ID: e8f4033c-f7d2-5d2c-adec-4cec39984bef

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
