// Dragnet [Ransomware]: dragnet-ransomware-2025-2527 — Mass File Rename (satanlockv2)
// Status: experimental | Level: high | ID: 24d58dbb-d056-5f5f-801f-6a5046346c92

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
