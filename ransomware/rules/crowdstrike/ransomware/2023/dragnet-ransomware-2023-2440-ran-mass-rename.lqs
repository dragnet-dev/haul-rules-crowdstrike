// Dragnet [Ransomware]: dragnet-ransomware-2023-2440 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 648b0f5b-5617-5ea8-b63d-d74b92cdf18c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
