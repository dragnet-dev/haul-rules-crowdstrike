// Dragnet [Ransomware]: dragnet-ransomware-2024-3262 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: af68678c-4584-5dff-b133-dc9bcaec5813

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
