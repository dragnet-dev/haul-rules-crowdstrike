// Dragnet [Ransomware]: dragnet-ransomware-2025-5017 — Mass File Rename (worldleaks)
// Status: experimental | Level: high | ID: 0f6ed21b-31a6-508d-8a5b-819664ce7afd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
