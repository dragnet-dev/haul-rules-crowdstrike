// Dragnet [Ransomware]: dragnet-ransomware-2024-4122 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: ba713636-3733-5e88-bab3-abcadb5e66dc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
