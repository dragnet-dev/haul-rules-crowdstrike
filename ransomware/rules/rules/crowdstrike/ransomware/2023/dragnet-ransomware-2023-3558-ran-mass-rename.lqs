// Dragnet [Ransomware]: dragnet-ransomware-2023-3558 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 2dfd8f9a-a7c5-5ccd-bacd-dee9bb9b75c2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
