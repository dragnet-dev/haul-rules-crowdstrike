// Dragnet [Container]: dragnet-container-2025-0202 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: e14d921a-1e26-58e1-bfef-16a9ba2b6286

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
