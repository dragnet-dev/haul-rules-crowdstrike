// Dragnet [Ransomware]: dragnet-ransomware-2025-5008 — Mass File Rename (VanHelsing)
// Status: experimental | Level: high | ID: deac222f-d2d3-5cba-9eba-582fb2d86999

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
