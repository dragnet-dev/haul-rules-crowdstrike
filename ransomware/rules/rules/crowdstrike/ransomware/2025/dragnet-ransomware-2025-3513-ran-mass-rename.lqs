// Dragnet [Ransomware]: dragnet-ransomware-2025-3513 — Mass File Rename (coinbasecartel)
// Status: test | Level: high | ID: a2ca20bf-4e59-5b09-97c9-0a10caf02cf3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
