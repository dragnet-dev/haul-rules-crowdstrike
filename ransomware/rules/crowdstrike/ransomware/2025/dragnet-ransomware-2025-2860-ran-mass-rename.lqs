// Dragnet [Ransomware]: dragnet-ransomware-2025-2860 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 49deb5a1-1e9a-596b-a659-e3e78fb4e37d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
