// Dragnet [Ransomware]: dragnet-ransomware-2025-4332 — Mass File Rename (crazyhunter)
// Status: experimental | Level: high | ID: 016d61ff-c5fb-5d21-af65-7779ba4c80f9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
