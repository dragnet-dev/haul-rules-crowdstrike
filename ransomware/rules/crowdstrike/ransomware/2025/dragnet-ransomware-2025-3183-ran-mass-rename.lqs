// Dragnet [Ransomware]: dragnet-ransomware-2025-3183 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 81415403-edfc-5488-9034-e0dbd62792e9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
