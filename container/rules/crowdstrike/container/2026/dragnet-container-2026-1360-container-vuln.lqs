// Dragnet [Container]: dragnet-container-2026-1360 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 8f62fa2e-7ede-5480-ad89-a06e8ccb9a3a

#event_simpleName=*
| (ImageFileName = *almalinux:10* OR ImageFileName = *almalinux:9* OR ImageFileName = *alpine:3.23* OR ImageFileName = *alpine edge:* OR ImageFileName = *azure linux:3.0* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:9* OR ImageFileName = *photon os:4.0* OR ImageFileName = *photon os:5.0*)
| table([timestamp, ComputerName])
| limit(1000)
