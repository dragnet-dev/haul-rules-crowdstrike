// Dragnet [Ransomware]: dragnet-ransomware-2020-0181 — Mass File Rename (revil)
// Status: deprecated | Level: high | ID: 596bca5c-7e62-57d1-891f-ead48717ea76

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
