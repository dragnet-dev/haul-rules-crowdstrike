// Dragnet [Ransomware]: dragnet-ransomware-2024-0249 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: bc57b195-1b70-51a0-8328-61919d267c04

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
