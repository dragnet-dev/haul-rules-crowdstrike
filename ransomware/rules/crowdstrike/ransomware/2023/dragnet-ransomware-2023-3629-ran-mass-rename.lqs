// Dragnet [Ransomware]: dragnet-ransomware-2023-3629 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 59576e7c-4408-5f1a-b9dc-30381625408a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
