// Dragnet [Ransomware]: dragnet-ransomware-2026-2158 — Mass File Rename (kairos)
// Status: deprecated | Level: high | ID: a7b9d945-fc76-5f2f-b5f1-399babf8d921

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
