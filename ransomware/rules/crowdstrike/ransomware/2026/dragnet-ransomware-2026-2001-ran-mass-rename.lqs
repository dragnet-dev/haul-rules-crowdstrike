// Dragnet [Ransomware]: dragnet-ransomware-2026-2001 — Mass File Rename (nightspire)
// Status: deprecated | Level: high | ID: bc816d84-81b3-57ca-b674-64d693919d55

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
