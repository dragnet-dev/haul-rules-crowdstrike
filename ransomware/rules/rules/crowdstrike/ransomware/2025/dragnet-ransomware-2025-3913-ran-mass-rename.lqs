// Dragnet [Ransomware]: dragnet-ransomware-2025-3913 — Mass File Rename (nightspire)
// Status: deprecated | Level: high | ID: 2faaeed4-9ffa-52f9-bd5c-1dc7a27b0d87

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
