// Dragnet [Ransomware]: dragnet-ransomware-2025-6836 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: ac005e46-2040-51ab-ada6-d014b056a257

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
