// Dragnet [Ransomware]: dragnet-ransomware-2023-2007 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 6f7ee562-2bf8-56a4-b8b3-3884221ca797

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
