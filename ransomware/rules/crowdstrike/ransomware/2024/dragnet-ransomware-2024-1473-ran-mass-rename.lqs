// Dragnet [Ransomware]: dragnet-ransomware-2024-1473 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 939623fd-2c1a-5a66-a796-5bb83cf5737b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
