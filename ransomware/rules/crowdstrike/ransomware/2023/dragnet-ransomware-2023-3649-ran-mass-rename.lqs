// Dragnet [Ransomware]: dragnet-ransomware-2023-3649 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 69f7cd52-d427-5f99-aea7-9e1efba740ba

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
