// Dragnet [Ransomware]: dragnet-ransomware-2023-2846 — Mass File Rename (malas)
// Status: experimental | Level: high | ID: 2b9d0617-ee8c-5a7b-8f02-da6386d46263

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
