// Dragnet [Container]: dragnet-container-2025-0144 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 58483424-9892-5748-88bc-b082210e3a63

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
