// Dragnet [Ransomware]: dragnet-ransomware-2025-2710 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 9f19c9b4-50cd-5e10-86b0-554694624328

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
