// Dragnet [Ransomware]: dragnet-ransomware-2022-2625 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 1feaf228-a88f-5346-b2c3-0ba94351f598

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
