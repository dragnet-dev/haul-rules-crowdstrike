// Dragnet [Ransomware]: dragnet-ransomware-2024-3927 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 5f98461b-052f-5813-8cba-9c14cd98a8af

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
