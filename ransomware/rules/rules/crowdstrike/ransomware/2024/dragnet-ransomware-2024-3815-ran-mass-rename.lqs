// Dragnet [Ransomware]: dragnet-ransomware-2024-3815 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 6416df77-47e1-5371-a9e8-a54557c630f3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
