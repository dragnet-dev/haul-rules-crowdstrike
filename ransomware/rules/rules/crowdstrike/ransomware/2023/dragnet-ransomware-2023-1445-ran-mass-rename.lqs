// Dragnet [Ransomware]: dragnet-ransomware-2023-1445 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: b6092887-5de3-545e-ba1a-f360cfe8f2f9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
