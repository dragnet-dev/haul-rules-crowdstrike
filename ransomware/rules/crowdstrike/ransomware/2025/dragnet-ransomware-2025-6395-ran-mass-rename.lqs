// Dragnet [Ransomware]: dragnet-ransomware-2025-6395 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: 4fbbbdb2-9af0-5818-a43e-bfa4ca1bf19c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
