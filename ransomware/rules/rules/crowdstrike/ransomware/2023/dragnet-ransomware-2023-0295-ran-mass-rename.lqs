// Dragnet [Ransomware]: dragnet-ransomware-2023-0295 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 611670ab-bf54-5725-ba9f-048264830afe

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
