// Dragnet [Ransomware]: dragnet-ransomware-2023-0955 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: c7bb3866-26f7-5930-b717-f6b9beed82cc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
