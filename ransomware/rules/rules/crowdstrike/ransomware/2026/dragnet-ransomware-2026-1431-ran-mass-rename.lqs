// Dragnet [Ransomware]: dragnet-ransomware-2026-1431 — Mass File Rename (lockbit5)
// Status: test | Level: high | ID: 8c9c9948-11c8-5c21-b5fd-764bdca061c7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
