// Dragnet [Ransomware]: dragnet-ransomware-2023-4323 — Mass File Rename (losttrust)
// Status: deprecated | Level: high | ID: 5167b917-0ab8-54e4-b687-c489110ff86a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
