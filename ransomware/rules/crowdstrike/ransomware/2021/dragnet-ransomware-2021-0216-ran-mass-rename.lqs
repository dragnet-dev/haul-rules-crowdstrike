// Dragnet [Ransomware]: dragnet-ransomware-2021-0216 — Mass File Rename (xinglocker)
// Status: deprecated | Level: high | ID: eccb72cc-b2dd-5642-bab6-ec59abaf95f6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
