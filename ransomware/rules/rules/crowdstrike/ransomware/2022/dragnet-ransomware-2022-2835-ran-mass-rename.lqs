// Dragnet [Ransomware]: dragnet-ransomware-2022-2835 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: c012b024-fbe0-597c-a537-eb8ee81b1a80

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
