// Dragnet [Ransomware]: dragnet-ransomware-2024-4298 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 02d0adf8-811b-50cf-82d0-bd025628f948

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
