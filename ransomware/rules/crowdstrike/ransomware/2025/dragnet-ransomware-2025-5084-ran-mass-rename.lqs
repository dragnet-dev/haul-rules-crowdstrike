// Dragnet [Ransomware]: dragnet-ransomware-2025-5084 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 48e2584c-fb00-55b8-b9d3-7c3b2ee56475

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
