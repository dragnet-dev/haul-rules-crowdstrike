// Dragnet [Ransomware]: dragnet-ransomware-2023-0357 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 687e3f7f-aa82-5114-9d7f-5f075984c0fa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
