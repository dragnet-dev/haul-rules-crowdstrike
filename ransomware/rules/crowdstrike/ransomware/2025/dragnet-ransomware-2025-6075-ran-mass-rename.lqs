// Dragnet [Ransomware]: dragnet-ransomware-2025-6075 — Mass File Rename (worldleaks)
// Status: experimental | Level: high | ID: d8576af8-73e9-5223-8ca6-e99169a341a1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
