// Dragnet [Ransomware]: dragnet-ransomware-2025-5259 — Mass File Rename (payoutsking)
// Status: test | Level: high | ID: e526f9d0-575b-5aa0-92c7-78c85a96fa15

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
