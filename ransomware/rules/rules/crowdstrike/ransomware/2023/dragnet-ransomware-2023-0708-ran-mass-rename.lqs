// Dragnet [Ransomware]: dragnet-ransomware-2023-0708 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: d1bb8cce-0c70-51ba-9bb0-64758f5d26dc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
