// Dragnet [Ransomware]: dragnet-ransomware-2024-3895 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 6a020c58-e269-5f6f-8969-b8ee696fa04c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
