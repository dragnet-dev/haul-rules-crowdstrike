// Dragnet [Ransomware]: dragnet-ransomware-2022-1176 — Mass File Rename (revil)
// Status: deprecated | Level: high | ID: d8915607-fa69-53de-b695-4b8e14c45b40

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
