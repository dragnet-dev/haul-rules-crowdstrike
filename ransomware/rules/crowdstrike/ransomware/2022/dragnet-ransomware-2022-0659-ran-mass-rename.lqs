// Dragnet [Ransomware]: dragnet-ransomware-2022-0659 — Mass File Rename (cuba)
// Status: deprecated | Level: high | ID: 86afda2f-cd1d-53b4-a8e7-a491793b77c4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
