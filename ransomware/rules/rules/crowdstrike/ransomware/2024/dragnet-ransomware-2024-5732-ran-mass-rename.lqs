// Dragnet [Ransomware]: dragnet-ransomware-2024-5732 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: c537d0f5-9c24-57a1-a8da-4a35d5fd92d0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
