// Dragnet [Ransomware]: dragnet-ransomware-2026-1090 — Mass File Rename (thegentlemen)
// Status: test | Level: high | ID: 68c677b0-d1f3-5477-b11b-c5dcc3eb31cc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
