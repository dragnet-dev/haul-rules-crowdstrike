// Dragnet [Ransomware]: dragnet-ransomware-2025-4466 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: d6263526-9436-51b7-9c40-28ceb1753fc4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
