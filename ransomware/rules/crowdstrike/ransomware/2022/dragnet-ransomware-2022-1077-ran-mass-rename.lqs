// Dragnet [Ransomware]: dragnet-ransomware-2022-1077 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 82e85e34-6051-5e49-9c13-15c887ebb506

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
