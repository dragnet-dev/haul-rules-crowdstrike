// Dragnet [Ransomware]: dragnet-ransomware-2025-0612 — Mass File Rename (cicada3301)
// Status: experimental | Level: high | ID: 660a8aff-2199-5811-aaef-44b6cdc2f9f3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
