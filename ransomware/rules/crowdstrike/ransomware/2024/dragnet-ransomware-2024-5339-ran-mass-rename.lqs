// Dragnet [Ransomware]: dragnet-ransomware-2024-5339 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: ded10ddc-1bb7-5ab9-b3a3-9ae513b46242

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
