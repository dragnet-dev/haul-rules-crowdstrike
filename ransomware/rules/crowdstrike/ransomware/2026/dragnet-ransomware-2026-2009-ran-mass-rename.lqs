// Dragnet [Ransomware]: dragnet-ransomware-2026-2009 — Mass File Rename (krybit)
// Status: stable | Level: high | ID: 2499a95d-5fdf-5cc8-8e37-5db558552f2c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
