// Dragnet [Ransomware]: dragnet-ransomware-2023-1075 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: fc31e786-9e81-576e-975b-be193b870e80

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
