// Dragnet [Container]: dragnet-container-2024-1416 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 56b55ce4-f7ce-5e4c-85d2-1594e0dd2b8c

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:9*)
| table([timestamp, ComputerName])
| limit(1000)
