// Dragnet [Ransomware]: dragnet-ransomware-2020-0088 — Mass File Rename (ragnarlocker)
// Status: deprecated | Level: high | ID: 565f8cc1-2bcb-5d16-8c71-cf541484cd69

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
