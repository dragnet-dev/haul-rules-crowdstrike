// Dragnet [Ransomware]: dragnet-ransomware-2024-3278 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 7cd6d5c0-b386-5cea-8025-ab98a5a2d7c7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
