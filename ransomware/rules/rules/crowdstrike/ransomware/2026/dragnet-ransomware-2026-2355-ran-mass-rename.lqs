// Dragnet [Ransomware]: dragnet-ransomware-2026-2355 — Mass File Rename (incransom)
// Status: stable | Level: high | ID: 9ba82b63-408d-5655-bf56-d94baba1514c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
