// Dragnet [Ransomware]: dragnet-ransomware-2023-3904 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 48c5bf74-06b2-5ea8-bba0-5a4d2d882818

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
