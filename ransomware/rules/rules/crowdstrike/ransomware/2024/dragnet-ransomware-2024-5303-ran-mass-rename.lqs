// Dragnet [Ransomware]: dragnet-ransomware-2024-5303 — Mass File Rename (ransomhouse)
// Status: experimental | Level: high | ID: 2a1356b4-0582-5cd9-986e-86020b501e98

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
