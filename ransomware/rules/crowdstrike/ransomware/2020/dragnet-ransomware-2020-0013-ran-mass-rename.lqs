// Dragnet [Ransomware]: dragnet-ransomware-2020-0013 — Mass File Rename (doppelpaymer)
// Status: deprecated | Level: high | ID: 9d9b5d29-3541-59bc-8063-08bb351a3b59

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
