// Dragnet [Ransomware]: dragnet-ransomware-2025-4834 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: fb328f4c-ecee-5246-ae42-5f8d811946cc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
