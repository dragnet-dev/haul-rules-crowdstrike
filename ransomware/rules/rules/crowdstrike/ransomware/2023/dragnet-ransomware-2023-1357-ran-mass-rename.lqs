// Dragnet [Ransomware]: dragnet-ransomware-2023-1357 — Mass File Rename (toufan)
// Status: deprecated | Level: high | ID: 25216e3a-9832-5d83-b02e-7a6abc02243e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
