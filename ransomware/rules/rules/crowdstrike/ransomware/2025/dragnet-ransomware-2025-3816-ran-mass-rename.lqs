// Dragnet [Ransomware]: dragnet-ransomware-2025-3816 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 6bbadc2e-e19c-5e55-8886-072110b5d2ca

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
