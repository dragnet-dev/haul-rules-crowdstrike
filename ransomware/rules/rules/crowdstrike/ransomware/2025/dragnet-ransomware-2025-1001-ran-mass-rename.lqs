// Dragnet [Ransomware]: dragnet-ransomware-2025-1001 — Mass File Rename (direwolf)
// Status: experimental | Level: high | ID: a9fa094d-6412-5420-b94b-fdc4f0f38d3e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
