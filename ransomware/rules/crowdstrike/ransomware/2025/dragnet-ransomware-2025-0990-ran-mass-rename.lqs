// Dragnet [Ransomware]: dragnet-ransomware-2025-0990 — Mass File Rename (direwolf)
// Status: experimental | Level: high | ID: 77c47659-bd34-5409-8a9e-cc94b1d388d4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
