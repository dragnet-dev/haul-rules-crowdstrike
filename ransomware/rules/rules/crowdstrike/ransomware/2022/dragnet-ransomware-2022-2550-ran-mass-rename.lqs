// Dragnet [Ransomware]: dragnet-ransomware-2022-2550 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: f555e2d5-8a5b-5f07-94b9-3b1b16abf41c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
