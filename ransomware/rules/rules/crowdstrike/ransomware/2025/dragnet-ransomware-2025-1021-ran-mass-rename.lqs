// Dragnet [Ransomware]: dragnet-ransomware-2025-1021 — Mass File Rename (nightspire)
// Status: deprecated | Level: high | ID: 6095d545-56aa-52d7-973e-5d9057d14584

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
