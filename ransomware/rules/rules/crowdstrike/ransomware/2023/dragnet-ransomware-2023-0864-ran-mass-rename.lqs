// Dragnet [Ransomware]: dragnet-ransomware-2023-0864 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 6bf7264a-0338-5a18-b5d4-cbf1b44e52b2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
