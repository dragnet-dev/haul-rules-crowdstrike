// Dragnet [Ransomware]: dragnet-ransomware-2024-2424 — Mass File Rename (monti)
// Status: experimental | Level: high | ID: 48825420-e8b1-5540-85f7-2099435f4947

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
