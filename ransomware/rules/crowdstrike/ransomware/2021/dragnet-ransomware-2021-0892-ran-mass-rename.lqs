// Dragnet [Ransomware]: dragnet-ransomware-2021-0892 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 7bd31f43-8b23-5a98-88f3-30fed4a84767

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
