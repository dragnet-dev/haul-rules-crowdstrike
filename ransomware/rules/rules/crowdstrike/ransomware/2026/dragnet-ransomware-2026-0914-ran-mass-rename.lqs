// Dragnet [Ransomware]: dragnet-ransomware-2026-0914 — Mass File Rename (AuditTeam)
// Status: stable | Level: high | ID: b2e29ff9-dcd6-5407-bea3-f06bb7bd1dd2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
