// Dragnet [Ransomware]: dragnet-ransomware-2023-4964 — Mass File Rename (play)
// Status: experimental | Level: high | ID: dd2b08d2-9c86-5e1e-bc6f-79af75f3bd7f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
