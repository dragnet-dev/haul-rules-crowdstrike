// Dragnet [Ransomware]: dragnet-ransomware-2021-0129 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 17870846-520b-533b-bac6-0068dbce94b5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
