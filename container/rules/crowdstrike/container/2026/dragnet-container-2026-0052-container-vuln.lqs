// Dragnet [Container]: dragnet-container-2026-0052 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 6c2e08dd-1d86-51a8-b466-664de3ff650a

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
