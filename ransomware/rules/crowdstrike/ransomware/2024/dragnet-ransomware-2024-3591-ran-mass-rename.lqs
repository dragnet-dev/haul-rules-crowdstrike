// Dragnet [Ransomware]: dragnet-ransomware-2024-3591 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: c7d030b2-f4d7-5c24-ac87-a0df74748250

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
