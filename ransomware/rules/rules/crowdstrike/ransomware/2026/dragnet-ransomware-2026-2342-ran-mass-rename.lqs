// Dragnet [Ransomware]: dragnet-ransomware-2026-2342 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: c79485be-ac9e-5eb8-93a3-af8dccaaf51c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
