// Dragnet [Ransomware]: dragnet-ransomware-2025-7076 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: eff0488a-c850-5fbc-87be-a11a647fb405

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
