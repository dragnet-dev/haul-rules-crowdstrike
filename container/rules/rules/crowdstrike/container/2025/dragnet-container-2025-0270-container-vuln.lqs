// Dragnet [Container]: dragnet-container-2025-0270 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 85b945e5-254b-5255-9df5-791f20d6aab7

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *redhat/ubi9:*)
| table([timestamp, ComputerName])
| limit(1000)
