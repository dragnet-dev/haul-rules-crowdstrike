// Dragnet [Container]: dragnet-container-2026-2554 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: ba3651da-2566-5017-a8b4-b3b96f644372

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6*)
| table([timestamp, ComputerName])
| limit(1000)
