// Dragnet [Ransomware]: dragnet-ransomware-2024-4651 — Mass File Rename (dragonransomware)
// Status: experimental | Level: high | ID: 461dc10c-2155-5a94-9895-dcd9ab28283f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
