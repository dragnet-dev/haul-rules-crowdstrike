// Dragnet [Ransomware]: dragnet-ransomware-2022-0759 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 626a50fd-08c3-5a9c-8e26-4e32786b98e9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
