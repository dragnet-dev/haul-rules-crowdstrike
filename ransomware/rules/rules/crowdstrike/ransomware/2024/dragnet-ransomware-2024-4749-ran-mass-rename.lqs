// Dragnet [Ransomware]: dragnet-ransomware-2024-4749 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: bceac623-3acf-5d81-891e-771e57ae2f8a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
