// Dragnet [Ransomware]: dragnet-ransomware-2026-2016 — Mass File Rename (safepay)
// Status: stable | Level: high | ID: b6827972-9312-5995-ac6d-74d8b70be69a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
