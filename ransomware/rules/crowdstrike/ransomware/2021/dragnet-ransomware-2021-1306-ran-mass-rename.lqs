// Dragnet [Ransomware]: dragnet-ransomware-2021-1306 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 183f5a71-434f-54e1-90ff-9c87316c0b35

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
