// Dragnet [Ransomware]: dragnet-ransomware-2020-0210 — Mass File Rename (revil)
// Status: deprecated | Level: high | ID: b35e9269-3f7d-5809-bcc8-eace996d2a24

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
