// Dragnet [Container]: dragnet-container-2025-0425 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 39d63a4d-2076-58c9-9eec-37b56005cd6e

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *redhat/ubi9:*)
| table([timestamp, ComputerName])
| limit(1000)
