// Dragnet [Ransomware]: dragnet-ransomware-2023-3809 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 13ce9514-78c5-55c2-8d0d-c6da0a853b9f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
