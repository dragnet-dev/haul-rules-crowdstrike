// Dragnet [Ransomware]: dragnet-ransomware-2022-1276 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 97a04ffe-c13c-57e9-ab17-970796c080ac

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
