// Dragnet [Ransomware]: dragnet-ransomware-2025-7702 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 5d94c003-248d-5fa5-88b9-0f09b5b44a5e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
