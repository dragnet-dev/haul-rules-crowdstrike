// Dragnet [Ransomware]: dragnet-ransomware-2025-0595 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 3cb65e4d-f804-536f-ac60-70d75654f84c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
