// Dragnet [Ransomware]: dragnet-ransomware-2023-1663 — Mass File Rename (play)
// Status: experimental | Level: high | ID: e097359e-dee6-58d8-9a17-87a5a5b09ecb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
