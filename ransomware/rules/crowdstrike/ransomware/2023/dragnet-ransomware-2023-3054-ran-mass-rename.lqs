// Dragnet [Ransomware]: dragnet-ransomware-2023-3054 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: b7aee576-0518-58e9-80e9-24d165cacad2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
