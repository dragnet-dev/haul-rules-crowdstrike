// Dragnet [Ransomware]: dragnet-ransomware-2021-0542 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 31c0d6ad-666d-5ba3-b4e8-c30580d18d7a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
