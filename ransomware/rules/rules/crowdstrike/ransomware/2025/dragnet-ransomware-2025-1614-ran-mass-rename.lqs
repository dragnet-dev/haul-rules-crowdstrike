// Dragnet [Ransomware]: dragnet-ransomware-2025-1614 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: a0a3607d-42ce-5d17-af31-5bc0785170f3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
