// Dragnet [Ransomware]: dragnet-ransomware-2025-4371 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: cf55c7fd-525c-5f7e-bd31-219d59e783c8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
