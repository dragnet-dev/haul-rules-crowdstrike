// Dragnet [Ransomware]: dragnet-ransomware-2023-0954 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: 8b1f0f35-e23d-5313-8b5d-28f7feac181d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
