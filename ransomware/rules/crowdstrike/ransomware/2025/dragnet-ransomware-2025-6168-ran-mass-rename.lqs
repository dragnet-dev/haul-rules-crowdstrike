// Dragnet [Ransomware]: dragnet-ransomware-2025-6168 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: c75f9a62-8a0c-560b-ab94-302f920530b5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
