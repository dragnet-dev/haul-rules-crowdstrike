// Dragnet [Ransomware]: dragnet-ransomware-2024-0685 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: b1a171c7-71da-579e-8265-a54686ad3b4d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
