// Dragnet [Ransomware]: dragnet-ransomware-2025-7299 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 95b78200-bbc4-5b6c-b631-f3067f76cb4f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
