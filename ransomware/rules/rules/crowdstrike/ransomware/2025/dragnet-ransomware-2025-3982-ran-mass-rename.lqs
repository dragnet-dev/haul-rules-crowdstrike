// Dragnet [Ransomware]: dragnet-ransomware-2025-3982 — Mass File Rename (minteye)
// Status: deprecated | Level: high | ID: 9a0d431a-7e0e-54f5-a42f-2b8060027f65

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
