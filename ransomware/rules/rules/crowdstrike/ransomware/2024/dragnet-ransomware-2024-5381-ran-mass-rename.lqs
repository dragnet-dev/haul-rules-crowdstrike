// Dragnet [Ransomware]: dragnet-ransomware-2024-5381 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 255cda38-8d60-52da-bc30-e6b650e90b17

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
