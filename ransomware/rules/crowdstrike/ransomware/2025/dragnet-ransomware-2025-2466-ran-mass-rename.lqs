// Dragnet [Ransomware]: dragnet-ransomware-2025-2466 — Mass File Rename (thegentlemen)
// Status: test | Level: high | ID: 75852b95-0eb7-5a49-9db4-0e0ec6c2d276

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
