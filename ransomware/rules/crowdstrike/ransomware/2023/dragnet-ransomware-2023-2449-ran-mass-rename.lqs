// Dragnet [Ransomware]: dragnet-ransomware-2023-2449 — Mass File Rename (ransomed)
// Status: experimental | Level: high | ID: 2234ff52-5fb2-50d8-a8d1-1d68f0fe77f5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
