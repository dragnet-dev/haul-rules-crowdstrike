// Dragnet [Ransomware]: dragnet-ransomware-2025-3638 — Mass File Rename (coinbasecartel)
// Status: test | Level: high | ID: 362d4c00-677a-5156-8722-c4cdac410b4e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
