// Dragnet [Ransomware]: dragnet-ransomware-2024-5707 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: b7742af8-f37c-5ea0-a69e-427ff308b95f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
