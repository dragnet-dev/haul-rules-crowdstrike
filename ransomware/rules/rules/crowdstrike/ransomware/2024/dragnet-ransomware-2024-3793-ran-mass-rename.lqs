// Dragnet [Ransomware]: dragnet-ransomware-2024-3793 — Mass File Rename (threeam)
// Status: experimental | Level: high | ID: 6a2a17fa-1c61-5a0a-b9a5-ffff3634484d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
