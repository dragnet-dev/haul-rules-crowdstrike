// Dragnet [Ransomware]: dragnet-ransomware-2026-0957 — Mass File Rename (everest)
// Status: stable | Level: high | ID: f408f8de-ab94-57df-ad5b-7b9ffa25dadf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
