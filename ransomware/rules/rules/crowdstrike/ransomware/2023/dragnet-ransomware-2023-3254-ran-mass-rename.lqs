// Dragnet [Ransomware]: dragnet-ransomware-2023-3254 — Mass File Rename (ransomed)
// Status: experimental | Level: high | ID: 61361ae3-d349-52df-b1c8-f27c9bc13de8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
