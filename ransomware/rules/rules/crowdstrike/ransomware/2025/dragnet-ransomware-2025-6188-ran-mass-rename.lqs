// Dragnet [Ransomware]: dragnet-ransomware-2025-6188 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 91e57ec4-fd39-5b67-a86f-27dbc0a4a6ff

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
