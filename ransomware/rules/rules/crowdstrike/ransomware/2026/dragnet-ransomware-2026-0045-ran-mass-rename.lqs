// Dragnet [Ransomware]: dragnet-ransomware-2026-0045 — Mass File Rename (worldleaks)
// Status: stable | Level: high | ID: cbc8f1b7-71b9-501e-a383-4706b4c69a06

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
