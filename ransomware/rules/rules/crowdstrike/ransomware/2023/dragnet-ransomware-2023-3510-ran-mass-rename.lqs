// Dragnet [Ransomware]: dragnet-ransomware-2023-3510 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: be21cc48-2cf3-5acf-868f-32b0ae6be29d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
