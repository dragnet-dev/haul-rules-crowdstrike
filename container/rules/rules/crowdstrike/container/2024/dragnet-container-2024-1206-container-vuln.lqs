// Dragnet [Container]: dragnet-container-2024-1206 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: e50d62a1-9c51-5211-99bb-cae8d7cfc1ea

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:7* OR ImageFileName = *debian:8* OR ImageFileName = *debian:9*)
| table([timestamp, ComputerName])
| limit(1000)
