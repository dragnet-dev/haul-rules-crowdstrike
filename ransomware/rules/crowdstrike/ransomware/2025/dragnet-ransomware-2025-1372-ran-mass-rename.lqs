// Dragnet [Ransomware]: dragnet-ransomware-2025-1372 — Mass File Rename (cephalus)
// Status: experimental | Level: high | ID: 59e544a4-1aaa-524c-9462-20dc3c3bcfdd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
