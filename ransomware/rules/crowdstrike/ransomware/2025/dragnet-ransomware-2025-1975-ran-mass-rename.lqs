// Dragnet [Ransomware]: dragnet-ransomware-2025-1975 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 85c540a1-6e5a-5193-8dc8-31e33ae2e631

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
