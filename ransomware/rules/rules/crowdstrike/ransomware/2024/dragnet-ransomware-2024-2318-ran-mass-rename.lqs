// Dragnet [Ransomware]: dragnet-ransomware-2024-2318 — Mass File Rename (dAn0n)
// Status: experimental | Level: high | ID: 4e833fca-ccc1-5ebe-af53-cec3aa299b57

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
