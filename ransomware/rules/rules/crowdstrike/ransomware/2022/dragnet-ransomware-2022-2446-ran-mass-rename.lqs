// Dragnet [Ransomware]: dragnet-ransomware-2022-2446 — Mass File Rename (ragnarlocker)
// Status: experimental | Level: high | ID: 03d32a3e-5952-5ffc-8636-697207f8973d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
