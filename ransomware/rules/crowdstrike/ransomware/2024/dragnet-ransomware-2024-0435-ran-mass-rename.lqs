// Dragnet [Ransomware]: dragnet-ransomware-2024-0435 — Mass File Rename (rhysida)
// Status: deprecated | Level: high | ID: b402df22-cd75-5f90-a3af-5239be3793c6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
