// Dragnet [Ransomware]: dragnet-ransomware-2023-3998 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 44472411-033d-551e-b89f-efaf02a9362b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
