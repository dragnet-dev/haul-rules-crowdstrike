// Dragnet [Ransomware]: dragnet-ransomware-2023-0234 — Mass File Rename (ransomed)
// Status: deprecated | Level: high | ID: 5c8c686e-820d-55e4-a384-cf80b0b68d61

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
