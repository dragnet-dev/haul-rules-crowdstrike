// Dragnet [Ransomware]: dragnet-ransomware-2022-0360 — Mass File Rename (blackbasta)
// Status: deprecated | Level: high | ID: 27dc350c-db1e-593c-bcdc-2f001b862586

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
