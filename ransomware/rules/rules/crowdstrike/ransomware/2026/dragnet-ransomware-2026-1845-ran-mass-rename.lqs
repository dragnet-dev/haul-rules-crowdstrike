// Dragnet [Ransomware]: dragnet-ransomware-2026-1845 — Mass File Rename (SilentRansomGroup)
// Status: deprecated | Level: high | ID: c92ecd3b-b0b8-570a-9b20-9ab911e462a7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
