// Dragnet [Ransomware]: dragnet-ransomware-2025-0417 — Mass File Rename (anubis)
// Status: experimental | Level: high | ID: 04b88614-29f2-558e-8bf3-3d5a39ab8f2a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
