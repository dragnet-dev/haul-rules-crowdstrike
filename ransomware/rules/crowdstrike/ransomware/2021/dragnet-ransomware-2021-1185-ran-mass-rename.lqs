// Dragnet [Ransomware]: dragnet-ransomware-2021-1185 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: b587e263-0dd2-573b-aac2-1525a93d0f79

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
