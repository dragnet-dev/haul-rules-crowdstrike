// Dragnet [Ransomware]: dragnet-ransomware-2023-1900 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 90706bb5-183a-5573-8eff-078885487394

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
