// Dragnet [Ransomware]: dragnet-ransomware-2024-3093 — Mass File Rename (argonauts)
// Status: experimental | Level: high | ID: f9b315f6-d3fa-58c3-8e58-2bbce39cc075

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
