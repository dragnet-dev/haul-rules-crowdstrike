// Dragnet [Container]: dragnet-container-2026-3130 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 10a62095-c340-57cd-bfa0-df5d7c3e3db6

#event_simpleName=*
| (ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10*)
| table([timestamp, ComputerName])
| limit(1000)
