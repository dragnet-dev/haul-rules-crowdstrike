// Dragnet [Ransomware]: dragnet-ransomware-2023-3534 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 235a8bbd-0a0c-598f-b4a4-1a8938133671

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
