// Dragnet [Ransomware]: dragnet-ransomware-2024-2897 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: e33eeb49-76ae-5086-88c8-946352017d06

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
