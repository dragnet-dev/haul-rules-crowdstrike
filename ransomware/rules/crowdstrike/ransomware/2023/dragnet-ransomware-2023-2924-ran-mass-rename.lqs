// Dragnet [Ransomware]: dragnet-ransomware-2023-2924 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 70202137-d80d-5f2d-ad10-e3344a84eb67

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
