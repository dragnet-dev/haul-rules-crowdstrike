// Dragnet [Ransomware]: dragnet-ransomware-2025-2931 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: a9e6e688-62e7-5150-b230-c978307066c8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
