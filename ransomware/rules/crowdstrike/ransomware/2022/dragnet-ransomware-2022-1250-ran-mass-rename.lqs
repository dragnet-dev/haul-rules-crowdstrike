// Dragnet [Ransomware]: dragnet-ransomware-2022-1250 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 9954fb8c-38f2-54a9-a468-a31192f83f7e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
