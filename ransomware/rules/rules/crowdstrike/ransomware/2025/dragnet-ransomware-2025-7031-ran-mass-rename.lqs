// Dragnet [Ransomware]: dragnet-ransomware-2025-7031 — Mass File Rename (sinobi)
// Status: experimental | Level: high | ID: bede3857-2508-5446-a192-9562c120e9da

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
