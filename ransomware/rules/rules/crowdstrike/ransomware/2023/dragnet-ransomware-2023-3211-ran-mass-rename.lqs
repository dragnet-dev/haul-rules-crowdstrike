// Dragnet [Ransomware]: dragnet-ransomware-2023-3211 — Mass File Rename (cuba)
// Status: deprecated | Level: high | ID: 88155b04-9502-5510-a9ab-09c1cdadd297

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
