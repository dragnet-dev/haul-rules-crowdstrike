// Dragnet [Ransomware]: dragnet-ransomware-2026-2901 — Mass File Rename (stormous)
// Status: deprecated | Level: high | ID: 073008fb-da0b-5d42-bc35-5516ee97827f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
