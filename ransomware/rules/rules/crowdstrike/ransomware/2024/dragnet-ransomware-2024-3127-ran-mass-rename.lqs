// Dragnet [Ransomware]: dragnet-ransomware-2024-3127 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: 2f7daacb-89a5-5885-b175-3f663f79b495

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
