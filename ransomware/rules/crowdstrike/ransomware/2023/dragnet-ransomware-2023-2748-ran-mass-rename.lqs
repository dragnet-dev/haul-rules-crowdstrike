// Dragnet [Ransomware]: dragnet-ransomware-2023-2748 — Mass File Rename (malas)
// Status: experimental | Level: high | ID: 0a536a61-f332-5b94-baa1-06ecf1db8a99

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
