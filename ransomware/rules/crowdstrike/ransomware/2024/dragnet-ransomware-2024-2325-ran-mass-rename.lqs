// Dragnet [Ransomware]: dragnet-ransomware-2024-2325 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: 7fd580b1-2939-5474-adad-9fe35d97d7e7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
