// Dragnet [Ransomware]: dragnet-ransomware-2025-5586 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 01f085fa-9b1f-52b0-b408-9cb13bfb1a16

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
