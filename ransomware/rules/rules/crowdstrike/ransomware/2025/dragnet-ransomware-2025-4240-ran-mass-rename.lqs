// Dragnet [Ransomware]: dragnet-ransomware-2025-4240 — Mass File Rename (BrainCipher)
// Status: experimental | Level: high | ID: 5ca299eb-9534-547c-8508-a05c3968dfa6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
