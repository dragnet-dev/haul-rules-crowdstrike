// Dragnet [Container]: dragnet-container-2026-1985 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 891c3d1d-c8ca-521d-934a-13e2662c720c

#event_simpleName=*
| (ImageFileName = *amazonlinux:1* OR ImageFileName = *chainguard:* OR ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10* OR ImageFileName = *ubuntu:13.04* OR ImageFileName = *ubuntu:13.10*)
| table([timestamp, ComputerName])
| limit(1000)
