// Dragnet [Ransomware]: dragnet-ransomware-2023-1105 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: b97efcfb-838d-5c89-a420-186654f698d9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
