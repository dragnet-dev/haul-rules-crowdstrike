// Dragnet [Container]: dragnet-container-2024-0271 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: e1df02ff-8c4d-5e1b-b2ca-161908587d89

#event_simpleName=*
| (ImageFileName = *alpine:3.10* OR ImageFileName = *alpine:3.11* OR ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:9* OR ImageFileName = *ubuntu:16.04-ESM* OR ImageFileName = *ubuntu:18.04* OR ImageFileName = *ubuntu:18.04-ESM* OR ImageFileName = *ubuntu:20.04* OR ImageFileName = *ubuntu:20.04-ESM* OR ImageFileName = *ubuntu:20.10*)
| table([timestamp, ComputerName])
| limit(1000)
