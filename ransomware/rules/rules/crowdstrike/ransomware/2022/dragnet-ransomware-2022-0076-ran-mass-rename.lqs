// Dragnet [Ransomware]: dragnet-ransomware-2022-0076 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 05e09df6-3e16-5bec-bfe8-f2dfe52c42c5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
