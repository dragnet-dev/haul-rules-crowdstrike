// Dragnet [Ransomware]: dragnet-ransomware-2024-0558 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: f235bcbd-6cf0-5d4a-bfcf-9602a7ca3845

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
