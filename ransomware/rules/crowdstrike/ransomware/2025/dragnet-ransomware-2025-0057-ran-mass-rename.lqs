// Dragnet [Ransomware]: dragnet-ransomware-2025-0057 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: f4db5c90-02da-5307-8cf2-1a51513337e2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
