// Dragnet [Ransomware]: dragnet-ransomware-2025-3835 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: 8e78b722-0965-5ce7-811d-a9ac4c866424

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
