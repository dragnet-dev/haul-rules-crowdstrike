// Dragnet [Ransomware]: dragnet-ransomware-2023-3524 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: fc1f073e-ea80-5e9c-846e-500afceda133

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
