// Dragnet [Ransomware]: dragnet-ransomware-2020-0192 — Mass File Rename (ragnarlocker)
// Status: deprecated | Level: high | ID: ccf59a25-21cf-509c-b665-63e39186fd53

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
