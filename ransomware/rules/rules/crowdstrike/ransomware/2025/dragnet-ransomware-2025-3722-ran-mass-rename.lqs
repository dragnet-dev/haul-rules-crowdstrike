// Dragnet [Ransomware]: dragnet-ransomware-2025-3722 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: d2d5501d-26cb-5766-959c-2b4ba67858d0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
