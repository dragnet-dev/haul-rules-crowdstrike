// Dragnet [Ransomware]: dragnet-ransomware-2024-0199 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 8094767c-e9f9-577c-b527-5eebf1f6aa23

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
