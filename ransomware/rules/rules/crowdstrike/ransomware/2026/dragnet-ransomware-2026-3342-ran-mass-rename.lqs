// Dragnet [Ransomware]: dragnet-ransomware-2026-3342 — Mass File Rename (incransom)
// Status: stable | Level: high | ID: b301448a-08b0-5187-8532-6a531c8df0bf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
