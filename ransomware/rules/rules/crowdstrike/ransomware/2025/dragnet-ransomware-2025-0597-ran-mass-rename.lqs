// Dragnet [Ransomware]: dragnet-ransomware-2025-0597 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 3b444bf5-550d-507d-861f-293361265399

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
