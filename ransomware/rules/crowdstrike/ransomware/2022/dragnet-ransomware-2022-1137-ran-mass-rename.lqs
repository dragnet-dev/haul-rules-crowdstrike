// Dragnet [Ransomware]: dragnet-ransomware-2022-1137 — Mass File Rename (royal)
// Status: deprecated | Level: high | ID: 22210870-0d8d-5150-b274-40fe04a0abb3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
