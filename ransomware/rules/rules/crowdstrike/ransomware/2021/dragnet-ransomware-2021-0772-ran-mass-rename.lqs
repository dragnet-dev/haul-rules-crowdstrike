// Dragnet [Ransomware]: dragnet-ransomware-2021-0772 — Mass File Rename (suncrypt)
// Status: deprecated | Level: high | ID: 7964ed4e-23cc-5cee-a651-34ffa0a4bd9a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
