// Dragnet [Ransomware]: dragnet-ransomware-2025-2914 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: d92793e9-972e-51e7-89bf-e9522b3f283c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
