// Dragnet [Ransomware]: dragnet-ransomware-2025-7913 — Mass File Rename (kazu)
// Status: experimental | Level: high | ID: 25196368-8c5d-5261-b8ae-c3debec3fbd5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
