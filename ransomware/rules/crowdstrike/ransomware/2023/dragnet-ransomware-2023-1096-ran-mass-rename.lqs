// Dragnet [Ransomware]: dragnet-ransomware-2023-1096 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: e0583216-fe22-54ec-a4c4-12feb2d0dd51

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
