// Dragnet [Ransomware]: dragnet-ransomware-2025-6283 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: fbd20bc7-d1bd-5c33-a782-19ead8787171

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
