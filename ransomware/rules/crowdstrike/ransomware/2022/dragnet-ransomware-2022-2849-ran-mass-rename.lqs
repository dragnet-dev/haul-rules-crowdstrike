// Dragnet [Ransomware]: dragnet-ransomware-2022-2849 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: c4b9ac40-869c-556e-84f0-e0632fc1497c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
