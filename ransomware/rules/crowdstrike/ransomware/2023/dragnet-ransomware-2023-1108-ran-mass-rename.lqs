// Dragnet [Ransomware]: dragnet-ransomware-2023-1108 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: e048effe-dc8e-54b0-9439-5e730fb13738

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
