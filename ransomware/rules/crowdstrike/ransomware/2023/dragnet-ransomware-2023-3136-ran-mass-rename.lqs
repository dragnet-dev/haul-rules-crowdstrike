// Dragnet [Ransomware]: dragnet-ransomware-2023-3136 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 86f92643-2de0-5c8f-b772-6600e317c6ca

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
