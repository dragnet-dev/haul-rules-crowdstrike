// Dragnet [Ransomware]: dragnet-ransomware-2023-5226 — Mass File Rename (snatch)
// Status: experimental | Level: high | ID: 312078fa-51fa-50be-b7b9-6eaf23b2ae6e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
