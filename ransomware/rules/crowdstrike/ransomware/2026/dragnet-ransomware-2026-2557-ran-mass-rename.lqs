// Dragnet [Ransomware]: dragnet-ransomware-2026-2557 — Mass File Rename (everest)
// Status: stable | Level: high | ID: 284b2aa8-7856-5c89-95f8-ede092cba109

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
