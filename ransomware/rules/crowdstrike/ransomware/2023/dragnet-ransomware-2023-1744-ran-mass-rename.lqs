// Dragnet [Ransomware]: dragnet-ransomware-2023-1744 — Mass File Rename (stormous)
// Status: experimental | Level: high | ID: 1aed0ada-2765-544a-9bbb-7b440d1217f4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
