// Dragnet [Ransomware]: dragnet-ransomware-2025-2454 — Mass File Rename (thegentlemen)
// Status: experimental | Level: high | ID: d4b2b42d-38dd-5521-b46d-d218b2094ea3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
