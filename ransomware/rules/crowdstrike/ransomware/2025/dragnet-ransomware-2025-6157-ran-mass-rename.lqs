// Dragnet [Ransomware]: dragnet-ransomware-2025-6157 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 0e167a36-5aa8-5219-975d-a74971d58184

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
