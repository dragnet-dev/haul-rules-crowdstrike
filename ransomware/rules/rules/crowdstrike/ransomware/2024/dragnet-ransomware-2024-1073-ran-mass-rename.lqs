// Dragnet [Ransomware]: dragnet-ransomware-2024-1073 — Mass File Rename (meow)
// Status: experimental | Level: high | ID: d9a1cb5d-2875-5989-8e8c-e7aa95e5c9d9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
