// Dragnet [Container]: dragnet-container-2024-1452 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 0a77f04e-112a-5102-af9c-ca171edd5c06

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:9* OR ImageFileName = *ubuntu:18.04* OR ImageFileName = *ubuntu:18.04-ESM* OR ImageFileName = *ubuntu:18.10*)
| table([timestamp, ComputerName])
| limit(1000)
