// Dragnet [Ransomware]: dragnet-ransomware-2025-2419 — Mass File Rename (thegentlemen)
// Status: experimental | Level: high | ID: 92f75bd8-e18a-50a5-8feb-244cab9a7d2f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
