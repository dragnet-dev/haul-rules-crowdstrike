// Dragnet [Ransomware]: dragnet-ransomware-2025-5073 — Mass File Rename (sarcoma)
// Status: deprecated | Level: high | ID: 9e77f363-e008-5d9d-8d87-4e5a226a48bf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
