// Dragnet [Ransomware]: dragnet-ransomware-2022-1449 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: a59ae693-e16e-550f-a8cb-6da522a9d25e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
