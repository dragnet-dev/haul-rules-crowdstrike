// Dragnet [Ransomware]: dragnet-ransomware-2023-1279 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 5f1e65ca-0b4e-53a3-92e5-ebec55f0f84e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
