// Dragnet [Ransomware]: dragnet-ransomware-2023-0716 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 5b88e575-0526-5d7b-a503-75e02ef9a39d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
