// Dragnet [Ransomware]: dragnet-ransomware-2021-0658 — Mass File Rename (groove)
// Status: deprecated | Level: high | ID: be96d030-1788-58cb-9b76-4beb800e1b86

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
