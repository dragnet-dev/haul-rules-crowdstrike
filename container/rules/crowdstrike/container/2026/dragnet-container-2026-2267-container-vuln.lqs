// Dragnet [Container]: dragnet-container-2026-2267 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 7c9b4a22-2e2b-528d-83f9-c32275118bf5

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
