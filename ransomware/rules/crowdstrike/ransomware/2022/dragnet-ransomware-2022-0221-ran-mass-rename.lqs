// Dragnet [Ransomware]: dragnet-ransomware-2022-0221 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 82aef3b5-283c-5f13-8738-d8a4e7f7c0a8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
