// Dragnet [Ransomware]: dragnet-ransomware-2024-2006 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 0162b7d6-d48f-5287-b9f7-aa34cc1094f9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
