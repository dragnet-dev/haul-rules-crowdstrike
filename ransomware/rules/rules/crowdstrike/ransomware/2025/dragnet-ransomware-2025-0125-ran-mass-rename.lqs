// Dragnet [Ransomware]: dragnet-ransomware-2025-0125 — Mass File Rename (rhysida)
// Status: deprecated | Level: high | ID: 3f3056d4-5190-54d2-acee-069fab4b3164

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
