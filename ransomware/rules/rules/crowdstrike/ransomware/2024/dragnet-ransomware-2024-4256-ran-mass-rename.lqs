// Dragnet [Ransomware]: dragnet-ransomware-2024-4256 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 85ff7916-83df-5cdf-851e-77ce6701c40d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
