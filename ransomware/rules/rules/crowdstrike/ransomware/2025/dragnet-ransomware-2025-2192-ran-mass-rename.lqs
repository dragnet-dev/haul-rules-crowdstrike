// Dragnet [Ransomware]: dragnet-ransomware-2025-2192 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 69d56d38-2f78-52ef-90a7-766e4be9b41b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
