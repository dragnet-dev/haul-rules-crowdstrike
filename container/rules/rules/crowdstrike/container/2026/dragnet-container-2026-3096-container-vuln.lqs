// Dragnet [Container]: dragnet-container-2026-3096 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: ef5704c1-8680-5e9d-bad3-a56b69231842

#event_simpleName=*
| (ImageFileName = *ubuntu:14.04* OR ImageFileName = *ubuntu:16.04* OR ImageFileName = *ubuntu:16.04-ESM* OR ImageFileName = *ubuntu:16.10* OR ImageFileName = *ubuntu:17.04*)
| table([timestamp, ComputerName])
| limit(1000)
