// Dragnet [Ransomware]: dragnet-ransomware-2023-3701 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: e5639c6c-8f35-5b4a-a786-e4c78ea37837

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
