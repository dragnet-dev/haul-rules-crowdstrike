// Dragnet [Ransomware]: dragnet-ransomware-2025-5565 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 6094e272-a0e8-5673-a9b3-c9f300299ada

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
