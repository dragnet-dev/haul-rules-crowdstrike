// Dragnet [Ransomware]: dragnet-ransomware-2023-3739 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 596b4465-a448-567a-9188-c73a8a9901f1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
