// Dragnet [Ransomware]: dragnet-ransomware-2025-1876 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 71a764d2-5804-5959-b706-064e8d1c5166

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
