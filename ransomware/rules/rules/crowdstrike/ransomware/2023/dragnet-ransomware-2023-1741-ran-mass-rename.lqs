// Dragnet [Ransomware]: dragnet-ransomware-2023-1741 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 51f573a9-1465-54a6-8fcd-cb28019f1f3a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
