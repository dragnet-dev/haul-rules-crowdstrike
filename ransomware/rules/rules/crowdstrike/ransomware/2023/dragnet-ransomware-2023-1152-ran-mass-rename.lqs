// Dragnet [Ransomware]: dragnet-ransomware-2023-1152 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 6fd49588-8dd8-56be-a7dc-83235f0bd784

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
