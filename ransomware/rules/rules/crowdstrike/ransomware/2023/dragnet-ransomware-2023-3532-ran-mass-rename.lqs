// Dragnet [Ransomware]: dragnet-ransomware-2023-3532 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 5ff42fc9-5fdd-5655-a60f-a9206fe22abb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
