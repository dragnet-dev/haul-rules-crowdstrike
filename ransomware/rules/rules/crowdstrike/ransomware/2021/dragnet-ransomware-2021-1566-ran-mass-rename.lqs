// Dragnet [Ransomware]: dragnet-ransomware-2021-1566 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 460e26b9-4e7d-5f2f-b6c3-5fb22ff60ef0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
