// Dragnet [Ransomware]: dragnet-ransomware-2025-1162 — Mass File Rename (underground)
// Status: experimental | Level: high | ID: 5740ddff-c5e5-50b2-a205-b9d4216ff88c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
