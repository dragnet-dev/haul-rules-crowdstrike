// Dragnet [Container]: dragnet-container-2026-2257 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: f014c8bb-4c73-5ae1-b0f2-18854c8e592f

#event_simpleName=*
| (ImageFileName = *chainguard:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
