// Dragnet [Ransomware]: dragnet-ransomware-2026-3248 — Mass File Rename (incransom)
// Status: stable | Level: high | ID: 8231e9ba-62e8-5ad6-a42e-e673f9ad9f79

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
