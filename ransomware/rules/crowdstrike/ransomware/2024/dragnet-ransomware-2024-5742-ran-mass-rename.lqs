// Dragnet [Ransomware]: dragnet-ransomware-2024-5742 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: 85061c74-244c-553a-8878-644f6820ad99

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
