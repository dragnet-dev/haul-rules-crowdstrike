// Dragnet [Ransomware]: dragnet-ransomware-2024-2821 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 35a93eab-c5ae-54a9-aeb0-eb8a90d4a0f1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
