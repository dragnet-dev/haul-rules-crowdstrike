// Dragnet [Ransomware]: dragnet-ransomware-2021-0433 — Mass File Rename (avaddon)
// Status: deprecated | Level: high | ID: 0a5d4b46-e66e-588b-b3ad-e3ee19c463be

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
