// Dragnet [Ransomware]: dragnet-ransomware-2025-7683 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 66d75d38-9ac2-562c-a69b-2cc3ba73564c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
