// Dragnet [Ransomware]: dragnet-ransomware-2023-4839 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: c03886dc-5e05-50f5-9bbf-7b343f144de0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
