// Dragnet [Ransomware]: dragnet-ransomware-2025-2890 — Mass File Rename (shinyhunters)
// Status: experimental | Level: high | ID: d24b4be9-c4dd-5ecd-82a6-acb711747305

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
