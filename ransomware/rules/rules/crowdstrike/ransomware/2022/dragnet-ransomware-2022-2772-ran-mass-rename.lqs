// Dragnet [Ransomware]: dragnet-ransomware-2022-2772 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 9c5d48df-0e1d-5ba0-99a6-2e5662029a94

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
