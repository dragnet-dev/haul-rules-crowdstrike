// Dragnet [Ransomware]: dragnet-ransomware-2024-0718 — Mass File Rename (ElDorado)
// Status: experimental | Level: high | ID: 1577417d-9079-507a-ac6b-06b46fd1c644

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
