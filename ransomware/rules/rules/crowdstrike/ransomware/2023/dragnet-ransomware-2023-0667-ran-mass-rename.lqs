// Dragnet [Ransomware]: dragnet-ransomware-2023-0667 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 91e663db-2b37-515c-a677-7a4f6fbaa972

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
