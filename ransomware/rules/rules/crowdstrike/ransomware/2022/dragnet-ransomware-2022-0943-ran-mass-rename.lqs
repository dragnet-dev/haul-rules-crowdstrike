// Dragnet [Ransomware]: dragnet-ransomware-2022-0943 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 70a0da98-137b-5e0d-95ea-cb0ed953dee7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
