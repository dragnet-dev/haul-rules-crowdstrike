// Dragnet [Ransomware]: dragnet-ransomware-2024-4071 — Mass File Rename (SilentRansomGroup)
// Status: deprecated | Level: high | ID: 3d5ca1f3-6881-51dc-b200-736783f7b5d6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
