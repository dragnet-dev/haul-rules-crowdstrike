// Dragnet [Ransomware]: dragnet-ransomware-2025-6028 — Mass File Rename (ransomhouse)
// Status: experimental | Level: high | ID: 4f8f102f-a4c5-5c59-a998-f1bcdfbf6992

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
