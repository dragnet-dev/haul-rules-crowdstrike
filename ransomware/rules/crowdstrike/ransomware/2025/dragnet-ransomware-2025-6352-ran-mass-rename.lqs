// Dragnet [Ransomware]: dragnet-ransomware-2025-6352 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: bfc75e98-d31a-5b76-85bf-0596797aaf1e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
