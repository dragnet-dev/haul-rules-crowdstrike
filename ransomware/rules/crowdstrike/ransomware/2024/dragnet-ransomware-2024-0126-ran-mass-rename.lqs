// Dragnet [Ransomware]: dragnet-ransomware-2024-0126 — Mass File Rename (cloak)
// Status: experimental | Level: high | ID: 8a2020bc-0258-56f9-aa71-0c2ed8fddbe4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
