// Dragnet [Ransomware]: dragnet-ransomware-2025-7541 — Mass File Rename (blackshrantac)
// Status: experimental | Level: high | ID: 8dad147a-ca19-5792-a6be-336bcf7f0cdf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
