// Dragnet [Ransomware]: dragnet-ransomware-2024-3204 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: db679536-6456-58cc-9366-2506c13c8dc1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
