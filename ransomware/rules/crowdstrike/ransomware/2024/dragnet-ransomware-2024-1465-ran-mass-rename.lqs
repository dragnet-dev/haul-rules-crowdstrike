// Dragnet [Ransomware]: dragnet-ransomware-2024-1465 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: d2d33ef8-8c1d-5dc8-83cf-fb040980b609

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
