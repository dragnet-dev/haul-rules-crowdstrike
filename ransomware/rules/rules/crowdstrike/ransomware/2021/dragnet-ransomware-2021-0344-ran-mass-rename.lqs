// Dragnet [Ransomware]: dragnet-ransomware-2021-0344 — Mass File Rename (nefilim)
// Status: deprecated | Level: high | ID: 14aab7be-888d-52bc-b24f-6cb205b35584

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
