// Dragnet [Ransomware]: dragnet-ransomware-2021-0487 — Mass File Rename (blackmatter)
// Status: deprecated | Level: high | ID: 2072e3d5-ba13-5322-95cb-7006fcc66bc4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
