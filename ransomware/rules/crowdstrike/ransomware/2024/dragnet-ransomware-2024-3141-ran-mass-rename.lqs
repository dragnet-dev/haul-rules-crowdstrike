// Dragnet [Ransomware]: dragnet-ransomware-2024-3141 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 1b5180a1-e1dc-574f-b37d-8eacaa301259

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
