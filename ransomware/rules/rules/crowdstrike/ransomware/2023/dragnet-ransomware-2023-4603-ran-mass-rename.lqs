// Dragnet [Ransomware]: dragnet-ransomware-2023-4603 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 1f1d4cb4-7c54-5b10-8d76-862c1a688d72

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
