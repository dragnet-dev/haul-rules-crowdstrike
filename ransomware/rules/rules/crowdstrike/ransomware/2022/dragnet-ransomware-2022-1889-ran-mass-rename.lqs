// Dragnet [Ransomware]: dragnet-ransomware-2022-1889 — Mass File Rename (revil)
// Status: deprecated | Level: high | ID: 1b412ba2-f0f6-5eb9-a22c-eab0b0f7ce9b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
