// Dragnet [Ransomware]: dragnet-ransomware-2025-1658 — Mass File Rename (sinobi)
// Status: experimental | Level: high | ID: 41b7b70c-8e48-5c40-875f-d92607b55271

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
