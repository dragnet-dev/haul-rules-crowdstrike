// Dragnet [Ransomware]: dragnet-ransomware-2026-3506 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 5747a1ac-1596-5b9c-b625-a35f31413aa9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
