// Dragnet [Ransomware]: dragnet-ransomware-2025-6218 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 975287fd-3a1e-51d7-a3c7-e26d48b424ab

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
