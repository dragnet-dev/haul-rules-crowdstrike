// Dragnet [Ransomware]: dragnet-ransomware-2024-5279 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: fd4717ed-3d15-5566-8f2b-7b0cc9d52fbc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
