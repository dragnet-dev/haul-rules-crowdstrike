// Dragnet [Ransomware]: dragnet-ransomware-2025-2004 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: 669031a5-934c-5256-8cad-225fc8f9339c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
