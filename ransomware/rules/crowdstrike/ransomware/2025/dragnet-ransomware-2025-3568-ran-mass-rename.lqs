// Dragnet [Ransomware]: dragnet-ransomware-2025-3568 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 0c867160-2f06-5a62-a3ff-18b77a4759ef

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
