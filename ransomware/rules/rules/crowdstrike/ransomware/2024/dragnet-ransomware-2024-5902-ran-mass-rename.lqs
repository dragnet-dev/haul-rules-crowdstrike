// Dragnet [Ransomware]: dragnet-ransomware-2024-5902 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 0ce9cd7b-48eb-59d3-885d-9e8037fbc7fe

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
