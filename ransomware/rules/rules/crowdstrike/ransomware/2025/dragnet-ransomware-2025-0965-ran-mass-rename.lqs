// Dragnet [Ransomware]: dragnet-ransomware-2025-0965 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: e18b15aa-fc9f-57f2-836a-71329bdab802

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
