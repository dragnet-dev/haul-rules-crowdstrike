// Dragnet [Ransomware]: dragnet-ransomware-2024-3338 — Mass File Rename (underground)
// Status: experimental | Level: high | ID: f4974663-7d53-5566-90bb-ea455146ccd7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
