// Dragnet [Ransomware]: dragnet-ransomware-2025-2771 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: de4fcc65-7ab8-50f3-bfe5-b5257be11943

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
