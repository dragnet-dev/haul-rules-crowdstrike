// Dragnet [Ransomware]: dragnet-ransomware-2024-0277 — Mass File Rename (alphalocker)
// Status: experimental | Level: high | ID: 10e28391-c26b-581c-8adc-214b1837b5a6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
