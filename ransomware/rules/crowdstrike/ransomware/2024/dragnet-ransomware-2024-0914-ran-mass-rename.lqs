// Dragnet [Ransomware]: dragnet-ransomware-2024-0914 — Mass File Rename (meow)
// Status: experimental | Level: high | ID: 5bb9638f-3149-55bf-94f4-ef4fbfd1bc55

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
