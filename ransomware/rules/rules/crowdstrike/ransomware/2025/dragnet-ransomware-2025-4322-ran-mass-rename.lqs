// Dragnet [Ransomware]: dragnet-ransomware-2025-4322 — Mass File Rename (worldleaks)
// Status: experimental | Level: high | ID: 780b18c9-07fd-53e7-9450-1da56ae107a6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
