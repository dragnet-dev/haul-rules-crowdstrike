// Dragnet [Ransomware]: dragnet-ransomware-2024-5313 — Mass File Rename (play)
// Status: experimental | Level: high | ID: d43686b9-4b29-5ca3-bcde-66e875722a45

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
