// Dragnet [Ransomware]: dragnet-ransomware-2025-0289 — Mass File Rename (sinobi)
// Status: experimental | Level: high | ID: ac92d1b1-6b61-5690-87dd-2246cc2dcd8e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
