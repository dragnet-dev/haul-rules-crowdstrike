// Dragnet [Ransomware]: dragnet-ransomware-2024-2231 — Mass File Rename (monti)
// Status: experimental | Level: high | ID: 62f2e46a-85ad-5337-a7af-a2e8f9b73e32

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
