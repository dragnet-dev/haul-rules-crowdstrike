// Dragnet [Ransomware]: dragnet-ransomware-2023-3359 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 9e8695a1-d85a-51e8-829c-a44f07a68b0e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
