// Dragnet [Ransomware]: dragnet-ransomware-2025-4879 — Mass File Rename (ransomhouse)
// Status: experimental | Level: high | ID: c6cdee37-df66-5b91-8914-afa50e11d4c1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
