// Dragnet [Ransomware]: dragnet-ransomware-2025-4147 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: bb7d2767-a462-598a-b850-d677670e7965

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
