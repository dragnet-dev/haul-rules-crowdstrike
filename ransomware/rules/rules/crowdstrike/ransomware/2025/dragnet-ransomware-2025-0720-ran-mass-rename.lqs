// Dragnet [Ransomware]: dragnet-ransomware-2025-0720 — Mass File Rename (play)
// Status: experimental | Level: high | ID: d42da533-1dc5-5e32-a3ba-486003ffc982

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
