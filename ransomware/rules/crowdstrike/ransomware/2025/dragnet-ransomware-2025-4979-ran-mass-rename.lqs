// Dragnet [Ransomware]: dragnet-ransomware-2025-4979 — Mass File Rename (kraken)
// Status: experimental | Level: high | ID: 0504327b-6363-57e1-9aae-f359e05dd4ce

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
