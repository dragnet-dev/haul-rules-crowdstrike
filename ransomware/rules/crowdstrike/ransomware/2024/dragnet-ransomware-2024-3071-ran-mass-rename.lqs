// Dragnet [Ransomware]: dragnet-ransomware-2024-3071 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: a6914967-cd37-59da-9f2a-6fbc13261ac7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
