// Dragnet [Ransomware]: dragnet-ransomware-2023-4904 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 69195af7-e7e4-57b5-b092-bd80d4a5ffba

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
