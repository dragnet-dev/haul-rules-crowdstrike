// Dragnet [Ransomware]: dragnet-ransomware-2024-2015 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 066c1bb1-6381-54c5-9e2c-2e4a728b1580

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
