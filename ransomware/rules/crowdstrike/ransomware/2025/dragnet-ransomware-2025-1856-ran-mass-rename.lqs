// Dragnet [Ransomware]: dragnet-ransomware-2025-1856 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 3ab744a4-2ca1-5832-aa59-cefd43022ff2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
