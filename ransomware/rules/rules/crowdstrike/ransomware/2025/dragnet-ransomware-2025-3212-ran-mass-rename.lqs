// Dragnet [Ransomware]: dragnet-ransomware-2025-3212 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 5b2e485a-3d6b-5787-8b42-9b72b7bdebb3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
