// Dragnet [Ransomware]: dragnet-ransomware-2024-5433 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 6d4f7c78-b7c1-52e3-a9a7-1df15889d9bf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
