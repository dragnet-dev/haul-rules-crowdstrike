// Dragnet [Container]: dragnet-container-2026-2249 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: e87490cb-ca5e-5cd0-a6c6-0a1ad992b8ef

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:7* OR ImageFileName = *debian:8*)
| table([timestamp, ComputerName])
| limit(1000)
