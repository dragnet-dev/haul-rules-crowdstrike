// Dragnet [Ransomware]: dragnet-ransomware-2025-0615 — Mass File Rename (frag)
// Status: deprecated | Level: high | ID: 9f2996c2-5076-5c64-bbfb-3407873c8b9c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
