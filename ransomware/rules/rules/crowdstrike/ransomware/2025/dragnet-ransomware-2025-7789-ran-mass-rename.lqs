// Dragnet [Ransomware]: dragnet-ransomware-2025-7789 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 8819b945-1c4a-59f4-968f-2db71155c50d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
