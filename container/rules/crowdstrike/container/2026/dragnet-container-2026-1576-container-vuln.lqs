// Dragnet [Container]: dragnet-container-2026-1576 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: f9621201-6972-5a9d-8613-4722bdb71eb3

#event_simpleName=*
| (ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10*)
| table([timestamp, ComputerName])
| limit(1000)
