// Dragnet [Ransomware]: dragnet-ransomware-2025-3972 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 9229e2f7-86f8-57ac-9f52-53efa734f300

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
