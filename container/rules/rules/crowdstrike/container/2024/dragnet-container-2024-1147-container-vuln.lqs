// Dragnet [Container]: dragnet-container-2024-1147 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 96efb25d-fd8a-5360-98ee-988e21d88253

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:9*)
| table([timestamp, ComputerName])
| limit(1000)
