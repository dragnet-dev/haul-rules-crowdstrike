// Dragnet [Ransomware]: dragnet-ransomware-2024-0162 — Mass File Rename (frag)
// Status: deprecated | Level: high | ID: 080712b3-4ed3-5247-a988-d9b8a0b2f2e3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
