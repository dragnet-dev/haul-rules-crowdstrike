// Dragnet [Ransomware]: dragnet-ransomware-2024-2587 — Mass File Rename (redransomware)
// Status: deprecated | Level: high | ID: d7e85013-5733-5878-8d7b-d4b123b97b9a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
