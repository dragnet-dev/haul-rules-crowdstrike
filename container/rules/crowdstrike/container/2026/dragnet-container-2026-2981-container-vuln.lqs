// Dragnet [Container]: dragnet-container-2026-2981 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 6995094e-ce94-5b6f-885b-56b0d6aa819c

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *redhat/ubi9:*)
| table([timestamp, ComputerName])
| limit(1000)
