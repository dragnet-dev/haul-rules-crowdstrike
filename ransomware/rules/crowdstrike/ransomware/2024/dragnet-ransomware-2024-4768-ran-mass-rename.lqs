// Dragnet [Ransomware]: dragnet-ransomware-2024-4768 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 230568c4-851e-5b97-9821-cd591db5caf1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
