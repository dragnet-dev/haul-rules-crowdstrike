// Dragnet [Ransomware]: dragnet-ransomware-2025-2928 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: 24a13893-7fd7-5055-bf09-ba4d0ba1c956

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
