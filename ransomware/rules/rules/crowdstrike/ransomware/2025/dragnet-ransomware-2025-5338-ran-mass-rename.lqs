// Dragnet [Ransomware]: dragnet-ransomware-2025-5338 — Mass File Rename (ciphbit)
// Status: deprecated | Level: high | ID: a67a1b7b-41a7-5ed6-a158-7ed1235a45dd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
