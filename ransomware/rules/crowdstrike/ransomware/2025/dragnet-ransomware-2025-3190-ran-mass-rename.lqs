// Dragnet [Ransomware]: dragnet-ransomware-2025-3190 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 9ae958f9-b4d8-5199-bac2-55fcbd9a6047

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
