// Dragnet [Ransomware]: dragnet-ransomware-2026-1576 — Mass File Rename (blacknevas)
// Status: stable | Level: high | ID: cc570d57-ed27-5bca-a467-f4f02f934699

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
