// Dragnet [Ransomware]: dragnet-ransomware-2022-2137 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 6e228674-f6b1-55ea-b11d-cdf59b93ba98

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
