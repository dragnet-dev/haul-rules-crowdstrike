// Dragnet [Ransomware]: dragnet-ransomware-2022-2789 — Mass File Rename (blackbasta)
// Status: deprecated | Level: high | ID: df7a70c1-21ad-5490-9ac5-45b5a18f353e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
