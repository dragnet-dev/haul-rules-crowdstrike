// Dragnet [Ransomware]: dragnet-ransomware-2025-2407 — Mass File Rename (thegentlemen)
// Status: experimental | Level: high | ID: be70274c-fd3c-5cc5-8bc4-4379c01dbfb1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
