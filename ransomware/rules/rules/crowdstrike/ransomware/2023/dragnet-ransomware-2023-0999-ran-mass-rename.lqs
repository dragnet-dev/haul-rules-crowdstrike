// Dragnet [Ransomware]: dragnet-ransomware-2023-0999 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 2b6dfacd-453e-5804-a58d-4e415c0d8c4d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
