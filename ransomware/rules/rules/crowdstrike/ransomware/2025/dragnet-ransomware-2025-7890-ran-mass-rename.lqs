// Dragnet [Ransomware]: dragnet-ransomware-2025-7890 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: dfc6f6f3-32fc-5221-810a-c419d666f975

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
