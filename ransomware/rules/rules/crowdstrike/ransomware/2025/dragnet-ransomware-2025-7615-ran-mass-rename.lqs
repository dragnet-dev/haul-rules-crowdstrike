// Dragnet [Ransomware]: dragnet-ransomware-2025-7615 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 6aa84fee-341d-5d45-a105-3cbb64bdf376

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
