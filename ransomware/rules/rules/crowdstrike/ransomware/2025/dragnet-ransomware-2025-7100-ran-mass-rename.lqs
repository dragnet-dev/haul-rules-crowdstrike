// Dragnet [Ransomware]: dragnet-ransomware-2025-7100 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 5dd0825b-1f7b-5498-a2bc-8edaae73e8da

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
