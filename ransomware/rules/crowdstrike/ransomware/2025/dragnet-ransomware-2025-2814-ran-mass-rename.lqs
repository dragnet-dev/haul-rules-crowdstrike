// Dragnet [Ransomware]: dragnet-ransomware-2025-2814 — Mass File Rename (kairos)
// Status: experimental | Level: high | ID: f3690ae2-0d83-53b7-88ea-26fa5ccbae7e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
