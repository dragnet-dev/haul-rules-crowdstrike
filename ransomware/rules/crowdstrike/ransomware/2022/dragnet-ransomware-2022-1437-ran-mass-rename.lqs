// Dragnet [Ransomware]: dragnet-ransomware-2022-1437 — Mass File Rename (blackbasta)
// Status: deprecated | Level: high | ID: f361bd07-40c8-5b82-9a6c-f2d6e0942d80

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
