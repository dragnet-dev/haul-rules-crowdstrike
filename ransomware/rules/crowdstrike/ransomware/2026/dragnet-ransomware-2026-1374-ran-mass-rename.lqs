// Dragnet [Ransomware]: dragnet-ransomware-2026-1374 — Mass File Rename (shinyhunters)
// Status: deprecated | Level: high | ID: 4d3ce8c6-f509-55a3-a76a-6e1a0cda10cd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
