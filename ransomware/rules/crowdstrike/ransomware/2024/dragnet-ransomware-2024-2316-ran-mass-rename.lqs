// Dragnet [Ransomware]: dragnet-ransomware-2024-2316 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: 92ce99fd-0b43-525b-93e3-2c5d486d715b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
