// Dragnet [Ransomware]: dragnet-ransomware-2023-4558 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: a14c53a7-2445-5a2f-ad9c-a37f08bec0e1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
