// Dragnet [Ransomware]: dragnet-ransomware-2022-1603 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: b6358680-d616-58bf-9dcd-dac710ced8f6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
