// Dragnet [Ransomware]: dragnet-ransomware-2024-2317 — Mass File Rename (dAn0n)
// Status: experimental | Level: high | ID: e20398bf-43fb-5bb1-b2dc-dbe64742294d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
