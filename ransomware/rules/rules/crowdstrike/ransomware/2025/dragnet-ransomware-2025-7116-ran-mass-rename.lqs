// Dragnet [Ransomware]: dragnet-ransomware-2025-7116 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 2d1f0f5a-4f46-521b-ade9-3cb3cd4abeee

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
