// Dragnet [Ransomware]: dragnet-ransomware-2024-0340 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 8855f6ee-9953-5a35-8533-72572b59d11e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
