// Dragnet [Ransomware]: dragnet-ransomware-2021-1678 — Mass File Rename (ragnarlocker)
// Status: deprecated | Level: high | ID: fedc368b-991e-5192-8c76-fc54d144436f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
