// Dragnet [Ransomware]: dragnet-ransomware-2025-0188 — Mass File Rename (beast)
// Status: experimental | Level: high | ID: ca094701-f4a4-5926-b038-1bca48164fc3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
