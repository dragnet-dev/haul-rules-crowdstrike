// Dragnet [Ransomware]: dragnet-ransomware-2025-3198 — Mass File Rename (arkana)
// Status: experimental | Level: high | ID: 43902ce8-3e16-54d8-ae52-6f3024234fc7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
