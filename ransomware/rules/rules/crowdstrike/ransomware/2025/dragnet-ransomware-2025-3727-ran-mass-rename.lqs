// Dragnet [Ransomware]: dragnet-ransomware-2025-3727 — Mass File Rename (skira)
// Status: experimental | Level: high | ID: 0f2bbc62-b4bf-5dd0-b390-9093dca1c8da

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
