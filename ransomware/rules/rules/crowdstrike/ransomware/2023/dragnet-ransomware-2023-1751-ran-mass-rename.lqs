// Dragnet [Ransomware]: dragnet-ransomware-2023-1751 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: b8947302-ed8d-5d18-9f2a-624878a8b352

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
