// Dragnet [Ransomware]: dragnet-ransomware-2022-1239 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: a809a98c-9561-5414-9aea-9d14f3f0eac9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
