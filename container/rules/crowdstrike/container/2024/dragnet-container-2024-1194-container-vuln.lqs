// Dragnet [Container]: dragnet-container-2024-1194 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: b425ff65-1f5c-5947-a7de-2e830c17834f

#event_simpleName=*
| (ImageFileName = *alpine:3.10* OR ImageFileName = *alpine:3.8* OR ImageFileName = *alpine:3.9* OR ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *ubuntu:18.04* OR ImageFileName = *ubuntu:18.04-ESM* OR ImageFileName = *ubuntu:19.04* OR ImageFileName = *ubuntu:19.10*)
| table([timestamp, ComputerName])
| limit(1000)
