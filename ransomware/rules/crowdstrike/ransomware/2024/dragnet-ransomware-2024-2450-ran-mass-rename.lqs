// Dragnet [Ransomware]: dragnet-ransomware-2024-2450 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 94a791e9-7ff1-5b52-b832-91ec517e4814

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
