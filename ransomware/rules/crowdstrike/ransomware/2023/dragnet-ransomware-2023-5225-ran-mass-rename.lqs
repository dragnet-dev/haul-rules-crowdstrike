// Dragnet [Ransomware]: dragnet-ransomware-2023-5225 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: df6348f9-17e8-5e34-9fdf-d321707ce3d2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
