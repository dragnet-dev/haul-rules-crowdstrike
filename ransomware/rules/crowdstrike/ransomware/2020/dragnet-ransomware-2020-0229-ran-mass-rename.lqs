// Dragnet [Ransomware]: dragnet-ransomware-2020-0229 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 927b34a8-fe4d-5e19-92f6-c83dfc2f0227

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
