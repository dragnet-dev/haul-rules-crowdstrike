// Dragnet [Ransomware]: dragnet-ransomware-2026-2297 — Mass File Rename (insomnia)
// Status: stable | Level: high | ID: 328cafe2-9b9f-57ab-9b8b-ff9a126eba84

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
