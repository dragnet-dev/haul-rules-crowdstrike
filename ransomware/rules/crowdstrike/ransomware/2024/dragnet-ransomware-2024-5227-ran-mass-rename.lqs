// Dragnet [Ransomware]: dragnet-ransomware-2024-5227 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 31c9f5a5-8c89-59cf-a26f-495aa80e5d94

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
