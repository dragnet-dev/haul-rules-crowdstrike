// Dragnet [Ransomware]: dragnet-ransomware-2026-2344 — Mass File Rename (interlock)
// Status: stable | Level: high | ID: 4d6fe5b5-9556-5ed2-88c5-ec354fbbc058

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
