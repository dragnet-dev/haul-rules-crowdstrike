// Dragnet [Ransomware]: dragnet-ransomware-2023-4643 — Mass File Rename (darkpower)
// Status: experimental | Level: high | ID: 3ed95dd8-76e2-5054-9c66-3ea9e5fb8d8c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
