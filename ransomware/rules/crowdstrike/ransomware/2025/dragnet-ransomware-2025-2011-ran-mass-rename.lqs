// Dragnet [Ransomware]: dragnet-ransomware-2025-2011 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: abc2a64d-c32a-58dd-a9b1-1609467f0062

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
