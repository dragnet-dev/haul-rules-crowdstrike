// Dragnet [Ransomware]: dragnet-ransomware-2025-0423 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 1415bd32-3930-58f5-a953-495b9353930a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
