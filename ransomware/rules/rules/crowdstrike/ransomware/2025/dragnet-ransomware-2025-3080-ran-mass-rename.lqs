// Dragnet [Ransomware]: dragnet-ransomware-2025-3080 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: aecd480b-1da3-51ad-91ca-6f3fd8e3bbc1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
