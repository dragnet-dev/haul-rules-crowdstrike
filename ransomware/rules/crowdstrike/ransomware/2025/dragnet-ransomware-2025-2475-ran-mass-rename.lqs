// Dragnet [Ransomware]: dragnet-ransomware-2025-2475 — Mass File Rename (thegentlemen)
// Status: experimental | Level: high | ID: 82af3ce2-47f1-5271-9f59-9f4d72068e72

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
