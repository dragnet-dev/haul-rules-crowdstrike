// Dragnet [Ransomware]: dragnet-ransomware-2024-0936 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: c7d4565d-c950-58b1-8a8d-20456108becd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
