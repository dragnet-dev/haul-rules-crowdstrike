// Dragnet [Ransomware]: dragnet-ransomware-2022-0723 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 927350f2-b83a-50a2-ae4a-daea20699fb3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
