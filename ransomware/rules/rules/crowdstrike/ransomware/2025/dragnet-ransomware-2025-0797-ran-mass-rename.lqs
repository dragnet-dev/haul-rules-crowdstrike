// Dragnet [Ransomware]: dragnet-ransomware-2025-0797 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 3de4e565-94d4-5896-825c-37c81ae4302f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
