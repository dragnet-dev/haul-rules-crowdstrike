// Dragnet [Ransomware]: dragnet-ransomware-2021-0076 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: a7636c29-83bf-57e7-8599-762b55bcdcc7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
