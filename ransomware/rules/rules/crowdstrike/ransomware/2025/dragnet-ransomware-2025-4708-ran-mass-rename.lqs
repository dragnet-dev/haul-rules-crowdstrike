// Dragnet [Ransomware]: dragnet-ransomware-2025-4708 — Mass File Rename (spacebears)
// Status: experimental | Level: high | ID: f5955efd-1be5-5abd-895d-271a33d2e225

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
