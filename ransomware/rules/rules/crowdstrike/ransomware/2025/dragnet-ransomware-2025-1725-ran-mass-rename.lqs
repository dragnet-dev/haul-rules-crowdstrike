// Dragnet [Ransomware]: dragnet-ransomware-2025-1725 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 960c51b9-0861-54bd-ab26-624735acafeb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
