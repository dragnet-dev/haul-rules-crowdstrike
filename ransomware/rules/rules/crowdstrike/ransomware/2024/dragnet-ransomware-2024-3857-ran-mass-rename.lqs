// Dragnet [Ransomware]: dragnet-ransomware-2024-3857 — Mass File Rename (arcusmedia)
// Status: experimental | Level: high | ID: a6fb616f-5a89-5dbd-b2c7-d3038eb1a6fe

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
