// Dragnet [Ransomware]: dragnet-ransomware-2024-3989 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 1a774ab4-3a43-57c5-886b-6ef25d7ce2e4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
