// Dragnet [Ransomware]: dragnet-ransomware-2024-2434 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: bb7d8386-8d12-57bc-96be-0c86ccc443ed

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
