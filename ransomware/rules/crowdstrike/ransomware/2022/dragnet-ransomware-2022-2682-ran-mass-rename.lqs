// Dragnet [Ransomware]: dragnet-ransomware-2022-2682 — Mass File Rename (onyx)
// Status: deprecated | Level: high | ID: 3091200d-220a-5233-be82-31bda34f0e6e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
