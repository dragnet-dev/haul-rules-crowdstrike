// Dragnet [Ransomware]: dragnet-ransomware-2022-2513 — Mass File Rename (cuba)
// Status: deprecated | Level: high | ID: c695d9b0-44a1-5be1-b2bc-b07a4e866a85

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
