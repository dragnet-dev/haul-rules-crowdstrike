// Dragnet [Ransomware]: dragnet-ransomware-2024-5097 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: a7a68940-00a2-529f-a794-93df2bd0619d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
