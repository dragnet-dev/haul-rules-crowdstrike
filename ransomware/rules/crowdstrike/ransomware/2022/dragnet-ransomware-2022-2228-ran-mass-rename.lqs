// Dragnet [Ransomware]: dragnet-ransomware-2022-2228 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: 97c232ad-add8-5a04-b795-ed39be865f36

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
