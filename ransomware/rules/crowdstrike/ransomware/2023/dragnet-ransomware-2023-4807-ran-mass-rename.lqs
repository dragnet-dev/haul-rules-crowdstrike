// Dragnet [Ransomware]: dragnet-ransomware-2023-4807 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: b11b4258-b716-5930-83f2-094ac0a1bea0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
