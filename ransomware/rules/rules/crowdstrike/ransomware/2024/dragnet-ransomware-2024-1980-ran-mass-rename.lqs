// Dragnet [Ransomware]: dragnet-ransomware-2024-1980 — Mass File Rename (meow)
// Status: experimental | Level: high | ID: 015dd50c-b8c5-594d-b98d-0c3f5bb00824

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
