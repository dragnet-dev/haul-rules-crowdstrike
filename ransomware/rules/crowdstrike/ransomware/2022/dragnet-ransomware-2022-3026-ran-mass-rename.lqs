// Dragnet [Ransomware]: dragnet-ransomware-2022-3026 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 6d818466-25ce-593d-8022-a68c67e55b2a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
