// Dragnet [Ransomware]: dragnet-ransomware-2022-2068 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 1f195b97-93c8-5bc8-8627-b6d840b836f7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
