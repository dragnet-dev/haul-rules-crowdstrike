// Dragnet [Ransomware]: dragnet-ransomware-2024-5178 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: 77361150-8c87-5195-804a-9d634609f038

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
