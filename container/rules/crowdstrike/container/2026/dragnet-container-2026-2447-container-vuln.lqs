// Dragnet [Container]: dragnet-container-2026-2447 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: c56d1025-f9ba-58b1-b1f2-6c4bf2834457

#event_simpleName=*
| (ImageFileName = *alpine edge:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
