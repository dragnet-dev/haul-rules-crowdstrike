// Dragnet [Ransomware]: dragnet-ransomware-2024-2292 — Mass File Rename (apt73)
// Status: experimental | Level: high | ID: fe737fa8-ed5c-5034-a398-5e4363846471

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
