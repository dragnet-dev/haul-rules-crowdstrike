// Dragnet [Ransomware]: dragnet-ransomware-2023-5094 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 6af9feb2-65f0-5707-9441-9f51548f68a9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
