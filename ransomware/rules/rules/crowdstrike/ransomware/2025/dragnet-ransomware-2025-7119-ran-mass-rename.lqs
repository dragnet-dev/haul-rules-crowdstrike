// Dragnet [Ransomware]: dragnet-ransomware-2025-7119 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 707921ac-6df6-513d-85c9-c6ff22ac1478

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
