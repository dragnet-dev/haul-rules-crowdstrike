// Dragnet [Ransomware]: dragnet-ransomware-2026-1604 — Mass File Rename (handala)
// Status: stable | Level: high | ID: 30d14b26-0308-52f5-b636-d566401fff7a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
