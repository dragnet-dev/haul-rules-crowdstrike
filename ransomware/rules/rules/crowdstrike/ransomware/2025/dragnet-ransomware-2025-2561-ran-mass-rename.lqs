// Dragnet [Ransomware]: dragnet-ransomware-2025-2561 — Mass File Rename (warlock)
// Status: deprecated | Level: high | ID: b84ece78-e4e5-5f24-8095-cf2a94f351be

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
