// Dragnet [Ransomware]: dragnet-ransomware-2024-0065 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 0d63e03d-0af9-5602-8515-17c29b0ab055

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
