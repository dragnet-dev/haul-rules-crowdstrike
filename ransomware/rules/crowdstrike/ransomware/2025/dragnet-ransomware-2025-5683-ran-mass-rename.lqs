// Dragnet [Ransomware]: dragnet-ransomware-2025-5683 — Mass File Rename (play)
// Status: experimental | Level: high | ID: a22a89f4-f7c9-5777-a025-19dc6acf121d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
