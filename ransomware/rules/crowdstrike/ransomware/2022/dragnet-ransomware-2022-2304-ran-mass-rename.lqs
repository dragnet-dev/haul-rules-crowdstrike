// Dragnet [Ransomware]: dragnet-ransomware-2022-2304 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: 699fac32-7970-573d-9e07-d9b98e7582d2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
