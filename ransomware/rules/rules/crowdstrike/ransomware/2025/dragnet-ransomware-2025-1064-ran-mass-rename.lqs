// Dragnet [Ransomware]: dragnet-ransomware-2025-1064 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 4ab3ac77-1470-5dd4-9d7b-cfc651334f25

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
