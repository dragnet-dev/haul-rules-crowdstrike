// Dragnet [Ransomware]: dragnet-ransomware-2022-3104 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 5f602bdf-a4fb-5b82-94ef-ded993b55258

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
