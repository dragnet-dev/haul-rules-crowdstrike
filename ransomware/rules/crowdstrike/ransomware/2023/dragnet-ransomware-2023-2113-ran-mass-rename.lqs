// Dragnet [Ransomware]: dragnet-ransomware-2023-2113 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 3bb8ae93-879e-57ad-8095-61216561eac9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
