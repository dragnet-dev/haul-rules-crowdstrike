// Dragnet [Ransomware]: dragnet-ransomware-2025-3679 — Mass File Rename (ralord)
// Status: experimental | Level: high | ID: c5469dae-184d-5054-8117-47e7483013d3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
