// Dragnet [Ransomware]: dragnet-ransomware-2026-0699 — Mass File Rename (incransom)
// Status: stable | Level: high | ID: 4b6da695-e931-5cce-828c-50e3ec61f430

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
