// Dragnet [Ransomware]: dragnet-ransomware-2024-0190 — Mass File Rename (play)
// Status: experimental | Level: high | ID: ff96f361-f5c6-510b-af49-243d73401a4c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
