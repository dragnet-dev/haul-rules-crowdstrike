// Dragnet [Ransomware]: dragnet-ransomware-2021-1377 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: eb247e61-de0c-5232-835b-9e015994e7d0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
