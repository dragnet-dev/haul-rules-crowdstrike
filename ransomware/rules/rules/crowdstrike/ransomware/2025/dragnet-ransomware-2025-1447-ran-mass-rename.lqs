// Dragnet [Ransomware]: dragnet-ransomware-2025-1447 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: d004c6a8-c509-5417-afb1-b765f94354d3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
