// Dragnet [Container]: dragnet-container-2026-3007 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 8f7f597b-35b9-57c2-a7f0-b3371c624751

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:5*)
| table([timestamp, ComputerName])
| limit(1000)
