// Dragnet [Ransomware]: dragnet-ransomware-2023-0740 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 18e4ad7c-4743-5126-b486-17dc05654b70

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
