// Dragnet [Ransomware]: dragnet-ransomware-2023-1166 — Mass File Rename (medusa)
// Status: deprecated | Level: high | ID: afe48708-d630-514f-8e7e-ea4dbd65a8b8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
