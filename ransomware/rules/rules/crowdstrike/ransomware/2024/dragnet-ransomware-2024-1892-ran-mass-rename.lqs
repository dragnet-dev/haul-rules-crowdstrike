// Dragnet [Ransomware]: dragnet-ransomware-2024-1892 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 2dd0f56e-0858-58af-a3f8-e1c4eae79e40

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
