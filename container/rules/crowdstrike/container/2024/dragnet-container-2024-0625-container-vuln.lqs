// Dragnet [Container]: dragnet-container-2024-0625 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: a6d13eba-9c40-5011-a948-5f4a1fde56d8

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *ubuntu:18.04* OR ImageFileName = *ubuntu:18.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
