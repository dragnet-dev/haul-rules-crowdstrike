// Dragnet [Ransomware]: dragnet-ransomware-2025-2205 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 05809c57-b22c-504c-ab2d-afa19c90da92

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
