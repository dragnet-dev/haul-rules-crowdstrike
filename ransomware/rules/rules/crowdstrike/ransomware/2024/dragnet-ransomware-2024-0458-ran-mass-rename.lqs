// Dragnet [Ransomware]: dragnet-ransomware-2024-0458 — Mass File Rename (play)
// Status: experimental | Level: high | ID: fa998ecb-630f-55b3-9a65-80cd9394cb88

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
