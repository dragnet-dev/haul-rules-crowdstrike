// Dragnet [Ransomware]: dragnet-ransomware-2024-2956 — Mass File Rename (nitrogen)
// Status: experimental | Level: high | ID: 58b46341-ce3a-55cf-a2bc-842e9b71bb6e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
