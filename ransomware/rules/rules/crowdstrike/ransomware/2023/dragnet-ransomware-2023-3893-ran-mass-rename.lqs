// Dragnet [Ransomware]: dragnet-ransomware-2023-3893 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 005879fa-e042-5486-a0aa-65169278ad59

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
