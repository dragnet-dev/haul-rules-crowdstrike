// Dragnet [Ransomware]: dragnet-ransomware-2025-1330 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: a8600e5e-9543-5519-bb67-266647908125

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
