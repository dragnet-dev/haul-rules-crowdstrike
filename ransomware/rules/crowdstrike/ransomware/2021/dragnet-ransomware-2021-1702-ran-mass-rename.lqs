// Dragnet [Ransomware]: dragnet-ransomware-2021-1702 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 57df2780-1bac-5c12-a7dd-91a22a8f7456

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
