// Dragnet [Ransomware]: dragnet-ransomware-2026-0051 — Mass File Rename (dragonforce)
// Status: test | Level: high | ID: 4f2a6c4d-51c8-5db8-99b1-74f3fd71c682

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
