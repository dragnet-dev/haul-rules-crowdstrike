// Dragnet [Ransomware]: dragnet-ransomware-2025-5876 — Mass File Rename (silent)
// Status: experimental | Level: high | ID: cad3cdcc-4024-5910-8b09-547975949b3a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
