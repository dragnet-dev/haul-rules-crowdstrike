// Dragnet [Ransomware]: dragnet-ransomware-2024-1016 — Mass File Rename (dragonransomware)
// Status: experimental | Level: high | ID: b3473044-14e1-55b1-a1c7-8b3f2db692b3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
