// Dragnet [Container]: dragnet-container-2025-0206 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 0df15c5e-0073-53f7-a962-c804e19e6565

#event_simpleName=*
| (ImageFileName = *ubuntu:14.04* OR ImageFileName = *ubuntu:16.04* OR ImageFileName = *ubuntu:16.04-ESM* OR ImageFileName = *ubuntu:17.04* OR ImageFileName = *ubuntu:17.10*)
| table([timestamp, ComputerName])
| limit(1000)
