// Dragnet [Ransomware]: dragnet-ransomware-2022-2583 — Mass File Rename (revil)
// Status: deprecated | Level: high | ID: 042d6c4b-1d3d-59d0-ab1a-8d50eb5886c6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
