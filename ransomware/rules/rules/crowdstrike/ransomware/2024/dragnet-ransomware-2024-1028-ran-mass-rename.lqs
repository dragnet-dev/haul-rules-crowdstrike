// Dragnet [Ransomware]: dragnet-ransomware-2024-1028 — Mass File Rename (monti)
// Status: experimental | Level: high | ID: 6f2fd996-fea8-5eec-9ae5-590450cbece6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
