// Dragnet [Ransomware]: dragnet-ransomware-2023-0447 — Mass File Rename (toufan)
// Status: deprecated | Level: high | ID: 3e7dc8e3-da8c-5086-9850-9fdb9e838c1b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
