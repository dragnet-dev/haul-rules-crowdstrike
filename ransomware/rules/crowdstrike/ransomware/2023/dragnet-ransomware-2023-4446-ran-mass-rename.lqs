// Dragnet [Ransomware]: dragnet-ransomware-2023-4446 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 669e1502-36f2-5970-a36d-fe83ecb21da0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
