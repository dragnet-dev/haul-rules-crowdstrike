// Dragnet [Ransomware]: dragnet-ransomware-2023-1477 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: b49e2be0-8893-5694-aae9-e06fff8177f0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
