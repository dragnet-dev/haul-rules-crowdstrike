// Dragnet [Ransomware]: dragnet-ransomware-2025-3710 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: d0717350-2f31-5d1a-845c-62c96020ef1e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
