// Dragnet [Ransomware]: dragnet-ransomware-2026-3459 — Mass File Rename (dragonforce)
// Status: stable | Level: high | ID: 77efa590-fe95-5961-af8d-3b2f94c7376d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
