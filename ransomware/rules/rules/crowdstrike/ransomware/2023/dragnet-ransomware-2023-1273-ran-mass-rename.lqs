// Dragnet [Ransomware]: dragnet-ransomware-2023-1273 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 8233058f-ab4d-571c-8667-64ee6b23623b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
