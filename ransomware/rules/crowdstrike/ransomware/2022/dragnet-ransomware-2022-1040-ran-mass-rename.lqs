// Dragnet [Ransomware]: dragnet-ransomware-2022-1040 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 7d34266d-3a49-5d1d-a975-fd8a0b1bb9ed

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
