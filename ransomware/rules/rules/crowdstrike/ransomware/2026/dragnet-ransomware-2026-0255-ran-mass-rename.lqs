// Dragnet [Ransomware]: dragnet-ransomware-2026-0255 — Mass File Rename (crypto24)
// Status: deprecated | Level: high | ID: 26ed844e-edf5-5de5-b7e2-bc2b00b49a4d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
