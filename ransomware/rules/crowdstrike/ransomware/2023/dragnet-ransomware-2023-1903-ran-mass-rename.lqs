// Dragnet [Ransomware]: dragnet-ransomware-2023-1903 — Mass File Rename (noescape)
// Status: experimental | Level: high | ID: 6197e462-957b-5eed-b558-2e7f89b0920a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
