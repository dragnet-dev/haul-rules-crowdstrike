// Dragnet [Ransomware]: dragnet-ransomware-2023-0308 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 82274c88-a829-5d36-a1a4-57a78f928dd9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
