// Dragnet [Ransomware]: dragnet-ransomware-2022-2305 — Mass File Rename (alphv)
// Status: deprecated | Level: high | ID: e7bd6aea-8b0d-5c76-b141-9284b68068b4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
