// Dragnet [Ransomware]: dragnet-ransomware-2025-0236 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: afc2d64d-fdbe-5db4-b61f-ec23fd408992

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
