// Dragnet [Ransomware]: dragnet-ransomware-2025-4633 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 24648f12-2e94-51ea-9700-21a9f7253e42

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
