// Dragnet [Ransomware]: dragnet-ransomware-2025-3387 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 008c2afc-1b1d-5e14-a1f3-52d0521dd137

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
