// Dragnet [Ransomware]: dragnet-ransomware-2022-0587 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 9a2b153c-768a-5733-933c-3aaebe768e1e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
