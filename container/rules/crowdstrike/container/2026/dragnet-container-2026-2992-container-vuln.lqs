// Dragnet [Container]: dragnet-container-2026-2992 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 23943346-6299-50fd-863a-dae13e85e73c

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
