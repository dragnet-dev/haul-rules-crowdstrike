// Dragnet [Ransomware]: dragnet-ransomware-2024-2760 — Mass File Rename (termite)
// Status: experimental | Level: high | ID: 57da3a3f-f398-504b-99ec-4c6ebfe68231

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
