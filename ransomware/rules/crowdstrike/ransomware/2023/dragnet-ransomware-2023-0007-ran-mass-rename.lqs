// Dragnet [Ransomware]: dragnet-ransomware-2023-0007 — Mass File Rename (noescape)
// Status: experimental | Level: high | ID: aeb72546-4ffd-5ece-ac50-70e7e721af48

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
