// Dragnet [Ransomware]: dragnet-ransomware-2023-3555 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: ad3cac7f-d1df-5e73-a0ea-16dea2d87818

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
