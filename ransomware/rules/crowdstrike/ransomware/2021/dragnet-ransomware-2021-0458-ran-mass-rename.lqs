// Dragnet [Ransomware]: dragnet-ransomware-2021-0458 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 14546fd8-c455-59d5-b69d-fef190f0c103

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
