// Dragnet [Ransomware]: dragnet-ransomware-2023-4252 — Mass File Rename (stormous)
// Status: deprecated | Level: high | ID: 32aa5a3e-3de9-5163-aff6-3c2abdc6ecf2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
