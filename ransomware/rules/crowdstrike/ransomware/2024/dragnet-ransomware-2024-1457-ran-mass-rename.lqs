// Dragnet [Ransomware]: dragnet-ransomware-2024-1457 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 0047e09a-b640-5629-911d-597409388862

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
