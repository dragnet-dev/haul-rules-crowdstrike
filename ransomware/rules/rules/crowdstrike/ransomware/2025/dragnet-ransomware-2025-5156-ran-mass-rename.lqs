// Dragnet [Ransomware]: dragnet-ransomware-2025-5156 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: e0444a69-8696-5866-8f83-073a144c570c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
