// Dragnet [Ransomware]: dragnet-ransomware-2023-4322 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: bb1916a8-d865-5a99-829f-eed81eec9783

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
