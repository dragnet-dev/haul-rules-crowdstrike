// Dragnet [Ransomware]: dragnet-ransomware-2021-0353 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: d6af8d56-a1a1-50c9-be26-55c657cacf23

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
