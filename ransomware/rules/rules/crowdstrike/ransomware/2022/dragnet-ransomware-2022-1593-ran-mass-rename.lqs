// Dragnet [Ransomware]: dragnet-ransomware-2022-1593 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: c05ba5af-ee2e-59c7-9d68-d6f086683342

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
