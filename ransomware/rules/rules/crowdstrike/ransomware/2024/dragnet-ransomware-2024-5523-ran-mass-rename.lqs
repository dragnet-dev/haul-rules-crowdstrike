// Dragnet [Ransomware]: dragnet-ransomware-2024-5523 — Mass File Rename (arcusmedia)
// Status: experimental | Level: high | ID: 0b20c237-c58b-5af5-ba56-dd62c5e44aff

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
