// Dragnet [Ransomware]: dragnet-ransomware-2023-2715 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 8dbf3070-bd8d-56fa-90e9-30a33c72aa50

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
