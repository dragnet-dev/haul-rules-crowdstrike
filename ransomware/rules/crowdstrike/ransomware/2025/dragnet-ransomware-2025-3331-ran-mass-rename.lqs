// Dragnet [Ransomware]: dragnet-ransomware-2025-3331 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 3ff620e2-d99b-56cc-b729-09265fb940d0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
