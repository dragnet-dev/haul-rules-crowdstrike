// Dragnet [Ransomware]: dragnet-ransomware-2025-6306 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 56b35004-2324-54cc-90b4-f4b0e4d408b4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
