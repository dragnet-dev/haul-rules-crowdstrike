// Dragnet [Ransomware]: dragnet-ransomware-2024-4073 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: 5d8ccbec-d985-5f27-a7dc-b68275aefd89

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
