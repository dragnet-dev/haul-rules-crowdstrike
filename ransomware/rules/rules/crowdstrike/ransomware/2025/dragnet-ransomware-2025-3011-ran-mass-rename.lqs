// Dragnet [Ransomware]: dragnet-ransomware-2025-3011 — Mass File Rename (cephalus)
// Status: deprecated | Level: high | ID: da5d8394-b1fa-55b9-b6bb-1ba1b6b60ccf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
