// Dragnet [Ransomware]: dragnet-ransomware-2024-2347 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 6514c641-f6b7-590c-995b-6639ca85e897

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
