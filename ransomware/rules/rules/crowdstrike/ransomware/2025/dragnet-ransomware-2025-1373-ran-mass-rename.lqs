// Dragnet [Ransomware]: dragnet-ransomware-2025-1373 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: dc219c9d-1c8d-52c6-966d-093493ea4d65

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
