// Dragnet [Ransomware]: dragnet-ransomware-2025-3362 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 5d62bad7-b4a9-59c4-adab-3019a2423e2c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
