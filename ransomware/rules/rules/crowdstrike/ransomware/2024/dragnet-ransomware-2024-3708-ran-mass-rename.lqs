// Dragnet [Ransomware]: dragnet-ransomware-2024-3708 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: e554c446-ce6c-5184-8e1b-520cd13304e4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
