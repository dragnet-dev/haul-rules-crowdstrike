// Dragnet [Container]: dragnet-container-2026-2570 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: b2c84d00-51e7-5494-9129-6e15a3f54cc6

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:7* OR ImageFileName = *debian:8* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:16.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
