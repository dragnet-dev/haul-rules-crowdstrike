// Dragnet [Ransomware]: dragnet-ransomware-2025-2634 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 225ee9ff-32eb-5ae2-84cf-307f24017164

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
