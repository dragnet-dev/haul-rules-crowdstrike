// Dragnet [Ransomware]: dragnet-ransomware-2025-1151 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: d4688632-280c-55d2-a97e-9b50fe3948b5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
