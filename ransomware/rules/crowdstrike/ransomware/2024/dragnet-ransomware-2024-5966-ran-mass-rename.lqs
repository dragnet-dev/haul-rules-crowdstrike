// Dragnet [Ransomware]: dragnet-ransomware-2024-5966 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: d78298c7-dfa3-5337-80c9-4ee74cd001a0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
