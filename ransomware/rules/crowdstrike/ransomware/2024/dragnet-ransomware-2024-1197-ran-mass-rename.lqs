// Dragnet [Ransomware]: dragnet-ransomware-2024-1197 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 8de60e4d-9775-53a6-b507-031c2f32e85e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
