// Dragnet [Container]: dragnet-container-2026-2617 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 1a95c90d-4f77-5dab-8e72-1649b2ff2259

#event_simpleName=*
| (ImageFileName = *amazonlinux:1* OR ImageFileName = *chainguard:* OR ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10*)
| table([timestamp, ComputerName])
| limit(1000)
