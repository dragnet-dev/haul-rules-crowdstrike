// Dragnet [Ransomware]: dragnet-ransomware-2022-0478 — Mass File Rename (mindware)
// Status: deprecated | Level: high | ID: 584c1a7f-6a35-5ef2-b676-3dc3c2a04ee9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
