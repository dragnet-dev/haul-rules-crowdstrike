// Dragnet [Ransomware]: dragnet-ransomware-2025-1751 — Mass File Rename (ransomhouse)
// Status: experimental | Level: high | ID: 85c3087d-46b4-56e9-a5f6-7e141cfe2809

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
