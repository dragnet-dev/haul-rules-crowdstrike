// Dragnet [Ransomware]: dragnet-ransomware-2024-1091 — Mass File Rename (rhysida)
// Status: deprecated | Level: high | ID: 8c9e8b6a-a697-5fdd-82a0-59b1dc033751

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
