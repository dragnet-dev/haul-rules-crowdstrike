// Dragnet [Ransomware]: dragnet-ransomware-2023-1665 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 92129dbe-3cb1-55da-96f1-08c918962085

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
