// Dragnet [Ransomware]: dragnet-ransomware-2025-7855 — Mass File Rename (cicada3301)
// Status: experimental | Level: high | ID: 9eb8da3c-f687-5590-a11c-6e54af8542dc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
