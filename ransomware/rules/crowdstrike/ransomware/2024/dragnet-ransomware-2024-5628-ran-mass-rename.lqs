// Dragnet [Ransomware]: dragnet-ransomware-2024-5628 — Mass File Rename (dragonforce)
// Status: deprecated | Level: high | ID: 059c7031-277d-5658-ac0b-5701a4e11421

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
