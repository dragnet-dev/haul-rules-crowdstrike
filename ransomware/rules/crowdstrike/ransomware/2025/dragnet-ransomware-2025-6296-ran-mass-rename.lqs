// Dragnet [Ransomware]: dragnet-ransomware-2025-6296 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: da0a6da8-f2ac-586c-80e0-ffc06ef469b5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
