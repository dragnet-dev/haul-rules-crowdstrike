// Dragnet [Ransomware]: dragnet-ransomware-2023-3278 — Mass File Rename (losttrust)
// Status: deprecated | Level: high | ID: 28b9762b-5265-57f6-b15f-7c82e4c5698d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
