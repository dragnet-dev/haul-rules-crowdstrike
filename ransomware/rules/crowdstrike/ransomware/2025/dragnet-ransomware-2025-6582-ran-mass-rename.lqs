// Dragnet [Ransomware]: dragnet-ransomware-2025-6582 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 9414e64b-06ca-5d73-88d7-a93b7e72df5e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
