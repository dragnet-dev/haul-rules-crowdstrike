// Dragnet [Ransomware]: dragnet-ransomware-2025-5243 — Mass File Rename (warlock)
// Status: deprecated | Level: high | ID: 8129a2c5-ccf9-5eaa-af07-1c0b8846973d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
