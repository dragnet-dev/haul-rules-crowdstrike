// Dragnet [Ransomware]: dragnet-ransomware-2023-2483 — Mass File Rename (noescape)
// Status: experimental | Level: high | ID: d505fc81-0059-5370-af96-d83b478ac671

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
