// Dragnet [Container]: dragnet-container-2024-0475 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 275505da-d826-5943-b1f8-d0393e9e1f1e

#event_simpleName=*
| (ImageFileName = *almalinux:8* OR ImageFileName = *alpine:3.10* OR ImageFileName = *alpine:3.11* OR ImageFileName = *alpine:3.9* OR ImageFileName = *amazonlinux:1* OR ImageFileName = *amazonlinux:2* OR ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:9* OR ImageFileName = *oraclelinux:7* OR ImageFileName = *oraclelinux:8* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:16.04* OR ImageFileName = *ubuntu:16.04-ESM* OR ImageFileName = *ubuntu:18.04* OR ImageFileName = *ubuntu:18.04-ESM* OR ImageFileName = *ubuntu:19.10* OR ImageFileName = *ubuntu:20.04* OR ImageFileName = *ubuntu:20.04-ESM* OR ImageFileName = *ubuntu:20.10* OR ImageFileName = *ubuntu:21.04*)
| table([timestamp, ComputerName])
| limit(1000)
