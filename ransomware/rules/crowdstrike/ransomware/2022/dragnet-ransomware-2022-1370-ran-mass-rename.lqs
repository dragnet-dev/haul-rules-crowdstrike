// Dragnet [Ransomware]: dragnet-ransomware-2022-1370 — Mass File Rename (cheers)
// Status: deprecated | Level: high | ID: ec5eb4a7-447a-5ede-afba-397f26ca761e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
