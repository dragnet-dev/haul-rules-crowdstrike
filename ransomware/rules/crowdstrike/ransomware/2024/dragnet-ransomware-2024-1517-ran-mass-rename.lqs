// Dragnet [Ransomware]: dragnet-ransomware-2024-1517 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: ab3f5c63-07c5-56ea-b525-f3551adb7305

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
