// Dragnet [Ransomware]: dragnet-ransomware-2022-2415 — Mass File Rename (darkleakmarket)
// Status: deprecated | Level: high | ID: 9c039fe8-5a3a-57e0-a1e2-566be8fa4c58

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
