// Dragnet [Ransomware]: dragnet-ransomware-2023-1576 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 4818b61e-4c1f-597c-95da-7c8c96f80c06

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
