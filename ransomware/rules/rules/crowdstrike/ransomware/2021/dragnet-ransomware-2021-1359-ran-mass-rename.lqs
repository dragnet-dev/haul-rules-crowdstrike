// Dragnet [Ransomware]: dragnet-ransomware-2021-1359 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 26a1fccb-c94c-54ac-b11d-f52a3e92f2cd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
