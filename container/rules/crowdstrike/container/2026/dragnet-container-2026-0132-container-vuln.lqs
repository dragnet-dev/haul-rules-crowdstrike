// Dragnet [Container]: dragnet-container-2026-0132 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 594aad17-0a0c-5755-ae71-551520aacb52

#event_simpleName=*
| (ImageFileName = *amazonlinux:1* OR ImageFileName = *chainguard:* OR ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10*)
| table([timestamp, ComputerName])
| limit(1000)
