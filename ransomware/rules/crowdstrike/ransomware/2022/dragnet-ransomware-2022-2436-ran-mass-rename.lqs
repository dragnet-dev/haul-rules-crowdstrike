// Dragnet [Ransomware]: dragnet-ransomware-2022-2436 — Mass File Rename (ragnarlocker)
// Status: deprecated | Level: high | ID: ac0112ad-c5c1-5cca-8722-195a3ff885d8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
