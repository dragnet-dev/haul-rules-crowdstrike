// Dragnet [Ransomware]: dragnet-ransomware-2023-4912 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 618505e7-2353-58df-aeb6-398a2485bca9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
