// Dragnet [Ransomware]: dragnet-ransomware-2026-0208 — Mass File Rename (incransom)
// Status: stable | Level: high | ID: 75c47c58-10f4-522b-81e4-c2fd93782938

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
