// Dragnet [Ransomware]: dragnet-ransomware-2022-0860 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: 38e114fd-a189-588c-8add-40ce10c84f18

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
