// Dragnet [Ransomware]: dragnet-ransomware-2025-0412 — Mass File Rename (pear)
// Status: experimental | Level: high | ID: fc95e542-df5a-59ea-a025-4dffb5fb12b0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
