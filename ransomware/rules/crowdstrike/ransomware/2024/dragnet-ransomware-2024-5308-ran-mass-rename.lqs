// Dragnet [Ransomware]: dragnet-ransomware-2024-5308 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 7c1cc273-11ea-5395-8163-2ffe1ff20994

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
