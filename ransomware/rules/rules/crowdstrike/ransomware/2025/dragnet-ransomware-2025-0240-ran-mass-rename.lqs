// Dragnet [Ransomware]: dragnet-ransomware-2025-0240 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 8902bf17-926e-5263-9bed-7f1eb1320d00

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
