// Dragnet [Ransomware]: dragnet-ransomware-2025-1156 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: be9501cf-8edf-5449-b48f-a9d91fe7417b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
