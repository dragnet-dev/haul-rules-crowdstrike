// Dragnet [Ransomware]: dragnet-ransomware-2025-5792 — Mass File Rename (interlock)
// Status: experimental | Level: high | ID: 2bd03d9d-1b55-52c0-89e3-d81d59476470

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
