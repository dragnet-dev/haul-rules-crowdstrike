// Dragnet [Ransomware]: dragnet-ransomware-2025-6555 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: c5f88c55-736c-519f-af6b-0a61c4222121

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
