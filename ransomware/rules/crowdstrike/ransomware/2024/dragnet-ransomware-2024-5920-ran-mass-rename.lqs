// Dragnet [Ransomware]: dragnet-ransomware-2024-5920 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 5c47683f-20e0-5e8d-bfb5-b11ee9282662

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
