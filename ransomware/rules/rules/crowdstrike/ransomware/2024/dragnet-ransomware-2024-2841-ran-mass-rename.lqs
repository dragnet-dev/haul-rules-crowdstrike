// Dragnet [Ransomware]: dragnet-ransomware-2024-2841 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 31d3a779-522e-5faf-83dc-989bb8e45a73

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
