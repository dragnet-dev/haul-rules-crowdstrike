// Dragnet [Ransomware]: dragnet-ransomware-2023-1652 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 2dd2fdd2-fc39-5cab-9ce9-26bd4d65af00

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
