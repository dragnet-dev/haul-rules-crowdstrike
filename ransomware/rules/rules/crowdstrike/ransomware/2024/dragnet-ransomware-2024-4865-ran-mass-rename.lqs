// Dragnet [Ransomware]: dragnet-ransomware-2024-4865 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 39bdb57c-79bd-5269-a51c-c1b2bd29492a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
