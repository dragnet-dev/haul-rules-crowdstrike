// Dragnet [Ransomware]: dragnet-ransomware-2025-7630 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: f8c82de3-7e1d-5c49-836f-08c39de61b0c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
