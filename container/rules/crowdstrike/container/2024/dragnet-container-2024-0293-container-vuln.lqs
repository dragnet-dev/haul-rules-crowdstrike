// Dragnet [Container]: dragnet-container-2024-0293 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 25397953-d7a1-59c4-b340-a8a3a5ee783e

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *redhat/ubi9:*)
| table([timestamp, ComputerName])
| limit(1000)
