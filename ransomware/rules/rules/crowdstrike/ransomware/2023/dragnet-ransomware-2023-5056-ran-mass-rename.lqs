// Dragnet [Ransomware]: dragnet-ransomware-2023-5056 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 3cdf1d81-7eec-5e24-bf88-56c50381faa1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
