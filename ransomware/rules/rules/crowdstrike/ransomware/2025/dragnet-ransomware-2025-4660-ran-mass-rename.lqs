// Dragnet [Ransomware]: dragnet-ransomware-2025-4660 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 3e74ab15-86ca-51aa-89e7-5c92095a00eb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
