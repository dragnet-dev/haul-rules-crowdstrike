// Dragnet [Ransomware]: dragnet-ransomware-2024-1304 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: b15fda1b-3b40-5055-bd42-8376dcd799ee

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
