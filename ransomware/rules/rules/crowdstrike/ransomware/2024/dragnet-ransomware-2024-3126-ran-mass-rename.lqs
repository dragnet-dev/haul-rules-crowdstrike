// Dragnet [Ransomware]: dragnet-ransomware-2024-3126 — Mass File Rename (dragonforce)
// Status: deprecated | Level: high | ID: 295a4441-7204-5952-a5c3-25f0b26552ce

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
