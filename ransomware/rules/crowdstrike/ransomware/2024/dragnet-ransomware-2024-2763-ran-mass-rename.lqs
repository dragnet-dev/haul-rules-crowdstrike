// Dragnet [Ransomware]: dragnet-ransomware-2024-2763 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 136c98d5-9f32-52fe-9479-e63b6b8a5436

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
