// Dragnet [Ransomware]: dragnet-ransomware-2023-5313 — Mass File Rename (hunters)
// Status: deprecated | Level: high | ID: adf276c7-cf04-55fc-a3e5-64934e71eec7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
