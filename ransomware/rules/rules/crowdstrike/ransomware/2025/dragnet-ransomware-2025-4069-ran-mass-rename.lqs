// Dragnet [Ransomware]: dragnet-ransomware-2025-4069 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 80a71db8-91d7-5a8d-a5a1-9294edf6f7cb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
