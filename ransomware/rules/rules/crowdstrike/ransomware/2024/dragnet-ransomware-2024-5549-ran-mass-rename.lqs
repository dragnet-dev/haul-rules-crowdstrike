// Dragnet [Ransomware]: dragnet-ransomware-2024-5549 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 49cc95ab-c0c1-57fe-8c8d-f161f432d611

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
