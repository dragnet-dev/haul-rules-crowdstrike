// Dragnet [Ransomware]: dragnet-ransomware-2023-1188 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 1d96d3e5-5112-5f8b-ab2f-f453e3a7790c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
