// Dragnet [Ransomware]: dragnet-ransomware-2022-0721 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 01a83623-217c-550d-b2f8-69f82bd427bf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
