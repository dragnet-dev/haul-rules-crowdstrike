// Dragnet [Ransomware]: dragnet-ransomware-2025-5039 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 2131baca-d770-5d53-8b6c-bba5a1253f31

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
