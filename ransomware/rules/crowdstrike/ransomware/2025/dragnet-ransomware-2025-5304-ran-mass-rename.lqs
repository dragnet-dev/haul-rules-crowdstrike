// Dragnet [Ransomware]: dragnet-ransomware-2025-5304 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 70bdd878-0914-5f99-8ddc-fc4dc661a2ac

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
