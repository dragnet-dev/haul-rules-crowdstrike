// Dragnet [Ransomware]: dragnet-ransomware-2025-3231 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 5b412a43-03f7-5ef8-805e-d874cde78243

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
