// Dragnet [Ransomware]: dragnet-ransomware-2025-3736 — Mass File Rename (sinobi)
// Status: experimental | Level: high | ID: bd921515-60f4-50ea-9739-d9ada3913926

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
