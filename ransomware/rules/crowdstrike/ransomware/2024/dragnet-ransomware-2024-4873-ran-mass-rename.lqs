// Dragnet [Ransomware]: dragnet-ransomware-2024-4873 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 792e9bd4-8da2-52cb-b962-563f80428d68

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
