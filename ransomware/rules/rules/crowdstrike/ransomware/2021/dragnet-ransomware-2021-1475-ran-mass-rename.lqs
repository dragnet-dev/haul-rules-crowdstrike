// Dragnet [Ransomware]: dragnet-ransomware-2021-1475 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 97f4bdf1-de08-5f18-b416-a6e0e0c2ded6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
