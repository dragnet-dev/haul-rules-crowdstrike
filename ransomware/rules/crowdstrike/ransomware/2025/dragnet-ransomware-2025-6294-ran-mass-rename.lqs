// Dragnet [Ransomware]: dragnet-ransomware-2025-6294 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: 1c8caaa6-c019-5269-b8dc-b54b7a8ad1cb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
