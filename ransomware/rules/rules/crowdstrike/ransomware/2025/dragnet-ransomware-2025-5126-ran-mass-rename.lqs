// Dragnet [Ransomware]: dragnet-ransomware-2025-5126 — Mass File Rename (spacebears)
// Status: test | Level: high | ID: a7565052-a244-5140-9c78-ca81bb30f6ee

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
