// Dragnet [Ransomware]: dragnet-ransomware-2023-3195 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 7d780915-95f5-582f-ab07-12f597071499

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
