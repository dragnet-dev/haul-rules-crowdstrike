// Dragnet [Ransomware]: dragnet-ransomware-2025-0866 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 38d22f29-01a9-5b46-8d70-ef6d7a88d7ec

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
