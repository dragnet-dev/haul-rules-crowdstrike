// Dragnet [Ransomware]: dragnet-ransomware-2025-0849 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 4835e0b7-a874-57a6-b4ae-75444441a2d1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
