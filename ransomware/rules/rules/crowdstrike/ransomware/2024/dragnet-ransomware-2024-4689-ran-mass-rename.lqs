// Dragnet [Ransomware]: dragnet-ransomware-2024-4689 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 88dde947-1d0f-53e5-aaf0-29b3826d2242

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
