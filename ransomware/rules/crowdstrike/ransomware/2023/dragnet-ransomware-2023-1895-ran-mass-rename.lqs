// Dragnet [Ransomware]: dragnet-ransomware-2023-1895 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 208eea94-a480-52d9-aafc-7478cad1ee29

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
