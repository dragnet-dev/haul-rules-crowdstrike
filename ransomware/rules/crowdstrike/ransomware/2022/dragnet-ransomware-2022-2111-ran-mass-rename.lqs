// Dragnet [Ransomware]: dragnet-ransomware-2022-2111 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 20ad79de-5290-51d6-a378-9b1edd464d98

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
