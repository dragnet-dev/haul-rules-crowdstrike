// Dragnet [Ransomware]: dragnet-ransomware-2022-0876 — Mass File Rename (lv)
// Status: deprecated | Level: high | ID: 22b131db-e8f2-560e-9440-1c87f831bb64

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
