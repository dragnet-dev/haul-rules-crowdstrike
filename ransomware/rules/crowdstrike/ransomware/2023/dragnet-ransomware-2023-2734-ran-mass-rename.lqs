// Dragnet [Ransomware]: dragnet-ransomware-2023-2734 — Mass File Rename (mallox)
// Status: experimental | Level: high | ID: a0ee3cc1-766e-5761-a1d8-b69acbc48437

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
