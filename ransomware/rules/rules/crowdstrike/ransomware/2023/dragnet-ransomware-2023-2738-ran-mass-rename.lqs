// Dragnet [Ransomware]: dragnet-ransomware-2023-2738 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 379d683a-505a-58c4-812f-2008d3ef5492

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
