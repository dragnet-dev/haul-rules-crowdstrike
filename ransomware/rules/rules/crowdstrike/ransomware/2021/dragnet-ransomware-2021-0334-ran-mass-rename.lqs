// Dragnet [Ransomware]: dragnet-ransomware-2021-0334 — Mass File Rename (everest)
// Status: deprecated | Level: high | ID: 0b3e691b-00c7-555d-8637-39de79f138e6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
