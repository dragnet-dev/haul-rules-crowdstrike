// Dragnet [Ransomware]: dragnet-ransomware-2026-1637 — Mass File Rename (LeakBazaar)
// Status: stable | Level: high | ID: b252af42-ebea-5b0e-8711-0df2f52a2987

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
