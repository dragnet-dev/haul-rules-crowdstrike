// Dragnet [Ransomware]: dragnet-ransomware-2023-0565 — Mass File Rename (karakurt)
// Status: experimental | Level: high | ID: c4e5ec81-cc6c-5c72-8140-78c94561fcd3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
