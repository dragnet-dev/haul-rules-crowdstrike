// Dragnet [Ransomware]: dragnet-ransomware-2024-4080 — Mass File Rename (madliberator)
// Status: experimental | Level: high | ID: dc9d765a-9fe3-5dac-bdbf-bc1f1750fa6d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
