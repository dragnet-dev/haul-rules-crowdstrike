// Dragnet [Ransomware]: dragnet-ransomware-2023-3563 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: befe88ac-bd81-5f3c-9566-9c2818e632f1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
