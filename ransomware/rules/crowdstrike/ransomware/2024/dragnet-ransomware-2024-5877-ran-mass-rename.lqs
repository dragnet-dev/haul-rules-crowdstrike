// Dragnet [Ransomware]: dragnet-ransomware-2024-5877 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 9d1cdb19-c4e8-537a-b702-41283b4e3bb1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
