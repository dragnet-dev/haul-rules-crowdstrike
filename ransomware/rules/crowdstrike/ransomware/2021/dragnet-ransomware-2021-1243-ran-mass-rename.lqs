// Dragnet [Ransomware]: dragnet-ransomware-2021-1243 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 06320130-3e66-5ecf-be03-64133768fda8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
