// Dragnet [Ransomware]: dragnet-ransomware-2024-3615 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 94ec5602-5dc8-5d97-9dfd-3790d58f8a86

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
