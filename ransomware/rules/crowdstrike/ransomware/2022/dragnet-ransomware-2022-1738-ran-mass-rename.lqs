// Dragnet [Ransomware]: dragnet-ransomware-2022-1738 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 0eeeec02-d588-53c2-b676-96b9fe794a13

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
