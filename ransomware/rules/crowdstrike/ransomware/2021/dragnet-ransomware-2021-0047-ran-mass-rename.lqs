// Dragnet [Ransomware]: dragnet-ransomware-2021-0047 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: c32ee740-0ff9-5e3b-a0cb-7be526dbb7d2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
