// Dragnet [Ransomware]: dragnet-ransomware-2022-2984 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 1d9905dd-cc4a-5671-a048-aa4b808d5c1e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
