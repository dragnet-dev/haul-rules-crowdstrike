// Dragnet [Ransomware]: dragnet-ransomware-2022-0048 — Mass File Rename (bianlian)
// Status: deprecated | Level: high | ID: d4fbbe5f-5f34-5593-ad3f-cbaa3e836ffb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
