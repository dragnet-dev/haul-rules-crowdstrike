// Dragnet [Ransomware]: dragnet-ransomware-2024-3894 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: c0701bd0-69f3-50fc-8fc9-60e5317efcd2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
