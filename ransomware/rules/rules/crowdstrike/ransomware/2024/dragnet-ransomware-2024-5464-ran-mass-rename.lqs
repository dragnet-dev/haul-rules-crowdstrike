// Dragnet [Ransomware]: dragnet-ransomware-2024-5464 — Mass File Rename (cloak)
// Status: experimental | Level: high | ID: 3f0beead-b220-50e7-ac51-13f9ca5e6ed8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
