// Dragnet [Ransomware]: dragnet-ransomware-2025-0437 — Mass File Rename (devman)
// Status: experimental | Level: high | ID: b78e57c9-4f36-5bd2-ab73-d4252d43dd4e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
