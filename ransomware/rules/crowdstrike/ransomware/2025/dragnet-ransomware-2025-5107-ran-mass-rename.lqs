// Dragnet [Ransomware]: dragnet-ransomware-2025-5107 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 68153367-d837-5ee2-8b7c-ae27e1eed445

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
