// Dragnet [Ransomware]: dragnet-ransomware-2024-3588 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 88405450-aeea-5f57-9057-e3e4b7f26409

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
