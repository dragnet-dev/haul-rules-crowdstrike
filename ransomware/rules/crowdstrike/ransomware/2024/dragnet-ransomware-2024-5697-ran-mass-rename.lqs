// Dragnet [Ransomware]: dragnet-ransomware-2024-5697 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 50a31d37-9e52-517f-89fa-9974d5cdfc31

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
