// Dragnet [Ransomware]: dragnet-ransomware-2025-1804 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 16a6278a-72cf-5979-942a-5cedbd8c575a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
