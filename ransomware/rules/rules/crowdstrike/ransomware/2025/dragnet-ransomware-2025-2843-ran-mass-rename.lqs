// Dragnet [Ransomware]: dragnet-ransomware-2025-2843 — Mass File Rename (beast)
// Status: experimental | Level: high | ID: 8d3b3bd9-bdcd-531c-9f05-c0ef93a4e6f8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
