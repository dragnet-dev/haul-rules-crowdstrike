// Dragnet [Ransomware]: dragnet-ransomware-2025-6449 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: c8a04043-a31d-5e6d-a07c-797898ded5ef

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
