// Dragnet [Ransomware]: dragnet-ransomware-2021-1075 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: c36acc8f-7fc6-573f-bdbb-88c3170ce18b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
