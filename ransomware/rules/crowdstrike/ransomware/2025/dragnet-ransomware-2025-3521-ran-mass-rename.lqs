// Dragnet [Ransomware]: dragnet-ransomware-2025-3521 — Mass File Rename (rhysida)
// Status: experimental | Level: high | ID: b47a5eea-1c36-5921-8080-2bbab517cff9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
