// Dragnet [Ransomware]: dragnet-ransomware-2025-1004 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: a01eda0e-bbcb-5a7e-96f6-c8edeabfc84e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
