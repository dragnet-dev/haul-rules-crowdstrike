// Dragnet [Ransomware]: dragnet-ransomware-2023-0915 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: cebed198-5536-5872-9230-ebb6c862df30

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
