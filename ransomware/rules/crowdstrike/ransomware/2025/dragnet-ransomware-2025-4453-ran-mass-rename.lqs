// Dragnet [Ransomware]: dragnet-ransomware-2025-4453 — Mass File Rename (chaos)
// Status: experimental | Level: high | ID: 2deabdf5-2698-5315-881e-37bc9cd6381b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
