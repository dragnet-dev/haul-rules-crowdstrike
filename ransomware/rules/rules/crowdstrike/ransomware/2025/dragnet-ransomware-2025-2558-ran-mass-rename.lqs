// Dragnet [Ransomware]: dragnet-ransomware-2025-2558 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: f651c3b6-5557-5763-a38b-d01e30d916a0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
