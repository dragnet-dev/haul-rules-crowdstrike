// Dragnet [Ransomware]: dragnet-ransomware-2023-0736 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 14465a19-a8cf-541b-9445-fd9d49696437

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
