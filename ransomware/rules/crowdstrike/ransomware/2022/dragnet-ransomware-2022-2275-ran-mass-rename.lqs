// Dragnet [Ransomware]: dragnet-ransomware-2022-2275 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: c7915c15-2cba-56ee-b926-1225c74e5549

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
