// Dragnet [Ransomware]: dragnet-ransomware-2023-1798 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: ef1d099f-8083-5b82-ab2c-b5f5306d140d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
