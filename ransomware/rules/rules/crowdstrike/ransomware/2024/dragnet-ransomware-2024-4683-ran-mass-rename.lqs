// Dragnet [Ransomware]: dragnet-ransomware-2024-4683 — Mass File Rename (blackout)
// Status: experimental | Level: high | ID: 55c70eca-fe56-52ee-889f-1f9de62da695

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
