// Dragnet [Ransomware]: dragnet-ransomware-2023-0347 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 430f0420-3674-5d04-9eb5-307b25916969

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
