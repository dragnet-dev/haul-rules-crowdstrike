// Dragnet [Ransomware]: dragnet-ransomware-2025-6976 — Mass File Rename (securotrop)
// Status: experimental | Level: high | ID: 6d85a265-9431-53e3-8ed1-02ce55bb572b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
