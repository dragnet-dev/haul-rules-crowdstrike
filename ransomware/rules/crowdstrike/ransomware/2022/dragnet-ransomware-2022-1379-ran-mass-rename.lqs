// Dragnet [Ransomware]: dragnet-ransomware-2022-1379 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 732f2e6b-a976-514c-8ef6-c5194bad54e5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
