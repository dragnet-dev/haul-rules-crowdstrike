// Dragnet [Ransomware]: dragnet-ransomware-2023-4226 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: f3576325-221a-5830-84ba-ff2ae16089fb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
