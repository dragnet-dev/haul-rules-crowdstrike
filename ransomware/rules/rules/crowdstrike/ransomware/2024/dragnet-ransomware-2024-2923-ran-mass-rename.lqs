// Dragnet [Ransomware]: dragnet-ransomware-2024-2923 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 0392fcd3-86dd-53f5-a624-36ab0454f728

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
