// Dragnet [Ransomware]: dragnet-ransomware-2023-2271 — Mass File Rename (knight)
// Status: experimental | Level: high | ID: d2ee0d61-512a-53bc-a446-a5c586c0e5d6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
