// Dragnet [Ransomware]: dragnet-ransomware-2024-1672 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: 78ce9d30-eb56-5cb5-92ad-1bf9d34f20b4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
