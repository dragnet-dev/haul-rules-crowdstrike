// Dragnet [Ransomware]: dragnet-ransomware-2024-1299 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 6c44ab8c-ed26-5f2d-a0a6-e1c4b288c726

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
