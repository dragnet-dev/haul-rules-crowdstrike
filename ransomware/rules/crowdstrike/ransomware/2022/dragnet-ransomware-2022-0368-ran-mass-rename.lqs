// Dragnet [Ransomware]: dragnet-ransomware-2022-0368 — Mass File Rename (blackbasta)
// Status: deprecated | Level: high | ID: 028ecc4a-f91c-517e-a53f-4584483a9eed

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
