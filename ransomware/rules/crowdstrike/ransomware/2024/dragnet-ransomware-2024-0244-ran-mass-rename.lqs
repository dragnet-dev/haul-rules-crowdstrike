// Dragnet [Ransomware]: dragnet-ransomware-2024-0244 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 2c6a7754-0513-5045-b7d2-6ed55c65077d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
