// Dragnet [Ransomware]: dragnet-ransomware-2024-5805 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 3963b96d-a814-5417-abe9-2f0fbf6f5726

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
