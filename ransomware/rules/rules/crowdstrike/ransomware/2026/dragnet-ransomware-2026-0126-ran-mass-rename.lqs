// Dragnet [Ransomware]: dragnet-ransomware-2026-0126 — Mass File Rename (cipherforce)
// Status: stable | Level: high | ID: 242d32b4-e1e2-53cc-9c24-190dd229a2bd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
