// Dragnet [Ransomware]: dragnet-ransomware-2025-2738 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: eabd5732-1c48-5a5a-a179-5300a581cdbf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
