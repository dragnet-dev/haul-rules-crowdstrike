// Dragnet [Container]: dragnet-container-2024-1157 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 84e925db-7db0-5f1f-a86f-6ff2348b4e81

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:9*)
| table([timestamp, ComputerName])
| limit(1000)
