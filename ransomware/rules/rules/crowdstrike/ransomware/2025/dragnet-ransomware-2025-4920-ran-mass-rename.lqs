// Dragnet [Ransomware]: dragnet-ransomware-2025-4920 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: caee1d22-1c82-5c20-af89-915a9704a957

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
