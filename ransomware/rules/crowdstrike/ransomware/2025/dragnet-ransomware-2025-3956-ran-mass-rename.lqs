// Dragnet [Ransomware]: dragnet-ransomware-2025-3956 — Mass File Rename (chaos)
// Status: experimental | Level: high | ID: 1a842278-3c59-5bfb-a2fd-bd9499078212

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
