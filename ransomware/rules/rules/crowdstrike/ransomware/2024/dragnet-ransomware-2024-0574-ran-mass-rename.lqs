// Dragnet [Ransomware]: dragnet-ransomware-2024-0574 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: bc59447e-4d50-5765-8b49-2a19d3ace4a5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
