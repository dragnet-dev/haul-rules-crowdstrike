// Dragnet [Ransomware]: dragnet-ransomware-2025-3334 — Mass File Rename (shinyhunters)
// Status: experimental | Level: high | ID: 86463cb2-491d-5e3d-b17d-abeab6e1dc74

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
