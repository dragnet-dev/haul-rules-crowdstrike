// Dragnet [Ransomware]: dragnet-ransomware-2025-6335 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: d50d690c-fdca-59c6-beb9-66016a3345ee

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
