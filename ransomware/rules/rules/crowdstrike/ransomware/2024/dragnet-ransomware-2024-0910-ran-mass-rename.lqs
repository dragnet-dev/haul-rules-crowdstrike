// Dragnet [Ransomware]: dragnet-ransomware-2024-0910 — Mass File Rename (ransomhouse)
// Status: experimental | Level: high | ID: d23eb7ed-f2a3-507b-b078-dde24748e109

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
