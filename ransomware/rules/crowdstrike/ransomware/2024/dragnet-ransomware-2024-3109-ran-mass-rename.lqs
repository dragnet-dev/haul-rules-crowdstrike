// Dragnet [Ransomware]: dragnet-ransomware-2024-3109 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 9c29c336-4ba7-5df6-9936-7b48f75a4333

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
