// Dragnet [Ransomware]: dragnet-ransomware-2023-1268 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: b354add8-230d-5b8f-9769-79d010b5156c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
