// Dragnet [Ransomware]: dragnet-ransomware-2025-5991 — Mass File Rename (chaos)
// Status: experimental | Level: high | ID: 2e556806-4d78-5817-b50e-c8e75cab719a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
