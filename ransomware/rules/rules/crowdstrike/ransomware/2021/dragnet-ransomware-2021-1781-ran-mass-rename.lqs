// Dragnet [Ransomware]: dragnet-ransomware-2021-1781 — Mass File Rename (alphv)
// Status: deprecated | Level: high | ID: 97184096-6c15-5a25-88d3-365f5748a554

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
