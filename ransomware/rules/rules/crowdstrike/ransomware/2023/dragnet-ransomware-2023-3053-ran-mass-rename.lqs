// Dragnet [Ransomware]: dragnet-ransomware-2023-3053 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 3010f757-b6fc-5d29-9de9-02505bb6de7f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
