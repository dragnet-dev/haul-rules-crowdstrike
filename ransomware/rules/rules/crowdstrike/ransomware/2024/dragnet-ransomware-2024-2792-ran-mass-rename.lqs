// Dragnet [Ransomware]: dragnet-ransomware-2024-2792 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 631f9371-08b3-5497-ae21-25301e0beed7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
