// Dragnet [Ransomware]: dragnet-ransomware-2025-6228 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 51afda86-5e51-5cf4-a8ef-c4055476d379

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
