// Dragnet [Ransomware]: dragnet-ransomware-2025-2347 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: f543a915-77e0-5af3-81c1-f6a81b9156aa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
