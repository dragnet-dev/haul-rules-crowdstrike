// Dragnet [Ransomware]: dragnet-ransomware-2024-3960 — Mass File Rename (meow)
// Status: experimental | Level: high | ID: c55dda22-15ae-5a6e-80bb-6b8f1c374992

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
