// Dragnet [Ransomware]: dragnet-ransomware-2025-1808 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: 84b97fe7-5402-542b-ab44-fcd7e503eb45

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
