// Dragnet [Ransomware]: dragnet-ransomware-2023-3958 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: a3fe46a9-d203-5848-9009-d5479762cb39

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
