// Dragnet [Ransomware]: dragnet-ransomware-2023-4678 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 7b4ddd60-c240-523d-9fce-e0cdeaf6fbe9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
