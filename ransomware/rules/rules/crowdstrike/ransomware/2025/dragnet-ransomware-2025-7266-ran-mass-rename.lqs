// Dragnet [Ransomware]: dragnet-ransomware-2025-7266 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 9fc4421a-3e8c-5e30-aedc-f7e4b7f7f9ae

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
