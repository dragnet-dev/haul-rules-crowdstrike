// Dragnet [Container]: dragnet-container-2026-2916 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 8e251b3f-51d5-51eb-957b-a68301f32ffe

#event_simpleName=*
| (ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *redhat/ubi9:*)
| table([timestamp, ComputerName])
| limit(1000)
