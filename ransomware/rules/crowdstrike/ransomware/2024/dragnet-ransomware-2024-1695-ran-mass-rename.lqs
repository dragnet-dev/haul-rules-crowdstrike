// Dragnet [Ransomware]: dragnet-ransomware-2024-1695 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: f85fccbf-6e7a-55af-8553-50a6b3847052

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
