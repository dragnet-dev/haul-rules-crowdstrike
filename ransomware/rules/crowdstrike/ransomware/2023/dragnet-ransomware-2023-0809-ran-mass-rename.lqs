// Dragnet [Ransomware]: dragnet-ransomware-2023-0809 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: 28624a5e-8acd-5080-a532-4e7ce00e1141

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
