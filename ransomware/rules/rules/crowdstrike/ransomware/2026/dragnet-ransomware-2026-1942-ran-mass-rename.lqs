// Dragnet [Ransomware]: dragnet-ransomware-2026-1942 — Mass File Rename (LeakBazaar)
// Status: stable | Level: high | ID: fa2f506f-cc00-5930-b0bb-573aa26e3996

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
