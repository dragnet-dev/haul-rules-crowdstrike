// Dragnet [Ransomware]: dragnet-ransomware-2023-5291 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: f5e619b9-a46f-5c21-99fa-1670223a5998

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
