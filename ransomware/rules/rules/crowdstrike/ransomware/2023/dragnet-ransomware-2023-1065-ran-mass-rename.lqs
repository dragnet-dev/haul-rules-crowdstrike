// Dragnet [Ransomware]: dragnet-ransomware-2023-1065 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 4c5face7-46f2-5100-9c15-fce21737b257

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
