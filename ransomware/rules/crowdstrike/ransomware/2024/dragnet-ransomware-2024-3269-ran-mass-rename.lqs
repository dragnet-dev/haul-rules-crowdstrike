// Dragnet [Ransomware]: dragnet-ransomware-2024-3269 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 77618846-f1fd-5c11-809d-6e55b9686536

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
