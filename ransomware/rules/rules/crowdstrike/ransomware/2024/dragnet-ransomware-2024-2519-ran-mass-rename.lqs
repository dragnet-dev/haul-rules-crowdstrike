// Dragnet [Ransomware]: dragnet-ransomware-2024-2519 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: 64ac1929-0f30-5efc-86a2-a263cc7c53a4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
