// Dragnet [Ransomware]: dragnet-ransomware-2025-5072 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: b3b00d76-04c6-5e43-9ede-1a71a10303e1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
