// Dragnet [Ransomware]: dragnet-ransomware-2022-0947 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 454a2df4-c4e2-5946-92af-fccf5a0c4f97

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
