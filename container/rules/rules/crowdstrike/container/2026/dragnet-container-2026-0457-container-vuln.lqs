// Dragnet [Container]: dragnet-container-2026-0457 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 3156746d-2f36-5878-8edf-8c3396ac180c

#event_simpleName=*
| (ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10* OR ImageFileName = *ubuntu:13.04* OR ImageFileName = *ubuntu:13.10*)
| table([timestamp, ComputerName])
| limit(1000)
