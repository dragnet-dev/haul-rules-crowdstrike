// Dragnet [Container]: dragnet-container-2026-0373 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 22614586-f08e-5949-abf2-b215b5a29d2c

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
