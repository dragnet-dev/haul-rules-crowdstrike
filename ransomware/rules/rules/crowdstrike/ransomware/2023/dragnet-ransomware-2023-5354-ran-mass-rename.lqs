// Dragnet [Ransomware]: dragnet-ransomware-2023-5354 — Mass File Rename (devman)
// Status: experimental | Level: high | ID: baa51830-06a9-5e91-9522-0356d3fb93ef

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
