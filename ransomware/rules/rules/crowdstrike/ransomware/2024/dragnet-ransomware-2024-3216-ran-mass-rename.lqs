// Dragnet [Ransomware]: dragnet-ransomware-2024-3216 — Mass File Rename (ElDorado)
// Status: deprecated | Level: high | ID: 4b55d55b-9f3f-5a59-bfd6-0a5e4db4220e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
