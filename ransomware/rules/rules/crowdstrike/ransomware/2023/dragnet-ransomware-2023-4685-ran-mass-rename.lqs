// Dragnet [Ransomware]: dragnet-ransomware-2023-4685 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 998ad330-9955-5ff9-a951-b6b1192a4fd2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
