// Dragnet [Ransomware]: dragnet-ransomware-2021-1489 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: b063007d-e1ec-54d2-af3e-5cc92e21b645

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
