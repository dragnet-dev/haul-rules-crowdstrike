// Dragnet [Ransomware]: dragnet-ransomware-2024-2447 — Mass File Rename (ransomexx)
// Status: experimental | Level: high | ID: ab93bbb9-567b-5da2-a7dd-1491d7e8f3fa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
