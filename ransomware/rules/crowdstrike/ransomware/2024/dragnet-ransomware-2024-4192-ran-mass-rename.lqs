// Dragnet [Ransomware]: dragnet-ransomware-2024-4192 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 83b3aa95-48ac-54dd-9034-806a42381970

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
