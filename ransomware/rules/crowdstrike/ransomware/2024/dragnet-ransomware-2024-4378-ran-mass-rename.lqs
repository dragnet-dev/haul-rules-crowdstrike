// Dragnet [Ransomware]: dragnet-ransomware-2024-4378 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 54505544-461e-5994-9053-4fe142d676bf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
