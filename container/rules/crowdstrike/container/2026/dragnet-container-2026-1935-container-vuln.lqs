// Dragnet [Container]: dragnet-container-2026-1935 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 634cbc9a-306b-5390-9ed0-a718281546d5

#event_simpleName=*
| (ImageFileName = *almalinux:10* OR ImageFileName = *almalinux:9* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:9*)
| table([timestamp, ComputerName])
| limit(1000)
