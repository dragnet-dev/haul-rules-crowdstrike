// Dragnet [Ransomware]: dragnet-ransomware-2023-3756 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: ac99b01f-82f7-52ed-a66a-0c37ec69c619

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
