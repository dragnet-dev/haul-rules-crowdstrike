// Dragnet [Ransomware]: dragnet-ransomware-2022-2990 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 639fda64-bb96-5fe6-94b4-1514ede072a5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
