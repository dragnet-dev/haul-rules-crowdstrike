// Dragnet [Ransomware]: dragnet-ransomware-2023-4780 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 44479c17-2187-5ac8-bec5-0edae3ea262f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
