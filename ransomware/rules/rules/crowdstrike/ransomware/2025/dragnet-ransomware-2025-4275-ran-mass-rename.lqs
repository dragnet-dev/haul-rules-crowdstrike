// Dragnet [Ransomware]: dragnet-ransomware-2025-4275 — Mass File Rename (termite)
// Status: experimental | Level: high | ID: d5c2d831-19bf-53af-a3ba-7ab82771d6c1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
