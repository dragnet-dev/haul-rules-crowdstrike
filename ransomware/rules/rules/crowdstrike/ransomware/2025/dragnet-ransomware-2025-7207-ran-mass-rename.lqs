// Dragnet [Ransomware]: dragnet-ransomware-2025-7207 — Mass File Rename (shinyhunters)
// Status: deprecated | Level: high | ID: 7df779c8-f5db-5d19-a6a4-59e0b3190168

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
