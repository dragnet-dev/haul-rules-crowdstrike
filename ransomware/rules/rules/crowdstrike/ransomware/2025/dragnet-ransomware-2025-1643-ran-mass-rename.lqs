// Dragnet [Ransomware]: dragnet-ransomware-2025-1643 — Mass File Rename (arcusmedia)
// Status: experimental | Level: high | ID: a2a35ade-9a96-5919-b4d5-8ca063ec75c0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
