// Dragnet [Ransomware]: dragnet-ransomware-2024-3187 — Mass File Rename (nitrogen)
// Status: experimental | Level: high | ID: 28b47290-2f2d-538d-89e4-7616d78dea1c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
