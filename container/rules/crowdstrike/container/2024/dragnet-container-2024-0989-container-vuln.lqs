// Dragnet [Container]: dragnet-container-2024-0989 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: ac9b9868-cced-59f2-bcdb-b4e5f2665792

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:9*)
| table([timestamp, ComputerName])
| limit(1000)
