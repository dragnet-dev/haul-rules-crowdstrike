// Dragnet [Ransomware]: dragnet-ransomware-2025-0203 — Mass File Rename (worldleaks)
// Status: test | Level: high | ID: 860533b7-241c-5606-bc57-7beefd454354

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
