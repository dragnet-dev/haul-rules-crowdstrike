// Dragnet [Ransomware]: dragnet-ransomware-2022-1869 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 3b04c91a-cff6-53d7-bde9-486503e3c7ab

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
