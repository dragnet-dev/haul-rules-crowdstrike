// Dragnet [Ransomware]: dragnet-ransomware-2025-0892 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 1a9f67fa-7104-5a2d-ab11-4d9f14bf14c4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
