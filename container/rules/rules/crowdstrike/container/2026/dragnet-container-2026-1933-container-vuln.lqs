// Dragnet [Container]: dragnet-container-2026-1933 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 47962f24-2440-5d85-a360-91589ad9e5bd

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *ubuntu:14.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
