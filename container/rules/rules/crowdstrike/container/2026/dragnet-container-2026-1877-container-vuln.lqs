// Dragnet [Container]: dragnet-container-2026-1877 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 6378fe5c-a1e4-536b-a99e-594b22d69765

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
