// Dragnet [Ransomware]: dragnet-ransomware-2024-5538 — Mass File Rename (play)
// Status: experimental | Level: high | ID: faf15f5e-547f-5c36-8753-141f0652150c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
