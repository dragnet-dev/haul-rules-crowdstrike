// Dragnet [Ransomware]: dragnet-ransomware-2024-1456 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: efb3620e-639f-5922-89fd-881e3d89273c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
