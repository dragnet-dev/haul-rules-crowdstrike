// Dragnet [Ransomware]: dragnet-ransomware-2025-2659 — Mass File Rename (play)
// Status: experimental | Level: high | ID: e54afa2d-f770-53a8-bb5a-2ac175deebfe

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
