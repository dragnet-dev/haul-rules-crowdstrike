// Dragnet [Container]: dragnet-container-2025-0226 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: fcd8a8fb-c4f6-5f91-9eea-69fbea93d7b9

#event_simpleName=*
| (ImageFileName = *azure linux:3.0* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
