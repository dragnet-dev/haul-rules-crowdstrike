// Dragnet [Ransomware]: dragnet-ransomware-2025-5834 — Mass File Rename (trinity)
// Status: experimental | Level: high | ID: bd20f8b3-e59e-516e-8505-af689288d655

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
