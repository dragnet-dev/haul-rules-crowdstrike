// Dragnet [Ransomware]: dragnet-ransomware-2025-3639 — Mass File Rename (cactus)
// Status: deprecated | Level: high | ID: ea12a95a-3479-5275-a553-6c9f238133c3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
