// Dragnet [Ransomware]: dragnet-ransomware-2025-6364 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 8026b4a8-307e-5ad6-92cd-473b966e93ea

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
