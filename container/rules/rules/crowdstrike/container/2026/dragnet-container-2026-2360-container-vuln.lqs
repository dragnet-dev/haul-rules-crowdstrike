// Dragnet [Container]: dragnet-container-2026-2360 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 4b1347bc-82af-5297-a3ec-b95be27f4956

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
