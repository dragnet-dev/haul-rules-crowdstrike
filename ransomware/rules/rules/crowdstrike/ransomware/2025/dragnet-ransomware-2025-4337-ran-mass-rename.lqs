// Dragnet [Ransomware]: dragnet-ransomware-2025-4337 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 08b2c73a-dec4-55bc-a2e0-15867c8bf46b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
