// Dragnet [Ransomware]: dragnet-ransomware-2024-3766 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: d8288a13-8aa2-5f7d-bf64-6dd0dee1bc8f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
