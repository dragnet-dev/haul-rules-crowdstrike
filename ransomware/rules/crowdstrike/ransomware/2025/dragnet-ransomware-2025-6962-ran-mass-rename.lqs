// Dragnet [Ransomware]: dragnet-ransomware-2025-6962 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 46c9f8b5-12bd-5f13-83cd-56e2e59a4fcc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
