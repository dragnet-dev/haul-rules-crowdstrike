// Dragnet [Ransomware]: dragnet-ransomware-2025-0189 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 72f52c53-9060-53aa-b49c-19a3e46c1943

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
