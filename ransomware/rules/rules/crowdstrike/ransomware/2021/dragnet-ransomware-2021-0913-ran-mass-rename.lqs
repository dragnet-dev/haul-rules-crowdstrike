// Dragnet [Ransomware]: dragnet-ransomware-2021-0913 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 88a5fa7a-b630-59b8-a446-cb3d5e9a20af

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
