// Dragnet [Ransomware]: dragnet-ransomware-2022-0412 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: dd3495b6-0b92-5401-92be-cbbd50fb3a3d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
