// Dragnet [Ransomware]: dragnet-ransomware-2023-1786 — Mass File Rename (play)
// Status: experimental | Level: high | ID: eda1e1c2-cb4c-58c8-b7a9-605965ea70bd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
