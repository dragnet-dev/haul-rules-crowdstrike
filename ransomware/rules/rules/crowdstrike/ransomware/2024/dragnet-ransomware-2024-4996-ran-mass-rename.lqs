// Dragnet [Ransomware]: dragnet-ransomware-2024-4996 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: cfbb6e26-f932-5bcc-a39a-5a4d722651dc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
