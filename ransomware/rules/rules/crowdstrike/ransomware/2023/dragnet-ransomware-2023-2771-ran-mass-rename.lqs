// Dragnet [Ransomware]: dragnet-ransomware-2023-2771 — Mass File Rename (malas)
// Status: experimental | Level: high | ID: afb33d61-280b-5fa5-9463-aff46a46c5d3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
