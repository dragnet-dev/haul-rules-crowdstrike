// Dragnet [Ransomware]: dragnet-ransomware-2023-2285 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 8009dfc7-c9f8-5098-a2d0-bc1a5d0adf9f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
