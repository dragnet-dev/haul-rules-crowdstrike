// Dragnet [Ransomware]: dragnet-ransomware-2024-0776 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 8a80e52a-61a0-5412-8a54-c362f6ef63b3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
