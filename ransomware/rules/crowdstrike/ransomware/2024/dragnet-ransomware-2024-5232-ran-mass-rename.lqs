// Dragnet [Ransomware]: dragnet-ransomware-2024-5232 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 7af02f20-6149-5534-833f-ff9eb1ba2289

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
