// Dragnet [Ransomware]: dragnet-ransomware-2024-3888 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: f869bdf1-24b0-5648-90f3-9c9651a1345c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
