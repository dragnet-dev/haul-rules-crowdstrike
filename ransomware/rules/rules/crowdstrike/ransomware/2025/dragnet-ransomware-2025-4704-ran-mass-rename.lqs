// Dragnet [Ransomware]: dragnet-ransomware-2025-4704 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 6403392e-be66-5585-b0d0-0f71fad141c2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
