// Dragnet [Ransomware]: dragnet-ransomware-2024-4609 — Mass File Rename (blacklock)
// Status: experimental | Level: high | ID: a021213a-bae0-5d15-9f6d-f08e52fb63cb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
