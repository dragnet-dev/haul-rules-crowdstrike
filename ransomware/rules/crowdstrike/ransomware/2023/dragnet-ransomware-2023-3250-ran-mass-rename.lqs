// Dragnet [Ransomware]: dragnet-ransomware-2023-3250 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 70cc6de8-b5a4-58b3-9e67-cdc9475ed434

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
