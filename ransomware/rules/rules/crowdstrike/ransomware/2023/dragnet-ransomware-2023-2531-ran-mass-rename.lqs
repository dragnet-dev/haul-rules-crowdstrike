// Dragnet [Ransomware]: dragnet-ransomware-2023-2531 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 02ad0239-15df-5023-ae6b-36ccb1fb9599

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
