// Dragnet [Ransomware]: dragnet-ransomware-2024-0444 — Mass File Rename (handala)
// Status: experimental | Level: high | ID: e2b48c2d-4d6e-58a7-9aa5-18766645636d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
