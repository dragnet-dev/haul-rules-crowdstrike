// Dragnet [Ransomware]: dragnet-ransomware-2023-3546 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: d9908d29-2e2a-571e-97ac-0298a90fbec1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
