// Dragnet [Ransomware]: dragnet-ransomware-2024-0831 — Mass File Rename (meow)
// Status: experimental | Level: high | ID: 1160c7f1-33f5-5c9d-b454-e38fe8a31d29

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
