// Dragnet [Ransomware]: dragnet-ransomware-2022-3031 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 2bc1cec6-c5e6-546b-9215-b838dc019de7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
