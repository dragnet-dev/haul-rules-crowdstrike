// Dragnet [Ransomware]: dragnet-ransomware-2024-1507 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 72c11f9f-106e-58b7-8440-8f5168f83331

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
