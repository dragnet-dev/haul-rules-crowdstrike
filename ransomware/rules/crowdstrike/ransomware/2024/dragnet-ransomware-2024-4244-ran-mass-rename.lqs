// Dragnet [Ransomware]: dragnet-ransomware-2024-4244 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: e59f7123-edbe-510e-9fba-d6a376c8983c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
