// Dragnet [Container]: dragnet-container-2026-1873 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 4910b689-3884-590c-80e6-d069c7d4ce5c

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
