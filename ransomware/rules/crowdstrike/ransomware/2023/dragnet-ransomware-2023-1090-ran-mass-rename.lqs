// Dragnet [Ransomware]: dragnet-ransomware-2023-1090 — Mass File Rename (royal)
// Status: experimental | Level: high | ID: 95a54426-a5f7-56d3-8b2f-f56104c70204

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
