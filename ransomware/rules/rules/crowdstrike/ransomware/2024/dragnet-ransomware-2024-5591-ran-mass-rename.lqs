// Dragnet [Ransomware]: dragnet-ransomware-2024-5591 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: cf2aba12-0c75-5443-809f-ee17f8945cd4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
