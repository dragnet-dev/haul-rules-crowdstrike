// Dragnet [Ransomware]: dragnet-ransomware-2023-1418 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 5320cb40-e380-5387-83f3-064bf27d079f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
