// Dragnet [Ransomware]: dragnet-ransomware-2025-6407 — Mass File Rename (devman)
// Status: experimental | Level: high | ID: bee06633-28d3-507a-946e-dd362b3eb9c9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
