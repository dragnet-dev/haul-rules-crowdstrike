// Dragnet [Ransomware]: dragnet-ransomware-2024-4591 — Mass File Rename (ElDorado)
// Status: deprecated | Level: high | ID: 761e7a68-6412-58b6-aed4-b2899f728546

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
