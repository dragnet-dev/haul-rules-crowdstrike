// Dragnet [Ransomware]: dragnet-ransomware-2025-3112 — Mass File Rename (worldleaks)
// Status: experimental | Level: high | ID: 384174ea-e0e6-5dea-ab44-e0d33d43cc07

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
