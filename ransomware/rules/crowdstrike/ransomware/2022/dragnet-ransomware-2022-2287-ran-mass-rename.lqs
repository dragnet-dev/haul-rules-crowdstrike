// Dragnet [Ransomware]: dragnet-ransomware-2022-2287 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: b535f383-472f-5367-859e-f464f3f25e48

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
