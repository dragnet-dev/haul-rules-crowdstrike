// Dragnet [Ransomware]: dragnet-ransomware-2024-3663 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 91b6d662-25a7-5b5f-9e42-d822c4e2e978

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
