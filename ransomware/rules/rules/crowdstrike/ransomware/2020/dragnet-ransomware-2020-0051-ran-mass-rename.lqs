// Dragnet [Ransomware]: dragnet-ransomware-2020-0051 — Mass File Rename (maze)
// Status: deprecated | Level: high | ID: 6ceb8f8f-0210-5821-8331-ee6d4c5e874c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
