// Dragnet [Ransomware]: dragnet-ransomware-2024-3347 — Mass File Rename (madliberator)
// Status: experimental | Level: high | ID: 42c8c364-7095-53e3-b6a2-b402b7948d28

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
