// Dragnet [Ransomware]: dragnet-ransomware-2023-2309 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: e33c2564-862f-5e8c-8940-7de1e5eb3282

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
