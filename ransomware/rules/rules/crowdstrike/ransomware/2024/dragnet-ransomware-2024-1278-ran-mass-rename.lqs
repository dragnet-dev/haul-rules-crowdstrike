// Dragnet [Ransomware]: dragnet-ransomware-2024-1278 — Mass File Rename (dragonforce)
// Status: deprecated | Level: high | ID: 3d69e7e5-59ad-5e5d-ab43-dfe551a8c6cb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
