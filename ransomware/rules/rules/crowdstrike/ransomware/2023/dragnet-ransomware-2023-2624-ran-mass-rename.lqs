// Dragnet [Ransomware]: dragnet-ransomware-2023-2624 — Mass File Rename (stormous)
// Status: experimental | Level: high | ID: 3d4cf2fe-7b7a-5b18-aed6-bce44db6c8bf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
