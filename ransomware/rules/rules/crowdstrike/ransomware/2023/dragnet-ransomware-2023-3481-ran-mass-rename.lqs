// Dragnet [Ransomware]: dragnet-ransomware-2023-3481 — Mass File Rename (beast)
// Status: experimental | Level: high | ID: 2dca6ac3-e0de-5573-87e3-e20d0735cc64

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
