// Dragnet [Ransomware]: dragnet-ransomware-2025-2839 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: d25c73b8-9234-549c-b2cf-7a73cda767bc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
