// Dragnet [Ransomware]: dragnet-ransomware-2024-3117 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 846a4034-7850-5c57-9d9a-a0e2c01650cf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
