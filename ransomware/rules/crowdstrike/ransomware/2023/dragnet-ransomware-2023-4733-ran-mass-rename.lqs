// Dragnet [Ransomware]: dragnet-ransomware-2023-4733 — Mass File Rename (royal)
// Status: experimental | Level: high | ID: 1a2322c6-9aa1-55dd-b07f-924f009989ef

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
