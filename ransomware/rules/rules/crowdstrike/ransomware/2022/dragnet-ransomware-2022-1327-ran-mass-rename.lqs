// Dragnet [Ransomware]: dragnet-ransomware-2022-1327 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: c0c4d935-7fba-5a0c-bc5a-fd26ca4a5268

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
