// Dragnet [Ransomware]: dragnet-ransomware-2023-0985 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 5bccf3c7-36b6-593c-a7d1-bc9a69d93732

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
