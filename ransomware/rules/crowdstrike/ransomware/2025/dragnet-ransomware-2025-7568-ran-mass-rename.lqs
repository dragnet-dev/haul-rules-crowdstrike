// Dragnet [Ransomware]: dragnet-ransomware-2025-7568 — Mass File Rename (nova)
// Status: experimental | Level: high | ID: 23d089fb-f1ed-5574-bb60-10987735e63d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
