// Dragnet [Ransomware]: dragnet-ransomware-2024-2282 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 2bdd74ce-566d-541a-99be-b14f227b3cc6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
