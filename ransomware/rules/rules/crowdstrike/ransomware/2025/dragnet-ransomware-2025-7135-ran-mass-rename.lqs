// Dragnet [Ransomware]: dragnet-ransomware-2025-7135 — Mass File Rename (shinyhunters)
// Status: experimental | Level: high | ID: 2794c5d6-9e89-5d59-a895-65739e97295d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
