// Dragnet [Ransomware]: dragnet-ransomware-2025-4827 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 6f0a4fa1-91d8-5dd4-9c82-b05d9b09b0a5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
