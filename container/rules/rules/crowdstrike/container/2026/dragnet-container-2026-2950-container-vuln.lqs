// Dragnet [Container]: dragnet-container-2026-2950 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: a01fe0df-ed15-521b-938a-6dfdc9e575a8

#event_simpleName=*
| (ImageFileName = *alpine edge:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
