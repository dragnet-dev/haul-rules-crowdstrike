// Dragnet [Ransomware]: dragnet-ransomware-2024-4737 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: 36afb911-07b4-5c87-94ab-fdc1fe12e2ac

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
