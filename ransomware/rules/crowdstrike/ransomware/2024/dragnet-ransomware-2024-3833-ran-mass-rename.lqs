// Dragnet [Ransomware]: dragnet-ransomware-2024-3833 — Mass File Rename (nitrogen)
// Status: experimental | Level: high | ID: c454c27d-689f-547c-a045-ffddc79fa872

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
