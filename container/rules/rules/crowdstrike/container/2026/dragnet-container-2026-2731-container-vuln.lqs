// Dragnet [Container]: dragnet-container-2026-2731 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: b4956e48-3f5c-5075-a537-9143b0492327

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:13.10*)
| table([timestamp, ComputerName])
| limit(1000)
