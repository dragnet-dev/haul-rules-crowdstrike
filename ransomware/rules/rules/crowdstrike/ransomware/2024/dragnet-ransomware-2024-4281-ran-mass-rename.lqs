// Dragnet [Ransomware]: dragnet-ransomware-2024-4281 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 402fa5ee-80b1-596b-9d1c-04da5e6083bc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
