// Dragnet [Ransomware]: dragnet-ransomware-2026-0303 — Mass File Rename (dragonforce)
// Status: stable | Level: high | ID: e14520e8-db50-520a-bf76-26500467801a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
