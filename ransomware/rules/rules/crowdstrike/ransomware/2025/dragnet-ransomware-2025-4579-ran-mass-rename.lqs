// Dragnet [Ransomware]: dragnet-ransomware-2025-4579 — Mass File Rename (chaos)
// Status: experimental | Level: high | ID: 46171d3a-ebae-5a55-a477-23ce7e52faf2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
