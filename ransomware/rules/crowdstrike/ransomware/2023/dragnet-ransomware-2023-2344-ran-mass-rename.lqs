// Dragnet [Ransomware]: dragnet-ransomware-2023-2344 — Mass File Rename (ransomed)
// Status: deprecated | Level: high | ID: 0b2adf7f-3293-55d1-aba1-1025f31e3021

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
