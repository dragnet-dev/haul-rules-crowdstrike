// Dragnet [Container]: dragnet-container-2026-0588 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 0e55568e-95ca-58ea-a0b8-36b7dae8a4be

#event_simpleName=*
| (ImageFileName = *debian:7* OR ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *oraclelinux:7* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:14.04*)
| table([timestamp, ComputerName])
| limit(1000)
