// Dragnet [Ransomware]: dragnet-ransomware-2024-4715 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 321450da-ab2c-5cc0-8987-db9b455aa283

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
