// Dragnet [Ransomware]: dragnet-ransomware-2025-2086 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: bb966a5b-1f6e-5f15-9ff6-8a8eeb287974

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
