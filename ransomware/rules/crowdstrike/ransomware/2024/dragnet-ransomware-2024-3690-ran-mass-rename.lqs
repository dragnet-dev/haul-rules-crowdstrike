// Dragnet [Ransomware]: dragnet-ransomware-2024-3690 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: e2078b17-f185-53a7-a968-e79c90086a18

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
