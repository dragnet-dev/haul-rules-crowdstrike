// Dragnet [Ransomware]: dragnet-ransomware-2024-4947 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: ce4de980-13a1-5143-b79a-3c986c8ef0b5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
