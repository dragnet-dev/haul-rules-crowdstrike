// Dragnet [Ransomware]: dragnet-ransomware-2026-0387 — Mass File Rename (payoutsking)
// Status: test | Level: high | ID: 236ae3ad-e1a3-5727-8193-4c4cf0876c7d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
