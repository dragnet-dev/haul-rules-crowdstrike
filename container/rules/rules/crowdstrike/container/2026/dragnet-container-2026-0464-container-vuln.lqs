// Dragnet [Container]: dragnet-container-2026-0464 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 1ec3ca65-93dd-5331-a4fc-f197cae5cb46

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:7* OR ImageFileName = *ubuntu:14.04*)
| table([timestamp, ComputerName])
| limit(1000)
