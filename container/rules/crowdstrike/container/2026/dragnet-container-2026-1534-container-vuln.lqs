// Dragnet [Container]: dragnet-container-2026-1534 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 5701c8ee-22be-5f9e-a01e-b158b6fd7356

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
