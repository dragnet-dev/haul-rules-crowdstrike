// Dragnet [Ransomware]: dragnet-ransomware-2024-3809 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: d4dabb42-212a-574e-9085-53e3ac54a150

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
