// Dragnet [Container]: dragnet-container-2026-2126 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 91bafe71-3de7-5bb8-9ee7-1530d41ac184

#event_simpleName=*
| (ImageFileName = *amazonlinux:1* OR ImageFileName = *debian:7* OR ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *oraclelinux:7* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:14.04*)
| table([timestamp, ComputerName])
| limit(1000)
