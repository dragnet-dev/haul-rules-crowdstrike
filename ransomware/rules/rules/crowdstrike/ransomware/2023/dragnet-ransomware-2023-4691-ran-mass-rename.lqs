// Dragnet [Ransomware]: dragnet-ransomware-2023-4691 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 065b1fb3-ce94-5a44-9749-a3981c10a37c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
