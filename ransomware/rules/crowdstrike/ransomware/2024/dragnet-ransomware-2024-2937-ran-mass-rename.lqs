// Dragnet [Ransomware]: dragnet-ransomware-2024-2937 — Mass File Rename (apt73)
// Status: experimental | Level: high | ID: f0653b12-b551-5ec3-bbbe-387b37fa7fec

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
