// Dragnet [Ransomware]: dragnet-ransomware-2025-3396 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: 100f9337-ae7f-500c-a4be-5681da9db440

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
