// Dragnet [Container]: dragnet-container-2025-0440 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: b2f9f35c-3168-5513-9db5-d251dd026ae9

#event_simpleName=*
| (ImageFileName = *almalinux:8* OR ImageFileName = *almalinux:9* OR ImageFileName = *alpine:3.19* OR ImageFileName = *alpine:3.20* OR ImageFileName = *alpine:3.21* OR ImageFileName = *alpine:3.22* OR ImageFileName = *alpine:3.23* OR ImageFileName = *alpine edge:* OR ImageFileName = *amazonlinux:2* OR ImageFileName = *chainguard:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:7* OR ImageFileName = *oraclelinux:8* OR ImageFileName = *oraclelinux:9* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:20.04* OR ImageFileName = *ubuntu:22.04* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
