// Dragnet [Ransomware]: dragnet-ransomware-2025-6506 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: d210671f-ef9e-56ff-851a-1fbf0c3946cf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
