// Dragnet [Ransomware]: dragnet-ransomware-2025-1819 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: 1acf8374-f118-52f5-bfe7-e6dbaed354ad

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
