// Dragnet [Ransomware]: dragnet-ransomware-2024-5374 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 9fcf990d-390b-59ab-952a-0c712a5f3e4c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
