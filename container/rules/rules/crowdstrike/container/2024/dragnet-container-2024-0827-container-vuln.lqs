// Dragnet [Container]: dragnet-container-2024-0827 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: df45d9ff-8e59-55ed-868f-88a331af491b

#event_simpleName=*
| (ImageFileName = *almalinux:8* OR ImageFileName = *amazonlinux:1* OR ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:8* OR ImageFileName = *debian:9* OR ImageFileName = *oraclelinux:7* OR ImageFileName = *oraclelinux:8* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:14.04-ESM* OR ImageFileName = *ubuntu:16.04* OR ImageFileName = *ubuntu:16.04-ESM* OR ImageFileName = *ubuntu:18.04* OR ImageFileName = *ubuntu:18.04-ESM* OR ImageFileName = *ubuntu:19.04* OR ImageFileName = *ubuntu:19.10*)
| table([timestamp, ComputerName])
| limit(1000)
