// Dragnet [Ransomware]: dragnet-ransomware-2024-0518 — Mass File Rename (handala)
// Status: experimental | Level: high | ID: 1e19fbe7-f2a8-571a-82b3-cb4b5b8ea188

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
