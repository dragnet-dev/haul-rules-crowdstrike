// Dragnet [Ransomware]: dragnet-ransomware-2025-0573 — Mass File Rename (coinbasecartel)
// Status: experimental | Level: high | ID: 9186f092-faae-5baf-995f-25e6d8b05337

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
