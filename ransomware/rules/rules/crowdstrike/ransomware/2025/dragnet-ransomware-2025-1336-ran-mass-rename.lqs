// Dragnet [Ransomware]: dragnet-ransomware-2025-1336 — Mass File Rename (nightspire)
// Status: deprecated | Level: high | ID: 18f3a97e-b515-5edb-9b9c-8ed4bb3c1e06

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
