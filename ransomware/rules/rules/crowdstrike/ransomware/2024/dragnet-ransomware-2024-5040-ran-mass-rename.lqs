// Dragnet [Ransomware]: dragnet-ransomware-2024-5040 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 325f22f4-0c7e-5fa4-adad-4061b978306b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
