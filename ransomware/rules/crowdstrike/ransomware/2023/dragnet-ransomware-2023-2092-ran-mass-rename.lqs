// Dragnet [Ransomware]: dragnet-ransomware-2023-2092 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 3067fbb2-ee05-56ef-908e-de04cd6fcf76

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
