// Dragnet [Ransomware]: dragnet-ransomware-2024-3727 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 1efe1d25-37b4-5339-a40c-6decd3ece9e2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
