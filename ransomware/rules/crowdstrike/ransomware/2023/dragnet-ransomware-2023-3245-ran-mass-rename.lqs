// Dragnet [Ransomware]: dragnet-ransomware-2023-3245 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 929a77e5-e681-500e-ab50-19945845194d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
