// Dragnet [Ransomware]: dragnet-ransomware-2026-3031 — Mass File Rename (genesis)
// Status: stable | Level: high | ID: d77ad4ab-a9f5-58f2-8066-d584fefaaa30

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
