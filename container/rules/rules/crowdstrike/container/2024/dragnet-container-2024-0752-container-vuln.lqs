// Dragnet [Container]: dragnet-container-2024-0752 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: e885a0f6-344a-5d03-9157-59e56a05c058

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:9*)
| table([timestamp, ComputerName])
| limit(1000)
