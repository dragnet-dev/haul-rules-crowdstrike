// Dragnet [Ransomware]: dragnet-ransomware-2025-7062 — Mass File Rename (devman)
// Status: experimental | Level: high | ID: 748c81fb-1d53-5565-9fa0-64592025c08d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
