// Dragnet [Ransomware]: dragnet-ransomware-2022-1733 — Mass File Rename (unsafe)
// Status: deprecated | Level: high | ID: 49c0f453-2dea-500f-8553-a72aeb64fe0a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
