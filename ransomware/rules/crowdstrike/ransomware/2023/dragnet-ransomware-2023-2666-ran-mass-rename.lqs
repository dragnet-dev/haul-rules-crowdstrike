// Dragnet [Ransomware]: dragnet-ransomware-2023-2666 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: cd12d0f0-38bd-5016-82c0-52cd1a430569

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
