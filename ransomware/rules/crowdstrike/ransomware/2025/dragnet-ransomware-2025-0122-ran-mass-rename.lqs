// Dragnet [Ransomware]: dragnet-ransomware-2025-0122 — Mass File Rename (warlock)
// Status: deprecated | Level: high | ID: bd8b8566-5f5e-52d3-8d61-159ce32cd9cd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
