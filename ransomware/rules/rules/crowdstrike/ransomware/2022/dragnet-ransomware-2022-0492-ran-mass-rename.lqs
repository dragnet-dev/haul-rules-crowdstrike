// Dragnet [Ransomware]: dragnet-ransomware-2022-0492 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: ff4c237c-05e1-5a9a-8933-62aa592ed0e7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
