// Dragnet [Ransomware]: dragnet-ransomware-2025-7101 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: e19164c3-5b4e-5b0a-8459-d98e8c6ef478

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
