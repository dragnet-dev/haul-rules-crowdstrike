// Dragnet [Container]: dragnet-container-2026-1254 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 573d7d9f-2428-552e-adea-3328ce162619

#event_simpleName=*
| (ImageFileName = *chainguard:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:5* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
