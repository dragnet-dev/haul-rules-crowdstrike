// Dragnet [Ransomware]: dragnet-ransomware-2023-2384 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: dff1a1b6-8ab9-56be-b5a1-f3089e0db12a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
