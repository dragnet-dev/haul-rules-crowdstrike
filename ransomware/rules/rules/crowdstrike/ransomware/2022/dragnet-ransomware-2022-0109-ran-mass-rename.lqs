// Dragnet [Ransomware]: dragnet-ransomware-2022-0109 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 677e302e-a43a-5619-8b52-a92a229e0bb2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
