// Dragnet [Ransomware]: dragnet-ransomware-2025-3457 — Mass File Rename (play)
// Status: experimental | Level: high | ID: c07729fb-d5df-59aa-a94b-36606d4ec995

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
