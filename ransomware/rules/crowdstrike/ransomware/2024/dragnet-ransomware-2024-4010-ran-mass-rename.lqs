// Dragnet [Ransomware]: dragnet-ransomware-2024-4010 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 76c98409-1382-54ea-97f8-9634d9c247d2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
