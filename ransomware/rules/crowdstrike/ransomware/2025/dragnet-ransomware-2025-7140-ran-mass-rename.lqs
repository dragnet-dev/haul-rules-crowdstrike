// Dragnet [Ransomware]: dragnet-ransomware-2025-7140 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 0e6932ca-0c85-5e63-9cc4-84a42ff86d62

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
