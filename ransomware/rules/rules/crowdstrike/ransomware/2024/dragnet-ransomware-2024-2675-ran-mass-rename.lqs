// Dragnet [Ransomware]: dragnet-ransomware-2024-2675 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 80c31948-baec-5ce0-b695-9b02cc67bbe9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
