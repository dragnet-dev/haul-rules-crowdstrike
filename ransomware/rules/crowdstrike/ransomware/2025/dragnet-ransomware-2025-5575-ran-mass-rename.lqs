// Dragnet [Ransomware]: dragnet-ransomware-2025-5575 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: 8794ac1e-6151-57db-8622-e34f8913295d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
