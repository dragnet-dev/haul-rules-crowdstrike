// Dragnet [Ransomware]: dragnet-ransomware-2024-5705 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: f1c0ea98-8e4c-5f09-a257-cc64b9dbfc19

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
