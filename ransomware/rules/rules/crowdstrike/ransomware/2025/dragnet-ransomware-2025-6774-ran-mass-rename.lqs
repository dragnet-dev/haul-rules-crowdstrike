// Dragnet [Ransomware]: dragnet-ransomware-2025-6774 — Mass File Rename (SilentRansomGroup)
// Status: deprecated | Level: high | ID: 0aabd56e-304b-56b3-8b4e-c8535c572722

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
