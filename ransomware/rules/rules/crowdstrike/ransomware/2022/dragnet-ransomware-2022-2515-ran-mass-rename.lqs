// Dragnet [Ransomware]: dragnet-ransomware-2022-2515 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 67a12e81-9fe3-5235-8b88-2d2629276259

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
