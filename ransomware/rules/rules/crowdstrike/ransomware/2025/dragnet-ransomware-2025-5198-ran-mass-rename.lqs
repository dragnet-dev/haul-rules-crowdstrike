// Dragnet [Ransomware]: dragnet-ransomware-2025-5198 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: 0b7d96ed-421c-5710-8bb7-afb043c6e2ce

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
