// Dragnet [Ransomware]: dragnet-ransomware-2022-1962 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 16064a22-c047-50da-90b6-755ae0709d37

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
