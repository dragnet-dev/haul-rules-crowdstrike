// Dragnet [Ransomware]: dragnet-ransomware-2022-2194 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 4d20cb80-9eae-523d-86f8-7205291898d2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
