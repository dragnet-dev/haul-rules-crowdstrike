// Dragnet [Ransomware]: dragnet-ransomware-2022-2337 — Mass File Rename (play)
// Status: deprecated | Level: high | ID: 1e0359dd-5189-5c8c-a1ae-8b22d0f5e071

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
