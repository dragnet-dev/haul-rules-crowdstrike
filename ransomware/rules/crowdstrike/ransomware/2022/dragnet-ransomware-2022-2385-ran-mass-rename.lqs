// Dragnet [Ransomware]: dragnet-ransomware-2022-2385 — Mass File Rename (leaktheanalyst)
// Status: deprecated | Level: high | ID: 87114ce6-b2a7-55b3-a6cd-e2c8e2123fd7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
