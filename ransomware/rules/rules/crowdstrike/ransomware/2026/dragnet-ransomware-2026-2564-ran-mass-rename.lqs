// Dragnet [Ransomware]: dragnet-ransomware-2026-2564 — Mass File Rename (fulcrumsec)
// Status: stable | Level: high | ID: b1a56d6c-e866-5087-989e-957dc5959bdf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
