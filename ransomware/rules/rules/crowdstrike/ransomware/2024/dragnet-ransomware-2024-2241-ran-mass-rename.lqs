// Dragnet [Ransomware]: dragnet-ransomware-2024-2241 — Mass File Rename (cloak)
// Status: deprecated | Level: high | ID: efaf6dcf-cadd-5fcc-af66-eff3d2acbc39

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
