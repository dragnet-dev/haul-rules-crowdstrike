// Dragnet [Ransomware]: dragnet-ransomware-2025-6950 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: f7294956-d5ad-560f-b5ab-622c269fa336

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
