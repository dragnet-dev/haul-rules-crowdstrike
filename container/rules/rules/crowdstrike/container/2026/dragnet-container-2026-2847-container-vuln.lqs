// Dragnet [Container]: dragnet-container-2026-2847 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 5b2feddc-3755-58f1-98cd-43e6e0e4dcfd

#event_simpleName=*
| (ImageFileName = *alpine:3.23* OR ImageFileName = *alpine edge:* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
