// Dragnet [Ransomware]: dragnet-ransomware-2024-0054 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 23c02fa9-ad5d-5ce8-b869-4c184a1c7541

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
