// Dragnet [Ransomware]: dragnet-ransomware-2023-5227 — Mass File Rename (abyss)
// Status: deprecated | Level: high | ID: cdaeefde-7628-5697-b6cf-6225ab18dbfe

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
