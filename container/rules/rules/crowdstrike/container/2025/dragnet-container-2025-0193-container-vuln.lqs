// Dragnet [Container]: dragnet-container-2025-0193 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 1f907597-173d-519d-abe0-672d91b79ded

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:9*)
| table([timestamp, ComputerName])
| limit(1000)
