// Dragnet [Ransomware]: dragnet-ransomware-2025-1119 — Mass File Rename (arcusmedia)
// Status: experimental | Level: high | ID: 63238ad3-0015-5c4b-9b0e-334918448591

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
