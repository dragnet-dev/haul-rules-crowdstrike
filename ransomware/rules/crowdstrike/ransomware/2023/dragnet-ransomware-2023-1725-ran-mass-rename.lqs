// Dragnet [Ransomware]: dragnet-ransomware-2023-1725 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 0c1f28b7-1782-5b4b-abdd-ca2b36b8caef

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
