// Dragnet [Ransomware]: dragnet-ransomware-2024-2671 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: d860b937-02fb-5411-a2b9-21ac7ca201ce

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
