// Dragnet [Ransomware]: dragnet-ransomware-2023-4253 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 7342b3eb-cec0-5cda-94ea-601bd1042365

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
