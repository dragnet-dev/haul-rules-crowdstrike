// Dragnet [Ransomware]: dragnet-ransomware-2023-1921 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 79015f2a-ff91-561f-9b25-8f7d142109fe

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
