// Dragnet [Ransomware]: dragnet-ransomware-2023-4376 — Mass File Rename (snatch)
// Status: experimental | Level: high | ID: cfdfb4d3-c89b-5c2a-a9f2-e4079ee45990

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
