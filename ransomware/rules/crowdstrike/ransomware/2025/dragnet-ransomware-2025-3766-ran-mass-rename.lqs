// Dragnet [Ransomware]: dragnet-ransomware-2025-3766 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: b036f90b-f6ed-55fd-943c-30747e65772b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
