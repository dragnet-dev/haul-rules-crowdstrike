// Dragnet [Ransomware]: dragnet-ransomware-2022-1513 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 0dd06bf5-8777-5cfd-a641-fe9fc3d727d2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
