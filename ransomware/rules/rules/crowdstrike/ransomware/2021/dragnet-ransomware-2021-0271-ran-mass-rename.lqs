// Dragnet [Ransomware]: dragnet-ransomware-2021-0271 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: bf3937d1-452a-5f86-902e-48b1190f5de5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
