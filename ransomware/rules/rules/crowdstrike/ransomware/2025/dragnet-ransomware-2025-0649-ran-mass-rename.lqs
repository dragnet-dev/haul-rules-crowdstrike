// Dragnet [Ransomware]: dragnet-ransomware-2025-0649 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: e7225e6e-c811-5137-9db7-eaba439f4798

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
