// Dragnet [Container]: dragnet-container-2026-1562 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: d48d9fc7-531b-53f4-86d3-c6aa0e5817a7

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:5*)
| table([timestamp, ComputerName])
| limit(1000)
