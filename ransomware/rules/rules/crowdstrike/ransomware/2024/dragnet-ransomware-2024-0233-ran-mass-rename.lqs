// Dragnet [Ransomware]: dragnet-ransomware-2024-0233 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: fcf22fe5-1571-5f2e-9385-0f87e8bc3cf5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
