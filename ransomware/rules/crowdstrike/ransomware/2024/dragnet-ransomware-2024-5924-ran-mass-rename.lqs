// Dragnet [Ransomware]: dragnet-ransomware-2024-5924 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 9cd571a9-2b94-5175-8d45-bf3139e97216

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
