// Dragnet [Ransomware]: dragnet-ransomware-2026-2184 — Mass File Rename (fulcrumsec)
// Status: stable | Level: high | ID: 89c49341-36d3-50b5-9553-fe09b6c6b202

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
