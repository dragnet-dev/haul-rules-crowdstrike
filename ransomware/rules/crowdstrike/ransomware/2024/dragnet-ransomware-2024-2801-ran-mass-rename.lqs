// Dragnet [Ransomware]: dragnet-ransomware-2024-2801 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 393e3226-8192-5550-b520-f281d094f035

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
