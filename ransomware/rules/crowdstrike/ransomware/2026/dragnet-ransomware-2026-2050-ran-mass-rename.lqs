// Dragnet [Ransomware]: dragnet-ransomware-2026-2050 — Mass File Rename (everest)
// Status: stable | Level: high | ID: abd66dc9-1a86-57c0-9279-cf1e21af3ac5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
