// Dragnet [Ransomware]: dragnet-ransomware-2023-2717 — Mass File Rename (cyclops)
// Status: deprecated | Level: high | ID: 5e081e8d-8016-5f28-8651-5654a5d89475

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
