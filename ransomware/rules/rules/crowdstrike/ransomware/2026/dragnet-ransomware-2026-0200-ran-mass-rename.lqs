// Dragnet [Ransomware]: dragnet-ransomware-2026-0200 — Mass File Rename (vect)
// Status: deprecated | Level: high | ID: 1ed91f27-8631-55ec-b14d-5c5261716e59

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
