// Dragnet [Ransomware]: dragnet-ransomware-2023-4358 — Mass File Rename (ciphbit)
// Status: deprecated | Level: high | ID: c16bfd08-ffa4-5e81-9732-e39d54ed50a0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
