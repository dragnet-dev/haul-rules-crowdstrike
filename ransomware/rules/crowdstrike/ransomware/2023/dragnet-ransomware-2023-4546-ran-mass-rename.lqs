// Dragnet [Ransomware]: dragnet-ransomware-2023-4546 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: aeb19972-ef10-5d9b-9700-f5d3dc8f105b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
