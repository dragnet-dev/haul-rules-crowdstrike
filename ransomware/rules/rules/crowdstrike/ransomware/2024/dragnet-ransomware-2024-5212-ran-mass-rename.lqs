// Dragnet [Ransomware]: dragnet-ransomware-2024-5212 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 1a23a2f0-aff4-52d2-aec2-3473f1ca65b9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
