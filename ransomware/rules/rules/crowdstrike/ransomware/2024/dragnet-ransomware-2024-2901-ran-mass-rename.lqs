// Dragnet [Ransomware]: dragnet-ransomware-2024-2901 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 90ae0b1b-4538-5282-820b-7b4bccf65fc5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
