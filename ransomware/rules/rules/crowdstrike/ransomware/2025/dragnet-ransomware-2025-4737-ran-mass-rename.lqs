// Dragnet [Ransomware]: dragnet-ransomware-2025-4737 — Mass File Rename (nova)
// Status: experimental | Level: high | ID: 9119202c-ad90-535f-8944-cf3ccf7b3cf7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
