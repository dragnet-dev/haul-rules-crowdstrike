// Dragnet [Ransomware]: dragnet-ransomware-2022-2527 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 7813d3c2-b71e-534c-8842-0563e4372c96

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
