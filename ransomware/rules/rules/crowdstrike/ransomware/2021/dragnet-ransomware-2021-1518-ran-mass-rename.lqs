// Dragnet [Ransomware]: dragnet-ransomware-2021-1518 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 91569144-542a-5482-82a0-cd6d97b23ad3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
