// Dragnet [Ransomware]: dragnet-ransomware-2023-0777 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 977aaf83-c3fc-5296-b12c-1cdf481f48e9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
