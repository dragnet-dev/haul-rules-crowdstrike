// Dragnet [Ransomware]: dragnet-ransomware-2023-3032 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: b7b821da-29a0-5d20-9dd3-a26a2a0badb3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
