// Dragnet [Ransomware]: dragnet-ransomware-2025-7248 — Mass File Rename (sinobi)
// Status: experimental | Level: high | ID: bf230c4d-a454-558f-af32-426638d9d5b1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
