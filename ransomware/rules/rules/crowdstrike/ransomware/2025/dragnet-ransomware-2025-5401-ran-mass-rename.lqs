// Dragnet [Ransomware]: dragnet-ransomware-2025-5401 — Mass File Rename (sinobi)
// Status: experimental | Level: high | ID: 7fd67692-db59-579c-8593-d33abccefdc6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
