// Dragnet [Ransomware]: dragnet-ransomware-2025-6271 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 08a4df64-8518-5720-b692-3c5a70eef0d8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
