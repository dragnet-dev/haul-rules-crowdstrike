// Dragnet [Ransomware]: dragnet-ransomware-2022-0229 — Mass File Rename (lv)
// Status: deprecated | Level: high | ID: 417ebfd0-39ba-5310-9431-607e908add15

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
