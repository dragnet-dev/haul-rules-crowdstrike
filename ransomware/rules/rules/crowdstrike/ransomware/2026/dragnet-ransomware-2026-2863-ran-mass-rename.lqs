// Dragnet [Ransomware]: dragnet-ransomware-2026-2863 — Mass File Rename (payoutsking)
// Status: stable | Level: high | ID: afc3283c-3d55-51ce-ac6f-d2ffb94dbf5c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
