// Dragnet [Ransomware]: dragnet-ransomware-2024-0893 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 1ce02e2d-63fd-5c9b-bb52-701852a1e57b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
