// Dragnet [Ransomware]: dragnet-ransomware-2025-1796 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: 461b1d7d-7fca-5634-be34-e7a945a5f7d4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
