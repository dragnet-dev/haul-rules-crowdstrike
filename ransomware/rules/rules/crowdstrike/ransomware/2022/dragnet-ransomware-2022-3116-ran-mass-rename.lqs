// Dragnet [Ransomware]: dragnet-ransomware-2022-3116 — Mass File Rename (avoslocker)
// Status: deprecated | Level: high | ID: 4bb8a748-2985-5b48-935e-31b1a3cd7a1f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
