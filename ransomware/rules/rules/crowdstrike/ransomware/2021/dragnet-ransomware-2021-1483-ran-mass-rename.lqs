// Dragnet [Ransomware]: dragnet-ransomware-2021-1483 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 963053ae-f75c-584a-9246-3e408d847528

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
