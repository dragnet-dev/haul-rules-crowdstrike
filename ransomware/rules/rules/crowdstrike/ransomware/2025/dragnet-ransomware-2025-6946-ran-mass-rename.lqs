// Dragnet [Ransomware]: dragnet-ransomware-2025-6946 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: b2d26e63-a837-593b-9e49-8f3df389a76f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
