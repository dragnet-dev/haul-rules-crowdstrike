// Dragnet [Ransomware]: dragnet-ransomware-2024-5371 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 3bc7506d-dedb-5ac2-8f20-31438c6f6b01

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
