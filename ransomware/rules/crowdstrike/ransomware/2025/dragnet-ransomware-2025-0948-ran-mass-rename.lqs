// Dragnet [Ransomware]: dragnet-ransomware-2025-0948 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 92add710-bd33-543a-aae5-b66892f0e506

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
