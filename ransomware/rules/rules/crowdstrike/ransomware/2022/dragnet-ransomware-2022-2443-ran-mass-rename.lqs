// Dragnet [Ransomware]: dragnet-ransomware-2022-2443 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 4303f703-9b35-58f6-a4e6-f18a3f61f545

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
