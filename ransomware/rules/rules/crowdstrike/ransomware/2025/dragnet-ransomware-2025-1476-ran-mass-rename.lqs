// Dragnet [Ransomware]: dragnet-ransomware-2025-1476 — Mass File Rename (anubis)
// Status: experimental | Level: high | ID: c4e0a682-b3e8-56fe-8dc0-360e889115e9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
