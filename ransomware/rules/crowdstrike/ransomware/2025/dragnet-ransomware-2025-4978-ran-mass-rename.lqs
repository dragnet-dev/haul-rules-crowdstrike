// Dragnet [Ransomware]: dragnet-ransomware-2025-4978 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: 7258a29c-dd25-5423-a3e0-51c633fe9704

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
