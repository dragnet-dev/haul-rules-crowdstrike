// Dragnet [Ransomware]: dragnet-ransomware-2021-1193 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 15459600-a519-5f0d-8c3d-155dae3f10f5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
