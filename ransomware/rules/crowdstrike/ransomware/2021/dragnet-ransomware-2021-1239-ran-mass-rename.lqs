// Dragnet [Ransomware]: dragnet-ransomware-2021-1239 — Mass File Rename (revil)
// Status: deprecated | Level: high | ID: b9addcc5-6d0c-5362-885c-53655e5c2c8d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
