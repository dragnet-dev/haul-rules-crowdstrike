// Dragnet [Ransomware]: dragnet-ransomware-2024-3564 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: 420b5a00-899f-5e29-95dd-9ac1d6d4814a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
