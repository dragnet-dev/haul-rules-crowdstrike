// Dragnet [Ransomware]: dragnet-ransomware-2026-3354 — Mass File Rename (anubis)
// Status: stable | Level: high | ID: a93125b9-af80-5f54-ac45-302fbbdd428f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
