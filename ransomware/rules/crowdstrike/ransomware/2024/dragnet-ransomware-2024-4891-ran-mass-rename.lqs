// Dragnet [Ransomware]: dragnet-ransomware-2024-4891 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: f8cdd25b-3df8-5790-abed-5681f8bfb600

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
