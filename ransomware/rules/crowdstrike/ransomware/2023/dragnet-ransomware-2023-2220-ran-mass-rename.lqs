// Dragnet [Ransomware]: dragnet-ransomware-2023-2220 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 4a3df101-bcff-5657-b737-ee42cea97834

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
