// Dragnet [Ransomware]: dragnet-ransomware-2024-5884 — Mass File Rename (kraken)
// Status: experimental | Level: high | ID: b7b7a64f-7b04-5195-8ad6-130d5b805edc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
