// Dragnet [Ransomware]: dragnet-ransomware-2025-6657 — Mass File Rename (play)
// Status: experimental | Level: high | ID: cec05b7f-e5cb-50e5-8b8b-4933102fe715

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
