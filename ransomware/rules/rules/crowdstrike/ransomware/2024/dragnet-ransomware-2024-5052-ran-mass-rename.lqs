// Dragnet [Ransomware]: dragnet-ransomware-2024-5052 — Mass File Rename (sarcoma)
// Status: deprecated | Level: high | ID: 8362e15d-5065-5f0f-aa1b-e526871527f0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
