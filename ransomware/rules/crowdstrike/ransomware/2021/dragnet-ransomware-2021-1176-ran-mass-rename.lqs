// Dragnet [Ransomware]: dragnet-ransomware-2021-1176 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 9e355209-d4f4-56e3-ab96-373595a74f4c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
