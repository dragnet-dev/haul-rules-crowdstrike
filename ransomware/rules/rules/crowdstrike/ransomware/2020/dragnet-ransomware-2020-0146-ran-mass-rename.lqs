// Dragnet [Ransomware]: dragnet-ransomware-2020-0146 — Mass File Rename (revil)
// Status: deprecated | Level: high | ID: edb86be2-3c51-53ba-9eae-8f00c70a0233

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
