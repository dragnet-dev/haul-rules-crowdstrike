// Dragnet [Ransomware]: dragnet-ransomware-2025-0932 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 39b06421-5fd7-532c-8863-f8ac9034d0d6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
