// Dragnet [Container]: dragnet-container-2026-1966 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: cdcec263-c912-5faa-8a56-9ca5dff6addf

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:5*)
| table([timestamp, ComputerName])
| limit(1000)
