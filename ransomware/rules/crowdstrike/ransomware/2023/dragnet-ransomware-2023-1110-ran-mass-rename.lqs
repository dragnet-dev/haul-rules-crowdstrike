// Dragnet [Ransomware]: dragnet-ransomware-2023-1110 — Mass File Rename (royal)
// Status: experimental | Level: high | ID: 83771704-45f7-5119-8cc3-72fd64157926

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
