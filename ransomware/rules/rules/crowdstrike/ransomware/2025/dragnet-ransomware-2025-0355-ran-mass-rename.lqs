// Dragnet [Ransomware]: dragnet-ransomware-2025-0355 — Mass File Rename (apos)
// Status: experimental | Level: high | ID: e4b1b5a1-a9ad-5770-a8b2-2227c101bbfd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
