// Dragnet [Ransomware]: dragnet-ransomware-2025-4856 — Mass File Rename (IMNCrew)
// Status: experimental | Level: high | ID: 247f64c2-5f84-5660-9a1a-85d40f7515a7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
