// Dragnet [Ransomware]: dragnet-ransomware-2022-1204 — Mass File Rename (avoslocker)
// Status: deprecated | Level: high | ID: 5730af35-eee1-5fc1-99d2-2c5951a555ab

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
