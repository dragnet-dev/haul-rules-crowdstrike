// Dragnet [Ransomware]: dragnet-ransomware-2025-6826 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: cc8a2685-f406-5aee-90c4-0231d9800654

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
