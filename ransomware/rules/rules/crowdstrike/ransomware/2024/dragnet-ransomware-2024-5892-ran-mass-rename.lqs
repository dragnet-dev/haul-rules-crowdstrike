// Dragnet [Ransomware]: dragnet-ransomware-2024-5892 — Mass File Rename (monti)
// Status: experimental | Level: high | ID: 15a4175f-b687-516b-b281-8b4f34c4d16d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
