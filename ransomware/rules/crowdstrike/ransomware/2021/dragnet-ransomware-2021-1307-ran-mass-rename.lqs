// Dragnet [Ransomware]: dragnet-ransomware-2021-1307 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 797acceb-6687-5a3d-b957-21ba8c8a7a15

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
