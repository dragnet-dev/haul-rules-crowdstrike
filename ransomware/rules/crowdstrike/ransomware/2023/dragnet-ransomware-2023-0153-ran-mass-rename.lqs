// Dragnet [Ransomware]: dragnet-ransomware-2023-0153 — Mass File Rename (noname)
// Status: experimental | Level: high | ID: b319bbef-a141-5c33-907e-edb8f780ab80

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
