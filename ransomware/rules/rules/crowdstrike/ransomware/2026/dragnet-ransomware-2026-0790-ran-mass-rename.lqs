// Dragnet [Ransomware]: dragnet-ransomware-2026-0790 — Mass File Rename (safepay)
// Status: stable | Level: high | ID: cabb25c1-ea58-5039-a9b2-d585c9c76c59

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
