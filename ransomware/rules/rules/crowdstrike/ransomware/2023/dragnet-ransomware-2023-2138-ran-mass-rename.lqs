// Dragnet [Ransomware]: dragnet-ransomware-2023-2138 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: ff09e52a-0732-5490-bbe6-5a47d4850443

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
