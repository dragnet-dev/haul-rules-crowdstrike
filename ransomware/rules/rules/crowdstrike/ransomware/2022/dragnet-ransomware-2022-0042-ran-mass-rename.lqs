// Dragnet [Ransomware]: dragnet-ransomware-2022-0042 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 04416509-fdda-50c1-9e76-2898f3a6a97d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
