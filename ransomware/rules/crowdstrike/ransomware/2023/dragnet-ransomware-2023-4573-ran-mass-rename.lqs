// Dragnet [Ransomware]: dragnet-ransomware-2023-4573 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 5cd5dc2c-57c2-5e40-9982-0ebac752112e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
