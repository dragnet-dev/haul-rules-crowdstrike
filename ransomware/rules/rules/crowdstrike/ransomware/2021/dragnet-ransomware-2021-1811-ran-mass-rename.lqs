// Dragnet [Ransomware]: dragnet-ransomware-2021-1811 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: f16f8c8a-f7e5-5cd1-b8ad-0a4e3199643d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
