// Dragnet [Ransomware]: dragnet-ransomware-2023-0221 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: b12b449a-29ec-5b0f-b752-ce3419aa4035

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
