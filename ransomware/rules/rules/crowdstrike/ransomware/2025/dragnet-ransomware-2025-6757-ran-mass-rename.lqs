// Dragnet [Ransomware]: dragnet-ransomware-2025-6757 — Mass File Rename (shinyhunters)
// Status: experimental | Level: high | ID: 6c93e0b7-0668-576e-8ce0-648c84b6be08

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
