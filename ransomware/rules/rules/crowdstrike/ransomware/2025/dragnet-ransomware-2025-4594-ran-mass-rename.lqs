// Dragnet [Ransomware]: dragnet-ransomware-2025-4594 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 05f7acbf-ffa1-5c71-9adc-b4e97d4cf817

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
