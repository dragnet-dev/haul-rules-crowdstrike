// Dragnet [Ransomware]: dragnet-ransomware-2025-3741 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 36e732b1-f351-5c5e-8e06-46c33077ca57

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
