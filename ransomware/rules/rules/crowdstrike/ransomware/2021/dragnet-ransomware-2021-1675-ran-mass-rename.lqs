// Dragnet [Ransomware]: dragnet-ransomware-2021-1675 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 07e2b773-5a92-571f-809f-663b80a7c9b2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
