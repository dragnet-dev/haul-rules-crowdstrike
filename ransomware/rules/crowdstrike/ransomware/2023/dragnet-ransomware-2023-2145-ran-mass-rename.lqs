// Dragnet [Ransomware]: dragnet-ransomware-2023-2145 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 35c68709-d9a2-5789-be61-bf789e0cb4e5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
