// Dragnet [Ransomware]: dragnet-ransomware-2024-2828 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 5a8d9712-645b-5830-bc62-6ba7c3497309

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
