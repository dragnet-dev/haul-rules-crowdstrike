// Dragnet [Ransomware]: dragnet-ransomware-2025-7465 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 3f9a2c2e-3cd0-5dfb-9ffa-38672275e9c7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
