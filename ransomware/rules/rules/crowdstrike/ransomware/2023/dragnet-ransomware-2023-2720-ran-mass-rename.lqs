// Dragnet [Ransomware]: dragnet-ransomware-2023-2720 — Mass File Rename (moneymessage)
// Status: experimental | Level: high | ID: 8fb8279b-9255-5fbf-b414-8a5688095902

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
