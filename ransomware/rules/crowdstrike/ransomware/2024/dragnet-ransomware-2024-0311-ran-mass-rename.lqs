// Dragnet [Ransomware]: dragnet-ransomware-2024-0311 — Mass File Rename (handala)
// Status: experimental | Level: high | ID: c6f1fbaa-3985-5f1f-9c59-82f4fb1fe712

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
