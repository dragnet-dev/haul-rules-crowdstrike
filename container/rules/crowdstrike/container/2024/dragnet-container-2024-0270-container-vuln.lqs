// Dragnet [Container]: dragnet-container-2024-0270 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 8bdd7cdc-a431-5910-8f78-e95fbf8e002a

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:9*)
| table([timestamp, ComputerName])
| limit(1000)
