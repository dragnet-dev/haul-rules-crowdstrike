// Dragnet [Ransomware]: dragnet-ransomware-2025-1204 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: d45e7d08-4b55-5065-a2f4-1e99b7e9e434

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
