// Dragnet [Ransomware]: dragnet-ransomware-2025-7149 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 56c260ea-afd7-5dbf-ba17-79816e7fb8b2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
