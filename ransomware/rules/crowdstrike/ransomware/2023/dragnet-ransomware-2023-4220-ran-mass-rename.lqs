// Dragnet [Ransomware]: dragnet-ransomware-2023-4220 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 46ec4f3d-186e-5213-8705-55a444b6bafd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
