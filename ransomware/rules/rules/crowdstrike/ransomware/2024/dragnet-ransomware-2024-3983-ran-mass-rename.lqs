// Dragnet [Ransomware]: dragnet-ransomware-2024-3983 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 0494fd3b-c77c-5b22-b34a-2753728e9de2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
