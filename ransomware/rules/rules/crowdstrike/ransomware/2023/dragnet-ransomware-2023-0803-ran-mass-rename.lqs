// Dragnet [Ransomware]: dragnet-ransomware-2023-0803 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: ebbc579f-7361-50b4-98bf-d885ced14c52

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
