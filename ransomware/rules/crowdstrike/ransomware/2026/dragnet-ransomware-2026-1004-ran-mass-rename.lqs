// Dragnet [Ransomware]: dragnet-ransomware-2026-1004 — Mass File Rename (handala)
// Status: stable | Level: high | ID: b2d7354b-9b68-5c09-b325-859671aa3b27

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
