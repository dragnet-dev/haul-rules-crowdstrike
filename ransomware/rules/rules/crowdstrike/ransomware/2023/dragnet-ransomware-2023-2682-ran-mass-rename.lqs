// Dragnet [Ransomware]: dragnet-ransomware-2023-2682 — Mass File Rename (cloak)
// Status: deprecated | Level: high | ID: 1e5257c9-1842-5a39-8a15-b146dba13fc4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
