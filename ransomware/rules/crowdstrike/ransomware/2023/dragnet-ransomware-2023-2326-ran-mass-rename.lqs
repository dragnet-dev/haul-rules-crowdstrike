// Dragnet [Ransomware]: dragnet-ransomware-2023-2326 — Mass File Rename (raworld)
// Status: experimental | Level: high | ID: 47136544-bb8d-5721-8203-986ae7d59544

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
