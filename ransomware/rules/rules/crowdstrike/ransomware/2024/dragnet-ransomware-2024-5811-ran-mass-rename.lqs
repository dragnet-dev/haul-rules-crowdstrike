// Dragnet [Ransomware]: dragnet-ransomware-2024-5811 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 5b3a6424-50f9-5ffd-8a7c-5367a8a94ed8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
