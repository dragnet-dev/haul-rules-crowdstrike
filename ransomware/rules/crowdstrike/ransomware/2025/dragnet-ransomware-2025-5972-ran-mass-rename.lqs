// Dragnet [Ransomware]: dragnet-ransomware-2025-5972 — Mass File Rename (blacklock)
// Status: experimental | Level: high | ID: 757b8c60-9424-5317-90ef-8fd8c115d3ff

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
