// Dragnet [Ransomware]: dragnet-ransomware-2025-7367 — Mass File Rename (shinyhunters)
// Status: experimental | Level: high | ID: 24b8e2ac-4fe8-58f6-87f8-6b37cf3e0d08

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
