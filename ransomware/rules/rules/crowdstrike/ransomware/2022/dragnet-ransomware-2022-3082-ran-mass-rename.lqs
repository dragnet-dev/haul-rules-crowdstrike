// Dragnet [Ransomware]: dragnet-ransomware-2022-3082 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 1749e380-544b-5fb7-a6ab-b8f70a16dce6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
