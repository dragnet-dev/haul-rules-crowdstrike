// Dragnet [Ransomware]: dragnet-ransomware-2025-7485 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 8599f381-5555-55a6-8e0f-09be632754d2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
