// Dragnet [Ransomware]: dragnet-ransomware-2024-5911 — Mass File Rename (apt73)
// Status: experimental | Level: high | ID: 0de9a7b7-fd41-54ee-8619-717300107b5f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
