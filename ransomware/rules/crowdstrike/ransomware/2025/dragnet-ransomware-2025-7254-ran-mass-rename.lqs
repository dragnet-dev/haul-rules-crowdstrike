// Dragnet [Ransomware]: dragnet-ransomware-2025-7254 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 6d495346-7d20-567b-a900-fa5cf2462d14

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
