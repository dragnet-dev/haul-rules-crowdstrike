// Dragnet [Ransomware]: dragnet-ransomware-2024-4949 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: ea849312-90e4-5588-98b7-9277230ca372

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
