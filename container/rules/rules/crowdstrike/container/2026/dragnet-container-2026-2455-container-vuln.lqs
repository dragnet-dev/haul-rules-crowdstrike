// Dragnet [Container]: dragnet-container-2026-2455 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: a3b2fe22-3513-578a-9c23-a7cbe2383660

#event_simpleName=*
| (ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10* OR ImageFileName = *ubuntu:13.04* OR ImageFileName = *ubuntu:13.10*)
| table([timestamp, ComputerName])
| limit(1000)
