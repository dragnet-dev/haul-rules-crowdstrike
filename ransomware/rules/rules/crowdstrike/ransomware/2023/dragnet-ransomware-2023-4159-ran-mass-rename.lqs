// Dragnet [Ransomware]: dragnet-ransomware-2023-4159 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: fb016575-93eb-5a93-aaec-7f224d768f84

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
