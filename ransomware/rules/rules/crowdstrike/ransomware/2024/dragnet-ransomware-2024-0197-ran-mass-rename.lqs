// Dragnet [Ransomware]: dragnet-ransomware-2024-0197 — Mass File Rename (redransomware)
// Status: deprecated | Level: high | ID: 9277317d-a15a-5a31-aa8a-417f0603e4f1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
