// Dragnet [Ransomware]: dragnet-ransomware-2025-6996 — Mass File Rename (fog)
// Status: deprecated | Level: high | ID: 0f0d3855-9f6c-585a-86bd-852e3c61d554

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
