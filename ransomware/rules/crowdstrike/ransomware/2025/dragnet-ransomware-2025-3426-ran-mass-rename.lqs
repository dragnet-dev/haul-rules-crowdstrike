// Dragnet [Ransomware]: dragnet-ransomware-2025-3426 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: b4893f94-943b-5daf-99fc-d2e31f2e2ade

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
