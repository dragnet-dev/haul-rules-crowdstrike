// Dragnet [Ransomware]: dragnet-ransomware-2024-2130 — Mass File Rename (flocker)
// Status: experimental | Level: high | ID: 399f7bf7-ff8b-5a09-bdf0-e9ed78333975

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
