// Dragnet [Ransomware]: dragnet-ransomware-2022-0310 — Mass File Rename (cheers)
// Status: deprecated | Level: high | ID: efdb3ba2-dea9-5bd5-adcd-1ecec02ce60d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
