// Dragnet [Ransomware]: dragnet-ransomware-2024-4299 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 5076d64c-f9b1-5262-9113-42e21390960c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
