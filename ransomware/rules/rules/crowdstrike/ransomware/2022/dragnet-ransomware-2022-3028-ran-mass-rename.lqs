// Dragnet [Ransomware]: dragnet-ransomware-2022-3028 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 5b472e96-d0f9-56a0-99ba-a14ba8125bf5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
