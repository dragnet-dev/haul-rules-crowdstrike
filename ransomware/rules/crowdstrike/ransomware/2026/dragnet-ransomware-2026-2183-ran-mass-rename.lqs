// Dragnet [Ransomware]: dragnet-ransomware-2026-2183 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 95e31450-a8d0-56ab-b8ec-469641c2a6cc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
