// Dragnet [Ransomware]: dragnet-ransomware-2021-0868 — Mass File Rename (revil)
// Status: deprecated | Level: high | ID: a8156a66-1209-5399-8d9f-5cb18977faac

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
