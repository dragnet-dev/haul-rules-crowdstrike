// Dragnet [Ransomware]: dragnet-ransomware-2024-5328 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: 6657ecfb-9ce9-583e-ad7c-cba5db89d222

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
