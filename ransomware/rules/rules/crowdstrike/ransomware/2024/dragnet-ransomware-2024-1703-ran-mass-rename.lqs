// Dragnet [Ransomware]: dragnet-ransomware-2024-1703 — Mass File Rename (spacebears)
// Status: experimental | Level: high | ID: 2416cd23-f841-5f19-ae94-8d5394b8f6fd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
