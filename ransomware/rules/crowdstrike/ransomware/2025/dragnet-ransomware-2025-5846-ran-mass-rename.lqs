// Dragnet [Ransomware]: dragnet-ransomware-2025-5846 — Mass File Rename (gunra)
// Status: experimental | Level: high | ID: 5228cb28-1e71-5741-96e5-1092d7ffe232

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
