// Dragnet [Container]: dragnet-container-2026-0170 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: e7a9793f-6c38-51d2-b602-23d6d81837fa

#event_simpleName=*
| (ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10* OR ImageFileName = *ubuntu:13.04* OR ImageFileName = *ubuntu:13.10*)
| table([timestamp, ComputerName])
| limit(1000)
