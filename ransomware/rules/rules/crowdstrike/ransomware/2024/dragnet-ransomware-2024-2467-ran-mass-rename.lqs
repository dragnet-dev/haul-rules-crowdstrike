// Dragnet [Ransomware]: dragnet-ransomware-2024-2467 — Mass File Rename (SilentRansomGroup)
// Status: deprecated | Level: high | ID: 54d2aa86-b429-5855-b94b-de850fec59fc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
