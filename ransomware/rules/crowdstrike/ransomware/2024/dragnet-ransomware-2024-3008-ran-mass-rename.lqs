// Dragnet [Ransomware]: dragnet-ransomware-2024-3008 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 57e9d64e-bbf5-515f-a2d3-bfe92072afed

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
