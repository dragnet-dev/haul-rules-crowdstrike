// Dragnet [Ransomware]: dragnet-ransomware-2023-0567 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 0e8e8b0d-9dbe-55a7-8b97-e9b13818383d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
