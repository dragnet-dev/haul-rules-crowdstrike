// Dragnet [Ransomware]: dragnet-ransomware-2025-1117 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: e2c61a4e-4dbf-5104-8741-940e73480aef

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
