// Dragnet [Ransomware]: dragnet-ransomware-2023-3315 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 2a8d1c65-a934-5ec5-aa41-6b6dd00d81d3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
