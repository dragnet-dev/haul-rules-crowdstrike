// Dragnet [Ransomware]: dragnet-ransomware-2023-3953 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 397249a3-30a0-5421-b420-bc830f93dc53

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
