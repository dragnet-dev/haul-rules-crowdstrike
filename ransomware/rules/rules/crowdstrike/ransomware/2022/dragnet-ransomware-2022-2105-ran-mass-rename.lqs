// Dragnet [Ransomware]: dragnet-ransomware-2022-2105 — Mass File Rename (vicesociety)
// Status: deprecated | Level: high | ID: 5f6024ec-360e-5840-8e85-660c74e7be27

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
