// Dragnet [Container]: dragnet-container-2026-1251 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: c6b9ffca-ee43-5603-8d9b-5238d83d45b7

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *ubuntu:16.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
