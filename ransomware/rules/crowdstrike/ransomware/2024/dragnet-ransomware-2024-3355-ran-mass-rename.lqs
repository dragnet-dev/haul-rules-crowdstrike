// Dragnet [Ransomware]: dragnet-ransomware-2024-3355 — Mass File Rename (mallox)
// Status: deprecated | Level: high | ID: 05b16a37-0b9f-5330-ab01-cb2df96cc91b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
