// Dragnet [Ransomware]: dragnet-ransomware-2023-4410 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: b3e8b222-5e7b-544c-8776-2555fc832385

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
