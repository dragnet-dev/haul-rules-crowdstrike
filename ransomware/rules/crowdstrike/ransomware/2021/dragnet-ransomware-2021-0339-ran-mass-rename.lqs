// Dragnet [Ransomware]: dragnet-ransomware-2021-0339 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 2b013b74-c6df-522f-b9ed-2530bd17372d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
