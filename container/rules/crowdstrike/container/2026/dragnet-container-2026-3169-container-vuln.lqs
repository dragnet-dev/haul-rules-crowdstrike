// Dragnet [Container]: dragnet-container-2026-3169 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 247ba270-5b0e-5d52-8bc7-dafc8cef3cc9

#event_simpleName=*
| (ImageFileName = *amazonlinux:1* OR ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10*)
| table([timestamp, ComputerName])
| limit(1000)
