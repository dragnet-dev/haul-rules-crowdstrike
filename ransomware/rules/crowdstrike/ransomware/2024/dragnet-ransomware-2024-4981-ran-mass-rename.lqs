// Dragnet [Ransomware]: dragnet-ransomware-2024-4981 — Mass File Rename (dAn0n)
// Status: experimental | Level: high | ID: 81251ab2-240e-5f15-8981-a440f85a5024

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
