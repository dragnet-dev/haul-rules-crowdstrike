// Dragnet [Ransomware]: dragnet-ransomware-2023-1750 — Mass File Rename (royal)
// Status: deprecated | Level: high | ID: 23f31363-be8a-5d34-b71f-2907886804fa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
