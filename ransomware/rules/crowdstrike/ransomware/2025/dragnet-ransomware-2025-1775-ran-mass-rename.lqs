// Dragnet [Ransomware]: dragnet-ransomware-2025-1775 — Mass File Rename (J)
// Status: experimental | Level: high | ID: d46335e1-1750-5ad5-b0df-e11d3e06c539

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
