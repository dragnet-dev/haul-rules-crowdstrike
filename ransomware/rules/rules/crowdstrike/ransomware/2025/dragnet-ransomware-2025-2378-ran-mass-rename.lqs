// Dragnet [Ransomware]: dragnet-ransomware-2025-2378 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 2acc478f-d0ef-5a5e-a42e-c14d68440ff8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
