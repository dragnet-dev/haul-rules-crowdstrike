// Dragnet [Ransomware]: dragnet-ransomware-2024-3236 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: fc37e6eb-1db3-52f8-9073-6e1cd936ce07

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
