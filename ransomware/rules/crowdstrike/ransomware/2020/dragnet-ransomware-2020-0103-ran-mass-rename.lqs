// Dragnet [Ransomware]: dragnet-ransomware-2020-0103 — Mass File Rename (doppelpaymer)
// Status: deprecated | Level: high | ID: 9a1bac8f-8449-58fd-9c63-2cbf4eb2be42

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
