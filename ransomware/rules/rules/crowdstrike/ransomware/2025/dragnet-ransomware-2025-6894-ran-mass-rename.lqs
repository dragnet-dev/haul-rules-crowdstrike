// Dragnet [Ransomware]: dragnet-ransomware-2025-6894 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 1aa3670e-5043-5256-b9b8-1e60a2b17c6a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
