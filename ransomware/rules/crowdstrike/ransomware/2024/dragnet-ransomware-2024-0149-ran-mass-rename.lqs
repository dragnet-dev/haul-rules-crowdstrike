// Dragnet [Ransomware]: dragnet-ransomware-2024-0149 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: 2e7f6fe3-9b86-5e95-b527-62795f5f7bef

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
