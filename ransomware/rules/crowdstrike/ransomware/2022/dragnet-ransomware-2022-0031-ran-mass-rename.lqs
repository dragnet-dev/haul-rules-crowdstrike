// Dragnet [Ransomware]: dragnet-ransomware-2022-0031 — Mass File Rename (royal)
// Status: deprecated | Level: high | ID: b96cad9b-64e2-5434-929e-9d517124d9ad

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
