// Dragnet [Ransomware]: dragnet-ransomware-2025-0564 — Mass File Rename (shinyhunters)
// Status: experimental | Level: high | ID: d968229f-09ec-5bd8-a29f-e5a780bfc964

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
