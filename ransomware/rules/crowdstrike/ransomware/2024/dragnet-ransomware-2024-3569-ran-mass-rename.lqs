// Dragnet [Ransomware]: dragnet-ransomware-2024-3569 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: ba2f9084-93e8-5ff1-ae0b-9a22f44ee0ff

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
