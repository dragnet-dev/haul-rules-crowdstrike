// Dragnet [Ransomware]: dragnet-ransomware-2023-4936 — Mass File Rename (monti)
// Status: experimental | Level: high | ID: 79dbe040-160b-5d2d-b787-75fe6d209e41

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
