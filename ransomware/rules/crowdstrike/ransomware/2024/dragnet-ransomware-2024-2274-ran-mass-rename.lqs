// Dragnet [Ransomware]: dragnet-ransomware-2024-2274 — Mass File Rename (ElDorado)
// Status: experimental | Level: high | ID: f3d68df4-4db0-57f2-8e76-45b7fdb41d88

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
