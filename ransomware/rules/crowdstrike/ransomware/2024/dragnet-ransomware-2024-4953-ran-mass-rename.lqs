// Dragnet [Ransomware]: dragnet-ransomware-2024-4953 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: dbd06b12-e9ad-5501-a6fb-3d39d01c784e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
