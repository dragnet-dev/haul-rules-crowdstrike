// Dragnet [Ransomware]: dragnet-ransomware-2025-4456 — Mass File Rename (killsec)
// Status: deprecated | Level: high | ID: ea6274b9-23b3-568a-859f-ec390c8c1126

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
