// Dragnet [Ransomware]: dragnet-ransomware-2023-0670 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: b79ec61d-1830-5fc8-a0a6-2b44bd21f7e8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
