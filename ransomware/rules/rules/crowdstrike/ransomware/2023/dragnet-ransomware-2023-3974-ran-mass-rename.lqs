// Dragnet [Ransomware]: dragnet-ransomware-2023-3974 — Mass File Rename (snatch)
// Status: experimental | Level: high | ID: 423f2bfa-995a-5c39-9136-9e8e71ea8eb1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
