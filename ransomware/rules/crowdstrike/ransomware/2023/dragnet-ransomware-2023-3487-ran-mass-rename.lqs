// Dragnet [Ransomware]: dragnet-ransomware-2023-3487 — Mass File Rename (noescape)
// Status: experimental | Level: high | ID: a38a05b3-800d-5d39-a45e-4b40cab8de40

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
