// Dragnet [Ransomware]: dragnet-ransomware-2024-3139 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: 4671d6e4-5724-5a8e-9471-21b5f767cec8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
