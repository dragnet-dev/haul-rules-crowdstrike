// Dragnet [Ransomware]: dragnet-ransomware-2025-1349 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 6f50394e-9040-5ae5-a75e-b00ca3bc7720

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
