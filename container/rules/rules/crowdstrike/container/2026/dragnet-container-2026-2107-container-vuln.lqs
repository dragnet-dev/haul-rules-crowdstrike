// Dragnet [Container]: dragnet-container-2026-2107 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 85fc2d8e-ea1f-591c-b9e1-5fbebf796ea0

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
