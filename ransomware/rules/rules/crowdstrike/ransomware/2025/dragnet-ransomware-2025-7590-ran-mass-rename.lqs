// Dragnet [Ransomware]: dragnet-ransomware-2025-7590 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 5739d16b-6dfa-57d9-b9b4-4b7f7861fcab

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
