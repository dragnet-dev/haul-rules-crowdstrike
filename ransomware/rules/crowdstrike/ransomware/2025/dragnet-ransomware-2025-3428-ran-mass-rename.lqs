// Dragnet [Ransomware]: dragnet-ransomware-2025-3428 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 26e57b36-8150-53be-b833-e9e16a826a4f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
