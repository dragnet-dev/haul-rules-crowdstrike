// Dragnet [Ransomware]: dragnet-ransomware-2026-1379 — Mass File Rename (dragonforce)
// Status: stable | Level: high | ID: c89b5f06-87ba-5994-8a75-014f5ec65723

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
