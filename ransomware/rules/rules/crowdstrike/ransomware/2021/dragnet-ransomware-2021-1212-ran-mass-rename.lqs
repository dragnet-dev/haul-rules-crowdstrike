// Dragnet [Ransomware]: dragnet-ransomware-2021-1212 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: f7485bcf-c93a-5d02-854b-3c790414acb3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
