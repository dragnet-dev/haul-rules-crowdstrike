// Dragnet [Ransomware]: dragnet-ransomware-2024-2196 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 47748119-1c3a-5afd-81af-8e7e9c0b84ae

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
