// Dragnet [Ransomware]: dragnet-ransomware-2025-5664 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: bae3d4df-72e7-58cf-9818-cedde0ceb180

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
