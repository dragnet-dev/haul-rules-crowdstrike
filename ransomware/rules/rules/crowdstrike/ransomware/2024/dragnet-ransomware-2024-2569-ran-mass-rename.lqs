// Dragnet [Ransomware]: dragnet-ransomware-2024-2569 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: dc9cdb31-a176-545a-8133-80fda1e302da

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
