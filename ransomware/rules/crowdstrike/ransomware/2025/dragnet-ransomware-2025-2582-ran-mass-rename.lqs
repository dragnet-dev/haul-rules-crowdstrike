// Dragnet [Ransomware]: dragnet-ransomware-2025-2582 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: f3b483ba-63e5-5867-b968-f476afc25bfc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
