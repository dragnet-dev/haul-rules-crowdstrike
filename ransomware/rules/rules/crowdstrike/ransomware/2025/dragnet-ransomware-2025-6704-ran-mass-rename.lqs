// Dragnet [Ransomware]: dragnet-ransomware-2025-6704 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 5790cbb2-1b34-5f82-84bb-f17a015853e1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
