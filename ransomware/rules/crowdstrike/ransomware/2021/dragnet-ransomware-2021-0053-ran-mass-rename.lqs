// Dragnet [Ransomware]: dragnet-ransomware-2021-0053 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 80d93e79-c81f-5f66-865f-8e47db2b9559

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
