// Dragnet [Ransomware]: dragnet-ransomware-2022-1036 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 0e466d82-3b14-54d3-a895-aef10556a0a5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
