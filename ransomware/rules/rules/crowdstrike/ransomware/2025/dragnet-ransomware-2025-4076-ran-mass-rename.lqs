// Dragnet [Ransomware]: dragnet-ransomware-2025-4076 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: afa9c9bb-dfe0-5f75-9619-1b0aacafb868

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
