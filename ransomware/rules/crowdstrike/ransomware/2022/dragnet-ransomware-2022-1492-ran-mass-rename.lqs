// Dragnet [Ransomware]: dragnet-ransomware-2022-1492 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 36d2d2ca-c219-5447-9626-cb483d0a8475

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
