// Dragnet [Ransomware]: dragnet-ransomware-2024-1467 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 632ae6fa-00b5-5797-b60a-d7c68c763f2e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
