// Dragnet [Ransomware]: dragnet-ransomware-2025-3053 — Mass File Rename (crypto24)
// Status: deprecated | Level: high | ID: 398609aa-d96a-599f-b0e9-ff6abfe83c15

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
