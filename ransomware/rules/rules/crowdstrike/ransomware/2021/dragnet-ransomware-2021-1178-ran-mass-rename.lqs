// Dragnet [Ransomware]: dragnet-ransomware-2021-1178 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 0850a851-dac2-5794-bfe7-b1a1a908e55c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
