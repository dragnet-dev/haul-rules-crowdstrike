// Dragnet [Ransomware]: dragnet-ransomware-2026-0621 — Mass File Rename (payload)
// Status: stable | Level: high | ID: 9535a3c2-faae-50e2-b0e7-6780b4cc8104

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
