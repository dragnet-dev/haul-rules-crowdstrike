// Dragnet [Container]: dragnet-container-2026-3059 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: db542764-680a-57aa-82ed-1c14d7601f37

#event_simpleName=*
| (ImageFileName = *alpine:3.23* OR ImageFileName = *alpine edge:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
