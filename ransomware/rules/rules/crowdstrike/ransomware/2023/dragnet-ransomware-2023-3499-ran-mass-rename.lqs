// Dragnet [Ransomware]: dragnet-ransomware-2023-3499 — Mass File Rename (snatch)
// Status: experimental | Level: high | ID: d08f3371-475b-54fe-8b7d-db72e83db87e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
