// Dragnet [Ransomware]: dragnet-ransomware-2025-6766 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 411f4f65-9265-5943-a679-e71772331a6d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
