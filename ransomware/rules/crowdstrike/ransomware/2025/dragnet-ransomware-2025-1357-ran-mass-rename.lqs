// Dragnet [Ransomware]: dragnet-ransomware-2025-1357 — Mass File Rename (worldleaks)
// Status: test | Level: high | ID: deb4405a-34d2-545c-8b55-2726df189af8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
