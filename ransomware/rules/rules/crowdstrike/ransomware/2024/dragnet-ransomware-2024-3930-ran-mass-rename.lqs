// Dragnet [Ransomware]: dragnet-ransomware-2024-3930 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 0de774c5-55c7-5bfe-ab63-cfae31896c2f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
