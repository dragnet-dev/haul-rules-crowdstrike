// Dragnet [Ransomware]: dragnet-ransomware-2026-1009 — Mass File Rename (lockbit5)
// Status: test | Level: high | ID: 0b76b1c7-f248-55db-9f62-1a28b4442188

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
