// Dragnet [Ransomware]: dragnet-ransomware-2023-3478 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 6b226581-42cb-508c-a941-a83498a55934

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
