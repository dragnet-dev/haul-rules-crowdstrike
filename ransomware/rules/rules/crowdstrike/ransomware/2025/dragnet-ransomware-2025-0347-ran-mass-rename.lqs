// Dragnet [Ransomware]: dragnet-ransomware-2025-0347 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 454cb508-0c0e-51db-ba69-6e97a8e3abf2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
