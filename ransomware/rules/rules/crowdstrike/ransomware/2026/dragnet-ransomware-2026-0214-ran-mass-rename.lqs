// Dragnet [Ransomware]: dragnet-ransomware-2026-0214 — Mass File Rename (anubis)
// Status: deprecated | Level: high | ID: f710652b-b2b3-530f-b789-d3b40bd4854f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
