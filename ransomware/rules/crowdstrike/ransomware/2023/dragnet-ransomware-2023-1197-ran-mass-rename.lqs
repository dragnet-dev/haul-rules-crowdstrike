// Dragnet [Ransomware]: dragnet-ransomware-2023-1197 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 2d9b0c5d-b9a5-5125-b8e5-0e41e5359923

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
