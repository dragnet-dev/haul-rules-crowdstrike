// Dragnet [Ransomware]: dragnet-ransomware-2025-0232 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 2a82f54e-5e5d-5bd6-9d49-c64bf77b6f23

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
