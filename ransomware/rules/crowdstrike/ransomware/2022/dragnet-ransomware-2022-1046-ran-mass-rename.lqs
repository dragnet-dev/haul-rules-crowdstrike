// Dragnet [Ransomware]: dragnet-ransomware-2022-1046 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 52606b66-f397-530f-a32e-e0dba563a5ef

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
