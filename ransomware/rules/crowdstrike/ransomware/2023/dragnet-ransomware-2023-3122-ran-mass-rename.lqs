// Dragnet [Ransomware]: dragnet-ransomware-2023-3122 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: e45f6b43-f58f-53fa-9b39-9e26983dd2ba

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
