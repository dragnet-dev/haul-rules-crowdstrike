// Dragnet [Ransomware]: dragnet-ransomware-2023-3849 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: ef70f10a-b5c5-54c9-981b-407134fd8f36

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
