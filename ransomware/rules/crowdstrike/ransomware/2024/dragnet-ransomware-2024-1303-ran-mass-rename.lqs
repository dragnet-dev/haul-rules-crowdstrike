// Dragnet [Ransomware]: dragnet-ransomware-2024-1303 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: cc3cef09-60ac-58fa-abdd-7d671aa67241

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
