// Dragnet [Ransomware]: dragnet-ransomware-2024-4152 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: be0efcb1-d40b-57d3-bb44-37c90474e074

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
