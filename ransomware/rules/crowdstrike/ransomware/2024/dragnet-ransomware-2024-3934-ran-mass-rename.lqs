// Dragnet [Ransomware]: dragnet-ransomware-2024-3934 — Mass File Rename (dragonforce)
// Status: deprecated | Level: high | ID: e7bacc17-ce58-5e4a-be95-aec5afbc63c1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
