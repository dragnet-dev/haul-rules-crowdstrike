// Dragnet [Ransomware]: dragnet-ransomware-2024-4858 — Mass File Rename (BrainCipher)
// Status: experimental | Level: high | ID: 6ef8a5ab-baa1-5f74-9514-8c2c951b958c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
