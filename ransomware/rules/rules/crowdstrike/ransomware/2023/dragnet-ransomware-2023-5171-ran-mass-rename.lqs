// Dragnet [Ransomware]: dragnet-ransomware-2023-5171 — Mass File Rename (ransomhouse)
// Status: deprecated | Level: high | ID: b6bb0654-6a6d-58ed-a791-beef8210647e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
