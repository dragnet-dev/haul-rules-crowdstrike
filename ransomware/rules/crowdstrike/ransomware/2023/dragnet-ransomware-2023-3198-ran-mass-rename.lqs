// Dragnet [Ransomware]: dragnet-ransomware-2023-3198 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: e1ecc03d-c221-5d0d-bb49-bee5bb7c01e8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
