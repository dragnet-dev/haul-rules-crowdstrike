// Dragnet [Ransomware]: dragnet-ransomware-2023-4500 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 6052f6e1-a791-587d-b751-b3446b80b61b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
