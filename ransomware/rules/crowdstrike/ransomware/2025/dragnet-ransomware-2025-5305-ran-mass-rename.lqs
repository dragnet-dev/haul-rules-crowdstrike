// Dragnet [Ransomware]: dragnet-ransomware-2025-5305 — Mass File Rename (spacebears)
// Status: experimental | Level: high | ID: ff2b729e-487e-5271-9ee5-05cb32164e5b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
