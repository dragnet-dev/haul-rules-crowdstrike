// Dragnet [Ransomware]: dragnet-ransomware-2024-2245 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: a3d80841-33f2-5a5e-92f2-874a317d16a7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
