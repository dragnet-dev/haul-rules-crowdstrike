// Dragnet [Ransomware]: dragnet-ransomware-2024-4295 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: f90a39ff-9b55-555b-bfb6-0c6dd7a539b7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
