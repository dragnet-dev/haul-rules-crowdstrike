// Dragnet [Ransomware]: dragnet-ransomware-2026-1123 — Mass File Rename (thegentlemen)
// Status: test | Level: high | ID: 4a6ef9de-d990-52de-89f9-1d5113c2b16b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
