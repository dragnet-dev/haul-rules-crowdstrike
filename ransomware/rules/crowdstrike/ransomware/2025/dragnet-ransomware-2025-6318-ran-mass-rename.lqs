// Dragnet [Ransomware]: dragnet-ransomware-2025-6318 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 3e0507c1-61a9-510a-860d-e7684933ed18

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
