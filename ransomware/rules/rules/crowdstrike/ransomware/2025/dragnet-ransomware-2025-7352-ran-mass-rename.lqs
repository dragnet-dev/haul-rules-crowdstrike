// Dragnet [Ransomware]: dragnet-ransomware-2025-7352 — Mass File Rename (shinyhunters)
// Status: experimental | Level: high | ID: 5e53b641-6c02-51f1-9860-c8c0178ae505

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
