// Dragnet [Ransomware]: dragnet-ransomware-2021-0501 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: b157d411-0e14-5f67-85d2-733779cd7d14

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
