// Dragnet [Ransomware]: dragnet-ransomware-2025-1627 — Mass File Rename (ransomhouse)
// Status: experimental | Level: high | ID: a5e11b53-1400-573a-9e5e-79385e065ca0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
