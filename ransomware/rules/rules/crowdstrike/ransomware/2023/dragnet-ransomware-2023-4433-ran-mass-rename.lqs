// Dragnet [Ransomware]: dragnet-ransomware-2023-4433 — Mass File Rename (play)
// Status: deprecated | Level: high | ID: 6bd62dec-8974-5d92-89b0-daaa91870e2b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
