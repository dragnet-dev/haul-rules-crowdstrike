// Dragnet [Ransomware]: dragnet-ransomware-2025-2415 — Mass File Rename (thegentlemen)
// Status: experimental | Level: high | ID: 8580331d-0fd0-508f-9796-990bbaee7ad9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
