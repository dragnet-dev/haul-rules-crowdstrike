// Dragnet [Ransomware]: dragnet-ransomware-2023-4086 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 3a556e97-83ad-54c2-ba56-fe3cffe30be9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
