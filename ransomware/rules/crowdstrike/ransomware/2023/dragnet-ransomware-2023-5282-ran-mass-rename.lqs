// Dragnet [Ransomware]: dragnet-ransomware-2023-5282 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: c645ca1a-9743-5b98-ad0d-2edfc063b9a3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
