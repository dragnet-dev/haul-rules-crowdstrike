// Dragnet [Ransomware]: dragnet-ransomware-2024-1369 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 371d6de6-d44d-58b1-adf7-8df71e9d2753

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
