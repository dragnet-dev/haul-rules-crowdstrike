// Dragnet [Ransomware]: dragnet-ransomware-2025-6363 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: c7d33c06-6cd3-53ee-bc93-d58e3470da47

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
