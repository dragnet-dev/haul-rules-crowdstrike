// Dragnet [Ransomware]: dragnet-ransomware-2025-1924 — Mass File Rename (payoutsking)
// Status: experimental | Level: high | ID: 1a72a8e4-2e3a-56b2-af66-a3c829f685e6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
