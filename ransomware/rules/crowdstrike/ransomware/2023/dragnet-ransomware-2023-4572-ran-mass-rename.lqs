// Dragnet [Ransomware]: dragnet-ransomware-2023-4572 — Mass File Rename (noescape)
// Status: experimental | Level: high | ID: 1ba9370e-a0ce-5cde-a906-b88e2df66dc2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
