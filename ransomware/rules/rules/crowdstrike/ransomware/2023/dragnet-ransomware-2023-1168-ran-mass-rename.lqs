// Dragnet [Ransomware]: dragnet-ransomware-2023-1168 — Mass File Rename (noescape)
// Status: experimental | Level: high | ID: 957bad9e-93f5-5785-88a2-603b39558dd7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
