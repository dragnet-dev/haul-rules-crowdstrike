// Dragnet [Ransomware]: dragnet-ransomware-2021-0002 — Mass File Rename (everest)
// Status: deprecated | Level: high | ID: 94ff3c8f-8b07-52cd-bbc7-e01f307ddf19

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
