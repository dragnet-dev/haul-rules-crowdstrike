// Dragnet [Ransomware]: dragnet-ransomware-2023-0795 — Mass File Rename (royal)
// Status: deprecated | Level: high | ID: 5bcc55b0-8ce2-58ff-8933-fcfa810371f9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
