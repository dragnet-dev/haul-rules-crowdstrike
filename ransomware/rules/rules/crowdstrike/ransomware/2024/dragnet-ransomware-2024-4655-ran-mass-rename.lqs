// Dragnet [Ransomware]: dragnet-ransomware-2024-4655 — Mass File Rename (play)
// Status: experimental | Level: high | ID: abd1d1ad-ff4f-5cb8-b248-1152996a7509

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
