// Dragnet [Ransomware]: dragnet-ransomware-2024-1322 — Mass File Rename (play)
// Status: experimental | Level: high | ID: ef9b5613-4691-592e-b29e-0ce67a3bbe5c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
