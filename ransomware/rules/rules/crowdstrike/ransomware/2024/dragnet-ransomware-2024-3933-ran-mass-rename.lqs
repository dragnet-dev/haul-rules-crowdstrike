// Dragnet [Ransomware]: dragnet-ransomware-2024-3933 — Mass File Rename (ransomhouse)
// Status: experimental | Level: high | ID: 047fefc9-748b-5010-bd76-90eae53b3b9a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
