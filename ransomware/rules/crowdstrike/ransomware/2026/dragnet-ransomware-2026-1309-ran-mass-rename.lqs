// Dragnet [Ransomware]: dragnet-ransomware-2026-1309 — Mass File Rename (ALP-001)
// Status: stable | Level: high | ID: 673c5c77-08b6-57eb-aca9-12cc1270fb44

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
