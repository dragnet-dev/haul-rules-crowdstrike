// Dragnet [Ransomware]: dragnet-ransomware-2022-0432 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: 48eb7a99-8b69-5fe7-baf0-4c9c83d25d76

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
