// Dragnet [Ransomware]: dragnet-ransomware-2022-0185 — Mass File Rename (royal)
// Status: deprecated | Level: high | ID: 901ed58d-c6e0-5ce4-8222-93f1639b4d60

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
