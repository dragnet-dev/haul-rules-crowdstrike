// Dragnet [Ransomware]: dragnet-ransomware-2024-4366 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: e8da1d4d-203e-583e-8deb-5d590ed54598

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
