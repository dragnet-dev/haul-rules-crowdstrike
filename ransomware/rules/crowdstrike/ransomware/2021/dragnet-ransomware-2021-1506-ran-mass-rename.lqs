// Dragnet [Ransomware]: dragnet-ransomware-2021-1506 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 2a3ad9f5-7465-5f07-b873-b280977ce5e1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
