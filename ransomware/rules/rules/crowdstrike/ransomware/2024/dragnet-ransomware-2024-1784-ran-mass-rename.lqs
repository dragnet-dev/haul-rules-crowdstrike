// Dragnet [Ransomware]: dragnet-ransomware-2024-1784 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 47b5463f-8a5b-58ce-ac72-79b665816992

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
