// Dragnet [Ransomware]: dragnet-ransomware-2024-3085 — Mass File Rename (moneymessage)
// Status: experimental | Level: high | ID: 11de2e63-ca44-545d-b4a4-3b737a15c683

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
