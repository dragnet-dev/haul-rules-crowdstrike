// Dragnet [Ransomware]: dragnet-ransomware-2025-1385 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: aa51f754-8cb7-58a0-96d0-2f1d52b14925

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
