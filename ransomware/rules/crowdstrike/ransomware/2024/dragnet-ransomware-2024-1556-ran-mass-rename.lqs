// Dragnet [Ransomware]: dragnet-ransomware-2024-1556 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 999e2cba-252e-5970-b2ea-0059258880e9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
