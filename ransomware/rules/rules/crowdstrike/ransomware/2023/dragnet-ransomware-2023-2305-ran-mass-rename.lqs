// Dragnet [Ransomware]: dragnet-ransomware-2023-2305 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 9468b0fc-e08d-50c7-b97c-27d671d24d6e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
