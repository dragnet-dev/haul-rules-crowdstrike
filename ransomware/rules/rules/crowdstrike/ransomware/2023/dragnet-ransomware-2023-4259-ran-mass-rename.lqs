// Dragnet [Ransomware]: dragnet-ransomware-2023-4259 — Mass File Rename (snatch)
// Status: experimental | Level: high | ID: 0da34283-4077-5f62-afb1-71d9f091ba37

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
