// Dragnet [Ransomware]: dragnet-ransomware-2024-5231 — Mass File Rename (rhysida)
// Status: deprecated | Level: high | ID: e4d8198c-e6b3-5533-a4a9-3c9aeec18058

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
