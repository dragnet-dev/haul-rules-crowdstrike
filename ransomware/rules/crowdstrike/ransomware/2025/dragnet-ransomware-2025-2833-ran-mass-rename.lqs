// Dragnet [Ransomware]: dragnet-ransomware-2025-2833 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: c7080ce4-5b37-5478-a6c9-285e5e0c4920

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
