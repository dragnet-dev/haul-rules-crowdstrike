// Dragnet [Ransomware]: dragnet-ransomware-2023-1950 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: b54b3bd5-5f9e-5a17-adc7-577247ab1ebf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
