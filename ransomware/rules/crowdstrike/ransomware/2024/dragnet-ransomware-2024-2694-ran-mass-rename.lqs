// Dragnet [Ransomware]: dragnet-ransomware-2024-2694 — Mass File Rename (ransomhouse)
// Status: experimental | Level: high | ID: b0cced54-2d11-5383-9f9f-ca0f5c825ff9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
