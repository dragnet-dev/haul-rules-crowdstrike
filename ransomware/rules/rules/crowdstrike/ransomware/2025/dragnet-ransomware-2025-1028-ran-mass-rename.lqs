// Dragnet [Ransomware]: dragnet-ransomware-2025-1028 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 57befc39-c9bb-5be7-8c8d-c7c781d5429b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
