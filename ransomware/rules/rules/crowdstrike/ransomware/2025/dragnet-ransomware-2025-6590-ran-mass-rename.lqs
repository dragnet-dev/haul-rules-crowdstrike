// Dragnet [Ransomware]: dragnet-ransomware-2025-6590 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 93163f75-f45a-53fc-9f15-f9b18ded3596

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
