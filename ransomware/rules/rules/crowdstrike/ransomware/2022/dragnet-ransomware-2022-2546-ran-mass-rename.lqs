// Dragnet [Ransomware]: dragnet-ransomware-2022-2546 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: a2090b53-b59c-53b5-8763-8295fb4bcd66

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
