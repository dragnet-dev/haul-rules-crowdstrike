// Dragnet [Ransomware]: dragnet-ransomware-2024-1060 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 59f3d05d-8b67-5c0e-8990-41615d49a379

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
