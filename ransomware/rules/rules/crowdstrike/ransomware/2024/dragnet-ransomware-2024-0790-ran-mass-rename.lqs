// Dragnet [Ransomware]: dragnet-ransomware-2024-0790 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 9b835aae-e6f9-5bfe-a99d-c685a2c94677

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
