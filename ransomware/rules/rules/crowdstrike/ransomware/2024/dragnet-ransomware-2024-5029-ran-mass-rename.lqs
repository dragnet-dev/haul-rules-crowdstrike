// Dragnet [Ransomware]: dragnet-ransomware-2024-5029 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 4c0793d1-9155-5b13-a38e-26e780ff2f12

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
