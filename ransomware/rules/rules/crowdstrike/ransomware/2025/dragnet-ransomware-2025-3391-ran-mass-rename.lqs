// Dragnet [Ransomware]: dragnet-ransomware-2025-3391 — Mass File Rename (coinbasecartel)
// Status: experimental | Level: high | ID: 9815ac52-06ba-5f6b-9331-1cf897d61efc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
