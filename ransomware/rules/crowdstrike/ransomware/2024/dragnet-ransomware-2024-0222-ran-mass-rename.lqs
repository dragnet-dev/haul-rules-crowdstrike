// Dragnet [Ransomware]: dragnet-ransomware-2024-0222 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 3d887370-ba0e-56db-b27a-cf6422a24eb8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
