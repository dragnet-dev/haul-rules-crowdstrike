// Dragnet [Ransomware]: dragnet-ransomware-2022-2969 — Mass File Rename (snatch)
// Status: deprecated | Level: high | ID: 75e83e79-7e04-56c0-bec5-6e1e46595ec4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
