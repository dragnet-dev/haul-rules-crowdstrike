// Dragnet [Ransomware]: dragnet-ransomware-2023-3820 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: ee1ad724-7a35-5fba-a6ba-74a84fb1f4b0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
