// Dragnet [Ransomware]: dragnet-ransomware-2025-4194 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 7c863250-c152-531d-891e-4968c48bcd9f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
