// Dragnet [Ransomware]: dragnet-ransomware-2026-1002 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: e5263f49-2f1a-51c8-b77e-76db0ef24a99

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
