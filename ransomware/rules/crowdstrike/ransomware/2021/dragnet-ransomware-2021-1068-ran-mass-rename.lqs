// Dragnet [Ransomware]: dragnet-ransomware-2021-1068 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: a269b9aa-6aa1-5945-a016-b50bce8fe25f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
