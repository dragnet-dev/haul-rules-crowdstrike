// Dragnet [Ransomware]: dragnet-ransomware-2022-1844 — Mass File Rename (stormous)
// Status: deprecated | Level: high | ID: af27392b-87cf-5116-be32-3528fb816f5e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
