// Dragnet [Ransomware]: dragnet-ransomware-2025-4539 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 8cf1efe1-e8ec-5f56-b88d-4276b6d8195f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
