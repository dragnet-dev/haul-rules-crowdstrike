// Dragnet [Ransomware]: dragnet-ransomware-2025-6033 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: 4547b2b7-27ae-50a2-b199-00781c0573a9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
