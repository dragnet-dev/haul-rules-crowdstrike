// Dragnet [Ransomware]: dragnet-ransomware-2024-2550 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: c16bafd4-3658-58e3-867e-44a198e8f10b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
