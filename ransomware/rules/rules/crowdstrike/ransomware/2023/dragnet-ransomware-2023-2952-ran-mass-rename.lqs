// Dragnet [Ransomware]: dragnet-ransomware-2023-2952 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 789cbd2a-2b45-5694-b6b3-7222aad02ef4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
