// Dragnet [Ransomware]: dragnet-ransomware-2024-2201 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 9d5fe1c4-679f-5200-b742-6360c17db1c9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
