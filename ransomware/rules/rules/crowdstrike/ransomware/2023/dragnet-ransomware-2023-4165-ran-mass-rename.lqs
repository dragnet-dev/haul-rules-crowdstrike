// Dragnet [Ransomware]: dragnet-ransomware-2023-4165 — Mass File Rename (moneymessage)
// Status: deprecated | Level: high | ID: 38db7e07-3e29-5609-aa13-08256acfa758

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
