// Dragnet [Ransomware]: dragnet-ransomware-2024-4263 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 86ea512b-bc38-529d-b62f-6dd5a31a8b4b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
