// Dragnet [Ransomware]: dragnet-ransomware-2023-1645 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 3123b116-8aae-564e-af03-97b39d846ede

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
