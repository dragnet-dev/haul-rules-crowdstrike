// Dragnet [Ransomware]: dragnet-ransomware-2021-0790 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: da2c7290-a28e-5c9f-ba54-dde7423d0b45

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
