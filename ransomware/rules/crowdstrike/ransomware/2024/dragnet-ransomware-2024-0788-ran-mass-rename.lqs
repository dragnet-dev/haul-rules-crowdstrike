// Dragnet [Ransomware]: dragnet-ransomware-2024-0788 — Mass File Rename (meow)
// Status: experimental | Level: high | ID: a493aabc-ba1a-5a65-b33a-3872c7848685

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
