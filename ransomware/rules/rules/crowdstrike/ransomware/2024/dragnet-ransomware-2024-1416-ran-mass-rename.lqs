// Dragnet [Ransomware]: dragnet-ransomware-2024-1416 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 1110c6d9-1527-5143-9d88-141c27fa51d0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
