// Dragnet [Ransomware]: dragnet-ransomware-2025-6389 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: c22c4bef-6cf2-5871-bd99-3c8011bfac49

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
