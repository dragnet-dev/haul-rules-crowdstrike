// Dragnet [Ransomware]: dragnet-ransomware-2025-3402 — Mass File Rename (crypto24)
// Status: deprecated | Level: high | ID: 804545d4-c6da-54b8-8ffb-0e29fea6b836

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
