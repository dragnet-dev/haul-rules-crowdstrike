// Dragnet [Ransomware]: dragnet-ransomware-2025-2535 — Mass File Rename (cloak)
// Status: deprecated | Level: high | ID: c221b318-e77a-5970-adab-1b56769d1434

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
