// Dragnet [Ransomware]: dragnet-ransomware-2025-1076 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: f880c60a-fcee-5973-bfda-efa5d7f1856a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
