// Dragnet [Ransomware]: dragnet-ransomware-2024-2563 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: 98053860-f822-583d-b28a-eddc91c4dea0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
