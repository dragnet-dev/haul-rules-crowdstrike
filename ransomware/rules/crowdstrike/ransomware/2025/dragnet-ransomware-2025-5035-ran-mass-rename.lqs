// Dragnet [Ransomware]: dragnet-ransomware-2025-5035 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 36d35dca-1422-506f-b9ff-5cdd26963b75

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
