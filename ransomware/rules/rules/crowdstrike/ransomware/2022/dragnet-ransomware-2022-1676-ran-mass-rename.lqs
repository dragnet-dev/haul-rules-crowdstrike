// Dragnet [Ransomware]: dragnet-ransomware-2022-1676 — Mass File Rename (revil)
// Status: deprecated | Level: high | ID: 96c583ad-c92b-5616-a6f1-bfc41210b1be

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
