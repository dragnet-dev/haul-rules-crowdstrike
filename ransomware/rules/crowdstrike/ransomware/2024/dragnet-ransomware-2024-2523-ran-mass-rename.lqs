// Dragnet [Ransomware]: dragnet-ransomware-2024-2523 — Mass File Rename (raworld)
// Status: experimental | Level: high | ID: a437e319-14cf-5651-bdb1-d75909bfed3b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
