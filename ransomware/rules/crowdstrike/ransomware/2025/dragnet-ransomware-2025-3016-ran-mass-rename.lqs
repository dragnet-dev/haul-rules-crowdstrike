// Dragnet [Ransomware]: dragnet-ransomware-2025-3016 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: bea05934-f8a3-5e41-b488-9f3e82a39643

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
