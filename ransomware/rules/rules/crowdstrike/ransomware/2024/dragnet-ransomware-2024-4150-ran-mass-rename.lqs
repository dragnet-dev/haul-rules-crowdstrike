// Dragnet [Ransomware]: dragnet-ransomware-2024-4150 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: e4e95039-b3aa-5633-a946-68d0b45554b7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
