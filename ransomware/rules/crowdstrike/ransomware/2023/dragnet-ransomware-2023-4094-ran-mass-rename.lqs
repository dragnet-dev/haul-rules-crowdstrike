// Dragnet [Ransomware]: dragnet-ransomware-2023-4094 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 6bb21d22-fafd-5759-825a-dba0e24da398

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
