// Dragnet [Ransomware]: dragnet-ransomware-2024-2221 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 3f9712e0-ad77-500a-abba-19a1fe3d8911

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
