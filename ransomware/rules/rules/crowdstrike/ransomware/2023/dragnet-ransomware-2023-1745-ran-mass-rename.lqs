// Dragnet [Ransomware]: dragnet-ransomware-2023-1745 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: e74b000f-249c-54de-b4e6-e00aacedaa1f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
