// Dragnet [Ransomware]: dragnet-ransomware-2023-1857 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 60106c40-6171-5cd1-a08d-2020ce3eced1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
