// Dragnet [Ransomware]: dragnet-ransomware-2023-2902 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 95404caf-3bde-53f9-bf38-b93d4c8f4b43

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
