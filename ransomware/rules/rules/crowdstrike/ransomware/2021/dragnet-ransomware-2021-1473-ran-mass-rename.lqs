// Dragnet [Ransomware]: dragnet-ransomware-2021-1473 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: e9d45462-7df6-5830-87bf-9a7b9beb23a7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
