// Dragnet [Container]: dragnet-container-2024-0770 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 86877664-c3cc-5e44-9daa-6e4073683652

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:7* OR ImageFileName = *debian:8* OR ImageFileName = *debian:9* OR ImageFileName = *ubuntu:16.04* OR ImageFileName = *ubuntu:16.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
