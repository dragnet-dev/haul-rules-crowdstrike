// Dragnet [Ransomware]: dragnet-ransomware-2022-0681 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: f3fe3009-4010-5155-b665-c0b21bdda532

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
