// Dragnet [Ransomware]: dragnet-ransomware-2026-1564 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 4a2a6f74-a53c-5f9a-ba1e-9406642d990a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
