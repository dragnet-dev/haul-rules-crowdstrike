// Dragnet [Ransomware]: dragnet-ransomware-2025-7739 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 1e03b559-5bf9-5e0c-97c5-2e646a3d755b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
