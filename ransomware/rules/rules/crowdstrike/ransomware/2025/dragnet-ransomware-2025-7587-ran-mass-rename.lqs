// Dragnet [Ransomware]: dragnet-ransomware-2025-7587 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 43026f8a-b37b-5410-86cf-03756ea78dda

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
