// Dragnet [Ransomware]: dragnet-ransomware-2025-0048 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 2f5cbb5e-d07c-57f0-b886-028080111a5c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
