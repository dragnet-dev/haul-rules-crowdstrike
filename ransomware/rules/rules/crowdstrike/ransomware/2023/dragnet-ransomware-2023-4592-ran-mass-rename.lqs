// Dragnet [Ransomware]: dragnet-ransomware-2023-4592 — Mass File Rename (snatch)
// Status: experimental | Level: high | ID: f1d96a90-9e2f-583f-8207-b0687a2363f6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
