// Dragnet [Ransomware]: dragnet-ransomware-2026-1744 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 996ce675-83f3-5e4e-a52b-29d087e79fcf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
