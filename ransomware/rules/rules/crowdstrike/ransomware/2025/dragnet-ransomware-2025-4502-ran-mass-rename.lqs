// Dragnet [Ransomware]: dragnet-ransomware-2025-4502 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 5cc4c302-25cb-5eb9-bd06-f501f9d87cf9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
