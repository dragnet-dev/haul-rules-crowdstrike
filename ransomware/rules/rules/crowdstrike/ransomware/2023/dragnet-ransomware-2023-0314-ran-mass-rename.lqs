// Dragnet [Ransomware]: dragnet-ransomware-2023-0314 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: dce9bbfa-5fa9-5c1e-93ed-48d8a5cd1613

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
