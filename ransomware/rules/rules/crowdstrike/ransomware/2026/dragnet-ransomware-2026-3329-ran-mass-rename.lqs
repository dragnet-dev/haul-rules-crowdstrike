// Dragnet [Ransomware]: dragnet-ransomware-2026-3329 — Mass File Rename (SilentRansomGroup)
// Status: deprecated | Level: high | ID: 6d9321bb-4464-58dd-b0f8-8187eebc3ff6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
