// Dragnet [Ransomware]: dragnet-ransomware-2024-3572 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 21760860-fbbc-5f55-b988-2184da545a22

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
