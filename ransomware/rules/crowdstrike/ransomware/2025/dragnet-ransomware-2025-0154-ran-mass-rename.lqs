// Dragnet [Ransomware]: dragnet-ransomware-2025-0154 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 9aa3ccc2-84e2-5964-a2bf-d03d1e085581

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
