// Dragnet [Ransomware]: dragnet-ransomware-2024-1769 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: f83df39a-9620-5470-bc04-5acdc6eda12e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
