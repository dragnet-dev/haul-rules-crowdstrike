// Dragnet [Ransomware]: dragnet-ransomware-2025-3990 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: eb377468-c9d1-598f-8e13-26c13500e4c3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
