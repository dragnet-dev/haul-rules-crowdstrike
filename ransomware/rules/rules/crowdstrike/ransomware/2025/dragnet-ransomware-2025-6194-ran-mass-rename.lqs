// Dragnet [Ransomware]: dragnet-ransomware-2025-6194 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 3f3ade6e-f0cd-543d-93ad-236ec5df5c05

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
