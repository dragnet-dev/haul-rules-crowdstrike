// Dragnet [Ransomware]: dragnet-ransomware-2023-4556 — Mass File Rename (monti)
// Status: experimental | Level: high | ID: 5f9e76f9-c344-5165-92d9-b76839b74790

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
