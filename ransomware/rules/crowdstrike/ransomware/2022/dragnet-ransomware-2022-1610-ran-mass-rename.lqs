// Dragnet [Ransomware]: dragnet-ransomware-2022-1610 — Mass File Rename (cuba)
// Status: deprecated | Level: high | ID: 6afcf01f-6e57-5946-b2d0-a55e3a1d429a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
