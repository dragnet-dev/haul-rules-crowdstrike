// Dragnet [Ransomware]: dragnet-ransomware-2024-4903 — Mass File Rename (stormous)
// Status: deprecated | Level: high | ID: bc65ba51-b6e5-53f2-b3d9-78fbbc9b66e7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
