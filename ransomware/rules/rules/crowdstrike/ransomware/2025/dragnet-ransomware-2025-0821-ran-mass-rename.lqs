// Dragnet [Ransomware]: dragnet-ransomware-2025-0821 — Mass File Rename (cicada3301)
// Status: experimental | Level: high | ID: a889b63f-3a4d-5543-9a51-f53e00212189

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
