// Dragnet [Ransomware]: dragnet-ransomware-2025-5626 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: a0ec9ef3-f00b-507d-ac93-c6675d07a32a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
