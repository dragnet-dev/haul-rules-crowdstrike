// Dragnet [Ransomware]: dragnet-ransomware-2022-1749 — Mass File Rename (snatch)
// Status: deprecated | Level: high | ID: 0a252ee7-71a7-5def-8d9f-08848cd41304

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
