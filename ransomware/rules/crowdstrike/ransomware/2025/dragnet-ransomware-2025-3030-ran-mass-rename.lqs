// Dragnet [Ransomware]: dragnet-ransomware-2025-3030 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: c059d726-36cd-565c-917c-c0b7dfc5f7c0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
