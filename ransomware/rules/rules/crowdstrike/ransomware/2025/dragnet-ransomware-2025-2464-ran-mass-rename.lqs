// Dragnet [Ransomware]: dragnet-ransomware-2025-2464 — Mass File Rename (thegentlemen)
// Status: test | Level: high | ID: 3f70742d-d83d-567a-959e-790248771da5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
