// Dragnet [Container]: dragnet-container-2024-1024 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 1a870b68-647e-5827-9418-bc24d3048f4f

#event_simpleName=*
| (ImageFileName = *amazonlinux:1* OR ImageFileName = *amazonlinux:2* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:7* OR ImageFileName = *debian:8* OR ImageFileName = *debian:9* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *oraclelinux:7* OR ImageFileName = *photon os:2.0* OR ImageFileName = *ubuntu:16.04* OR ImageFileName = *ubuntu:16.04-ESM* OR ImageFileName = *ubuntu:17.10*)
| table([timestamp, ComputerName])
| limit(1000)
