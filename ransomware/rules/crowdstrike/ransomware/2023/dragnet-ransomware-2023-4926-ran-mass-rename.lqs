// Dragnet [Ransomware]: dragnet-ransomware-2023-4926 — Mass File Rename (noescape)
// Status: experimental | Level: high | ID: 9b3eb987-1620-5377-b621-a17a7e707211

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
