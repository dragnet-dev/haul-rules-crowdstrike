// Dragnet [Ransomware]: dragnet-ransomware-2024-0645 — Mass File Rename (arcusmedia)
// Status: experimental | Level: high | ID: 0e5d6584-c24e-581b-b023-9df2f6e67904

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
