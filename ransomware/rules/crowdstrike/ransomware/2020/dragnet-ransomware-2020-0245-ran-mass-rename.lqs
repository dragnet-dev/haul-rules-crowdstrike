// Dragnet [Ransomware]: dragnet-ransomware-2020-0245 — Mass File Rename (ryuk)
// Status: deprecated | Level: high | ID: 0ece5fe0-9753-541e-940a-e55724522cbb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
