// Dragnet [Ransomware]: dragnet-ransomware-2024-0965 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: a20d5920-08b4-516d-ad6a-5c68e798ee01

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
