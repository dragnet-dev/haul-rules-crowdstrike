// Dragnet [Ransomware]: dragnet-ransomware-2026-1315 — Mass File Rename (cmdorganization)
// Status: deprecated | Level: high | ID: 65533c79-70d8-5d74-83dd-c4ac2211bb96

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
