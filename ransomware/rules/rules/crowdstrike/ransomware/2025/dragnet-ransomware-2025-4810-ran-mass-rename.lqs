// Dragnet [Ransomware]: dragnet-ransomware-2025-4810 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: 11e35ca8-e842-51d5-a696-1298d26a7545

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
