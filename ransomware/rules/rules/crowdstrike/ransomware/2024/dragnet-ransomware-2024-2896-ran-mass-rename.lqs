// Dragnet [Ransomware]: dragnet-ransomware-2024-2896 — Mass File Rename (spacebears)
// Status: experimental | Level: high | ID: e500ef8a-1790-5cfb-bee8-9928d46e656a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
