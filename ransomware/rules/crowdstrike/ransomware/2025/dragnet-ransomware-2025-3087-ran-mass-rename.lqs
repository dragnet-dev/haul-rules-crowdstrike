// Dragnet [Ransomware]: dragnet-ransomware-2025-3087 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: 17a0c799-4477-5052-a9c9-975f06766073

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
