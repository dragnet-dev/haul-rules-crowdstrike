// Dragnet [Ransomware]: dragnet-ransomware-2024-2307 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 6aa88e4d-3925-5004-8cf7-22a58bc67947

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
