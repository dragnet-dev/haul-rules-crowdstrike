// Dragnet [Ransomware]: dragnet-ransomware-2022-1325 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 780b2e79-11b2-5b39-b9c5-715b71753195

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
