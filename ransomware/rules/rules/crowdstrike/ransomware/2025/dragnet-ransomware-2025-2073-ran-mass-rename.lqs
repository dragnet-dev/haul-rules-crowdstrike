// Dragnet [Ransomware]: dragnet-ransomware-2025-2073 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: e344491b-10e4-571b-98dd-d822a26a84a8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
