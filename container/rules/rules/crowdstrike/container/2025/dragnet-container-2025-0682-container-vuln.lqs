// Dragnet [Container]: dragnet-container-2025-0682 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: c755028b-4b9c-58fb-ab0b-c2bec183a156

#event_simpleName=*
| (ImageFileName = *chainguard:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:18.04-ESM* OR ImageFileName = *ubuntu:20.04-ESM* OR ImageFileName = *ubuntu:22.04* OR ImageFileName = *ubuntu:24.04* OR ImageFileName = *ubuntu:25.04* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
