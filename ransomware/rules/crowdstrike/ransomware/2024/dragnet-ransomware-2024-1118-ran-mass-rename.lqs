// Dragnet [Ransomware]: dragnet-ransomware-2024-1118 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 4b0cc3ae-ba35-54df-969f-a2fdee25133b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
