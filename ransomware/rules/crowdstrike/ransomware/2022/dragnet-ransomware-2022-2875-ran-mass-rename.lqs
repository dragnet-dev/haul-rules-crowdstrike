// Dragnet [Ransomware]: dragnet-ransomware-2022-2875 — Mass File Rename (avoslocker)
// Status: deprecated | Level: high | ID: 79aa8c3e-b1e2-5b22-bb2e-9f9a764fadb2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
