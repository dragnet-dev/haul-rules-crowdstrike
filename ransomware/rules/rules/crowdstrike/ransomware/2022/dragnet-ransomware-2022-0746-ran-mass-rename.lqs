// Dragnet [Ransomware]: dragnet-ransomware-2022-0746 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 9c8e6d57-1080-53f2-96f6-20bed2de6a1e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
