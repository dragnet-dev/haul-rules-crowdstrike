// Dragnet [Container]: dragnet-container-2025-0138 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 5afd232e-7654-5e8a-898e-ca944093e176

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
