// Dragnet [Ransomware]: dragnet-ransomware-2025-2465 — Mass File Rename (thegentlemen)
// Status: test | Level: high | ID: eaa0683c-5f6b-52e5-85a6-180dfedd1cee

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
