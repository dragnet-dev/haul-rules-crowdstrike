// Dragnet [Ransomware]: dragnet-ransomware-2024-1079 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 4966c48b-d602-51c5-8fcb-18b1c0b78e8a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
