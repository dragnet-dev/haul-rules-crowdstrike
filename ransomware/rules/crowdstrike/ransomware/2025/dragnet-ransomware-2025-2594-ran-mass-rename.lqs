// Dragnet [Ransomware]: dragnet-ransomware-2025-2594 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 5b0dc6e2-38a5-5350-b84c-cc336ae80e0e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
