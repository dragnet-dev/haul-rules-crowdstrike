// Dragnet [Ransomware]: dragnet-ransomware-2022-1881 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 9f4e7253-839c-5702-ba8b-8fc4a3afc3c1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
