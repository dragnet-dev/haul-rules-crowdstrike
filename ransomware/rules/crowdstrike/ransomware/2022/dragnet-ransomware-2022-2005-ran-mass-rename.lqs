// Dragnet [Ransomware]: dragnet-ransomware-2022-2005 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: a117eac6-37e0-57cc-9b0f-f8b6e7be018a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
