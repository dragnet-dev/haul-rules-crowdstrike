// Dragnet [Ransomware]: dragnet-ransomware-2022-1840 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 8877502a-f3c4-5632-ae69-001d611806c7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
