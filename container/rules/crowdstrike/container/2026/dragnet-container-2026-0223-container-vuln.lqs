// Dragnet [Container]: dragnet-container-2026-0223 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: cbfa4223-586c-5e24-af2d-a9646404f2cf

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
