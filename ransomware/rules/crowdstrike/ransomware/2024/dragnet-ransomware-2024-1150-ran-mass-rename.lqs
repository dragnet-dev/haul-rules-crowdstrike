// Dragnet [Ransomware]: dragnet-ransomware-2024-1150 — Mass File Rename (ransomhouse)
// Status: experimental | Level: high | ID: 9d527486-7a83-5c2f-a26d-e7c71f19462f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
