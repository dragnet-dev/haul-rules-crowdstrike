// Dragnet [Ransomware]: dragnet-ransomware-2025-1338 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 3e9b9fbe-5131-5d55-b908-5ea5afc8d4bc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
