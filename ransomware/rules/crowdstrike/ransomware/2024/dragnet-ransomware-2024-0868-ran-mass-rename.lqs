// Dragnet [Ransomware]: dragnet-ransomware-2024-0868 — Mass File Rename (stormous)
// Status: deprecated | Level: high | ID: fafde03e-9900-5088-9519-d8611ebac596

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
