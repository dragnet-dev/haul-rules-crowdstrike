// Dragnet [Ransomware]: dragnet-ransomware-2020-0001 — Mass File Rename (sekhmet)
// Status: deprecated | Level: high | ID: 730feb33-7b27-56b0-bbb2-3b176d259e2e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
