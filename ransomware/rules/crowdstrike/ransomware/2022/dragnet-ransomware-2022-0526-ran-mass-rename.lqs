// Dragnet [Ransomware]: dragnet-ransomware-2022-0526 — Mass File Rename (blackbasta)
// Status: deprecated | Level: high | ID: b14ded18-821d-5fcb-8f1a-44cb8b95fe7e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
