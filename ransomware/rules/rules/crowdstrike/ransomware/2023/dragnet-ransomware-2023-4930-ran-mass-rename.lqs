// Dragnet [Ransomware]: dragnet-ransomware-2023-4930 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 16b42841-74d6-5bb0-9065-3fc0d42478af

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
