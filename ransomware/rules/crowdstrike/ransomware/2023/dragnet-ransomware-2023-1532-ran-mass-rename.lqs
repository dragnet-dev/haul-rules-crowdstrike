// Dragnet [Ransomware]: dragnet-ransomware-2023-1532 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: e9def9d7-98ac-559c-ad73-9f760ed7c561

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
