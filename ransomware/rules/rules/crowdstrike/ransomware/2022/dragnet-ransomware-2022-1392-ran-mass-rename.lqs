// Dragnet [Ransomware]: dragnet-ransomware-2022-1392 — Mass File Rename (cuba)
// Status: deprecated | Level: high | ID: ace81ad1-2ab5-5fd3-8077-3a4a4f5394ca

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
