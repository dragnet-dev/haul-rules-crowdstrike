// Dragnet [Ransomware]: dragnet-ransomware-2023-4074 — Mass File Rename (darkrace)
// Status: experimental | Level: high | ID: f62ace95-a47a-5b5f-ae76-06f2affa96e8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
