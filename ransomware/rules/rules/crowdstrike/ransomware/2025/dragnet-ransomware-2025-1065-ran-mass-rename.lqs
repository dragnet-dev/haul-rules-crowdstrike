// Dragnet [Ransomware]: dragnet-ransomware-2025-1065 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 859f5842-5cce-5ce4-9d9d-9fd7f678335d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
