// Dragnet [Ransomware]: dragnet-ransomware-2024-0653 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 172c3bba-3474-5f07-a077-0f72e32c1b63

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
