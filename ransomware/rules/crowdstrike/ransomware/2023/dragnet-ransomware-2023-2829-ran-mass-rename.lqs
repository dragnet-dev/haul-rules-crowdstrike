// Dragnet [Ransomware]: dragnet-ransomware-2023-2829 — Mass File Rename (malas)
// Status: experimental | Level: high | ID: 4c992efd-8c8c-5c4b-a872-2c462e72d253

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
