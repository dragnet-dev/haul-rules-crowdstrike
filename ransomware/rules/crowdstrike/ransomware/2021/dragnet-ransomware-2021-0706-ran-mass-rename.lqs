// Dragnet [Ransomware]: dragnet-ransomware-2021-0706 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: a4934604-d340-561c-ae82-e5790a78ac7f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
