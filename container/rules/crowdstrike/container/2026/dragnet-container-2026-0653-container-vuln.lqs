// Dragnet [Container]: dragnet-container-2026-0653 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: db4291fc-5755-54c0-9412-4012c495a1e2

#event_simpleName=*
| (ImageFileName = *alpine edge:* OR ImageFileName = *amazonlinux:2* OR ImageFileName = *amazonlinux:2023* OR ImageFileName = *chainguard:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *photon os:5.0* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
