// Dragnet [Ransomware]: dragnet-ransomware-2025-0609 — Mass File Rename (apos)
// Status: experimental | Level: high | ID: 104253f8-cca5-51c6-9728-9ddaa5eadeb2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
