// Dragnet [Ransomware]: dragnet-ransomware-2023-3651 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 04de758f-aaa1-5368-9b62-5910c89bfb16

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
