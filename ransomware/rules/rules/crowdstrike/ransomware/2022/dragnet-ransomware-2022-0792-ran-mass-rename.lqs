// Dragnet [Ransomware]: dragnet-ransomware-2022-0792 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 1346edce-2c12-5f64-89a5-775064ff8966

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
