// Dragnet [Ransomware]: dragnet-ransomware-2025-3280 — Mass File Rename (nitrogen)
// Status: experimental | Level: high | ID: 0287c6d1-0e12-5f7d-a378-65f99255d882

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
