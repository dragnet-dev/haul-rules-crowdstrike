// Dragnet [Ransomware]: dragnet-ransomware-2024-2140 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 64914a81-3a0a-553c-bc1e-908076978ab0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
