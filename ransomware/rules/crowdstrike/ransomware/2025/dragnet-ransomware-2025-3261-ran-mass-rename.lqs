// Dragnet [Ransomware]: dragnet-ransomware-2025-3261 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: da23913b-a330-5822-9e37-7e55954059da

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
