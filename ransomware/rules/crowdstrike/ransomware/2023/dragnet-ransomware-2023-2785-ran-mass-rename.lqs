// Dragnet [Ransomware]: dragnet-ransomware-2023-2785 — Mass File Rename (malas)
// Status: experimental | Level: high | ID: 2f6525de-e99d-59f2-ba20-acbf0f41187e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
