// Dragnet [Ransomware]: dragnet-ransomware-2021-1392 — Mass File Rename (payloadbin)
// Status: deprecated | Level: high | ID: 287ac12f-8fb5-5fd1-95c9-8d141ac31b15

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
