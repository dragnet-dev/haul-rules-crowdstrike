// Dragnet [Ransomware]: dragnet-ransomware-2022-0743 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: aa321123-81d7-5fb8-8b08-91df0dc79400

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
