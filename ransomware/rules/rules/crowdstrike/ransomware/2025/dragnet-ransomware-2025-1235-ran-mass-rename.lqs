// Dragnet [Ransomware]: dragnet-ransomware-2025-1235 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: 70a30284-f845-50a2-9468-56c4aac18509

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
