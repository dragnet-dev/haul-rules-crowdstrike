// Dragnet [Container]: dragnet-container-2024-0099 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: b1389e74-4de0-5099-9897-2d5ec07dc6ca

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:9* OR ImageFileName = *ubuntu:18.04* OR ImageFileName = *ubuntu:18.04-ESM* OR ImageFileName = *ubuntu:20.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
