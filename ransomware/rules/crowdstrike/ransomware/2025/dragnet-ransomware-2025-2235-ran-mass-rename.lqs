// Dragnet [Ransomware]: dragnet-ransomware-2025-2235 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: a78f570c-b301-546e-b1e3-55b225bc8f7d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
