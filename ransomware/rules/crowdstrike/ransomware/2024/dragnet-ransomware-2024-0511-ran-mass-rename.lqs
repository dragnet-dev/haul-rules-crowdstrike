// Dragnet [Ransomware]: dragnet-ransomware-2024-0511 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 60df1379-1311-5854-8f8f-1cffc8f1c92f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
