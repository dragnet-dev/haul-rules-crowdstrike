// Dragnet [Ransomware]: dragnet-ransomware-2025-1174 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: 556220a4-3b4f-5eba-b6fc-68a092bcea55

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
