// Dragnet [Ransomware]: dragnet-ransomware-2025-2725 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: 96617356-6d0b-5076-8373-0622bfeb0cfc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
