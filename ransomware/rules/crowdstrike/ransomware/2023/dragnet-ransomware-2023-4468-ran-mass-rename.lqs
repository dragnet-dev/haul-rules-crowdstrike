// Dragnet [Ransomware]: dragnet-ransomware-2023-4468 — Mass File Rename (royal)
// Status: experimental | Level: high | ID: ca6d75e0-ad68-53a0-a0cb-08b89b79a277

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
