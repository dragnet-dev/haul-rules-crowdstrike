// Dragnet [Container]: dragnet-container-2024-1344 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: e1b4af3c-12ec-55f3-b90c-0c501ddd1323

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:8* OR ImageFileName = *debian:9* OR ImageFileName = *ubuntu:18.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
