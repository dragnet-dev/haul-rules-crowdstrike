// Dragnet [Ransomware]: dragnet-ransomware-2025-0463 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: fd5b8d7d-cb0a-5b09-9c44-b702c160c57e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
