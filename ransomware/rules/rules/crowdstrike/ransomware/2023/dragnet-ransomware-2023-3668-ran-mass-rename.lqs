// Dragnet [Ransomware]: dragnet-ransomware-2023-3668 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 864121be-9d8d-574a-98ed-4eae8d5cd3b6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
