// Dragnet [Ransomware]: dragnet-ransomware-2023-2526 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 70a61330-6c37-591a-a193-5476e1a1d416

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
