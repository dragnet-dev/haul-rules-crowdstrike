// Dragnet [Ransomware]: dragnet-ransomware-2024-5759 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: 880269f9-7e95-5291-a5d8-c64958e8ed8b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
