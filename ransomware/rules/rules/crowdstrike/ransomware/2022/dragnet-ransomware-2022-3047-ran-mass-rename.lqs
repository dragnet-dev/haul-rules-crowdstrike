// Dragnet [Ransomware]: dragnet-ransomware-2022-3047 — Mass File Rename (ragnarlocker)
// Status: deprecated | Level: high | ID: 8ffb171f-7dff-5ef6-b34b-a4bd15559f15

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
