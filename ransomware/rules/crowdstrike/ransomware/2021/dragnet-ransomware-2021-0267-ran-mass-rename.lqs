// Dragnet [Ransomware]: dragnet-ransomware-2021-0267 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: bec6e342-ded3-56df-a02c-3086bdbc72b2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
