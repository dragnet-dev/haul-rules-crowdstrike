// Dragnet [Ransomware]: dragnet-ransomware-2024-4901 — Mass File Rename (meow)
// Status: experimental | Level: high | ID: 578c84ec-b736-543a-8d05-02e46337a74f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
