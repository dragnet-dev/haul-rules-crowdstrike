// Dragnet [Ransomware]: dragnet-ransomware-2024-0260 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 6200aa6d-7500-5f2a-b871-c2ae8d6227c7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
