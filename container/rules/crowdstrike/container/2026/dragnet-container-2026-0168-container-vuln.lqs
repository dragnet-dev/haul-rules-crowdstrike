// Dragnet [Container]: dragnet-container-2026-0168 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 08bd557d-c5b1-509d-81f2-cb08cf50cd82

#event_simpleName=*
| (ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10* OR ImageFileName = *ubuntu:13.04* OR ImageFileName = *ubuntu:13.10*)
| table([timestamp, ComputerName])
| limit(1000)
