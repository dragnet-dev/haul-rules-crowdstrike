// Dragnet [Ransomware]: dragnet-ransomware-2023-4426 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 128ba5e3-1f54-5e37-8df5-6c10edec2b9c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
