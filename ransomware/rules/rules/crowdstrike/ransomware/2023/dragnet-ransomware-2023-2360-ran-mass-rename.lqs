// Dragnet [Ransomware]: dragnet-ransomware-2023-2360 — Mass File Rename (monti)
// Status: experimental | Level: high | ID: da912af9-ed51-5ffa-91ed-4f9506be1488

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
