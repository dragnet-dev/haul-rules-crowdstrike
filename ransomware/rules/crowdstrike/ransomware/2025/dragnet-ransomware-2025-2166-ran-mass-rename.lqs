// Dragnet [Ransomware]: dragnet-ransomware-2025-2166 — Mass File Rename (radar)
// Status: experimental | Level: high | ID: f9fa5b1a-cf7e-5b47-96fe-9c1f3245710d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
