// Dragnet [Ransomware]: dragnet-ransomware-2023-4231 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 73868e41-a0b4-53bf-b772-5b0b419b8065

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
