// Dragnet [Ransomware]: dragnet-ransomware-2026-0806 — Mass File Rename (lockbit5)
// Status: stable | Level: high | ID: 74dde9aa-5f76-5192-9e3e-16a2f9cb3d2d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
