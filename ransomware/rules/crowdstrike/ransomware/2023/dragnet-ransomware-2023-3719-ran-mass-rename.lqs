// Dragnet [Ransomware]: dragnet-ransomware-2023-3719 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 07e6db92-73fe-539c-8b76-aaadb9b7ac90

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
