// Dragnet [Ransomware]: dragnet-ransomware-2025-5391 — Mass File Rename (sinobi)
// Status: experimental | Level: high | ID: b05d8a28-d9a9-5f0b-9ace-c1ade2c78f60

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
