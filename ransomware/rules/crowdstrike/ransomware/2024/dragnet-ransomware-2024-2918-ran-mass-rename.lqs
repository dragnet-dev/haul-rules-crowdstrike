// Dragnet [Ransomware]: dragnet-ransomware-2024-2918 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 3ad228b8-0be3-529e-b340-20f35e4c26b0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
