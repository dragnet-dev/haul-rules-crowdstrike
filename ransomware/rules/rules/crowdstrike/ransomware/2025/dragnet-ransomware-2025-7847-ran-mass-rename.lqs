// Dragnet [Ransomware]: dragnet-ransomware-2025-7847 — Mass File Rename (spacebears)
// Status: experimental | Level: high | ID: 8f21b561-cece-5613-b9d8-8f9e83f7a1dd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
