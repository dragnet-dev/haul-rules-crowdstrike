// Dragnet [Ransomware]: dragnet-ransomware-2024-0407 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: c06cc8e1-bfb8-5dc5-b2a7-23ba2dacb7d4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
