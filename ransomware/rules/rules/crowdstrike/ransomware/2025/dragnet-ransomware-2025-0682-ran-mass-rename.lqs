// Dragnet [Ransomware]: dragnet-ransomware-2025-0682 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: fd3367a3-8dcf-5602-a341-2b932c08a9ed

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
