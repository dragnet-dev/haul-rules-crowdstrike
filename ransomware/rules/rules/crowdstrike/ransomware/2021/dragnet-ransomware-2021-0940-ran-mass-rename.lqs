// Dragnet [Ransomware]: dragnet-ransomware-2021-0940 — Mass File Rename (ransomexx)
// Status: experimental | Level: high | ID: c43f0c65-4cd3-5635-91a6-bc9a7c369a68

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
