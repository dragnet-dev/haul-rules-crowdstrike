// Dragnet [Ransomware]: dragnet-ransomware-2025-5242 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: b8db6fba-2af9-5514-a384-8cc8f9e3792c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
