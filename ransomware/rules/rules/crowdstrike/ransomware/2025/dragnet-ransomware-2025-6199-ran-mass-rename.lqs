// Dragnet [Ransomware]: dragnet-ransomware-2025-6199 — Mass File Rename (interlock)
// Status: experimental | Level: high | ID: f9b01ba5-89d9-540b-a48f-ea15c622be1b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
