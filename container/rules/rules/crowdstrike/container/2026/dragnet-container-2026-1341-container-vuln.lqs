// Dragnet [Container]: dragnet-container-2026-1341 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: e2393700-396f-52d1-9b0e-dc1f3d6a90aa

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:7* OR ImageFileName = *debian:8* OR ImageFileName = *debian:9* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:14.04* OR ImageFileName = *ubuntu:16.04* OR ImageFileName = *ubuntu:16.04-ESM* OR ImageFileName = *ubuntu:17.04* OR ImageFileName = *ubuntu:17.10*)
| table([timestamp, ComputerName])
| limit(1000)
