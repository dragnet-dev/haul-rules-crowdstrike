// Dragnet [Ransomware]: dragnet-ransomware-2025-0606 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 3da5f518-7a21-53b7-830f-31632763eb8e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
