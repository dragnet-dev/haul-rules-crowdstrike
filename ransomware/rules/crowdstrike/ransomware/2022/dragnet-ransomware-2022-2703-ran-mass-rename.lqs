// Dragnet [Ransomware]: dragnet-ransomware-2022-2703 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 902c0151-cffe-5219-9a3f-b4debb441f33

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
