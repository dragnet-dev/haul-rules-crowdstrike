// Dragnet [Ransomware]: dragnet-ransomware-2022-2057 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: f367e97f-02e6-5c64-af84-5496950837f4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
