// Dragnet [Container]: dragnet-container-2026-0202 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 231bf1d1-4f95-5f43-a76c-b36d998ce98f

#event_simpleName=*
| (ImageFileName = *chainguard:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
