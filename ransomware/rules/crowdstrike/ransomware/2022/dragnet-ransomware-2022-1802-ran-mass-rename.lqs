// Dragnet [Ransomware]: dragnet-ransomware-2022-1802 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: d6cc3af9-af7e-5ac5-80f5-6186f94e36e5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
