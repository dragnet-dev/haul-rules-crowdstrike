// Dragnet [Ransomware]: dragnet-ransomware-2024-0909 — Mass File Rename (meow)
// Status: experimental | Level: high | ID: b322a51c-4d3a-5eb9-887c-560c5f65a697

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
