// Dragnet [Ransomware]: dragnet-ransomware-2022-1546 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 53455d9a-47a4-57c3-869e-2a697d20d67b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
