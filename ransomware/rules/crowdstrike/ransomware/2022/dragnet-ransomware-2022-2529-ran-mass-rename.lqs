// Dragnet [Ransomware]: dragnet-ransomware-2022-2529 — Mass File Rename (avoslocker)
// Status: deprecated | Level: high | ID: 0864430a-3cd3-5f12-9f6e-1cf4fcd1f5cf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
