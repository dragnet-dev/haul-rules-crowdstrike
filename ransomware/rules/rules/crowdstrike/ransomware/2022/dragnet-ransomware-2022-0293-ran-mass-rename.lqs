// Dragnet [Ransomware]: dragnet-ransomware-2022-0293 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 4b34ea29-ae49-5213-b2d3-b34a07d0a71b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
