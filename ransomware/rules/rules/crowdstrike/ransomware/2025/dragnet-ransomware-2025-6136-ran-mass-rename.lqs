// Dragnet [Ransomware]: dragnet-ransomware-2025-6136 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 9f42b54c-07a1-5abf-b093-0096154b7f09

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
