// Dragnet [Ransomware]: dragnet-ransomware-2025-7762 — Mass File Rename (minteye)
// Status: deprecated | Level: high | ID: 16443a25-19cb-5c89-90a0-92d776f44931

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
