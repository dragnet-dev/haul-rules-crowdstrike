// Dragnet [Ransomware]: dragnet-ransomware-2024-3632 — Mass File Rename (blacklock)
// Status: experimental | Level: high | ID: c36ed4fe-348c-5563-9430-c5a281e93023

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
