// Dragnet [Ransomware]: dragnet-ransomware-2020-0258 — Mass File Rename (ragnarlocker)
// Status: deprecated | Level: high | ID: 3e03f6f2-822e-5b8e-b9c1-ed49b67537f3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
