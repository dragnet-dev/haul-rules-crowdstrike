// Dragnet [Ransomware]: dragnet-ransomware-2025-4001 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 721a25cf-3599-5160-a456-9178700921ea

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
