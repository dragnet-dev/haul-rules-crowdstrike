// Dragnet [Ransomware]: dragnet-ransomware-2025-5105 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: b73914ae-0225-5426-9785-0087cc1b02d0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
