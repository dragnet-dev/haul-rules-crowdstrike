// Dragnet [Ransomware]: dragnet-ransomware-2023-2562 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 0bc92d6d-f697-5975-950c-9cb0c00790d2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
