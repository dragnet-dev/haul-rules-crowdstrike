// Dragnet [Ransomware]: dragnet-ransomware-2024-0147 — Mass File Rename (dAn0n)
// Status: experimental | Level: high | ID: 5debc3a2-0e22-5064-bbbe-b310bdd439d1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
