// Dragnet [Ransomware]: dragnet-ransomware-2023-1371 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 9580a8a5-dd4c-535f-bd25-4954a562d9b8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
