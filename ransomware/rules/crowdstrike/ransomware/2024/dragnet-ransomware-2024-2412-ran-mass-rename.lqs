// Dragnet [Ransomware]: dragnet-ransomware-2024-2412 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 26738bff-9779-51f7-b579-55cf1630cca5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
