// Dragnet [Ransomware]: dragnet-ransomware-2025-3502 — Mass File Rename (gunra)
// Status: experimental | Level: high | ID: fb3b4870-6c95-59af-b94d-88469426e0fb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
