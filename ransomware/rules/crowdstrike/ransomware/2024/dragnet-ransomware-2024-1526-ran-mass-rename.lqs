// Dragnet [Ransomware]: dragnet-ransomware-2024-1526 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 8e63372a-0cc3-559d-be40-7a0b6af14edf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
