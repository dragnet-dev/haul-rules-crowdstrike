// Dragnet [Ransomware]: dragnet-ransomware-2021-1348 — Mass File Rename (ragnarlocker)
// Status: deprecated | Level: high | ID: 3277a036-af5f-52b9-b6da-cdcabb1ab671

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
