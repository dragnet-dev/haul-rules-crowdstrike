// Dragnet [Ransomware]: dragnet-ransomware-2022-1556 — Mass File Rename (daixin)
// Status: deprecated | Level: high | ID: 5afde562-a058-561e-bd2a-e4a4fb704473

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
