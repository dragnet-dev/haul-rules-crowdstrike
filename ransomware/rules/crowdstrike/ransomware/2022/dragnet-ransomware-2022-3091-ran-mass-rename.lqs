// Dragnet [Ransomware]: dragnet-ransomware-2022-3091 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: c451e6b0-e11b-5c38-901b-339942a6c357

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
