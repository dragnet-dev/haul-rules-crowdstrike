// Dragnet [Ransomware]: dragnet-ransomware-2023-0856 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 87f3bbe4-cfb7-56a9-a4d4-c5bc41aed432

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
