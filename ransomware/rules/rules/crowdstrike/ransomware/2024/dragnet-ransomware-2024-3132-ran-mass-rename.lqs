// Dragnet [Ransomware]: dragnet-ransomware-2024-3132 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: 31a2793f-b1fd-5536-9579-1c65389a8f47

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
