// Dragnet [Ransomware]: dragnet-ransomware-2024-0052 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 7b762f2c-f2c1-5edc-a444-7e36f819cedf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
