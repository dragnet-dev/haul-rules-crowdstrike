// Dragnet [Ransomware]: dragnet-ransomware-2024-4305 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: bfb979ea-cf72-5e2e-98bc-21ee58f524f0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
