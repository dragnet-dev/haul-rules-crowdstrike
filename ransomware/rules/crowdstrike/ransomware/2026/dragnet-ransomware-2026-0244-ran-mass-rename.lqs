// Dragnet [Ransomware]: dragnet-ransomware-2026-0244 — Mass File Rename (spacebears)
// Status: test | Level: high | ID: 7d6de68d-b86a-5ac5-9efa-2db2801ab998

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
