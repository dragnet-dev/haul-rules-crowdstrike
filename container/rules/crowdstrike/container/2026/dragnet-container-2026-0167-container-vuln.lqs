// Dragnet [Container]: dragnet-container-2026-0167 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: d85a1600-d1e2-5fa1-a368-2e173c473187

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:5*)
| table([timestamp, ComputerName])
| limit(1000)
