// Dragnet [Ransomware]: dragnet-ransomware-2023-2945 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 390e34cb-ae3f-5c0c-8b8e-e5692883363a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
