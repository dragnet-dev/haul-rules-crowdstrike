// Dragnet [Ransomware]: dragnet-ransomware-2025-1216 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: 9ab59011-48ec-5e64-b6ab-7f14f0e7b924

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
