// Dragnet [Ransomware]: dragnet-ransomware-2025-2356 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 65e88a80-31c6-536d-8360-6008cf3a3f86

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
