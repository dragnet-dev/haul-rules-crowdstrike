// Dragnet [Container]: dragnet-container-2026-1230 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 00700ce3-5c17-569d-a481-5f5969be661e

#event_simpleName=*
| (ImageFileName = *alpine:3.4* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:8* OR ImageFileName = *ubuntu:14.04* OR ImageFileName = *ubuntu:14.04-ESM* OR ImageFileName = *ubuntu:16.04* OR ImageFileName = *ubuntu:16.04-ESM* OR ImageFileName = *ubuntu:16.10*)
| table([timestamp, ComputerName])
| limit(1000)
