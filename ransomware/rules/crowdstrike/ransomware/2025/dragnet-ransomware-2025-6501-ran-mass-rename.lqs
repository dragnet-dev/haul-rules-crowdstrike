// Dragnet [Ransomware]: dragnet-ransomware-2025-6501 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 2efb3d57-6f70-5c26-a19a-160b244704dc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
