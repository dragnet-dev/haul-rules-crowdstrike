// Dragnet [Ransomware]: dragnet-ransomware-2026-0848 — Mass File Rename (incransom)
// Status: stable | Level: high | ID: 0de15fa7-add4-5bf7-aaf6-cf64aa78b810

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
