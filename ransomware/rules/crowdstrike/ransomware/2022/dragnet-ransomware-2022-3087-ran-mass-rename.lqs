// Dragnet [Ransomware]: dragnet-ransomware-2022-3087 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 464334a1-1ec8-525d-bfd3-ec51d5c24879

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
