// Dragnet [Ransomware]: dragnet-ransomware-2023-3431 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: bd8fd2e6-273f-565e-94fd-7983e815f706

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
