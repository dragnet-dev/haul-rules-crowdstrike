// Dragnet [Ransomware]: dragnet-ransomware-2023-0252 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 48f72146-d9bb-5964-8a54-840ecbf71dc4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
