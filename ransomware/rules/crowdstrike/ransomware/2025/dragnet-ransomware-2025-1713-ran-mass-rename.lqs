// Dragnet [Ransomware]: dragnet-ransomware-2025-1713 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 1a5e0149-4277-58dc-a819-5cbfd8de24df

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
