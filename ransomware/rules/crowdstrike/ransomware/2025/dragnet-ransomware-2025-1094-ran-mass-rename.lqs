// Dragnet [Ransomware]: dragnet-ransomware-2025-1094 — Mass File Rename (cicada3301)
// Status: experimental | Level: high | ID: 307ab900-7bfa-55b9-b3c4-1a7798d9d91c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
