// Dragnet [Ransomware]: dragnet-ransomware-2025-0207 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: c4da3595-1ef4-5562-88d1-4b6559c56c71

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
