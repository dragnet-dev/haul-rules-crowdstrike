// Dragnet [Ransomware]: dragnet-ransomware-2023-3750 — Mass File Rename (rhysida)
// Status: deprecated | Level: high | ID: 4ed36aa4-96b9-5c96-a0f5-c9355ecea11b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
