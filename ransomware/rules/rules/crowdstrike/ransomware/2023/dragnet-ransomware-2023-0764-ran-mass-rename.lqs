// Dragnet [Ransomware]: dragnet-ransomware-2023-0764 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: c998b99c-1708-5056-b1fe-a03cefb95bb5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
