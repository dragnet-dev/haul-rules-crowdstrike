// Dragnet [Container]: dragnet-container-2026-2020 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 97ac51cd-5f86-55df-839d-d0cc43821aa1

#event_simpleName=*
| (ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10* OR ImageFileName = *ubuntu:13.04* OR ImageFileName = *ubuntu:13.10*)
| table([timestamp, ComputerName])
| limit(1000)
