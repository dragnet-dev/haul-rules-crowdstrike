// Dragnet [Ransomware]: dragnet-ransomware-2025-3926 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: bc2b71de-cd89-5d04-b558-99b70467c385

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
