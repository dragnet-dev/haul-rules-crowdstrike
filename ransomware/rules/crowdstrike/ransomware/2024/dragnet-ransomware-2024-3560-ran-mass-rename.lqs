// Dragnet [Ransomware]: dragnet-ransomware-2024-3560 — Mass File Rename (meow)
// Status: experimental | Level: high | ID: f748185b-4376-5eb6-884a-0b548d59af04

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
