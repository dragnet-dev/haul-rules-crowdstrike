// Dragnet [Ransomware]: dragnet-ransomware-2026-3484 — Mass File Rename (blackwater)
// Status: stable | Level: high | ID: da24c788-6de8-5361-963d-f5ecf2994503

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
