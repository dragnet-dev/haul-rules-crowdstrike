// Dragnet [Ransomware]: dragnet-ransomware-2026-1119 — Mass File Rename (thegentlemen)
// Status: test | Level: high | ID: fa75eef4-489a-5fab-bd56-f5a64cdb2f2c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
