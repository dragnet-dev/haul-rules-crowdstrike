// Dragnet [Container]: dragnet-container-2026-2049 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 3c9e063e-29a2-556b-b466-257930306a2b

#event_simpleName=*
| (ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *oraclelinux:7*)
| table([timestamp, ComputerName])
| limit(1000)
