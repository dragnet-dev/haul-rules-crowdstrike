// Dragnet [Container]: dragnet-container-2026-0549 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 2346df5a-bf85-510f-9be1-b7af4ead9828

#event_simpleName=*
| (ImageFileName = *chainguard:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
