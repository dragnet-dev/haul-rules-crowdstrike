// Dragnet [Ransomware]: dragnet-ransomware-2022-2804 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: f436277a-ed9d-5332-9e0d-025087bf01a9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
