// Dragnet [Ransomware]: dragnet-ransomware-2023-1234 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 15a4d448-e57a-542f-9a5d-fea23ef78bb7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
