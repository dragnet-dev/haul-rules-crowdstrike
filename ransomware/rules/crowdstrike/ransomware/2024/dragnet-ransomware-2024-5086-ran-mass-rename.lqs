// Dragnet [Ransomware]: dragnet-ransomware-2024-5086 — Mass File Rename (threeam)
// Status: experimental | Level: high | ID: 7516af9a-8409-5a40-8630-5afcd5a82fbd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
