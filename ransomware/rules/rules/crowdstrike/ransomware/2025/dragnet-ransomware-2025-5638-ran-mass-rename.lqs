// Dragnet [Ransomware]: dragnet-ransomware-2025-5638 — Mass File Rename (kairos)
// Status: experimental | Level: high | ID: a9117bbb-23b8-5e0f-91ec-47de1e54a352

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
