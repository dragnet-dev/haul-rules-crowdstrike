// Dragnet [Ransomware]: dragnet-ransomware-2026-1355 — Mass File Rename (nightspire)
// Status: deprecated | Level: high | ID: a217b6e2-7f88-5e75-860d-cddb08dff02a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
