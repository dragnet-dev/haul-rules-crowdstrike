// Dragnet [Ransomware]: dragnet-ransomware-2025-2819 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: 73624688-a5d2-54f4-a8ae-f31d1f603a22

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
