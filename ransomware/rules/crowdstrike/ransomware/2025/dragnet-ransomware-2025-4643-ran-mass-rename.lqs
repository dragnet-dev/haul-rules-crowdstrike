// Dragnet [Ransomware]: dragnet-ransomware-2025-4643 — Mass File Rename (global)
// Status: experimental | Level: high | ID: 2c36afa5-c02c-5964-92d3-429a8bd44243

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
