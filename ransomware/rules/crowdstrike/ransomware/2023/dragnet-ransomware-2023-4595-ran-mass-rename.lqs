// Dragnet [Ransomware]: dragnet-ransomware-2023-4595 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: 9e1723c7-9f3f-5171-8b9d-65d099e377d2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
