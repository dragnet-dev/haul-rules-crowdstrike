// Dragnet [Ransomware]: dragnet-ransomware-2023-3960 — Mass File Rename (royal)
// Status: experimental | Level: high | ID: 3c005c8e-b00d-50ef-acae-32a85fbe0182

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
