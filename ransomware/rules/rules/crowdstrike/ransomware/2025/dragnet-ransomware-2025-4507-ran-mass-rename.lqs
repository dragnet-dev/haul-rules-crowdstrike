// Dragnet [Ransomware]: dragnet-ransomware-2025-4507 — Mass File Rename (sinobi)
// Status: experimental | Level: high | ID: d9a4b494-9cbd-5648-bf00-8ac28094e4df

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
