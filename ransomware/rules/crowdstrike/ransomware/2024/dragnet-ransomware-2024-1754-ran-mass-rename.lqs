// Dragnet [Ransomware]: dragnet-ransomware-2024-1754 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 64514111-fdb8-5193-b492-0380c9b7e8f5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
