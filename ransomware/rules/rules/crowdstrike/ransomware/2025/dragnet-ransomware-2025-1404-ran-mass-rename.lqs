// Dragnet [Ransomware]: dragnet-ransomware-2025-1404 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 24b3d73b-c264-543e-a0c1-e29ce0ad71a8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
