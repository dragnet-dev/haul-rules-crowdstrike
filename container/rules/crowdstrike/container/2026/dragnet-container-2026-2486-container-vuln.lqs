// Dragnet [Container]: dragnet-container-2026-2486 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 2cfc5d78-dab1-51a8-873c-a28869401231

#event_simpleName=*
| (ImageFileName = *chainguard:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
