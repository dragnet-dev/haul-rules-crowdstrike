// Dragnet [Ransomware]: dragnet-ransomware-2025-7253 — Mass File Rename (J)
// Status: experimental | Level: high | ID: 62506940-23c8-5fa2-9844-1ea67c3fb259

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
