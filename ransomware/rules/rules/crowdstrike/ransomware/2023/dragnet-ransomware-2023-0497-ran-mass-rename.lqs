// Dragnet [Ransomware]: dragnet-ransomware-2023-0497 — Mass File Rename (metaencryptor)
// Status: experimental | Level: high | ID: 354dea10-644b-5248-8b1b-bd57558bf81f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
