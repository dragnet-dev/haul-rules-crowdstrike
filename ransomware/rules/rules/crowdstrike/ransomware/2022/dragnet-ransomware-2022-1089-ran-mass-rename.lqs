// Dragnet [Ransomware]: dragnet-ransomware-2022-1089 — Mass File Rename (payloadbin)
// Status: deprecated | Level: high | ID: 8fe65ece-4d75-51ad-8062-74221f159a5d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
