// Dragnet [Ransomware]: dragnet-ransomware-2024-4755 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 4d172db6-df4f-5d16-bded-cd00f80a203b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
