// Dragnet [Container]: dragnet-container-2024-0945 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 412492a8-daee-58e6-accb-11ce2c037ac4

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
