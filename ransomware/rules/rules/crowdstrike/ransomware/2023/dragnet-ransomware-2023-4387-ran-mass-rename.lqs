// Dragnet [Ransomware]: dragnet-ransomware-2023-4387 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: e05d2bcd-afde-5a48-b17d-9728c85f478a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
