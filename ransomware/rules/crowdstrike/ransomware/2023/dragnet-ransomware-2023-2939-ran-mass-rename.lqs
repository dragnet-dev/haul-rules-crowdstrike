// Dragnet [Ransomware]: dragnet-ransomware-2023-2939 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: bdd80553-7fa6-5da2-89ba-4a237726d518

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
