// Dragnet [Ransomware]: dragnet-ransomware-2026-3356 — Mass File Rename (fulcrumsec)
// Status: stable | Level: high | ID: 07f0a3ab-e241-52b1-8779-5e03b475eb8f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
