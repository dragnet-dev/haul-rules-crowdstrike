// Dragnet [Ransomware]: dragnet-ransomware-2024-0373 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: 53bc01d0-4a53-56a8-a5a5-82a1112d983a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
