// Dragnet [Ransomware]: dragnet-ransomware-2021-0693 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 8e14db87-ebe1-5219-ab52-6666ee07cece

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
