// Dragnet [Ransomware]: dragnet-ransomware-2025-7080 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 5f7337a6-4121-5f86-a79d-b3fb3589769b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
