// Dragnet [Ransomware]: dragnet-ransomware-2024-4144 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 150c9ce7-802d-55f4-b28d-04c48ee97e5a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
