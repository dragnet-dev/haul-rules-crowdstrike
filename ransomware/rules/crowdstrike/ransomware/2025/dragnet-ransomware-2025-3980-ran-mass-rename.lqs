// Dragnet [Ransomware]: dragnet-ransomware-2025-3980 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 688ee1f1-03f8-561e-b38e-717230ad1969

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
