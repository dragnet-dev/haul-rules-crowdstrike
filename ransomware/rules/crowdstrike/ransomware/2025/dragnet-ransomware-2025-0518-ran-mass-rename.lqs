// Dragnet [Ransomware]: dragnet-ransomware-2025-0518 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 7c412730-2d9e-59b8-bb4d-1d75923fee4d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
