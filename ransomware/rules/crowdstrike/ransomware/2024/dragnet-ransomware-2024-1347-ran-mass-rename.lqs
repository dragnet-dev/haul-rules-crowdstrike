// Dragnet [Ransomware]: dragnet-ransomware-2024-1347 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 035ae7d7-c83c-54c2-9cd4-4488e61b7d3a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
