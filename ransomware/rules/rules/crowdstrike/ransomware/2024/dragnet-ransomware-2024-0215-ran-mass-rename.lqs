// Dragnet [Ransomware]: dragnet-ransomware-2024-0215 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: a1149a58-126a-5661-bd9f-c32f4d4be267

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
