// Dragnet [Ransomware]: dragnet-ransomware-2023-2967 — Mass File Rename (royal)
// Status: experimental | Level: high | ID: 23365e79-67e1-5977-beeb-dc953760a6f7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
