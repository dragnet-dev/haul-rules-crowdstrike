// Dragnet [Ransomware]: dragnet-ransomware-2023-2070 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 6262fde4-99f5-59cc-814c-5908b57fc98f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
