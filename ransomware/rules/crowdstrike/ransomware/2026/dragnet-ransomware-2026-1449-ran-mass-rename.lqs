// Dragnet [Ransomware]: dragnet-ransomware-2026-1449 — Mass File Rename (spacebears)
// Status: test | Level: high | ID: 5d757a4e-11c7-5c1a-bc6f-d866dfb1e8bc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
