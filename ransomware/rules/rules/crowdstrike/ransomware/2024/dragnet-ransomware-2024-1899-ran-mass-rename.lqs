// Dragnet [Ransomware]: dragnet-ransomware-2024-1899 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: d3d844d0-50ae-5e2c-bb4b-9323451d43b8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
