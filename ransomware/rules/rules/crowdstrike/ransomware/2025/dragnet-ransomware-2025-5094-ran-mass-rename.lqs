// Dragnet [Ransomware]: dragnet-ransomware-2025-5094 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: b5f043b6-77ca-5d67-a959-4383fc2e33a3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
