// Dragnet [Ransomware]: dragnet-ransomware-2023-1563 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 97c26dba-509c-52d4-bf87-c0d56a80adb1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
