// Dragnet [Ransomware]: dragnet-ransomware-2022-2971 — Mass File Rename (cuba)
// Status: deprecated | Level: high | ID: 96ad0657-38fc-5012-8e4a-7e3d245c57d8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
