// Dragnet [Ransomware]: dragnet-ransomware-2024-2798 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 7657211f-8f5c-5b29-9be4-315d97e84fd5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
