// Dragnet [Ransomware]: dragnet-ransomware-2022-2405 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: d53bfe27-669b-576c-bc80-c1bf37950e35

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
