// Dragnet [Ransomware]: dragnet-ransomware-2025-7681 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 2db22ccf-577c-52a7-a426-32d3b15cc450

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
