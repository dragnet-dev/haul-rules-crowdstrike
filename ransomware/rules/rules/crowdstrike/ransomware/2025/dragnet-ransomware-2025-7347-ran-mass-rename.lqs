// Dragnet [Ransomware]: dragnet-ransomware-2025-7347 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 68d2ec2d-53da-5b2e-aae1-a928a28dd689

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
