// Dragnet [Ransomware]: dragnet-ransomware-2026-0300 — Mass File Rename (lockbit5)
// Status: test | Level: high | ID: e41cb922-b041-5048-b56a-c8787144493e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
