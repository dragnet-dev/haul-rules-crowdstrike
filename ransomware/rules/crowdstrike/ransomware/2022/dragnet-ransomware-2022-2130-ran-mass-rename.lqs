// Dragnet [Ransomware]: dragnet-ransomware-2022-2130 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: e433337c-664d-5bad-9b5e-58331f112f6e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
