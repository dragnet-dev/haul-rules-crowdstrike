// Dragnet [Ransomware]: dragnet-ransomware-2025-4116 — Mass File Rename (shinyhunters)
// Status: experimental | Level: high | ID: ef219d96-a253-5950-a788-587144d9b1b5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
