// Dragnet [Ransomware]: dragnet-ransomware-2022-0237 — Mass File Rename (cuba)
// Status: deprecated | Level: high | ID: 0e214940-707e-5cd9-a566-cabb7657f905

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
