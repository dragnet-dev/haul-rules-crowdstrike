// Dragnet [Ransomware]: dragnet-ransomware-2025-1452 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 3b243993-96f2-5192-9955-8ece540a739a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
