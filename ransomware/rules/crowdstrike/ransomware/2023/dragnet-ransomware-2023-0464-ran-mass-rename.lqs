// Dragnet [Ransomware]: dragnet-ransomware-2023-0464 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 224505d4-8ae3-5358-9d81-a5d63dcfb801

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
