// Dragnet [Ransomware]: dragnet-ransomware-2025-1319 — Mass File Rename (datacarry)
// Status: deprecated | Level: high | ID: c97c7506-308b-5282-80c8-dc64e2979dd3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
