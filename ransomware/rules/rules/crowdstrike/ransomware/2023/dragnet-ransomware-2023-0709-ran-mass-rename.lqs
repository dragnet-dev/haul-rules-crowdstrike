// Dragnet [Ransomware]: dragnet-ransomware-2023-0709 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 21a5dc36-3f84-5730-99da-b54edfff2a83

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
