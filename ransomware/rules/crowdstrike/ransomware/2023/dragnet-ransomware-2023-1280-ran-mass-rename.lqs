// Dragnet [Ransomware]: dragnet-ransomware-2023-1280 — Mass File Rename (donutleaks)
// Status: experimental | Level: high | ID: b073288b-ec28-5d8a-84eb-09d058d64726

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
