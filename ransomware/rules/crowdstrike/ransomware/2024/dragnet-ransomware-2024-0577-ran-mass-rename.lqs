// Dragnet [Ransomware]: dragnet-ransomware-2024-0577 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: c7426e1e-de6f-59ce-8a1f-c3bb02ee323a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
