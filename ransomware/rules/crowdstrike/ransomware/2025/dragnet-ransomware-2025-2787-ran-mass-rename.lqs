// Dragnet [Ransomware]: dragnet-ransomware-2025-2787 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: 0e338bd4-6fb6-579a-baf8-14231d014284

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
