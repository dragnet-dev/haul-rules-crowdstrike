// Dragnet [Ransomware]: dragnet-ransomware-2024-1149 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 15f2d609-c6c7-5866-adf7-3883a2c7792e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
