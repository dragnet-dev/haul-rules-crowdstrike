// Dragnet [Ransomware]: dragnet-ransomware-2022-1666 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: e928ae30-4551-57a4-9c38-15fef8c0c5b0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
