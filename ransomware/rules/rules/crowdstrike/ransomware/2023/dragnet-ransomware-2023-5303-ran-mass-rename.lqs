// Dragnet [Ransomware]: dragnet-ransomware-2023-5303 — Mass File Rename (malekteam)
// Status: experimental | Level: high | ID: 0a340d95-f7a6-5fa8-b50c-f876535a1634

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
