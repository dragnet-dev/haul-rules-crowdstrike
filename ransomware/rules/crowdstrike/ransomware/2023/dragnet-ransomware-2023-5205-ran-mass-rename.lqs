// Dragnet [Ransomware]: dragnet-ransomware-2023-5205 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 3890090b-c4a0-5433-949e-725b833dda27

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
