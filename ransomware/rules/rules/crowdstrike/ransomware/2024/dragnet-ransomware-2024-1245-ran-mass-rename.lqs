// Dragnet [Ransomware]: dragnet-ransomware-2024-1245 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: c69a0e2f-0a0b-53d8-8482-430050ca909c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
