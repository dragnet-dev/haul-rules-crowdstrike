// Dragnet [Ransomware]: dragnet-ransomware-2021-1684 — Mass File Rename (blackmatter)
// Status: deprecated | Level: high | ID: 81ca5573-7ebf-56bf-9378-fadccb3ebc77

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
