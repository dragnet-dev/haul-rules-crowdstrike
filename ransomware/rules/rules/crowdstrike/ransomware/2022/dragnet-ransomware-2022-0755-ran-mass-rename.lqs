// Dragnet [Ransomware]: dragnet-ransomware-2022-0755 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: e239936d-d6a7-5646-8303-e9427db43a49

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
