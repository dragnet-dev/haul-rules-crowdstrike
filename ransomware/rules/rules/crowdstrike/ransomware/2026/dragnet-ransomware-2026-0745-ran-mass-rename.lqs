// Dragnet [Ransomware]: dragnet-ransomware-2026-0745 — Mass File Rename (lockbit5)
// Status: stable | Level: high | ID: dfaafaf7-a0f1-5f2a-9642-f95a4c5233df

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
