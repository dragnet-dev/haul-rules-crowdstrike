// Dragnet [Ransomware]: dragnet-ransomware-2023-0987 — Mass File Rename (trigona)
// Status: experimental | Level: high | ID: b1c7ff60-8b99-5571-913a-52251835900c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
