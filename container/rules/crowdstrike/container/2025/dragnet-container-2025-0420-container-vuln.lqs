// Dragnet [Container]: dragnet-container-2025-0420 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: ed632592-e72a-5d27-b005-a3250774b179

#event_simpleName=*
| (ImageFileName = *almalinux:9* OR ImageFileName = *alpine:3.19* OR ImageFileName = *alpine:3.20* OR ImageFileName = *alpine:3.21* OR ImageFileName = *alpine:3.22* OR ImageFileName = *alpine:3.23* OR ImageFileName = *alpine edge:* OR ImageFileName = *amazonlinux:2023* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:9* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:24.04*)
| table([timestamp, ComputerName])
| limit(1000)
