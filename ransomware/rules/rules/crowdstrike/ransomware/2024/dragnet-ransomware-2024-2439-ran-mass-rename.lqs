// Dragnet [Ransomware]: dragnet-ransomware-2024-2439 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 2e787fa3-7fda-592c-911e-7892f5eb17e6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
