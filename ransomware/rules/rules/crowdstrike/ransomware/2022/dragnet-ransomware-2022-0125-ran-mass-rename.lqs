// Dragnet [Ransomware]: dragnet-ransomware-2022-0125 — Mass File Rename (cuba)
// Status: deprecated | Level: high | ID: 8fd27141-7a85-5e3a-94d6-423e05fb1a48

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
