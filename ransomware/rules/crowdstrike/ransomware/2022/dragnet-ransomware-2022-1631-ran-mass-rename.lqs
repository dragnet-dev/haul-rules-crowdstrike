// Dragnet [Ransomware]: dragnet-ransomware-2022-1631 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 0bdbf37d-3009-5cc3-a277-512930dceb59

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
