// Dragnet [Ransomware]: dragnet-ransomware-2026-3213 — Mass File Rename (sinobi)
// Status: stable | Level: high | ID: 6c5b6f1e-108e-5ac9-87ec-6634da042dc7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
