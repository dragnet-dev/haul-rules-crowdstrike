// Dragnet [Ransomware]: dragnet-ransomware-2025-0459 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: ddbbf4ff-9f0b-5fc7-a32e-5aca6fb53ff0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
