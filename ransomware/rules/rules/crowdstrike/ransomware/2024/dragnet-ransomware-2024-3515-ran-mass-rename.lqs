// Dragnet [Ransomware]: dragnet-ransomware-2024-3515 — Mass File Rename (flocker)
// Status: experimental | Level: high | ID: 9d46972e-7e1e-5659-86cb-883a213ed725

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
