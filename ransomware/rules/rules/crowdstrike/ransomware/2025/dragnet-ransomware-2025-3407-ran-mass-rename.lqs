// Dragnet [Ransomware]: dragnet-ransomware-2025-3407 — Mass File Rename (dragonforce)
// Status: test | Level: high | ID: bbf88e9e-107f-572d-b8e6-7a1c0d037621

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
