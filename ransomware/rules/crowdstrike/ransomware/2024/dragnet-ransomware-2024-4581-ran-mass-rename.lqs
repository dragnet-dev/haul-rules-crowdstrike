// Dragnet [Ransomware]: dragnet-ransomware-2024-4581 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 184532c5-ac52-5348-b622-15ca256180d6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
