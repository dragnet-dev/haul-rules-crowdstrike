// Dragnet [Ransomware]: dragnet-ransomware-2022-0199 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: ddf9d101-0ee7-5feb-8d6f-3764efcf2b1d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
