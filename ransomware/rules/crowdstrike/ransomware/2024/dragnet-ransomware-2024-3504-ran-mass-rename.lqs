// Dragnet [Ransomware]: dragnet-ransomware-2024-3504 — Mass File Rename (trinity)
// Status: experimental | Level: high | ID: 5b43bd18-0ab7-5521-8bd1-7b2b032eb032

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
