// Dragnet [Ransomware]: dragnet-ransomware-2025-6975 — Mass File Rename (securotrop)
// Status: experimental | Level: high | ID: 690fdfa1-6622-5315-954f-fd8606d02145

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
