// Dragnet [Ransomware]: dragnet-ransomware-2024-0845 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 49976023-e5d5-5abe-9207-c5ca29275e54

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
