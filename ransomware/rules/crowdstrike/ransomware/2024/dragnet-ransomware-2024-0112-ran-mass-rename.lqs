// Dragnet [Ransomware]: dragnet-ransomware-2024-0112 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: bf767615-5e24-5cfd-a8ae-0871e58da73d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
