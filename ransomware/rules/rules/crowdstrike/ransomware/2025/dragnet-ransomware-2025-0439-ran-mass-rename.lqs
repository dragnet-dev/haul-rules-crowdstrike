// Dragnet [Ransomware]: dragnet-ransomware-2025-0439 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: e92a4bee-fe38-543f-a691-ee6ed080a8ff

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
