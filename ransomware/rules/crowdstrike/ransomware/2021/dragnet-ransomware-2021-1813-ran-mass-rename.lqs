// Dragnet [Ransomware]: dragnet-ransomware-2021-1813 — Mass File Rename (xinglocker)
// Status: deprecated | Level: high | ID: 49b2de48-56b0-5d93-a086-72ecd75d4b37

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
