// Dragnet [Ransomware]: dragnet-ransomware-2025-3314 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 31459b18-b33d-5cb4-8776-65d97760f13d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
