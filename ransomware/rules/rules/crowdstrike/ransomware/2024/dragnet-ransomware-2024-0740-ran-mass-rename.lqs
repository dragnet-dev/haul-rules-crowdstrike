// Dragnet [Ransomware]: dragnet-ransomware-2024-0740 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 197423ee-87ec-5640-a9dd-5b8de610ce5b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
