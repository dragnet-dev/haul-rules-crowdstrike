// Dragnet [Ransomware]: dragnet-ransomware-2025-0853 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 7cb0990c-1615-5d07-9095-fe4e0b7af7f1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
