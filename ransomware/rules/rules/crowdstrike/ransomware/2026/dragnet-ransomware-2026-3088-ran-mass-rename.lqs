// Dragnet [Ransomware]: dragnet-ransomware-2026-3088 — Mass File Rename (dragonforce)
// Status: test | Level: high | ID: f3779270-9112-59c6-95e5-0492d7a5ae72

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
