// Dragnet [Ransomware]: dragnet-ransomware-2021-1538 — Mass File Rename (lorenz)
// Status: deprecated | Level: high | ID: 31bebac6-72e1-5c40-86c2-b2d15f6f7857

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
