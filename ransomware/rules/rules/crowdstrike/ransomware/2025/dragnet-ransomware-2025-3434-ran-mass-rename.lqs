// Dragnet [Ransomware]: dragnet-ransomware-2025-3434 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: a4ab70cc-20a1-5b51-b801-f7559b67b4d4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
