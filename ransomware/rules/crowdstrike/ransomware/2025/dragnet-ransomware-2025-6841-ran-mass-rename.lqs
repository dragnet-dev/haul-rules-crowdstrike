// Dragnet [Ransomware]: dragnet-ransomware-2025-6841 — Mass File Rename (arcusmedia)
// Status: experimental | Level: high | ID: d0a88563-5110-53fe-ac24-43a0c44e2138

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
