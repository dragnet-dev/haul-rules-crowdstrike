// Dragnet [Ransomware]: dragnet-ransomware-2026-0891 — Mass File Rename (incransom)
// Status: stable | Level: high | ID: 40d7735b-e144-53a5-aaf4-a5b4a117c615

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
