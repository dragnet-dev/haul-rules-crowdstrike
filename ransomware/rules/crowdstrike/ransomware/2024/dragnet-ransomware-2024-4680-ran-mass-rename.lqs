// Dragnet [Ransomware]: dragnet-ransomware-2024-4680 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 3395b6f0-8f97-5a40-a950-48af924487dd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
