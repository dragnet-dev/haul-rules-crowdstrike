// Dragnet [Container]: dragnet-container-2024-0668 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 7cd124d6-9a80-55c1-90bf-8e219a90f73d

#event_simpleName=*
| (ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *ubuntu:22.04* OR ImageFileName = *ubuntu:24.04*)
| table([timestamp, ComputerName])
| limit(1000)
