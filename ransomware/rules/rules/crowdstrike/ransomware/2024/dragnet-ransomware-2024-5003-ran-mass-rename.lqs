// Dragnet [Ransomware]: dragnet-ransomware-2024-5003 — Mass File Rename (rhysida)
// Status: deprecated | Level: high | ID: 238f02e2-3cb9-5e75-b5f2-9bb02d2fabf0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
