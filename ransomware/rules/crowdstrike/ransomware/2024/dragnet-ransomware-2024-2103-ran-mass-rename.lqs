// Dragnet [Ransomware]: dragnet-ransomware-2024-2103 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: d989a9c6-0701-5436-9d50-f7e8167a16ed

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
