// Dragnet [Ransomware]: dragnet-ransomware-2022-0393 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: be78d10d-dabf-5a40-a86b-ff259558617a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
