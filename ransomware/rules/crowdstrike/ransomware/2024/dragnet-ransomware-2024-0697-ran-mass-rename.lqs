// Dragnet [Ransomware]: dragnet-ransomware-2024-0697 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: cbe968d7-2bc4-5a32-bd97-6d1a217699d7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
