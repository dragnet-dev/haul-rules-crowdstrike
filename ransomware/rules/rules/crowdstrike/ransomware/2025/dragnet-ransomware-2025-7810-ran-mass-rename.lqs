// Dragnet [Ransomware]: dragnet-ransomware-2025-7810 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: dcb7e504-4471-53f6-b3a7-42e7cfd0d0de

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
