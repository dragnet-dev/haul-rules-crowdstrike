// Dragnet [Ransomware]: dragnet-ransomware-2025-2446 — Mass File Rename (thegentlemen)
// Status: test | Level: high | ID: 0cb94d96-3f51-542e-8cb6-872cd7169320

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
