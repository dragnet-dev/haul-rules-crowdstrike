// Dragnet [Ransomware]: dragnet-ransomware-2024-5423 — Mass File Rename (kairos)
// Status: experimental | Level: high | ID: b8d2767b-ed72-5ce2-ba6e-e168b64f8b48

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
