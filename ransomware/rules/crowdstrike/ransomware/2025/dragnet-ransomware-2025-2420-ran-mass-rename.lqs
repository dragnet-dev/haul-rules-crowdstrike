// Dragnet [Ransomware]: dragnet-ransomware-2025-2420 — Mass File Rename (thegentlemen)
// Status: experimental | Level: high | ID: 9c4130d6-3023-505e-adb5-f0abf2546d57

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
