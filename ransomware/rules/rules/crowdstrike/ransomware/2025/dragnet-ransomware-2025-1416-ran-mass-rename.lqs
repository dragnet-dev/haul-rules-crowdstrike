// Dragnet [Ransomware]: dragnet-ransomware-2025-1416 — Mass File Rename (genesis)
// Status: experimental | Level: high | ID: c57c3540-a692-50c3-9310-fd0561cf179b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
