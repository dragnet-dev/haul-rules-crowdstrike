// Dragnet [Ransomware]: dragnet-ransomware-2024-3098 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: fc5df383-413f-5880-aca6-575e21f04630

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
