// Dragnet [Ransomware]: dragnet-ransomware-2023-3730 — Mass File Rename (threeam)
// Status: experimental | Level: high | ID: 23de4017-0a17-5172-a670-6fde78a69c23

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
