// Dragnet [Ransomware]: dragnet-ransomware-2025-7009 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 2bbd4da3-23c1-509b-a7e5-3c737a3cfa25

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
