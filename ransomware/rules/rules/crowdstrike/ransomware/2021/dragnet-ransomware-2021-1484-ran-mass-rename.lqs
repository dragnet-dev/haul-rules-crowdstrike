// Dragnet [Ransomware]: dragnet-ransomware-2021-1484 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 611b9efd-b058-506f-b47f-f994b9351232

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
