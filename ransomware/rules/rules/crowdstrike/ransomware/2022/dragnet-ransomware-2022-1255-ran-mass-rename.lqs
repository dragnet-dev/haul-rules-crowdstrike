// Dragnet [Ransomware]: dragnet-ransomware-2022-1255 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 0215cf56-3c27-58fb-9443-d80916f6350f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
