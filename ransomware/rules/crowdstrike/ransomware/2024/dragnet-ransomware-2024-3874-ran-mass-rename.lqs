// Dragnet [Ransomware]: dragnet-ransomware-2024-3874 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 0a529195-d1dc-5bd8-8295-fccacecc36a7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
