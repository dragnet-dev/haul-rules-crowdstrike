// Dragnet [Ransomware]: dragnet-ransomware-2023-4559 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: d25d0986-77fd-5058-b557-d2e390d6a4a4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
