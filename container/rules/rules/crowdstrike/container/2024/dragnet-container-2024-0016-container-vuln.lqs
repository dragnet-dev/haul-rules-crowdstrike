// Dragnet [Container]: dragnet-container-2024-0016 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 6827978a-1c70-5169-aad1-317effd3ab50

#event_simpleName=*
| (ImageFileName = *cbl-mariner:1.0* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
