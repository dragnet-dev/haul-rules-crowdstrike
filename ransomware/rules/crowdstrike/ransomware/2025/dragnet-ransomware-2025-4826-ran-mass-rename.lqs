// Dragnet [Ransomware]: dragnet-ransomware-2025-4826 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: fadb4fff-aea2-5b1b-a2ca-3d2b64b15129

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
