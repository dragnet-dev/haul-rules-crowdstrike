// Dragnet [Ransomware]: dragnet-ransomware-2024-4677 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: 0cb94b24-3e50-50bc-961d-0071b680c813

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
