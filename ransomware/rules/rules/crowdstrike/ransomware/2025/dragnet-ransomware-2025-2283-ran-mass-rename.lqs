// Dragnet [Ransomware]: dragnet-ransomware-2025-2283 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 50fe8dd9-1c70-52d4-a7d3-8376bf7dba78

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
