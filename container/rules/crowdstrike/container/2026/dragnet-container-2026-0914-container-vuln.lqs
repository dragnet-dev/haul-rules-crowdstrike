// Dragnet [Container]: dragnet-container-2026-0914 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: c1dd6dbf-6f99-588d-a604-db7a734cc4e1

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *ubuntu:12.04*)
| table([timestamp, ComputerName])
| limit(1000)
