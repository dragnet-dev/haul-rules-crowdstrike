// Dragnet [Ransomware]: dragnet-ransomware-2020-0016 — Mass File Rename (maze)
// Status: deprecated | Level: high | ID: 15886042-7176-5279-aa06-c4816a649ac3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
