// Dragnet [Ransomware]: dragnet-ransomware-2025-2507 — Mass File Rename (nightspire)
// Status: deprecated | Level: high | ID: 13576e37-d906-52df-960a-77be5ff7806f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
