// Dragnet [Ransomware]: dragnet-ransomware-2023-0628 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: fe8d602f-6141-5d24-ac88-f50475efbbb3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
