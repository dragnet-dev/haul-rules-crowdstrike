// Dragnet [Ransomware]: dragnet-ransomware-2025-1811 — Mass File Rename (arcusmedia)
// Status: experimental | Level: high | ID: bda59e52-043d-51bb-aa24-fbb32ba58d0c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
