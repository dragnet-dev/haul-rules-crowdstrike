// Dragnet [Container]: dragnet-container-2026-0947 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 1fbfa19c-4e54-5f2d-8e18-ea220c061d6a

#event_simpleName=*
| (ImageFileName = *alpine:3.3* OR ImageFileName = *alpine:3.4* OR ImageFileName = *alpine:3.5* OR ImageFileName = *alpine:3.6* OR ImageFileName = *chainguard:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:7* OR ImageFileName = *debian:8* OR ImageFileName = *debian:9* OR ImageFileName = *oraclelinux:7* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:14.04* OR ImageFileName = *ubuntu:14.04-ESM* OR ImageFileName = *ubuntu:16.04* OR ImageFileName = *ubuntu:16.04-ESM* OR ImageFileName = *ubuntu:17.04*)
| table([timestamp, ComputerName])
| limit(1000)
