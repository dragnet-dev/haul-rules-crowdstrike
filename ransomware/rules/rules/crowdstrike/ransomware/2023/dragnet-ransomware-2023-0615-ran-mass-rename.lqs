// Dragnet [Ransomware]: dragnet-ransomware-2023-0615 — Mass File Rename (monti)
// Status: experimental | Level: high | ID: 98b8e6c8-4e5c-5f23-9962-2116ecef1cb3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
