// Dragnet [Ransomware]: dragnet-ransomware-2025-0002 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 63deb560-1c64-59d6-83fd-4e4520b9b3a2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
