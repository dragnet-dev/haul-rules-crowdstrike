// Dragnet [Ransomware]: dragnet-ransomware-2022-0262 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 6b0377ea-bb2a-5339-a3cb-79531bad3689

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
