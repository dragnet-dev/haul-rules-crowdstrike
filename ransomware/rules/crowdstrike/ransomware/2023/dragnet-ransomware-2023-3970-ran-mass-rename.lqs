// Dragnet [Ransomware]: dragnet-ransomware-2023-3970 — Mass File Rename (abyss)
// Status: deprecated | Level: high | ID: 0ac123eb-529e-54c8-842d-ff54bef31681

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
