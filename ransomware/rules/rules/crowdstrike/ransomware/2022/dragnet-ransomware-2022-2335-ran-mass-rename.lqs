// Dragnet [Ransomware]: dragnet-ransomware-2022-2335 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 8ed04a3a-5520-559c-bb51-669393f4d302

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
