// Dragnet [Ransomware]: dragnet-ransomware-2023-4854 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 737b9d2c-1f21-55dc-850c-bf957fb2b64f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
