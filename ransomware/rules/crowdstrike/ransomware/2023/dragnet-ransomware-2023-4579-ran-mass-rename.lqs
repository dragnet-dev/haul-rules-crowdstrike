// Dragnet [Ransomware]: dragnet-ransomware-2023-4579 — Mass File Rename (play)
// Status: experimental | Level: high | ID: a3ad4f25-2446-5b17-ac04-7ea7b4540e5b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
