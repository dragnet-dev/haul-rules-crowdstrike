// Dragnet [Container]: dragnet-container-2026-0864 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: eeb9db5c-21af-530b-a6e0-7c7175330f72

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:7* OR ImageFileName = *debian:8*)
| table([timestamp, ComputerName])
| limit(1000)
