// Dragnet [Ransomware]: dragnet-ransomware-2025-3173 — Mass File Rename (sarcoma)
// Status: deprecated | Level: high | ID: 5397a98d-8d9d-521a-b85f-c7f7438a172a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
