// Dragnet [Ransomware]: dragnet-ransomware-2024-3561 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 0f7767b8-82f6-57f7-b662-9322d9fa64f5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
