// Dragnet [Ransomware]: dragnet-ransomware-2024-3220 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 8fa5ab3b-7f35-58e8-aa65-c19d171161e6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
