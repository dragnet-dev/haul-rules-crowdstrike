// Dragnet [Ransomware]: dragnet-ransomware-2025-7281 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 4bd6fbaf-6d01-5dc7-a49b-48b8757beacb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
