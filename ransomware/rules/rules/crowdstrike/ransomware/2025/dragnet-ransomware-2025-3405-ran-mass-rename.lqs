// Dragnet [Ransomware]: dragnet-ransomware-2025-3405 — Mass File Rename (devman)
// Status: experimental | Level: high | ID: d9da4740-c289-5127-9207-827562a2d7b5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
