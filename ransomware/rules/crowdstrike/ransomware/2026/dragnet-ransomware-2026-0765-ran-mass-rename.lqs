// Dragnet [Ransomware]: dragnet-ransomware-2026-0765 — Mass File Rename (dragonforce)
// Status: stable | Level: high | ID: 8910449b-da89-5fe8-920a-f2cf06054e34

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
