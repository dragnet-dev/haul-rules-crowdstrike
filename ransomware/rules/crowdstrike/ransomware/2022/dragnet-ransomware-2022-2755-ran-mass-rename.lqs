// Dragnet [Ransomware]: dragnet-ransomware-2022-2755 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: ad0368ce-bb4d-59a3-a1ee-c8d59f2997df

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
