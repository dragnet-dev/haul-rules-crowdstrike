// Dragnet [Container]: dragnet-container-2024-0094 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 92c5c567-d6a8-561c-8245-aa86a0ef9e18

#event_simpleName=*
| (ImageFileName = *alpine:3.17* OR ImageFileName = *alpine:3.18* OR ImageFileName = *alpine:3.19* OR ImageFileName = *alpine:3.20* OR ImageFileName = *alpine:3.21* OR ImageFileName = *alpine:3.22* OR ImageFileName = *alpine:3.23* OR ImageFileName = *alpine edge:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
