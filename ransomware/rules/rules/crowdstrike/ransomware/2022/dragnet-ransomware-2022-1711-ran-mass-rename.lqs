// Dragnet [Ransomware]: dragnet-ransomware-2022-1711 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 0452c7c3-8a3a-5201-bfe8-a04ea17ef186

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
