// Dragnet [Ransomware]: dragnet-ransomware-2023-5234 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: bc9eb4bf-4bbf-51c1-af73-db9bc70929d3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
