// Dragnet [Ransomware]: dragnet-ransomware-2025-2774 — Mass File Rename (beast)
// Status: experimental | Level: high | ID: fed46f5a-1916-5a94-a836-89960f939124

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
