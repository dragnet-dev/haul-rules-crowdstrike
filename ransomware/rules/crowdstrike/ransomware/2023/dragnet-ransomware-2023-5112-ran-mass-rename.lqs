// Dragnet [Ransomware]: dragnet-ransomware-2023-5112 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: f1a91b0a-566a-5f43-a460-3590543c85d8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
