// Dragnet [Container]: dragnet-container-2024-0844 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: f0adf3e7-0d92-5e2d-9502-532550fc6c93

#event_simpleName=*
| (ImageFileName = *amazonlinux:2* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:8* OR ImageFileName = *debian:9* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *oraclelinux:7* OR ImageFileName = *oraclelinux:8* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:16.04* OR ImageFileName = *ubuntu:18.04* OR ImageFileName = *ubuntu:18.10* OR ImageFileName = *ubuntu:19.04*)
| table([timestamp, ComputerName])
| limit(1000)
