// Dragnet [Ransomware]: dragnet-ransomware-2024-5752 — Mass File Rename (nitrogen)
// Status: experimental | Level: high | ID: d1d46d65-bc7c-53b6-8d7f-757c5ee06ac4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
