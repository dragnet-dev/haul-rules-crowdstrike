// Dragnet [Ransomware]: dragnet-ransomware-2024-1250 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 632cda7e-d670-566b-8495-9606cb293d9c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
