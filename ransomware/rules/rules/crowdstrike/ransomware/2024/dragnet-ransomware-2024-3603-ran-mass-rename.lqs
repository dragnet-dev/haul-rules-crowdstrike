// Dragnet [Ransomware]: dragnet-ransomware-2024-3603 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 0345dfdc-e57f-56f0-bcc8-0a0eeae10aab

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
