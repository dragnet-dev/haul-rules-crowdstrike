// Dragnet [Ransomware]: dragnet-ransomware-2025-1440 — Mass File Rename (chaos)
// Status: experimental | Level: high | ID: 386b00d9-08fe-5773-99b8-dce31d34c9b9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
