// Dragnet [Ransomware]: dragnet-ransomware-2023-2137 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: cf842a59-7334-5bbb-9b76-1744aea66bac

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
