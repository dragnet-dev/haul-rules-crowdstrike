// Dragnet [Ransomware]: dragnet-ransomware-2025-5550 — Mass File Rename (beast)
// Status: experimental | Level: high | ID: 5be51458-eb8b-5ca2-8e5d-b8e86bac8056

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
