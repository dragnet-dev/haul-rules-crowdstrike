// Dragnet [Ransomware]: dragnet-ransomware-2024-5262 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: d9f4eb21-0ddd-5546-8442-417de39a7ae3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
