// Dragnet [Ransomware]: dragnet-ransomware-2024-1998 — Mass File Rename (rhysida)
// Status: deprecated | Level: high | ID: de1228ec-392c-5727-ae40-24aaa6e3fd80

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
