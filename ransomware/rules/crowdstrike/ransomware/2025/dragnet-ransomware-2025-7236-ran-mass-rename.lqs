// Dragnet [Ransomware]: dragnet-ransomware-2025-7236 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: e15f6d33-e016-5450-a679-d2e8808135de

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
