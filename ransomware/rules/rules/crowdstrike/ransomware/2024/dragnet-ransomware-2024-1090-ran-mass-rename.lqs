// Dragnet [Ransomware]: dragnet-ransomware-2024-1090 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: f0567567-aeb9-563e-9631-3abc0f75d11b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
