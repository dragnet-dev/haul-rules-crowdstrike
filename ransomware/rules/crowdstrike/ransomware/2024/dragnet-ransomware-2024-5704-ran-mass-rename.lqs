// Dragnet [Ransomware]: dragnet-ransomware-2024-5704 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 8152544b-1d7c-50fc-9ff9-32ebb60dfb31

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
