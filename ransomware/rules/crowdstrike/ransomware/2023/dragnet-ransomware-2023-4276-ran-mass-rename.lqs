// Dragnet [Ransomware]: dragnet-ransomware-2023-4276 — Mass File Rename (stormous)
// Status: experimental | Level: high | ID: 7eaf2da3-1491-50b7-8326-77c37534a35a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
