// Dragnet [Container]: dragnet-container-2026-1949 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 9c2cfcee-d089-5665-870a-ba0efd7e8ae0

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10*)
| table([timestamp, ComputerName])
| limit(1000)
