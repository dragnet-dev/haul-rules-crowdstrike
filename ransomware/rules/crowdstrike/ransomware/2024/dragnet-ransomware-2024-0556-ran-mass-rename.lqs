// Dragnet [Ransomware]: dragnet-ransomware-2024-0556 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 57fba5d1-7442-533b-9315-24962436d5ea

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
