// Dragnet [Ransomware]: dragnet-ransomware-2026-1790 — Mass File Rename (killsec)
// Status: deprecated | Level: high | ID: e071da35-377d-5d29-9829-2e6fd88a4cb9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
