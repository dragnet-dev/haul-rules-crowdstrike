// Dragnet [Ransomware]: dragnet-ransomware-2025-3929 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 372af721-a5d1-5be2-ba72-328ad8d025f8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
