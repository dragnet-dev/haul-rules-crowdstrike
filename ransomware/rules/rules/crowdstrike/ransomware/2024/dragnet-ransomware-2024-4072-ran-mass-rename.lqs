// Dragnet [Ransomware]: dragnet-ransomware-2024-4072 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: 88c27f57-a54c-5a87-95eb-37ffb3a4d696

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
