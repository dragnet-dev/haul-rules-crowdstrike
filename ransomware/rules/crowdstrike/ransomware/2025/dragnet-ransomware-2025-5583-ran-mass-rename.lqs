// Dragnet [Ransomware]: dragnet-ransomware-2025-5583 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: b0915c27-d01c-5b71-84e5-b8ca17d5a847

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
