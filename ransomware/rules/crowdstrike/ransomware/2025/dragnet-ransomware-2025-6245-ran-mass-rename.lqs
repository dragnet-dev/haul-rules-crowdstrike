// Dragnet [Ransomware]: dragnet-ransomware-2025-6245 — Mass File Rename (devman)
// Status: experimental | Level: high | ID: b3e940c1-2ba4-5187-8e64-1e43b219adaa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
