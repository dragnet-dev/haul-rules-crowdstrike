// Dragnet [Container]: dragnet-container-2025-0020 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: ebcbd66f-9cbb-5e2f-8c26-096b3bc140ee

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *ubuntu:16.04-ESM* OR ImageFileName = *ubuntu:18.04-ESM* OR ImageFileName = *ubuntu:20.04-ESM* OR ImageFileName = *ubuntu:22.04*)
| table([timestamp, ComputerName])
| limit(1000)
