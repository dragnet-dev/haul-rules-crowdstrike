// Dragnet [Ransomware]: dragnet-ransomware-2021-0796 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: e783c4ff-43fb-52be-948f-c07f51e2a93d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
