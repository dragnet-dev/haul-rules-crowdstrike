// Dragnet [Ransomware]: dragnet-ransomware-2024-3916 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 3fa25b20-2608-5e10-8e51-15595f3a6609

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
