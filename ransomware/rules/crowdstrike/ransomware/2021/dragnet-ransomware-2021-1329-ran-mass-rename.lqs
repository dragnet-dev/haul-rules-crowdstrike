// Dragnet [Ransomware]: dragnet-ransomware-2021-1329 — Mass File Rename (avaddon)
// Status: deprecated | Level: high | ID: 0c5cb83d-1a50-513b-911c-2c18ee33fa05

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
