// Dragnet [Ransomware]: dragnet-ransomware-2024-2919 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 085c92bc-c549-586d-b52e-2e4c548c8dd7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
