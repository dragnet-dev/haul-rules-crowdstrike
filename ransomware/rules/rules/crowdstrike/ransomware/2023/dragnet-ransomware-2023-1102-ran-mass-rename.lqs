// Dragnet [Ransomware]: dragnet-ransomware-2023-1102 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: a76ff8df-2404-5708-bb25-281a7e31cf86

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
