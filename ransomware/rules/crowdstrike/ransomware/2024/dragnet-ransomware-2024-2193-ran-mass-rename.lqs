// Dragnet [Ransomware]: dragnet-ransomware-2024-2193 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: a5c0bf25-73a5-5857-94e5-04cf1fffe3e0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
