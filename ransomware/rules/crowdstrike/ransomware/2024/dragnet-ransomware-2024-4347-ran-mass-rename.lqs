// Dragnet [Ransomware]: dragnet-ransomware-2024-4347 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: b3d6fba7-3a52-51f1-8ef3-9836b860b55e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
