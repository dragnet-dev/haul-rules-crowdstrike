// Dragnet [Ransomware]: dragnet-ransomware-2024-5001 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: faed88b2-2c61-53e6-a48c-2e2317413740

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
