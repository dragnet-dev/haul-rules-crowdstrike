// Dragnet [Ransomware]: dragnet-ransomware-2021-1106 — Mass File Rename (blackmatter)
// Status: deprecated | Level: high | ID: 071b5de8-0fa6-57c8-b34e-4aa20bbdfd21

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
