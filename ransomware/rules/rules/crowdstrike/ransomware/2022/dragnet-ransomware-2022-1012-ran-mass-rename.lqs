// Dragnet [Ransomware]: dragnet-ransomware-2022-1012 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 27ba99d7-c95d-5de9-8efd-b49075099727

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
