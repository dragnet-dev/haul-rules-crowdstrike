// Dragnet [Ransomware]: dragnet-ransomware-2023-4894 — Mass File Rename (abyss)
// Status: deprecated | Level: high | ID: 729614ac-920a-5fd4-81c6-b280789a58d2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
