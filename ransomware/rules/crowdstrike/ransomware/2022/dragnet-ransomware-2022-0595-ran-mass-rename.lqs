// Dragnet [Ransomware]: dragnet-ransomware-2022-0595 — Mass File Rename (medusalocker)
// Status: deprecated | Level: high | ID: 02613329-806a-564d-99c0-52d9d8e9b7d5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
