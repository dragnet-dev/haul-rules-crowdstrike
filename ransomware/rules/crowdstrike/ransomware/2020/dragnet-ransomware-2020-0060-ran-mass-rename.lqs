// Dragnet [Ransomware]: dragnet-ransomware-2020-0060 — Mass File Rename (netwalker)
// Status: deprecated | Level: high | ID: 17cb45a7-5bad-5bf8-8b8e-636a7b7ec9f5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
