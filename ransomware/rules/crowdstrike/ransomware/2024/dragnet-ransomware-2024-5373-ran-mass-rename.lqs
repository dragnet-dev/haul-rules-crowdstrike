// Dragnet [Ransomware]: dragnet-ransomware-2024-5373 — Mass File Rename (threeam)
// Status: experimental | Level: high | ID: 91f7a6cf-10c7-501e-b445-d700faae81e7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
