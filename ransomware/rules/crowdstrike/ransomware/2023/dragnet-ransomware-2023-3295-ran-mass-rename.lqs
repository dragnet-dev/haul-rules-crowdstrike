// Dragnet [Ransomware]: dragnet-ransomware-2023-3295 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 5a443be8-66ae-5686-ac1e-a8e5f5bf538d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
