// Dragnet [Ransomware]: dragnet-ransomware-2023-0162 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: 2efe585c-939b-5d12-9b2f-c9538fb62a2b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
