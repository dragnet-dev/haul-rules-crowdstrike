// Dragnet [Ransomware]: dragnet-ransomware-2022-2106 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: dbda9b74-bd18-5ed9-a597-347d485238fd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
