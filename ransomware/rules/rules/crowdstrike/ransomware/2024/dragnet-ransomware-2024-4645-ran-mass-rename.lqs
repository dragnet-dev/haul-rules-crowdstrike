// Dragnet [Ransomware]: dragnet-ransomware-2024-4645 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: 26f53114-ed6a-50f4-975e-4442f33b4ba7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
