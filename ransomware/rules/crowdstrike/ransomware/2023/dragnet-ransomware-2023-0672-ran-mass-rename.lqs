// Dragnet [Ransomware]: dragnet-ransomware-2023-0672 — Mass File Rename (interlock)
// Status: experimental | Level: high | ID: 7f6edf6d-124e-5916-88d1-a09c66871a8d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
