// Dragnet [Ransomware]: dragnet-ransomware-2026-0872 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 7422f366-a9a0-59c5-9e6d-a455fbfa67b2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
