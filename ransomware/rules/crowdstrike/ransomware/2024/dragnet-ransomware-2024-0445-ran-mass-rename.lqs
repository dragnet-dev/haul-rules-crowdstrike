// Dragnet [Ransomware]: dragnet-ransomware-2024-0445 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: bd505d46-ed02-5458-88c3-3771492dd838

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
