// Dragnet [Ransomware]: dragnet-ransomware-2024-0736 — Mass File Rename (meow)
// Status: experimental | Level: high | ID: ddf8da1d-8704-55af-a1ca-63a95ddf7c02

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
