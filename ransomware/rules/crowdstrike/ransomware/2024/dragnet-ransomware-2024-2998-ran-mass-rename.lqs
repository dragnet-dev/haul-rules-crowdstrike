// Dragnet [Ransomware]: dragnet-ransomware-2024-2998 — Mass File Rename (dragonforce)
// Status: deprecated | Level: high | ID: 6f831b2a-41ae-5d1e-a1ed-d5b25cd3826e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
