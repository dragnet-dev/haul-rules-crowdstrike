// Dragnet [Ransomware]: dragnet-ransomware-2025-5245 — Mass File Rename (beast)
// Status: experimental | Level: high | ID: c50b5b79-63a6-56f3-bce1-357ea87a5d53

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
