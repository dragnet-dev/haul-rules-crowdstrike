// Dragnet [Ransomware]: dragnet-ransomware-2023-4994 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 4e17e4e3-22dd-5849-87ff-093c7ebda900

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
