// Dragnet [Ransomware]: dragnet-ransomware-2023-2473 — Mass File Rename (stormous)
// Status: deprecated | Level: high | ID: 37324703-6bbc-5542-a227-f117aaea3dac

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
