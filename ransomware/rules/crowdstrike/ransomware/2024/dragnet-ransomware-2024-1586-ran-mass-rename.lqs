// Dragnet [Ransomware]: dragnet-ransomware-2024-1586 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: 211ec235-b9e5-56a4-af85-a59b7919a764

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
