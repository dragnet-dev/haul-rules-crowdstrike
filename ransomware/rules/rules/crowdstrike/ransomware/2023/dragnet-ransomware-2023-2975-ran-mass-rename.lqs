// Dragnet [Ransomware]: dragnet-ransomware-2023-2975 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: e8faa831-8c1e-5f81-8209-66e3b15b8851

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
