// Dragnet [Ransomware]: dragnet-ransomware-2023-4066 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 8c162ddd-5a46-590b-a0d7-57fb39fbffe2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
