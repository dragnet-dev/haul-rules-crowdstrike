// Dragnet [Ransomware]: dragnet-ransomware-2025-7519 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 6be3bba5-495b-5b8e-acca-0db4ad2a8636

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
