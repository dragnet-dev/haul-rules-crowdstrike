// Dragnet [Ransomware]: dragnet-ransomware-2024-2875 — Mass File Rename (trigona)
// Status: experimental | Level: high | ID: dbf07996-b805-5fc9-ad89-0be688619189

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
