// Dragnet [Ransomware]: dragnet-ransomware-2024-3485 — Mass File Rename (threeam)
// Status: experimental | Level: high | ID: 731c603d-e2b1-5986-b81b-312cbf80bfb5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
