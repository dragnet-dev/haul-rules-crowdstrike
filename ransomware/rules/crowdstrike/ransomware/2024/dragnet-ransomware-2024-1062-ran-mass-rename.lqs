// Dragnet [Ransomware]: dragnet-ransomware-2024-1062 — Mass File Rename (malekteam)
// Status: experimental | Level: high | ID: db431c34-e251-55c4-9c95-2a5b20ccbdb7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
