// Dragnet [Ransomware]: dragnet-ransomware-2020-0137 — Mass File Rename (prolock)
// Status: deprecated | Level: high | ID: 9bcab997-7472-59e8-828f-9cddce2d41d1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
