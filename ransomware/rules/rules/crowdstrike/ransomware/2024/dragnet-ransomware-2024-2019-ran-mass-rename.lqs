// Dragnet [Ransomware]: dragnet-ransomware-2024-2019 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: a7b10843-c05d-5c70-bb5d-905db051f18e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
