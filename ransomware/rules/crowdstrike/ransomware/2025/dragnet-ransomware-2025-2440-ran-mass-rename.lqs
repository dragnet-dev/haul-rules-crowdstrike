// Dragnet [Ransomware]: dragnet-ransomware-2025-2440 — Mass File Rename (thegentlemen)
// Status: experimental | Level: high | ID: bb890375-7f7a-5b43-bcb8-f81e90a40bbd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
