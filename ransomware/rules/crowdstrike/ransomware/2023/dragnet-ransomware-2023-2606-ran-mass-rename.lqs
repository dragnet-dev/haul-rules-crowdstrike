// Dragnet [Ransomware]: dragnet-ransomware-2023-2606 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: bb5bc634-e487-51bf-aa60-262de1aea743

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
