// Dragnet [Ransomware]: dragnet-ransomware-2022-0670 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 5f6d9a32-3b92-51af-a9e3-7ca425cfd547

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
