// Dragnet [Ransomware]: dragnet-ransomware-2022-0396 — Mass File Rename (snatch)
// Status: deprecated | Level: high | ID: 5fda3e75-d347-50fa-8cc9-0b4f9bee1cae

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
