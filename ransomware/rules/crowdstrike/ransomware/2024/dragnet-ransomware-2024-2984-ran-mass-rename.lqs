// Dragnet [Ransomware]: dragnet-ransomware-2024-2984 — Mass File Rename (play)
// Status: experimental | Level: high | ID: c2afc80d-f166-5e57-9f67-cc8412c23b94

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
