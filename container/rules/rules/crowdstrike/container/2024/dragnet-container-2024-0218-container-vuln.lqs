// Dragnet [Container]: dragnet-container-2024-0218 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: f0277c6e-8ccc-5ddb-b79b-ca571cf429aa

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:8* OR ImageFileName = *debian:9* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:18.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
