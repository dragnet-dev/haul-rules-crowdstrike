// Dragnet [Ransomware]: dragnet-ransomware-2025-6029 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 8aea3e96-36f9-5034-b421-febbfbb352c1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
