// Dragnet [Ransomware]: dragnet-ransomware-2025-5804 — Mass File Rename (rhysida)
// Status: deprecated | Level: high | ID: 5aa85234-2192-566b-a147-3bd62cb9cd85

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
