// Dragnet [Ransomware]: dragnet-ransomware-2024-3332 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: f6b5dca9-db03-5886-9d51-5f29ed01aa30

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
