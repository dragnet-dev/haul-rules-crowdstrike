// Dragnet [Ransomware]: dragnet-ransomware-2022-0703 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 64b6f03f-024e-51c6-bb5b-d0d8ee948204

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
