// Dragnet [Ransomware]: dragnet-ransomware-2025-5056 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 1f95bbe1-fa83-5e71-8b35-cd3736b68472

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
