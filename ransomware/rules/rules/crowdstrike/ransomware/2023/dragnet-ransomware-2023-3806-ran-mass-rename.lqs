// Dragnet [Ransomware]: dragnet-ransomware-2023-3806 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 62ba8b2a-e5cb-5fb6-b9c8-5833d04b679b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
