// Dragnet [Ransomware]: dragnet-ransomware-2020-0002 — Mass File Rename (nefilim)
// Status: deprecated | Level: high | ID: 521f1493-c9c1-5060-b89e-9ec64341a62e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
