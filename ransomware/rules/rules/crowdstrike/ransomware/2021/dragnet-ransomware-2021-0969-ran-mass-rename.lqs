// Dragnet [Ransomware]: dragnet-ransomware-2021-0969 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 562a5b28-e761-5e95-9313-f497954ea979

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
