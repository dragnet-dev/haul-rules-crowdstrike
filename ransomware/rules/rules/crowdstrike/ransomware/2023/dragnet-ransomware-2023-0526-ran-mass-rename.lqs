// Dragnet [Ransomware]: dragnet-ransomware-2023-0526 — Mass File Rename (noescape)
// Status: experimental | Level: high | ID: 92f7ae5c-d7d6-5c40-8ed8-5531b103b25c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
