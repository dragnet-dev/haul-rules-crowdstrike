// Dragnet [Ransomware]: dragnet-ransomware-2023-2577 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: ec0dfc3c-880e-5e4b-b41d-e41ef8e6c1aa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
