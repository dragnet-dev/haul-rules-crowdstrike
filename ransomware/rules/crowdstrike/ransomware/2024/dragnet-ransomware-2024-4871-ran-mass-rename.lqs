// Dragnet [Ransomware]: dragnet-ransomware-2024-4871 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 2b00042c-8ea8-54d7-bba8-d163c96bd774

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
