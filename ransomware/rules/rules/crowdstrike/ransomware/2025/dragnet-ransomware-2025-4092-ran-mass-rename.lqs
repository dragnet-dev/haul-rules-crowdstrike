// Dragnet [Ransomware]: dragnet-ransomware-2025-4092 — Mass File Rename (SilentRansomGroup)
// Status: deprecated | Level: high | ID: 0c0dd8a9-ccd1-5ce3-a900-39726f425af7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
