// Dragnet [Ransomware]: dragnet-ransomware-2021-0523 — Mass File Rename (xinglocker)
// Status: deprecated | Level: high | ID: d067cc99-102e-5504-8406-2f3e340e8817

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
