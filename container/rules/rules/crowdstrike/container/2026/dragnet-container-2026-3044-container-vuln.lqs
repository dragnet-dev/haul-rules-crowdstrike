// Dragnet [Container]: dragnet-container-2026-3044 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 4a0bfa54-fb86-55f9-abf9-d7ac64dbce35

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:5*)
| table([timestamp, ComputerName])
| limit(1000)
