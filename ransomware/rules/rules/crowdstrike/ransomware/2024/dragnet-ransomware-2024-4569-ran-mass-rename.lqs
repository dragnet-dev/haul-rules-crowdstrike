// Dragnet [Ransomware]: dragnet-ransomware-2024-4569 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: 533a7267-0dc8-5afc-a455-0923f05c7dc7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
