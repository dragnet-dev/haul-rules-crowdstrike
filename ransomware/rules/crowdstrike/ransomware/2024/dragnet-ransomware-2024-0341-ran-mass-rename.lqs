// Dragnet [Ransomware]: dragnet-ransomware-2024-0341 — Mass File Rename (play)
// Status: experimental | Level: high | ID: cee6a51e-5d0c-54e3-b7bb-6ab0808d55cf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
