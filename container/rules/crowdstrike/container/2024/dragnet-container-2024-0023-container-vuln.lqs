// Dragnet [Container]: dragnet-container-2024-0023 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 4fe14df1-8308-542d-96b0-3970bff1285e

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
