// Dragnet [Ransomware]: dragnet-ransomware-2020-0078 — Mass File Rename (ryuk)
// Status: deprecated | Level: high | ID: 85976f0d-4357-5026-9e43-4e8e62393434

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
