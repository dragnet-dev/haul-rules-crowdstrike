// Dragnet [Ransomware]: dragnet-ransomware-2022-2450 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: d3c03e62-f4a7-53ae-9c37-de5d4da1fac2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
