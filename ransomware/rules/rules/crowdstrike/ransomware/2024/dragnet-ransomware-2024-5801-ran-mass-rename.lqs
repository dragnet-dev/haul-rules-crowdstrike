// Dragnet [Ransomware]: dragnet-ransomware-2024-5801 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: ae56c3e2-35ed-51a1-9a22-a57e4f00871a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
