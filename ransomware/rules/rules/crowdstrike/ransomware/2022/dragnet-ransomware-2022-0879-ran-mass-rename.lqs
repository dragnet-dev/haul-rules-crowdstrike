// Dragnet [Ransomware]: dragnet-ransomware-2022-0879 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 152be540-3197-5bd9-8865-9891294c196d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
