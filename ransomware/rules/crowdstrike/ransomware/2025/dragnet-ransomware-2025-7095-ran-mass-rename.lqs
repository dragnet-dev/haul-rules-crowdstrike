// Dragnet [Ransomware]: dragnet-ransomware-2025-7095 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: f065067f-841b-517e-a44c-02f8fb71f1ce

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
