// Dragnet [Ransomware]: dragnet-ransomware-2022-0802 — Mass File Rename (medusalocker)
// Status: deprecated | Level: high | ID: a4c7d2b6-ea1a-59c3-b4ea-4717446437c2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
