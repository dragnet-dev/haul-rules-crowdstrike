// Dragnet [Ransomware]: dragnet-ransomware-2023-0148 — Mass File Rename (toufan)
// Status: deprecated | Level: high | ID: 45f52544-138e-5338-9c67-03f2e4a8d4b5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
