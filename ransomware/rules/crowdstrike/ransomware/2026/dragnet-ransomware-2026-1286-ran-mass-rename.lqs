// Dragnet [Ransomware]: dragnet-ransomware-2026-1286 — Mass File Rename (fulcrumsec)
// Status: stable | Level: high | ID: 4995a70a-2461-552a-8cfa-ce5e97ac28c1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
