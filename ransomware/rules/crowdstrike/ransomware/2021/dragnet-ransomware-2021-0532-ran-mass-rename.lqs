// Dragnet [Ransomware]: dragnet-ransomware-2021-0532 — Mass File Rename (lockbit)
// Status: deprecated | Level: high | ID: 3bee2a4d-f595-54f4-ae1e-28c59c4127cd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
