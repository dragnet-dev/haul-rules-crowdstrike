// Dragnet [Ransomware]: dragnet-ransomware-2024-5518 — Mass File Rename (cloak)
// Status: deprecated | Level: high | ID: df8c5f23-2253-554f-ae6f-1f1264f7fcb8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
