// Dragnet [Container]: dragnet-container-2026-2016 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 571b643d-c934-5248-879f-825086ece5ea

#event_simpleName=*
| (ImageFileName = *amazonlinux:1* OR ImageFileName = *chainguard:* OR ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10*)
| table([timestamp, ComputerName])
| limit(1000)
