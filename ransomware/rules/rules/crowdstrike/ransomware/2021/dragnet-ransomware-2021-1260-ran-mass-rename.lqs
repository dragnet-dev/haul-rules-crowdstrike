// Dragnet [Ransomware]: dragnet-ransomware-2021-1260 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: d92d6bf5-9da3-5cb8-9e02-5a794c6bbc3d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
