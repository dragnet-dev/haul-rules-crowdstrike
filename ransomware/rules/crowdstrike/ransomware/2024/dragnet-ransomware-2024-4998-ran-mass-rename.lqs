// Dragnet [Ransomware]: dragnet-ransomware-2024-4998 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: 0ec8758a-994a-5de6-8163-1e2b9af2bbd9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
