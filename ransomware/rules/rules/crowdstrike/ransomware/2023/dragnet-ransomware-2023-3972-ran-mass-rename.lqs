// Dragnet [Ransomware]: dragnet-ransomware-2023-3972 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 4594f27f-c82b-56c3-a0ca-d1c397337301

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
