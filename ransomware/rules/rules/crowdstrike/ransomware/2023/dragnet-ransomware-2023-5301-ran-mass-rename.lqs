// Dragnet [Ransomware]: dragnet-ransomware-2023-5301 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 33000cb6-da0f-589a-998f-babd7f69f535

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
