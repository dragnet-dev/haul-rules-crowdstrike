// Dragnet [Ransomware]: dragnet-ransomware-2023-3576 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 116750de-44b7-56c2-b063-2ba89c65ef93

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
