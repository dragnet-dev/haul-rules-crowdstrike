// Dragnet [Ransomware]: dragnet-ransomware-2024-4708 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: b5ac789d-f9f4-5cbe-a250-bb90240fd913

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
