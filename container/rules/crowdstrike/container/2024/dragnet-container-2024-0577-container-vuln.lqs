// Dragnet [Container]: dragnet-container-2024-0577 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 5b5c4126-5543-5eed-bc39-6e3a8d145921

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *ubuntu:14.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
