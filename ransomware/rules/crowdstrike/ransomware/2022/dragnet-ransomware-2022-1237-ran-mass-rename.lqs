// Dragnet [Ransomware]: dragnet-ransomware-2022-1237 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: dde450bb-3b77-5d60-bb85-8463239d11cf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
