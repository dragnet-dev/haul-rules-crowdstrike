// Dragnet [Ransomware]: dragnet-ransomware-2025-7663 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: a18e68d0-5b0e-582b-926e-0d8d062d8d79

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
