// Dragnet [Ransomware]: dragnet-ransomware-2026-2952 — Mass File Rename (lockbit5)
// Status: stable | Level: high | ID: d70faa3d-4d32-5769-ab4a-4846cfac3484

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
