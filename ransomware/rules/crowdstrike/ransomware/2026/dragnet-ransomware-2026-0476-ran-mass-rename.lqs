// Dragnet [Ransomware]: dragnet-ransomware-2026-0476 — Mass File Rename (insomnia)
// Status: test | Level: high | ID: 1ea27512-be97-54dc-a538-94e39d3d78ff

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
