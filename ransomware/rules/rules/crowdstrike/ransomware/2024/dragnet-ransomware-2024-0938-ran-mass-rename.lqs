// Dragnet [Ransomware]: dragnet-ransomware-2024-0938 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 5fde1c18-40f2-51de-aa21-c9dce889cac2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
