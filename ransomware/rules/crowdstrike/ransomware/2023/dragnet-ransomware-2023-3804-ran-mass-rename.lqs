// Dragnet [Ransomware]: dragnet-ransomware-2023-3804 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 01ad5c19-6a53-5b34-89ba-02ff3677baeb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
