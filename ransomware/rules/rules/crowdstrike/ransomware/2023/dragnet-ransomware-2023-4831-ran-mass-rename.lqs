// Dragnet [Ransomware]: dragnet-ransomware-2023-4831 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 8d30a613-591b-50ce-a709-bdde0811821c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
