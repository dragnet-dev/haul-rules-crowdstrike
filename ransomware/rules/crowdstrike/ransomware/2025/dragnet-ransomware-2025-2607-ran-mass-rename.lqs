// Dragnet [Ransomware]: dragnet-ransomware-2025-2607 — Mass File Rename (beast)
// Status: experimental | Level: high | ID: 29b27aae-992c-5298-8e9f-29d6b34d93b8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
