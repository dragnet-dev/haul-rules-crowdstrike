// Dragnet [Ransomware]: dragnet-ransomware-2025-7884 — Mass File Rename (nitrogen)
// Status: experimental | Level: high | ID: df72831a-6a1e-5da1-99eb-aab84d867f49

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
