// Dragnet [Ransomware]: dragnet-ransomware-2024-1836 — Mass File Rename (beast)
// Status: experimental | Level: high | ID: 749dfdd0-9c10-5bbf-9ded-6bf47e5b9e9c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
