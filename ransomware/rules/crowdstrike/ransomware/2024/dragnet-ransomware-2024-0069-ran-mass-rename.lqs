// Dragnet [Ransomware]: dragnet-ransomware-2024-0069 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: b3307da7-9744-5d2a-93fe-b0c6964b832f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
