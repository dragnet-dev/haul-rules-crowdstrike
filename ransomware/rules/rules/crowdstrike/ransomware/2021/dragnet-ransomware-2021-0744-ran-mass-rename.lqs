// Dragnet [Ransomware]: dragnet-ransomware-2021-0744 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 5cbf7caa-08de-515c-88ad-697c3c743024

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
