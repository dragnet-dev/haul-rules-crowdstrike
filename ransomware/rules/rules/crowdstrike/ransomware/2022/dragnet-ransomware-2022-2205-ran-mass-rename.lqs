// Dragnet [Ransomware]: dragnet-ransomware-2022-2205 — Mass File Rename (revil)
// Status: deprecated | Level: high | ID: 27194ad1-bd94-5ab5-a273-639579b680c8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
