// Dragnet [Ransomware]: dragnet-ransomware-2026-1340 — Mass File Rename (dragonforce)
// Status: stable | Level: high | ID: 01fbb73e-1087-5372-a23d-65d1c8fe7f2f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
