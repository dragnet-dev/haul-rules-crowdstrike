// Dragnet [Ransomware]: dragnet-ransomware-2025-6094 — Mass File Rename (coinbasecartel)
// Status: experimental | Level: high | ID: 81c02883-41d1-5328-892e-a074066185ff

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
