// Dragnet [Ransomware]: dragnet-ransomware-2024-1392 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 52bd51ba-9e7e-565c-8504-5ffc6777db3b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
