// Dragnet [Ransomware]: dragnet-ransomware-2026-2568 — Mass File Rename (krybit)
// Status: stable | Level: high | ID: d9e87944-4ac3-5b40-9fb0-4911e8ee1d0b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
