// Dragnet [Ransomware]: dragnet-ransomware-2023-0164 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 7e37f006-059c-5d87-85c7-737289d613cd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
