// Dragnet [Ransomware]: dragnet-ransomware-2021-1349 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: b35561a3-e68c-566c-831b-6e3df95cfdee

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
