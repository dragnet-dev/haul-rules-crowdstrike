// Dragnet [Ransomware]: dragnet-ransomware-2023-3610 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 36bd08b2-0fe0-504e-9a9c-5408b7cb73f9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
