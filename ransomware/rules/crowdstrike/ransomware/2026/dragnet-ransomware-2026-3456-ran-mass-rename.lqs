// Dragnet [Ransomware]: dragnet-ransomware-2026-3456 — Mass File Rename (worldleaks)
// Status: stable | Level: high | ID: d23ea029-8fa5-5d80-9d0c-cf4b66ddba61

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
