// Dragnet [Ransomware]: dragnet-ransomware-2025-5842 — Mass File Rename (gunra)
// Status: experimental | Level: high | ID: f02df470-4cc6-5833-a954-882efb1378d5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
