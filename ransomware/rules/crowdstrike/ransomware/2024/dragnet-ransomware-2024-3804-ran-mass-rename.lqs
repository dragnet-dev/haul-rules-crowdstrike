// Dragnet [Ransomware]: dragnet-ransomware-2024-3804 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: ae6242d1-b8bc-5802-897e-b055b841b9a2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
