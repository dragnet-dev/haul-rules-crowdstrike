// Dragnet [Ransomware]: dragnet-ransomware-2025-5048 — Mass File Rename (payoutsking)
// Status: experimental | Level: high | ID: 1b1c3e55-c2b8-5178-b3f6-d73468d6dcd1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
