// Dragnet [Ransomware]: dragnet-ransomware-2025-7039 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 917623e9-9945-554c-ba55-beea95e3d87b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
