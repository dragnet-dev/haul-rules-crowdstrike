// Dragnet [Ransomware]: dragnet-ransomware-2024-0330 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 5a647f6f-7ab7-5e45-8443-abd6bc53b627

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
