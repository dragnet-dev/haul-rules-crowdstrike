// Dragnet [Ransomware]: dragnet-ransomware-2024-5442 — Mass File Rename (monti)
// Status: experimental | Level: high | ID: dc40ec43-5d89-5a7e-96c8-0e3f8be02302

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
