// Dragnet [Ransomware]: dragnet-ransomware-2025-3921 — Mass File Rename (pear)
// Status: experimental | Level: high | ID: 1582af13-b772-5d23-86a2-18bcb986b7da

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
