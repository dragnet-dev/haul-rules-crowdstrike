// Dragnet [Ransomware]: dragnet-ransomware-2025-6402 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: 8ff69e0e-3878-57f0-b964-a946681aa512

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
