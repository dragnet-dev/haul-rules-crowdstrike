// Dragnet [Container]: dragnet-container-2026-2737 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 13c2ac7e-03a3-5597-8f75-d117698bf5b3

#event_simpleName=*
| (ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10* OR ImageFileName = *ubuntu:13.04* OR ImageFileName = *ubuntu:13.10*)
| table([timestamp, ComputerName])
| limit(1000)
