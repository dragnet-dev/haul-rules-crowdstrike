// Dragnet [Ransomware]: dragnet-ransomware-2023-0622 — Mass File Rename (noescape)
// Status: experimental | Level: high | ID: bf868e78-b6e9-5d4f-94a3-f2280105e50a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
