// Dragnet [Ransomware]: dragnet-ransomware-2021-1477 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: e83c6f61-17d7-5e9e-a4a4-8923b08b7de6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
