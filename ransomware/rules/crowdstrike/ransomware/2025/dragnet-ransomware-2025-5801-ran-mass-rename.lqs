// Dragnet [Ransomware]: dragnet-ransomware-2025-5801 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: ac0586de-edbd-5137-9ee4-1cd2690903c5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
