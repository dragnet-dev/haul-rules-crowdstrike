// Dragnet [Ransomware]: dragnet-ransomware-2023-0863 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: b3fd0ea1-8bc2-521d-ad73-8cc6b88401dd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
