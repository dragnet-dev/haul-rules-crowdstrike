// Dragnet [Ransomware]: dragnet-ransomware-2025-1481 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 8fadf7ed-d582-5dce-87ed-0ff9497eabac

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
