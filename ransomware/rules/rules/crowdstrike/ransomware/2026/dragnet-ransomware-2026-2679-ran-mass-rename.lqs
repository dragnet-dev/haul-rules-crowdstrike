// Dragnet [Ransomware]: dragnet-ransomware-2026-2679 — Mass File Rename (incransom)
// Status: stable | Level: high | ID: 6470393a-3be5-5554-8424-7fc64dfeae50

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
