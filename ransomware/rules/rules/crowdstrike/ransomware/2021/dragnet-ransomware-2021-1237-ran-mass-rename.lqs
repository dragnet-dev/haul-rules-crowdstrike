// Dragnet [Ransomware]: dragnet-ransomware-2021-1237 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 432b1166-751b-51e0-85d1-7af5c1ad3dd4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
