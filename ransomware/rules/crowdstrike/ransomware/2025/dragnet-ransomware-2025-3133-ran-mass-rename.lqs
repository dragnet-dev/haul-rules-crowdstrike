// Dragnet [Ransomware]: dragnet-ransomware-2025-3133 — Mass File Rename (flocker)
// Status: experimental | Level: high | ID: 95623b8e-7af7-58f5-9f52-d00486ea37c8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
