// Dragnet [Ransomware]: dragnet-ransomware-2025-6623 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 8856d861-58df-52e5-be73-8319e5e0d9fd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
