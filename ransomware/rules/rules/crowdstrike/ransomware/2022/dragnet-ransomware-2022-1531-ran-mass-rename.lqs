// Dragnet [Ransomware]: dragnet-ransomware-2022-1531 — Mass File Rename (ragnarlocker)
// Status: deprecated | Level: high | ID: ceaac68f-c631-5792-b787-7219a871aaad

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
