// Dragnet [Ransomware]: dragnet-ransomware-2023-3452 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 9ffb2e4f-8c06-537d-b95a-2ee398138992

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
