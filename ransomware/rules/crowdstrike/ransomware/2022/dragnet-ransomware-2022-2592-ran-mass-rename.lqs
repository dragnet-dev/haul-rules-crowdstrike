// Dragnet [Ransomware]: dragnet-ransomware-2022-2592 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: c7334c75-18bd-5d19-970e-703d936cf313

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
