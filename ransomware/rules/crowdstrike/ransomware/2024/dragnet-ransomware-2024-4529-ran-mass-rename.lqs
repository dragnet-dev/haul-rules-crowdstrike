// Dragnet [Ransomware]: dragnet-ransomware-2024-4529 — Mass File Rename (dragonforce)
// Status: deprecated | Level: high | ID: be5d67d6-655f-5025-832d-df897c6ced96

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
