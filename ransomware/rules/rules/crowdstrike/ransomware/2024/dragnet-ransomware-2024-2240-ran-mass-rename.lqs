// Dragnet [Ransomware]: dragnet-ransomware-2024-2240 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: e7051966-e395-5fb2-a396-5aff6f25535b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
