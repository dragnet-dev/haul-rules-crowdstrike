// Dragnet [Ransomware]: dragnet-ransomware-2026-1277 — Mass File Rename (dragonforce)
// Status: stable | Level: high | ID: 24e3565d-5382-5f76-8d05-6a572e798021

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
