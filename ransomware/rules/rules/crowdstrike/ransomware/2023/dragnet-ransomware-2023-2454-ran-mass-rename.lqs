// Dragnet [Ransomware]: dragnet-ransomware-2023-2454 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 60dab6f6-a2fd-5d3c-b869-eb6f68075d1c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
