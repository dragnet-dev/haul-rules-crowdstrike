// Dragnet [Container]: dragnet-container-2024-0447 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 443c6508-d3e4-52cf-8aea-b4c5311cefea

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:9*)
| table([timestamp, ComputerName])
| limit(1000)
