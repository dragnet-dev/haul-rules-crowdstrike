// Dragnet [Ransomware]: dragnet-ransomware-2022-1750 — Mass File Rename (ragnarlocker)
// Status: deprecated | Level: high | ID: f67e6e5e-ffa5-5216-90d9-5ab637cb4ca6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
