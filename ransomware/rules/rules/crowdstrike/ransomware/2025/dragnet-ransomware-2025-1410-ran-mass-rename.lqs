// Dragnet [Ransomware]: dragnet-ransomware-2025-1410 — Mass File Rename (weyhro)
// Status: experimental | Level: high | ID: 50e90135-5c22-5eff-8015-fc0f819b04cd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
