// Dragnet [Ransomware]: dragnet-ransomware-2022-1764 — Mass File Rename (cuba)
// Status: deprecated | Level: high | ID: 90bad837-23fa-5b26-9db9-1e14d859f496

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
