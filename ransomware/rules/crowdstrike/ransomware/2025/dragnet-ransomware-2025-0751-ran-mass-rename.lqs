// Dragnet [Ransomware]: dragnet-ransomware-2025-0751 — Mass File Rename (frag)
// Status: deprecated | Level: high | ID: 0524c8f0-aff0-57f0-a018-54890689e518

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
