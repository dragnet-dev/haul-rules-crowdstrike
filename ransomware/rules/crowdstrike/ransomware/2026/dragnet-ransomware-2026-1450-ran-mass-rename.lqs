// Dragnet [Ransomware]: dragnet-ransomware-2026-1450 — Mass File Rename (safepay)
// Status: stable | Level: high | ID: abacc69b-f852-5268-99d8-301668b6c3d6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
