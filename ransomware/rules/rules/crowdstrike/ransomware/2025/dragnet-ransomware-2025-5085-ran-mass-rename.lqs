// Dragnet [Ransomware]: dragnet-ransomware-2025-5085 — Mass File Rename (worldleaks)
// Status: experimental | Level: high | ID: 72de72a8-73a5-5ed5-9e56-4cee9dae6190

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
