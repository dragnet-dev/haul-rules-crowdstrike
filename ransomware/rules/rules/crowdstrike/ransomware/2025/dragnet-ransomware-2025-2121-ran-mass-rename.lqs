// Dragnet [Ransomware]: dragnet-ransomware-2025-2121 — Mass File Rename (hellcat)
// Status: deprecated | Level: high | ID: e68bdfc5-d336-501c-8f06-46d40a0e2b0d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
