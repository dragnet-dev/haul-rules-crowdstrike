// Dragnet [Ransomware]: dragnet-ransomware-2021-0139 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 8ba57a01-9972-5dcd-8360-22ac9efcc6a3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
