// Dragnet [Ransomware]: dragnet-ransomware-2020-0209 — Mass File Rename (maze)
// Status: deprecated | Level: high | ID: 5b581456-ada0-56dc-9cae-e7885080560a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
