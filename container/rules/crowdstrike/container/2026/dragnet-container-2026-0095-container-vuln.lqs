// Dragnet [Container]: dragnet-container-2026-0095 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 1219e699-8f3f-532a-8bf7-536df9440bbc

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10*)
| table([timestamp, ComputerName])
| limit(1000)
