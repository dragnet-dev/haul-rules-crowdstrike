// Dragnet [Ransomware]: dragnet-ransomware-2023-1624 — Mass File Rename (karakurt)
// Status: experimental | Level: high | ID: 8a46cd93-a311-52b8-9705-c58f513f774c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
