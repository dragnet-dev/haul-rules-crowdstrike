// Dragnet [Ransomware]: dragnet-ransomware-2025-7412 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 8328c985-75d7-5747-ab06-839f90d512e5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
