// Dragnet [Ransomware]: dragnet-ransomware-2025-7707 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 3c72452a-372c-5a70-bdb8-2f8f1a054a09

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
