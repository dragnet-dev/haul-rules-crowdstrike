// Dragnet [Ransomware]: dragnet-ransomware-2022-2356 — Mass File Rename (cuba)
// Status: deprecated | Level: high | ID: ea60d138-ce3b-5c81-bb05-cac9bc2489c6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
