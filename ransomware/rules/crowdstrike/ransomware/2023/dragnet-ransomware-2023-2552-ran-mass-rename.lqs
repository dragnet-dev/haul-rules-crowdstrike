// Dragnet [Ransomware]: dragnet-ransomware-2023-2552 — Mass File Rename (ransomhouse)
// Status: experimental | Level: high | ID: 425914be-70bd-5f02-b93a-a7bd0400ff89

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
