// Dragnet [Ransomware]: dragnet-ransomware-2024-0462 — Mass File Rename (cloak)
// Status: deprecated | Level: high | ID: 77f72781-cf95-5c0e-bdcf-b2024e91aea7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
