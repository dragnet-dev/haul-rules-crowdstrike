// Dragnet [Ransomware]: dragnet-ransomware-2025-0600 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: b2be7413-de3b-53df-9dff-4b55190ae6d5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
