// Dragnet [Ransomware]: dragnet-ransomware-2026-1114 — Mass File Rename (thegentlemen)
// Status: test | Level: high | ID: 25d03d3f-9617-5bc2-93aa-a9bc5bf08e7d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
