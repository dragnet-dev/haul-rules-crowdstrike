// Dragnet [Ransomware]: dragnet-ransomware-2024-0248 — Mass File Rename (underground)
// Status: experimental | Level: high | ID: d8880d77-bcd3-50f8-a99c-28ad9cb233ea

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
