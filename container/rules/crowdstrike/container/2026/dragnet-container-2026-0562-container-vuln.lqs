// Dragnet [Container]: dragnet-container-2026-0562 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 019774ee-2995-5af4-a682-d895195ce650

#event_simpleName=*
| (ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *ubuntu:12.04*)
| table([timestamp, ComputerName])
| limit(1000)
