// Dragnet [Ransomware]: dragnet-ransomware-2025-3372 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: e22983c1-aa54-5ee5-9a9c-1b1b30a0e947

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
