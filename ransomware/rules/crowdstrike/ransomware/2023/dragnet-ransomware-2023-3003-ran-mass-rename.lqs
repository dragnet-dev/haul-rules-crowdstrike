// Dragnet [Ransomware]: dragnet-ransomware-2023-3003 — Mass File Rename (stormous)
// Status: deprecated | Level: high | ID: e18689f1-f99b-57ae-935b-91ab141c93e8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
