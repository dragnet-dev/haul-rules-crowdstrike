// Dragnet [Ransomware]: dragnet-ransomware-2022-0282 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 1ab05a1e-a664-579e-9c2c-9b57c94072b4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
