// Dragnet [Ransomware]: dragnet-ransomware-2025-5812 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 6814adc1-a3fd-5f5f-b06c-8c774ce5f136

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
