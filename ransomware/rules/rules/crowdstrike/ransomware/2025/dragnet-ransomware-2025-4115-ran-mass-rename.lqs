// Dragnet [Ransomware]: dragnet-ransomware-2025-4115 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 951e3148-2c86-517d-9a9a-bf03986aa45b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
