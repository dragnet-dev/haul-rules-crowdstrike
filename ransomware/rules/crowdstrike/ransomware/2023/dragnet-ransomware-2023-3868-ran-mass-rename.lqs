// Dragnet [Ransomware]: dragnet-ransomware-2023-3868 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 051f0139-74f1-59b9-9863-0c541b434e81

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
