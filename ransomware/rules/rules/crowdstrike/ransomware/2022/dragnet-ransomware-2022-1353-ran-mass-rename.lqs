// Dragnet [Ransomware]: dragnet-ransomware-2022-1353 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 212458cf-4365-5ab7-bdfb-8ef672303fa8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
