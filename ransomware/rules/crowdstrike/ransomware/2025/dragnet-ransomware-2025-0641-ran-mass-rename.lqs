// Dragnet [Ransomware]: dragnet-ransomware-2025-0641 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 1a43cce1-4398-5d9a-b3ee-a9418ff59ee3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
