// Dragnet [Container]: dragnet-container-2024-0207 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 08d74ba9-a864-5231-8d2c-161397931167

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
