// Dragnet [Ransomware]: dragnet-ransomware-2024-1658 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: d7b8f0c0-91b9-5421-9cfa-61af84564b92

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
