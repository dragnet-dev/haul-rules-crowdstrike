// Dragnet [Container]: dragnet-container-2026-1592 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 77712f05-d74f-5791-8c57-1e5ceb3d85a6

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:5*)
| table([timestamp, ComputerName])
| limit(1000)
