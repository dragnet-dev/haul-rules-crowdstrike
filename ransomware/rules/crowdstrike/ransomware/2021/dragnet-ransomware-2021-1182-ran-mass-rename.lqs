// Dragnet [Ransomware]: dragnet-ransomware-2021-1182 — Mass File Rename (azroteam)
// Status: deprecated | Level: high | ID: 46845143-5b4d-5dc4-9456-fd858749e3f1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
