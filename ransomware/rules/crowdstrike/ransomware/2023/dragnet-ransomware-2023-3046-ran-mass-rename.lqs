// Dragnet [Ransomware]: dragnet-ransomware-2023-3046 — Mass File Rename (ransomed)
// Status: experimental | Level: high | ID: 2e07bede-606a-51ce-93a6-4d68bde785e9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
