// Dragnet [Ransomware]: dragnet-ransomware-2025-4522 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 27b2ebfa-ddce-541f-86a1-d4d3d99e97dc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
