// Dragnet [Ransomware]: dragnet-ransomware-2025-1067 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: 67ae1786-c696-5f0f-b7bb-a3088477a2cf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
