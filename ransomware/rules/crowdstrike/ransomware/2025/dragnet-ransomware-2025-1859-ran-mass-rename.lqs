// Dragnet [Ransomware]: dragnet-ransomware-2025-1859 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 81ff80c7-f304-5fae-995f-aade69a0603e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
