// Dragnet [Ransomware]: dragnet-ransomware-2025-1503 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: b9304761-e092-5e9f-ab98-8491e592be58

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
