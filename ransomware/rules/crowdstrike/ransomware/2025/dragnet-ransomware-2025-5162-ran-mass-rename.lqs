// Dragnet [Ransomware]: dragnet-ransomware-2025-5162 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 21f162c7-c890-5ed0-bd63-184f566cf924

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
