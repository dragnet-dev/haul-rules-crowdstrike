// Dragnet [Ransomware]: dragnet-ransomware-2023-4980 — Mass File Rename (stormous)
// Status: experimental | Level: high | ID: 37602f30-2abe-5a73-9af0-019889ae80ba

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
