// Dragnet [Ransomware]: dragnet-ransomware-2024-4893 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 3497b625-0f44-5bc4-bb68-42290accdcb2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
