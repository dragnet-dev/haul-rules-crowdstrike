// Dragnet [Ransomware]: dragnet-ransomware-2025-2208 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: 79b823ea-c378-5a9a-903b-4a68a9a9bd8f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
