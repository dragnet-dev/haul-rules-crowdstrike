// Dragnet [Ransomware]: dragnet-ransomware-2024-2788 — Mass File Rename (dragonforce)
// Status: deprecated | Level: high | ID: d23a1d87-b240-57ec-ad59-84b6b2dcf291

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
