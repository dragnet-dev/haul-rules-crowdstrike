// Dragnet [Ransomware]: dragnet-ransomware-2025-2630 — Mass File Rename (d4rk4rmy)
// Status: deprecated | Level: high | ID: e8d01705-b0c0-5701-9310-4b16c79c75c1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
