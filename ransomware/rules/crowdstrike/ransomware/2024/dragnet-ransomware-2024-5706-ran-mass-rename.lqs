// Dragnet [Ransomware]: dragnet-ransomware-2024-5706 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 07a0e4f6-5110-57a1-b0cd-b6b831172316

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
