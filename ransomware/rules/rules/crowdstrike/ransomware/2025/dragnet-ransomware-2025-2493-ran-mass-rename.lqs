// Dragnet [Ransomware]: dragnet-ransomware-2025-2493 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 8827cba9-6075-517f-8fcf-be5c2a0bd15f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
