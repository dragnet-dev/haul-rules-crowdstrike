// Dragnet [Ransomware]: dragnet-ransomware-2025-3953 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 256d3e28-8f02-5152-b6c1-a0dd510e28fd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
