// Dragnet [Ransomware]: dragnet-ransomware-2024-3970 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 1045da3a-9a60-53fc-a8c4-29d041a05365

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
