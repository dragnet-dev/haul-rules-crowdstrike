// Dragnet [Ransomware]: dragnet-ransomware-2023-2985 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 672ca467-d15f-5071-8102-55421049be1d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
