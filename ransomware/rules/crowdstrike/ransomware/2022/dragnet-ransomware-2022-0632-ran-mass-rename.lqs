// Dragnet [Ransomware]: dragnet-ransomware-2022-0632 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: c4b1be62-6abc-5cd2-bcd7-a307808a1eb0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
