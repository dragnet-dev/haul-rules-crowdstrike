// Dragnet [Ransomware]: dragnet-ransomware-2025-6828 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: a6c0ca3a-0297-54df-80c0-df9b6ad1fa1d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
