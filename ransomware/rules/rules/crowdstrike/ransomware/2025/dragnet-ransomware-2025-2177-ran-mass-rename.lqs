// Dragnet [Ransomware]: dragnet-ransomware-2025-2177 — Mass File Rename (play)
// Status: experimental | Level: high | ID: bdff9d9c-993f-5e16-a8d5-328634365a8c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
