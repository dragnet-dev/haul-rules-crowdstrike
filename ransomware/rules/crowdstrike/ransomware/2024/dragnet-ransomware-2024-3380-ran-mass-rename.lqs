// Dragnet [Ransomware]: dragnet-ransomware-2024-3380 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: b0fb3860-c711-5385-86d1-c55d640ce680

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
