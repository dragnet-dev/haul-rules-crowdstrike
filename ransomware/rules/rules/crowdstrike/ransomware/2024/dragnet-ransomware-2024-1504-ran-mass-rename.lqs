// Dragnet [Ransomware]: dragnet-ransomware-2024-1504 — Mass File Rename (blackout)
// Status: experimental | Level: high | ID: f39e56c3-c12b-5e33-b424-6b26fa2fc739

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
