// Dragnet [Ransomware]: dragnet-ransomware-2021-0827 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 32e83724-6351-5858-a058-de370e0ed715

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
