// Dragnet [Ransomware]: dragnet-ransomware-2023-1079 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 67f66c9d-9675-5261-9f62-3a6fa9ac9a65

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
