// Dragnet [Ransomware]: dragnet-ransomware-2023-4406 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 8f4dba50-164a-5ec9-a21c-f3c87c609b9c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
