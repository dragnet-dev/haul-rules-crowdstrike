// Dragnet [Ransomware]: dragnet-ransomware-2025-7478 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 3d148ff0-1dda-5a11-877f-73beec1e8698

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
