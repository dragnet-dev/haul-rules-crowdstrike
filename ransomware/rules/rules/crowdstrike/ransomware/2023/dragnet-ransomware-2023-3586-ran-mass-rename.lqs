// Dragnet [Ransomware]: dragnet-ransomware-2023-3586 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 867b1343-7398-5929-9232-5f4d219cb21a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
