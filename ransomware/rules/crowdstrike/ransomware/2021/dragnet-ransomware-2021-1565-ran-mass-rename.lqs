// Dragnet [Ransomware]: dragnet-ransomware-2021-1565 — Mass File Rename (payloadbin)
// Status: deprecated | Level: high | ID: 09d30316-c031-5a9b-b56a-adf8f1d16528

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
