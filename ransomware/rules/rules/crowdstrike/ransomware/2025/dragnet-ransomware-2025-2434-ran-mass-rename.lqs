// Dragnet [Ransomware]: dragnet-ransomware-2025-2434 — Mass File Rename (thegentlemen)
// Status: experimental | Level: high | ID: db205f9f-a965-5b09-86a9-f1c859cab8b6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
