// Dragnet [Ransomware]: dragnet-ransomware-2021-0548 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: abc2e638-7159-5450-8d3b-98e556358f08

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
