// Dragnet [Ransomware]: dragnet-ransomware-2024-4124 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 3277e99b-3ea2-556b-8125-5e1f5390ef7c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
