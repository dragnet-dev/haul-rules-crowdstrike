// Dragnet [Ransomware]: dragnet-ransomware-2024-2727 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 864181b3-4f8c-575c-b98f-4819cf1a18b3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
