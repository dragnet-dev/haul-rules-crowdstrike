// Dragnet [Ransomware]: dragnet-ransomware-2026-3244 — Mass File Rename (AiLock)
// Status: deprecated | Level: high | ID: 2a88f9dc-27b2-5722-82e7-9010555c0589

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
