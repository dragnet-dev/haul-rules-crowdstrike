// Dragnet [Ransomware]: dragnet-ransomware-2024-2807 — Mass File Rename (cicada3301)
// Status: experimental | Level: high | ID: 27ee3b04-deda-59fa-b3a9-a482cfd3b522

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
