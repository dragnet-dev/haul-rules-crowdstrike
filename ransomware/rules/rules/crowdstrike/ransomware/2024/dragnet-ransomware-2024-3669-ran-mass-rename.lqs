// Dragnet [Ransomware]: dragnet-ransomware-2024-3669 — Mass File Rename (kairos)
// Status: experimental | Level: high | ID: f8edd7cc-782f-557f-ba74-6001363a8746

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
