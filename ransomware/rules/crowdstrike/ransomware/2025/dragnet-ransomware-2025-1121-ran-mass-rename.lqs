// Dragnet [Ransomware]: dragnet-ransomware-2025-1121 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 0070b3e6-50c9-5a6e-a329-64aefc649713

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
