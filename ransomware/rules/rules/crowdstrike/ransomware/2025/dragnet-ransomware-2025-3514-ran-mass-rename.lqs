// Dragnet [Ransomware]: dragnet-ransomware-2025-3514 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: ab5617ff-1850-5cef-a20f-d5b343bc5a5e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
