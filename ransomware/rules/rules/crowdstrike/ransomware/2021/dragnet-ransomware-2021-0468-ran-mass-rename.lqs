// Dragnet [Ransomware]: dragnet-ransomware-2021-0468 — Mass File Rename (groove)
// Status: deprecated | Level: high | ID: fd4c154a-fb3d-5619-afda-1b866bf174e8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
