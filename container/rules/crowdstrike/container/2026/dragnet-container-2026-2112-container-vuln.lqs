// Dragnet [Container]: dragnet-container-2026-2112 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 18192add-0638-5c2d-8345-2da31dd77bec

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:5*)
| table([timestamp, ComputerName])
| limit(1000)
