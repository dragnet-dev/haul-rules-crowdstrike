// Dragnet [Ransomware]: dragnet-ransomware-2023-3222 — Mass File Rename (stormous)
// Status: experimental | Level: high | ID: e61e9b1f-a2ad-57bd-9346-5a429c335fec

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
