// Dragnet [Ransomware]: dragnet-ransomware-2021-1575 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 9129a839-93a7-57ff-b37f-b39a672dfb29

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
