// Dragnet [Ransomware]: dragnet-ransomware-2022-1773 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 293202b5-6326-58cc-995d-a0424b6eb255

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
