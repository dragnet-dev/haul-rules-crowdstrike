// Dragnet [Ransomware]: dragnet-ransomware-2026-2887 — Mass File Rename (interlock)
// Status: stable | Level: high | ID: f0e7419c-30e5-5b88-be23-8617117d77d2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
