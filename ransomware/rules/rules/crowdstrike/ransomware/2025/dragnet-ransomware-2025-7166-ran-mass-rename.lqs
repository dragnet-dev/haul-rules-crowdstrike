// Dragnet [Ransomware]: dragnet-ransomware-2025-7166 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 42668e6d-6950-57c5-bfd4-b9c5294b5e6c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
