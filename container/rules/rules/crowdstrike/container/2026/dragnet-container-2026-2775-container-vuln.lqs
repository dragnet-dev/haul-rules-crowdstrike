// Dragnet [Container]: dragnet-container-2026-2775 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 29bae805-6eb3-5381-b941-bef454a99377

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6*)
| table([timestamp, ComputerName])
| limit(1000)
