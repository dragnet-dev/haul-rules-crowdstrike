// Dragnet [Ransomware]: dragnet-ransomware-2024-0206 — Mass File Rename (ciphbit)
// Status: deprecated | Level: high | ID: 4429286a-ab92-5757-ad03-962c080923bf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
