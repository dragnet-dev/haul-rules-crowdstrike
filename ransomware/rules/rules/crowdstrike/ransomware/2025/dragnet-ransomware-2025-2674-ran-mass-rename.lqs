// Dragnet [Ransomware]: dragnet-ransomware-2025-2674 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: d5a10855-9333-5ce3-a226-831bc044d6ff

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
