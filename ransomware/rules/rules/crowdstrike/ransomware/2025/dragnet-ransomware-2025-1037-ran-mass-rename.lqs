// Dragnet [Ransomware]: dragnet-ransomware-2025-1037 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 644ec50a-fae9-51a1-96e3-11bb10607d0b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
