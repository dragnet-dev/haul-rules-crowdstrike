// Dragnet [Ransomware]: dragnet-ransomware-2020-0215 — Mass File Rename (maze)
// Status: deprecated | Level: high | ID: 7f9f1dac-564b-5151-9f1c-fb2211d35e8b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
