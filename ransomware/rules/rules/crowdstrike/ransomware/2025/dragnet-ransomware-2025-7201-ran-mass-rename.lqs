// Dragnet [Ransomware]: dragnet-ransomware-2025-7201 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 2248655f-3a0a-505f-8c03-a8ffa1baa22c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
