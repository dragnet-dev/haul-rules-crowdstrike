// Dragnet [Ransomware]: dragnet-ransomware-2024-2410 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 2adc84f0-f503-5a8d-8b8d-0a9a0c8acd3a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
