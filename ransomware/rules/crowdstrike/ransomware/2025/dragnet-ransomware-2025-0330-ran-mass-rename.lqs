// Dragnet [Ransomware]: dragnet-ransomware-2025-0330 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: f231089b-58d7-5e48-957b-b2af9fd0e0c8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
