// Dragnet [Ransomware]: dragnet-ransomware-2025-2523 — Mass File Rename (arcusmedia)
// Status: experimental | Level: high | ID: 115a8924-27f8-579a-a4e3-3c855a10be1a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
