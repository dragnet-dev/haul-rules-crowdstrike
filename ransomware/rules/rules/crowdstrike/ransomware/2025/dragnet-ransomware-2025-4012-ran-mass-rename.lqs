// Dragnet [Ransomware]: dragnet-ransomware-2025-4012 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: 6bcd4166-fe5a-5118-a8e1-da9c3b7608a0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
