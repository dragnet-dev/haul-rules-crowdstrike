// Dragnet [Ransomware]: dragnet-ransomware-2022-0936 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: fb27854f-e527-526a-909f-e347e7af2d7a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
