// Dragnet [Ransomware]: dragnet-ransomware-2025-1757 — Mass File Rename (devman)
// Status: experimental | Level: high | ID: c7b45073-8b79-59c3-9f57-9021a267d93f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
