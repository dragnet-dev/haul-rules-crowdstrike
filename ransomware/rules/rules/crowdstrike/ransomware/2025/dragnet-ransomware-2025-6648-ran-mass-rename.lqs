// Dragnet [Ransomware]: dragnet-ransomware-2025-6648 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: f9dab3c1-6119-5e7f-b436-6bfacbb1b498

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
