// Dragnet [Ransomware]: dragnet-ransomware-2026-1972 — Mass File Rename (BrainCipher)
// Status: stable | Level: high | ID: d38a388d-0eb8-543c-ab77-0ecc1222b2c6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
