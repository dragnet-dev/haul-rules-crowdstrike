// Dragnet [Ransomware]: dragnet-ransomware-2023-5376 — Mass File Rename (abyss)
// Status: deprecated | Level: high | ID: 2ccab48e-44d7-5410-80e2-d66e4b94f5b0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
