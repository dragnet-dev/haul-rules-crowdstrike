// Dragnet [Ransomware]: dragnet-ransomware-2022-0780 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: f65fb709-dbc3-5000-91b9-a3ad477f39eb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
