// Dragnet [Ransomware]: dragnet-ransomware-2024-3379 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: ba6bb568-0c69-587b-a41a-b400fab0d5e8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
