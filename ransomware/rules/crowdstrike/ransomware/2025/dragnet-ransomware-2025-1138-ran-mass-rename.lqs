// Dragnet [Ransomware]: dragnet-ransomware-2025-1138 — Mass File Rename (interlock)
// Status: experimental | Level: high | ID: 11add4e2-4115-54de-a790-f5e721ff501c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
