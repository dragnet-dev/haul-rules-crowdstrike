// Dragnet [Ransomware]: dragnet-ransomware-2021-1341 — Mass File Rename (ragnarlocker)
// Status: deprecated | Level: high | ID: 068e4fa0-1f26-557d-9118-c427548b8b21

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
