// Dragnet [Ransomware]: dragnet-ransomware-2023-4597 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: e7df1c79-a6f3-5888-87cd-6018601f243e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
