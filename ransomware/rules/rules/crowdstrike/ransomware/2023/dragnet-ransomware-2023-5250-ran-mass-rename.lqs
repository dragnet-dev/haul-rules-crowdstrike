// Dragnet [Ransomware]: dragnet-ransomware-2023-5250 — Mass File Rename (ransomed)
// Status: experimental | Level: high | ID: 25807bfc-373a-551e-80f7-3e749d08d15c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
