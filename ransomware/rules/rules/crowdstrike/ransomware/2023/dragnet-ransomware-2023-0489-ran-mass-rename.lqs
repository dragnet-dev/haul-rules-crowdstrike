// Dragnet [Ransomware]: dragnet-ransomware-2023-0489 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 8973c8c6-8ac1-5643-9ea7-327bd5bd9976

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
