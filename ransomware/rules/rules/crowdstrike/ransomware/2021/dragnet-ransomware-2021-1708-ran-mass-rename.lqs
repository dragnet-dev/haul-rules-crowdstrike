// Dragnet [Ransomware]: dragnet-ransomware-2021-1708 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: c92d6da7-ea49-5564-80ac-3222839342e3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
