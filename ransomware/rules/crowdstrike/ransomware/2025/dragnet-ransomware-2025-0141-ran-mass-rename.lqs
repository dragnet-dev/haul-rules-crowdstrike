// Dragnet [Ransomware]: dragnet-ransomware-2025-0141 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 61afcc86-71d4-53c7-8a35-72fb04c0c2e7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
