// Dragnet [Ransomware]: dragnet-ransomware-2023-4194 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: bf1c2987-98a5-54fe-9ad3-4b0ecc147786

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
