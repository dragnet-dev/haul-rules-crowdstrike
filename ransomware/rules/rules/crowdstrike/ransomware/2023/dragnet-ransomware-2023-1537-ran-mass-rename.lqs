// Dragnet [Ransomware]: dragnet-ransomware-2023-1537 — Mass File Rename (threeam)
// Status: experimental | Level: high | ID: cef86680-5e05-5082-9cfb-8a156247a0ad

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
