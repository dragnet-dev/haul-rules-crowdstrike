// Dragnet [Ransomware]: dragnet-ransomware-2025-1923 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: 3c578d54-8105-50fa-a7e2-d6716081d222

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
