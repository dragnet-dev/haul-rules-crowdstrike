// Dragnet [Ransomware]: dragnet-ransomware-2024-3838 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: b02caae0-a725-5b39-893b-3655b0de3081

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
