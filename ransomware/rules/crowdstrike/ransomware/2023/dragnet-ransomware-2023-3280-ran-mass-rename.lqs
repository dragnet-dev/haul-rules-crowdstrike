// Dragnet [Ransomware]: dragnet-ransomware-2023-3280 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: c5feb70f-9d2f-538d-a938-a1dfe67f7940

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
