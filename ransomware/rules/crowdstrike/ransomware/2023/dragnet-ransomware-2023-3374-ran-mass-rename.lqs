// Dragnet [Ransomware]: dragnet-ransomware-2023-3374 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: ed64d993-9261-5b80-940e-bc6efbcaba68

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
