// Dragnet [Ransomware]: dragnet-ransomware-2025-6502 — Mass File Rename (warlock)
// Status: deprecated | Level: high | ID: 40dc6f4c-59ce-5921-af3c-269142783781

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
