// Dragnet [Ransomware]: dragnet-ransomware-2026-1393 — Mass File Rename (dragonforce)
// Status: test | Level: high | ID: a99c04cb-564f-5077-b252-4611306715c7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
