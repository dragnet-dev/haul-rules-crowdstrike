// Dragnet [Ransomware]: dragnet-ransomware-2023-0349 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: 02f60e47-af30-5b47-a4a2-50f606b5dcd0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
