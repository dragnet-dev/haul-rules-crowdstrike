// Dragnet [Ransomware]: dragnet-ransomware-2022-3150 — Mass File Rename (quantum)
// Status: deprecated | Level: high | ID: 96eddbf8-6119-53d8-b2ff-5c87de82eac9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
