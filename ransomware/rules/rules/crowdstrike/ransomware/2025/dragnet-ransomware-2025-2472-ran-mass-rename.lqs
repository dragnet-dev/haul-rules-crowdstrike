// Dragnet [Ransomware]: dragnet-ransomware-2025-2472 — Mass File Rename (thegentlemen)
// Status: test | Level: high | ID: f6973f7e-9725-5bc6-a95c-c946031e7a9b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
