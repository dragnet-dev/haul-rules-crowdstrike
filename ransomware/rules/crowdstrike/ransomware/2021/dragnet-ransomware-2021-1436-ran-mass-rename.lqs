// Dragnet [Ransomware]: dragnet-ransomware-2021-1436 — Mass File Rename (marketo)
// Status: deprecated | Level: high | ID: 2c3589c4-29dd-5f9c-8202-fde8ca0ca7f7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
