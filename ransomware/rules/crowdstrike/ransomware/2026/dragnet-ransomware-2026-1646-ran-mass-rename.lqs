// Dragnet [Ransomware]: dragnet-ransomware-2026-1646 — Mass File Rename (kairos)
// Status: deprecated | Level: high | ID: b52d7a67-43d8-52d9-b1e7-0d52a1298581

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
