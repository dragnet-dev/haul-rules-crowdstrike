// Dragnet [Ransomware]: dragnet-ransomware-2025-0444 — Mass File Rename (nightspire)
// Status: deprecated | Level: high | ID: b28f30c1-7dc3-58db-b7a9-2113098c8de8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
