// Dragnet [Ransomware]: dragnet-ransomware-2023-0676 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: eaca411c-aeba-50ac-bb99-d0aed8116284

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
