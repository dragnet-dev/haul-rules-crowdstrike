// Dragnet [Ransomware]: dragnet-ransomware-2024-5055 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: a2422c93-42e5-5661-a27e-32d94a22fb21

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
