// Dragnet [Ransomware]: dragnet-ransomware-2026-0710 — Mass File Rename (payoutsking)
// Status: stable | Level: high | ID: 81813c4f-ef8a-5dc6-a7cf-910efd15d9f1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
