// Dragnet [Ransomware]: dragnet-ransomware-2023-5277 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 0a10d5bc-796a-58ef-8716-994746dba221

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
