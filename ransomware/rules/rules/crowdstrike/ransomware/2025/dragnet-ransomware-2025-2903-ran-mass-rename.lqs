// Dragnet [Ransomware]: dragnet-ransomware-2025-2903 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 11514374-bab7-55b0-b09e-05b43db3fb79

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
