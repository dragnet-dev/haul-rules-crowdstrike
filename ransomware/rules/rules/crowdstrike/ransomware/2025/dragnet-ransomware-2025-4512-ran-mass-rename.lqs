// Dragnet [Ransomware]: dragnet-ransomware-2025-4512 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: acf116ea-0fd7-541e-b0e2-62bf3aaf2119

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
