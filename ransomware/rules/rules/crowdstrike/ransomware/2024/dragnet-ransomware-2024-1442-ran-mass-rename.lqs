// Dragnet [Ransomware]: dragnet-ransomware-2024-1442 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 08140404-b944-5b23-89f1-94f27bc2e853

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
