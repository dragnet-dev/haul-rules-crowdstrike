// Dragnet [Ransomware]: dragnet-ransomware-2024-3686 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 45a132be-6103-5dce-9e3d-9372937b7d57

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
