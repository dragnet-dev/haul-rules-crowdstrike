// Dragnet [Ransomware]: dragnet-ransomware-2025-3945 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 17a25cb8-f539-59b6-afcb-85483a0eacf1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
