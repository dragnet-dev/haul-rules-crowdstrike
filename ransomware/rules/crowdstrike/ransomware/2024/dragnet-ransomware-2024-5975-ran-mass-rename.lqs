// Dragnet [Ransomware]: dragnet-ransomware-2024-5975 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 9185f861-083a-50b1-85e2-8a0670e04c1b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
