// Dragnet [Ransomware]: dragnet-ransomware-2021-1063 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 20348950-cdea-5b46-9f23-36c3ab02d420

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
