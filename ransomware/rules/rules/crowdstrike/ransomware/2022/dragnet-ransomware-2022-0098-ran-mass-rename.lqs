// Dragnet [Ransomware]: dragnet-ransomware-2022-0098 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 2e435bab-287b-542c-9180-2d3dc2bdc7ab

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
