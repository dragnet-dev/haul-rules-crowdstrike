// Dragnet [Ransomware]: dragnet-ransomware-2025-1312 — Mass File Rename (radar)
// Status: deprecated | Level: high | ID: 1349beb2-fbba-530a-8a7e-a83758999121

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
