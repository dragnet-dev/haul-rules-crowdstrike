// Dragnet [Ransomware]: dragnet-ransomware-2026-2215 — Mass File Rename (blackwater)
// Status: stable | Level: high | ID: 1fe63b18-34f5-5717-90ee-3086a5d37894

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
