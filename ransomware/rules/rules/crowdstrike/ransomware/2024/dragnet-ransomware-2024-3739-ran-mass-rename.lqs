// Dragnet [Ransomware]: dragnet-ransomware-2024-3739 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 36149af1-d626-5cea-acde-9b7823e863d8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
