// Dragnet [Ransomware]: dragnet-ransomware-2022-1345 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: d67ee901-2622-5b0e-aa60-f34a7143c480

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
