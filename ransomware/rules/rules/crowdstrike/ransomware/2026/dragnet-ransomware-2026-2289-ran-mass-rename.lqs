// Dragnet [Ransomware]: dragnet-ransomware-2026-2289 — Mass File Rename (netrunner)
// Status: stable | Level: high | ID: 42ff3fa0-b49a-5537-8ca9-399622e2f4d0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
