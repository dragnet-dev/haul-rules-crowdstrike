// Dragnet [Ransomware]: dragnet-ransomware-2023-2361 — Mass File Rename (monti)
// Status: experimental | Level: high | ID: 74948759-4ae0-5ad3-9e58-3f75f41fdcb2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
