// Dragnet [Ransomware]: dragnet-ransomware-2025-2835 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 73a20c6f-af1a-5538-998f-6f872cd437aa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
