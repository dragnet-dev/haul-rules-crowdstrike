// Dragnet [Ransomware]: dragnet-ransomware-2025-2006 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: a6b37313-4e3d-5999-9da3-c71e75d37558

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
