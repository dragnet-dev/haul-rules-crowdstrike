// Dragnet [Ransomware]: dragnet-ransomware-2025-0225 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: f95123a5-9740-5891-a028-8964d3d6b7e7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
