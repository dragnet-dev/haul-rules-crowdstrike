// Dragnet [Ransomware]: dragnet-ransomware-2025-4082 — Mass File Rename (anubis)
// Status: experimental | Level: high | ID: 7b52d650-cd3d-5551-a8cf-98fccb9e1e77

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
