// Dragnet [Ransomware]: dragnet-ransomware-2023-1502 — Mass File Rename (ElDorado)
// Status: deprecated | Level: high | ID: 29142e05-d393-5adb-87ec-6c1c51aeafcd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
