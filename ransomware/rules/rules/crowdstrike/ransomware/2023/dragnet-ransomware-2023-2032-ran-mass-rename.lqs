// Dragnet [Ransomware]: dragnet-ransomware-2023-2032 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 605636aa-3073-5dd2-a7cd-08b1074b6dc0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
