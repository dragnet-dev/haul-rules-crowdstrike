// Dragnet [Ransomware]: dragnet-ransomware-2024-6001 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 5c2634dc-b8c2-51cd-a995-283976ea048a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
