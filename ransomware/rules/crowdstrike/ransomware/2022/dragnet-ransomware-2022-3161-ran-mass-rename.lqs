// Dragnet [Ransomware]: dragnet-ransomware-2022-3161 — Mass File Rename (blackbasta)
// Status: deprecated | Level: high | ID: 9c185e74-f3ef-5a77-8468-cf31ebd5e827

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
