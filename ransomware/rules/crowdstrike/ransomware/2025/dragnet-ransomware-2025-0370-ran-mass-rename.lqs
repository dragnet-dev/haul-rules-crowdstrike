// Dragnet [Ransomware]: dragnet-ransomware-2025-0370 — Mass File Rename (play)
// Status: experimental | Level: high | ID: ed799768-fc12-5081-96fc-8e506fe1b011

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
