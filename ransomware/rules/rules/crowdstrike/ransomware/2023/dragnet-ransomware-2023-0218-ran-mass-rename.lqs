// Dragnet [Ransomware]: dragnet-ransomware-2023-0218 — Mass File Rename (play)
// Status: experimental | Level: high | ID: f5edcc66-b5aa-5ca6-aa90-1a86d7cb7a62

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
