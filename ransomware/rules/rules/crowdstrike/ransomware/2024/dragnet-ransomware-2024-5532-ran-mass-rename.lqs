// Dragnet [Ransomware]: dragnet-ransomware-2024-5532 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: 6c1c4820-0162-53d4-b822-1b49c4e8120c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
