// Dragnet [Ransomware]: dragnet-ransomware-2022-0419 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: a93416b8-e7f8-52a5-b5eb-c4851b61af1b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
