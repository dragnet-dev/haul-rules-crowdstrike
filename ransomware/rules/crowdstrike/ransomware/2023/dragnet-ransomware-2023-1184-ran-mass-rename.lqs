// Dragnet [Ransomware]: dragnet-ransomware-2023-1184 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 515eb407-35ae-5d83-b113-53e5ce48b5f1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
