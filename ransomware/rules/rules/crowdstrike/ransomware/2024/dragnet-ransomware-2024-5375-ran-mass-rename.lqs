// Dragnet [Ransomware]: dragnet-ransomware-2024-5375 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 0d862c83-c423-5dc0-808b-8c010a31cb59

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
