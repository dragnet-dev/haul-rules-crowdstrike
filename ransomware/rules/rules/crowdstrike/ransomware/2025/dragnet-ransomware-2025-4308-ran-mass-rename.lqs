// Dragnet [Ransomware]: dragnet-ransomware-2025-4308 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: daff9a22-ce85-5ab2-b6c4-0f1c5f5add44

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
