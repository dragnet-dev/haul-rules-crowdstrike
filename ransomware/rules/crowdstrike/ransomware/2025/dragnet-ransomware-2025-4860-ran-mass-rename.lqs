// Dragnet [Ransomware]: dragnet-ransomware-2025-4860 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 4a8bfae8-79d7-5807-88f4-bebd85b02f7b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
