// Dragnet [Ransomware]: dragnet-ransomware-2024-1208 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: bae04002-a606-5e54-8a0a-b939f79702c8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
