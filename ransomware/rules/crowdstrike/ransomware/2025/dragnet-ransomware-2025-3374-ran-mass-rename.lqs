// Dragnet [Ransomware]: dragnet-ransomware-2025-3374 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 6eb92c82-af89-5b47-afab-b018ec6857b6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
