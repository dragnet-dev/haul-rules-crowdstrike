// Dragnet [Ransomware]: dragnet-ransomware-2023-3328 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 9846fdc7-d54d-55b3-bf31-599aee5f8b9b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
