// Dragnet [Ransomware]: dragnet-ransomware-2025-1146 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 085eef0c-2a41-5e04-933c-a4d326e6b4da

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
