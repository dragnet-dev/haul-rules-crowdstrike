// Dragnet [Ransomware]: dragnet-ransomware-2022-0661 — Mass File Rename (ransomexx)
// Status: deprecated | Level: high | ID: f817d1cd-d762-5161-bfc4-27de40efc941

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
