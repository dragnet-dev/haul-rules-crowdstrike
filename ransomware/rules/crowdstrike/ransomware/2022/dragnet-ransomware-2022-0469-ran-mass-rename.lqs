// Dragnet [Ransomware]: dragnet-ransomware-2022-0469 — Mass File Rename (royal)
// Status: deprecated | Level: high | ID: 625a10bb-776d-5434-b1b2-444cabf67603

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
