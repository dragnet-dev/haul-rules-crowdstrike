// Dragnet [Ransomware]: dragnet-ransomware-2025-6008 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 45701cae-65c1-54cc-900a-6b0a481b772e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
