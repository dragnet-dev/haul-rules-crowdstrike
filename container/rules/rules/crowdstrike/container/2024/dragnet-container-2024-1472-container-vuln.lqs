// Dragnet [Container]: dragnet-container-2024-1472 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 6fcbf5a9-7404-5fcb-906f-b8abbbab6ef0

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:9* OR ImageFileName = *ubuntu:18.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
