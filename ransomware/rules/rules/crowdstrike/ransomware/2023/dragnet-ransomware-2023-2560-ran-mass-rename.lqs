// Dragnet [Ransomware]: dragnet-ransomware-2023-2560 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: ff36e4a6-a01d-5d1c-bf70-1c77bd911d7b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
