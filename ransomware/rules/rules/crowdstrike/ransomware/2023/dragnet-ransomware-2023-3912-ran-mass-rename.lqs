// Dragnet [Ransomware]: dragnet-ransomware-2023-3912 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 0dc352e1-1f26-5185-a46c-25b5e9e3478e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
