// Dragnet [Ransomware]: dragnet-ransomware-2021-0747 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 9d1ff35e-8fab-5b1b-9461-343bfd53ba9e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
