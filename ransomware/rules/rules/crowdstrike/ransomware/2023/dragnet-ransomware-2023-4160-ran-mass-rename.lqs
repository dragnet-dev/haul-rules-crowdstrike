// Dragnet [Ransomware]: dragnet-ransomware-2023-4160 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 777b9332-fb8f-5cae-9bb3-ef118b5c11d2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
