// Dragnet [Ransomware]: dragnet-ransomware-2025-0541 — Mass File Rename (lockbit5)
// Status: experimental | Level: high | ID: 2089cd4d-821f-5f9f-9539-f382abaa4976

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
