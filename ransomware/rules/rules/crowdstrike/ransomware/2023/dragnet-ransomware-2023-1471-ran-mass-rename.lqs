// Dragnet [Ransomware]: dragnet-ransomware-2023-1471 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 987c9b7a-1404-58a3-ae4e-1888bf25cc74

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
