// Dragnet [Ransomware]: dragnet-ransomware-2026-1028 — Mass File Rename (thegentlemen)
// Status: test | Level: high | ID: ec311e72-c577-5f48-ae7f-d3e638b2b261

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
