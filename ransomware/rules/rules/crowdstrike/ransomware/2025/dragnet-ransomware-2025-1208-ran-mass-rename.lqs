// Dragnet [Ransomware]: dragnet-ransomware-2025-1208 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 2d5531ba-7e84-5dac-8e3b-a9971d1bc9e5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
