// Dragnet [Ransomware]: dragnet-ransomware-2025-2884 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 4bd992eb-4923-5413-b7e1-ca8f5555ee18

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
