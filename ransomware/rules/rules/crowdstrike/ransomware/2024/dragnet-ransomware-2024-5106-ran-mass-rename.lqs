// Dragnet [Ransomware]: dragnet-ransomware-2024-5106 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 2fd4031b-f9a3-52ab-9c90-cfb9b852971c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
