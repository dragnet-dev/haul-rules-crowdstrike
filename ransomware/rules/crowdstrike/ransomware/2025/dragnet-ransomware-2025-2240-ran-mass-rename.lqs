// Dragnet [Ransomware]: dragnet-ransomware-2025-2240 — Mass File Rename (chaos)
// Status: experimental | Level: high | ID: 189db850-e44b-5273-9f35-996f21e521ef

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
