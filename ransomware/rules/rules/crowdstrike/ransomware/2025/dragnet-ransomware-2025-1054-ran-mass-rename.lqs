// Dragnet [Ransomware]: dragnet-ransomware-2025-1054 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: bcbf35b2-9d1d-5fd1-9839-cbbaa7011045

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
