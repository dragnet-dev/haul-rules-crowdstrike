// Dragnet [Ransomware]: dragnet-ransomware-2025-5235 — Mass File Rename (spacebears)
// Status: experimental | Level: high | ID: 24e77f2a-9c8b-5f89-915b-ea6b7baf0b40

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
