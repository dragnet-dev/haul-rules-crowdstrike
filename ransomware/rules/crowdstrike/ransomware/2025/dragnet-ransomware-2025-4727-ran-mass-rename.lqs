// Dragnet [Ransomware]: dragnet-ransomware-2025-4727 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 30587273-6e26-5108-ae9c-9275b4f5f976

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
