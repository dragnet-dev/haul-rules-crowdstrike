// Dragnet [Ransomware]: dragnet-ransomware-2025-6276 — Mass File Rename (sinobi)
// Status: experimental | Level: high | ID: f3238d46-bdde-55b3-9086-b6571391863e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
