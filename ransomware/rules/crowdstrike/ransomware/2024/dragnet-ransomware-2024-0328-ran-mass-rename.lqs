// Dragnet [Ransomware]: dragnet-ransomware-2024-0328 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 3fb05a99-1578-553d-929f-46c8e76f165c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
