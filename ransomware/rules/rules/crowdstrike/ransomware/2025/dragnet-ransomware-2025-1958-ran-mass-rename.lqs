// Dragnet [Ransomware]: dragnet-ransomware-2025-1958 — Mass File Rename (ransomhouse)
// Status: experimental | Level: high | ID: bdd8550f-55c8-52cd-96ef-f00d939a6700

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
