// Dragnet [Ransomware]: dragnet-ransomware-2022-0834 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: 92243c07-3733-5448-9330-21d67d9dd2cf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
