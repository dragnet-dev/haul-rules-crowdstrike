// Dragnet [Ransomware]: dragnet-ransomware-2024-2174 — Mass File Rename (cloak)
// Status: deprecated | Level: high | ID: 5cac91a0-cbd4-5fe4-af07-7ad04a710096

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
