// Dragnet [Ransomware]: dragnet-ransomware-2022-0616 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: fbf180b4-20b8-5efd-838d-a6bc3b6fdb41

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
