// Dragnet [Ransomware]: dragnet-ransomware-2024-3885 — Mass File Rename (dunghill)
// Status: experimental | Level: high | ID: 27cbc0b4-e5f3-5bd3-b2e9-40a4c4cf3660

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
