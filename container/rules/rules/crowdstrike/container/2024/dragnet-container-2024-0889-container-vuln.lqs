// Dragnet [Container]: dragnet-container-2024-0889 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 35ea38f8-debd-5711-b9af-3578049e2459

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
