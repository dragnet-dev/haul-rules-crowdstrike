// Dragnet [Ransomware]: dragnet-ransomware-2022-1380 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 996df57e-575e-5741-8ed4-d11d00bedb82

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
