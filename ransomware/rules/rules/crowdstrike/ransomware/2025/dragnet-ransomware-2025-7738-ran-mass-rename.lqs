// Dragnet [Ransomware]: dragnet-ransomware-2025-7738 — Mass File Rename (play)
// Status: experimental | Level: high | ID: a4ed76fc-a35a-5255-9d9c-7afed87ac911

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
