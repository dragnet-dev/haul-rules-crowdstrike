// Dragnet [Ransomware]: dragnet-ransomware-2021-1739 — Mass File Rename (cuba)
// Status: deprecated | Level: high | ID: c4239cf3-e8b2-53fa-a389-0ec6f23627f1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
