// Dragnet [Ransomware]: dragnet-ransomware-2023-1693 — Mass File Rename (noescape)
// Status: experimental | Level: high | ID: e1b64f1e-79ef-586d-ac7b-b8872bc839ce

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
