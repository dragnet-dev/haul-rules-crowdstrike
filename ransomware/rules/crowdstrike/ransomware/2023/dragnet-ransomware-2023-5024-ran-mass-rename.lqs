// Dragnet [Ransomware]: dragnet-ransomware-2023-5024 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 01961385-8e33-520a-817f-4b8712572079

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
