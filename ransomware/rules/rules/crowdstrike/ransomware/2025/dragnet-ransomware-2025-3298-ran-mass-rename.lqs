// Dragnet [Ransomware]: dragnet-ransomware-2025-3298 — Mass File Rename (embargo)
// Status: experimental | Level: high | ID: 3aa5e2c3-6ae5-52b8-870c-0f77a5d4e2ad

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
