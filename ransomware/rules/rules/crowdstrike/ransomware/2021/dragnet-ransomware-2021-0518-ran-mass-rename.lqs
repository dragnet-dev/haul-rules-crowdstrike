// Dragnet [Ransomware]: dragnet-ransomware-2021-0518 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 153a06eb-f3c8-54ad-815a-5436726127c3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
