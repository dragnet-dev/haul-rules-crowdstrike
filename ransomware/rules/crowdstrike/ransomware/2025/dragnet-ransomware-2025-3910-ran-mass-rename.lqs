// Dragnet [Ransomware]: dragnet-ransomware-2025-3910 — Mass File Rename (interlock)
// Status: experimental | Level: high | ID: 00b17b86-cc15-56a2-b4d0-afc4f1cba41a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
