// Dragnet [Ransomware]: dragnet-ransomware-2022-0389 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 3edf948f-19e1-5ac6-8605-215888acdbda

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
