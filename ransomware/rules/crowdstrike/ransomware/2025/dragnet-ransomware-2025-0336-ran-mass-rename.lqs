// Dragnet [Ransomware]: dragnet-ransomware-2025-0336 — Mass File Rename (shinyhunters)
// Status: experimental | Level: high | ID: e7bc9bcc-64f6-58e3-b456-39f5afe39ca6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
