// Dragnet [Ransomware]: dragnet-ransomware-2023-5203 — Mass File Rename (ciphbit)
// Status: deprecated | Level: high | ID: 5f33fcbd-1942-5bd4-8887-4ca1eb3278ab

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
