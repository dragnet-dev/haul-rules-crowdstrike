// Dragnet [Ransomware]: dragnet-ransomware-2026-2232 — Mass File Rename (shinyhunters)
// Status: deprecated | Level: high | ID: 7abae2f0-8d22-55e9-a967-cb1176664850

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
