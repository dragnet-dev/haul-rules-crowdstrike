// Dragnet [Ransomware]: dragnet-ransomware-2024-0468 — Mass File Rename (play)
// Status: experimental | Level: high | ID: a371f97e-8d31-508a-bc72-01e51e69b2d5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
