// Dragnet [Container]: dragnet-container-2024-1471 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: ab22767b-374b-546a-b749-59f6bd71c2e5

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *ubuntu:18.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
