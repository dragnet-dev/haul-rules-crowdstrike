// Dragnet [Ransomware]: dragnet-ransomware-2023-0702 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: c692f38a-7d4a-5f51-938c-d9e77c3b992a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
