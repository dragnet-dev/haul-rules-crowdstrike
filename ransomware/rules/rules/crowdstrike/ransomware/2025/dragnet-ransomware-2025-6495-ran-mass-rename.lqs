// Dragnet [Ransomware]: dragnet-ransomware-2025-6495 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 329cd5d6-da46-58b4-9f1d-0026610f45e8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
