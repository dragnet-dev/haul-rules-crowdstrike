// Dragnet [Ransomware]: dragnet-ransomware-2023-4238 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 725297e8-59a6-5615-a72a-55ab38b182f3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
