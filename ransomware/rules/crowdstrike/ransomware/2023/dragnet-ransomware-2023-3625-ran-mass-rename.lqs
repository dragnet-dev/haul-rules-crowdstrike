// Dragnet [Ransomware]: dragnet-ransomware-2023-3625 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: da49361e-3868-5fe9-a1b4-e6e13bf3330d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
