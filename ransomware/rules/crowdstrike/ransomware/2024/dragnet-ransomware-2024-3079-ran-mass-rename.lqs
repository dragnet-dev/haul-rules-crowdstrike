// Dragnet [Ransomware]: dragnet-ransomware-2024-3079 — Mass File Rename (arcusmedia)
// Status: experimental | Level: high | ID: b71e35bf-74af-52c4-8d3d-faf2c8fe9fd8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
