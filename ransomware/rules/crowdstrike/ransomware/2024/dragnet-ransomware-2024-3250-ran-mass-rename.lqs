// Dragnet [Ransomware]: dragnet-ransomware-2024-3250 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 4b6b7fee-029a-56a5-891d-061277276ab6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
