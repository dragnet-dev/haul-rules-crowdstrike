// Dragnet [Ransomware]: dragnet-ransomware-2025-6843 — Mass File Rename (desolator)
// Status: experimental | Level: high | ID: 512c20b9-737f-5333-a5b4-5a34d9d223ef

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
