// Dragnet [Ransomware]: dragnet-ransomware-2024-1583 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 2f889310-8a3e-5942-8747-9afc7f541378

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
