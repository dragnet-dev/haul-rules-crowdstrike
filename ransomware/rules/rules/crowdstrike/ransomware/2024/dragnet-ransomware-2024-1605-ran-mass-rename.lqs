// Dragnet [Ransomware]: dragnet-ransomware-2024-1605 — Mass File Rename (safepay)
// Status: deprecated | Level: high | ID: ce14600c-8079-541c-be97-ef0add5f00ed

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
