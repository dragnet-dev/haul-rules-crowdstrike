// Dragnet [Ransomware]: dragnet-ransomware-2022-1748 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: a1fc7727-f4f5-5114-90be-0f1a9e53630d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
