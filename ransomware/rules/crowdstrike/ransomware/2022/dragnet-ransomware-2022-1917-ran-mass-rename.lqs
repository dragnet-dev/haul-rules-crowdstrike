// Dragnet [Ransomware]: dragnet-ransomware-2022-1917 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 40dbab10-2d35-5040-8832-470363cb2815

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
