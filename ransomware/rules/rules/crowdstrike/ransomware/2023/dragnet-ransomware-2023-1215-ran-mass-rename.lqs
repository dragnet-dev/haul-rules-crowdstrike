// Dragnet [Ransomware]: dragnet-ransomware-2023-1215 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 8b887adf-73e9-525d-93d8-cd5cf38befbb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
