// Dragnet [Ransomware]: dragnet-ransomware-2025-1672 — Mass File Rename (worldleaks)
// Status: experimental | Level: high | ID: f0851352-7017-5ee7-8715-8e5b85baf01b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
