// Dragnet [Ransomware]: dragnet-ransomware-2022-1898 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: a9ab9dc7-18ef-5199-97be-971bd75b1bac

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
