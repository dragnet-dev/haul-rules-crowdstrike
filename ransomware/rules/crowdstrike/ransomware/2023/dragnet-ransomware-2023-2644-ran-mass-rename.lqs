// Dragnet [Ransomware]: dragnet-ransomware-2023-2644 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: a55ce1c4-fbc8-5b7d-9096-009bb44a2a83

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
