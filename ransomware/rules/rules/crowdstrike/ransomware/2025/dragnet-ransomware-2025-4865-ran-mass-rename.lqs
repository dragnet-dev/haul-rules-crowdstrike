// Dragnet [Ransomware]: dragnet-ransomware-2025-4865 — Mass File Rename (insomnia)
// Status: experimental | Level: high | ID: ad6e49b8-d690-5adb-a435-1cec6bc80bdc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
