// Dragnet [Ransomware]: dragnet-ransomware-2022-0085 — Mass File Rename (mindware)
// Status: deprecated | Level: high | ID: c98ca744-6426-56a7-b6c8-94e4a11f3e37

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
