// Dragnet [Ransomware]: dragnet-ransomware-2025-6605 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 2f491c4f-dbf9-51e8-ac10-8fb405197e36

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
