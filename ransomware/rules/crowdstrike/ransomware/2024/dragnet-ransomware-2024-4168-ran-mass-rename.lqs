// Dragnet [Ransomware]: dragnet-ransomware-2024-4168 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 74297daf-7978-5c76-ba70-0093999b2955

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
