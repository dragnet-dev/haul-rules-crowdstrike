// Dragnet [Ransomware]: dragnet-ransomware-2025-6097 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 24241fd3-741c-5e66-813a-9676cda4cede

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
