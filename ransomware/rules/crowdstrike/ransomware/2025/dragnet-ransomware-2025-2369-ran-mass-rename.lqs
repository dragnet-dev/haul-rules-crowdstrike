// Dragnet [Ransomware]: dragnet-ransomware-2025-2369 — Mass File Rename (ElDorado)
// Status: deprecated | Level: high | ID: f0132e6b-7b2c-5694-b7e0-b715914016fe

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
