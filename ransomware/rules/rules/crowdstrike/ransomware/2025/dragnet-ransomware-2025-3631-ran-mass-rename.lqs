// Dragnet [Ransomware]: dragnet-ransomware-2025-3631 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 2281e190-0217-5732-b1ae-23ff067b3072

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
