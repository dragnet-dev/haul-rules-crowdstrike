// Dragnet [Ransomware]: dragnet-ransomware-2024-5142 — Mass File Rename (ElDorado)
// Status: deprecated | Level: high | ID: 9ff04832-1bfd-5d94-a7b6-96029f5f93ee

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
