// Dragnet [Ransomware]: dragnet-ransomware-2022-0635 — Mass File Rename (leaktheanalyst)
// Status: deprecated | Level: high | ID: 6d2d21ee-3a3f-53c9-b9d2-b08ab2d86036

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
