// Dragnet [Ransomware]: dragnet-ransomware-2023-2373 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 19d663e2-d175-58bd-900f-30fca4ad66e2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
