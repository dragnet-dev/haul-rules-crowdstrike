// Dragnet [Ransomware]: dragnet-ransomware-2025-7225 — Mass File Rename (global)
// Status: deprecated | Level: high | ID: dea148e5-afe9-5f12-9a8f-bab8d90ebdb5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
