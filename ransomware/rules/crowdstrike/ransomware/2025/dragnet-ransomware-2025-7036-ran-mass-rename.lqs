// Dragnet [Ransomware]: dragnet-ransomware-2025-7036 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 51b00269-8c7d-558f-a26f-8c30899cb266

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
