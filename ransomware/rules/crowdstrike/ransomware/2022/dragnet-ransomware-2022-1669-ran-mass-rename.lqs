// Dragnet [Ransomware]: dragnet-ransomware-2022-1669 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 07b005c0-d78b-5668-996c-9ff50a5dd080

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
