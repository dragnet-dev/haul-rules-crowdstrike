// Dragnet [Ransomware]: dragnet-ransomware-2026-1506 — Mass File Rename (interlock)
// Status: stable | Level: high | ID: 2acf3ee5-78ba-5e55-8498-cd7fb764764a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
