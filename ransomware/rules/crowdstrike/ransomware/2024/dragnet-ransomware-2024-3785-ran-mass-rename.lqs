// Dragnet [Ransomware]: dragnet-ransomware-2024-3785 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 710272d0-716f-5487-89bf-7d5f2e8c3551

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
