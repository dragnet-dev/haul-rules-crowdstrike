// Dragnet [Ransomware]: dragnet-ransomware-2023-0605 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 9ad2f349-2e11-50c4-acf5-9fc9dcabb028

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
