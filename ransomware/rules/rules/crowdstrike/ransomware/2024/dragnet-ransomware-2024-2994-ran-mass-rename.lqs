// Dragnet [Ransomware]: dragnet-ransomware-2024-2994 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: bcd1c043-0826-531c-9560-e767acd5a8fa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
