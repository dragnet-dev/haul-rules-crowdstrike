// Dragnet [Ransomware]: dragnet-ransomware-2024-3782 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 6041fb98-3b4d-5f82-b9d3-1b33446ecd35

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
