// Dragnet [Ransomware]: dragnet-ransomware-2023-5000 — Mass File Rename (medusalocker)
// Status: experimental | Level: high | ID: 1f4de8a1-9f7d-5a4f-94aa-45e05c754693

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
