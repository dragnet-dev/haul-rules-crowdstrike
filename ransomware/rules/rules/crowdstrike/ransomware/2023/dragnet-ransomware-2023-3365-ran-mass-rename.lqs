// Dragnet [Ransomware]: dragnet-ransomware-2023-3365 — Mass File Rename (cactus)
// Status: deprecated | Level: high | ID: f808f7f2-14e9-5bb0-9c70-8f60d9586781

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
