// Dragnet [Ransomware]: dragnet-ransomware-2025-3352 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 59ca68cb-f0fa-518a-bea8-15744e8de7f4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
