// Dragnet [Ransomware]: dragnet-ransomware-2023-0766 — Mass File Rename (royal)
// Status: deprecated | Level: high | ID: 15cd4f59-a5ef-5000-80cc-437744a51be6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
