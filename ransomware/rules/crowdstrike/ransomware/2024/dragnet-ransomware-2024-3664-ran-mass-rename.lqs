// Dragnet [Ransomware]: dragnet-ransomware-2024-3664 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: a2e5ad3d-5f35-5cef-8e32-1f5551c22e25

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
