// Dragnet [Ransomware]: dragnet-ransomware-2023-3439 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: d0b6ea01-8142-53cd-8b5e-57dc3d05c5bd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
