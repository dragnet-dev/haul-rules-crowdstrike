// Dragnet [Ransomware]: dragnet-ransomware-2022-0726 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 0a54be38-0a52-5be7-a461-1291f3367ce9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
