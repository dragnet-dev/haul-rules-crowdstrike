// Dragnet [Ransomware]: dragnet-ransomware-2025-0566 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 6bfab25c-2b6e-5a9d-8c87-1e7c7f2f8057

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
