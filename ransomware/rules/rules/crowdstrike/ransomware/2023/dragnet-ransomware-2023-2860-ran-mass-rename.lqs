// Dragnet [Ransomware]: dragnet-ransomware-2023-2860 — Mass File Rename (malas)
// Status: experimental | Level: high | ID: 868309fe-dda8-5cde-8a43-9551f12dff73

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
