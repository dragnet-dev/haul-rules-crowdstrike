// Dragnet [Ransomware]: dragnet-ransomware-2025-6422 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: 935fe41b-c179-57f6-8f46-cd22ee2318d7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
