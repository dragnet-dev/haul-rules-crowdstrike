// Dragnet [Ransomware]: dragnet-ransomware-2025-4759 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 8fda3298-4ee6-55ba-b1a9-88e34d5117bd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
