// Dragnet [Ransomware]: dragnet-ransomware-2023-4023 — Mass File Rename (stormous)
// Status: experimental | Level: high | ID: 951c35a0-d497-57f5-863f-bbf35cf2d214

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
