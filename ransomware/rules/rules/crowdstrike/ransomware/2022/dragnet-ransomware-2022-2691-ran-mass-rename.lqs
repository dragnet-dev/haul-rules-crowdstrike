// Dragnet [Ransomware]: dragnet-ransomware-2022-2691 — Mass File Rename (kelvinsecurity)
// Status: deprecated | Level: high | ID: 0f9b5227-31ec-58b0-bb42-28cd8c72900f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
