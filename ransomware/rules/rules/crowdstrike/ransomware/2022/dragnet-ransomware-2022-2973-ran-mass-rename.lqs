// Dragnet [Ransomware]: dragnet-ransomware-2022-2973 — Mass File Rename (lv)
// Status: deprecated | Level: high | ID: 35fd1221-14ab-5429-87b4-9150886e4548

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
