// Dragnet [Ransomware]: dragnet-ransomware-2025-3048 — Mass File Rename (ransomhouse)
// Status: experimental | Level: high | ID: 4a59e929-9829-5cdd-929e-d1830ce9eda6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
