// Dragnet [Ransomware]: dragnet-ransomware-2026-3018 — Mass File Rename (payoutsking)
// Status: deprecated | Level: high | ID: 8ba0c169-32f4-5b81-855a-7c67d0d71744

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
