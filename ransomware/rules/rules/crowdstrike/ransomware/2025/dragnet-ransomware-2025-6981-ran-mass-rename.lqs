// Dragnet [Ransomware]: dragnet-ransomware-2025-6981 — Mass File Rename (securotrop)
// Status: experimental | Level: high | ID: 4822a10c-0226-51aa-a986-8bc9b0e1886c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
