// Dragnet [Ransomware]: dragnet-ransomware-2025-6428 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: d4bc0356-ac8a-5ed3-a256-09af6fdac096

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
