// Dragnet [Ransomware]: dragnet-ransomware-2023-3376 — Mass File Rename (ransomexx)
// Status: experimental | Level: high | ID: 4e08aa04-6036-5141-bfd0-58df4d78a722

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
