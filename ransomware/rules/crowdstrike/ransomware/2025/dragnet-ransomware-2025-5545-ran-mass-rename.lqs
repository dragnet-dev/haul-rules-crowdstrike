// Dragnet [Ransomware]: dragnet-ransomware-2025-5545 — Mass File Rename (play)
// Status: experimental | Level: high | ID: c53cf5a9-70df-57fa-81b0-4700d3e2932c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
