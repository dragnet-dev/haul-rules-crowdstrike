// Dragnet [Ransomware]: dragnet-ransomware-2025-3247 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 20c6629a-eb1c-5e87-8fda-ce3547479e6d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
