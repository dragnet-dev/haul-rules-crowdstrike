// Dragnet [Ransomware]: dragnet-ransomware-2026-2092 — Mass File Rename (everest)
// Status: stable | Level: high | ID: 2ba0d882-f5ea-53db-9f01-67d6bb318b5c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
