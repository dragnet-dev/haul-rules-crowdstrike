// Dragnet [Ransomware]: dragnet-ransomware-2023-4341 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: cc179d82-5393-59d8-a868-4a436709b0bc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
