// Dragnet [Ransomware]: dragnet-ransomware-2022-3097 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 4612e35c-f62a-5218-97ea-e508a6b8cfe1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
