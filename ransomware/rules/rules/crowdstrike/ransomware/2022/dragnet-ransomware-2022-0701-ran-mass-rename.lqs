// Dragnet [Ransomware]: dragnet-ransomware-2022-0701 — Mass File Rename (blackbasta)
// Status: deprecated | Level: high | ID: 1a628bba-fa77-5fa1-9e0f-d6d5107d458d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
