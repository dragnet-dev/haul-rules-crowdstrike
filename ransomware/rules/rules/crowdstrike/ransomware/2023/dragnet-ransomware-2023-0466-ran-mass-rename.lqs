// Dragnet [Ransomware]: dragnet-ransomware-2023-0466 — Mass File Rename (royal)
// Status: deprecated | Level: high | ID: fa338ae6-b303-5ec4-8532-5a21530d3852

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
