// Dragnet [Ransomware]: dragnet-ransomware-2024-1713 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 86012d4c-7efc-5d84-9a26-41dc7562af5e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
