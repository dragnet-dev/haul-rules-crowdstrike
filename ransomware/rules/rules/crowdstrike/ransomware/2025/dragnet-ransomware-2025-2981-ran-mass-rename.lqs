// Dragnet [Ransomware]: dragnet-ransomware-2025-2981 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 51856f61-6281-550d-babe-e85e791f1142

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
