// Dragnet [Ransomware]: dragnet-ransomware-2022-1706 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 3f1bca4e-7171-500d-a86c-4799467c93a4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
