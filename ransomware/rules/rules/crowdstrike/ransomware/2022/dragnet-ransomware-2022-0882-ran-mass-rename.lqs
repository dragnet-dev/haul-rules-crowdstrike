// Dragnet [Ransomware]: dragnet-ransomware-2022-0882 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 3d19664a-f8ff-57fb-8d07-c6b9bcf55c20

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
