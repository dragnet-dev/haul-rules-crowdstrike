// Dragnet [Ransomware]: dragnet-ransomware-2023-0482 — Mass File Rename (meow)
// Status: experimental | Level: high | ID: c9befe79-d11f-5bbd-9f9a-98afe003dc9a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
