// Dragnet [Ransomware]: dragnet-ransomware-2025-2339 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 3f0f95bf-d1d5-5d69-b4a1-6ce238e67a49

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
