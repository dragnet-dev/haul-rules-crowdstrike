// Dragnet [Ransomware]: dragnet-ransomware-2025-6871 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 345f6ed0-44a4-58f7-9e08-1a4731da3a16

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
