// Dragnet [Ransomware]: dragnet-ransomware-2025-6620 — Mass File Rename (worldleaks)
// Status: test | Level: high | ID: e467ec0e-20f8-5220-b7bb-2d9de0ab2eb6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
