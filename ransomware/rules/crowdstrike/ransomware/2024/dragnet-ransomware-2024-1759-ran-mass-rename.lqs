// Dragnet [Ransomware]: dragnet-ransomware-2024-1759 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 8b3783fb-9c23-5e5d-b252-096dc810f647

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
