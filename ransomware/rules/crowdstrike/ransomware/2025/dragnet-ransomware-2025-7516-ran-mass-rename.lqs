// Dragnet [Ransomware]: dragnet-ransomware-2025-7516 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 3d83510a-459e-5ce4-bc75-8a7a50386a07

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
