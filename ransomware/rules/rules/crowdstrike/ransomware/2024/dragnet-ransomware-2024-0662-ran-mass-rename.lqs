// Dragnet [Ransomware]: dragnet-ransomware-2024-0662 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: 75fba067-d204-5ca2-8969-080398103625

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
