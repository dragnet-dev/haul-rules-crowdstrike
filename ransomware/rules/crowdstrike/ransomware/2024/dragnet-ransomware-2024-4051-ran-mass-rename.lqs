// Dragnet [Ransomware]: dragnet-ransomware-2024-4051 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 92526b7c-f888-522b-a72b-c32c3b000479

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
