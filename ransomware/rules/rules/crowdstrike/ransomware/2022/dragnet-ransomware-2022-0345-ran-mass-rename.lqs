// Dragnet [Ransomware]: dragnet-ransomware-2022-0345 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: ed1dcc49-9ba1-5c2b-9c95-8c50c3e71990

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
