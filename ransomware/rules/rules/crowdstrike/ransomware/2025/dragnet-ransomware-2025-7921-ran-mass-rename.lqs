// Dragnet [Ransomware]: dragnet-ransomware-2025-7921 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 2ec894b5-c28a-5c89-b0df-f9d0ca389c4a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
