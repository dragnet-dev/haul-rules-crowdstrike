// Dragnet [Ransomware]: dragnet-ransomware-2024-1492 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 02778368-ea42-596d-b357-a56546d30650

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
