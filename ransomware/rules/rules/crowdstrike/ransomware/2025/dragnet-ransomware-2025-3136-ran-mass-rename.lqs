// Dragnet [Ransomware]: dragnet-ransomware-2025-3136 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: abdd2ad4-6a9e-5eef-a943-d20d63599032

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
