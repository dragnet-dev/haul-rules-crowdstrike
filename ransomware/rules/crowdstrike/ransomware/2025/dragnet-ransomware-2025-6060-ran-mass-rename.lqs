// Dragnet [Ransomware]: dragnet-ransomware-2025-6060 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 56f71568-9bfa-57d2-871d-67d8a7f870fa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
