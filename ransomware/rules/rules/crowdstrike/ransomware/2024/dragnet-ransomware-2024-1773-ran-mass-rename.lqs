// Dragnet [Ransomware]: dragnet-ransomware-2024-1773 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: ab3d16f0-0a44-5d90-ad87-d36ddb3fb31b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
