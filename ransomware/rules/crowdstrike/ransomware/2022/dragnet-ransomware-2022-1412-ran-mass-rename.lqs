// Dragnet [Ransomware]: dragnet-ransomware-2022-1412 — Mass File Rename (cuba)
// Status: deprecated | Level: high | ID: bef68235-3bda-5026-b448-4e13d0852ac0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
