// Dragnet [Ransomware]: dragnet-ransomware-2025-2265 — Mass File Rename (cloak)
// Status: deprecated | Level: high | ID: c6478ab1-9405-50cc-8a5f-cd4c837af12c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
