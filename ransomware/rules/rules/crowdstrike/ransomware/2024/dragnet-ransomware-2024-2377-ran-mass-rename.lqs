// Dragnet [Ransomware]: dragnet-ransomware-2024-2377 — Mass File Rename (play)
// Status: experimental | Level: high | ID: ac1c8385-c025-52f9-bfe5-ef9011a6aa97

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
