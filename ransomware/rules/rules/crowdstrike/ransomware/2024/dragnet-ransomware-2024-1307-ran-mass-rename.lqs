// Dragnet [Ransomware]: dragnet-ransomware-2024-1307 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 1500f1a2-d29e-5cb6-8be1-d133061daf13

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
