// Dragnet [Ransomware]: dragnet-ransomware-2025-7158 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: 90a86e9f-937f-5f11-b0de-87d4c9838f71

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
