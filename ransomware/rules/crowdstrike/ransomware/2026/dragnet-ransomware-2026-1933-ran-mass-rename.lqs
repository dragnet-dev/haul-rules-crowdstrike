// Dragnet [Ransomware]: dragnet-ransomware-2026-1933 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 16ef7730-4f4a-57ca-a6e3-6c9e016cf00e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
