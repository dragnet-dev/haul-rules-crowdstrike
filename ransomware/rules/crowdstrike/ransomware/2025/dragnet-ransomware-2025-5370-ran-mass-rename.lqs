// Dragnet [Ransomware]: dragnet-ransomware-2025-5370 — Mass File Rename (blacklock)
// Status: experimental | Level: high | ID: e80c1c68-4090-5d53-b533-03ac185ed84a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
