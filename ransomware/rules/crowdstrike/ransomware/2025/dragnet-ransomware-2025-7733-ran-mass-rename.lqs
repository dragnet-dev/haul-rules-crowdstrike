// Dragnet [Ransomware]: dragnet-ransomware-2025-7733 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 0c984d7d-7790-591b-941e-0e801c357277

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
