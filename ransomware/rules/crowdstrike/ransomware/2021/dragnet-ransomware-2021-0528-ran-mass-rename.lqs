// Dragnet [Ransomware]: dragnet-ransomware-2021-0528 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 331f3b2a-02f5-53be-8635-3a61cdd26d60

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
