// Dragnet [Ransomware]: dragnet-ransomware-2023-0626 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 33f7fd4e-2673-5d6e-8fc5-58e0e733e2d2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
