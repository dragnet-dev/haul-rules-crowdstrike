// Dragnet [Ransomware]: dragnet-ransomware-2023-4450 — Mass File Rename (stormous)
// Status: experimental | Level: high | ID: 746f3fad-a45c-5840-8fe1-87d1ca08e988

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
