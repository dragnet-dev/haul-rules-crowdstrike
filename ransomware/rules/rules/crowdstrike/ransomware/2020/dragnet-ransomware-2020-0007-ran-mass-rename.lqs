// Dragnet [Ransomware]: dragnet-ransomware-2020-0007 — Mass File Rename (maze)
// Status: deprecated | Level: high | ID: 41a4d342-d9d0-5356-a850-3449c6154068

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
