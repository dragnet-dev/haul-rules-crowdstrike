// Dragnet [Ransomware]: dragnet-ransomware-2024-0473 — Mass File Rename (arcusmedia)
// Status: experimental | Level: high | ID: a3f363ce-fc94-5dfa-bcf1-3da1c527714c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
