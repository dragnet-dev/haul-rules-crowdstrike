// Dragnet [Ransomware]: dragnet-ransomware-2024-5978 — Mass File Rename (darkvault)
// Status: experimental | Level: high | ID: 7da3585b-ccda-5fe7-b3dd-c863f4cb21b7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
