// Dragnet [Ransomware]: dragnet-ransomware-2024-5718 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 6df898ed-c22a-5388-a7c8-e3b83b189781

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
