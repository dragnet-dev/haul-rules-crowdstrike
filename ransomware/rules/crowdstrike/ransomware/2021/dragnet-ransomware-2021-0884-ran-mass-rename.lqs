// Dragnet [Ransomware]: dragnet-ransomware-2021-0884 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: e1100eee-8184-57d0-871f-b82bbb4bec1c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
