// Dragnet [Ransomware]: dragnet-ransomware-2025-3501 — Mass File Rename (gunra)
// Status: experimental | Level: high | ID: b0ceb756-ad4d-5e46-b4f4-f4c1c6073b49

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
