// Dragnet [Ransomware]: dragnet-ransomware-2022-0014 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: b00ce385-67de-5dcb-99f1-87974857a3b4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
