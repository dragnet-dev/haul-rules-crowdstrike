// Dragnet [Ransomware]: dragnet-ransomware-2023-1969 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: b2fb0b02-44ac-5892-a571-3da3c90330ed

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
