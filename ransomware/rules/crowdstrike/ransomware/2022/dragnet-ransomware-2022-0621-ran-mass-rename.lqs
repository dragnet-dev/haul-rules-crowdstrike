// Dragnet [Ransomware]: dragnet-ransomware-2022-0621 — Mass File Rename (midas)
// Status: deprecated | Level: high | ID: 1f329f59-71fc-58d7-8acc-d032987a5375

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
