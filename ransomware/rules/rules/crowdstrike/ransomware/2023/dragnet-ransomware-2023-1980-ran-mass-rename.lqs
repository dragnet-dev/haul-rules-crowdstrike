// Dragnet [Ransomware]: dragnet-ransomware-2023-1980 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 30d16e8e-741b-5510-afe1-1eecc32a1ce7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
