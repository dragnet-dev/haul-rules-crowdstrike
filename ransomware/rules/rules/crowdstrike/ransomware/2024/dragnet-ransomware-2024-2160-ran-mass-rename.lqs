// Dragnet [Ransomware]: dragnet-ransomware-2024-2160 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 8e74c54a-772e-571e-bae8-efd5e52fe9af

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
