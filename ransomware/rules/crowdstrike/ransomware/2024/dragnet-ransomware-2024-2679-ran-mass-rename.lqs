// Dragnet [Ransomware]: dragnet-ransomware-2024-2679 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: 3198d210-f3d4-5288-843e-436c0471109e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
