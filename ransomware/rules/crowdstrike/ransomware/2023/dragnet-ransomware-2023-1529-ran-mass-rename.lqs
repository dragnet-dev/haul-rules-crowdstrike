// Dragnet [Ransomware]: dragnet-ransomware-2023-1529 — Mass File Rename (ransomed)
// Status: experimental | Level: high | ID: 8a50f411-6679-5a76-b7ee-1d0f627ae7ac

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
