// Dragnet [Ransomware]: dragnet-ransomware-2023-4069 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: 1de1feec-ad68-561f-a1fb-03f02f348ff9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
