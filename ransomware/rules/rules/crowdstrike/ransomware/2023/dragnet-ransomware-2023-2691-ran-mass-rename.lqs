// Dragnet [Ransomware]: dragnet-ransomware-2023-2691 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: ea7c6aef-ffeb-5c8b-aaca-213d4b279137

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
