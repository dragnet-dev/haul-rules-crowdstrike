// Dragnet [Container]: dragnet-container-2026-1940 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 7911603e-d7eb-5445-97df-1abb5d0e7eee

#event_simpleName=*
| (ImageFileName = *debian:7* OR ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10* OR ImageFileName = *ubuntu:13.10*)
| table([timestamp, ComputerName])
| limit(1000)
