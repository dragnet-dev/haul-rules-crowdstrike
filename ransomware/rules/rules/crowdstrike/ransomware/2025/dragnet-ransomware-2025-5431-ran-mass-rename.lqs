// Dragnet [Ransomware]: dragnet-ransomware-2025-5431 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 4e592c22-7148-5059-9ddf-c4347ac4d2cd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
