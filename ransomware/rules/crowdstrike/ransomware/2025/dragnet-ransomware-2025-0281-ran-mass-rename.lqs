// Dragnet [Ransomware]: dragnet-ransomware-2025-0281 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 57e594a1-2881-5bf6-8703-464e41d9a941

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
