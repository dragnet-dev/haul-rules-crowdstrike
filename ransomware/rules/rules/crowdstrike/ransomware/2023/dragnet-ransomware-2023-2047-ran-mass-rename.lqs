// Dragnet [Ransomware]: dragnet-ransomware-2023-2047 — Mass File Rename (medusalocker)
// Status: experimental | Level: high | ID: 39565863-f662-52c9-8fde-bb8dca96205d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
