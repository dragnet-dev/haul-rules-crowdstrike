// Dragnet [Ransomware]: dragnet-ransomware-2024-0321 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: f6edc600-64bc-5e4a-83cd-618842dd5414

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
