// Dragnet [Ransomware]: dragnet-ransomware-2026-0414 — Mass File Rename (nightspire)
// Status: deprecated | Level: high | ID: b67aadd0-5d18-5e7c-a77a-3aad3bed07f9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
