// Dragnet [Ransomware]: dragnet-ransomware-2025-1123 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: c572b3cb-acf7-5bc0-aa1c-550848d819ad

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
