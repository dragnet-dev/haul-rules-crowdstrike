// Dragnet [Container]: dragnet-container-2024-1445 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 562c332b-5464-570f-93db-43d1e564009f

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
