// Dragnet [Ransomware]: dragnet-ransomware-2025-6533 — Mass File Rename (devman)
// Status: deprecated | Level: high | ID: d1357416-c6f5-5761-9bd8-26daf3de9f40

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
