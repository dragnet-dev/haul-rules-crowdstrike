// Dragnet [Container]: dragnet-container-2026-1511 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: cbfc4d00-ae87-5708-843c-51873bd6a3ba

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:7* OR ImageFileName = *ubuntu:14.04*)
| table([timestamp, ComputerName])
| limit(1000)
