// Dragnet [Ransomware]: dragnet-ransomware-2024-5661 — Mass File Rename (apt73)
// Status: experimental | Level: high | ID: e6e1297d-866a-5066-8d4f-b57037443a6f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
