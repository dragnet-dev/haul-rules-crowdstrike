// Dragnet [Ransomware]: dragnet-ransomware-2022-1877 — Mass File Rename (vicesociety)
// Status: deprecated | Level: high | ID: 97143708-8159-518b-828e-d197565751f0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
