// Dragnet [Ransomware]: dragnet-ransomware-2023-4928 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 4b6160e6-9edf-55a4-94fa-e665b70e0dac

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
