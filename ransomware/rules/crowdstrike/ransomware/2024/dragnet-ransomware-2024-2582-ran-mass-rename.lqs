// Dragnet [Ransomware]: dragnet-ransomware-2024-2582 — Mass File Rename (arcusmedia)
// Status: experimental | Level: high | ID: 6984e808-3cdc-5d0e-b96b-bd398fc3b35f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
