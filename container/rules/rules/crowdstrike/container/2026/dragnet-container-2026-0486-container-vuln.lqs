// Dragnet [Container]: dragnet-container-2026-0486 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: d4938c10-7886-5804-b118-18544960116e

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
