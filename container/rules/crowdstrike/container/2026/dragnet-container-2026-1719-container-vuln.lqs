// Dragnet [Container]: dragnet-container-2026-1719 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 34792e91-f141-57ff-90d7-e6231f462604

#event_simpleName=*
| (ImageFileName = *alpine:3.2* OR ImageFileName = *alpine:3.3* OR ImageFileName = *amazonlinux:1* OR ImageFileName = *debian:7* OR ImageFileName = *debian:8* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:14.04* OR ImageFileName = *ubuntu:14.04-ESM* OR ImageFileName = *ubuntu:16.04* OR ImageFileName = *ubuntu:16.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
