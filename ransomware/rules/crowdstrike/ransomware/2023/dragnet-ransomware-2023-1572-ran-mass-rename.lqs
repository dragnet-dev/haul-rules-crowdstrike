// Dragnet [Ransomware]: dragnet-ransomware-2023-1572 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: fc52d2ba-fbae-5c5d-9bba-7cb0c88200cb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
