// Dragnet [Ransomware]: dragnet-ransomware-2026-1555 — Mass File Rename (vect)
// Status: deprecated | Level: high | ID: 38802195-e5d6-5045-ba32-ade9b70187e3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
