// Dragnet [Ransomware]: dragnet-ransomware-2025-2039 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 0504730f-f536-5708-b7ca-2cc25c144cae

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
