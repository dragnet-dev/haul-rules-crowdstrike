// Dragnet [Ransomware]: dragnet-ransomware-2025-2644 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: a3176a1a-e3d8-5b16-ba42-93b34fcf9ad5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
