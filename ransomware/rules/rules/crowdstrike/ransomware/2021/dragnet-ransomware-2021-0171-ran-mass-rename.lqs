// Dragnet [Ransomware]: dragnet-ransomware-2021-0171 — Mass File Rename (networm)
// Status: deprecated | Level: high | ID: 0f3000ab-e112-5562-80b5-970e16eddbfb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
