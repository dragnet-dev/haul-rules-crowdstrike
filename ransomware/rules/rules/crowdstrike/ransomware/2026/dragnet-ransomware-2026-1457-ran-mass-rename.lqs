// Dragnet [Ransomware]: dragnet-ransomware-2026-1457 — Mass File Rename (lockbit5)
// Status: stable | Level: high | ID: 005c3531-6e2f-5ade-beb0-bd0c5cb2494d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
