// Dragnet [Ransomware]: dragnet-ransomware-2023-2801 — Mass File Rename (malas)
// Status: experimental | Level: high | ID: fcf52b6f-132b-5c08-bf2d-b87844828019

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
