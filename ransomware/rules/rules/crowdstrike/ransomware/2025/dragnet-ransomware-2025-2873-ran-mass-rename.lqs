// Dragnet [Ransomware]: dragnet-ransomware-2025-2873 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 82e5f6c7-9e0d-56aa-b89b-d4661fcb25a6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
