// Dragnet [Ransomware]: dragnet-ransomware-2021-1313 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: aa73ba6a-426b-5cd7-a218-c1f45b6611f0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
