// Dragnet [Ransomware]: dragnet-ransomware-2023-1442 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: a62fc617-d555-5238-ae4f-edf10474f01d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
