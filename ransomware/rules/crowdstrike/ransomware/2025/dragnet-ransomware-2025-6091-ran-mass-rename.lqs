// Dragnet [Ransomware]: dragnet-ransomware-2025-6091 — Mass File Rename (nova)
// Status: experimental | Level: high | ID: d1b56ac1-3373-5f71-8fba-d8c3952117c6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
