// Dragnet [Container]: dragnet-container-2024-0373 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 85f7aabe-ddb0-532d-a242-edfe5cf609ed

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:9* OR ImageFileName = *ubuntu:18.04-ESM* OR ImageFileName = *ubuntu:20.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
