// Dragnet [Ransomware]: dragnet-ransomware-2023-4506 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 8b8b1e20-1ce9-5d87-8f27-d9f16f589794

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
