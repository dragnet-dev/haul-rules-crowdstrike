// Dragnet [Ransomware]: dragnet-ransomware-2024-2552 — Mass File Rename (madliberator)
// Status: experimental | Level: high | ID: a4323b0b-3d6b-525c-862d-507fee78dec0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
