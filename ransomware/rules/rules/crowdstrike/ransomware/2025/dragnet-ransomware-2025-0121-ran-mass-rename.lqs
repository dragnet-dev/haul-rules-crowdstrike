// Dragnet [Ransomware]: dragnet-ransomware-2025-0121 — Mass File Rename (anubis)
// Status: experimental | Level: high | ID: 9bf56c04-17d4-54be-9526-293d79edfa6f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
