// Dragnet [Ransomware]: dragnet-ransomware-2026-2150 — Mass File Rename (ALP-001)
// Status: stable | Level: high | ID: e5cdee4a-5861-5449-b813-bc60d24ea52d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
