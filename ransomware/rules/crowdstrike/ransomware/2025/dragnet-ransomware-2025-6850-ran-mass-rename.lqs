// Dragnet [Ransomware]: dragnet-ransomware-2025-6850 — Mass File Rename (worldleaks)
// Status: experimental | Level: high | ID: 157444a5-b1ad-5358-94c4-a5cbacba878c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
