// Dragnet [Ransomware]: dragnet-ransomware-2025-3012 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: af0122e7-b7e4-5954-81c0-efcd3beb1043

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
