// Dragnet [Ransomware]: dragnet-ransomware-2023-0646 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 2daa11de-50c2-5153-ac0b-bce0e6c766d4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
