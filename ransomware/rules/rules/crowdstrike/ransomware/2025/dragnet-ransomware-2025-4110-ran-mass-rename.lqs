// Dragnet [Ransomware]: dragnet-ransomware-2025-4110 — Mass File Rename (sinobi)
// Status: experimental | Level: high | ID: 4f884588-6b67-5e6a-89d6-8f8d693af270

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
