// Dragnet [Ransomware]: dragnet-ransomware-2025-0839 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 99eb1dbe-3733-59bc-a154-d6499ac8295f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
