// Dragnet [Ransomware]: dragnet-ransomware-2022-1702 — Mass File Rename (avoslocker)
// Status: deprecated | Level: high | ID: 494ca0e8-7331-5878-a72a-3558b1de47f7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
