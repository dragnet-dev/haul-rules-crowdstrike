// Dragnet [Ransomware]: dragnet-ransomware-2024-5130 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: b933095a-411d-5d43-abd6-c8f9ea431925

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
