// Dragnet [Ransomware]: dragnet-ransomware-2024-6011 — Mass File Rename (ElDorado)
// Status: deprecated | Level: high | ID: 5bd8b94d-b5ee-5187-af18-5ecb044e6587

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
