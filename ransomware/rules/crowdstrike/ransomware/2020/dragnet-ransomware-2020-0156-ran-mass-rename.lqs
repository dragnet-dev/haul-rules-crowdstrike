// Dragnet [Ransomware]: dragnet-ransomware-2020-0156 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 795d7c76-f9ae-5629-a66e-e80ad85ec23f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
