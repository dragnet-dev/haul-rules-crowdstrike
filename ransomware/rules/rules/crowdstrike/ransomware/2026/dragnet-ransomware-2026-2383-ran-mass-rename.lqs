// Dragnet [Ransomware]: dragnet-ransomware-2026-2383 — Mass File Rename (handala)
// Status: stable | Level: high | ID: 537a2e25-0c2f-5275-ad3b-1a4f60624b01

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
