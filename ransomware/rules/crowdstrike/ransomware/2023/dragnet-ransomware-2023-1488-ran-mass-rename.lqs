// Dragnet [Ransomware]: dragnet-ransomware-2023-1488 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 8536b3f6-fe5f-5136-93a6-91d37ac83556

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
