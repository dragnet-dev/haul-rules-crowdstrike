// Dragnet [Ransomware]: dragnet-ransomware-2024-3500 — Mass File Rename (interlock)
// Status: experimental | Level: high | ID: 3848e20e-fea5-561d-8c5f-478ac5fd7b84

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
