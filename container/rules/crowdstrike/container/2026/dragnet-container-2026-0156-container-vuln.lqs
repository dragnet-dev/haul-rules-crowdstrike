// Dragnet [Container]: dragnet-container-2026-0156 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 85ce44aa-7b23-538d-a328-63114e2b35ac

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
