// Dragnet [IOC]: dragnet-ransomware-2026-3467 — Malicious File Hash
// Status: test | Level: medium | ID: c6d51c76-e241-5b80-8b81-06c6fcf37a2c

#event_simpleName=PeFileWritten OR #event_simpleName=NewExecutableWritten
| (MD5HashData = "7886f04af218392a1688528ff599a4eb" OR MD5HashData = "35702b428046bc2eca42ec97adf4f598" OR SHA256HashData = "b2a8d97da2a653de75d3d1be583910233a81a3794364e19ee4bc352b06b48f36")
| table([timestamp, ComputerName, FilePath, ImageFileName])
| limit(1000)
