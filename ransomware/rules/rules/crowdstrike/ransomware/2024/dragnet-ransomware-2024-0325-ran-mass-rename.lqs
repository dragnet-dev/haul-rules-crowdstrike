// Dragnet [Ransomware]: dragnet-ransomware-2024-0325 — Mass File Rename (play)
// Status: experimental | Level: high | ID: dd50bd66-3aba-589e-9780-b2bac1ce529f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
