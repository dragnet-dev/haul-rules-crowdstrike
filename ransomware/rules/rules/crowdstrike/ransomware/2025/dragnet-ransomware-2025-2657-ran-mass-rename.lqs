// Dragnet [Ransomware]: dragnet-ransomware-2025-2657 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: 7140b063-b843-532d-82d0-4203ec093255

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
