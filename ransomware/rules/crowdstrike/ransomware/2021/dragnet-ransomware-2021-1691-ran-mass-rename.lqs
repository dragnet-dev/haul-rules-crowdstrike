// Dragnet [Ransomware]: dragnet-ransomware-2021-1691 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: b33be6bc-0bbe-59ae-8160-87a6d28a4ea8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
