// Dragnet [Ransomware]: dragnet-ransomware-2023-3379 — Mass File Rename (noescape)
// Status: experimental | Level: high | ID: 1aa6c9d7-8646-571e-832e-304b18eb979b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
