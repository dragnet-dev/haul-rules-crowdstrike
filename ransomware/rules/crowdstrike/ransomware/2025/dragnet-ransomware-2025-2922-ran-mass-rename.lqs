// Dragnet [Ransomware]: dragnet-ransomware-2025-2922 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 0e30f473-cce3-541d-ad6f-b0e0f807a16e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
