// Dragnet [Ransomware]: dragnet-ransomware-2022-3100 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: e6595647-3506-5631-9dd2-a3d05690b586

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
