// Dragnet [Ransomware]: dragnet-ransomware-2021-1765 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 0f35b52a-76f8-5b62-8bcf-bd15be28dfc7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
