// Dragnet [Ransomware]: dragnet-ransomware-2023-1412 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 56f079fd-8e85-54c6-b2e7-1ded6ed840f7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
