// Dragnet [Ransomware]: dragnet-ransomware-2025-1459 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 071a11e8-8993-52e6-bf3a-4f0436d239d6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
