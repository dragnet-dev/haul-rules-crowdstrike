// Dragnet [Ransomware]: dragnet-ransomware-2023-5230 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 04d98213-3a0d-50a5-963b-77b2a5098636

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
