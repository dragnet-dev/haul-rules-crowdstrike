// Dragnet [Ransomware]: dragnet-ransomware-2024-1186 — Mass File Rename (stormous)
// Status: deprecated | Level: high | ID: c5a7e4fc-f914-5a91-a748-59693ab811b7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
