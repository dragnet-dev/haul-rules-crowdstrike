// Dragnet [Container]: dragnet-container-2024-0001 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 3de99873-2618-58ba-b8ec-fd750db8b713

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:8* OR ImageFileName = *photon os:3.0* OR ImageFileName = *ubuntu:14.04-ESM* OR ImageFileName = *ubuntu:16.04* OR ImageFileName = *ubuntu:16.04-ESM* OR ImageFileName = *ubuntu:18.04* OR ImageFileName = *ubuntu:18.04-ESM* OR ImageFileName = *ubuntu:19.04* OR ImageFileName = *ubuntu:19.10*)
| table([timestamp, ComputerName])
| limit(1000)
