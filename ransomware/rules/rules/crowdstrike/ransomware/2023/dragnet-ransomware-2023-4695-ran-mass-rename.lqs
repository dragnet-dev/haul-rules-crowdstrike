// Dragnet [Ransomware]: dragnet-ransomware-2023-4695 — Mass File Rename (losttrust)
// Status: deprecated | Level: high | ID: 5be48eca-d1ba-524d-8a69-a432a7cbefb7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
