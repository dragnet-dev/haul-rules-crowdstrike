// Dragnet [Ransomware]: dragnet-ransomware-2025-7592 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: e1c52803-a79c-5d33-ba73-7cbbce9a941b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
