// Dragnet [Container]: dragnet-container-2026-0372 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 22e0ee32-1499-562b-880a-4ddd9daffc0e

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
