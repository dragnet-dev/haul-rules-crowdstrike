// Dragnet [Ransomware]: dragnet-ransomware-2025-1536 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: f503d835-4475-5cee-84fb-46273fc7efb9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
