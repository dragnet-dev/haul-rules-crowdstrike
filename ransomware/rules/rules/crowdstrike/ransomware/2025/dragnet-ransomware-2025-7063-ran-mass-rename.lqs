// Dragnet [Ransomware]: dragnet-ransomware-2025-7063 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: 29014253-3bd5-5a50-9511-7ea5a53c02d4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
