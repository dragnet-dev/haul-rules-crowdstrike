// Dragnet [Ransomware]: dragnet-ransomware-2025-7579 — Mass File Rename (chaos)
// Status: experimental | Level: high | ID: f5a19969-33d5-56c5-b13d-8e8385d72804

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
