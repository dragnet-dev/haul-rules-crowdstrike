// Dragnet [Ransomware]: dragnet-ransomware-2023-5018 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: d09e0d11-7f84-5372-aeaf-36a651c9484f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
