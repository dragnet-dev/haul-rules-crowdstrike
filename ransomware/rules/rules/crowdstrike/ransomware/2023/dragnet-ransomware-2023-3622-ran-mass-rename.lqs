// Dragnet [Ransomware]: dragnet-ransomware-2023-3622 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: fc24340a-e551-5ec7-a2f0-f4525e953c3e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
