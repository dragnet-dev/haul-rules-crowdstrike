// Dragnet [Ransomware]: dragnet-ransomware-2026-2487 — Mass File Rename (lockbit5)
// Status: stable | Level: high | ID: c8fcb38d-cd45-581d-a592-4de04a26213e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
