// Dragnet [Ransomware]: dragnet-ransomware-2026-0182 — Mass File Rename (everest)
// Status: stable | Level: high | ID: e31a3da5-6471-5538-be3d-07f7e7d12376

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
