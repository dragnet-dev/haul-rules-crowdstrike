// Dragnet [Ransomware]: dragnet-ransomware-2023-1496 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: af8f85e5-beaf-5927-94ce-23f5520b7c31

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
