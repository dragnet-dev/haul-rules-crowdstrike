// Dragnet [Ransomware]: dragnet-ransomware-2021-0778 — Mass File Rename (payloadbin)
// Status: deprecated | Level: high | ID: ef29616e-8ffd-5b93-a8f0-a76e8c2b49d3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
