// Dragnet [Ransomware]: dragnet-ransomware-2022-2915 — Mass File Rename (royal)
// Status: deprecated | Level: high | ID: 37e5afd5-0745-53f0-8fc4-8657e0b9a634

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
