// Dragnet [Ransomware]: dragnet-ransomware-2025-7071 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: febe7f2b-45d5-545e-adcf-0799d7f3b185

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
