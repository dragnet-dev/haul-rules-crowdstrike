// Dragnet [Ransomware]: dragnet-ransomware-2023-3434 — Mass File Rename (play)
// Status: deprecated | Level: high | ID: 8a094018-8e2f-5eb3-85a3-0d1363bc07c8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
