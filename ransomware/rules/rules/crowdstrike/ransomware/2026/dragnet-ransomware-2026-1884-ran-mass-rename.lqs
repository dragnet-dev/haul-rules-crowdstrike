// Dragnet [Ransomware]: dragnet-ransomware-2026-1884 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 6e9e3f0f-8fd7-5459-8806-b4dfbb6ea5c8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
