// Dragnet [Ransomware]: dragnet-ransomware-2025-7389 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: 176b6c47-e87f-5c1b-b5e7-4214859b1a37

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
