// Dragnet [Ransomware]: dragnet-ransomware-2021-0245 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 49ca9c74-1bf5-57a9-815c-de4117e2dfda

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
