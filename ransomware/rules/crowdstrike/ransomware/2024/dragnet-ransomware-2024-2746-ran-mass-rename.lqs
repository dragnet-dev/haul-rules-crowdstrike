// Dragnet [Ransomware]: dragnet-ransomware-2024-2746 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: e93ca61c-19a2-53a0-ab78-99949eafccc6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
