// Dragnet [Ransomware]: dragnet-ransomware-2025-4506 — Mass File Rename (nightspire)
// Status: deprecated | Level: high | ID: 48107a89-809e-57ae-b789-22a309afc062

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
