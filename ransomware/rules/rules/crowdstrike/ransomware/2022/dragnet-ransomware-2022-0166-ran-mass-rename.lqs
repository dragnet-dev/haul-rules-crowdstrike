// Dragnet [Ransomware]: dragnet-ransomware-2022-0166 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 961492b2-bb96-5324-8ce3-d590e5224398

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
