// Dragnet [Ransomware]: dragnet-ransomware-2023-0362 — Mass File Rename (noescape)
// Status: experimental | Level: high | ID: 677f0de7-a335-5651-b20e-4a3ac5309929

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
