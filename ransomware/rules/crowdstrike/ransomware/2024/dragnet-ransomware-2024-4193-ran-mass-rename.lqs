// Dragnet [Ransomware]: dragnet-ransomware-2024-4193 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 70d149af-43f1-5463-a559-662d6874cf7c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
