// Dragnet [Ransomware]: dragnet-ransomware-2022-0891 — Mass File Rename (pandora)
// Status: deprecated | Level: high | ID: 989886b5-cf1b-5145-8a80-9e2f4614c8c6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
