// Dragnet [Ransomware]: dragnet-ransomware-2026-2833 — Mass File Rename (killsec)
// Status: deprecated | Level: high | ID: 098b3770-aee2-5556-9ac0-d97d0f0e7504

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
