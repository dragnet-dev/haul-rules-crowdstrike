// Dragnet [Ransomware]: dragnet-ransomware-2023-2699 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 454564e7-3211-52fd-b6a7-029c6197d02a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
