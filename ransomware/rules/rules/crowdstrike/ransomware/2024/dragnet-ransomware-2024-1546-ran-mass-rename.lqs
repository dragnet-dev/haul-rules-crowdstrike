// Dragnet [Ransomware]: dragnet-ransomware-2024-1546 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: deb9eefb-2e05-5b50-bb66-24d08b6a26f4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
