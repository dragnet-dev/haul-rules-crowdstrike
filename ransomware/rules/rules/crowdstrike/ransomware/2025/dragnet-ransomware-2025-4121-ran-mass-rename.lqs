// Dragnet [Ransomware]: dragnet-ransomware-2025-4121 — Mass File Rename (kraken)
// Status: experimental | Level: high | ID: 505c5661-f92c-5452-ae48-1b6d1baff8dd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
