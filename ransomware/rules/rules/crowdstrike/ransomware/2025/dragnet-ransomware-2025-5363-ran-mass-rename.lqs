// Dragnet [Ransomware]: dragnet-ransomware-2025-5363 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: a97b349e-151f-5dbf-a8d7-6aee64787e2d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
