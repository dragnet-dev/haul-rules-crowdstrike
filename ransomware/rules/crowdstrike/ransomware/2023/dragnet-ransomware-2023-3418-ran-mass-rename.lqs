// Dragnet [Ransomware]: dragnet-ransomware-2023-3418 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 4793bbae-596c-545d-8492-868bc9541b23

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
