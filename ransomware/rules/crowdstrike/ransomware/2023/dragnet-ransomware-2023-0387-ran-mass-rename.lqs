// Dragnet [Ransomware]: dragnet-ransomware-2023-0387 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 59853bcd-e977-5f36-84bd-4d839198fb02

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
