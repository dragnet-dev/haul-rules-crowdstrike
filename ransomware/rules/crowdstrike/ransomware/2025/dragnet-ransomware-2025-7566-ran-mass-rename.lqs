// Dragnet [Ransomware]: dragnet-ransomware-2025-7566 — Mass File Rename (nova)
// Status: experimental | Level: high | ID: 0ef242fe-e667-56c5-b834-dbfad2a6e332

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
