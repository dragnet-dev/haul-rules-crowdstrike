// Dragnet [Container]: dragnet-container-2024-0310 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: dc05f945-97b0-52cc-94dc-83c029c0f1ae

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
