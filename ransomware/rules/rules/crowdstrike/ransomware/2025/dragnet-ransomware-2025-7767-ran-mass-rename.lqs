// Dragnet [Ransomware]: dragnet-ransomware-2025-7767 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: fbd1cdb8-5f27-5778-9ea5-c7df3ef90818

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
