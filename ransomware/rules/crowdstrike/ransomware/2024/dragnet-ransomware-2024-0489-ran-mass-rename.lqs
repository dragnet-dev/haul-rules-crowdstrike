// Dragnet [Ransomware]: dragnet-ransomware-2024-0489 — Mass File Rename (play)
// Status: experimental | Level: high | ID: e309bbbf-3e9a-5a04-b295-a0060eb7be91

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
