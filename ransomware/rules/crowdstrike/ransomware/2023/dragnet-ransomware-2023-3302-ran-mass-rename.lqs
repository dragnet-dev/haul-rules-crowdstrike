// Dragnet [Ransomware]: dragnet-ransomware-2023-3302 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 70f51f0e-f4e0-5ffd-8971-79059f852239

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
