// Dragnet [Ransomware]: dragnet-ransomware-2024-3229 — Mass File Rename (raworld)
// Status: experimental | Level: high | ID: 1c6e7a6e-9d90-5dbb-81f0-a19f060a75ae

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
