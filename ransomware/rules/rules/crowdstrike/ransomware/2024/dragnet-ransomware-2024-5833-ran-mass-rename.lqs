// Dragnet [Ransomware]: dragnet-ransomware-2024-5833 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 31f16df7-d810-518b-99af-4b635cee05d3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
