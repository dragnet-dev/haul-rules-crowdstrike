// Dragnet [Container]: dragnet-container-2026-0490 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 1137de3c-8941-5e39-b21c-b921315244cd

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:5*)
| table([timestamp, ComputerName])
| limit(1000)
