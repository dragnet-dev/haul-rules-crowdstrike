// Dragnet [Ransomware]: dragnet-ransomware-2025-3613 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 84da05e7-4ff0-5cd9-b7e3-d3d19c5b6d97

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
