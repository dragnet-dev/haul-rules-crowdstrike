// Dragnet [Ransomware]: dragnet-ransomware-2023-2747 — Mass File Rename (malas)
// Status: experimental | Level: high | ID: 8435e268-a442-5e2c-9f4e-3f184fa673f8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
