// Dragnet [Ransomware]: dragnet-ransomware-2024-3404 — Mass File Rename (raworld)
// Status: experimental | Level: high | ID: 277aba76-ba7a-5a21-8fd5-a9d0c1a148bd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
