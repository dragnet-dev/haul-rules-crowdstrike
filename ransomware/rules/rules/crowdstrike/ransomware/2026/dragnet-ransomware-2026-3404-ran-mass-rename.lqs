// Dragnet [Ransomware]: dragnet-ransomware-2026-3404 — Mass File Rename (payload)
// Status: stable | Level: high | ID: 8118f61f-8178-5591-a9e1-18a696799072

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
