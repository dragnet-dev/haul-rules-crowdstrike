// Dragnet [Ransomware]: dragnet-ransomware-2024-2700 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: 980af227-cf1c-5203-8b11-249d7b1a6a8f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
