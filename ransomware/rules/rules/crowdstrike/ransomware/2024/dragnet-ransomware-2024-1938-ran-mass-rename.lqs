// Dragnet [Ransomware]: dragnet-ransomware-2024-1938 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 6bcec99c-465b-5122-b172-8ca50edf0320

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
