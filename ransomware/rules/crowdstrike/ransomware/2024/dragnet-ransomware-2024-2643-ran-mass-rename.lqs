// Dragnet [Ransomware]: dragnet-ransomware-2024-2643 — Mass File Rename (handala)
// Status: experimental | Level: high | ID: f998e3af-cd45-52d9-be74-7543323f9c00

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
