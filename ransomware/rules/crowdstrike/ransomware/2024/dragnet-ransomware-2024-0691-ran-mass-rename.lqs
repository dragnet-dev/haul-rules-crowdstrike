// Dragnet [Ransomware]: dragnet-ransomware-2024-0691 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 391156ca-de3b-5a86-9040-d8a568b677c3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
