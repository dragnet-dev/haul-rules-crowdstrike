// Dragnet [Ransomware]: dragnet-ransomware-2025-7214 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 5eb32880-63fc-5270-bb27-10bde2944ba7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
