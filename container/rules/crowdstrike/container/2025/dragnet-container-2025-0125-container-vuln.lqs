// Dragnet [Container]: dragnet-container-2025-0125 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: a93732d9-42fd-5fcf-a397-b8102d41d79f

#event_simpleName=*
| (ImageFileName = *almalinux:8* OR ImageFileName = *almalinux:9* OR ImageFileName = *chainguard:* OR ImageFileName = *oraclelinux:8* OR ImageFileName = *oraclelinux:9* OR ImageFileName = *redhat/ubi9:*)
| table([timestamp, ComputerName])
| limit(1000)
