// Dragnet [Ransomware]: dragnet-ransomware-2023-4398 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 020e3fcf-f179-56a5-9f75-fce95e7847a7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
