// Dragnet [Ransomware]: dragnet-ransomware-2025-3600 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 8a0ad15d-cfa4-57f9-99b5-151e5cf2f314

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
