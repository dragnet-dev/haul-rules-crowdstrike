// Dragnet [Ransomware]: dragnet-ransomware-2025-0959 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 9823559c-febd-5f6a-8836-6eb43fc34d52

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
