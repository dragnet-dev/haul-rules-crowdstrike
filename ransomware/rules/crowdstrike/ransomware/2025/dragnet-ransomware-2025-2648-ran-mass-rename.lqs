// Dragnet [Ransomware]: dragnet-ransomware-2025-2648 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 885e970e-c5d5-5100-94d4-c13a19c3616d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
