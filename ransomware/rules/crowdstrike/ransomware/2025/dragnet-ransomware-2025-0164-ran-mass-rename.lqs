// Dragnet [Ransomware]: dragnet-ransomware-2025-0164 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 4c225bb6-d7f8-5608-b0cf-2bca9eae95fd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
