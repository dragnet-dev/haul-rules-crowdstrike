// Dragnet [Ransomware]: dragnet-ransomware-2023-3900 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 426bada3-1226-53f3-9393-27dcf900fe5e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
