// Dragnet [Ransomware]: dragnet-ransomware-2023-3352 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: 052fd5d8-1049-5ada-a287-6ce3b0ecc4be

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
