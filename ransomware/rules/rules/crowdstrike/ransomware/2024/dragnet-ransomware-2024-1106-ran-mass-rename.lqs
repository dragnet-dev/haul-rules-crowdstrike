// Dragnet [Ransomware]: dragnet-ransomware-2024-1106 — Mass File Rename (abyss)
// Status: deprecated | Level: high | ID: 01e9dd99-0009-57f3-931a-8ecd43252695

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
