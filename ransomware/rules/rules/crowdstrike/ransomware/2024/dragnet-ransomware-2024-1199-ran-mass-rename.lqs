// Dragnet [Ransomware]: dragnet-ransomware-2024-1199 — Mass File Rename (raworld)
// Status: experimental | Level: high | ID: 7103d47b-e949-555a-88de-3cfefc1d4870

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
