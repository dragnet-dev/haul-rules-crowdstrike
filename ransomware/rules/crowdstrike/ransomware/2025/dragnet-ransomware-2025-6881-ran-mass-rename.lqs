// Dragnet [Ransomware]: dragnet-ransomware-2025-6881 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 4a1a0aa5-593c-59a1-97eb-b9458a8d1873

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
