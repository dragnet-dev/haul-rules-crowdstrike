// Dragnet [Ransomware]: dragnet-ransomware-2023-1554 — Mass File Rename (monti)
// Status: experimental | Level: high | ID: 1ccbaa16-693b-5eb2-9e6e-1d143c049d38

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
