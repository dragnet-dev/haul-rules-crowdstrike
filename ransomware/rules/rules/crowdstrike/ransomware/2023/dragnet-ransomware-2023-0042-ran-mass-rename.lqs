// Dragnet [Ransomware]: dragnet-ransomware-2023-0042 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: b21ce585-4547-5920-9bf7-267c083e737e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
