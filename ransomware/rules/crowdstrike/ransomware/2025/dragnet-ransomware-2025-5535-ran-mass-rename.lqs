// Dragnet [Ransomware]: dragnet-ransomware-2025-5535 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: b5fd7232-d41d-5f46-8b45-2f45da36aaa2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
