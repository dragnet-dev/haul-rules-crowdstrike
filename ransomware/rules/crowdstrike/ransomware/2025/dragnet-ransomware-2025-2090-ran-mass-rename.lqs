// Dragnet [Ransomware]: dragnet-ransomware-2025-2090 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 25a99972-def8-5d9c-9d19-e2dd4f5e8561

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
