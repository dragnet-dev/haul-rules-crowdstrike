// Dragnet [Ransomware]: dragnet-ransomware-2023-2868 — Mass File Rename (malas)
// Status: experimental | Level: high | ID: cd0b42dc-55f6-54cc-be00-6392de296f3a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
