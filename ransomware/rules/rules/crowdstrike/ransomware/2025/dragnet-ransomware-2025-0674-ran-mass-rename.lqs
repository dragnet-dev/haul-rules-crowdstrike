// Dragnet [Ransomware]: dragnet-ransomware-2025-0674 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: f05dd2a4-5aa7-52dc-8bbf-ef4d1529746a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
