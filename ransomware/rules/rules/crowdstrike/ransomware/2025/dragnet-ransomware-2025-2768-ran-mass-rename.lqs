// Dragnet [Ransomware]: dragnet-ransomware-2025-2768 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 268a6c24-e987-53c8-a5ce-0be6e09d6859

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
