// Dragnet [Ransomware]: dragnet-ransomware-2025-0424 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: e90a20ff-9c78-5bcf-8124-e89722d37094

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
