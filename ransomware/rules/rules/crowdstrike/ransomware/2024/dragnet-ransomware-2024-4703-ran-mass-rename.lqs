// Dragnet [Ransomware]: dragnet-ransomware-2024-4703 — Mass File Rename (handala)
// Status: experimental | Level: high | ID: bd5da72e-4810-512d-91ad-64f571103fde

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
