// Dragnet [Ransomware]: dragnet-ransomware-2025-7452 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: d19c2fa9-13e6-5692-892d-1d543ea1f8b4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
