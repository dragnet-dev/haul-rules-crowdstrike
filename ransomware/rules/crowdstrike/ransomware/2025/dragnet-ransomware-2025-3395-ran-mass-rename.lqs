// Dragnet [Ransomware]: dragnet-ransomware-2025-3395 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: ca962418-f59b-5ee8-ae27-b6edfd5756b7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
