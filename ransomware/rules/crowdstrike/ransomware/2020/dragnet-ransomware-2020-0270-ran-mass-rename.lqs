// Dragnet [Ransomware]: dragnet-ransomware-2020-0270 — Mass File Rename (egregor)
// Status: deprecated | Level: high | ID: 7aa7ddc5-31a4-5ef9-b0c3-2aa653f2d4ff

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
