// Dragnet [Ransomware]: dragnet-ransomware-2025-6014 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: d61c53d0-edcd-5996-8eaa-4428ddf4c272

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
