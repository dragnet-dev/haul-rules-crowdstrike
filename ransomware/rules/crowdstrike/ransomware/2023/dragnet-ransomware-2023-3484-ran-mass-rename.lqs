// Dragnet [Ransomware]: dragnet-ransomware-2023-3484 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: d60e711a-393b-5026-b78f-c7deccfe376a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
