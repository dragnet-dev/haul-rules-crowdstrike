// Dragnet [Ransomware]: dragnet-ransomware-2021-0423 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 747535d2-6503-5cec-9674-af1471fde8b8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
