// Dragnet [Ransomware]: dragnet-ransomware-2023-0820 — Mass File Rename (monti)
// Status: experimental | Level: high | ID: ad9b0a78-05a9-5636-a931-6caa2d926782

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
