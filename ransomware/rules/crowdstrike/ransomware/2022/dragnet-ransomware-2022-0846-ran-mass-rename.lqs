// Dragnet [Ransomware]: dragnet-ransomware-2022-0846 — Mass File Rename (sparta)
// Status: deprecated | Level: high | ID: 78b69a37-1b83-5640-8b10-dccc6ae75764

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
