// Dragnet [Ransomware]: dragnet-ransomware-2024-4405 — Mass File Rename (raworld)
// Status: experimental | Level: high | ID: f22674df-a01b-5baf-9acb-816492e96b4a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
