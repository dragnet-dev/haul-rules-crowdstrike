// Dragnet [Ransomware]: dragnet-ransomware-2025-4937 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: aaa2e3df-25ee-5514-a953-434d58f33c1e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
