// Dragnet [Ransomware]: dragnet-ransomware-2023-0693 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 4bd67679-e043-58ee-a90b-f7e94a24b2c1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
