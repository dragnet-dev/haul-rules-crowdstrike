// Dragnet [Ransomware]: dragnet-ransomware-2021-0807 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 90f82c28-988d-5a60-87b5-5e3d18e51d98

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
