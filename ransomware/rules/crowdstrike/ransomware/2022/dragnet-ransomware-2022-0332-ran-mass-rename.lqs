// Dragnet [Ransomware]: dragnet-ransomware-2022-0332 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 944ec84a-2000-5453-a04c-aa7ceab00b80

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
