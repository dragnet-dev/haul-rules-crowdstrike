// Dragnet [Ransomware]: dragnet-ransomware-2023-4728 — Mass File Rename (royal)
// Status: deprecated | Level: high | ID: b69265a1-001c-50da-9f90-2131dd8ee269

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
