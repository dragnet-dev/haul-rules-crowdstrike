// Dragnet [Ransomware]: dragnet-ransomware-2024-2437 — Mass File Rename (interlock)
// Status: experimental | Level: high | ID: 25d77dd5-5e07-5f1a-a7c6-98b6a16e5557

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
