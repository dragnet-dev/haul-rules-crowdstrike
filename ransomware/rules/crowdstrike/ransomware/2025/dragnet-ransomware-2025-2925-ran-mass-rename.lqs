// Dragnet [Ransomware]: dragnet-ransomware-2025-2925 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 8a66d222-b146-56e9-bb33-2f81c7e8a2d3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
