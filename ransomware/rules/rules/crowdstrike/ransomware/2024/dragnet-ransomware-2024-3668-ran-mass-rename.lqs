// Dragnet [Ransomware]: dragnet-ransomware-2024-3668 — Mass File Rename (dragonforce)
// Status: deprecated | Level: high | ID: ceecad6f-872e-5893-ab11-bea573f092f2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
