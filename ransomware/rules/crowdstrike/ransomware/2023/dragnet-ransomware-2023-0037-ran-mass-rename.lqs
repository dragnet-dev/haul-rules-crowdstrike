// Dragnet [Ransomware]: dragnet-ransomware-2023-0037 — Mass File Rename (noescape)
// Status: experimental | Level: high | ID: 031de8e4-bfc0-5a8a-a594-8aae5010c895

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
