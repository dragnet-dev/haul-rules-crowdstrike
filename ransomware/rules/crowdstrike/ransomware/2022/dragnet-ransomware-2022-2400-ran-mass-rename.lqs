// Dragnet [Ransomware]: dragnet-ransomware-2022-2400 — Mass File Rename (alphv)
// Status: deprecated | Level: high | ID: 394b1a6d-0f2e-568e-be5a-f2baffcd9e0d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
