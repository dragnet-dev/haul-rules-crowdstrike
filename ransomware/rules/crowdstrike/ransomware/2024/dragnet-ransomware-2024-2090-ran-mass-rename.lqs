// Dragnet [Ransomware]: dragnet-ransomware-2024-2090 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: f50c49fd-ea7c-55e7-8267-be1d550c1392

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
