// Dragnet [Ransomware]: dragnet-ransomware-2023-3078 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: c5496b85-da7b-5905-b81d-7a242b00961e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
