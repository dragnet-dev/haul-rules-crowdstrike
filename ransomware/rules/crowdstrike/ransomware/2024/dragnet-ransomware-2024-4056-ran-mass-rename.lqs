// Dragnet [Ransomware]: dragnet-ransomware-2024-4056 — Mass File Rename (nitrogen)
// Status: experimental | Level: high | ID: 59f5cbd0-e3ea-5cb4-b02a-4aefd20699b9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
