// Dragnet [Ransomware]: dragnet-ransomware-2025-5739 — Mass File Rename (nightspire)
// Status: deprecated | Level: high | ID: 57f4af0b-d45e-56b5-8dc6-9f1cf41534b2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
