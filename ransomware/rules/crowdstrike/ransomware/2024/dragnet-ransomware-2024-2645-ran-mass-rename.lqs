// Dragnet [Ransomware]: dragnet-ransomware-2024-2645 — Mass File Rename (play)
// Status: experimental | Level: high | ID: bdd65bab-7f07-5139-b33e-bde6d900dca8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
