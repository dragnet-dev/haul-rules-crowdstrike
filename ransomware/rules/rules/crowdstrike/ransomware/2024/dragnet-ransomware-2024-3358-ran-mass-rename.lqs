// Dragnet [Ransomware]: dragnet-ransomware-2024-3358 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 2698d26b-0445-52a4-b91c-ee8e4a83dd9a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
