// Dragnet [Ransomware]: dragnet-ransomware-2022-0145 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: f596c8ff-ad56-5160-99ea-f34732e8ad56

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
