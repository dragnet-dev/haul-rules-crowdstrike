// Dragnet [Ransomware]: dragnet-ransomware-2023-2873 — Mass File Rename (malas)
// Status: experimental | Level: high | ID: 7268205b-2462-50cc-a5fd-328f5a8d16a0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
