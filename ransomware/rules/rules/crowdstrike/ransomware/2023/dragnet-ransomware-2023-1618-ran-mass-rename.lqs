// Dragnet [Ransomware]: dragnet-ransomware-2023-1618 — Mass File Rename (stormous)
// Status: experimental | Level: high | ID: 6bb93cbc-8bf2-5f89-af97-e15e52feb2bf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
