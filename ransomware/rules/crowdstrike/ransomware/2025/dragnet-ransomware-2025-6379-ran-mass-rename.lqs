// Dragnet [Ransomware]: dragnet-ransomware-2025-6379 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: a8ee2d8e-9d0d-5b17-8dd9-163247e9e8ac

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
