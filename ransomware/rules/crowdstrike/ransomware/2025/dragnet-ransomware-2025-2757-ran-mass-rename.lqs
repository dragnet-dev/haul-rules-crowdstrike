// Dragnet [Ransomware]: dragnet-ransomware-2025-2757 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: 69a6fa7a-dc22-5644-b30e-6c44076ea1e6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
