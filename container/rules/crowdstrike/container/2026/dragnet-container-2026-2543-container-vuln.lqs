// Dragnet [Container]: dragnet-container-2026-2543 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: df9dd840-507a-51df-84d1-f42a04187e6e

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
