// Dragnet [Ransomware]: dragnet-ransomware-2023-5335 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: eecfe1ac-6b62-589a-abac-65736775f3a5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
