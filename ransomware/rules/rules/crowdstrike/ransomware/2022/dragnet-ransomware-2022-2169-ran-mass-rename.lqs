// Dragnet [Ransomware]: dragnet-ransomware-2022-2169 — Mass File Rename (alphv)
// Status: deprecated | Level: high | ID: 5656ae01-62ce-57c5-bb4a-cbb65e6bcda4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
