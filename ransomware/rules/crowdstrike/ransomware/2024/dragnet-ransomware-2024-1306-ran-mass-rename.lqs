// Dragnet [Ransomware]: dragnet-ransomware-2024-1306 — Mass File Rename (arcusmedia)
// Status: experimental | Level: high | ID: 9e985da2-b610-52fa-b8a3-a367e08f3471

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
