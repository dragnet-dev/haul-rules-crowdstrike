// Dragnet [Ransomware]: dragnet-ransomware-2021-1504 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: b8a9a822-f28c-5827-b151-76b8f03d78b2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
