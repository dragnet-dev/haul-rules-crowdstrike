// Dragnet [Ransomware]: dragnet-ransomware-2022-1236 — Mass File Rename (midas)
// Status: deprecated | Level: high | ID: b23730eb-1e18-5ff9-9de2-d98779a4fb0b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
