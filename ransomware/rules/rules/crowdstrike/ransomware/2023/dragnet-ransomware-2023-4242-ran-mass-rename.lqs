// Dragnet [Ransomware]: dragnet-ransomware-2023-4242 — Mass File Rename (play)
// Status: experimental | Level: high | ID: dd102447-c6b8-5e37-b68d-d351fb430767

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
