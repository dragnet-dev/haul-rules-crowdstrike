// Dragnet [Ransomware]: dragnet-ransomware-2026-2467 — Mass File Rename (nitrogen)
// Status: test | Level: high | ID: 63f40a03-908a-50cf-9802-0c94afe339e0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
