// Dragnet [Ransomware]: dragnet-ransomware-2025-1277 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 23779d9d-5b79-569d-811a-c48cc843be06

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
