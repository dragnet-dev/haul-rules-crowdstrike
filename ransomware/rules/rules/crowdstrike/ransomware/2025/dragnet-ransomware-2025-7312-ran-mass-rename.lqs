// Dragnet [Ransomware]: dragnet-ransomware-2025-7312 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: aac5eb5e-ce82-5462-9c86-7116d4bfb16c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
