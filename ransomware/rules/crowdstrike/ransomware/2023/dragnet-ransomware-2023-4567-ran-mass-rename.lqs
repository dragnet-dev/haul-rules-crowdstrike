// Dragnet [Ransomware]: dragnet-ransomware-2023-4567 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 47165cbb-e4bc-5106-8b92-b4b5ecb2dff6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
