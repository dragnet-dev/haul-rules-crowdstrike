// Dragnet [Ransomware]: dragnet-ransomware-2025-6737 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: d4396015-582e-5f07-8ad4-baf965016ea7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
