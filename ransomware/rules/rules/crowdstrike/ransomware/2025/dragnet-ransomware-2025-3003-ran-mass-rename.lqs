// Dragnet [Ransomware]: dragnet-ransomware-2025-3003 — Mass File Rename (flocker)
// Status: experimental | Level: high | ID: f01f3f4a-91e7-58d0-a737-2a188ae04e6c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
