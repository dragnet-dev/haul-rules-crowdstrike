// Dragnet [Ransomware]: dragnet-ransomware-2024-4837 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: 224b4a46-250d-51bf-9f74-ef7445c635c6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
