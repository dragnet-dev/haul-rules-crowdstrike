// Dragnet [Ransomware]: dragnet-ransomware-2024-4753 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 9ded817e-620f-575d-893a-b75b140009ec

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
