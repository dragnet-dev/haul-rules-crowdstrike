// Dragnet [Ransomware]: dragnet-ransomware-2024-3645 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: ebb0e32a-d10c-5adb-ab45-14db399e584a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
