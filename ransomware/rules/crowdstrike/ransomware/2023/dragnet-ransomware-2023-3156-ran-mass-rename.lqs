// Dragnet [Ransomware]: dragnet-ransomware-2023-3156 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: bbb924c0-26b1-5fa9-80e3-576313ca799b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
