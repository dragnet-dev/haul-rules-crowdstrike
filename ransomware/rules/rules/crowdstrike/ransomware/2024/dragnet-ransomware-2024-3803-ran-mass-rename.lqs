// Dragnet [Ransomware]: dragnet-ransomware-2024-3803 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: f49361bf-ab8d-56ca-86e6-431f7a97296f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
