// Dragnet [Ransomware]: dragnet-ransomware-2024-0041 — Mass File Rename (arcusmedia)
// Status: experimental | Level: high | ID: 3624292e-4959-593c-8d34-bafdc0141eb3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
