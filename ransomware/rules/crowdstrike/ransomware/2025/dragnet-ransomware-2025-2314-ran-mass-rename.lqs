// Dragnet [Ransomware]: dragnet-ransomware-2025-2314 — Mass File Rename (termite)
// Status: experimental | Level: high | ID: 92b2b4b1-0635-5c5d-82dd-8b5d487266ac

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
