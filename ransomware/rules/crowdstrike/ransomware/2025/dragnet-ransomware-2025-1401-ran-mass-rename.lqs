// Dragnet [Ransomware]: dragnet-ransomware-2025-1401 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: f2a019d0-825f-5126-9fb0-beb465e49b26

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
