// Dragnet [Ransomware]: dragnet-ransomware-2023-2611 — Mass File Rename (snatch)
// Status: experimental | Level: high | ID: 23bfc4ed-9936-5761-83eb-2d60650f3ad0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
