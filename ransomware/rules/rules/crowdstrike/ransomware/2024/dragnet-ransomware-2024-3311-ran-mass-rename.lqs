// Dragnet [Ransomware]: dragnet-ransomware-2024-3311 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: ead6751c-dbe4-55d2-9ce1-68dce930e390

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
