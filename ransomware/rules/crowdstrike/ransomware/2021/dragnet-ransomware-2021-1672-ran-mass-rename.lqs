// Dragnet [Ransomware]: dragnet-ransomware-2021-1672 — Mass File Rename (midas)
// Status: deprecated | Level: high | ID: dda52344-1d9e-5b2d-ae74-bcdf3cc11ceb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
