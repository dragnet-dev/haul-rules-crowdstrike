// Dragnet [Ransomware]: dragnet-ransomware-2023-0833 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 91201a9a-bed6-5702-a59a-f9475c2ed581

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
