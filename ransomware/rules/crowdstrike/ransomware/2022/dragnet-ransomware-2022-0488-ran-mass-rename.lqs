// Dragnet [Ransomware]: dragnet-ransomware-2022-0488 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: b4d60432-f041-58a2-bfe3-14c337c9bbb5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
