// Dragnet [Ransomware]: dragnet-ransomware-2025-2689 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 0fb4429a-be9f-5e9d-accf-10a23cd3c8a5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
