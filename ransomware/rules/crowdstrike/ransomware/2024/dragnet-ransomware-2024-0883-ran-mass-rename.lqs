// Dragnet [Ransomware]: dragnet-ransomware-2024-0883 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 7ddcffd9-cd05-5c12-8477-240a18d2a397

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
