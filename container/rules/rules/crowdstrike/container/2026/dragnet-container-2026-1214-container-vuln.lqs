// Dragnet [Container]: dragnet-container-2026-1214 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 59e2af61-8c7f-5a8a-9a5f-7983498ce9b8

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10*)
| table([timestamp, ComputerName])
| limit(1000)
