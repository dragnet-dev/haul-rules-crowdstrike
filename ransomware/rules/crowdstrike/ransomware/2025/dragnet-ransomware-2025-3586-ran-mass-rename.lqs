// Dragnet [Ransomware]: dragnet-ransomware-2025-3586 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: 13db1dd6-bc84-545f-a6b6-be326254b1cf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
