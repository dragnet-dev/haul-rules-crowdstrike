// Dragnet [Ransomware]: dragnet-ransomware-2023-5285 — Mass File Rename (play)
// Status: deprecated | Level: high | ID: 49e7536c-da16-5ad7-8680-407d091f3ffe

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
