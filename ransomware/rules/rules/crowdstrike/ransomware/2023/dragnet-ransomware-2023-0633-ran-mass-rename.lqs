// Dragnet [Ransomware]: dragnet-ransomware-2023-0633 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 8173e4ff-2fa7-53a2-a655-485d0607bac8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
