// Dragnet [Container]: dragnet-container-2026-1888 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 2b88cd61-352f-57e5-84ba-891f6a92f179

#event_simpleName=*
| (ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10*)
| table([timestamp, ComputerName])
| limit(1000)
