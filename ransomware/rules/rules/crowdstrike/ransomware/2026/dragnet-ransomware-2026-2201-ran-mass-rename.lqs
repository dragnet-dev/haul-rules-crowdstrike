// Dragnet [Ransomware]: dragnet-ransomware-2026-2201 — Mass File Rename (coinbasecartel)
// Status: stable | Level: high | ID: 294d98c6-0aab-57e4-b9cc-ac39a8bf517c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
