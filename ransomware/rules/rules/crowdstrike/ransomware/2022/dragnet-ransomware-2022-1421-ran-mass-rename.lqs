// Dragnet [Ransomware]: dragnet-ransomware-2022-1421 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 2ca8f491-c8d3-5ebf-9c4b-3a8fdb01f8fd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
