// Dragnet [Ransomware]: dragnet-ransomware-2025-7770 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 387aa481-d034-5a0e-9d6a-97954c1f49c3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
