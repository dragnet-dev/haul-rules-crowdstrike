// Dragnet [Ransomware]: dragnet-ransomware-2025-0543 — Mass File Rename (direwolf)
// Status: experimental | Level: high | ID: 9203b01a-a770-506f-a77e-9b399316c271

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
