// Dragnet [Ransomware]: dragnet-ransomware-2025-7222 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: 561d43e0-1501-55ab-aede-c3534cc46572

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
