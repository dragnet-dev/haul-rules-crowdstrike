// Dragnet [Ransomware]: dragnet-ransomware-2023-5359 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: d36e237b-d1fa-597d-8ab0-a29e76c23c16

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
