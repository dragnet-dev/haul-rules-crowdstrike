// Dragnet [Ransomware]: dragnet-ransomware-2024-1602 — Mass File Rename (blacklock)
// Status: experimental | Level: high | ID: 71c8d876-aedf-5272-badc-c7724b8e0317

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
