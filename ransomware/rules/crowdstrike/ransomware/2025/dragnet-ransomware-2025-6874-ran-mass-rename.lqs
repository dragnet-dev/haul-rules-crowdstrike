// Dragnet [Ransomware]: dragnet-ransomware-2025-6874 — Mass File Rename (ransomexx)
// Status: experimental | Level: high | ID: 7cb465fe-e1ee-5d23-b073-8981ec201cff

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
