// Dragnet [Ransomware]: dragnet-ransomware-2025-1233 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: adb06d07-8276-5d1b-ac1c-8c9d208b96fb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
