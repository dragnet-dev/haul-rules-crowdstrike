// Dragnet [Ransomware]: dragnet-ransomware-2025-4616 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 54193553-1b40-57ee-987c-138454a8183e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
