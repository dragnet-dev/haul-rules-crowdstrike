// Dragnet [Ransomware]: dragnet-ransomware-2025-0675 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: fa95236f-4af9-5e5d-bd03-c258afc7ff8f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
