// Dragnet [Ransomware]: dragnet-ransomware-2023-4662 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 0de3d97e-1fc3-5e19-b362-6489c30cef10

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
