// Dragnet [Ransomware]: dragnet-ransomware-2025-6076 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 1a20c51b-f52f-5f0c-9903-4c9f10d385b4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
