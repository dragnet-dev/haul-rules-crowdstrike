// Dragnet [Ransomware]: dragnet-ransomware-2025-6179 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: f851a0be-f8ba-540f-904a-2b4f988d62f8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
