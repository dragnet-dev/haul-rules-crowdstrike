// Dragnet [Ransomware]: dragnet-ransomware-2023-5296 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 81d0f8c8-cc93-5e5e-92e7-939faf477b91

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
