// Dragnet [Ransomware]: dragnet-ransomware-2025-7759 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: afb88eb6-4605-5f40-be38-60069eab3143

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
