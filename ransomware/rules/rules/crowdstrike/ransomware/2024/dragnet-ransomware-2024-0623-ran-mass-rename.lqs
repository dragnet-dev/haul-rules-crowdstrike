// Dragnet [Ransomware]: dragnet-ransomware-2024-0623 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: bb143153-21e4-5db4-b2b2-6dd277ad2362

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
