// Dragnet [Ransomware]: dragnet-ransomware-2022-0053 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 1f28317c-8dec-50c3-8d17-317269bc1d6c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
