// Dragnet [Ransomware]: dragnet-ransomware-2023-0091 — Mass File Rename (knight)
// Status: experimental | Level: high | ID: ecd220f7-a63d-5767-a7ad-fcf7678d2917

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
