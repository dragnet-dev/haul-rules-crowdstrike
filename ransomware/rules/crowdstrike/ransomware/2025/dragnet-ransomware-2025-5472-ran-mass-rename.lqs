// Dragnet [Ransomware]: dragnet-ransomware-2025-5472 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: ec002965-2a3b-5841-a05c-a8d2eb17d54e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
