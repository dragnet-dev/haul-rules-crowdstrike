// Dragnet [Ransomware]: dragnet-ransomware-2026-0190 — Mass File Rename (everest)
// Status: stable | Level: high | ID: b8147c17-3028-5315-a858-a09b9ea54ea3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
