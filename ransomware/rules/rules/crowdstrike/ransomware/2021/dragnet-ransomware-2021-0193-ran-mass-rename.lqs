// Dragnet [Ransomware]: dragnet-ransomware-2021-0193 — Mass File Rename (everest)
// Status: deprecated | Level: high | ID: 2f450822-655a-5b39-8d64-cf7d2a0569d1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
