// Dragnet [Ransomware]: dragnet-ransomware-2023-3527 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 6df69a62-6bd3-5ec6-be6a-ef1b5f6b4a12

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
