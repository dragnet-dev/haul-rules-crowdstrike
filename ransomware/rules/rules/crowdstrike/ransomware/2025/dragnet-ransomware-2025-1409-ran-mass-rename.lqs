// Dragnet [Ransomware]: dragnet-ransomware-2025-1409 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 16595439-2fb4-5058-be15-6533052943d1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
