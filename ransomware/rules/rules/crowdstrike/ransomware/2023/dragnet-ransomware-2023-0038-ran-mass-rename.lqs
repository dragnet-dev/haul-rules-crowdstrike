// Dragnet [Ransomware]: dragnet-ransomware-2023-0038 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: f6c4bf8c-f0ca-51be-92a6-22a7b2426ca2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
