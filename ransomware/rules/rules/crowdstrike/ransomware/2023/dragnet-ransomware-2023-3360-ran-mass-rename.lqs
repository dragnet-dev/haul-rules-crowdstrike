// Dragnet [Ransomware]: dragnet-ransomware-2023-3360 — Mass File Rename (raworld)
// Status: experimental | Level: high | ID: 6fd07237-5a71-5192-831e-6a4133f50aae

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
