// Dragnet [Ransomware]: dragnet-ransomware-2026-0972 — Mass File Rename (benzona)
// Status: deprecated | Level: high | ID: 968e1662-669b-5522-9d7e-b2e938466e1a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
