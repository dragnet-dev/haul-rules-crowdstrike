// Dragnet [Ransomware]: dragnet-ransomware-2023-1628 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: b57ec4ac-4a8b-52b0-8ed6-e096a5bf6cc2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
