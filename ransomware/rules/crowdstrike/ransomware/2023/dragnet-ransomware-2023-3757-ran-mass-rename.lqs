// Dragnet [Ransomware]: dragnet-ransomware-2023-3757 — Mass File Rename (ransomed)
// Status: experimental | Level: high | ID: a6c4ff58-37fa-5dbd-8017-2f98c4e9e7c6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
