// Dragnet [Ransomware]: dragnet-ransomware-2024-5467 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: a5c35a0f-0a45-5fc3-ab0a-c96343737591

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
