// Dragnet [Ransomware]: dragnet-ransomware-2024-1420 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 0235d928-ed47-519b-af81-a605515be707

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
