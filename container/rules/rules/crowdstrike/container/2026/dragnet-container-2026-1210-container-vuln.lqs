// Dragnet [Container]: dragnet-container-2026-1210 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 0358db44-4dd7-5751-8c02-1c8f50395d87

#event_simpleName=*
| (ImageFileName = *amazonlinux:1* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:7* OR ImageFileName = *debian:8* OR ImageFileName = *oraclelinux:7* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:14.04* OR ImageFileName = *ubuntu:14.04-ESM* OR ImageFileName = *ubuntu:15.10*)
| table([timestamp, ComputerName])
| limit(1000)
