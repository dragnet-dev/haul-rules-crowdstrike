// Dragnet [Ransomware]: dragnet-ransomware-2022-2900 — Mass File Rename (sparta)
// Status: deprecated | Level: high | ID: 7a90bf56-93bc-5211-9c2b-fb0f5206f912

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
