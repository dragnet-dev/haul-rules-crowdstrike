// Dragnet [Ransomware]: dragnet-ransomware-2023-3183 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 57c496ff-aa47-5277-b3dd-7b5888bc2c93

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
