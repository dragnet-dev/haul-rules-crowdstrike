// Dragnet [Ransomware]: dragnet-ransomware-2024-5929 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 67f9097c-2b0c-52a7-874f-26970d167a3d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
