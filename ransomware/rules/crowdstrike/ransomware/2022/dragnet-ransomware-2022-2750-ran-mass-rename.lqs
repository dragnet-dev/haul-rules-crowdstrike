// Dragnet [Ransomware]: dragnet-ransomware-2022-2750 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 594f7d5e-73c4-5d19-8590-9264f28265d7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
