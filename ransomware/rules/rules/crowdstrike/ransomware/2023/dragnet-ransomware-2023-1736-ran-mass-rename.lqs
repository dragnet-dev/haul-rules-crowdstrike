// Dragnet [Ransomware]: dragnet-ransomware-2023-1736 — Mass File Rename (rhysida)
// Status: experimental | Level: high | ID: ccc53448-a937-5586-ade1-47a4a32eece3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
