// Dragnet [Ransomware]: dragnet-ransomware-2025-2560 — Mass File Rename (apos)
// Status: experimental | Level: high | ID: 8dd3a32b-0bb9-5818-9743-f954b69d2af5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
