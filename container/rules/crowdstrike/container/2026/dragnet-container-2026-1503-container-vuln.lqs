// Dragnet [Container]: dragnet-container-2026-1503 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 3c96296f-9ab1-5ec3-aa17-2c1f345e01f9

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:7* OR ImageFileName = *debian:8* OR ImageFileName = *debian:9* OR ImageFileName = *ubuntu:16.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
