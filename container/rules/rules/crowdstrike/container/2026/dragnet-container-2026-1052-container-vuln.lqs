// Dragnet [Container]: dragnet-container-2026-1052 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 70114b42-e2e7-5f18-a9fa-14fc3997fe95

#event_simpleName=*
| (ImageFileName = *alpine:3.3* OR ImageFileName = *alpine:3.4* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:8* OR ImageFileName = *ubuntu:16.04* OR ImageFileName = *ubuntu:16.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
