// Dragnet [Ransomware]: dragnet-ransomware-2022-1006 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 0b79f778-9670-5b6b-854f-09f81bf47b5c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
