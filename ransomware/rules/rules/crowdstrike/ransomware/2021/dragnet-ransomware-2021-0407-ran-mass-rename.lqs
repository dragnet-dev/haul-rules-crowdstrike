// Dragnet [Ransomware]: dragnet-ransomware-2021-0407 — Mass File Rename (avoslocker)
// Status: deprecated | Level: high | ID: 29ad38ba-259f-5401-af2e-56ed83af4c45

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
