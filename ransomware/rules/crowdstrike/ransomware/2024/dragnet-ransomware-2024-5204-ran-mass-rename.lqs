// Dragnet [Ransomware]: dragnet-ransomware-2024-5204 — Mass File Rename (play)
// Status: experimental | Level: high | ID: adbe111a-b300-5f5d-907a-bf0b9918cf7f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
