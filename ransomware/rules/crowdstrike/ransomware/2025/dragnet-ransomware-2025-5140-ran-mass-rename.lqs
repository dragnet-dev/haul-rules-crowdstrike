// Dragnet [Ransomware]: dragnet-ransomware-2025-5140 — Mass File Rename (sinobi)
// Status: experimental | Level: high | ID: fb7ae847-542a-5fb9-b319-d6292c5b5961

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
