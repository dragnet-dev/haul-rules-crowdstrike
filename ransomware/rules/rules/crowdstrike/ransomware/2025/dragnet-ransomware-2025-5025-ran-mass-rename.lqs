// Dragnet [Ransomware]: dragnet-ransomware-2025-5025 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 41e9bbf8-2059-5b05-b93e-0116a90ecb81

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
