// Dragnet [Ransomware]: dragnet-ransomware-2024-4250 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 2e9d3290-9f05-55b3-a126-822e1e83c208

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
