// Dragnet [Ransomware]: dragnet-ransomware-2024-0465 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: c90dedb9-40f8-5c8d-8196-532c78371295

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
