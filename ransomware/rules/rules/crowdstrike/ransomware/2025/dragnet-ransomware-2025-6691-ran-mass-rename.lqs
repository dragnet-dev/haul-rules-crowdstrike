// Dragnet [Ransomware]: dragnet-ransomware-2025-6691 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: d519408b-8423-558b-90fc-3a2dd8be10b7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
