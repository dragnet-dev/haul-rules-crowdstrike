// Dragnet [Ransomware]: dragnet-ransomware-2024-4781 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 439fbc2f-12f0-5462-a481-9e0fb232645b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
