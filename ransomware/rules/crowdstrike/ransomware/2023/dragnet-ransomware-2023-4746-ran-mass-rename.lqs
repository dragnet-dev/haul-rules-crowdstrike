// Dragnet [Ransomware]: dragnet-ransomware-2023-4746 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: e6f296be-a247-5017-83a4-6bd8dbee0719

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
