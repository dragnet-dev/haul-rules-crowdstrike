// Dragnet [Ransomware]: dragnet-ransomware-2024-4501 — Mass File Rename (dAn0n)
// Status: experimental | Level: high | ID: 1ca7ad02-27ab-5757-9cae-fbebd25005ec

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
