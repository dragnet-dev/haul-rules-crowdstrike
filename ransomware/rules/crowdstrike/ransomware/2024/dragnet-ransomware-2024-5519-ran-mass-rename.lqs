// Dragnet [Ransomware]: dragnet-ransomware-2024-5519 — Mass File Rename (monti)
// Status: experimental | Level: high | ID: 0e30bcf7-5c53-5693-8d57-e2feaabf6061

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
