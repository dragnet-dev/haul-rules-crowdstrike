// Dragnet [Ransomware]: dragnet-ransomware-2022-0978 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 45a56c8b-a0b6-5603-83c5-21b0c60af9fb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
