// Dragnet [Ransomware]: dragnet-ransomware-2021-1347 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: ec9ee22b-c396-537a-bdc2-374190cc95de

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
