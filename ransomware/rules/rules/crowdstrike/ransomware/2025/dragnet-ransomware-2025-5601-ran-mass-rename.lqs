// Dragnet [Ransomware]: dragnet-ransomware-2025-5601 — Mass File Rename (cephalus)
// Status: deprecated | Level: high | ID: 326eb7dd-59ca-538a-a545-2107bd82a24f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
