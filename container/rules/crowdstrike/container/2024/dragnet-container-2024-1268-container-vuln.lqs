// Dragnet [Container]: dragnet-container-2024-1268 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 39f0017f-d25c-59ec-adb6-a8ae3dd58779

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *ubuntu:16.04* OR ImageFileName = *ubuntu:16.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
