// Dragnet [Ransomware]: dragnet-ransomware-2023-1106 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: d07d629d-69fd-5aca-a15e-0536e23c361b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
