// Dragnet [Ransomware]: dragnet-ransomware-2025-0981 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 09b481fc-92e4-591f-a7c5-2517e168b6fa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
