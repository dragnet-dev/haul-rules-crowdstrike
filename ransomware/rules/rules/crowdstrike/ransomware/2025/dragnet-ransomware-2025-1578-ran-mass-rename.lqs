// Dragnet [Ransomware]: dragnet-ransomware-2025-1578 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: 8f7fc701-f843-54e1-8d2d-bc6ad4e628cf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
