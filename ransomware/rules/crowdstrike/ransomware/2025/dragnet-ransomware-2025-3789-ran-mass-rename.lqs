// Dragnet [Ransomware]: dragnet-ransomware-2025-3789 — Mass File Rename (obscura)
// Status: deprecated | Level: high | ID: 3ebb6065-cef2-5408-be37-ab7d9c43ab8e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
