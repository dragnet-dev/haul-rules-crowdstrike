// Dragnet [Ransomware]: dragnet-ransomware-2022-2884 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 1aa47276-babe-5063-b5a1-da70b7329ae2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
