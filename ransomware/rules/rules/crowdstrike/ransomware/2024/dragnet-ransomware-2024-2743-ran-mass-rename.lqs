// Dragnet [Ransomware]: dragnet-ransomware-2024-2743 — Mass File Rename (stormous)
// Status: deprecated | Level: high | ID: 0abc5b86-df62-5711-bcda-f1ffeba40d71

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
