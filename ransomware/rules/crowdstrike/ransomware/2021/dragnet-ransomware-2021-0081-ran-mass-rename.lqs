// Dragnet [Ransomware]: dragnet-ransomware-2021-0081 — Mass File Rename (azroteam)
// Status: deprecated | Level: high | ID: 8476d00e-4aaa-5585-90dc-5bc13d09fd5a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
