// Dragnet [Ransomware]: dragnet-ransomware-2024-2152 — Mass File Rename (helldown)
// Status: experimental | Level: high | ID: b7097ed0-7f74-589d-8b25-6d14ec233c51

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
