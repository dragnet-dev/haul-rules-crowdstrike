// Dragnet [Container]: dragnet-container-2026-1742 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: df5ce9a6-c6b3-57c8-a507-b224bf85ef62

#event_simpleName=*
| (ImageFileName = *debian:7* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10* OR ImageFileName = *ubuntu:13.04* OR ImageFileName = *ubuntu:13.10*)
| table([timestamp, ComputerName])
| limit(1000)
