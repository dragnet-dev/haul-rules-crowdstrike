// Dragnet [Ransomware]: dragnet-ransomware-2021-0135 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 4d3239dc-51d5-5334-8510-4efd0f18734c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
