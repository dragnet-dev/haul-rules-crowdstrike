// Dragnet [Ransomware]: dragnet-ransomware-2024-4375 — Mass File Rename (snatch)
// Status: experimental | Level: high | ID: 412dd6aa-b9f0-5dfd-b601-899319bbb23c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
