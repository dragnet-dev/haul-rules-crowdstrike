// Dragnet [Ransomware]: dragnet-ransomware-2022-0288 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: 9a3ae016-5124-5c73-af63-6cd3abc40bf8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
