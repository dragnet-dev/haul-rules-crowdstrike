// Dragnet [Ransomware]: dragnet-ransomware-2023-1974 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 4a26c39c-0823-5496-b14c-d7c0aa210e90

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
