// Dragnet [Ransomware]: dragnet-ransomware-2023-1222 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 8c2e2d4f-76b9-5a3e-9776-57ab69b0d534

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
