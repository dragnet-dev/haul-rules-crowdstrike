// Dragnet [Ransomware]: dragnet-ransomware-2023-0059 — Mass File Rename (qilin)
// Status: deprecated | Level: high | ID: 3247b30e-efca-5dde-9d06-352be7c20a6f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
