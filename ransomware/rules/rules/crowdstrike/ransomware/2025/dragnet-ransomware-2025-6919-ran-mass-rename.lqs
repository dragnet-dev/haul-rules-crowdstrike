// Dragnet [Ransomware]: dragnet-ransomware-2025-6919 — Mass File Rename (blacknevas)
// Status: experimental | Level: high | ID: 55432dfe-41cf-5443-8823-7272081ac96f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
