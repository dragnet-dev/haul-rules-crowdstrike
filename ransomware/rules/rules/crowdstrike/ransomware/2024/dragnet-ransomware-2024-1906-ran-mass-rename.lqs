// Dragnet [Ransomware]: dragnet-ransomware-2024-1906 — Mass File Rename (thegentlemen)
// Status: experimental | Level: high | ID: 4c852d76-1b1e-5935-ba44-365d2390a1cf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
