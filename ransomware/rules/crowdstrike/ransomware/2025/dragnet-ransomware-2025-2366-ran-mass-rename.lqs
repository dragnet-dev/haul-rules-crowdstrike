// Dragnet [Ransomware]: dragnet-ransomware-2025-2366 — Mass File Rename (incransom)
// Status: test | Level: high | ID: dd20ef23-0e0c-5623-9554-b743c6e51b89

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
