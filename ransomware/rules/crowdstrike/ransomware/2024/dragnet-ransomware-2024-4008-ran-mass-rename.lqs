// Dragnet [Ransomware]: dragnet-ransomware-2024-4008 — Mass File Rename (ransomhouse)
// Status: experimental | Level: high | ID: 13672b6e-372b-53aa-a388-fe4d1ae415b3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
