// Dragnet [Ransomware]: dragnet-ransomware-2025-2596 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 06044113-3cc5-55a1-a66f-e9f8b22e621e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
