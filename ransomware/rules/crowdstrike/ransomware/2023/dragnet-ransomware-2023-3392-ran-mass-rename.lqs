// Dragnet [Ransomware]: dragnet-ransomware-2023-3392 — Mass File Rename (play)
// Status: experimental | Level: high | ID: fca5a41b-0a14-56e6-abbe-51734fc0f7fd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
