// Dragnet [Ransomware]: dragnet-ransomware-2026-2934 — Mass File Rename (payoutsking)
// Status: stable | Level: high | ID: 44a581c2-540a-5c2f-9b24-f225f555b166

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
