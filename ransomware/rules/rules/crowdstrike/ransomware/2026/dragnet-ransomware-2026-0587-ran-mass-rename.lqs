// Dragnet [Ransomware]: dragnet-ransomware-2026-0587 — Mass File Rename (AuditTeam)
// Status: stable | Level: high | ID: a974d9e0-709f-5459-8fe4-c3bf76b324d3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
