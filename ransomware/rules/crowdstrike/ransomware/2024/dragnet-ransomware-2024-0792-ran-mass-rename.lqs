// Dragnet [Ransomware]: dragnet-ransomware-2024-0792 — Mass File Rename (stormous)
// Status: deprecated | Level: high | ID: 9d7026de-3868-53a8-b446-f84759ada70b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
