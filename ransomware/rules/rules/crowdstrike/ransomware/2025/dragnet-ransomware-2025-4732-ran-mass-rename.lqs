// Dragnet [Ransomware]: dragnet-ransomware-2025-4732 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 09378f04-a912-5f60-ae04-baf80a693541

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
