// Dragnet [Ransomware]: dragnet-ransomware-2024-3765 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: a674cd6f-a2c8-5864-8beb-6bb3384ac9d8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
