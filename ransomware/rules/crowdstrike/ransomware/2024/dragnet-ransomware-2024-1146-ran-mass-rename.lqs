// Dragnet [Ransomware]: dragnet-ransomware-2024-1146 — Mass File Rename (medusalocker)
// Status: experimental | Level: high | ID: 225a34eb-ff47-560d-b3d2-77a8f724086d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
