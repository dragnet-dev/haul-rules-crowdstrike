// Dragnet [Ransomware]: dragnet-ransomware-2025-5451 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: f2e2baf2-b9ee-50d4-813f-862a5666e321

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
