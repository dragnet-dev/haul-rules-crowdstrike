// Dragnet [Ransomware]: dragnet-ransomware-2025-3010 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: d1b19faa-e879-562d-a94f-1b84bf4f929c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
