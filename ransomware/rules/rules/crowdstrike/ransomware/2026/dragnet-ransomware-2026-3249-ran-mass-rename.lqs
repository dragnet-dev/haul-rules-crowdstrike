// Dragnet [Ransomware]: dragnet-ransomware-2026-3249 — Mass File Rename (shinyhunters)
// Status: deprecated | Level: high | ID: 2cd69f8e-621c-5342-a296-e3983983809c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
