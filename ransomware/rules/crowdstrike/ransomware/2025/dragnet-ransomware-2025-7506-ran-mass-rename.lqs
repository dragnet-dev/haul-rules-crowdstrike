// Dragnet [Ransomware]: dragnet-ransomware-2025-7506 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: d258dbc6-78c8-5829-8261-33371aabf86e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
