// Dragnet [Ransomware]: dragnet-ransomware-2025-0348 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: afea4a54-c43e-5767-9d19-b45968e7085d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
