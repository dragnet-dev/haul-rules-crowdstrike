// Dragnet [Ransomware]: dragnet-ransomware-2025-3826 — Mass File Rename (kairos)
// Status: experimental | Level: high | ID: 61a5e792-7b5f-5b4e-8402-776cd6b8ae64

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
