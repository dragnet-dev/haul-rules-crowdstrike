// Dragnet [Ransomware]: dragnet-ransomware-2022-0696 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 3778d143-8e32-5844-a551-8eb51b01ddbb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
