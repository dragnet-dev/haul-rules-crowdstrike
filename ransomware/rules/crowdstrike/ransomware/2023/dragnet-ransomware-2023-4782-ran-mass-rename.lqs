// Dragnet [Ransomware]: dragnet-ransomware-2023-4782 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 24358a26-8e6c-5243-b93a-51b0f090b916

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
