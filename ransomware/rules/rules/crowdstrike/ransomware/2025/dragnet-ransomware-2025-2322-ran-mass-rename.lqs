// Dragnet [Ransomware]: dragnet-ransomware-2025-2322 — Mass File Rename (ralord)
// Status: experimental | Level: high | ID: 61098f2c-6710-530f-9fdb-f5c77611d739

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
