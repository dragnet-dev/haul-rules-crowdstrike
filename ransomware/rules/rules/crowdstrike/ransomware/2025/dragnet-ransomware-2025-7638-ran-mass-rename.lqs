// Dragnet [Ransomware]: dragnet-ransomware-2025-7638 — Mass File Rename (nova)
// Status: experimental | Level: high | ID: 8708c8b6-ff46-59d9-ae41-423da67615cb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
