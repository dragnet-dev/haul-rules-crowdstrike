// Dragnet [Ransomware]: dragnet-ransomware-2025-6338 — Mass File Rename (nightspire)
// Status: deprecated | Level: high | ID: 7db9078e-9b41-5dd2-8a3e-ad9e36afc8b8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
