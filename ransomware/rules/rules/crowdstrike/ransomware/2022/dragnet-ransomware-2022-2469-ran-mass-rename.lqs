// Dragnet [Ransomware]: dragnet-ransomware-2022-2469 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 69791de3-954c-58f3-8e3a-3965d1013d60

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
