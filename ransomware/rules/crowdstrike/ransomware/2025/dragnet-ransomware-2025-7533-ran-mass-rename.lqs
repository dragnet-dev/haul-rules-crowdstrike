// Dragnet [Ransomware]: dragnet-ransomware-2025-7533 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 86faef48-45f4-5a72-be32-2fa797f33e1f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
