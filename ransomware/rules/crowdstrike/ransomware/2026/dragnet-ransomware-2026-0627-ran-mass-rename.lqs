// Dragnet [Ransomware]: dragnet-ransomware-2026-0627 — Mass File Rename (nightspire)
// Status: deprecated | Level: high | ID: c65f91b7-aec4-571c-bffa-c5e4fbeea30d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
