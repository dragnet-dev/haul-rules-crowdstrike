// Dragnet [Ransomware]: dragnet-ransomware-2023-2589 — Mass File Rename (play)
// Status: experimental | Level: high | ID: c82d5359-542b-5891-92e9-bb49320fcf9c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
