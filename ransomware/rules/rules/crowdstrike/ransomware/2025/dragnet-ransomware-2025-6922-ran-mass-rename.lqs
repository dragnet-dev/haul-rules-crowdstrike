// Dragnet [Ransomware]: dragnet-ransomware-2025-6922 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 38812e2f-c045-58fa-b302-2d2662f10c5f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
