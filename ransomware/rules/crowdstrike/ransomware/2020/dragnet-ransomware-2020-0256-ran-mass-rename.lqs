// Dragnet [Ransomware]: dragnet-ransomware-2020-0256 — Mass File Rename (maze)
// Status: deprecated | Level: high | ID: 690b7356-e186-5efe-a4d4-5f38c0c73ffb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
