// Dragnet [Ransomware]: dragnet-ransomware-2025-1140 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 872536a8-26e7-58ac-b6bf-abdf65c996e7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
