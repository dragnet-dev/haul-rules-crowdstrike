// Dragnet [Ransomware]: dragnet-ransomware-2021-1651 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: e079e4bf-5df9-5d46-bda4-fdbf29fade0d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
