// Dragnet [Ransomware]: dragnet-ransomware-2024-4957 — Mass File Rename (play)
// Status: experimental | Level: high | ID: da5d1b08-d1d0-5178-ac9e-9c506b2fccc3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
