// Dragnet [Ransomware]: dragnet-ransomware-2023-2856 — Mass File Rename (malas)
// Status: experimental | Level: high | ID: 0713832c-906e-520a-a093-edef2405f456

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
