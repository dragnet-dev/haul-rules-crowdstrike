// Dragnet [Ransomware]: dragnet-ransomware-2023-1837 — Mass File Rename (royal)
// Status: experimental | Level: high | ID: 23591b1a-8b42-56d2-a83f-4b0ab37c48b4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
