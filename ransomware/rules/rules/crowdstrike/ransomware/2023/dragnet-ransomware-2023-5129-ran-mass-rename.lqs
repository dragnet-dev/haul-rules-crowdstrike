// Dragnet [Ransomware]: dragnet-ransomware-2023-5129 — Mass File Rename (ciphbit)
// Status: deprecated | Level: high | ID: 87119740-2291-5772-a4df-42bfca8b5c54

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
