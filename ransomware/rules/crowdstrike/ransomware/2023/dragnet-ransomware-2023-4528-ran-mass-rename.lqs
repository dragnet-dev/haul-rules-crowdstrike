// Dragnet [Ransomware]: dragnet-ransomware-2023-4528 — Mass File Rename (ragnarlocker)
// Status: experimental | Level: high | ID: bba9977e-38e7-56f7-abf0-644fa730a898

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
