// Dragnet [Ransomware]: dragnet-ransomware-2024-5671 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 2eaf83b1-cab8-5435-b843-8fbb3cf72cbd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
