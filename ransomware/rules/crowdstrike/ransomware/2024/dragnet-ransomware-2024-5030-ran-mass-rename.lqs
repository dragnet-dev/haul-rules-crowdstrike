// Dragnet [Ransomware]: dragnet-ransomware-2024-5030 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: b3a8e1c6-3219-56ca-8e0d-b7b14cab507e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
