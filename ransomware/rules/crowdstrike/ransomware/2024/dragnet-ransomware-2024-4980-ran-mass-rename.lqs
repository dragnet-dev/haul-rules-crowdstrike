// Dragnet [Ransomware]: dragnet-ransomware-2024-4980 — Mass File Rename (safepay)
// Status: deprecated | Level: high | ID: f4801c6d-80e1-5598-a37b-7e6e4fc95363

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
