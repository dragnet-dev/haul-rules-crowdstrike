// Dragnet [Ransomware]: dragnet-ransomware-2025-5715 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: b8d8fed1-4f53-543b-b4ee-57984ef3c0b9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
