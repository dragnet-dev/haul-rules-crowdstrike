// Dragnet [Ransomware]: dragnet-ransomware-2025-7307 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: dad1d136-9192-541f-b708-a8adbab75b7c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
