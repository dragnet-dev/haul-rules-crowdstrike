// Dragnet [Ransomware]: dragnet-ransomware-2025-3218 — Mass File Rename (lockbit5)
// Status: test | Level: high | ID: bc8ea384-39b5-5440-8ba5-b081b3a21b8d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
