// Dragnet [Ransomware]: dragnet-ransomware-2026-3240 — Mass File Rename (lockbit5)
// Status: stable | Level: high | ID: 9c1ef8cb-d41f-59f4-8a08-d20d9df4d7f8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
