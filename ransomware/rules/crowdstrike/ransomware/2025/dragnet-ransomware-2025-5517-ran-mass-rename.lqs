// Dragnet [Ransomware]: dragnet-ransomware-2025-5517 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: f62742c2-b2f5-5b33-865d-7bccc82b7b27

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
