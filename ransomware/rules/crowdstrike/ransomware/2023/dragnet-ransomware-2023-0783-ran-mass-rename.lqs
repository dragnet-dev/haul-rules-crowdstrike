// Dragnet [Ransomware]: dragnet-ransomware-2023-0783 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 5d00eb0e-0d27-523f-9f62-5ce8a571f82b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
