// Dragnet [Ransomware]: dragnet-ransomware-2025-2631 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: c9ab49fb-6f8a-55be-82a6-e297e68573a8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
