// Dragnet [Ransomware]: dragnet-ransomware-2023-1147 — Mass File Rename (royal)
// Status: experimental | Level: high | ID: 5a6d5035-2752-5d5a-aeda-ec6548900ae8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
