// Dragnet [Container]: dragnet-container-2026-0349 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: d9233f77-188e-5c3e-9219-c05a5a144a52

#event_simpleName=*
| (ImageFileName = *chainguard:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
