// Dragnet [Ransomware]: dragnet-ransomware-2024-5830 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: c273b538-63a5-5cd8-818c-2d06e5de0f74

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
