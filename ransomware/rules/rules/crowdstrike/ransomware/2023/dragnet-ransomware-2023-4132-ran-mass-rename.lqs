// Dragnet [Ransomware]: dragnet-ransomware-2023-4132 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 0a00ddfc-979a-5537-98f3-24d3ad633351

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
