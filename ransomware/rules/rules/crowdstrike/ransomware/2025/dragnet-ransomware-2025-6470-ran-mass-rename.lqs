// Dragnet [Ransomware]: dragnet-ransomware-2025-6470 — Mass File Rename (nova)
// Status: experimental | Level: high | ID: 674da6bc-ee96-5515-9545-2dee03ae2725

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
