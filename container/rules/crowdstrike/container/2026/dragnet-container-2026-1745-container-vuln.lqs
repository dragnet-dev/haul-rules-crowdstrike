// Dragnet [Container]: dragnet-container-2026-1745 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 542a64b0-35f6-521e-953b-8484b0804376

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:7* OR ImageFileName = *oraclelinux:7* OR ImageFileName = *redhat/ubi9:*)
| table([timestamp, ComputerName])
| limit(1000)
