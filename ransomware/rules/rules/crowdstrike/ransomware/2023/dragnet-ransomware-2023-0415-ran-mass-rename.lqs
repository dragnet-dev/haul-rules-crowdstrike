// Dragnet [Ransomware]: dragnet-ransomware-2023-0415 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 376241ef-b9b8-5ec7-a29f-76722fa4da33

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
