// Dragnet [Ransomware]: dragnet-ransomware-2024-0176 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: 812efc35-14a6-5650-850e-8aed1e77f25f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
