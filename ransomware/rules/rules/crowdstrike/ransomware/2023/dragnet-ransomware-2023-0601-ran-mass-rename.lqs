// Dragnet [Ransomware]: dragnet-ransomware-2023-0601 — Mass File Rename (knight)
// Status: experimental | Level: high | ID: d9e3a270-aa69-5278-b466-6db132de5d1a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
