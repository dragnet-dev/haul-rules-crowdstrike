// Dragnet [Ransomware]: dragnet-ransomware-2024-2366 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: b9307bf1-c81b-5523-a99f-21c7f3edcfda

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
