// Dragnet [Ransomware]: dragnet-ransomware-2025-4503 — Mass File Rename (interlock)
// Status: experimental | Level: high | ID: 3c8917ef-cb60-57cc-80bd-cc5fe7964be1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
