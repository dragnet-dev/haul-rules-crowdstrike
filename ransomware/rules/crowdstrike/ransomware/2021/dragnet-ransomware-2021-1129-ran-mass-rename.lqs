// Dragnet [Ransomware]: dragnet-ransomware-2021-1129 — Mass File Rename (avaddon)
// Status: deprecated | Level: high | ID: b4e9dd76-1cd4-5b8d-a4c5-0816022e3ba3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
