// Dragnet [Ransomware]: dragnet-ransomware-2024-0744 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 56ff92e2-f977-59dd-ba9d-3582ba6ed94c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
