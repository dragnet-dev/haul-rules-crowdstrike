// Dragnet [Ransomware]: dragnet-ransomware-2024-0113 — Mass File Rename (orca)
// Status: experimental | Level: high | ID: 1b64a476-23e5-5282-a69a-9481dd40709a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
