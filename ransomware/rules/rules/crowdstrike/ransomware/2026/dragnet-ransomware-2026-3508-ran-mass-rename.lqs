// Dragnet [Ransomware]: dragnet-ransomware-2026-3508 — Mass File Rename (incransom)
// Status: test | Level: high | ID: 0b73beee-fd3f-557b-9fa1-d9bb8d1da36a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
