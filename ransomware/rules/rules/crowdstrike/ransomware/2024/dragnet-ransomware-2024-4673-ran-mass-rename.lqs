// Dragnet [Ransomware]: dragnet-ransomware-2024-4673 — Mass File Rename (BrainCipher)
// Status: experimental | Level: high | ID: f99b1e78-d29f-59f0-95b5-f47c0ada0609

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
