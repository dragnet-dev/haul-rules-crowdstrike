// Dragnet [Ransomware]: dragnet-ransomware-2023-2214 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: d01ef0f0-b717-5f1e-9350-39b5eb774374

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
