// Dragnet [Ransomware]: dragnet-ransomware-2025-2201 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: ae1c34ef-e4a1-52c8-b64d-f1d4bf427532

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
