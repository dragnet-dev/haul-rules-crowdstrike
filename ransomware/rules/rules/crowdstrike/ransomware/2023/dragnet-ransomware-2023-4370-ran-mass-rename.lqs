// Dragnet [Ransomware]: dragnet-ransomware-2023-4370 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 429c8587-4f47-52f4-a7f5-51247495065e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
