// Dragnet [Ransomware]: dragnet-ransomware-2025-3297 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 8586bac9-1cc0-5f25-b32b-da9440b1ae31

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
