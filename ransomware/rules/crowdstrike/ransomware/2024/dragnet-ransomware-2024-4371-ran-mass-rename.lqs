// Dragnet [Ransomware]: dragnet-ransomware-2024-4371 — Mass File Rename (cloak)
// Status: experimental | Level: high | ID: c0a7499f-c747-546f-92bf-2dbb1e0ea227

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
