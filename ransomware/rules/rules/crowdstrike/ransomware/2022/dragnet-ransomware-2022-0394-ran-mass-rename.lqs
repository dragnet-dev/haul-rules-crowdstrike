// Dragnet [Ransomware]: dragnet-ransomware-2022-0394 — Mass File Rename (mindware)
// Status: deprecated | Level: high | ID: b5e01807-4eb7-583e-9d36-41822fcc23ca

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
