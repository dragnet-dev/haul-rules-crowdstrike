// Dragnet [Ransomware]: dragnet-ransomware-2025-1426 — Mass File Rename (sinobi)
// Status: experimental | Level: high | ID: f0eaa49f-d937-503e-84f5-52ae0d95b4c9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
