// Dragnet [Ransomware]: dragnet-ransomware-2022-2731 — Mass File Rename (karakurt)
// Status: experimental | Level: high | ID: 3fdf7db2-ddca-59c0-b7a7-ea756170a227

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
