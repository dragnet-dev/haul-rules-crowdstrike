// Dragnet [Container]: dragnet-container-2026-1951 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 5590fa57-4fdc-52a1-b825-2685d9570805

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *ubuntu:14.04* OR ImageFileName = *ubuntu:14.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
