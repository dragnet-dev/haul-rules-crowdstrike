// Dragnet [Ransomware]: dragnet-ransomware-2025-4327 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: a9423c73-9046-530b-82a9-07eee5edacbc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
