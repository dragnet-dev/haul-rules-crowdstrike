// Dragnet [Ransomware]: dragnet-ransomware-2024-0209 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 8b290c8b-911d-5945-b84e-5342a4215407

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
