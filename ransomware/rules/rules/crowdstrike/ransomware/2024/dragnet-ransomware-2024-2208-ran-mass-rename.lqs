// Dragnet [Ransomware]: dragnet-ransomware-2024-2208 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: cb86e67a-fc34-5692-bc98-fddd30a7e002

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
