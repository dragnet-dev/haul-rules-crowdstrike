// Dragnet [Ransomware]: dragnet-ransomware-2024-5543 — Mass File Rename (kairos)
// Status: experimental | Level: high | ID: 3285b83e-161f-556b-8cfd-19d2d865a910

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
