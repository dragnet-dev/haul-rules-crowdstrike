// Dragnet [Ransomware]: dragnet-ransomware-2024-1888 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 95ea9dd9-4f17-5e8b-a526-407b347208f7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
