// Dragnet [Ransomware]: dragnet-ransomware-2025-4997 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 4ed57d06-d363-5476-befa-05e8cfcd1c7a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
