// Dragnet [Ransomware]: dragnet-ransomware-2025-7497 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 9b15a6ac-3257-5cb4-acc0-97d47430028f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
