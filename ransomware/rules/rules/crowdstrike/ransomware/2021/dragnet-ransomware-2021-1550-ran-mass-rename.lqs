// Dragnet [Ransomware]: dragnet-ransomware-2021-1550 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 79158e43-7ed6-5889-90a9-13d78475a303

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
