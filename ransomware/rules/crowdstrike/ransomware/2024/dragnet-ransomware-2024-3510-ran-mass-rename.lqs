// Dragnet [Ransomware]: dragnet-ransomware-2024-3510 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 96329ad9-f868-5565-a3fb-2bffd20c9268

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
