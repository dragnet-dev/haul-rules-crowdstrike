// Dragnet [Ransomware]: dragnet-ransomware-2024-0594 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: b0802d70-04bc-536e-b8d5-419f004527bc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
