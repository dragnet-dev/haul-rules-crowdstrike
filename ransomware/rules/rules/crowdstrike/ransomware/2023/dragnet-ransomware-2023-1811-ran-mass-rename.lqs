// Dragnet [Ransomware]: dragnet-ransomware-2023-1811 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 20d2e58c-1aad-5752-b2eb-ee0756650360

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
