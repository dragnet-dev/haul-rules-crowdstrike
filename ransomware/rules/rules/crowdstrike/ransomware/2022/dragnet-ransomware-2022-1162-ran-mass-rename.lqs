// Dragnet [Ransomware]: dragnet-ransomware-2022-1162 — Mass File Rename (royal)
// Status: deprecated | Level: high | ID: d7f6bf35-5a43-5327-b002-e57d94739191

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
