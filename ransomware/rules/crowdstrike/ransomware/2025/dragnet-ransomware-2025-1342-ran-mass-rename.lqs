// Dragnet [Ransomware]: dragnet-ransomware-2025-1342 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: ce43a6d8-be2f-5935-bf5e-8455e4003143

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
