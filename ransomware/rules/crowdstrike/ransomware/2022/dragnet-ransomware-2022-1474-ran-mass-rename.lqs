// Dragnet [Ransomware]: dragnet-ransomware-2022-1474 — Mass File Rename (bianlian)
// Status: deprecated | Level: high | ID: dfe60a09-41dd-551b-bd2d-f138a8798ccb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
