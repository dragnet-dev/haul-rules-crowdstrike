// Dragnet [Container]: dragnet-container-2026-1485 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: ede4ae66-006a-55f2-88e7-b41ffdbed7bf

#event_simpleName=*
| (ImageFileName = *alpine edge:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
