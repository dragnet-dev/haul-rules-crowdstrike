// Dragnet [Ransomware]: dragnet-ransomware-2023-1822 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: f8726360-51f3-5c08-84b9-99324db79ef3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
