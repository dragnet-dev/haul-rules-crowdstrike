// Dragnet [Ransomware]: dragnet-ransomware-2024-4553 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 5a7eff24-8418-505e-90eb-e1271370f533

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
