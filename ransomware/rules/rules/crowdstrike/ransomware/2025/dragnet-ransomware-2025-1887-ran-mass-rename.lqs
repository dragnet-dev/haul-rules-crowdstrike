// Dragnet [Ransomware]: dragnet-ransomware-2025-1887 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 6d60f64a-cba3-5422-aaa9-0b772f64edce

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
