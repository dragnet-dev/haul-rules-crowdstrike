// Dragnet [Ransomware]: dragnet-ransomware-2025-0958 — Mass File Rename (play)
// Status: experimental | Level: high | ID: bb9c937a-2a42-5abc-9bff-3c92505786fa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
