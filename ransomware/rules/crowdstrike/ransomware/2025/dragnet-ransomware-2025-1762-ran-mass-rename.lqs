// Dragnet [Ransomware]: dragnet-ransomware-2025-1762 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: b24f2c41-c4da-5b74-8718-e8b5dfcf3955

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
