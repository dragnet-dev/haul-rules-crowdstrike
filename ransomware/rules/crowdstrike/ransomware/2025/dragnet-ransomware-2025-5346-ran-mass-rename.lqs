// Dragnet [Ransomware]: dragnet-ransomware-2025-5346 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 5a597d24-a7f1-5f8d-8b0a-36abb78e65b6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
