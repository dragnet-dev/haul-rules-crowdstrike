// Dragnet [Ransomware]: dragnet-ransomware-2024-3545 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 4d1b1bc6-2eb2-5b20-9767-21e4cc38bf03

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
