// Dragnet [Ransomware]: dragnet-ransomware-2025-0067 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 5a87643e-1519-5ccd-b85b-1cf481dc7f04

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
