// Dragnet [Ransomware]: dragnet-ransomware-2024-5352 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: 5905115e-9632-5b03-b1c9-7107ef9c204f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
