// Dragnet [Ransomware]: dragnet-ransomware-2024-3327 — Mass File Rename (rhysida)
// Status: deprecated | Level: high | ID: 6d4073a9-ef82-5167-ae42-cd9cf38bdabf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
