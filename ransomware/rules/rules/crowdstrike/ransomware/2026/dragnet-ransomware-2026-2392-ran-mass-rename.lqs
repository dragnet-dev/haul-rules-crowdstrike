// Dragnet [Ransomware]: dragnet-ransomware-2026-2392 — Mass File Rename (payload)
// Status: stable | Level: high | ID: 9fc01bfe-ef3a-5565-95be-1b5089ddca0e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
