// Dragnet [Ransomware]: dragnet-ransomware-2025-7374 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 58214d8e-6b92-5106-98b2-78319e844014

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
