// Dragnet [Ransomware]: dragnet-ransomware-2024-0674 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 80735777-11e1-561e-988f-0f05346590da

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
