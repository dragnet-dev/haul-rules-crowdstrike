// Dragnet [Ransomware]: dragnet-ransomware-2024-3371 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: f093e683-ce55-5d9c-8f64-cdc25491fa65

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
