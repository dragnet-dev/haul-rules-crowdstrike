// Dragnet [Ransomware]: dragnet-ransomware-2023-4004 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 6c52f1dc-beec-50da-a28e-f6e39db28ad5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
