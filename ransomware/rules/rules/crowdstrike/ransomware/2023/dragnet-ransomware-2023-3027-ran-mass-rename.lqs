// Dragnet [Ransomware]: dragnet-ransomware-2023-3027 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 92dfada3-7a8d-5a8d-a600-b53a0bf40a0a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
