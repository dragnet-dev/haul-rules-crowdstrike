// Dragnet [Container]: dragnet-container-2026-0304 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 458bc5d5-3175-571c-91a8-7f0c31400e5f

#event_simpleName=*
| (ImageFileName = *amazonlinux:2023* OR ImageFileName = *azure linux:3.0* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *photon os:4.0* OR ImageFileName = *photon os:5.0*)
| table([timestamp, ComputerName])
| limit(1000)
