// Dragnet [Ransomware]: dragnet-ransomware-2022-2354 — Mass File Rename (everest)
// Status: deprecated | Level: high | ID: 4c6c6598-0dcd-5a9d-b993-c277abc39f1f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
