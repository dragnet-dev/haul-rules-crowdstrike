// Dragnet [Ransomware]: dragnet-ransomware-2023-4049 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 0a30086e-67b6-5df9-9411-33e3222f0dea

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
