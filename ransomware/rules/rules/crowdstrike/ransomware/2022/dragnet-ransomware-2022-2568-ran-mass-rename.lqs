// Dragnet [Ransomware]: dragnet-ransomware-2022-2568 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 4da122a2-2ab5-5bb1-a321-563ddbc25e2e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
