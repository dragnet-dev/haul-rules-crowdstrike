// Dragnet [Ransomware]: dragnet-ransomware-2023-0858 — Mass File Rename (knight)
// Status: experimental | Level: high | ID: dbc94fb1-509e-56f1-9249-ac302c520f5b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
