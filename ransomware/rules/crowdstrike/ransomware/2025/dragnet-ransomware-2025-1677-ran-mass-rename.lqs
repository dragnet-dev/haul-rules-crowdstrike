// Dragnet [Ransomware]: dragnet-ransomware-2025-1677 — Mass File Rename (ralord)
// Status: experimental | Level: high | ID: 8a04ba98-8198-58ff-a59f-7cdeba42dbdd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
