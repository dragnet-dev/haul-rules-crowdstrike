// Dragnet [Ransomware]: dragnet-ransomware-2023-4299 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 1887deba-0483-542d-bd0a-29898a9aa2ed

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
