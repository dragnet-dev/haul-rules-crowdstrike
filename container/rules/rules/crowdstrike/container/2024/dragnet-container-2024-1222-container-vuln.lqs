// Dragnet [Container]: dragnet-container-2024-1222 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: e270a9bf-7378-5ffc-9bc4-cd7dcaad51c3

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:7*)
| table([timestamp, ComputerName])
| limit(1000)
