// Dragnet [Ransomware]: dragnet-ransomware-2024-1535 — Mass File Rename (handala)
// Status: experimental | Level: high | ID: 2476597b-f874-5e6d-a1ad-a3cacbdd278f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
