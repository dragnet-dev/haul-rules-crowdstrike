// Dragnet [Container]: dragnet-container-2026-1568 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 8e6c6dac-bb33-554d-b048-3417def9a985

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:5*)
| table([timestamp, ComputerName])
| limit(1000)
