// Dragnet [Ransomware]: dragnet-ransomware-2023-3588 — Mass File Rename (royal)
// Status: experimental | Level: high | ID: 000ee75b-c269-5d12-a4b0-43ef49454dc4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
