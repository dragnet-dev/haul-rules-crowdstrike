// Dragnet [Container]: dragnet-container-2026-2075 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: dfaecac9-5745-57fe-ac75-64e29461b641

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10*)
| table([timestamp, ComputerName])
| limit(1000)
