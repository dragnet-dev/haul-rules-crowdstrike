// Dragnet [Ransomware]: dragnet-ransomware-2024-2122 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: e277b2aa-ea11-5b33-8f62-ca1dc1bd95bd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
