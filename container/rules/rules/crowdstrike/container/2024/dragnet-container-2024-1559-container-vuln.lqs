// Dragnet [Container]: dragnet-container-2024-1559 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 523c7475-1179-59b4-94b2-32f6170e6720

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:9*)
| table([timestamp, ComputerName])
| limit(1000)
