// Dragnet [Ransomware]: dragnet-ransomware-2024-4648 — Mass File Rename (darkvault)
// Status: experimental | Level: high | ID: 5a53c641-f3d2-5748-8f33-69a6b23c0825

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
