// Dragnet [Ransomware]: dragnet-ransomware-2023-1361 — Mass File Rename (play)
// Status: deprecated | Level: high | ID: f44f1a3d-6962-51dd-a259-8aad278a8771

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
