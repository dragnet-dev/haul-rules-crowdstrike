// Dragnet [Ransomware]: dragnet-ransomware-2025-6743 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: b39217a5-0f0c-53e2-babb-e7cf0035f93d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
