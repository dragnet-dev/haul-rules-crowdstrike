// Dragnet [Ransomware]: dragnet-ransomware-2022-0484 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: d7f6da90-1ca2-5df5-9ff6-09ec77b77081

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
