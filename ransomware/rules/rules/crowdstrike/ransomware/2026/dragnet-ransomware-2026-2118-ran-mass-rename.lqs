// Dragnet [Ransomware]: dragnet-ransomware-2026-2118 — Mass File Rename (rhysida)
// Status: deprecated | Level: high | ID: 1fcc4978-1e2f-5d0c-b8b1-38497285e201

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
