// Dragnet [Ransomware]: dragnet-ransomware-2022-0001 — Mass File Rename (blackbasta)
// Status: deprecated | Level: high | ID: 46d46097-cdea-5ec6-a56c-fcd0e6220b90

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
