// Dragnet [Ransomware]: dragnet-ransomware-2024-1447 — Mass File Rename (ElDorado)
// Status: deprecated | Level: high | ID: f89d2488-eb23-5753-ad76-c41ffa0f3ed1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
