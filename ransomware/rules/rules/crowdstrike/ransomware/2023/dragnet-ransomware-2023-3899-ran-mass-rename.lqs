// Dragnet [Ransomware]: dragnet-ransomware-2023-3899 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 300523a6-7c79-5812-a0e5-3299d10f3302

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
