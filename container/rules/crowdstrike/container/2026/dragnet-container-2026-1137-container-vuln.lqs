// Dragnet [Container]: dragnet-container-2026-1137 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: b52cf185-961b-5a77-941d-caf05d8a1c6b

#event_simpleName=*
| (ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10* OR ImageFileName = *ubuntu:13.04* OR ImageFileName = *ubuntu:13.10*)
| table([timestamp, ComputerName])
| limit(1000)
