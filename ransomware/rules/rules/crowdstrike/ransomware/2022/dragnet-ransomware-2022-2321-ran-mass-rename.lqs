// Dragnet [Ransomware]: dragnet-ransomware-2022-2321 — Mass File Rename (royal)
// Status: deprecated | Level: high | ID: 669d82be-1fee-5b60-b0fc-1913860c0ac2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
