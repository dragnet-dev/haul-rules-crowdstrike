// Dragnet [Ransomware]: dragnet-ransomware-2025-7793 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: de5c5e15-99ac-5613-8590-fd2b3627039a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
