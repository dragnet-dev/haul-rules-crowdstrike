// Dragnet [Ransomware]: dragnet-ransomware-2022-0872 — Mass File Rename (alphv)
// Status: deprecated | Level: high | ID: 23281e82-f4cd-5b80-a944-af49fbab3c93

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
