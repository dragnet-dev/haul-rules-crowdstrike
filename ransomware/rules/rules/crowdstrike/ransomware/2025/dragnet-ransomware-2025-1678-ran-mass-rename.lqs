// Dragnet [Ransomware]: dragnet-ransomware-2025-1678 — Mass File Rename (kraken)
// Status: experimental | Level: high | ID: fbe9f5b8-1749-5eca-9d28-0971435c60f8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
