// Dragnet [Ransomware]: dragnet-ransomware-2022-1618 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 9e596c62-23d8-5fd6-9bfb-afffecbf4aab

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
