// Dragnet [Ransomware]: dragnet-ransomware-2022-2923 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 36f6520d-b0af-59bd-8c50-5f757358d0f2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
