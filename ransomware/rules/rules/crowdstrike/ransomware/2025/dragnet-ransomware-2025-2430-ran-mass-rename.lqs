// Dragnet [Ransomware]: dragnet-ransomware-2025-2430 — Mass File Rename (thegentlemen)
// Status: experimental | Level: high | ID: 06d3e872-f233-539e-ae83-0e3ef10a61a5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
