// Dragnet [Container]: dragnet-container-2026-1992 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 06c78c10-7d38-5158-b46b-08ff03d2062f

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:5*)
| table([timestamp, ComputerName])
| limit(1000)
