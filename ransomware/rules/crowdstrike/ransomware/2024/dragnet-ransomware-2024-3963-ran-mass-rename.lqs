// Dragnet [Ransomware]: dragnet-ransomware-2024-3963 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: bc0a87fc-5273-5b16-a3ea-7b4ee042d0ec

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
