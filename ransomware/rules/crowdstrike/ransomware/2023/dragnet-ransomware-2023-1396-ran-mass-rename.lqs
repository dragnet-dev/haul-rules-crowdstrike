// Dragnet [Ransomware]: dragnet-ransomware-2023-1396 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 26c61c2c-7158-5d1a-a898-c9103a78800b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
