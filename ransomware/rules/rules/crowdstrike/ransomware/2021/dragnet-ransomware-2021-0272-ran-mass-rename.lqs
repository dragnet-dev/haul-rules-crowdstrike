// Dragnet [Ransomware]: dragnet-ransomware-2021-0272 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 51611312-3ac3-5d72-8d31-ef130aaa08c0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
