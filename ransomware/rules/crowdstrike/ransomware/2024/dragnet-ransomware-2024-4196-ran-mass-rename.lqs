// Dragnet [Ransomware]: dragnet-ransomware-2024-4196 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 95877801-6528-5884-b752-f762eb62ff6c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
