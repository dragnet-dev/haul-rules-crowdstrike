// Dragnet [Ransomware]: dragnet-ransomware-2023-5339 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 865810b1-ee92-53f7-8253-8bac2be9ec30

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
