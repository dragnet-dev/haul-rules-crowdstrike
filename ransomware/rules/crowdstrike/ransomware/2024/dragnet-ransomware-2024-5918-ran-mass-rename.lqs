// Dragnet [Ransomware]: dragnet-ransomware-2024-5918 — Mass File Rename (underground)
// Status: experimental | Level: high | ID: 81dc08b0-9d0b-5caf-9fa1-39e6c0090c03

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
