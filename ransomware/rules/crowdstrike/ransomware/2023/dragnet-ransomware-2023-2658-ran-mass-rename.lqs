// Dragnet [Ransomware]: dragnet-ransomware-2023-2658 — Mass File Rename (donutleaks)
// Status: experimental | Level: high | ID: eda5586c-69ee-5a6d-931b-7545fc8ff72b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
