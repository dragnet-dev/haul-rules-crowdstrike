// Dragnet [Ransomware]: dragnet-ransomware-2024-2510 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 2ca264b4-af67-53d3-a568-d728cb5f1920

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
