// Dragnet [Ransomware]: dragnet-ransomware-2025-2855 — Mass File Rename (blacknevas)
// Status: experimental | Level: high | ID: c051767c-68e3-5d8a-a6a0-ff6e5271bf26

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
