// Dragnet [Container]: dragnet-container-2025-0297 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 68caaca3-b0d6-5ae2-8496-4c9d5aa62b72

#event_simpleName=*
| (ImageFileName = *alpine:3.4* OR ImageFileName = *alpine:3.5* OR ImageFileName = *alpine:3.6* OR ImageFileName = *amazonlinux:1* OR ImageFileName = *amazonlinux:2* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:7* OR ImageFileName = *debian:8* OR ImageFileName = *debian:9* OR ImageFileName = *redhat/ubi9:*)
| table([timestamp, ComputerName])
| limit(1000)
