// Dragnet [Ransomware]: dragnet-ransomware-2024-1863 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 9bee25cd-424f-5acc-9406-65256b28790f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
