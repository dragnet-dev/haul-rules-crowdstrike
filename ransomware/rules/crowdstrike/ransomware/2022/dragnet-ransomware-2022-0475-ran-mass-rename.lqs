// Dragnet [Ransomware]: dragnet-ransomware-2022-0475 — Mass File Rename (mountlocker)
// Status: deprecated | Level: high | ID: ac626227-12ce-57bb-b9ba-0682c56cdfb0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
