// Dragnet [Ransomware]: dragnet-ransomware-2025-7203 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: b5f267ba-df1e-5a23-bdb3-e529c2abc490

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
