// Dragnet [Ransomware]: dragnet-ransomware-2021-0075 — Mass File Rename (xinglocker)
// Status: deprecated | Level: high | ID: 3b00caa5-35fa-5158-94d2-1db69529419e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
