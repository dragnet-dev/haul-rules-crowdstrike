// Dragnet [Ransomware]: dragnet-ransomware-2025-2540 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: babd9b03-782a-5506-8063-ff645cbc4976

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
