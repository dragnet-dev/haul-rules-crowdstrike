// Dragnet [Ransomware]: dragnet-ransomware-2026-1755 — Mass File Rename (cloak)
// Status: deprecated | Level: high | ID: 90a9dfc4-33d0-5cf4-a2f2-16ed6a20b67f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
