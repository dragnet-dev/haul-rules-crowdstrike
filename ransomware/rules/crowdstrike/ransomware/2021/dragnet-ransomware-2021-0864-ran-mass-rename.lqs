// Dragnet [Ransomware]: dragnet-ransomware-2021-0864 — Mass File Rename (revil)
// Status: deprecated | Level: high | ID: a6f5850a-1b5d-5dfb-bb18-ea3326d8e8aa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
