// Dragnet [Ransomware]: dragnet-ransomware-2023-1893 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 995f5598-24a2-5cdc-8bd9-43d2ed0cb68c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
