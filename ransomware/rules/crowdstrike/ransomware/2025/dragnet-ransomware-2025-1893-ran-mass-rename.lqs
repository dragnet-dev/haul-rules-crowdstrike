// Dragnet [Ransomware]: dragnet-ransomware-2025-1893 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: db16d86f-c843-55a7-a0cd-860ddefe5e11

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
