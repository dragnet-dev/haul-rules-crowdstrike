// Dragnet [Ransomware]: dragnet-ransomware-2023-0261 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: e7a3b4e1-98da-5ff7-a556-2b6a1f85210a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
