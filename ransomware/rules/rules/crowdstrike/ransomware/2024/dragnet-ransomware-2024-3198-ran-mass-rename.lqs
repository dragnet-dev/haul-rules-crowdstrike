// Dragnet [Ransomware]: dragnet-ransomware-2024-3198 — Mass File Rename (trigona)
// Status: experimental | Level: high | ID: e9f6112b-1fee-58fd-83ac-f6f794f8df0f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
