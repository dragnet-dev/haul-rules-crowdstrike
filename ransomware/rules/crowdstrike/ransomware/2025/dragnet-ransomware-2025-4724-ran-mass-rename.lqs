// Dragnet [Ransomware]: dragnet-ransomware-2025-4724 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 91fbbdec-abe1-5990-85f5-4c47dbd34a60

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
