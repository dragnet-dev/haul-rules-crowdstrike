// Dragnet [Ransomware]: dragnet-ransomware-2024-1276 — Mass File Rename (stormous)
// Status: deprecated | Level: high | ID: e71374df-3448-59e3-b903-5373e3773482

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
