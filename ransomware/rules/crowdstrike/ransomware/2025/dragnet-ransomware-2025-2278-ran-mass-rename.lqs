// Dragnet [Ransomware]: dragnet-ransomware-2025-2278 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: c8d73555-f8d8-56e1-b7c9-6484627c0dc1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
