// Dragnet [Ransomware]: dragnet-ransomware-2022-2295 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 91e838cd-69c2-59d0-a164-6538e726628b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
