// Dragnet [Ransomware]: dragnet-ransomware-2025-1534 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 3ea03946-2640-51d0-a680-609ff07eff54

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
