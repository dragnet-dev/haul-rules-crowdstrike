// Dragnet [Ransomware]: dragnet-ransomware-2025-6900 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: a3582f1b-0551-5757-9597-51126dbda8cb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
