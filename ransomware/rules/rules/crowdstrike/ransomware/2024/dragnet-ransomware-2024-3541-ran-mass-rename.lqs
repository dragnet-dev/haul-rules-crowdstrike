// Dragnet [Ransomware]: dragnet-ransomware-2024-3541 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: cbcfcfb1-9b10-549b-8af9-e163b46203c1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
