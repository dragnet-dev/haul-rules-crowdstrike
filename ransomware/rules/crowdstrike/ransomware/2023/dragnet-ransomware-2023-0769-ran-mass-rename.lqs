// Dragnet [Ransomware]: dragnet-ransomware-2023-0769 — Mass File Rename (ransomed)
// Status: experimental | Level: high | ID: 8edb999e-ce86-52ca-821f-753f11898143

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
