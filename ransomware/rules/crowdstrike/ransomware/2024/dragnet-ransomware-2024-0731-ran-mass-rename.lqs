// Dragnet [Ransomware]: dragnet-ransomware-2024-0731 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 413eeb26-49a1-562f-b7fe-eb0c1bb428a0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
