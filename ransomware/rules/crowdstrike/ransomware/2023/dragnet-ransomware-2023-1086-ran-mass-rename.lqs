// Dragnet [Ransomware]: dragnet-ransomware-2023-1086 — Mass File Rename (toufan)
// Status: deprecated | Level: high | ID: 31f2c122-3d5d-5b92-80e2-613dcfe28a2b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
