// Dragnet [Ransomware]: dragnet-ransomware-2024-5383 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: 4368bbfe-aba3-5d09-886d-e28e409ac7e0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
