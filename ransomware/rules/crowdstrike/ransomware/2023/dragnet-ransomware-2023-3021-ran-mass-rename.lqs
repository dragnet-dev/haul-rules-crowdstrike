// Dragnet [Ransomware]: dragnet-ransomware-2023-3021 — Mass File Rename (ragnarlocker)
// Status: experimental | Level: high | ID: bf5bfd8e-a26d-565d-80c4-ae0b9699ca8d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
