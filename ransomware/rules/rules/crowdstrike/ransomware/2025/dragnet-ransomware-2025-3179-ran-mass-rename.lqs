// Dragnet [Ransomware]: dragnet-ransomware-2025-3179 — Mass File Rename (nitrogen)
// Status: experimental | Level: high | ID: 0cf1b60c-9afe-5bad-9a7a-81b3cae93316

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
