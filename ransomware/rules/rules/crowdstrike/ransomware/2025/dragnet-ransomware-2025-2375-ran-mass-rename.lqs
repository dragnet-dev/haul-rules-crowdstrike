// Dragnet [Ransomware]: dragnet-ransomware-2025-2375 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 2a3cb7d5-f275-57a0-9e86-9dfc8a48c21a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
