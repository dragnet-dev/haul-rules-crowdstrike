// Dragnet [Ransomware]: dragnet-ransomware-2025-3260 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 8c34964c-9133-5838-ba43-f5420aac5b67

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
