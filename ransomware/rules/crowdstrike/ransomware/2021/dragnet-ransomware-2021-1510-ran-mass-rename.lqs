// Dragnet [Ransomware]: dragnet-ransomware-2021-1510 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 650a0447-5161-553b-ab24-1efdd0ba8bd8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
