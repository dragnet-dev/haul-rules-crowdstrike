// Dragnet [Ransomware]: dragnet-ransomware-2022-2711 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 2d538701-5016-5a6e-b720-911c06c872f7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
