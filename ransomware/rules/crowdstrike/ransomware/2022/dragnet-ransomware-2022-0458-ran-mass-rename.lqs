// Dragnet [Ransomware]: dragnet-ransomware-2022-0458 — Mass File Rename (royal)
// Status: deprecated | Level: high | ID: 31a401e8-b94e-5678-8b14-7f42a07c5def

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
