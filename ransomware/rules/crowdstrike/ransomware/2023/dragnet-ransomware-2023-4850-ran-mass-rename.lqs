// Dragnet [Ransomware]: dragnet-ransomware-2023-4850 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 3868c952-ccf6-559b-a5a8-9a5c727d3f0c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
