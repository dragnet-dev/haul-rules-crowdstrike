// Dragnet [Ransomware]: dragnet-ransomware-2025-1479 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: eac6db55-750e-5b20-9375-3f2cbd262166

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
