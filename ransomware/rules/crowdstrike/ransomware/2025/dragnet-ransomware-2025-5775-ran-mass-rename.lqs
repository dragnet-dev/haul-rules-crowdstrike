// Dragnet [Ransomware]: dragnet-ransomware-2025-5775 — Mass File Rename (nightspire)
// Status: deprecated | Level: high | ID: 26585f77-ebd3-5756-9399-2e42da140d16

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
