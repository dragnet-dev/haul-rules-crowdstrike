// Dragnet [Ransomware]: dragnet-ransomware-2024-0257 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: fb1466e9-1b3f-5013-aec1-75ced32879e9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
