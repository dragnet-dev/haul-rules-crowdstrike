// Dragnet [Ransomware]: dragnet-ransomware-2025-4725 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: ca408eee-a246-544d-abaf-c84694182e8c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
