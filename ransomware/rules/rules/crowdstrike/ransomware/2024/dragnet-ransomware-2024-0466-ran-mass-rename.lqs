// Dragnet [Ransomware]: dragnet-ransomware-2024-0466 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 1f2d0c06-810b-51c2-9e4c-fe8098278581

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
