// Dragnet [Ransomware]: dragnet-ransomware-2023-5299 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: cadae0e7-c0d6-597d-ba44-e823ca1620c7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
