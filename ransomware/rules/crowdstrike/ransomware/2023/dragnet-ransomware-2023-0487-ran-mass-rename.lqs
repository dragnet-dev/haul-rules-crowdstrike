// Dragnet [Ransomware]: dragnet-ransomware-2023-0487 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 997d2e02-8f8d-5035-afe3-0db6dac6e209

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
