// Dragnet [Ransomware]: dragnet-ransomware-2025-7212 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 9f99311a-386a-5348-a03a-55a75686ea5e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
