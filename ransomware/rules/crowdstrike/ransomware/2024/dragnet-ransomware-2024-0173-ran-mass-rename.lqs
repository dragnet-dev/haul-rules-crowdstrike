// Dragnet [Ransomware]: dragnet-ransomware-2024-0173 — Mass File Rename (cloak)
// Status: deprecated | Level: high | ID: bb8d10a8-2e97-5a0c-ba37-ce36790fd939

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
