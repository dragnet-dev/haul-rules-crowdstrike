// Dragnet [Ransomware]: dragnet-ransomware-2024-4479 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: b32517eb-0b0f-5886-a185-2ff19f3e8a34

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
