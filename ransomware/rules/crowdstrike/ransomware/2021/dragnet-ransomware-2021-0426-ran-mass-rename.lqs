// Dragnet [Ransomware]: dragnet-ransomware-2021-0426 — Mass File Rename (spook)
// Status: deprecated | Level: high | ID: e5a100e0-8f1f-5ceb-a2f2-689e714775dd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
