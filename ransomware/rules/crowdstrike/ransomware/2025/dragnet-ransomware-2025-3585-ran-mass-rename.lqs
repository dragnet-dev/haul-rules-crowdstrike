// Dragnet [Ransomware]: dragnet-ransomware-2025-3585 — Mass File Rename (kairos)
// Status: experimental | Level: high | ID: 21f41aff-f24e-55c8-828a-574980124a4e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
