// Dragnet [Container]: dragnet-container-2026-0818 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 0ba62cb1-0429-59a4-896e-27d2843e8cab

#event_simpleName=*
| (ImageFileName = *chainguard:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:7* OR ImageFileName = *debian:8* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:14.04* OR ImageFileName = *ubuntu:14.04-ESM* OR ImageFileName = *ubuntu:16.04* OR ImageFileName = *ubuntu:16.04-ESM* OR ImageFileName = *ubuntu:16.10* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
