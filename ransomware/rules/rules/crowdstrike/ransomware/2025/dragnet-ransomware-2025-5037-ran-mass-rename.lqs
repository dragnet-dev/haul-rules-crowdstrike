// Dragnet [Ransomware]: dragnet-ransomware-2025-5037 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: 9ba7f793-c566-5a98-8ba4-9b53b39855ce

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
