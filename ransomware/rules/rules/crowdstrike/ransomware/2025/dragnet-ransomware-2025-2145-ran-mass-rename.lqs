// Dragnet [Ransomware]: dragnet-ransomware-2025-2145 — Mass File Rename (trinity)
// Status: experimental | Level: high | ID: 5f9c85cd-30ed-5efd-82f1-1528e5a2f874

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
