// Dragnet [Ransomware]: dragnet-ransomware-2022-1459 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: 29e5f7ba-0893-5e4a-9828-8f048410a25f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
