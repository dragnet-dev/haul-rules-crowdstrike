// Dragnet [Ransomware]: dragnet-ransomware-2022-0501 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: bc495e1b-b113-5d55-af5a-33e997e8784b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
