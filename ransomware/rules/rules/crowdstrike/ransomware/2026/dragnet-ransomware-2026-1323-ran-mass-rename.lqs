// Dragnet [Ransomware]: dragnet-ransomware-2026-1323 — Mass File Rename (payoutsking)
// Status: test | Level: high | ID: 33d0cb27-19e0-5e4e-8d25-7501ff887e6d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
