// Dragnet [Ransomware]: dragnet-ransomware-2022-3050 — Mass File Rename (kelvinsecurity)
// Status: deprecated | Level: high | ID: c2420915-c3f8-5f3d-8289-13ba7216cd8c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
