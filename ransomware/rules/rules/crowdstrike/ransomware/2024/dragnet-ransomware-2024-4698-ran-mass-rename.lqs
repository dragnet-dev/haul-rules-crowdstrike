// Dragnet [Ransomware]: dragnet-ransomware-2024-4698 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: b101943b-677f-5407-b1ba-3fb14db68c7a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
