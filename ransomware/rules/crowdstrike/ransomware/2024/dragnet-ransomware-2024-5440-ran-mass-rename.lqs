// Dragnet [Ransomware]: dragnet-ransomware-2024-5440 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 3889d758-5257-5e84-8b55-437a98a2c044

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
