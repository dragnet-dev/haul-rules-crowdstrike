// Dragnet [Ransomware]: dragnet-ransomware-2023-3523 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 44a9c91b-a25d-5e51-b08f-395a64f298b9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
