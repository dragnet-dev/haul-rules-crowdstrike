// Dragnet [Ransomware]: dragnet-ransomware-2024-6036 — Mass File Rename (spacebears)
// Status: experimental | Level: high | ID: 5d2a88fb-e1e1-5750-8d72-cd79c86b7ce9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
