// Dragnet [Ransomware]: dragnet-ransomware-2022-2484 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: fec998e2-9124-597a-b92b-f9f4acc6c795

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
