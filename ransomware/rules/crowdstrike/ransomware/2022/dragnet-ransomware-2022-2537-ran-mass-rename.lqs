// Dragnet [Ransomware]: dragnet-ransomware-2022-2537 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 4c3a1901-aa42-5ec4-92f0-e9ab92a7c243

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
