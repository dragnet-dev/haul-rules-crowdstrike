// Dragnet [Ransomware]: dragnet-ransomware-2025-7272 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: 6e00b61e-b777-5294-9cde-3a5e7fc9ec7e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
