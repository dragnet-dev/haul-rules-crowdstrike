// Dragnet [Ransomware]: dragnet-ransomware-2024-4992 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: bf18626c-a09d-5690-8108-fa68933037e0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
