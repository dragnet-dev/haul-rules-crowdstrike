// Dragnet [Ransomware]: dragnet-ransomware-2024-1789 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: a893f1cf-5fe3-5fe2-92e3-5cda86e9186a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
