// Dragnet [Ransomware]: dragnet-ransomware-2025-7556 — Mass File Rename (play)
// Status: experimental | Level: high | ID: ebc38c98-23d5-54ad-9cbf-b38e9a934a0e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
