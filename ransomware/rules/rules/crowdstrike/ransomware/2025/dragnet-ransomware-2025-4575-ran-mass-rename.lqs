// Dragnet [Ransomware]: dragnet-ransomware-2025-4575 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: b2f67d03-286e-5d07-852b-6e29adfbea31

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
