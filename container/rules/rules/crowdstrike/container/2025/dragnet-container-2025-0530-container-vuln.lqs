// Dragnet [Container]: dragnet-container-2025-0530 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 296dec8f-2723-569d-becc-3342878172db

#event_simpleName=*
| (ImageFileName = *azure linux:3.0* OR ImageFileName = *cbl-mariner:2.0* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
