// Dragnet [Ransomware]: dragnet-ransomware-2024-1800 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 87a7a17c-3b75-536e-bcdf-41726288ff8a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
