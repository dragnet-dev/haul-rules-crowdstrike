// Dragnet [Ransomware]: dragnet-ransomware-2025-5805 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: ec78319a-f08e-5590-aed2-047bbb82008c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
