// Dragnet [Ransomware]: dragnet-ransomware-2024-1503 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 5219074c-ec1c-527b-a393-79f47127298d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
