// Dragnet [Ransomware]: dragnet-ransomware-2022-1968 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: d211d2ee-b251-59c5-9275-99ff9abde68d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
