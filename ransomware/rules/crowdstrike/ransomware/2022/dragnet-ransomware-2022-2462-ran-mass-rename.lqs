// Dragnet [Ransomware]: dragnet-ransomware-2022-2462 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 303f1348-bf72-55e8-be63-325e9a6cea55

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
