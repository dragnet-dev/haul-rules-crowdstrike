// Dragnet [Ransomware]: dragnet-ransomware-2023-2039 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: ea127767-fab4-5351-84b9-120e9bc99dbb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
