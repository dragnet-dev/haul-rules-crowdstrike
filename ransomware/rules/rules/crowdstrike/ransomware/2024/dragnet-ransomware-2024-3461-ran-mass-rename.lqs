// Dragnet [Ransomware]: dragnet-ransomware-2024-3461 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 14883104-11f6-54f5-8150-f1e90dbb8f8d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
