// Dragnet [Ransomware]: dragnet-ransomware-2025-3733 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: d150e3a3-fe29-55fb-9cf4-c4cb715ac30e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
