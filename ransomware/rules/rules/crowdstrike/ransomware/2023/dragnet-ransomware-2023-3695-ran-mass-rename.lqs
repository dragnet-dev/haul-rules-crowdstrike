// Dragnet [Ransomware]: dragnet-ransomware-2023-3695 — Mass File Rename (noescape)
// Status: experimental | Level: high | ID: d1fb3a8a-159e-579d-b062-0074358e4780

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
