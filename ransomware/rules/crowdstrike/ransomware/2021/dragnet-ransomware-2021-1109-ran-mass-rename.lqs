// Dragnet [Ransomware]: dragnet-ransomware-2021-1109 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: fd741ce1-e389-5e7f-9695-4ff899ad2f8b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
