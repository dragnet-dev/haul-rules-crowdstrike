// Dragnet [Ransomware]: dragnet-ransomware-2021-1338 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 25a91985-f43d-560d-a8e4-9f4374c68a41

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
