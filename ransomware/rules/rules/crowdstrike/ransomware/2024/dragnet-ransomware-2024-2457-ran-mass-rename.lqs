// Dragnet [Ransomware]: dragnet-ransomware-2024-2457 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 35b2ca52-dbc7-5fe2-ba33-73f47fb3eb6f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
