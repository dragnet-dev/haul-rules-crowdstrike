// Dragnet [Ransomware]: dragnet-ransomware-2024-5295 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 29ff72a8-c862-5a27-9449-c8da3e7fad3f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
