// Dragnet [Ransomware]: dragnet-ransomware-2022-1790 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: e3e70e0a-4415-5633-854b-d4af07af3841

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
