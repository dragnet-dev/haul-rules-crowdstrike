// Dragnet [Container]: dragnet-container-2024-1424 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: f476d266-72f6-5580-bd98-fc9368883e57

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:8*)
| table([timestamp, ComputerName])
| limit(1000)
