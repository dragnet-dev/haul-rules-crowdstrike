// Dragnet [Container]: dragnet-container-2026-1824 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: aa2cee7e-ea6f-5039-9c90-3f807f3ac2e2

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6*)
| table([timestamp, ComputerName])
| limit(1000)
