// Dragnet [Ransomware]: dragnet-ransomware-2025-6539 — Mass File Rename (sinobi)
// Status: experimental | Level: high | ID: 6e8231e4-a3ac-53cb-8a75-6726dfc38c83

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
