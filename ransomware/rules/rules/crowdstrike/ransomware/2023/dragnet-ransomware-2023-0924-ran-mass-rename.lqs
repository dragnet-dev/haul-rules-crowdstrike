// Dragnet [Ransomware]: dragnet-ransomware-2023-0924 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: bd4b91ce-7db4-5b72-8c71-b2716127f041

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
