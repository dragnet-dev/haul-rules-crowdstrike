// Dragnet [Ransomware]: dragnet-ransomware-2023-2875 — Mass File Rename (malas)
// Status: experimental | Level: high | ID: d4b6923d-322c-590a-ae8a-e46646335c45

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
