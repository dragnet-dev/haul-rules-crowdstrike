// Dragnet [Ransomware]: dragnet-ransomware-2026-3017 — Mass File Rename (cloak)
// Status: deprecated | Level: high | ID: c76c789a-88bd-5a2b-81cf-812b9337d8c0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
