// Dragnet [Ransomware]: dragnet-ransomware-2025-0292 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 3f669a32-5b9f-5233-b6ee-3cb04bed1ac9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
