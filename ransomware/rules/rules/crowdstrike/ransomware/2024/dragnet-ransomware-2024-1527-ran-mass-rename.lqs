// Dragnet [Ransomware]: dragnet-ransomware-2024-1527 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: ab7ab480-0d5b-509e-bf20-21c0a004b093

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
