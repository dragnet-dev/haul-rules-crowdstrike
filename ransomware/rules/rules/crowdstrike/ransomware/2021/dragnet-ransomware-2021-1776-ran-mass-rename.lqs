// Dragnet [Ransomware]: dragnet-ransomware-2021-1776 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 6a5f21d5-b817-5f1e-810c-16804652995a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
