// Dragnet [Ransomware]: dragnet-ransomware-2022-0482 — Mass File Rename (blackbasta)
// Status: deprecated | Level: high | ID: 60a8c23b-3e79-56cd-b78c-4845004da4ca

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
