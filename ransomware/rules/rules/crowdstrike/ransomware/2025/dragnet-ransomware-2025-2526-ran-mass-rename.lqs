// Dragnet [Ransomware]: dragnet-ransomware-2025-2526 — Mass File Rename (frag)
// Status: deprecated | Level: high | ID: 697ccdba-0e9e-5b56-8f41-432c5fd42d99

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
