// Dragnet [Ransomware]: dragnet-ransomware-2022-1341 — Mass File Rename (onyx)
// Status: deprecated | Level: high | ID: db7604fe-79a0-5b0c-b9a2-a805459e4738

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
