// Dragnet [Ransomware]: dragnet-ransomware-2025-7098 — Mass File Rename (blackshrantac)
// Status: experimental | Level: high | ID: 5f9e50d2-1ebb-53b0-a0eb-79f5a6b41906

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
