// Dragnet [Ransomware]: dragnet-ransomware-2026-2514 — Mass File Rename (payoutsking)
// Status: deprecated | Level: high | ID: 6c380b64-46e6-512e-a695-dff33fecd227

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
