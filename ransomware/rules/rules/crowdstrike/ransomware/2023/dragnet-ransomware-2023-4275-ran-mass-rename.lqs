// Dragnet [Ransomware]: dragnet-ransomware-2023-4275 — Mass File Rename (play)
// Status: experimental | Level: high | ID: e339a1eb-4656-572f-aabb-aa427d483a68

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
