// Dragnet [Ransomware]: dragnet-ransomware-2022-2905 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: ea3e5921-8fcb-538b-9905-e08524730875

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
