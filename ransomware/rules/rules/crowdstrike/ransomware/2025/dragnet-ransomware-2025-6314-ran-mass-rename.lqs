// Dragnet [Ransomware]: dragnet-ransomware-2025-6314 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 94749a39-fc95-5115-82e3-2711e9871d0a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
