// Dragnet [Ransomware]: dragnet-ransomware-2023-0325 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 233dd954-e81a-521a-8264-b909ff265d13

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
