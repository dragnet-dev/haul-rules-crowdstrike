// Dragnet [Ransomware]: dragnet-ransomware-2024-3135 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: fa12c504-daac-5f63-b24d-146820fa215f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
