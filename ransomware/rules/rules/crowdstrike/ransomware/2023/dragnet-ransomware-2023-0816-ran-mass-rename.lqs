// Dragnet [Ransomware]: dragnet-ransomware-2023-0816 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: cf2aa104-191f-5a03-9c7e-95ae3d023d71

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
