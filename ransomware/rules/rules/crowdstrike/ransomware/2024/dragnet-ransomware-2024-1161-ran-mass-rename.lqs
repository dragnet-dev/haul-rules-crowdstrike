// Dragnet [Ransomware]: dragnet-ransomware-2024-1161 — Mass File Rename (stormous)
// Status: experimental | Level: high | ID: e30a8a96-52a4-58f9-8b3e-b2300143a40e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
