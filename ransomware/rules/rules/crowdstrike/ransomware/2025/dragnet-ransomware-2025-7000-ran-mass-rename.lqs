// Dragnet [Ransomware]: dragnet-ransomware-2025-7000 — Mass File Rename (worldleaks)
// Status: experimental | Level: high | ID: 5d7e95dc-f011-5b1a-918c-1b98fb19966a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
