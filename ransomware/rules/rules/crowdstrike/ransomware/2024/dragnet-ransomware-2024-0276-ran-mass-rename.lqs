// Dragnet [Ransomware]: dragnet-ransomware-2024-0276 — Mass File Rename (blackout)
// Status: experimental | Level: high | ID: 39b78474-7006-576a-ac40-cfce1b798c90

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
