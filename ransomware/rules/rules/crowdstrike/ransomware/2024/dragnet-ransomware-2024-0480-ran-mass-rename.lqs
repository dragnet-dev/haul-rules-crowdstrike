// Dragnet [Ransomware]: dragnet-ransomware-2024-0480 — Mass File Rename (mallox)
// Status: experimental | Level: high | ID: 1d4d1c04-4726-5fad-b604-8f74e4c36c6a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
