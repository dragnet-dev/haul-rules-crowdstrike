// Dragnet [Container]: dragnet-container-2024-0933 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 7b4acc38-1679-5e6f-bff4-0f130f232ac3

#event_simpleName=*
| (ImageFileName = *almalinux:8* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:8* OR ImageFileName = *photon os:1.0* OR ImageFileName = *photon os:2.0* OR ImageFileName = *photon os:3.0* OR ImageFileName = *redhat/ubi9:*)
| table([timestamp, ComputerName])
| limit(1000)
