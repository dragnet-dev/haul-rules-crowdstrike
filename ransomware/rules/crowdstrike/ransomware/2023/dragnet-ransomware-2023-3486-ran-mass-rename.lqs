// Dragnet [Ransomware]: dragnet-ransomware-2023-3486 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: bb16b59e-7abd-55dc-abdb-ec06eeb9aac1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
