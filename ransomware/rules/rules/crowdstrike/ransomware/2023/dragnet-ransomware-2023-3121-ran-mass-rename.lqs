// Dragnet [Ransomware]: dragnet-ransomware-2023-3121 — Mass File Rename (snatch)
// Status: experimental | Level: high | ID: f2eeaa58-d19b-550d-b843-5c3dc235fc97

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
