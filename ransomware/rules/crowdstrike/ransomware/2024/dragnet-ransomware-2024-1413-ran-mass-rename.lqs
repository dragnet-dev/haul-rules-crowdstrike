// Dragnet [Ransomware]: dragnet-ransomware-2024-1413 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: cf727373-b706-599c-a495-5c2322d84c77

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
