// Dragnet [Ransomware]: dragnet-ransomware-2024-2429 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 2d0f2c0d-0878-5d24-accc-116709494592

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
