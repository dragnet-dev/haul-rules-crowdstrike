// Dragnet [Ransomware]: dragnet-ransomware-2025-2687 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 4c463361-e968-5853-86a9-906e6dcc412a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
