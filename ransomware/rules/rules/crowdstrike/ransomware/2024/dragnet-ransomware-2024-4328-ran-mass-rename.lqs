// Dragnet [Ransomware]: dragnet-ransomware-2024-4328 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 847011a8-e7e5-59b8-b588-d3b1c321d5e1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
