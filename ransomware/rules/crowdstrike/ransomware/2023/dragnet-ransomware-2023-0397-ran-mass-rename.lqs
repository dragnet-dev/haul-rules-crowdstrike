// Dragnet [Ransomware]: dragnet-ransomware-2023-0397 — Mass File Rename (noescape)
// Status: experimental | Level: high | ID: e3474146-c128-58e0-b021-8feb16bbba6b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
