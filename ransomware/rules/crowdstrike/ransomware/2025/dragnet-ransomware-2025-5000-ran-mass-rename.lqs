// Dragnet [Ransomware]: dragnet-ransomware-2025-5000 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 277c506d-9de2-56a0-83ad-9381552ca671

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
