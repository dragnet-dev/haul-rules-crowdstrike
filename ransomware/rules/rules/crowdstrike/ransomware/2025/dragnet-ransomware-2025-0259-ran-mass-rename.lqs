// Dragnet [Ransomware]: dragnet-ransomware-2025-0259 — Mass File Rename (worldleaks)
// Status: experimental | Level: high | ID: 3f55d651-e1ee-5f41-9b73-55d5540caebe

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
