// Dragnet [Ransomware]: dragnet-ransomware-2021-1516 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: a4c8658f-5caa-5a1e-9a29-2a8e3784f77b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
