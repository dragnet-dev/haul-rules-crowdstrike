// Dragnet [Ransomware]: dragnet-ransomware-2025-4220 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 25f54d15-cff1-5fb2-9ef4-b3bb9c2df23a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
