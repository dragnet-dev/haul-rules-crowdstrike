// Dragnet [Ransomware]: dragnet-ransomware-2023-1315 — Mass File Rename (metaencryptor)
// Status: experimental | Level: high | ID: f1ddf24a-b8ac-5e53-bd63-afd698f6e37e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
