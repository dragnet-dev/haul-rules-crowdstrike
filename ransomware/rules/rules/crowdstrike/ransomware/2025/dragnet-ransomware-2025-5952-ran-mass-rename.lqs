// Dragnet [Ransomware]: dragnet-ransomware-2025-5952 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: bfb75e96-1b6a-5a86-89ca-3215cde86c02

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
