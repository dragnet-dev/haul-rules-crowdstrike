// Dragnet [Ransomware]: dragnet-ransomware-2024-4278 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: cb70560d-5f39-5bd0-b2d6-6fb0618aa42a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
