// Dragnet [Ransomware]: dragnet-ransomware-2024-1989 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: 79ba32e3-ef3a-5c81-afb6-72a0807a989b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
