// Dragnet [Ransomware]: dragnet-ransomware-2023-5298 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 22f8b265-2148-524d-afe8-6bdbf84ecc5d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
