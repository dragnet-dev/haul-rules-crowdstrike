// Dragnet [Ransomware]: dragnet-ransomware-2023-2184 — Mass File Rename (noescape)
// Status: experimental | Level: high | ID: 84382f73-5f27-5015-967b-c5497b2cbca9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
