// Dragnet [Ransomware]: dragnet-ransomware-2022-1168 — Mass File Rename (stormous)
// Status: deprecated | Level: high | ID: 953b44b2-452b-53c4-a309-d0f460c674b4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
