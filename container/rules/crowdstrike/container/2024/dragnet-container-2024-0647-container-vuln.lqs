// Dragnet [Container]: dragnet-container-2024-0647 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 3f916bf0-cfe4-57db-b685-365bfa48fd49

#event_simpleName=*
| (ImageFileName = *azure linux:3.0* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *photon os:3.0* OR ImageFileName = *photon os:4.0* OR ImageFileName = *redhat/ubi9:*)
| table([timestamp, ComputerName])
| limit(1000)
