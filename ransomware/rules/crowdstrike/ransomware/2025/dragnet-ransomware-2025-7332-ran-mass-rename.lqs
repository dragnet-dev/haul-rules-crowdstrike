// Dragnet [Ransomware]: dragnet-ransomware-2025-7332 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: 3ff15459-d4f5-5698-965e-eec29ea0b320

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
