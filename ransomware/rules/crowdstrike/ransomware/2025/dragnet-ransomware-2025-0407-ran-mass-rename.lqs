// Dragnet [Ransomware]: dragnet-ransomware-2025-0407 — Mass File Rename (obscura)
// Status: experimental | Level: high | ID: 56287964-1287-5e25-845d-f5fc7272aadb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
