// Dragnet [Ransomware]: dragnet-ransomware-2024-4613 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 3e5a9770-dac2-58c0-8c26-3d5ffab17519

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
