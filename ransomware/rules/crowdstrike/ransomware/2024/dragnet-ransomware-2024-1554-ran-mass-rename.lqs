// Dragnet [Ransomware]: dragnet-ransomware-2024-1554 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: ee0e7a71-0a79-5644-be32-31b4a528efc3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
