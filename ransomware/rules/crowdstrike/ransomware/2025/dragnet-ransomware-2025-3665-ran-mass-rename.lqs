// Dragnet [Ransomware]: dragnet-ransomware-2025-3665 — Mass File Rename (nasirsecurity)
// Status: experimental | Level: high | ID: 0f2b9e45-7bf6-58d5-8c79-34637163a656

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
