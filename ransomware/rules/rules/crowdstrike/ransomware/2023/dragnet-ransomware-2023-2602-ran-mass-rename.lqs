// Dragnet [Ransomware]: dragnet-ransomware-2023-2602 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: 9aeae264-42a5-5261-aef1-7896f59a72dc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
