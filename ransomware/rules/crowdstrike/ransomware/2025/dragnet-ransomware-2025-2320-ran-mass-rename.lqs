// Dragnet [Ransomware]: dragnet-ransomware-2025-2320 — Mass File Rename (obscura)
// Status: experimental | Level: high | ID: cca05e4d-5855-5c49-902c-7eda479afe47

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
