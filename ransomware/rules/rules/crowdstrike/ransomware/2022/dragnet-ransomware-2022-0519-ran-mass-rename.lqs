// Dragnet [Ransomware]: dragnet-ransomware-2022-0519 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: dffbbf75-ebc2-54e6-a86b-7c9ef2bbd734

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
