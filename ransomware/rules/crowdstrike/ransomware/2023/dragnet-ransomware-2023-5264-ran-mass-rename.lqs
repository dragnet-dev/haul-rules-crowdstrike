// Dragnet [Ransomware]: dragnet-ransomware-2023-5264 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 8092ba38-2821-5389-bb2c-b6ae64d10959

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
