// Dragnet [Ransomware]: dragnet-ransomware-2022-2085 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: b6b53d50-c556-5582-8b50-9bb7021be137

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
