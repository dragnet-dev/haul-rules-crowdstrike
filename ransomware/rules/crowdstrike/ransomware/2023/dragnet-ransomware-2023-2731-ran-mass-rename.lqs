// Dragnet [Ransomware]: dragnet-ransomware-2023-2731 — Mass File Rename (cyclops)
// Status: deprecated | Level: high | ID: 65116f2e-5bc0-5282-a19a-ea499c66a82f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
