// Dragnet [Ransomware]: dragnet-ransomware-2024-5575 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 04e6feb2-8249-5940-b6b3-827f6bf1c20a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
