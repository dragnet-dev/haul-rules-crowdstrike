// Dragnet [Ransomware]: dragnet-ransomware-2023-3502 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: aff00e4c-e740-5e25-86ec-53e5ac2eb836

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
