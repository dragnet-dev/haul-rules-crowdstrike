// Dragnet [Ransomware]: dragnet-ransomware-2025-6093 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: 74c2ec8b-6307-57d2-bde5-f1bf5a39da5a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
