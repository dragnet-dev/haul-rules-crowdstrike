// Dragnet [Container]: dragnet-container-2026-2794 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 590a8406-9f5a-5711-bb47-c959cc8956b4

#event_simpleName=*
| (ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10* OR ImageFileName = *ubuntu:13.04* OR ImageFileName = *ubuntu:13.10*)
| table([timestamp, ComputerName])
| limit(1000)
