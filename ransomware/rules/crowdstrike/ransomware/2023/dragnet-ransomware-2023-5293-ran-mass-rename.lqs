// Dragnet [Ransomware]: dragnet-ransomware-2023-5293 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: f318533a-4a4b-5368-be0e-9fc6df0cf6f4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
