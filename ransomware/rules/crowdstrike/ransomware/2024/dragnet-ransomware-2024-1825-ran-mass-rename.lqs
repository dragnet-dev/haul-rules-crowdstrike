// Dragnet [Ransomware]: dragnet-ransomware-2024-1825 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 152e3ddd-56f8-5496-ad74-86af5ad6dc38

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
