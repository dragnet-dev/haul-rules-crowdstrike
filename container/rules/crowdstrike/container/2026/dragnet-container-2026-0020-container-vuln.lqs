// Dragnet [Container]: dragnet-container-2026-0020 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 8607a401-2443-5cb7-af9b-e265b6b3c887

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13*)
| table([timestamp, ComputerName])
| limit(1000)
