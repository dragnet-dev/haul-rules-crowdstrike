// Dragnet [Ransomware]: dragnet-ransomware-2025-3093 — Mass File Rename (insomnia)
// Status: experimental | Level: high | ID: b6011322-6ec3-5438-abc7-87e83f8c7126

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
