// Dragnet [Ransomware]: dragnet-ransomware-2025-4462 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 4d992d23-db71-5a50-aa0c-0b0df1f74ecd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
