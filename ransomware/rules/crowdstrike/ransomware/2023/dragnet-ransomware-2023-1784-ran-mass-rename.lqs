// Dragnet [Ransomware]: dragnet-ransomware-2023-1784 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: dd901ac5-32da-5b59-ba1e-a9ecb31efa7b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
