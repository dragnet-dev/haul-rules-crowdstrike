// Dragnet [Container]: dragnet-container-2024-1120 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 6b7ecd5b-5bdd-539b-ac3c-d637d75c1b08

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:8* OR ImageFileName = *debian:9* OR ImageFileName = *ubuntu:18.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
