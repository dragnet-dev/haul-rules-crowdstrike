// Dragnet [Ransomware]: dragnet-ransomware-2024-1301 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: bd5a6144-30ea-50b7-9e52-8553d332bda9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
