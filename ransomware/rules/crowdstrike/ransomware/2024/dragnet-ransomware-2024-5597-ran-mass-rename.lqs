// Dragnet [Ransomware]: dragnet-ransomware-2024-5597 — Mass File Rename (BrainCipher)
// Status: experimental | Level: high | ID: 9af85bd6-c135-517a-b9e0-be150517343c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
