// Dragnet [Ransomware]: dragnet-ransomware-2025-7168 — Mass File Rename (SilentRansomGroup)
// Status: deprecated | Level: high | ID: be35b35b-679c-5790-8f8a-bd8234c67943

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
