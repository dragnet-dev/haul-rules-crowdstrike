// Dragnet [Ransomware]: dragnet-ransomware-2025-4818 — Mass File Rename (direwolf)
// Status: experimental | Level: high | ID: 0e914e27-ec02-54a8-9631-f9220f26b6f8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
