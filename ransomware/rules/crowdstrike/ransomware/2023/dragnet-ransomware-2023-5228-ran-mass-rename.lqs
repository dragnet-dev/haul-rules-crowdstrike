// Dragnet [Ransomware]: dragnet-ransomware-2023-5228 — Mass File Rename (noescape)
// Status: experimental | Level: high | ID: f69eb959-9285-5a7b-871f-9a02e63e83bd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
