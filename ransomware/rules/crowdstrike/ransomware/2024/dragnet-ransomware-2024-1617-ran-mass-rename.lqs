// Dragnet [Ransomware]: dragnet-ransomware-2024-1617 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 7b0a8e25-9609-5691-bdbb-5ab0854a6d13

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
