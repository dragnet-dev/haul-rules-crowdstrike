// Dragnet [Ransomware]: dragnet-ransomware-2022-1324 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 99e2b525-f0a3-5e36-b101-7ab6b07409bd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
