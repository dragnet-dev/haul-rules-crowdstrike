// Dragnet [Ransomware]: dragnet-ransomware-2023-3790 — Mass File Rename (siegedsec)
// Status: deprecated | Level: high | ID: 6a4b55b7-8ae2-5bfd-b950-cd4103d2333f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
