// Dragnet [Ransomware]: dragnet-ransomware-2026-0250 — Mass File Rename (incransom)
// Status: test | Level: high | ID: f6e14e65-626d-5a00-ad52-6a0588c1f0e7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
