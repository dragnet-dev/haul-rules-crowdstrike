// Dragnet [Ransomware]: dragnet-ransomware-2025-5266 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 423234ca-aff3-59d8-b390-7bf8afd9d0be

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
