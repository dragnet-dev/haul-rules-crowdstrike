// Dragnet [Ransomware]: dragnet-ransomware-2021-0037 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: b3ae0dd1-f88d-5d7d-ac3e-4ebbdff0e689

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
