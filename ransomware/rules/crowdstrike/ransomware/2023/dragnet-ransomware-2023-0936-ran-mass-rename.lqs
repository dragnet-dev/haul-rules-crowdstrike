// Dragnet [Ransomware]: dragnet-ransomware-2023-0936 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 91cfaff7-791c-5bee-be34-f48c0d5abbd9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
