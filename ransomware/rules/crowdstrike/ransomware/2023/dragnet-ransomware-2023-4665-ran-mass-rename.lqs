// Dragnet [Ransomware]: dragnet-ransomware-2023-4665 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 12ae6377-53c8-5ab9-95e1-1485c20a2ed0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
