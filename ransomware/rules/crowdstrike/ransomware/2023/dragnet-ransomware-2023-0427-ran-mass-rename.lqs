// Dragnet [Ransomware]: dragnet-ransomware-2023-0427 — Mass File Rename (royal)
// Status: experimental | Level: high | ID: 101e78cc-327f-5f6d-9b6e-652c00fab828

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
