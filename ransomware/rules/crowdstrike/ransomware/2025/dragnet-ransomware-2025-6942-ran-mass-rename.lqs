// Dragnet [Ransomware]: dragnet-ransomware-2025-6942 — Mass File Rename (sinobi)
// Status: experimental | Level: high | ID: 5afbfe1b-38b3-5f0c-8953-793983489b2f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
