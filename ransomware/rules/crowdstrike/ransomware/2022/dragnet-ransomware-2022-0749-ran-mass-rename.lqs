// Dragnet [Ransomware]: dragnet-ransomware-2022-0749 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 7849b16d-37c2-5fb3-8a13-6771d426f92c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
