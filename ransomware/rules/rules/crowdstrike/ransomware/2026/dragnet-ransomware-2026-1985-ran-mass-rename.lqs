// Dragnet [Ransomware]: dragnet-ransomware-2026-1985 — Mass File Rename (nightspire)
// Status: deprecated | Level: high | ID: 38567578-081f-59df-9794-9dbb8ac34651

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
