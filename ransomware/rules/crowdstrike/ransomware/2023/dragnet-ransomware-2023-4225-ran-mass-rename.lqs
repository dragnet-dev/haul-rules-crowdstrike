// Dragnet [Ransomware]: dragnet-ransomware-2023-4225 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: d0fa41e6-d3e4-595b-9bfb-c0f7369e19cc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
