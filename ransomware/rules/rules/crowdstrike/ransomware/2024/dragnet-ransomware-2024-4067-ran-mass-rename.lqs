// Dragnet [Ransomware]: dragnet-ransomware-2024-4067 — Mass File Rename (cloak)
// Status: deprecated | Level: high | ID: e30ec93e-01f3-5c64-b385-360619ed9ab2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
