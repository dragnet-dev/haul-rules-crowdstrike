// Dragnet [Ransomware]: dragnet-ransomware-2023-2196 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 7a4767cd-b6f5-5094-b097-e84a96f1da92

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
