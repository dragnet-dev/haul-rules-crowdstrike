// Dragnet [Ransomware]: dragnet-ransomware-2025-6400 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: 1d114e7e-8009-5890-83f4-fe52d94dc071

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
