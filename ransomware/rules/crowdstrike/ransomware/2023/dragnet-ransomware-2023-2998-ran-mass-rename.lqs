// Dragnet [Ransomware]: dragnet-ransomware-2023-2998 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 6b85a39f-86bf-55b2-be67-89edc28026e4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
