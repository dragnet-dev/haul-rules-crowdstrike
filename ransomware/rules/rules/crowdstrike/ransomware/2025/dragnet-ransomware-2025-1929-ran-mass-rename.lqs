// Dragnet [Ransomware]: dragnet-ransomware-2025-1929 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: cfe4ef70-5dc3-5f26-aefe-2f514cd7cf4e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
