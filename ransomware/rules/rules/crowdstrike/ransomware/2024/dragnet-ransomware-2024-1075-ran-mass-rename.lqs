// Dragnet [Ransomware]: dragnet-ransomware-2024-1075 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 3f2c5a24-4b60-50b7-80c5-cfa94db7c17b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
