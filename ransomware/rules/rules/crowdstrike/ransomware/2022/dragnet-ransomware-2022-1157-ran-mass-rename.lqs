// Dragnet [Ransomware]: dragnet-ransomware-2022-1157 — Mass File Rename (midas)
// Status: deprecated | Level: high | ID: e18b5ccb-27bc-5215-8185-ec626faf8b72

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
