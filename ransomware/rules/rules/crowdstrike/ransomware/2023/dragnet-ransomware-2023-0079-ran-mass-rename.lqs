// Dragnet [Ransomware]: dragnet-ransomware-2023-0079 — Mass File Rename (play)
// Status: deprecated | Level: high | ID: 81730b84-7dbb-56b9-8a5a-f17f2c66200c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
