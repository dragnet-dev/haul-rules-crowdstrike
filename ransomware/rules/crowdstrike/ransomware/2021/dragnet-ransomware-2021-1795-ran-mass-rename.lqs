// Dragnet [Ransomware]: dragnet-ransomware-2021-1795 — Mass File Rename (avaddon)
// Status: deprecated | Level: high | ID: 12fca40a-1b08-5b1d-befc-8f88ed16684d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
