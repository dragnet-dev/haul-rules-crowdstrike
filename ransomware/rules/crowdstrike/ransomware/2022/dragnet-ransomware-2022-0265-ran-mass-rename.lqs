// Dragnet [Ransomware]: dragnet-ransomware-2022-0265 — Mass File Rename (onyx)
// Status: deprecated | Level: high | ID: 833a7436-7c17-51a0-9491-04ac81c9ffee

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
