// Dragnet [Ransomware]: dragnet-ransomware-2020-0064 — Mass File Rename (doppelpaymer)
// Status: deprecated | Level: high | ID: 3be3be72-7be5-5375-9efe-4879e83a4f28

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
