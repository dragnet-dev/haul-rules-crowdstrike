// Dragnet [Container]: dragnet-container-2026-2083 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 9f13ef38-bf45-552c-ac72-fa66e3e9de7a

#event_simpleName=*
| (ImageFileName = *alpine:3.4* OR ImageFileName = *alpine:3.5* OR ImageFileName = *amazonlinux:1* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:7* OR ImageFileName = *debian:8* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *oraclelinux:7* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:14.04* OR ImageFileName = *ubuntu:16.04* OR ImageFileName = *ubuntu:16.04-ESM* OR ImageFileName = *ubuntu:16.10*)
| table([timestamp, ComputerName])
| limit(1000)
