// Dragnet [Ransomware]: dragnet-ransomware-2025-4446 — Mass File Rename (sinobi)
// Status: experimental | Level: high | ID: e212f83a-435c-5d88-b2f4-2fd765c205a6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
