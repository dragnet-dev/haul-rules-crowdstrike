// Dragnet [Ransomware]: dragnet-ransomware-2021-1784 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 7ec574c7-b46b-5210-9982-4b3603c91704

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
