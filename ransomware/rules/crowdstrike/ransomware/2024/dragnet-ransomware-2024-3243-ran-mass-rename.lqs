// Dragnet [Ransomware]: dragnet-ransomware-2024-3243 — Mass File Rename (rhysida)
// Status: experimental | Level: high | ID: c05e7c4e-3e96-5d56-8dad-6a5b7d959b50

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
