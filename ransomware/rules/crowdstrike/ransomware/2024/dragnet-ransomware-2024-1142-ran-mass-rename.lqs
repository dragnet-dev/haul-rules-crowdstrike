// Dragnet [Ransomware]: dragnet-ransomware-2024-1142 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 2e67e936-9d4a-5cb1-a45b-8d6b7fa1f68c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
