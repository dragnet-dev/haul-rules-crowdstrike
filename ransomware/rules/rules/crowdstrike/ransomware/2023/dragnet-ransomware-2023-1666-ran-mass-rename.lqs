// Dragnet [Ransomware]: dragnet-ransomware-2023-1666 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 0cf159f0-91d5-53dc-8a95-3f05dbc878c3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
