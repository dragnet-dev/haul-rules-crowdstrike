// Dragnet [Container]: dragnet-container-2026-2260 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: eb7557f6-3eea-5cf8-bf4d-4f20053e7b89

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
