// Dragnet [Ransomware]: dragnet-ransomware-2025-2199 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: b7210f09-fdd2-582c-9698-23188b3302d7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
