// Dragnet [Ransomware]: dragnet-ransomware-2024-3412 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 7aa3a155-40f8-5930-8489-3da8373a84d4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
