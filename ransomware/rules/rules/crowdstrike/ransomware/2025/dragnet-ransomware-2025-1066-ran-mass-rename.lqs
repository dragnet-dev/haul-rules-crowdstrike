// Dragnet [Ransomware]: dragnet-ransomware-2025-1066 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 93dc4de6-9408-5c23-847d-46fbe709f66b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
