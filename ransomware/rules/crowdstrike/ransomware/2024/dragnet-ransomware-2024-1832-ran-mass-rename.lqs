// Dragnet [Ransomware]: dragnet-ransomware-2024-1832 — Mass File Rename (apt73)
// Status: experimental | Level: high | ID: 7d849a60-b6bb-5dbd-8e93-6eaff8f4373e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
