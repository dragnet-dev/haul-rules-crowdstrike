// Dragnet [Ransomware]: dragnet-ransomware-2024-5622 — Mass File Rename (arcusmedia)
// Status: experimental | Level: high | ID: ccfdc674-f5e3-52bf-829f-76f318541e90

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
