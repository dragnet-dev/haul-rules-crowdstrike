// Dragnet [Ransomware]: dragnet-ransomware-2024-3649 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 20b15818-c62b-5923-9862-f2fa0febbf03

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
