// Dragnet [Ransomware]: dragnet-ransomware-2024-1410 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 54bd02d8-6838-5bef-a296-8663fe3160ae

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
