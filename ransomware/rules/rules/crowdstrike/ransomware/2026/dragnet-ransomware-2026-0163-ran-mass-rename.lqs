// Dragnet [Ransomware]: dragnet-ransomware-2026-0163 — Mass File Rename (lockbit5)
// Status: stable | Level: high | ID: e8ff04bc-e60a-5b80-ae8e-e369fb493933

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
