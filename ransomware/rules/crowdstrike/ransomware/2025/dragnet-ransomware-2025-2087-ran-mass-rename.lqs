// Dragnet [Ransomware]: dragnet-ransomware-2025-2087 — Mass File Rename (RunSomeWares)
// Status: experimental | Level: high | ID: 08c08356-06ff-55d9-9e3c-8cb19471e0ee

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
