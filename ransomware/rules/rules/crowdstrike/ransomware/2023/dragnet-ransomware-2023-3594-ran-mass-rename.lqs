// Dragnet [Ransomware]: dragnet-ransomware-2023-3594 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 66678251-9736-5be8-942f-ff35e7fca60e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
