// Dragnet [Ransomware]: dragnet-ransomware-2024-4482 — Mass File Rename (dAn0n)
// Status: experimental | Level: high | ID: 40e25eb0-8408-5167-9fc2-802190ce4d29

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
