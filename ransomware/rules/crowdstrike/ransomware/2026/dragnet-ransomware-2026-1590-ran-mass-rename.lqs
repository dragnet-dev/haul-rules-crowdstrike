// Dragnet [Ransomware]: dragnet-ransomware-2026-1590 — Mass File Rename (safepay)
// Status: stable | Level: high | ID: dda13016-e216-5fd6-8765-baa8b4f69552

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
