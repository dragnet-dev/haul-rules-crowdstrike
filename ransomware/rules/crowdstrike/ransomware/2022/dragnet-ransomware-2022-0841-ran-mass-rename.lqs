// Dragnet [Ransomware]: dragnet-ransomware-2022-0841 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 9fb6e5a3-cff5-5b4f-a405-f83755abc6b4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
