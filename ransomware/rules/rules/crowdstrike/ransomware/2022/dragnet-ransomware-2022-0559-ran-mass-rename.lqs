// Dragnet [Ransomware]: dragnet-ransomware-2022-0559 — Mass File Rename (kelvinsecurity)
// Status: deprecated | Level: high | ID: 1a241277-3cba-5cd1-8640-e6c5364b2f22

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
