// Dragnet [Ransomware]: dragnet-ransomware-2020-0205 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 7233b22e-4354-574b-82ba-d3c52ef4ba80

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
