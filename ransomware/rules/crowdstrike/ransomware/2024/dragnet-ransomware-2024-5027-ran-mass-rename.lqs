// Dragnet [Ransomware]: dragnet-ransomware-2024-5027 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 9b4ff290-555f-527a-ab64-772a8cd4be61

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
