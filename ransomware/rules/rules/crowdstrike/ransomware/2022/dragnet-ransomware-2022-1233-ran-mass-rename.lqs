// Dragnet [Ransomware]: dragnet-ransomware-2022-1233 — Mass File Rename (blackbasta)
// Status: deprecated | Level: high | ID: f962b7a2-9af2-5db1-ab25-b08244aef176

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
