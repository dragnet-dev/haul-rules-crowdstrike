// Dragnet [Ransomware]: dragnet-ransomware-2025-4482 — Mass File Rename (anubis)
// Status: experimental | Level: high | ID: 69e2f19c-c2c5-569f-b757-466a33a07796

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
