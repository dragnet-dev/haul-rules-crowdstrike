// Dragnet [Ransomware]: dragnet-ransomware-2023-0012 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 484e5b8a-2ef9-5c16-9637-ffb2205b55ee

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
