// Dragnet [Ransomware]: dragnet-ransomware-2024-3594 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: f66377fd-b173-5075-88a8-8c924c18e573

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
