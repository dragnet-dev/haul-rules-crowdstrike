// Dragnet [Ransomware]: dragnet-ransomware-2025-4870 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: 00bd42b6-475f-5511-a82d-ea0a07e65f73

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
