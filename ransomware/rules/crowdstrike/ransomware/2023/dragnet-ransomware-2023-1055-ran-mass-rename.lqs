// Dragnet [Ransomware]: dragnet-ransomware-2023-1055 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 8a88e4dc-e800-52ad-bbf6-1d1a50c78ac7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
