// Dragnet [Ransomware]: dragnet-ransomware-2022-1664 — Mass File Rename (everest)
// Status: deprecated | Level: high | ID: 6d749556-cf5a-5b0e-a90b-6e1c751b5eed

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
