// Dragnet [Ransomware]: dragnet-ransomware-2024-4249 — Mass File Rename (trigona)
// Status: experimental | Level: high | ID: 6867acc9-c230-52dd-94b6-fdeb993f1c07

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
