// Dragnet [Ransomware]: dragnet-ransomware-2024-1930 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: ed8069d6-163d-5da9-a2fd-b1a32a2b06cb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
