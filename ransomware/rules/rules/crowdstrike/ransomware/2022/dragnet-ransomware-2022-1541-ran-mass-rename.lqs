// Dragnet [Ransomware]: dragnet-ransomware-2022-1541 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 05c6e65f-a490-593f-915f-5e3b67b5ac61

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
