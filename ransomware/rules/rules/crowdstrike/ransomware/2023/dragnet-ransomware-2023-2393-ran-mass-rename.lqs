// Dragnet [Ransomware]: dragnet-ransomware-2023-2393 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 667ce58e-dab1-5aea-a1d0-127af56163a7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
