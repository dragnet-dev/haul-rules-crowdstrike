// Dragnet [Ransomware]: dragnet-ransomware-2023-1697 — Mass File Rename (mallox)
// Status: deprecated | Level: high | ID: 480387c8-cdbc-5cd8-86f9-ab46b76e0a7c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
