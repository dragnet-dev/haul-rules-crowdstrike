// Dragnet [Ransomware]: dragnet-ransomware-2023-2517 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: e87d6877-1c9e-5d02-a67e-dbc0d87a2d01

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
