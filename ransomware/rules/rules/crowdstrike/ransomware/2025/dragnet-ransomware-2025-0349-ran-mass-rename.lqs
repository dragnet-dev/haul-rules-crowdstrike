// Dragnet [Ransomware]: dragnet-ransomware-2025-0349 — Mass File Rename (crazyhunter)
// Status: experimental | Level: high | ID: b116cfd7-000d-5a06-bf0d-540d0ba28126

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
