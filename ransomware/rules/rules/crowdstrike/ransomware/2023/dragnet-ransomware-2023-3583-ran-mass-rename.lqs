// Dragnet [Ransomware]: dragnet-ransomware-2023-3583 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 9f0e5316-81a1-5f2c-b7cf-8e3ebe90eff7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
