// Dragnet [Ransomware]: dragnet-ransomware-2022-0120 — Mass File Rename (cuba)
// Status: deprecated | Level: high | ID: 715b89e4-99d4-5b8d-a70a-f8c6cc28e214

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
