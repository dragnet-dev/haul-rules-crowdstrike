// Dragnet [Ransomware]: dragnet-ransomware-2024-1448 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: af81f977-0396-56f8-9f36-5304f42603ac

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
