// Dragnet [Ransomware]: dragnet-ransomware-2022-1272 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 60f99d8e-07e2-5320-8229-3916a3cfdd40

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
