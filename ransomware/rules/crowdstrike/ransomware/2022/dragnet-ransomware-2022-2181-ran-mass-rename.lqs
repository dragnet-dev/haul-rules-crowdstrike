// Dragnet [Ransomware]: dragnet-ransomware-2022-2181 — Mass File Rename (quantum)
// Status: deprecated | Level: high | ID: a373c5f1-1d3d-56b9-accf-eac9ba2c2aa7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
