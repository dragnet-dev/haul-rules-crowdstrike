// Dragnet [Ransomware]: dragnet-ransomware-2025-4104 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: c7ad9455-76a6-53cc-abbf-d300bff2f9e4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
