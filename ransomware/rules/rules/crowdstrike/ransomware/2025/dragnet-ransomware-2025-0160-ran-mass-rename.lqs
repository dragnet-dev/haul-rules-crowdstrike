// Dragnet [Ransomware]: dragnet-ransomware-2025-0160 — Mass File Rename (play)
// Status: experimental | Level: high | ID: b436b4bf-94a8-5c52-9cc3-11c71fd0318b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
