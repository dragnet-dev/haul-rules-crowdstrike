// Dragnet [Ransomware]: dragnet-ransomware-2024-0997 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: ef347fd3-0ef2-5f77-bd34-dbe76e779376

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
