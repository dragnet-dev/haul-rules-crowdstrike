// Dragnet [Ransomware]: dragnet-ransomware-2025-1768 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 0a475321-a42d-560d-b505-f32d7d689ebc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
