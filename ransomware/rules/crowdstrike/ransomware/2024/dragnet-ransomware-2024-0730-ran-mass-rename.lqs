// Dragnet [Ransomware]: dragnet-ransomware-2024-0730 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: fd32f935-5984-5f45-9f9a-fb1dd1262540

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
