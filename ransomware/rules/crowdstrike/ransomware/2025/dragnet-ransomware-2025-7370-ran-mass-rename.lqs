// Dragnet [Ransomware]: dragnet-ransomware-2025-7370 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 7ba45596-5552-5368-b37a-401c55ecd5a1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
