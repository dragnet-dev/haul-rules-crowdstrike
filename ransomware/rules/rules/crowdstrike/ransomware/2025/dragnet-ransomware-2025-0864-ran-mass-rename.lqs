// Dragnet [Ransomware]: dragnet-ransomware-2025-0864 — Mass File Rename (sarcoma)
// Status: deprecated | Level: high | ID: 798f769d-2db5-5c00-b968-a8a14c22909b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
