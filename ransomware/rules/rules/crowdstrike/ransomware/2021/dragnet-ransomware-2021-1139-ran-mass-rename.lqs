// Dragnet [Ransomware]: dragnet-ransomware-2021-1139 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: 61c6bf38-b0ae-5049-8d1f-50ed7ecc6173

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
