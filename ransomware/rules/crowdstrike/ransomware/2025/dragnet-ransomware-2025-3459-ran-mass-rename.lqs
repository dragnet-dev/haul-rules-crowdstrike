// Dragnet [Ransomware]: dragnet-ransomware-2025-3459 — Mass File Rename (flocker)
// Status: experimental | Level: high | ID: edcfb8f8-33dc-5fd0-a51d-8f2a3d72c31d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
