// Dragnet [Ransomware]: dragnet-ransomware-2023-2784 — Mass File Rename (malas)
// Status: experimental | Level: high | ID: 5972181d-c441-5206-b9aa-0efcc7ef97f9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
