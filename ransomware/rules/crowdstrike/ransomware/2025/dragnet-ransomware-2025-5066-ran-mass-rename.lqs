// Dragnet [Ransomware]: dragnet-ransomware-2025-5066 — Mass File Rename (killsec)
// Status: deprecated | Level: high | ID: b1267fa3-90b5-5254-96af-65d1fcd5f796

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
