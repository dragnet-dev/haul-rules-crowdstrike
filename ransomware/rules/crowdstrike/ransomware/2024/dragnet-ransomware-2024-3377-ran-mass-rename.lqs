// Dragnet [Ransomware]: dragnet-ransomware-2024-3377 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: ad5348a5-75aa-59ea-a67a-9252ad3f47fd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
