// Dragnet [Ransomware]: dragnet-ransomware-2024-5856 — Mass File Rename (handala)
// Status: experimental | Level: high | ID: 2a57088f-4d07-549f-99cf-2b006b4f956a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
