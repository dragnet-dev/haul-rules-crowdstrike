// Dragnet [Ransomware]: dragnet-ransomware-2025-1738 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: cb932f03-1876-5000-9ec6-ed671d45d1b0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
