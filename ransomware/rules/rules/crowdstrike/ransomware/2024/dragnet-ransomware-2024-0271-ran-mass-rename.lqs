// Dragnet [Ransomware]: dragnet-ransomware-2024-0271 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: eab0e784-9663-5415-b5a3-a0ba663bf2a2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
