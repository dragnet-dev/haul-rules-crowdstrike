// Dragnet [Ransomware]: dragnet-ransomware-2023-0718 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: eb267aef-b683-5bc1-8e5a-4581c9b956d2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
