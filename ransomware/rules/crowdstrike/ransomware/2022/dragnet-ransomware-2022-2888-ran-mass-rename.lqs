// Dragnet [Ransomware]: dragnet-ransomware-2022-2888 — Mass File Rename (everest)
// Status: deprecated | Level: high | ID: cc80b387-730b-570d-8aa1-47679ea3de81

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
