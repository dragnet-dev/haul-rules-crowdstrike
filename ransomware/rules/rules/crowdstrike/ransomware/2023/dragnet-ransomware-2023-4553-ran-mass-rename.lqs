// Dragnet [Ransomware]: dragnet-ransomware-2023-4553 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 236f9e2d-585f-5cd8-8741-13eb211012ae

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
