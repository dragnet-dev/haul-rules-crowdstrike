// Dragnet [Ransomware]: dragnet-ransomware-2023-3727 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: a75977fa-8203-5b3a-b795-6ee59f6a2208

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
