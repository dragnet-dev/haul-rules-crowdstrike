// Dragnet [Ransomware]: dragnet-ransomware-2024-4971 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 05b38f0d-ac79-50bc-a99d-e23120dc9598

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
