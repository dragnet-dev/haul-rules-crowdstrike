// Dragnet [Ransomware]: dragnet-ransomware-2025-1246 — Mass File Rename (beast)
// Status: experimental | Level: high | ID: 4156349b-f731-5395-867e-da297fbaff33

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
