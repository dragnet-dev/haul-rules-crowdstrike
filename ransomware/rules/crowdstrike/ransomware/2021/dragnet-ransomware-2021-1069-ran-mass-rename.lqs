// Dragnet [Ransomware]: dragnet-ransomware-2021-1069 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: ce188020-03d5-5dc5-9552-b82d6d321d3a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
