// Dragnet [Ransomware]: dragnet-ransomware-2024-5560 — Mass File Rename (apt73)
// Status: experimental | Level: high | ID: 889e00b8-170f-5ec5-8b75-945c4d70f272

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
