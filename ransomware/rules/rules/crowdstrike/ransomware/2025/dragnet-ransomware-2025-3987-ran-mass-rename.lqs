// Dragnet [Ransomware]: dragnet-ransomware-2025-3987 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 26d32fbb-e41b-5987-9473-f52d8f74504b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
