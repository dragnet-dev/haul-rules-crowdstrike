// Dragnet [Ransomware]: dragnet-ransomware-2021-0938 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 24e0b55d-2956-535d-980b-6b14eca91be9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
