// Dragnet [Ransomware]: dragnet-ransomware-2022-3141 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 87c48175-27ed-5b61-959f-a502a0625f14

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
