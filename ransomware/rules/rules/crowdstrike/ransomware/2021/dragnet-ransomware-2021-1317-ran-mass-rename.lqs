// Dragnet [Ransomware]: dragnet-ransomware-2021-1317 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 5c37f20f-be6e-53e2-9f58-c37b3c754ef9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
