// Dragnet [Ransomware]: dragnet-ransomware-2023-2536 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: f4219ee0-6aaf-5835-889c-6e932e1a8706

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
