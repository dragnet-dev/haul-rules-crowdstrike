// Dragnet [Ransomware]: dragnet-ransomware-2022-1133 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: a0ffef10-9003-5708-b60d-510b6c1eae58

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
