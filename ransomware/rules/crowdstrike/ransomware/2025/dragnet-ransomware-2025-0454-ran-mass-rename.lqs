// Dragnet [Ransomware]: dragnet-ransomware-2025-0454 — Mass File Rename (devman)
// Status: experimental | Level: high | ID: 881029f5-b819-52b4-838c-fa8521e0c37d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
