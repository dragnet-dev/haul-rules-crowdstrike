// Dragnet [Ransomware]: dragnet-ransomware-2025-4931 — Mass File Rename (coinbasecartel)
// Status: experimental | Level: high | ID: e13951f0-7f00-54f1-b939-1861a96d0ee2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
