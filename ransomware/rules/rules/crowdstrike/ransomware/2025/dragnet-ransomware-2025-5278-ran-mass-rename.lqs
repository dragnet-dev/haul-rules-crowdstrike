// Dragnet [Ransomware]: dragnet-ransomware-2025-5278 — Mass File Rename (sinobi)
// Status: experimental | Level: high | ID: e1a00cea-7078-5d39-8c4e-b57aafb3c092

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
