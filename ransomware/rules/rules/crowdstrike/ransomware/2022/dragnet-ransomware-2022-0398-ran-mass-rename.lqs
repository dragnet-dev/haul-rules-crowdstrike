// Dragnet [Ransomware]: dragnet-ransomware-2022-0398 — Mass File Rename (everest)
// Status: deprecated | Level: high | ID: a0edca35-6ca3-5518-b725-9844b5f11b49

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
