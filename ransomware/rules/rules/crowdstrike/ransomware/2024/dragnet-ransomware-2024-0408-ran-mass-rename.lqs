// Dragnet [Ransomware]: dragnet-ransomware-2024-0408 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: cf33755f-ffa6-5c9f-9883-9aa6bf52bfc9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
