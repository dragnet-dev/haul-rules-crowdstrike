// Dragnet [Ransomware]: dragnet-ransomware-2020-0032 — Mass File Rename (ryuk)
// Status: deprecated | Level: high | ID: e09535a4-a1db-501b-b9cd-9c8e5fbfa373

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
