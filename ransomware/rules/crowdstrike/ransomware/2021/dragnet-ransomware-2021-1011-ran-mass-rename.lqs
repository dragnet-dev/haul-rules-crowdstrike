// Dragnet [Ransomware]: dragnet-ransomware-2021-1011 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: d1b1e810-bff3-5bbd-98c8-7006f920a4af

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
