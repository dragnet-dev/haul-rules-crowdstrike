// Dragnet [Ransomware]: dragnet-ransomware-2025-0089 — Mass File Rename (nitrogen)
// Status: experimental | Level: high | ID: b8b92498-d3d0-5e6e-9b66-76711759cdc3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
