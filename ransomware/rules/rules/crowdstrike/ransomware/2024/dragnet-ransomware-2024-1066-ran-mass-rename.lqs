// Dragnet [Ransomware]: dragnet-ransomware-2024-1066 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: bcd8e3c9-645f-57eb-ac95-e273de9bea1e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
