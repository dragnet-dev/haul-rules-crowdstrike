// Dragnet [Ransomware]: dragnet-ransomware-2023-1769 — Mass File Rename (play)
// Status: experimental | Level: high | ID: ce0cdad8-987e-5ee7-8086-91c2490cf7c4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
