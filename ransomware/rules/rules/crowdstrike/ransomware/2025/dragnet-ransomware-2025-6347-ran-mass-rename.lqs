// Dragnet [Ransomware]: dragnet-ransomware-2025-6347 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 48c3bed6-86f4-5319-a6ee-917ca571d906

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
