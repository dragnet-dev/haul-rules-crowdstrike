// Dragnet [Ransomware]: dragnet-ransomware-2026-3311 — Mass File Rename (payload)
// Status: stable | Level: high | ID: f012e4ba-e2c2-5518-80ae-f36039cb230d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
