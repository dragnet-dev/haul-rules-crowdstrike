// Dragnet [Ransomware]: dragnet-ransomware-2022-1989 — Mass File Rename (blackbasta)
// Status: deprecated | Level: high | ID: 62763147-46f6-5d4f-bb7d-a11e767ce15b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
