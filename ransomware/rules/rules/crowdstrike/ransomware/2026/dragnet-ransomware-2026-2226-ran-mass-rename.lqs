// Dragnet [Ransomware]: dragnet-ransomware-2026-2226 — Mass File Rename (dragonforce)
// Status: stable | Level: high | ID: 26decdab-baff-5d30-8524-263f69d36461

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
