// Dragnet [Ransomware]: dragnet-ransomware-2025-1641 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 282b220c-e582-5ec1-b817-8817ecbc6356

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
