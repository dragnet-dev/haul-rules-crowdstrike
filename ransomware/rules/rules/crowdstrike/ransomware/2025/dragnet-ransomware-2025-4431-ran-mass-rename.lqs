// Dragnet [Ransomware]: dragnet-ransomware-2025-4431 — Mass File Rename (chaos)
// Status: experimental | Level: high | ID: 5e24788d-94de-5e5f-9e81-8e69c5b3a815

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
