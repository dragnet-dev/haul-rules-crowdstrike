// Dragnet [Ransomware]: dragnet-ransomware-2023-0266 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 25c1e6db-800e-5d87-ad2b-f0780b62e776

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
