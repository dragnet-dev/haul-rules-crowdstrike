// Dragnet [Ransomware]: dragnet-ransomware-2024-1536 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: eea1531f-85ff-5de5-bcdb-c7d54c4e07bb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
