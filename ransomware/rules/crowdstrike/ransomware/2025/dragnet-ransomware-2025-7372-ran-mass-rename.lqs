// Dragnet [Ransomware]: dragnet-ransomware-2025-7372 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: d36c9c23-8d1e-569a-9ad9-05bd777d03f1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
