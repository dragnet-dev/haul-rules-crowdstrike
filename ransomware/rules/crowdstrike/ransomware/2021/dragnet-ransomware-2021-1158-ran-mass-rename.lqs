// Dragnet [Ransomware]: dragnet-ransomware-2021-1158 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 04af3e9a-0e2b-50b1-a209-530c6b7c4093

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
