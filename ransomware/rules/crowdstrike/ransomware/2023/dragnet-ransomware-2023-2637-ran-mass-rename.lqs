// Dragnet [Ransomware]: dragnet-ransomware-2023-2637 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 2a98560c-430b-5e01-87ef-073fcf070486

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
