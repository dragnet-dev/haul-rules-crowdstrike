// Dragnet [Ransomware]: dragnet-ransomware-2025-1625 — Mass File Rename (kairos)
// Status: experimental | Level: high | ID: c90eeb2e-6a67-5fb2-ba5d-43c698c17ff3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
