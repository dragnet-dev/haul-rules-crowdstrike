// Dragnet [Ransomware]: dragnet-ransomware-2023-1198 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: fdb522f9-82f2-55cb-9d79-f331f191c7ce

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
