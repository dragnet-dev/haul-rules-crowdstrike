// Dragnet [Ransomware]: dragnet-ransomware-2023-2565 — Mass File Rename (snatch)
// Status: experimental | Level: high | ID: eec98e5b-8f98-5b54-8469-e63a449a9e24

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
