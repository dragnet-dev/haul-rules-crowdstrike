// Dragnet [Ransomware]: dragnet-ransomware-2020-0004 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 589e650c-92db-54b9-9a6c-10b4a90dfd7f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
