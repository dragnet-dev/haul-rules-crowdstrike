// Dragnet [Ransomware]: dragnet-ransomware-2023-0081 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: c7f195e3-130c-5e8d-97fd-3136e8901d39

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
