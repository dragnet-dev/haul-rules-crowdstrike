// Dragnet [Ransomware]: dragnet-ransomware-2026-3519 — Mass File Rename (interlock)
// Status: test | Level: high | ID: 18b84a87-a205-5281-aa6e-9bb8100f27ca

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
