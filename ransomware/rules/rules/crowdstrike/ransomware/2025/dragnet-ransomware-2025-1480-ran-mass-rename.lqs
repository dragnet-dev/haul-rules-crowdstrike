// Dragnet [Ransomware]: dragnet-ransomware-2025-1480 — Mass File Rename (threeam)
// Status: experimental | Level: high | ID: 62b9a6b5-e285-56b2-8f84-a3861f1b5c41

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
