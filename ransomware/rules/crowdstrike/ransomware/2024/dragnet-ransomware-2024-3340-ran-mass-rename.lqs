// Dragnet [Ransomware]: dragnet-ransomware-2024-3340 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: da2729e3-ecde-5a67-8528-d2aedc93e17f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
