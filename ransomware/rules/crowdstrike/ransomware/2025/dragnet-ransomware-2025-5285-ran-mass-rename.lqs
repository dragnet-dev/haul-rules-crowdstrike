// Dragnet [Ransomware]: dragnet-ransomware-2025-5285 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: 1990de9b-10ee-5090-aab8-9b4e841629da

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
