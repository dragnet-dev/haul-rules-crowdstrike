// Dragnet [Ransomware]: dragnet-ransomware-2024-3067 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: 363b6080-c46f-5500-bce0-c3372d09f24d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
