// Dragnet [Ransomware]: dragnet-ransomware-2024-3281 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 89e2381d-beb2-5e25-82de-2148cdbbc8d2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
