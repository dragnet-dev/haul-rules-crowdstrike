// Dragnet [Ransomware]: dragnet-ransomware-2023-1305 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 6d015370-c91b-5746-ad4d-381227645249

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
