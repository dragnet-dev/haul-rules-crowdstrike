// Dragnet [Ransomware]: dragnet-ransomware-2023-1566 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: ffe8223c-7f2f-5db6-9ed2-b931a273ce1c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
