// Dragnet [Ransomware]: dragnet-ransomware-2022-2447 — Mass File Rename (blackbasta)
// Status: deprecated | Level: high | ID: 4a6bb61a-cb12-575b-b0e0-3dd73a75fa5b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
