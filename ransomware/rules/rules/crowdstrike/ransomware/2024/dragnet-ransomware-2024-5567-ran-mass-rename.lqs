// Dragnet [Ransomware]: dragnet-ransomware-2024-5567 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 67cd7f5c-e40b-5344-bc59-f3a47b14195e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
