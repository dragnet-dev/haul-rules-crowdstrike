// Dragnet [Ransomware]: dragnet-ransomware-2024-4020 — Mass File Rename (abyss)
// Status: deprecated | Level: high | ID: 84b1b8bd-7de4-5822-b183-4a7de87d41e6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
