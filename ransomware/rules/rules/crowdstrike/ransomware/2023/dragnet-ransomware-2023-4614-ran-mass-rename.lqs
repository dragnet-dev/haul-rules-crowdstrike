// Dragnet [Ransomware]: dragnet-ransomware-2023-4614 — Mass File Rename (cactus)
// Status: deprecated | Level: high | ID: 3e6ac5f9-dd9c-538c-b423-1909357bb239

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
