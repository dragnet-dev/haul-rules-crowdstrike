// Dragnet [Ransomware]: dragnet-ransomware-2023-0185 — Mass File Rename (royal)
// Status: experimental | Level: high | ID: 38fab12d-1d3c-5128-9742-672a8ed52add

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
