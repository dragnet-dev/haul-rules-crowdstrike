// Dragnet [Ransomware]: dragnet-ransomware-2025-3582 — Mass File Rename (warlock)
// Status: deprecated | Level: high | ID: 32633ae7-2a65-5aba-b65b-551e1495b89f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
