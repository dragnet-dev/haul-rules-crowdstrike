// Dragnet [Ransomware]: dragnet-ransomware-2025-6121 — Mass File Rename (interlock)
// Status: experimental | Level: high | ID: 3f4608b4-12fd-5b64-96b2-b95fcb45f5e1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
