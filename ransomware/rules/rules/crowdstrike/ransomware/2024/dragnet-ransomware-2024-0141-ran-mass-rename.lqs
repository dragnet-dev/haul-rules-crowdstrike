// Dragnet [Ransomware]: dragnet-ransomware-2024-0141 — Mass File Rename (arcusmedia)
// Status: experimental | Level: high | ID: d78adf35-db6d-5e82-bbb4-d5599e97b656

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
