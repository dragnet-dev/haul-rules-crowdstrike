// Dragnet [Ransomware]: dragnet-ransomware-2024-6024 — Mass File Rename (cloak)
// Status: deprecated | Level: high | ID: 191c2cee-d2eb-5f0b-b9e3-336ebf6f8a55

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
