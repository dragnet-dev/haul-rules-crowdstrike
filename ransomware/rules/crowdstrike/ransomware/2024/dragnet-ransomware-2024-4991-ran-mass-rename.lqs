// Dragnet [Ransomware]: dragnet-ransomware-2024-4991 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 59d09dce-d922-5c44-8509-15bf6fa71bcd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
