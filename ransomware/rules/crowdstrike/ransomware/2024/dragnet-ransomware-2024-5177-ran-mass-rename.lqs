// Dragnet [Ransomware]: dragnet-ransomware-2024-5177 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: c7434de9-85d8-51f3-9a30-e61be8973397

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
