// Dragnet [Ransomware]: dragnet-ransomware-2025-1206 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 76238fa7-f6ef-5be9-aa76-6ee90a05b984

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
