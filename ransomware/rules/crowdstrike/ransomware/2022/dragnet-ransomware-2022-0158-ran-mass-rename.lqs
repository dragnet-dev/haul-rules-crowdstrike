// Dragnet [Ransomware]: dragnet-ransomware-2022-0158 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: 4f7db512-dede-5716-99ee-c340a19902f9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
