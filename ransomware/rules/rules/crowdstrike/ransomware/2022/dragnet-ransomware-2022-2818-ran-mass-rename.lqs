// Dragnet [Ransomware]: dragnet-ransomware-2022-2818 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 3482a982-b893-59b0-93d2-f853cb6f71cd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
