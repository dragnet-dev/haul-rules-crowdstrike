// Dragnet [Ransomware]: dragnet-ransomware-2023-4916 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: aaaed904-2114-54e6-a174-ebd57e079b38

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
