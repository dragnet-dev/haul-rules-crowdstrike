// Dragnet [Ransomware]: dragnet-ransomware-2026-1691 — Mass File Rename (nightspire)
// Status: deprecated | Level: high | ID: 61fdb98a-0dc1-56ed-96ec-9f65b0b342f3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
