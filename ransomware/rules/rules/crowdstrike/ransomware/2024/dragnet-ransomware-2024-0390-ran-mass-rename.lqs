// Dragnet [Ransomware]: dragnet-ransomware-2024-0390 — Mass File Rename (darkvault)
// Status: experimental | Level: high | ID: b8ce5c00-723b-5582-9e8a-f716a6a903e0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
