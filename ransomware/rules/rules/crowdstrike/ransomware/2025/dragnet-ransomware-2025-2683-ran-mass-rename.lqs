// Dragnet [Ransomware]: dragnet-ransomware-2025-2683 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 314077dc-4c14-5109-a113-805d8ae21569

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
