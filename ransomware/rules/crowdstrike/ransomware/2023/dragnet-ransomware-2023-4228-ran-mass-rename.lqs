// Dragnet [Ransomware]: dragnet-ransomware-2023-4228 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 96851496-868b-53d1-b349-ac714e622bf8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
