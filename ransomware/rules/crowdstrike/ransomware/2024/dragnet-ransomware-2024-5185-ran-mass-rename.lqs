// Dragnet [Ransomware]: dragnet-ransomware-2024-5185 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: 153494e7-c50a-5a3b-8deb-a9a02309e339

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
