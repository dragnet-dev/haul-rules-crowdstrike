// Dragnet [Ransomware]: dragnet-ransomware-2022-2935 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: a636e7dd-9c6c-5d27-b581-c19767df92ad

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
