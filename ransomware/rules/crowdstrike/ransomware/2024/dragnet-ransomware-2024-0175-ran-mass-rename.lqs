// Dragnet [Ransomware]: dragnet-ransomware-2024-0175 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: 746132c9-20ef-5e30-b061-8186bb0d7dc7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
