// Dragnet [Ransomware]: dragnet-ransomware-2023-0486 — Mass File Rename (monti)
// Status: experimental | Level: high | ID: ba53ec52-5e9d-5b6f-83c9-79edc2da5f8e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
