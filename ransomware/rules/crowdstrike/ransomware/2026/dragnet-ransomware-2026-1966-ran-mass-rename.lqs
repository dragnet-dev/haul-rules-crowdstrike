// Dragnet [Ransomware]: dragnet-ransomware-2026-1966 — Mass File Rename (worldleaks)
// Status: stable | Level: high | ID: 61d8a329-733e-5ceb-b8ad-81e66a13819d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
