// Dragnet [Container]: dragnet-container-2026-2957 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: bcd26fd8-11a5-5acd-9a2e-32a0977fe095

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
