// Dragnet [Ransomware]: dragnet-ransomware-2023-1924 — Mass File Rename (snatch)
// Status: experimental | Level: high | ID: cdb8d823-3ec7-58f5-9e2c-697876f069f1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
