// Dragnet [Ransomware]: dragnet-ransomware-2025-7608 — Mass File Rename (flocker)
// Status: experimental | Level: high | ID: 995f135d-a5d6-5215-ab48-f71fa1c0dfad

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
