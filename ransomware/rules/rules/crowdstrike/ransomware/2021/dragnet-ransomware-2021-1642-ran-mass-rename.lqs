// Dragnet [Ransomware]: dragnet-ransomware-2021-1642 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 60564d40-8459-5d7d-9708-2aeabbfe0955

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
