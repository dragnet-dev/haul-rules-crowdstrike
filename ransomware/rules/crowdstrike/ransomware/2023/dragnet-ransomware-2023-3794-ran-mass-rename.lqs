// Dragnet [Ransomware]: dragnet-ransomware-2023-3794 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 0546c3f0-ed80-5ce6-b9ca-57e0b61a111e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
