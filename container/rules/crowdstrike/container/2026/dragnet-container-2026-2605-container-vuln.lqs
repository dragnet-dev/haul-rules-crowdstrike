// Dragnet [Container]: dragnet-container-2026-2605 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 94cd8b45-f70c-5799-bbf1-c5a4f6283ddd

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
