// Dragnet [Ransomware]: dragnet-ransomware-2025-5145 — Mass File Rename (dragonforce)
// Status: test | Level: high | ID: f1bade28-4551-5b44-bbe8-6eb3be6cc98f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
