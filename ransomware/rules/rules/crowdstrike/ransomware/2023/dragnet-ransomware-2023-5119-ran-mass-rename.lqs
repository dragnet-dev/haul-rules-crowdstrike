// Dragnet [Ransomware]: dragnet-ransomware-2023-5119 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: f294f08d-e4c5-56f5-9c8f-e6abbd519ebc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
