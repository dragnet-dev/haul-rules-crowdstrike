// Dragnet [Ransomware]: dragnet-ransomware-2024-2497 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: d2e38c51-7794-59fb-8240-dbec38d4a947

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
