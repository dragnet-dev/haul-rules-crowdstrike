// Dragnet [Ransomware]: dragnet-ransomware-2023-0835 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 2b8ef415-ed48-5fdf-8c3f-39737d2c1ded

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
