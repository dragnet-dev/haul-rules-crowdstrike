// Dragnet [Ransomware]: dragnet-ransomware-2025-5829 — Mass File Rename (anubis)
// Status: experimental | Level: high | ID: 8ff25438-c31d-5211-ab6b-c05f5a493ffa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
