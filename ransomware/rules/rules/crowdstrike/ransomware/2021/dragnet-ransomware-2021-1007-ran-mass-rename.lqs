// Dragnet [Ransomware]: dragnet-ransomware-2021-1007 — Mass File Rename (azroteam)
// Status: deprecated | Level: high | ID: 47d785aa-29a3-50e1-91e9-cab5108596bc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
