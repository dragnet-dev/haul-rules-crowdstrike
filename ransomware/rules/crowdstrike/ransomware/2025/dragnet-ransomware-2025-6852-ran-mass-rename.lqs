// Dragnet [Ransomware]: dragnet-ransomware-2025-6852 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 59d82330-2be1-5ce6-890b-0ecd43764fbe

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
