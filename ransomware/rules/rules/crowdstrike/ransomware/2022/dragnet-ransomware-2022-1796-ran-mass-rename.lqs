// Dragnet [Ransomware]: dragnet-ransomware-2022-1796 — Mass File Rename (ragnarlocker)
// Status: deprecated | Level: high | ID: 849aaa8a-a315-5365-9630-9cfbca06b0e3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
