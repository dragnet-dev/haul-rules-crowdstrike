// Dragnet [Ransomware]: dragnet-ransomware-2022-2344 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: b5b53f54-ff7f-5dc4-b43b-a93368ecc931

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
