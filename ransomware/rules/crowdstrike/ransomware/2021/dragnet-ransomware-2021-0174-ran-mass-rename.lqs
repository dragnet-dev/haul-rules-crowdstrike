// Dragnet [Ransomware]: dragnet-ransomware-2021-0174 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 30d534eb-eea2-5763-bba6-555c6ccba042

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
