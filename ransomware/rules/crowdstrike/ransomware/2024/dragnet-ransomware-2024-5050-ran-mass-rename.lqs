// Dragnet [Ransomware]: dragnet-ransomware-2024-5050 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 847fe439-1b25-5a6b-8bc7-d5cdbcf44513

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
