// Dragnet [Ransomware]: dragnet-ransomware-2025-2390 — Mass File Rename (incransom)
// Status: test | Level: high | ID: d6ac0c98-1b87-5f1e-bf2f-b63258ed503d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
