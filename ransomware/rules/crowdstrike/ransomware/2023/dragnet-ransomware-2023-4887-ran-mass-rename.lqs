// Dragnet [Ransomware]: dragnet-ransomware-2023-4887 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: c8ff23cd-ae41-593c-84d2-765053c508e3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
