// Dragnet [Ransomware]: dragnet-ransomware-2023-2753 — Mass File Rename (malas)
// Status: experimental | Level: high | ID: c90beb33-4308-556f-ac77-14cc32bfc601

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
