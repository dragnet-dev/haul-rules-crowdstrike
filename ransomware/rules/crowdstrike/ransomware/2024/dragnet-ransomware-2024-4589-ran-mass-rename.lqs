// Dragnet [Ransomware]: dragnet-ransomware-2024-4589 — Mass File Rename (qilin)
// Status: deprecated | Level: high | ID: 9dfcaff7-88ca-533d-9c45-576c3d2fd565

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
