// Dragnet [Ransomware]: dragnet-ransomware-2024-4255 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: da6fa2eb-f487-5c9e-8c61-9556efa1defa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
