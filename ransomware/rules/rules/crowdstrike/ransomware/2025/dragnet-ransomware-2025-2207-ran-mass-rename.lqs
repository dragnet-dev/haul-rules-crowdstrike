// Dragnet [Ransomware]: dragnet-ransomware-2025-2207 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: c43f6611-b004-5a8b-a7b6-1c332bccd2f7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
