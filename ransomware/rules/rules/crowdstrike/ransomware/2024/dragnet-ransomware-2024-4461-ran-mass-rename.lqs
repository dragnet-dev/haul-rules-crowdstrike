// Dragnet [Ransomware]: dragnet-ransomware-2024-4461 — Mass File Rename (safepay)
// Status: deprecated | Level: high | ID: 2155414c-4510-5cec-a518-1eaf70600582

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
