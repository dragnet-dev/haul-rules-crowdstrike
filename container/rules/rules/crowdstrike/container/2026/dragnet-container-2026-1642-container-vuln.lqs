// Dragnet [Container]: dragnet-container-2026-1642 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: c677f487-843b-521e-b0e9-8e8f6cfdb4a8

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
