// Dragnet [Ransomware]: dragnet-ransomware-2026-0718 — Mass File Rename (incransom)
// Status: test | Level: high | ID: bb61d302-2310-50d7-947f-b929fba400f1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
