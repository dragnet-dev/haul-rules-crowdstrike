// Dragnet [Ransomware]: dragnet-ransomware-2022-0953 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: acb34f41-f160-5545-b102-31ff77e90bfc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
