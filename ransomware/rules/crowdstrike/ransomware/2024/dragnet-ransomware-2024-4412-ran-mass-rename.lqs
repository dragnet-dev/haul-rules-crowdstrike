// Dragnet [Ransomware]: dragnet-ransomware-2024-4412 — Mass File Rename (raworld)
// Status: experimental | Level: high | ID: 47749c3b-de8a-5577-b284-c35d11c8e6b0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
