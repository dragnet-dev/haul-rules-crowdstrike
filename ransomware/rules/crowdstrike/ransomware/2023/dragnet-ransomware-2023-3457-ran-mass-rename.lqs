// Dragnet [Ransomware]: dragnet-ransomware-2023-3457 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: dd33df7e-6b4f-5b03-8093-5b421ee485ec

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
