// Dragnet [Ransomware]: dragnet-ransomware-2025-3589 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 7c6cab70-d108-5cb3-8f68-90d1aae20eb9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
