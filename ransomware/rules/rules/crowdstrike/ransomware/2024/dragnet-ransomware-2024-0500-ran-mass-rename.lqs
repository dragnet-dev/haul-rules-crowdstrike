// Dragnet [Ransomware]: dragnet-ransomware-2024-0500 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: d11597a3-3f57-5e86-bdfe-6c565d42de08

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
