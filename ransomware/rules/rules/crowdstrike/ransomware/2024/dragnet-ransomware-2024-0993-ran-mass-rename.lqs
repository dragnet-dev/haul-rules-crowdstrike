// Dragnet [Ransomware]: dragnet-ransomware-2024-0993 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 986b9516-7d4e-5934-8296-b5a2caf152a5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
