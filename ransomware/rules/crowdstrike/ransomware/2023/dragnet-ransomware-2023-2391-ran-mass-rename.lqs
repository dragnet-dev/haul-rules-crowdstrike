// Dragnet [Ransomware]: dragnet-ransomware-2023-2391 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: a16402b8-3982-542f-8b65-5a506799c882

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
