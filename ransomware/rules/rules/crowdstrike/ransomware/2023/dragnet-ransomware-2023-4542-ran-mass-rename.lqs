// Dragnet [Ransomware]: dragnet-ransomware-2023-4542 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 6ec14d46-7e85-50b5-b35e-8af412d976e0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
