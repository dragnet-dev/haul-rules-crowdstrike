// Dragnet [Ransomware]: dragnet-ransomware-2025-3365 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 84f8b65a-8231-5996-9987-4854830cc1d2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
