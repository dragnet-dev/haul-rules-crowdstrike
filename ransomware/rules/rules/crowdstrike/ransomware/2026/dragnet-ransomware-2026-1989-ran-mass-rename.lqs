// Dragnet [Ransomware]: dragnet-ransomware-2026-1989 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: cd2e815e-1da1-5535-99d8-c7d6337d5937

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
