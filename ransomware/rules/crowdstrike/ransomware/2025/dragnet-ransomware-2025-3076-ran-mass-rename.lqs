// Dragnet [Ransomware]: dragnet-ransomware-2025-3076 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: acc032b8-e823-5890-9fc7-a747dfef3efa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
