// Dragnet [Ransomware]: dragnet-ransomware-2021-0277 — Mass File Rename (phoenixcryptolocker)
// Status: deprecated | Level: high | ID: ae4fdec8-1e21-5edd-8003-f06c83456bbd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
