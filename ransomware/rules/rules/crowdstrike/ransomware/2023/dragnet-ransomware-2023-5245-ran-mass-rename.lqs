// Dragnet [Ransomware]: dragnet-ransomware-2023-5245 — Mass File Rename (blacklock)
// Status: experimental | Level: high | ID: 5a1f8f06-0caf-52fb-a90d-9175dd7759ba

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
