// Dragnet [Ransomware]: dragnet-ransomware-2025-2611 — Mass File Rename (weyhro)
// Status: experimental | Level: high | ID: b4c11b2e-5515-5f79-ae26-e896eb0cda4d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
