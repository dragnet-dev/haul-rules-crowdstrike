// Dragnet [Container]: dragnet-container-2024-0013 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 36abb012-3f80-5a67-baaa-da00e00faba8

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:9* OR ImageFileName = *photon os:3.0* OR ImageFileName = *ubuntu:18.04* OR ImageFileName = *ubuntu:18.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
