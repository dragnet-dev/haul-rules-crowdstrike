// Dragnet [Ransomware]: dragnet-ransomware-2023-2994 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: ffa35610-1b25-5d72-a623-f0ba5bbaedc4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
