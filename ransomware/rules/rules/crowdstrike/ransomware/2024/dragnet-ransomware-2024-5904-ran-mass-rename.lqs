// Dragnet [Ransomware]: dragnet-ransomware-2024-5904 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 0957930b-9179-55d4-9bfb-612a7d82299d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
