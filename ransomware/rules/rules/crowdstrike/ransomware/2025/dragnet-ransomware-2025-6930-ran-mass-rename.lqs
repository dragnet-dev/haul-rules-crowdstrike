// Dragnet [Ransomware]: dragnet-ransomware-2025-6930 — Mass File Rename (kraken)
// Status: experimental | Level: high | ID: 6b67584f-5299-5f69-9db5-9aec4aa515d4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
