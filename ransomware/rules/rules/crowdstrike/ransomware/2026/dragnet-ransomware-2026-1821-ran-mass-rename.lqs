// Dragnet [Ransomware]: dragnet-ransomware-2026-1821 — Mass File Rename (dragonforce)
// Status: stable | Level: high | ID: dde92e0a-5f12-54e8-8a57-d519241116dc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
