// Dragnet [Ransomware]: dragnet-ransomware-2024-5992 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: c3c580c8-31ac-58c8-a1ab-b1f52f7ad4bb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
