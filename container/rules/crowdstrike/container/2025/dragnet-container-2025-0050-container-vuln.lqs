// Dragnet [Container]: dragnet-container-2025-0050 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: d7a814cf-8ac3-50c0-b4c5-cf6f8cdf08de

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
