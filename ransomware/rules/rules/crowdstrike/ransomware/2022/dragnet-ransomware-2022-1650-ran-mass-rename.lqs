// Dragnet [Ransomware]: dragnet-ransomware-2022-1650 — Mass File Rename (snatch)
// Status: deprecated | Level: high | ID: 764c4220-f377-5090-8b68-b39b7ba55780

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
