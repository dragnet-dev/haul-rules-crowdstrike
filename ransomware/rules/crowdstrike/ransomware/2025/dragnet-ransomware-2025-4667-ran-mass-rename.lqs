// Dragnet [Ransomware]: dragnet-ransomware-2025-4667 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: cf3342d8-04a2-5464-9406-40ab5485c747

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
