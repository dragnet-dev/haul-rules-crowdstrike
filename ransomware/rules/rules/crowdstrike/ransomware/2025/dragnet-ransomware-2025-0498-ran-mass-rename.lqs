// Dragnet [Ransomware]: dragnet-ransomware-2025-0498 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 73012930-b40d-5252-8a99-c3cb76be0536

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
