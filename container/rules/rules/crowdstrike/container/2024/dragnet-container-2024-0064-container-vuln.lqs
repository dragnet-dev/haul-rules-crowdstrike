// Dragnet [Container]: dragnet-container-2024-0064 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: b5dbdf23-59a2-5965-bed0-2e8b65e6784f

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *ubuntu:20.04-ESM* OR ImageFileName = *ubuntu:22.04*)
| table([timestamp, ComputerName])
| limit(1000)
