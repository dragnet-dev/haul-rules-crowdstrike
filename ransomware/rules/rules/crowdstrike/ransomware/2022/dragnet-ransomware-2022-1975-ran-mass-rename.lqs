// Dragnet [Ransomware]: dragnet-ransomware-2022-1975 — Mass File Rename (cuba)
// Status: deprecated | Level: high | ID: cc1399ed-c6df-53ba-8607-10166e297c7a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
