// Dragnet [Ransomware]: dragnet-ransomware-2023-3226 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 1d92e917-d437-5139-bf02-6f4729842810

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
