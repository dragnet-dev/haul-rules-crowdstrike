// Dragnet [Ransomware]: dragnet-ransomware-2025-5996 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 5fed164b-912d-58f0-9fde-0da3add78712

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
