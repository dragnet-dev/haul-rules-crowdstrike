// Dragnet [Container]: dragnet-container-2026-1874 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: b12adb82-cd4c-5ee0-a38f-28524eafaf42

#event_simpleName=*
| (ImageFileName = *chainguard:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
