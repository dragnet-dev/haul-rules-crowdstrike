// Dragnet [Ransomware]: dragnet-ransomware-2023-3428 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 6ede3ed8-687e-5162-b07f-91b9de5506b4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
