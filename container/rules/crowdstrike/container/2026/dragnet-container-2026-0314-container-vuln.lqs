// Dragnet [Container]: dragnet-container-2026-0314 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 89365d54-49dc-5c12-b468-f8b32b5669e5

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:7* OR ImageFileName = *debian:8* OR ImageFileName = *ubuntu:18.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
