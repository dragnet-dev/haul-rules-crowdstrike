// Dragnet [Ransomware]: dragnet-ransomware-2023-2510 — Mass File Rename (trigona)
// Status: experimental | Level: high | ID: 734694e7-9731-57a2-a674-2e6db12b2c06

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
