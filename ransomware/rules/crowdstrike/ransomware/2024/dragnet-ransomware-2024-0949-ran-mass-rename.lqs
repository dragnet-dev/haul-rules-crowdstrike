// Dragnet [Ransomware]: dragnet-ransomware-2024-0949 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: 1d9f65ff-88be-51f5-89d6-7c3aafad7caa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
