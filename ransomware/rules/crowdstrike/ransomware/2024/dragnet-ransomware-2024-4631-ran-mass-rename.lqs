// Dragnet [Ransomware]: dragnet-ransomware-2024-4631 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 468e1deb-7fdf-5b4e-a272-5af0f14d7f50

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
