// Dragnet [Ransomware]: dragnet-ransomware-2025-4060 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: f75740ab-356e-505a-afdc-907daf8fb1a0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
