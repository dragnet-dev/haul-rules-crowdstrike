// Dragnet [Ransomware]: dragnet-ransomware-2026-2340 — Mass File Rename (handala)
// Status: stable | Level: high | ID: 706a86fb-4f99-5e2c-91ec-cee273f1c238

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
