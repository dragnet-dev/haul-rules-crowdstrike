// Dragnet [Ransomware]: dragnet-ransomware-2026-2563 — Mass File Rename (nightspire)
// Status: deprecated | Level: high | ID: b5490d15-b080-588b-b22e-e250af09309c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
