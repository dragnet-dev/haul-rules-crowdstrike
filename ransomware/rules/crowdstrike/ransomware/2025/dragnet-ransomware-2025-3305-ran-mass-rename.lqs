// Dragnet [Ransomware]: dragnet-ransomware-2025-3305 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: 58cf1969-d3ec-575d-a511-aaa359bddafc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
