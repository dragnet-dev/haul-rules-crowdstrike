// Dragnet [Ransomware]: dragnet-ransomware-2024-0086 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: bcf3a0e1-a19d-5433-abcb-aab59fb899a0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
