// Dragnet [Container]: dragnet-container-2024-0089 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 98209097-4892-5960-9880-1be71f95da14

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *ubuntu:22.04*)
| table([timestamp, ComputerName])
| limit(1000)
