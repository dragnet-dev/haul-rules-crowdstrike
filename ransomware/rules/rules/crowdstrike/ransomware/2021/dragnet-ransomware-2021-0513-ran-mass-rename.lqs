// Dragnet [Ransomware]: dragnet-ransomware-2021-0513 — Mass File Rename (groove)
// Status: deprecated | Level: high | ID: aa093db6-95c6-5466-8908-75a3be3daa1c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
