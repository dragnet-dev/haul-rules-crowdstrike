// Dragnet [Ransomware]: dragnet-ransomware-2022-0512 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: af9406c5-0362-51c9-95a7-07fd84c2aad2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
