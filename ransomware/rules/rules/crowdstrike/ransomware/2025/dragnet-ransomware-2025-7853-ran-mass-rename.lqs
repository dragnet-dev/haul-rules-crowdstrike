// Dragnet [Ransomware]: dragnet-ransomware-2025-7853 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 64d437f3-408a-5d81-ac9a-25a5d61561c5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
