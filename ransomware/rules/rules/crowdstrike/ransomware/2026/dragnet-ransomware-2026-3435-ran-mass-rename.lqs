// Dragnet [Ransomware]: dragnet-ransomware-2026-3435 — Mass File Rename (safepay)
// Status: stable | Level: high | ID: d808e889-1842-54b6-a43d-2197f30f793e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
