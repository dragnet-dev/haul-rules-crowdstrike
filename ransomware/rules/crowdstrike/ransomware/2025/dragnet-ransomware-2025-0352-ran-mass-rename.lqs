// Dragnet [Ransomware]: dragnet-ransomware-2025-0352 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: d4793fcb-5963-50f1-99fc-2de81178bf75

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
