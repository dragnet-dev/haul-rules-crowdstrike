// Dragnet [Ransomware]: dragnet-ransomware-2025-6677 — Mass File Rename (cicada3301)
// Status: experimental | Level: high | ID: 06670c16-e930-53ba-b6fe-d4564bc5c714

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
