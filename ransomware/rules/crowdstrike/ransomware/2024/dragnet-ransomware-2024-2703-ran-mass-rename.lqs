// Dragnet [Ransomware]: dragnet-ransomware-2024-2703 — Mass File Rename (play)
// Status: experimental | Level: high | ID: e724dc94-b9c0-5a2c-8b33-0b5d39e173c8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
