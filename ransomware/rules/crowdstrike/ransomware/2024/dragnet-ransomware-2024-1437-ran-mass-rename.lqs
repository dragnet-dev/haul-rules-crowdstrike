// Dragnet [Ransomware]: dragnet-ransomware-2024-1437 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 569f259a-d955-5808-a538-79ab6403147f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
