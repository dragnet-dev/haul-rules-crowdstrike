// Dragnet [Ransomware]: dragnet-ransomware-2024-1192 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: bd437437-e1b1-5ef7-a93e-81205df79547

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
