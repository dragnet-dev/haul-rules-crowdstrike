// Dragnet [Ransomware]: dragnet-ransomware-2025-5634 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: d8d31dee-e095-5fe8-8d52-1602bb61a8ce

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
