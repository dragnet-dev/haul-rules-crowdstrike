// Dragnet [Ransomware]: dragnet-ransomware-2025-7878 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 445c33f0-639d-5f85-bf66-0792dc885091

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
