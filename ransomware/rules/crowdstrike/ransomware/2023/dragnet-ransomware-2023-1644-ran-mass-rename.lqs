// Dragnet [Ransomware]: dragnet-ransomware-2023-1644 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 99437050-e062-5fa9-9def-df5a8bca9f60

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
