// Dragnet [Ransomware]: dragnet-ransomware-2024-6027 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: ffb7bf1f-933f-5929-8531-d51584ba28b3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
