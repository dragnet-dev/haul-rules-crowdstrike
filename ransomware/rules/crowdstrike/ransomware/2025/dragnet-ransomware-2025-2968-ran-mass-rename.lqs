// Dragnet [Ransomware]: dragnet-ransomware-2025-2968 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 1b064947-8f5d-5d6d-956a-4f2e9b8842b2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
