// Dragnet [Ransomware]: dragnet-ransomware-2025-5956 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 816ae25e-8a3e-5cde-97ce-26618e6f34c6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
