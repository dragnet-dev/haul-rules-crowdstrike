// Dragnet [Ransomware]: dragnet-ransomware-2020-0063 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 8b8e5c23-9d08-5a9e-9a38-fed5bd9305d7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
