// Dragnet [Ransomware]: dragnet-ransomware-2025-6388 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: 3eb1440d-4e99-5bbb-b4a9-2a76be3b8b2d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
