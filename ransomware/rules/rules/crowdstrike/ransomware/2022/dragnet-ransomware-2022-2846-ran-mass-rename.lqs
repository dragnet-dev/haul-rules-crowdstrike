// Dragnet [Ransomware]: dragnet-ransomware-2022-2846 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 725d08c3-9a46-53a1-b0ca-bfdceb117745

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
