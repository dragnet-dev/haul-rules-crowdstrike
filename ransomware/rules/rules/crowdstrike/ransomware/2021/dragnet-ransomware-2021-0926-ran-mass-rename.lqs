// Dragnet [Ransomware]: dragnet-ransomware-2021-0926 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: ce9e82d9-a85b-5f9f-9a78-857f90444848

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
