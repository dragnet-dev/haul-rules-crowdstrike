// Dragnet [Ransomware]: dragnet-ransomware-2025-2815 — Mass File Rename (warlock)
// Status: experimental | Level: high | ID: a5a35662-f179-5e7f-ac6f-c013850c7e12

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
