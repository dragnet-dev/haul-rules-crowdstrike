// Dragnet [Ransomware]: dragnet-ransomware-2023-3955 — Mass File Rename (knight)
// Status: experimental | Level: high | ID: a933d772-d7be-5a88-92f9-5b8e8793f84b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
