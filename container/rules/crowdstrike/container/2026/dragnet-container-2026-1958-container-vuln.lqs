// Dragnet [Container]: dragnet-container-2026-1958 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 49846e71-9a79-51ac-b7b7-8e5a4563f4c6

#event_simpleName=*
| (ImageFileName = *amazonlinux:2* OR ImageFileName = *chainguard:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:22.04* OR ImageFileName = *ubuntu:24.04* OR ImageFileName = *ubuntu:24.10*)
| table([timestamp, ComputerName])
| limit(1000)
