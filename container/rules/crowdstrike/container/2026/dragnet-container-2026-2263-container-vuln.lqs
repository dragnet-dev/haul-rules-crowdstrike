// Dragnet [Container]: dragnet-container-2026-2263 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 20d883fc-c6a8-55af-bb5e-d4f20f53bd5b

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:8* OR ImageFileName = *ubuntu:15.10*)
| table([timestamp, ComputerName])
| limit(1000)
