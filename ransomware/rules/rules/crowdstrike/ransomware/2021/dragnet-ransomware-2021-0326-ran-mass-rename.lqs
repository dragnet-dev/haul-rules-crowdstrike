// Dragnet [Ransomware]: dragnet-ransomware-2021-0326 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 10c7f20f-47b3-5e97-88ad-f275afe60bcf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
