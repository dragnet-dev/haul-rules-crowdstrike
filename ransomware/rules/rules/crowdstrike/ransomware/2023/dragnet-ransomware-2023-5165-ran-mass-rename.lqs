// Dragnet [Ransomware]: dragnet-ransomware-2023-5165 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 6bc8f481-7c56-5ce8-9989-569343bc3d69

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
