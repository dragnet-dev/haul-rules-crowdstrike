// Dragnet [Ransomware]: dragnet-ransomware-2025-3199 — Mass File Rename (coinbasecartel)
// Status: experimental | Level: high | ID: 7845983e-ab13-58ef-995d-47bbb05b947a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
