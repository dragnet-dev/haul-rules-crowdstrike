// Dragnet [Ransomware]: dragnet-ransomware-2025-7336 — Mass File Rename (morpheus)
// Status: deprecated | Level: high | ID: 45dd279c-e06b-5257-9c95-e8247b719d8f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
