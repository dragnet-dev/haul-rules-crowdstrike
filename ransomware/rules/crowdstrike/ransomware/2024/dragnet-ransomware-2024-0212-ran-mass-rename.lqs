// Dragnet [Ransomware]: dragnet-ransomware-2024-0212 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 1a6e9f30-f1e8-58b3-957e-c9ef3980be95

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
