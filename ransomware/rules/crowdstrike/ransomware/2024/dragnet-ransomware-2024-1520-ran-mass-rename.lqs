// Dragnet [Ransomware]: dragnet-ransomware-2024-1520 — Mass File Rename (play)
// Status: experimental | Level: high | ID: d2447f2c-4efd-5ca7-9b88-5ded78a5b5e1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
