// Dragnet [Ransomware]: dragnet-ransomware-2022-2449 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 83161a82-1a17-5db2-8033-a6643449bfd2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
