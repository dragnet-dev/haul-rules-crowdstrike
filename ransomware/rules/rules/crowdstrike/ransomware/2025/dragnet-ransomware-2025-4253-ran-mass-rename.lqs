// Dragnet [Ransomware]: dragnet-ransomware-2025-4253 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: cce6c3b6-0c9f-587b-a262-7f212ae7d4d6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
