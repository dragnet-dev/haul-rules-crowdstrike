// Dragnet [Ransomware]: dragnet-ransomware-2021-1363 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 248ec3b9-6cf8-5729-9cf9-b8b57a6828f0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
