// Dragnet [Ransomware]: dragnet-ransomware-2023-2638 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 1979c5ae-5448-53a2-9588-dd7cfdd6ae51

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
