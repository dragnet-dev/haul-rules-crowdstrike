// Dragnet [Ransomware]: dragnet-ransomware-2023-5192 — Mass File Rename (trigona)
// Status: deprecated | Level: high | ID: 1a2b4aa6-9cbb-52c5-baca-fef2d21a456a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
