// Dragnet [Ransomware]: dragnet-ransomware-2023-4139 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: cd8ce813-aa83-55b8-b9a4-4ddd1106b5d1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
