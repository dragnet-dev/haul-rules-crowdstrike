// Dragnet [Ransomware]: dragnet-ransomware-2022-1893 — Mass File Rename (ransomexx)
// Status: experimental | Level: high | ID: 84b6783c-3685-5920-80c8-f193892a5be0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
