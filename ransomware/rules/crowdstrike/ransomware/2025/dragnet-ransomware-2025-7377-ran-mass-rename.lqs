// Dragnet [Ransomware]: dragnet-ransomware-2025-7377 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 71a35e68-9880-5415-ad4c-0febef00e4e5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
