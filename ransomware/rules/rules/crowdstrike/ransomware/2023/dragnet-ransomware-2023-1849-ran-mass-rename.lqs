// Dragnet [Ransomware]: dragnet-ransomware-2023-1849 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: b7642bc5-3c6a-576c-ac26-056aa91352a2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
