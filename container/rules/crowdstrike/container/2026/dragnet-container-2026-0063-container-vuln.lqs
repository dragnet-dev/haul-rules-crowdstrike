// Dragnet [Container]: dragnet-container-2026-0063 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 44007e74-c43a-5b0e-947c-1c6dbfd27928

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
