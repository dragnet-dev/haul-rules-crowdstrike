// Dragnet [Ransomware]: dragnet-ransomware-2023-2527 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 927dd285-c736-555b-8a52-937fa788d643

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
