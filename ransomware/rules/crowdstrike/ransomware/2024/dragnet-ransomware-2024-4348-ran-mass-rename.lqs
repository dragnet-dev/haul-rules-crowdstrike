// Dragnet [Ransomware]: dragnet-ransomware-2024-4348 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 3395900e-11a1-5a2f-972e-7493e7b3231e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
