// Dragnet [Ransomware]: dragnet-ransomware-2023-0393 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 21fd5f4d-07ea-564d-ba8d-9ab3f9780002

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
