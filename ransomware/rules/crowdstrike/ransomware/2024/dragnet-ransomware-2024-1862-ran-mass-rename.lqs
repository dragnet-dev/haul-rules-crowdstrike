// Dragnet [Ransomware]: dragnet-ransomware-2024-1862 — Mass File Rename (arcusmedia)
// Status: experimental | Level: high | ID: b57e00f7-b048-5121-ae08-5dad45b32f90

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
