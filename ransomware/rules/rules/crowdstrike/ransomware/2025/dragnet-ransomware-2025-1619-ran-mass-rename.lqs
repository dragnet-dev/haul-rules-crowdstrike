// Dragnet [Ransomware]: dragnet-ransomware-2025-1619 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: e09b62f0-0bd8-5cb2-923a-39969fb3640e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
