// Dragnet [Ransomware]: dragnet-ransomware-2024-4913 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 4ce171d3-3fc5-5b92-bf05-7736936c2fb9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
