// Dragnet [Ransomware]: dragnet-ransomware-2026-1147 — Mass File Rename (thegentlemen)
// Status: stable | Level: high | ID: a2faee0d-3f70-56e4-b23e-530bdab2e7f6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
