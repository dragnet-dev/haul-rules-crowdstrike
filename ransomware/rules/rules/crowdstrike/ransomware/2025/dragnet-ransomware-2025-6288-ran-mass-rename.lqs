// Dragnet [Ransomware]: dragnet-ransomware-2025-6288 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 150f4677-c4dc-5375-95a5-aa4a94cebedb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
