// Dragnet [Container]: dragnet-container-2026-0697 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: f74faec5-073f-596b-9d0b-2adbe1de2e55

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:5*)
| table([timestamp, ComputerName])
| limit(1000)
