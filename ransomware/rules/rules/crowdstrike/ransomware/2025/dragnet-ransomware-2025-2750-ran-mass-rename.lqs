// Dragnet [Ransomware]: dragnet-ransomware-2025-2750 — Mass File Rename (teamxxx)
// Status: experimental | Level: high | ID: f7bef792-8e1a-5a4a-a364-ff9dedc168a4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
