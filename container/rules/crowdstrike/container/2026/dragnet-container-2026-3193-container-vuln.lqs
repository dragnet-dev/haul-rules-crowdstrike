// Dragnet [Container]: dragnet-container-2026-3193 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 787bbe25-aa14-5381-8d98-9c5958ff4ee2

#event_simpleName=*
| (ImageFileName = *alpine edge:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:24.04* OR ImageFileName = *ubuntu:25.10* OR ImageFileName = *ubuntu:26.04*)
| table([timestamp, ComputerName])
| limit(1000)
