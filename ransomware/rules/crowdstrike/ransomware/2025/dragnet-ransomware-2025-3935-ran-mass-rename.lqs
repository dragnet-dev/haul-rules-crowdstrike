// Dragnet [Ransomware]: dragnet-ransomware-2025-3935 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 90336a5d-1fe5-5893-8bd7-139302136ec5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
