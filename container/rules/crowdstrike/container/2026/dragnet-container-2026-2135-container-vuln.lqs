// Dragnet [Container]: dragnet-container-2026-2135 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 89db9247-14da-59bd-b810-99b688a26809

#event_simpleName=*
| (ImageFileName = *debian:7* OR ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10* OR ImageFileName = *ubuntu:13.04*)
| table([timestamp, ComputerName])
| limit(1000)
