// Dragnet [Ransomware]: dragnet-ransomware-2025-1329 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: 0cdf3a6a-30f6-5012-9286-ce5ef47deb91

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
