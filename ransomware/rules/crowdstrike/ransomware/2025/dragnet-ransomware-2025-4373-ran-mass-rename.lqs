// Dragnet [Ransomware]: dragnet-ransomware-2025-4373 — Mass File Rename (interlock)
// Status: experimental | Level: high | ID: b152b64b-c853-5776-a622-d66e339c3259

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
