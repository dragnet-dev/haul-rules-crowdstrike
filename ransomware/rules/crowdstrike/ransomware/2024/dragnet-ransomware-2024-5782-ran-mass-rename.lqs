// Dragnet [Ransomware]: dragnet-ransomware-2024-5782 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 7a7181c4-9b13-57c7-b19b-79ee64e55621

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
