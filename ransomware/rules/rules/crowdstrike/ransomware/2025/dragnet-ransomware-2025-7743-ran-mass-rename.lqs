// Dragnet [Ransomware]: dragnet-ransomware-2025-7743 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 2e74e793-b7be-5534-89b3-10aa64bc0633

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
