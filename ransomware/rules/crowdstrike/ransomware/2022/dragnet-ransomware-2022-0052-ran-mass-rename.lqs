// Dragnet [Ransomware]: dragnet-ransomware-2022-0052 — Mass File Rename (lorenz)
// Status: deprecated | Level: high | ID: 29dc2c49-7b07-5af1-9df1-73f9e071e16f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
