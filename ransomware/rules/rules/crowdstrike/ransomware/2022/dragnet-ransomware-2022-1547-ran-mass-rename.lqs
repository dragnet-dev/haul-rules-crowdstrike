// Dragnet [Ransomware]: dragnet-ransomware-2022-1547 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 7cc76196-6df7-552f-8e86-9a2e03eff4a7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
