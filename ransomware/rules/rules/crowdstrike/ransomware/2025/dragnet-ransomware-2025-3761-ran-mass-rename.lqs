// Dragnet [Ransomware]: dragnet-ransomware-2025-3761 — Mass File Rename (shinyhunters)
// Status: experimental | Level: high | ID: a1e961b3-7ad2-5a53-a2bc-8ae2b0536e38

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
