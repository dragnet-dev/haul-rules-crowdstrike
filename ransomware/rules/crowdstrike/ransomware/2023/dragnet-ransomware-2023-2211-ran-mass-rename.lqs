// Dragnet [Ransomware]: dragnet-ransomware-2023-2211 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 061c0845-96a9-5592-a45d-1d3e7d4717fc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
