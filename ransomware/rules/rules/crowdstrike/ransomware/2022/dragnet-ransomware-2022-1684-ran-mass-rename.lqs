// Dragnet [Ransomware]: dragnet-ransomware-2022-1684 — Mass File Rename (ransomhouse)
// Status: deprecated | Level: high | ID: 46f5239a-bc5b-5328-ad80-abc704c3db17

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
