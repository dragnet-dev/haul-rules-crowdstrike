// Dragnet [Ransomware]: dragnet-ransomware-2025-7728 — Mass File Rename (spacebears)
// Status: experimental | Level: high | ID: 3d298a3f-7851-5096-b798-1cebea38789f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
