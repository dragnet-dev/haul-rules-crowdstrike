// Dragnet [Ransomware]: dragnet-ransomware-2020-0194 — Mass File Rename (doppelpaymer)
// Status: deprecated | Level: high | ID: ac36128c-1965-5f30-80f1-034c6e3fedd5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
