// Dragnet [Container]: dragnet-container-2026-1352 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 1fcf5d94-a021-5edf-b648-f17a1756a9d9

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:7* OR ImageFileName = *oraclelinux:7* OR ImageFileName = *ubuntu:17.04*)
| table([timestamp, ComputerName])
| limit(1000)
