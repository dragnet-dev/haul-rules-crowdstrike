// Dragnet [Ransomware]: dragnet-ransomware-2023-2166 — Mass File Rename (losttrust)
// Status: deprecated | Level: high | ID: 8df7b768-b125-5518-8891-f4e4474bbc67

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
