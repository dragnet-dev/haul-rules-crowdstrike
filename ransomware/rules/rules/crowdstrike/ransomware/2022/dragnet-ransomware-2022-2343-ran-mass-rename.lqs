// Dragnet [Ransomware]: dragnet-ransomware-2022-2343 — Mass File Rename (everest)
// Status: deprecated | Level: high | ID: 426fc218-c3b7-58e8-84ad-727eccd4a3e9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
