// Dragnet [Ransomware]: dragnet-ransomware-2021-1116 — Mass File Rename (revil)
// Status: deprecated | Level: high | ID: 2eb4a72b-4aa4-534a-be05-ae8b94ef2c9c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
