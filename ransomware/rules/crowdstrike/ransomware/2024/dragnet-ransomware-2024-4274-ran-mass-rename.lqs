// Dragnet [Ransomware]: dragnet-ransomware-2024-4274 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 1eed1055-d7e8-528d-a60a-6270a931f179

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
