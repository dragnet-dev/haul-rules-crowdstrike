// Dragnet [Ransomware]: dragnet-ransomware-2024-0148 — Mass File Rename (kairos)
// Status: experimental | Level: high | ID: 09f5d163-68b0-5bdd-ad4e-8e05bd4b06ec

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
