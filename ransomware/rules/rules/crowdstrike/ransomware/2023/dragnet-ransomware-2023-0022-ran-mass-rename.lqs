// Dragnet [Ransomware]: dragnet-ransomware-2023-0022 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: e6833346-4be8-5804-8b22-aa2f9e4ef236

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
