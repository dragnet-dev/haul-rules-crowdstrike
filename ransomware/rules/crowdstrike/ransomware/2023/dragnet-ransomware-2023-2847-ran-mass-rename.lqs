// Dragnet [Ransomware]: dragnet-ransomware-2023-2847 — Mass File Rename (malas)
// Status: experimental | Level: high | ID: 881c4061-3473-5976-afca-ce5e89b3dfa3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
