// Dragnet [Ransomware]: dragnet-ransomware-2021-1513 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: aa87a06c-ff2c-530b-9165-191bcdacf7b5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
