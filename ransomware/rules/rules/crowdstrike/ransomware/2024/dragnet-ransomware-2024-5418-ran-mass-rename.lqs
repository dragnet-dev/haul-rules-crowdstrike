// Dragnet [Ransomware]: dragnet-ransomware-2024-5418 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: c231af55-9819-5bb5-b423-2373de3e0dbb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
