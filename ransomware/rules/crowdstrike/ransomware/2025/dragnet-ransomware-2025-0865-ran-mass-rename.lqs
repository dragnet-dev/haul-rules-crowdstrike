// Dragnet [Ransomware]: dragnet-ransomware-2025-0865 — Mass File Rename (handala)
// Status: experimental | Level: high | ID: 5b49a371-562a-53a6-a0ea-cc6ac112f20a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
