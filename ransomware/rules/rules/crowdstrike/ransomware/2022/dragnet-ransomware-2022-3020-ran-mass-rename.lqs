// Dragnet [Ransomware]: dragnet-ransomware-2022-3020 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: b5a0d5fb-0eaf-5d22-932f-7ea936ccb3a5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
