// Dragnet [Ransomware]: dragnet-ransomware-2022-1907 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 803a5fc0-0cb5-55f1-861a-8f3002418702

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
