// Dragnet [Ransomware]: dragnet-ransomware-2025-7415 — Mass File Rename (nova)
// Status: experimental | Level: high | ID: 9fda02a2-fb9e-52a2-9304-b48e6349616f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
