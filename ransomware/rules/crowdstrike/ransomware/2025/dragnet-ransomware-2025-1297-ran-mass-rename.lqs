// Dragnet [Ransomware]: dragnet-ransomware-2025-1297 — Mass File Rename (warlock)
// Status: deprecated | Level: high | ID: 5205ef30-6e6b-55ce-a5af-c484aa9189e7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
