// Dragnet [Ransomware]: dragnet-ransomware-2024-1935 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: e0ecd398-e771-5c57-8bd0-779ce82738d7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
