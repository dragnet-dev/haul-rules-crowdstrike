// Dragnet [Ransomware]: dragnet-ransomware-2024-2610 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 9e9f1fab-6b35-5324-be90-52c042bc51db

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
