// Dragnet [Ransomware]: dragnet-ransomware-2022-3054 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 5a5ac9de-d6d3-5101-9743-fb9af33f0afa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
