// Dragnet [Ransomware]: dragnet-ransomware-2024-2915 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 0167c106-2627-5d42-a3fc-c30e4b0313de

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
