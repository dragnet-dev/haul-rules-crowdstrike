// Dragnet [Ransomware]: dragnet-ransomware-2025-0238 — Mass File Rename (interlock)
// Status: experimental | Level: high | ID: 43def71c-45bf-5972-afcc-c7f799a90021

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
