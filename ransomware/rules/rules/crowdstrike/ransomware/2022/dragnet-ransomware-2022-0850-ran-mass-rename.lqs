// Dragnet [Ransomware]: dragnet-ransomware-2022-0850 — Mass File Rename (avoslocker)
// Status: deprecated | Level: high | ID: 07f999c9-ccb4-51e6-827a-21bf61d7bdbd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
