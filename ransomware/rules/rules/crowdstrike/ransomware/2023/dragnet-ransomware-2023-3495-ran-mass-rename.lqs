// Dragnet [Ransomware]: dragnet-ransomware-2023-3495 — Mass File Rename (royal)
// Status: experimental | Level: high | ID: b34d09cf-4ba0-5a7d-a529-088f18a12f2c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
