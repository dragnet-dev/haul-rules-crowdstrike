// Dragnet [Ransomware]: dragnet-ransomware-2021-1772 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 2e3c1877-9115-51d1-b4ce-2921b3539f43

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
