// Dragnet [Ransomware]: dragnet-ransomware-2023-1774 — Mass File Rename (trigona)
// Status: experimental | Level: high | ID: 492a377b-63d6-55ff-8c30-354c7e0a2309

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
