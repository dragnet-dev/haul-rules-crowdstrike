// Dragnet [Ransomware]: dragnet-ransomware-2024-0819 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: 6f7144b1-071d-5730-9311-93bb3128b1ae

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
