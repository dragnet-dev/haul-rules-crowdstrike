// Dragnet [Ransomware]: dragnet-ransomware-2021-0315 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 2b445d55-74c6-5bf2-86f6-c4aba7427d50

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
