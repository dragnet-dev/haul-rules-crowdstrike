// Dragnet [Container]: dragnet-container-2026-2652 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 111e3e1b-8b3e-5c1a-9593-95125d86afce

#event_simpleName=*
| (ImageFileName = *almalinux:10* OR ImageFileName = *almalinux:9* OR ImageFileName = *chainguard:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:9* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
