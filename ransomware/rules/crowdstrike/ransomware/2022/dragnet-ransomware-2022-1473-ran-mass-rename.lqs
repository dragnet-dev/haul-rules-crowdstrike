// Dragnet [Ransomware]: dragnet-ransomware-2022-1473 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 3a01001a-0197-5abb-b0bd-f4780dfb187c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
