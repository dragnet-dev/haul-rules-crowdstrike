// Dragnet [Ransomware]: dragnet-ransomware-2023-3147 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 4367dd78-9a11-50c9-ac99-be239d97f97d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
