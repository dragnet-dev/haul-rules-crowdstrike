// Dragnet [Ransomware]: dragnet-ransomware-2025-2767 — Mass File Rename (nitrogen)
// Status: experimental | Level: high | ID: 3f6939fc-d7ff-5be4-848a-4296726b8ce7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
