// Dragnet [Ransomware]: dragnet-ransomware-2024-0022 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: d5ab3fbf-4b82-5cfa-b7cf-8df5e1b92178

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
