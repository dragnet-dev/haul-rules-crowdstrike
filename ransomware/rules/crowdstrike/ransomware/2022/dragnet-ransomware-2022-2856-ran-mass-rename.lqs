// Dragnet [Ransomware]: dragnet-ransomware-2022-2856 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: e7435309-b636-59b1-9f2f-f3727fbe5541

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
