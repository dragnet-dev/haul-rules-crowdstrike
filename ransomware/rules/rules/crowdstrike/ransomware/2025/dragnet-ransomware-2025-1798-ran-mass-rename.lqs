// Dragnet [Ransomware]: dragnet-ransomware-2025-1798 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: a9a24165-d88e-54c5-93d1-e5c835df0ff3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
