// Dragnet [Ransomware]: dragnet-ransomware-2023-4421 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 0d41f9a7-3d77-5e96-8e1b-e2fcc36699f3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
