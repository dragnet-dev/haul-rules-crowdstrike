// Dragnet [Ransomware]: dragnet-ransomware-2025-0949 — Mass File Rename (shinyhunters)
// Status: experimental | Level: high | ID: 8f6906d3-a0e6-5829-a6bd-2e2ee4fe53de

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
