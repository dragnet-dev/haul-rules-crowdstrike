// Dragnet [Ransomware]: dragnet-ransomware-2024-3718 — Mass File Rename (dragonransomware)
// Status: experimental | Level: high | ID: f7f58817-9095-55c0-a5ae-78492cd3285d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
