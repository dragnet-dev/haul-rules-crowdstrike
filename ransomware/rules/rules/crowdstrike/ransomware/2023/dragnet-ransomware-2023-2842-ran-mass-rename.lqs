// Dragnet [Ransomware]: dragnet-ransomware-2023-2842 — Mass File Rename (malas)
// Status: experimental | Level: high | ID: a1fabb65-0cc0-5315-b2c4-e857c6a0666a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
