// Dragnet [Ransomware]: dragnet-ransomware-2025-4603 — Mass File Rename (ciphbit)
// Status: deprecated | Level: high | ID: 9b4e7ef5-44b7-5206-9b5d-6a79c28f0f70

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
