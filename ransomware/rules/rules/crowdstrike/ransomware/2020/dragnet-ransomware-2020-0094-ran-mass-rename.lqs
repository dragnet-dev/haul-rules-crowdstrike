// Dragnet [Ransomware]: dragnet-ransomware-2020-0094 — Mass File Rename (ragnarlocker)
// Status: deprecated | Level: high | ID: 7dc9e1b8-3b72-5d16-96fb-12db05a0fb59

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
