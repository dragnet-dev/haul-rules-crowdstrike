// Dragnet [Ransomware]: dragnet-ransomware-2023-0594 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: a8dc59ee-08e0-56fb-b26c-b5e406f9ff84

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
