// Dragnet [Ransomware]: dragnet-ransomware-2025-7040 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 590c8b52-469a-5c6a-b28b-3e643066c08b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
