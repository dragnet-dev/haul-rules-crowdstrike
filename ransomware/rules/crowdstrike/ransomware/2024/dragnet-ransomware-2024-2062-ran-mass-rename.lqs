// Dragnet [Ransomware]: dragnet-ransomware-2024-2062 — Mass File Rename (apos)
// Status: experimental | Level: high | ID: 8d46f4e3-c41e-5731-87c6-227bbb9cf4d5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
