// Dragnet [Ransomware]: dragnet-ransomware-2025-4582 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: d95a33ff-c6d5-5a98-b300-6f3e5a32ad94

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
