// Dragnet [Ransomware]: dragnet-ransomware-2024-4773 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: 29a6af0a-168f-5ab1-90e3-c50256efabf4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
