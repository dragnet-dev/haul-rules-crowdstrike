// Dragnet [Ransomware]: dragnet-ransomware-2025-5640 — Mass File Rename (rhysida)
// Status: experimental | Level: high | ID: dd8f6401-523e-5b25-97d2-823cfe13380a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
