// Dragnet [Ransomware]: dragnet-ransomware-2024-5477 — Mass File Rename (arcusmedia)
// Status: experimental | Level: high | ID: 572020d0-aaae-5041-81d1-8fd9b20676f0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
