// Dragnet [Ransomware]: dragnet-ransomware-2023-3926 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: 2674d7e5-5c6d-5236-a754-90d3d06fa016

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
