// Dragnet [Ransomware]: dragnet-ransomware-2023-1458 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 653911e5-dfbf-52f5-ab4f-25b7cae62652

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
