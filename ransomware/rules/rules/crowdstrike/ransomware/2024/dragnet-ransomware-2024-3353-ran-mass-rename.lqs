// Dragnet [Ransomware]: dragnet-ransomware-2024-3353 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: bc7932c6-8893-5872-b9fe-a57abacc396e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
