// Dragnet [Ransomware]: dragnet-ransomware-2024-2025 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 6604af7d-2977-5c78-a469-ad61f57114b1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
