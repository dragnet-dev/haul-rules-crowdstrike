// Dragnet [Ransomware]: dragnet-ransomware-2024-5247 — Mass File Rename (trigona)
// Status: experimental | Level: high | ID: b3bec5bf-a9df-5084-95be-049832665d49

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
