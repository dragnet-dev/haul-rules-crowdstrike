// Dragnet [Ransomware]: dragnet-ransomware-2024-1519 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: c9289008-8ff9-5b42-9682-c94711c12458

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
