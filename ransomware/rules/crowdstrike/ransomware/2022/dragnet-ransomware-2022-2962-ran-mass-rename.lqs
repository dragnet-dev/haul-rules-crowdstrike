// Dragnet [Ransomware]: dragnet-ransomware-2022-2962 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: cd86036e-2f7d-5c59-9dd7-19b17296502f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
