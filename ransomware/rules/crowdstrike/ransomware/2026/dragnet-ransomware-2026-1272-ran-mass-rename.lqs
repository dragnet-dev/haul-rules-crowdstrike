// Dragnet [Ransomware]: dragnet-ransomware-2026-1272 — Mass File Rename (lockbit5)
// Status: stable | Level: high | ID: 0cc53111-ad8f-51ff-bd1e-9021eeaa6eaf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
