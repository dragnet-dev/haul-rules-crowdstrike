// Dragnet [Ransomware]: dragnet-ransomware-2025-6614 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 7ffcb11b-12b1-51d7-80ac-06d6ecbdbc67

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
