// Dragnet [Ransomware]: dragnet-ransomware-2023-2016 — Mass File Rename (stormous)
// Status: experimental | Level: high | ID: f02a745b-aaf0-577c-8643-b70257a3dd5b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
