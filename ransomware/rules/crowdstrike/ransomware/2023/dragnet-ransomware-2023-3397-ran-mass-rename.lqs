// Dragnet [Ransomware]: dragnet-ransomware-2023-3397 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: eec393fe-654c-5343-a4f4-a3401fb946f9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
