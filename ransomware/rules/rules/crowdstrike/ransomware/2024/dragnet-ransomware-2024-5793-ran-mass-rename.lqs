// Dragnet [Ransomware]: dragnet-ransomware-2024-5793 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: f2b3c7a6-49d3-5bc3-beda-b48cd892dc8d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
