// Dragnet [Ransomware]: dragnet-ransomware-2025-4640 — Mass File Rename (play)
// Status: experimental | Level: high | ID: f9fa4300-964a-5457-811b-6d9e3e1292b4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
