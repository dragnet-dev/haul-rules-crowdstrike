// Dragnet [Ransomware]: dragnet-ransomware-2022-0027 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: cf441ed8-3780-5a94-8178-15c49cd7c859

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
