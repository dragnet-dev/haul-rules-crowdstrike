// Dragnet [Ransomware]: dragnet-ransomware-2025-0142 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: 94f99935-951a-5478-8fed-1020b73c3deb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
