// Dragnet [Ransomware]: dragnet-ransomware-2024-1286 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 13821c56-7fd8-5a60-9c22-03ea9973bd8f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
