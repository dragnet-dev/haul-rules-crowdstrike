// Dragnet [Ransomware]: dragnet-ransomware-2025-1510 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: c2711eaa-1ca9-5e98-ad44-38a8bf457596

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
