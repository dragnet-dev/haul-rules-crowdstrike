// Dragnet [Ransomware]: dragnet-ransomware-2023-4871 — Mass File Rename (play)
// Status: deprecated | Level: high | ID: 1faf1b4c-195e-5d87-bfa5-2359181400b1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
