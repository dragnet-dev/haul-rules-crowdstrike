// Dragnet [Ransomware]: dragnet-ransomware-2024-3465 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 2193f713-9490-57fe-a4c7-a0b465ce1257

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
