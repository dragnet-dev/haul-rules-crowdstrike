// Dragnet [Ransomware]: dragnet-ransomware-2022-1565 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 6bb2bbc9-6d3a-5684-abb4-dbaae6001d84

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
