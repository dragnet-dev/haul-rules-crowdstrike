// Dragnet [Container]: dragnet-container-2026-2210 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 388b2f0a-2d1d-57d2-8473-bf217111eb4d

#event_simpleName=*
| (ImageFileName = *almalinux:10* OR ImageFileName = *almalinux:8* OR ImageFileName = *almalinux:9* OR ImageFileName = *amazonlinux:2* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *oraclelinux:7* OR ImageFileName = *oraclelinux:8* OR ImageFileName = *oraclelinux:9* OR ImageFileName = *redhat/ubi9:*)
| table([timestamp, ComputerName])
| limit(1000)
