// Dragnet [Ransomware]: dragnet-ransomware-2023-1291 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 1543f49c-669a-5b31-b5b8-1ae8d74c44a0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
