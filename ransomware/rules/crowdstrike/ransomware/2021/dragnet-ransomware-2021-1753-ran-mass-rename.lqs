// Dragnet [Ransomware]: dragnet-ransomware-2021-1753 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: b142cef9-629b-53dd-918b-a9018ded8ff5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
