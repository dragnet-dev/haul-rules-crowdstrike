// Dragnet [Container]: dragnet-container-2024-1504 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 7ef0fd0a-a37e-5ce8-a41a-1ae4354f130b

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *ubuntu:14.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
