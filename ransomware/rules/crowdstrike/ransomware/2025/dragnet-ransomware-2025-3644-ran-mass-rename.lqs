// Dragnet [Ransomware]: dragnet-ransomware-2025-3644 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: c21c5453-0268-5110-b667-c02824ba552a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
