// Dragnet [Ransomware]: dragnet-ransomware-2025-1759 — Mass File Rename (nightspire)
// Status: deprecated | Level: high | ID: db9e8d67-67a1-5c7f-b1d4-a98d2a80d027

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
