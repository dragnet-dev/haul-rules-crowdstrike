// Dragnet [Ransomware]: dragnet-ransomware-2024-4208 — Mass File Rename (ciphbit)
// Status: deprecated | Level: high | ID: c452eca9-3eb9-50a6-af35-8bca547c7ee4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
