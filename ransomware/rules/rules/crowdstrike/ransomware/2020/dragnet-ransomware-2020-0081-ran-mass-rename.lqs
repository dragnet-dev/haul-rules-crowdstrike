// Dragnet [Ransomware]: dragnet-ransomware-2020-0081 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: e13b5813-feec-5c84-a557-348cfaf666bb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
