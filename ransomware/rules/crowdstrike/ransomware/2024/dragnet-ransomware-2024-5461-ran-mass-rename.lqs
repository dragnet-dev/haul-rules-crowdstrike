// Dragnet [Ransomware]: dragnet-ransomware-2024-5461 — Mass File Rename (threeam)
// Status: experimental | Level: high | ID: 0eae50f1-c7c3-5425-9ec4-2c7a4b303d8d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
