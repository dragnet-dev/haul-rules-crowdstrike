// Dragnet [Ransomware]: dragnet-ransomware-2025-6886 — Mass File Rename (flocker)
// Status: experimental | Level: high | ID: e2a0abb1-ff9b-5654-9ca1-6c4e3c67a7d2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
