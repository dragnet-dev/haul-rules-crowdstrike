// Dragnet [Container]: dragnet-container-2024-1073 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 8a507ffe-96c6-5f90-8d81-246c77ebcd58

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
