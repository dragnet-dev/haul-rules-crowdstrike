// Dragnet [Ransomware]: dragnet-ransomware-2025-0157 — Mass File Rename (insomnia)
// Status: experimental | Level: high | ID: b03d4a10-36a2-59ee-87c2-68410e7b2360

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
