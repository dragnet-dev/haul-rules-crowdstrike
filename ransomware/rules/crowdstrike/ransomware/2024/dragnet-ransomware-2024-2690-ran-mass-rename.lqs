// Dragnet [Ransomware]: dragnet-ransomware-2024-2690 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: ed6cd607-f22a-56ca-9962-1d91507a0eea

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
