// Dragnet [Ransomware]: dragnet-ransomware-2021-0687 — Mass File Rename (avaddon)
// Status: deprecated | Level: high | ID: 3a3ac97c-fe33-58f7-b03f-bd13e35567c4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
