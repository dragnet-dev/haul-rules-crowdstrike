// Dragnet [Ransomware]: dragnet-ransomware-2023-0940 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 873f22b6-b8b2-5912-87d4-fa24dfe04f84

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
