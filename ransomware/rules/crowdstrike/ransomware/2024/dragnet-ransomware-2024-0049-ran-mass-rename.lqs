// Dragnet [Ransomware]: dragnet-ransomware-2024-0049 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 18936c97-82df-5765-916a-00de1a409c71

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
