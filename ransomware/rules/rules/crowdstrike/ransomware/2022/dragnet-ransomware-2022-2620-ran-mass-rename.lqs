// Dragnet [Ransomware]: dragnet-ransomware-2022-2620 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 9cd99a4b-5abb-540d-b60c-a53ae0179ac5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
