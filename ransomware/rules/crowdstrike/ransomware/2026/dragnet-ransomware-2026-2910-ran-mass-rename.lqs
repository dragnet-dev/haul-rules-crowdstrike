// Dragnet [Ransomware]: dragnet-ransomware-2026-2910 — Mass File Rename (AiLock)
// Status: deprecated | Level: high | ID: 6a8c4a6f-0c92-50b5-828a-f1d731239367

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
