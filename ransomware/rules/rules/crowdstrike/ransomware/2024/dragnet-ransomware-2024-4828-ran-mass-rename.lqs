// Dragnet [Ransomware]: dragnet-ransomware-2024-4828 — Mass File Rename (flocker)
// Status: experimental | Level: high | ID: d88b1e8d-1b73-5289-9ca6-0cc8c195a918

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
