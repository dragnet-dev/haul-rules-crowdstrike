// Dragnet [Ransomware]: dragnet-ransomware-2023-2463 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 684a3281-b5a9-53f7-a16c-300a971c8307

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
