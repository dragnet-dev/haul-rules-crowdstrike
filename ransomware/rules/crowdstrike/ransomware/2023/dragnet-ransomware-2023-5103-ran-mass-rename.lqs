// Dragnet [Ransomware]: dragnet-ransomware-2023-5103 — Mass File Rename (noescape)
// Status: experimental | Level: high | ID: d65840c5-0d88-5865-9da4-3a94c5477a1e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
