// Dragnet [Ransomware]: dragnet-ransomware-2024-1947 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 6e59986d-8a6b-53b7-a6ec-58833ee7266a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
