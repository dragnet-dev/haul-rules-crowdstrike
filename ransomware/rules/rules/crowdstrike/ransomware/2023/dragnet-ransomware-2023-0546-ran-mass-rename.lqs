// Dragnet [Ransomware]: dragnet-ransomware-2023-0546 — Mass File Rename (dragonforce)
// Status: deprecated | Level: high | ID: e2ecd537-70e2-55bd-87ab-bfb89ee5505b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
