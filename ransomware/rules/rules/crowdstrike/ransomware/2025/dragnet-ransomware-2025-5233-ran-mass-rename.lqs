// Dragnet [Ransomware]: dragnet-ransomware-2025-5233 — Mass File Rename (warlock)
// Status: deprecated | Level: high | ID: f15d1588-52b4-5490-bb83-7cff4abbd8c9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
