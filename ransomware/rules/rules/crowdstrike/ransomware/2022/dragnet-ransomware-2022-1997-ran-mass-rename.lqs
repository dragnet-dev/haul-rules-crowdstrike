// Dragnet [Ransomware]: dragnet-ransomware-2022-1997 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 90955286-fd68-569e-a181-8d6e36e151bb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
