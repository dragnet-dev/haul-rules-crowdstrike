// Dragnet [Ransomware]: dragnet-ransomware-2024-0213 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: 1f688cfc-5996-5362-bc66-c1c59bf1105f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
