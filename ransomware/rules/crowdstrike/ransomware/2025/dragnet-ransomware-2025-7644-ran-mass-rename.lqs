// Dragnet [Ransomware]: dragnet-ransomware-2025-7644 — Mass File Rename (cicada3301)
// Status: experimental | Level: high | ID: 75726566-62cc-5022-ae43-c0d327fe5ddb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
