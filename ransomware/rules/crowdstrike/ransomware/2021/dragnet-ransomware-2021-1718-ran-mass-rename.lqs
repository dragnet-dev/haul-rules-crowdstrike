// Dragnet [Ransomware]: dragnet-ransomware-2021-1718 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: f7e21ed7-bba8-5154-836e-96f835673d82

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
