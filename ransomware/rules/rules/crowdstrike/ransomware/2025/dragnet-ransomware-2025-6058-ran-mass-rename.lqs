// Dragnet [Ransomware]: dragnet-ransomware-2025-6058 — Mass File Rename (pear)
// Status: experimental | Level: high | ID: f4841165-85a6-5666-af0d-70eebecb9a0b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
