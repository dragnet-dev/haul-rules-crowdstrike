// Dragnet [Ransomware]: dragnet-ransomware-2023-1517 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 2e0c08f0-d348-5114-a287-36f47fa06c76

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
