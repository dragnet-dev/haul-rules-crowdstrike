// Dragnet [Ransomware]: dragnet-ransomware-2022-2401 — Mass File Rename (lv)
// Status: deprecated | Level: high | ID: 25d9d1bd-7501-52b4-8f60-202eb1d0d943

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
