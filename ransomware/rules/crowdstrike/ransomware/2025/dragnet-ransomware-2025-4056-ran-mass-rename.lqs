// Dragnet [Ransomware]: dragnet-ransomware-2025-4056 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: ac71a99a-d600-5de1-b040-c7e3e77523f8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
