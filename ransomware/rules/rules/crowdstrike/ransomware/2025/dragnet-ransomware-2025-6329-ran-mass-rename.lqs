// Dragnet [Ransomware]: dragnet-ransomware-2025-6329 — Mass File Rename (incransom)
// Status: test | Level: high | ID: 596818a6-e5f1-5a62-894f-2917be559577

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
