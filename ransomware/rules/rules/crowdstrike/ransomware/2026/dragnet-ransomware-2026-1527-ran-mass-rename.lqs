// Dragnet [Ransomware]: dragnet-ransomware-2026-1527 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 30e11e01-80d8-5dab-8d7b-7e793127f83f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
