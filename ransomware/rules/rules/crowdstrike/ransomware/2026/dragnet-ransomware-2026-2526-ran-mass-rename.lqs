// Dragnet [Ransomware]: dragnet-ransomware-2026-2526 — Mass File Rename (dragonforce)
// Status: test | Level: high | ID: e93ddef5-a2d4-597d-bbd9-7839ac4d8ec0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
