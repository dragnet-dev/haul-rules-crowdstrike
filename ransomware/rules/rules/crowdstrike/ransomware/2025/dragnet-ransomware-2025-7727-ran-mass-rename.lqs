// Dragnet [Ransomware]: dragnet-ransomware-2025-7727 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 1dd4aed1-f1f3-5ddb-ae31-296bcde94f5c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
