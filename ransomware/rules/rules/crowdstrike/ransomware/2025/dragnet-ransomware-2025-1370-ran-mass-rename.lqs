// Dragnet [Ransomware]: dragnet-ransomware-2025-1370 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 7101b2e0-7fa6-59a9-93d0-8a366b552b0e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
