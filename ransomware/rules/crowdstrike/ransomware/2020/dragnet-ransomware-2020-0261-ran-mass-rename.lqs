// Dragnet [Ransomware]: dragnet-ransomware-2020-0261 — Mass File Rename (nefilim)
// Status: deprecated | Level: high | ID: 509ccfd6-d8e7-52e1-84db-41fab385d3c3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
