// Dragnet [Ransomware]: dragnet-ransomware-2025-6713 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: e5c1a590-e032-5c90-baf4-1399d673203d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
