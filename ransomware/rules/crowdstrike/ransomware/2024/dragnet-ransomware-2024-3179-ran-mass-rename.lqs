// Dragnet [Ransomware]: dragnet-ransomware-2024-3179 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: fa0698bf-b69b-5f08-9a84-a00efb6194c6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
