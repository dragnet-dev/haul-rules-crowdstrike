// Dragnet [Ransomware]: dragnet-ransomware-2023-5093 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: 85dc9f73-9718-58f2-8b4e-5ebf98233657

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
