// Dragnet [Ransomware]: dragnet-ransomware-2023-4475 — Mass File Rename (rhysida)
// Status: deprecated | Level: high | ID: 65b86215-c665-5f18-b46f-89c902ca1c48

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
