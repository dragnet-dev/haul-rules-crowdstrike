// Dragnet [Ransomware]: dragnet-ransomware-2022-1892 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 5e3c2585-f1bf-5b69-a807-23182d8c7dd8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
