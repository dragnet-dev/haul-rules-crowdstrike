// Dragnet [Ransomware]: dragnet-ransomware-2021-1164 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: 03271b0e-76b2-514f-9173-1207de481dfe

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
