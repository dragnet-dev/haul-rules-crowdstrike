// Dragnet [Ransomware]: dragnet-ransomware-2023-0103 — Mass File Rename (siegedsec)
// Status: experimental | Level: high | ID: 174d4167-a906-59a6-9cfb-e23e7a6a0397

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
