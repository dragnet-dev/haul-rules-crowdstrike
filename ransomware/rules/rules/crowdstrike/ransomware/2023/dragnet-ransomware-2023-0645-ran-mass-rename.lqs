// Dragnet [Ransomware]: dragnet-ransomware-2023-0645 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 9e2a96a8-bc02-5fa3-bda3-019ef0fd708f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
