// Dragnet [Ransomware]: dragnet-ransomware-2025-5454 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 6ac7c515-db89-561f-8802-fda6c9a730c7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
