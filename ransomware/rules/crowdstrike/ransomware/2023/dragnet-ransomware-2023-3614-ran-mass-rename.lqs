// Dragnet [Ransomware]: dragnet-ransomware-2023-3614 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 20cafd12-0e0c-5efa-bf8f-6c15b57b8be9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
