// Dragnet [Ransomware]: dragnet-ransomware-2022-0490 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 721cf143-1651-57d7-a54e-7bdd9561e12c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
