// Dragnet [Ransomware]: dragnet-ransomware-2024-2462 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: df352fe8-02b0-5f39-af20-8fff83b7969c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
