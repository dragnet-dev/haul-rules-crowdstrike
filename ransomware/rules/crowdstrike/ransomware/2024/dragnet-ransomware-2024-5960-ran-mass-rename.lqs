// Dragnet [Ransomware]: dragnet-ransomware-2024-5960 — Mass File Rename (qilin)
// Status: deprecated | Level: high | ID: d0e1d74a-8f0b-5cde-8364-ab50078e32e2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
