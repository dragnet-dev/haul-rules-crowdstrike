// Dragnet [Ransomware]: dragnet-ransomware-2025-4100 — Mass File Rename (moneymessage)
// Status: experimental | Level: high | ID: a404831b-a080-5808-b54e-b5e7aff31c34

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
