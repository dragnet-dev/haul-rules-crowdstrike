// Dragnet [Ransomware]: dragnet-ransomware-2023-1035 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: d0422337-f800-56ca-b24c-500b3a540d4e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
