// Dragnet [Ransomware]: dragnet-ransomware-2024-5848 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: 391161a7-4de8-59b1-85d6-be4d3cc05b45

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
