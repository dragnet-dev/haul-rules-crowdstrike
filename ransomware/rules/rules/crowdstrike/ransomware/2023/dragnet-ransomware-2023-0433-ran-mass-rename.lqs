// Dragnet [Ransomware]: dragnet-ransomware-2023-0433 — Mass File Rename (toufan)
// Status: deprecated | Level: high | ID: 3dce2c9d-edd4-508b-8e9d-b046e75f04c8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
