// Dragnet [Ransomware]: dragnet-ransomware-2025-7695 — Mass File Rename (nova)
// Status: experimental | Level: high | ID: 25f2181e-554f-514c-8a2b-0ad5316231da

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
