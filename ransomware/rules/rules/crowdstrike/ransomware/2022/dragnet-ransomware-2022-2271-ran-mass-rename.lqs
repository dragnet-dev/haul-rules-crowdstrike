// Dragnet [Ransomware]: dragnet-ransomware-2022-2271 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 29f5716f-f528-5131-b0ef-d2d46e26403d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
