// Dragnet [Ransomware]: dragnet-ransomware-2021-0545 — Mass File Rename (midas)
// Status: deprecated | Level: high | ID: ef563389-e0b7-57d4-994c-a0dee5ed9ff1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
