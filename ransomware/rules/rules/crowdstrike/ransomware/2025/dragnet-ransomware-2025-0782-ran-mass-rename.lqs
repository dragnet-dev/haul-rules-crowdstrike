// Dragnet [Ransomware]: dragnet-ransomware-2025-0782 — Mass File Rename (bert)
// Status: experimental | Level: high | ID: 79a5be3e-7bc4-5d78-8ee3-9a7c254354c8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
