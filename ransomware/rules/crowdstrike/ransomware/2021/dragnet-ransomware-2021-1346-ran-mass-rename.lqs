// Dragnet [Ransomware]: dragnet-ransomware-2021-1346 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: f50fe946-da3d-50b4-a688-3aa9e7343dff

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
