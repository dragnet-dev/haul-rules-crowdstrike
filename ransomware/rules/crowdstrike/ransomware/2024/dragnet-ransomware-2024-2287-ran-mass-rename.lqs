// Dragnet [Ransomware]: dragnet-ransomware-2024-2287 — Mass File Rename (safepay)
// Status: deprecated | Level: high | ID: df243fd8-bbfa-5825-a26e-5f10c670697c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
