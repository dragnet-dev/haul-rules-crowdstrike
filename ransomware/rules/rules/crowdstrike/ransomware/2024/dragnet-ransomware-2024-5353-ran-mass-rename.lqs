// Dragnet [Ransomware]: dragnet-ransomware-2024-5353 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: 5e0bdc87-b91d-56f6-970f-c747c1beacb3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
