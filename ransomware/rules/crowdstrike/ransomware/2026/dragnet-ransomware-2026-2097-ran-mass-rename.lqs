// Dragnet [Ransomware]: dragnet-ransomware-2026-2097 — Mass File Rename (lockbit5)
// Status: stable | Level: high | ID: 0e82b364-04e3-5328-8a6e-1ba90a558015

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
