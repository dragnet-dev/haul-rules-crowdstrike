// Dragnet [Ransomware]: dragnet-ransomware-2025-6456 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 975c93a0-b9c7-526a-a4b9-992ed0fd1fea

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
