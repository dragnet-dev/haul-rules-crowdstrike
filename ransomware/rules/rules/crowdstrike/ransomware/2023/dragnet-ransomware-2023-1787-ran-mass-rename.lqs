// Dragnet [Ransomware]: dragnet-ransomware-2023-1787 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 1a1df329-0aec-5456-ad53-ff631c66cdaf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
