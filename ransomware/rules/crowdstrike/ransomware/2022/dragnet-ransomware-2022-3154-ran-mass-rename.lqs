// Dragnet [Ransomware]: dragnet-ransomware-2022-3154 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 2872650a-d632-546e-8dfe-cd420b1f8e3f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
