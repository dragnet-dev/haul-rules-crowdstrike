// Dragnet [Ransomware]: dragnet-ransomware-2023-3880 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: bcfb3e28-2e30-5f54-905d-cc49fdbb67cd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
