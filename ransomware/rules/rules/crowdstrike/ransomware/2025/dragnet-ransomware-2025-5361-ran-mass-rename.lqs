// Dragnet [Ransomware]: dragnet-ransomware-2025-5361 — Mass File Rename (securotrop)
// Status: experimental | Level: high | ID: 6fa8cd01-a4dd-51bd-95b4-2a46ca42413d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
