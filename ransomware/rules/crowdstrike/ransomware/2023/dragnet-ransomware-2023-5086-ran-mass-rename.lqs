// Dragnet [Ransomware]: dragnet-ransomware-2023-5086 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 0fadebbb-26a5-559c-a5e6-d33e54aacfdb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
