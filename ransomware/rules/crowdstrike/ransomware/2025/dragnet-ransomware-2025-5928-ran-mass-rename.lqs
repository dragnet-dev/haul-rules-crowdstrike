// Dragnet [Ransomware]: dragnet-ransomware-2025-5928 — Mass File Rename (worldleaks)
// Status: experimental | Level: high | ID: 09713f70-b7de-587a-80a3-758c303f4c84

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
