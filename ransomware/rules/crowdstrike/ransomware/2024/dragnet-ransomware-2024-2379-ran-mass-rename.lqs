// Dragnet [Ransomware]: dragnet-ransomware-2024-2379 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: b0d46919-1e7d-53f7-9893-a80ea80958b0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
