// Dragnet [Ransomware]: dragnet-ransomware-2025-4476 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: c50097d3-f9f2-5260-87a1-a19ca3902a3e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
