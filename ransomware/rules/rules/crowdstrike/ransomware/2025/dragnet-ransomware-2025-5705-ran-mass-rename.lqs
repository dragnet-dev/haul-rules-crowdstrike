// Dragnet [Ransomware]: dragnet-ransomware-2025-5705 — Mass File Rename (spacebears)
// Status: experimental | Level: high | ID: 517754ff-3dd3-57b1-95dd-a24cbe7c4049

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
