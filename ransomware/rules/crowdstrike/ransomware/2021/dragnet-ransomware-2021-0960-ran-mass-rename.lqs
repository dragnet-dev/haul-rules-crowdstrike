// Dragnet [Ransomware]: dragnet-ransomware-2021-0960 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: ed3b38a0-f0d1-53bd-b836-b8c92ad7d66d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
