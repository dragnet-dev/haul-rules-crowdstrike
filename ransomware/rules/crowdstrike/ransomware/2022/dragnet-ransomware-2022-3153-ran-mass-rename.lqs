// Dragnet [Ransomware]: dragnet-ransomware-2022-3153 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 2b37a86f-66c5-5878-ac69-7f744079bdad

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
