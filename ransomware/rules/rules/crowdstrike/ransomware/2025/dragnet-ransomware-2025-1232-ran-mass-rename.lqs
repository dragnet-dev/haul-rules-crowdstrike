// Dragnet [Ransomware]: dragnet-ransomware-2025-1232 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 981f7b11-3d44-5142-bdc1-01bf5b74e37a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
