// Dragnet [Ransomware]: dragnet-ransomware-2025-2015 — Mass File Rename (lockbit5)
// Status: test | Level: high | ID: 61b8f2b5-40e6-5469-abdc-62ec12766540

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
