// Dragnet [Ransomware]: dragnet-ransomware-2024-0959 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 1d2ab0e1-e2ae-546b-a494-2abbb452b691

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
