// Dragnet [Ransomware]: dragnet-ransomware-2024-4301 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: ab2f203c-bb1c-54ba-9877-18aa1529715f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
