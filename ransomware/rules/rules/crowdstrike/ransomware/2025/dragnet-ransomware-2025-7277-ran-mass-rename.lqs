// Dragnet [Ransomware]: dragnet-ransomware-2025-7277 — Mass File Rename (tridentlocker)
// Status: experimental | Level: high | ID: 79fb8176-78f3-5ef2-96ae-69b605a7fb25

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
