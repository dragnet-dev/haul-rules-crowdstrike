// Dragnet [Ransomware]: dragnet-ransomware-2024-4350 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 6b7e11e4-1e3d-50cd-b1d0-83ddc882665d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
