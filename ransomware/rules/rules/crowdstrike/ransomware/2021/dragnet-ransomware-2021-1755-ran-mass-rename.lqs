// Dragnet [Ransomware]: dragnet-ransomware-2021-1755 — Mass File Rename (midas)
// Status: deprecated | Level: high | ID: 49346b57-2757-5b3e-bab6-cacef1564b73

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
