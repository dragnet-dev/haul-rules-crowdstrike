// Dragnet [Ransomware]: dragnet-ransomware-2025-2418 — Mass File Rename (thegentlemen)
// Status: experimental | Level: high | ID: e2938d38-4d1a-51c6-8ebc-5e20e75ed7cf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
