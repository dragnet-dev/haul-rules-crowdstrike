// Dragnet [Ransomware]: dragnet-ransomware-2022-1216 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: c72e5095-f412-5898-b100-3d125e517e41

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
