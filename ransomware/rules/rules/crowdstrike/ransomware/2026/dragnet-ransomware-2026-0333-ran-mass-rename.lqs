// Dragnet [Ransomware]: dragnet-ransomware-2026-0333 — Mass File Rename (vect)
// Status: deprecated | Level: high | ID: 3b457061-8644-5b4b-886f-c4ac9ce03927

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
