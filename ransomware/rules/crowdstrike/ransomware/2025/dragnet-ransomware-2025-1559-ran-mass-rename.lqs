// Dragnet [Ransomware]: dragnet-ransomware-2025-1559 — Mass File Rename (BrainCipher)
// Status: experimental | Level: high | ID: af0474a1-a700-57f8-8db9-9a5fb4fdb18b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
