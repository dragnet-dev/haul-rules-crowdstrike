// Dragnet [Ransomware]: dragnet-ransomware-2022-2514 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 0d2ebaf1-5a1d-591b-828a-65bca810a0a4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
