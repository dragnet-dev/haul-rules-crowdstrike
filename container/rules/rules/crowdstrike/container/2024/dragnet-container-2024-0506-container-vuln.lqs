// Dragnet [Container]: dragnet-container-2024-0506 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 2a59c584-4f56-56ff-89e7-f6eababe0057

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
