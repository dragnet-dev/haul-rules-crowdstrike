// Dragnet [Ransomware]: dragnet-ransomware-2024-4258 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: afeb0b38-81b3-58d1-b6e0-e0929538ee8b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
