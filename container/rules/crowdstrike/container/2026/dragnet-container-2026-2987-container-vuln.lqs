// Dragnet [Container]: dragnet-container-2026-2987 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 0edd16ef-d61b-5e08-8c0c-e22d314c3175

#event_simpleName=*
| (ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10* OR ImageFileName = *ubuntu:13.04* OR ImageFileName = *ubuntu:13.10*)
| table([timestamp, ComputerName])
| limit(1000)
