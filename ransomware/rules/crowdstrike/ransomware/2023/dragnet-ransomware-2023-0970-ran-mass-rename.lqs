// Dragnet [Ransomware]: dragnet-ransomware-2023-0970 — Mass File Rename (raworld)
// Status: experimental | Level: high | ID: d25df812-ab62-5d01-879e-b32a18e24582

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
