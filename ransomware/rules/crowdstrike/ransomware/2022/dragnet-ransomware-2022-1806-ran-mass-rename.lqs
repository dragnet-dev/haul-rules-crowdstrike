// Dragnet [Ransomware]: dragnet-ransomware-2022-1806 — Mass File Rename (ransomhouse)
// Status: deprecated | Level: high | ID: 51ba8689-3a0a-5296-a689-9e578d85276f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
