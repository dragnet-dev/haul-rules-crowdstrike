// Dragnet [Ransomware]: dragnet-ransomware-2023-0568 — Mass File Rename (avoslocker)
// Status: deprecated | Level: high | ID: cc4eb323-f80b-5eb4-a3c8-6f9fdbcda171

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
