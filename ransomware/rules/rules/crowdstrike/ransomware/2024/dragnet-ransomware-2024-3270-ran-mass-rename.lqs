// Dragnet [Ransomware]: dragnet-ransomware-2024-3270 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 338c845e-c3ba-525b-99d0-7dd4848e6200

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
