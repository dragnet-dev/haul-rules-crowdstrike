// Dragnet [Ransomware]: dragnet-ransomware-2023-4671 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: df499f47-10b5-5cc8-a1d2-c878858d2321

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
