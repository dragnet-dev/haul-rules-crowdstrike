// Dragnet [Ransomware]: dragnet-ransomware-2023-1891 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 5c972c4c-29a8-5a33-97bd-eed165656ae4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
