// Dragnet [Ransomware]: dragnet-ransomware-2024-2759 — Mass File Rename (apt73)
// Status: experimental | Level: high | ID: ae4288fe-6be9-5250-8c51-9684961a523f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
