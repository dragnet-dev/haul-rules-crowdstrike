// Dragnet [Container]: dragnet-container-2026-2813 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 353a5108-98b8-5da4-bd8f-950b0434b7c6

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:7* OR ImageFileName = *debian:8* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:14.04* OR ImageFileName = *ubuntu:14.04-ESM* OR ImageFileName = *ubuntu:15.04* OR ImageFileName = *ubuntu:15.10*)
| table([timestamp, ComputerName])
| limit(1000)
