// Dragnet [Ransomware]: dragnet-ransomware-2025-4911 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 9af82c46-a4a7-5be6-a95e-0de3e4bc94cf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
