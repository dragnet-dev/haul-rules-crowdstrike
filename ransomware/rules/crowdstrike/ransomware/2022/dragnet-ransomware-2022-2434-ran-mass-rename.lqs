// Dragnet [Ransomware]: dragnet-ransomware-2022-2434 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: c9b150f8-01d2-54f0-aafd-cc685cb77875

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
