// Dragnet [Ransomware]: dragnet-ransomware-2024-3418 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: ae885bfe-7a16-5504-9a8c-3a19893992ec

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
