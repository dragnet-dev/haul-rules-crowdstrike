// Dragnet [Ransomware]: dragnet-ransomware-2025-3551 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 7a7260be-0fbc-54e5-9765-1dd9641654a4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
