// Dragnet [Ransomware]: dragnet-ransomware-2025-7211 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 73dd2ca8-afaa-56f8-92b1-bc21d5a7d0e5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
