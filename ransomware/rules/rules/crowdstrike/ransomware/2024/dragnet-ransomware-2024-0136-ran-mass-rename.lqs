// Dragnet [Ransomware]: dragnet-ransomware-2024-0136 — Mass File Rename (play)
// Status: experimental | Level: high | ID: dedd322f-5d44-5490-b3df-572769813e89

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
