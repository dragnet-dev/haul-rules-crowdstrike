// Dragnet [Ransomware]: dragnet-ransomware-2024-5176 — Mass File Rename (safepay)
// Status: deprecated | Level: high | ID: 4732378e-a332-5635-b8d2-6f1dd8ff7571

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
