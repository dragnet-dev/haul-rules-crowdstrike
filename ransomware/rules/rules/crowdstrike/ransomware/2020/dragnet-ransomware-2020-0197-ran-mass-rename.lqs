// Dragnet [Ransomware]: dragnet-ransomware-2020-0197 — Mass File Rename (maze)
// Status: deprecated | Level: high | ID: 6c2827a2-0130-579e-a850-d77123a6d6ea

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
