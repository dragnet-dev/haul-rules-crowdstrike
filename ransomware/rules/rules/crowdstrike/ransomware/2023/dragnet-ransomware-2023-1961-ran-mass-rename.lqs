// Dragnet [Ransomware]: dragnet-ransomware-2023-1961 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 671c8f14-11b7-5c68-8efd-6cc46efddcdc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
