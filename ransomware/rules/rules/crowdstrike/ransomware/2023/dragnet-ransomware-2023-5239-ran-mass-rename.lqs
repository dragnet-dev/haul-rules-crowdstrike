// Dragnet [Ransomware]: dragnet-ransomware-2023-5239 — Mass File Rename (donutleaks)
// Status: experimental | Level: high | ID: 6f28a4c8-3b36-5f77-a664-762f1aafeb49

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
