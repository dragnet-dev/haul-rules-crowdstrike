// Dragnet [Ransomware]: dragnet-ransomware-2023-1944 — Mass File Rename (toufan)
// Status: deprecated | Level: high | ID: b0a3d062-d629-5640-90d7-6ffdcec383da

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
