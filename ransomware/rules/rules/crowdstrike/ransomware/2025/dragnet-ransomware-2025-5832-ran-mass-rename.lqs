// Dragnet [Ransomware]: dragnet-ransomware-2025-5832 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: bcdc94f1-6b92-5e7a-8d5f-60fb33948d69

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
