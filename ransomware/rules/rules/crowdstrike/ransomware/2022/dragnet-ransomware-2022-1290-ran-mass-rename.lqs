// Dragnet [Ransomware]: dragnet-ransomware-2022-1290 — Mass File Rename (ransomexx)
// Status: experimental | Level: high | ID: eaa008ea-f52c-52b9-a650-cb7b64dedbc2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
