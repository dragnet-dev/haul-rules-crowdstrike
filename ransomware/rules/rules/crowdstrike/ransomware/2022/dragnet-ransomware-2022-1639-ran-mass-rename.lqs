// Dragnet [Ransomware]: dragnet-ransomware-2022-1639 — Mass File Rename (icefire)
// Status: deprecated | Level: high | ID: d11f8c1d-dd43-595f-afb7-35fcf8bb44af

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
