// Dragnet [Ransomware]: dragnet-ransomware-2021-0371 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: c6f759b5-5763-5887-b6f9-c312cf7c8a9f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
