// Dragnet [Ransomware]: dragnet-ransomware-2022-3127 — Mass File Rename (kelvinsecurity)
// Status: deprecated | Level: high | ID: f0f4a2ac-f99c-57dc-8679-9a73cbdb80b9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
