// Dragnet [Ransomware]: dragnet-ransomware-2025-5007 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 2e15774a-2537-590f-a14f-a060f6a7ddca

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
