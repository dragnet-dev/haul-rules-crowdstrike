// Dragnet [Ransomware]: dragnet-ransomware-2024-2117 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 5a06696b-02d6-5cbf-9a37-fce59dbc6214

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
