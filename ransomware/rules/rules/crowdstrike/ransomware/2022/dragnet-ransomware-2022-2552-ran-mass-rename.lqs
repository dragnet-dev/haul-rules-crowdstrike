// Dragnet [Ransomware]: dragnet-ransomware-2022-2552 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: a2c36927-fe38-550b-b259-93faf024e492

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
