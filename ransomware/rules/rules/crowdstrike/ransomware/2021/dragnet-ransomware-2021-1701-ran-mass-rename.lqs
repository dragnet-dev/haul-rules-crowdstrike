// Dragnet [Ransomware]: dragnet-ransomware-2021-1701 — Mass File Rename (everest)
// Status: deprecated | Level: high | ID: 5d7bfe9e-e090-5175-a3e3-f13bcefe7e8c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
