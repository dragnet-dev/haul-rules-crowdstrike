// Dragnet [Ransomware]: dragnet-ransomware-2023-3163 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 6ab91187-c17e-5f6e-8926-023cf351c7f3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
