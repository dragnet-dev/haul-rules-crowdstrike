// Dragnet [Ransomware]: dragnet-ransomware-2025-2905 — Mass File Rename (sinobi)
// Status: experimental | Level: high | ID: 963bd3c6-47ba-50fc-8d1e-28fca1e043f0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
