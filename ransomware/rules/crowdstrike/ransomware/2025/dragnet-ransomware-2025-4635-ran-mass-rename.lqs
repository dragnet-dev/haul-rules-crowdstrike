// Dragnet [Ransomware]: dragnet-ransomware-2025-4635 — Mass File Rename (flocker)
// Status: experimental | Level: high | ID: 44f32c5e-8c8c-5fde-9722-7413cef18de2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
