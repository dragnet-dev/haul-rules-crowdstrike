// Dragnet [Ransomware]: dragnet-ransomware-2024-5402 — Mass File Rename (meow)
// Status: experimental | Level: high | ID: fe08cc45-e91d-549b-9b8d-b0b43ed1deff

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
