// Dragnet [Ransomware]: dragnet-ransomware-2025-5116 — Mass File Rename (payoutsking)
// Status: deprecated | Level: high | ID: 200c5c1d-d625-5eba-9667-f550aa884450

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
