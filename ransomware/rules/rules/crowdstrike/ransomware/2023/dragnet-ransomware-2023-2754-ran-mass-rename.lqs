// Dragnet [Ransomware]: dragnet-ransomware-2023-2754 — Mass File Rename (malas)
// Status: experimental | Level: high | ID: ab8f1198-5a0e-5285-978d-c2cdbc16f6bc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
