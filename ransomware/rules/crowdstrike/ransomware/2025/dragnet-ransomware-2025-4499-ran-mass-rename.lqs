// Dragnet [Ransomware]: dragnet-ransomware-2025-4499 — Mass File Rename (cloak)
// Status: deprecated | Level: high | ID: d2b3f878-2efd-5803-8345-511ce1031c0d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
