// Dragnet [Ransomware]: dragnet-ransomware-2023-0647 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: a6d82b1b-38b4-5077-a461-a45f479e8393

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
