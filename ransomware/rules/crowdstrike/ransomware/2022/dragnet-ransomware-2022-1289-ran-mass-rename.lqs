// Dragnet [Ransomware]: dragnet-ransomware-2022-1289 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: f358acd4-8533-5aa5-b9d4-19db9041abec

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
