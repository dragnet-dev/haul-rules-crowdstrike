// Dragnet [Ransomware]: dragnet-ransomware-2024-0333 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: e859f912-5a69-505e-a305-07df6691456c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
