// Dragnet [Ransomware]: dragnet-ransomware-2024-1971 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 26f708ed-46d7-5421-b657-26348926575f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
