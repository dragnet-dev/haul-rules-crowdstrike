// Dragnet [Ransomware]: dragnet-ransomware-2026-0141 — Mass File Rename (payoutsking)
// Status: test | Level: high | ID: 4853db8e-ccd4-5c9f-9ccf-d75e42505226

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
