// Dragnet [Ransomware]: dragnet-ransomware-2025-4720 — Mass File Rename (RunSomeWares)
// Status: experimental | Level: high | ID: 4d5b1416-145a-5ba3-b7bc-a26fbd217009

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
