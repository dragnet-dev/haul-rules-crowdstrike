// Dragnet [Ransomware]: dragnet-ransomware-2026-2827 — Mass File Rename (incransom)
// Status: stable | Level: high | ID: e76ea048-7d82-5656-a0e8-0015d2680c6d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
