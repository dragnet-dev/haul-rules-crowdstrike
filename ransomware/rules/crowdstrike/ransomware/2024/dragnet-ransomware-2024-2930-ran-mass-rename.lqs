// Dragnet [Ransomware]: dragnet-ransomware-2024-2930 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: c5456bf5-7383-514d-89c4-4874d54eb14e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
