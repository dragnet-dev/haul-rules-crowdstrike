// Dragnet [Ransomware]: dragnet-ransomware-2024-3429 — Mass File Rename (stormous)
// Status: deprecated | Level: high | ID: 5799a6b1-fa2a-5449-ad1f-70b555181425

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
