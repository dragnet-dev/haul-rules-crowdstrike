// Dragnet [Container]: dragnet-container-2026-0241 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: b2214c2c-8355-5bca-b50e-0fef79898164

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
