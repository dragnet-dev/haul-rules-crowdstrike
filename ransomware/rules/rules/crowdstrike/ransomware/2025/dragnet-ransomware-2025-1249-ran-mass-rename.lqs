// Dragnet [Ransomware]: dragnet-ransomware-2025-1249 — Mass File Rename (kraken)
// Status: experimental | Level: high | ID: 8d8ad14c-ba34-5e82-89a4-e9f1772676c3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
