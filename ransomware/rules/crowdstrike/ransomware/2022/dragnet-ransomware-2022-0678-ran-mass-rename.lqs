// Dragnet [Ransomware]: dragnet-ransomware-2022-0678 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 935812bf-aa07-5a28-9190-a4c69df1fca9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
