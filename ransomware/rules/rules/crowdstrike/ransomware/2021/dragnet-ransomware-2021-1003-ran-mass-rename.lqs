// Dragnet [Ransomware]: dragnet-ransomware-2021-1003 — Mass File Rename (avaddon)
// Status: deprecated | Level: high | ID: 78b643e6-6132-5092-88ab-3891861ced81

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
