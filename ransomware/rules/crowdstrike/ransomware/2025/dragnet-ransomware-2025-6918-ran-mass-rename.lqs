// Dragnet [Ransomware]: dragnet-ransomware-2025-6918 — Mass File Rename (worldleaks)
// Status: experimental | Level: high | ID: ac79c583-67e7-59ec-a2dc-2a834b08a974

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
