// Dragnet [Ransomware]: dragnet-ransomware-2021-0387 — Mass File Rename (alphv)
// Status: deprecated | Level: high | ID: 5c87051b-f7ac-5389-b6ce-ff6c2f31d228

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
