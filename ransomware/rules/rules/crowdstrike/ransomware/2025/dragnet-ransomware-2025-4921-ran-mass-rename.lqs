// Dragnet [Ransomware]: dragnet-ransomware-2025-4921 — Mass File Rename (kraken)
// Status: experimental | Level: high | ID: b053a788-ee20-52d6-9d5f-540d574eadf7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
