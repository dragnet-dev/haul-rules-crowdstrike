// Dragnet [Ransomware]: dragnet-ransomware-2025-6529 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: b5feb080-d3bb-502a-9cb4-0b9f972292f8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
