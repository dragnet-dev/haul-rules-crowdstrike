// Dragnet [Ransomware]: dragnet-ransomware-2025-4463 — Mass File Rename (anubis)
// Status: experimental | Level: high | ID: 6100b10c-6b61-5742-abf0-f941bc89c726

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
