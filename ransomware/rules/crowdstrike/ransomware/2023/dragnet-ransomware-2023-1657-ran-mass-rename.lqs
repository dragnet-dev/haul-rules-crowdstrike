// Dragnet [Ransomware]: dragnet-ransomware-2023-1657 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: ed303eb0-5e45-5f51-b248-56faf9eb611b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
