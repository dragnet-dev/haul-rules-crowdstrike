// Dragnet [Ransomware]: dragnet-ransomware-2024-4431 — Mass File Rename (raworld)
// Status: experimental | Level: high | ID: 2fcb717f-ec9a-5b76-a975-9c1d069efba3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
