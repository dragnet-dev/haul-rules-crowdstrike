// Dragnet [Ransomware]: dragnet-ransomware-2025-1743 — Mass File Rename (play)
// Status: experimental | Level: high | ID: f82f8efb-2bfc-55e6-a2fb-b848ba258aa8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
