// Dragnet [Ransomware]: dragnet-ransomware-2024-1439 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: acec6842-7a57-53e6-9ab2-2f62326f2891

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
