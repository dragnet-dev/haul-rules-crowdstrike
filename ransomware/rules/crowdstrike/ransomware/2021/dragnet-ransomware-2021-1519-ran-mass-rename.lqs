// Dragnet [Ransomware]: dragnet-ransomware-2021-1519 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: e03ffa60-ec63-522d-8c0c-1a7c8caf3b8e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
