// Dragnet [Ransomware]: dragnet-ransomware-2026-3142 — Mass File Rename (thegentlemen)
// Status: deprecated | Level: high | ID: ba10e263-dd87-5ca0-b443-e0905b11d3c6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
