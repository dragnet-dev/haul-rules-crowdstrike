// Dragnet [Ransomware]: dragnet-ransomware-2026-1164 — Mass File Rename (thegentlemen)
// Status: stable | Level: high | ID: 307237cc-0b96-5e99-b884-c01f62780f7f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
