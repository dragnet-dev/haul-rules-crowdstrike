// Dragnet [Container]: dragnet-container-2024-0290 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: cd995d34-5def-54c8-9104-91f731d35d47

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
