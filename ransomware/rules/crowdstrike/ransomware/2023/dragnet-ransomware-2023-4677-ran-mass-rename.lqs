// Dragnet [Ransomware]: dragnet-ransomware-2023-4677 — Mass File Rename (ransomed)
// Status: experimental | Level: high | ID: e2429bef-b447-50ff-b9a4-e7e939b8139a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
