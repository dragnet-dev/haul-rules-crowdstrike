// Dragnet [Ransomware]: dragnet-ransomware-2025-4112 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: e0220699-9239-5642-9321-6c695573a313

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
