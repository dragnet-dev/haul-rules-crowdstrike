// Dragnet [Ransomware]: dragnet-ransomware-2023-0192 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 03205cf0-7e02-53bc-a09d-e49600f0481c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
