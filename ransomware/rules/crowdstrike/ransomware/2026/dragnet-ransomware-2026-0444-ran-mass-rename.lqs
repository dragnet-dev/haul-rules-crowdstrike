// Dragnet [Ransomware]: dragnet-ransomware-2026-0444 — Mass File Rename (stormous)
// Status: deprecated | Level: high | ID: 37596074-7b5f-52c8-9bec-3c117dda0eb7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
