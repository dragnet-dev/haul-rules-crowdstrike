// Dragnet [Ransomware]: dragnet-ransomware-2025-2127 — Mass File Rename (global)
// Status: deprecated | Level: high | ID: c663ac17-3146-536f-bb31-76a76d02ac29

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
