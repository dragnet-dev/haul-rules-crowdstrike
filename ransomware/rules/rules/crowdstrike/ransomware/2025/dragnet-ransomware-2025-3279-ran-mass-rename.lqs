// Dragnet [Ransomware]: dragnet-ransomware-2025-3279 — Mass File Rename (incransom)
// Status: test | Level: high | ID: 0c7c52aa-e115-525b-a760-2fb98ddba6ed

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
