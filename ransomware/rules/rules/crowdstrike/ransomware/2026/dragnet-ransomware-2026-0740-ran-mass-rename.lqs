// Dragnet [Ransomware]: dragnet-ransomware-2026-0740 — Mass File Rename (lockbit5)
// Status: test | Level: high | ID: 1fc56032-a93c-514d-9f80-874b9ad7cd08

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
