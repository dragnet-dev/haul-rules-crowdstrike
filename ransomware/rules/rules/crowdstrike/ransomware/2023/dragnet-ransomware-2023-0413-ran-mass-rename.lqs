// Dragnet [Ransomware]: dragnet-ransomware-2023-0413 — Mass File Rename (stormous)
// Status: experimental | Level: high | ID: e130b018-776e-506a-8a50-41d6af09e6f0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
