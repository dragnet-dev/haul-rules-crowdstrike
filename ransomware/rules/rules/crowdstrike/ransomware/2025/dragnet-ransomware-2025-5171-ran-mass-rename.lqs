// Dragnet [Ransomware]: dragnet-ransomware-2025-5171 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: ffebc4d4-8734-5207-b848-117f468c3523

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
