// Dragnet [Ransomware]: dragnet-ransomware-2021-0412 — Mass File Rename (lockdata)
// Status: deprecated | Level: high | ID: 1a3e5f18-2628-50db-bfca-0a6c259aa6a9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
