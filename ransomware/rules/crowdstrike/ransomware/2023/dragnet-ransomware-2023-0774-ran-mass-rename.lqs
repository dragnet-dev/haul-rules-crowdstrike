// Dragnet [Ransomware]: dragnet-ransomware-2023-0774 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 1f03a9d9-1989-5200-ba42-683999870565

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
