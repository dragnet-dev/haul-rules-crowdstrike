// Dragnet [Ransomware]: dragnet-ransomware-2025-5998 — Mass File Rename (desolator)
// Status: experimental | Level: high | ID: db7f3813-f778-5c10-82b5-44d1be35a121

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
