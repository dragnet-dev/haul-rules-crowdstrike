// Dragnet [Ransomware]: dragnet-ransomware-2025-4370 — Mass File Rename (worldleaks)
// Status: experimental | Level: high | ID: 1721fa05-642a-51c0-9c4c-44cfa3eb46e6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
