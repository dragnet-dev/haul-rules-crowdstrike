// Dragnet [Ransomware]: dragnet-ransomware-2023-1848 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 4d5320a2-9978-5a53-8dea-f226abb040a6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
