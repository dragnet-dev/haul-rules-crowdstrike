// Dragnet [Ransomware]: dragnet-ransomware-2023-1753 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 9b61847c-aa95-530f-8ec0-f96584583377

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
