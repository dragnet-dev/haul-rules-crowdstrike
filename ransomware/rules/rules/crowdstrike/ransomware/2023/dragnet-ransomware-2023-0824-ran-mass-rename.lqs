// Dragnet [Ransomware]: dragnet-ransomware-2023-0824 — Mass File Rename (ransomed)
// Status: experimental | Level: high | ID: a555e21c-91ba-5c02-bb9d-94bce8325338

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
