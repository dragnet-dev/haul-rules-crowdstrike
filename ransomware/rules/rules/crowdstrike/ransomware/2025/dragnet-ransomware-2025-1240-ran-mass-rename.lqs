// Dragnet [Ransomware]: dragnet-ransomware-2025-1240 — Mass File Rename (worldleaks)
// Status: experimental | Level: high | ID: cf0e7673-fa9d-5f70-a69d-0202e281da9d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
