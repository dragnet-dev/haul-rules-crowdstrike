// Dragnet [Ransomware]: dragnet-ransomware-2023-0862 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: adc9e0ec-3e23-52ed-9e42-74c1f6100658

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
