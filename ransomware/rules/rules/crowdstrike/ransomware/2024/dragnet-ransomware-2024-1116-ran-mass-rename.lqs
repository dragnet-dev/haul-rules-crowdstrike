// Dragnet [Ransomware]: dragnet-ransomware-2024-1116 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: a2c1749c-0d90-551f-bc29-8261f8d00dba

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
