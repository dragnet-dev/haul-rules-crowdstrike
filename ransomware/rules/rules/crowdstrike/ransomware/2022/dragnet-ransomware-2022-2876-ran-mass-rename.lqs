// Dragnet [Ransomware]: dragnet-ransomware-2022-2876 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: c3227095-f1d3-5c58-81a6-a25b1b836f13

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
