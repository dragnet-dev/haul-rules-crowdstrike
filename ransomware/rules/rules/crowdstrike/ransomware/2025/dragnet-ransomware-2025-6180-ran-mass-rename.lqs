// Dragnet [Ransomware]: dragnet-ransomware-2025-6180 — Mass File Rename (apt73)
// Status: experimental | Level: high | ID: 1f4b4c9d-9337-565e-b55a-def8324abf29

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
