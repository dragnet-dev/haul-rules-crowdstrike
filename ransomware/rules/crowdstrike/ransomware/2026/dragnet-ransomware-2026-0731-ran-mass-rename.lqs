// Dragnet [Ransomware]: dragnet-ransomware-2026-0731 — Mass File Rename (killsec)
// Status: deprecated | Level: high | ID: 7997600b-46eb-509f-abbd-432068012fe4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
