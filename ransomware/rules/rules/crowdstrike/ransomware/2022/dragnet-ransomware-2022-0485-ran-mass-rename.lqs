// Dragnet [Ransomware]: dragnet-ransomware-2022-0485 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: c6a21ddf-b66a-523a-b8de-d97410c64ae4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
