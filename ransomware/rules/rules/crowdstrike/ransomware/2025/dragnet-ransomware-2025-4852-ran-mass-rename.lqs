// Dragnet [Ransomware]: dragnet-ransomware-2025-4852 — Mass File Rename (IMNCrew)
// Status: experimental | Level: high | ID: c91c8472-7bd7-564f-8bdb-26a794bdcf13

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
