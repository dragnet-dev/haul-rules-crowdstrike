// Dragnet [Ransomware]: dragnet-ransomware-2021-0490 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 4e1bc518-cc8f-5d75-8945-feade5c6c13f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
