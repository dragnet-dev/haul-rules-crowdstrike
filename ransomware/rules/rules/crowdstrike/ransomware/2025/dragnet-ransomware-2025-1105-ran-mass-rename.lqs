// Dragnet [Ransomware]: dragnet-ransomware-2025-1105 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 4ba48fdd-8da6-5eaa-8a49-dd43f10add4b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
