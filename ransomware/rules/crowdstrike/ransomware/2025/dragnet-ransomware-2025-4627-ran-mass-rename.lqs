// Dragnet [Ransomware]: dragnet-ransomware-2025-4627 — Mass File Rename (sinobi)
// Status: experimental | Level: high | ID: 80895182-f660-560e-a40d-d034825101e2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
