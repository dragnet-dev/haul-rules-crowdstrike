// Dragnet [Ransomware]: dragnet-ransomware-2021-0570 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: f201b328-92d7-597d-96dd-27573da6919f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
