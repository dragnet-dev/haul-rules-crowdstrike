// Dragnet [Ransomware]: dragnet-ransomware-2025-3418 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: b0242b81-6f70-5ede-9567-4f8ec711050d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
