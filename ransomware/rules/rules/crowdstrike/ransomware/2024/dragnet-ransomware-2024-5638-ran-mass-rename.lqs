// Dragnet [Ransomware]: dragnet-ransomware-2024-5638 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 5ee34699-7e51-561b-8218-439dbe475b85

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
