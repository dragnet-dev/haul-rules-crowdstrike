// Dragnet [Ransomware]: dragnet-ransomware-2023-4722 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 0c06c1e7-3fbd-5c29-b47b-954e9457a6d1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
