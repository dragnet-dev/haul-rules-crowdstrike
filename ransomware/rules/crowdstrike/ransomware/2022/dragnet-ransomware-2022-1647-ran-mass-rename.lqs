// Dragnet [Ransomware]: dragnet-ransomware-2022-1647 — Mass File Rename (ransomexx)
// Status: experimental | Level: high | ID: a3e3510d-fd74-5d1e-bcdf-8e99ec08e42a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
