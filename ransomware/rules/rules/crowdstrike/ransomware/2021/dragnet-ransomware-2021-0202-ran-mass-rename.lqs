// Dragnet [Ransomware]: dragnet-ransomware-2021-0202 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: b21c1836-5bf8-56d3-846d-e47fd17d299a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
