// Dragnet [Ransomware]: dragnet-ransomware-2021-1605 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 706a0048-e143-5c8b-8ab9-ab7c37d32ff4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
