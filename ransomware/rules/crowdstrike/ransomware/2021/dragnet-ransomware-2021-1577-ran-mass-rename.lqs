// Dragnet [Ransomware]: dragnet-ransomware-2021-1577 — Mass File Rename (avaddon)
// Status: deprecated | Level: high | ID: 44e92a4d-9457-5f96-9d0e-ce1683993b5b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
