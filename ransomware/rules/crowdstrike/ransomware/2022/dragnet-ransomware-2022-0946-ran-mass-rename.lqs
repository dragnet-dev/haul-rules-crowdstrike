// Dragnet [Ransomware]: dragnet-ransomware-2022-0946 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 8b4975b8-d0c1-525d-9ae1-9dad643de9f8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
