// Dragnet [Ransomware]: dragnet-ransomware-2021-1428 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 6a2597f2-f7ea-5931-aa7f-14b8e0d14e28

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
