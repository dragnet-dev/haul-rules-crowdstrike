// Dragnet [Ransomware]: dragnet-ransomware-2022-2433 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: a2a2441b-2041-5ffb-a5c3-77b4db23717e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
