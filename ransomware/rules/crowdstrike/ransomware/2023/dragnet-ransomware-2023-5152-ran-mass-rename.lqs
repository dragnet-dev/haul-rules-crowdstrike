// Dragnet [Ransomware]: dragnet-ransomware-2023-5152 — Mass File Rename (toufan)
// Status: deprecated | Level: high | ID: 83b1436f-c136-54ce-8814-49eb49906c59

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
