// Dragnet [Ransomware]: dragnet-ransomware-2024-3868 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 7136ff6d-369a-5e90-a517-acb1682ecb24

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
