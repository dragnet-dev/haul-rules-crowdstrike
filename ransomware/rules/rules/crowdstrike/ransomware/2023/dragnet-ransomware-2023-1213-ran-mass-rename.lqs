// Dragnet [Ransomware]: dragnet-ransomware-2023-1213 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 6451b909-3d0d-5a29-837f-75f5636d3c8a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
