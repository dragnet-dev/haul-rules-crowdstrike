// Dragnet [Ransomware]: dragnet-ransomware-2023-1646 — Mass File Rename (ransomed)
// Status: deprecated | Level: high | ID: 53d55626-6372-52e7-9b76-113ba1e883cd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
