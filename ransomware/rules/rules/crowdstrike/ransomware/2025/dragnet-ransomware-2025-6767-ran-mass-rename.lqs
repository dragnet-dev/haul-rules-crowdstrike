// Dragnet [Ransomware]: dragnet-ransomware-2025-6767 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: dcc968d2-0a8e-5fab-b7c7-bb7dda858255

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
