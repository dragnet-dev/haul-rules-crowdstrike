// Dragnet [Ransomware]: dragnet-ransomware-2025-7077 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 8e5b8941-54e2-5a72-9274-c7188036d5f0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
