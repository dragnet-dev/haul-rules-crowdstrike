// Dragnet [Ransomware]: dragnet-ransomware-2022-0134 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 9457ec47-ccee-5e30-88b0-356d2036b2b1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
