// Dragnet [Container]: dragnet-container-2026-2518 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 80a8cfb4-9164-5036-affc-ad1d30a59f20

#event_simpleName=*
| (ImageFileName = *amazonlinux:1* OR ImageFileName = *chainguard:* OR ImageFileName = *debian:7* OR ImageFileName = *debian:8* OR ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *oraclelinux:7* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:14.04* OR ImageFileName = *ubuntu:16.04* OR ImageFileName = *ubuntu:16.04-ESM* OR ImageFileName = *ubuntu:16.10*)
| table([timestamp, ComputerName])
| limit(1000)
