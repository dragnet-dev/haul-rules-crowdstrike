// Dragnet [Ransomware]: dragnet-ransomware-2026-0283 — Mass File Rename (payload)
// Status: stable | Level: high | ID: 631890ea-1e6b-5d8c-a368-37adfa956805

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
