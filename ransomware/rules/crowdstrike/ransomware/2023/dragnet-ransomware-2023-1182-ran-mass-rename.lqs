// Dragnet [Ransomware]: dragnet-ransomware-2023-1182 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: 33f6f88d-7f05-5ed6-a4da-fc0cf612e4a2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
