// Dragnet [Ransomware]: dragnet-ransomware-2024-2209 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 680a4727-1847-5aaf-9818-3f89df670c6a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
