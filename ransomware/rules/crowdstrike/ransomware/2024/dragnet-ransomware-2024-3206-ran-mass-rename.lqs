// Dragnet [Ransomware]: dragnet-ransomware-2024-3206 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: de0e4d55-5313-541c-b186-94d719ed84e5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
