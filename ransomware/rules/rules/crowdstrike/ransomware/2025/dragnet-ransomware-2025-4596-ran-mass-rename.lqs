// Dragnet [Ransomware]: dragnet-ransomware-2025-4596 — Mass File Rename (sinobi)
// Status: experimental | Level: high | ID: b66a08b1-d402-57d6-9d45-15feee791ff9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
