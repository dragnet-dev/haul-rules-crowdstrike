// Dragnet [Ransomware]: dragnet-ransomware-2021-1802 — Mass File Rename (payloadbin)
// Status: deprecated | Level: high | ID: 0763d500-50a0-5cea-b853-0f02bd4423ab

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
