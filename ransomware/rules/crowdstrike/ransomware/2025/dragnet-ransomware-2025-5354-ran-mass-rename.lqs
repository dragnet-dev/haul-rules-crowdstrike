// Dragnet [Ransomware]: dragnet-ransomware-2025-5354 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: c84279ee-12eb-5269-817c-242d9366c906

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
