// Dragnet [Ransomware]: dragnet-ransomware-2025-6721 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 1aa7f98e-e696-5deb-8aac-54818133f528

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
