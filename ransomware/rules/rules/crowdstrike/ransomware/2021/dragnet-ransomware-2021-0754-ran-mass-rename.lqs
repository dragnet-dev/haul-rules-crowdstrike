// Dragnet [Ransomware]: dragnet-ransomware-2021-0754 — Mass File Rename (ragnarlocker)
// Status: deprecated | Level: high | ID: f1e5d75f-7189-51b1-ac28-da44c4d71b35

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
