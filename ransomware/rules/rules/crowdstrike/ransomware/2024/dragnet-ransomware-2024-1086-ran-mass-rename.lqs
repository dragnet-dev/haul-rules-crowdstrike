// Dragnet [Ransomware]: dragnet-ransomware-2024-1086 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 389d7fcb-79bb-57ae-9bfd-c25251b2fce7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
