// Dragnet [Ransomware]: dragnet-ransomware-2025-0395 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 96018d44-d164-50a4-82da-bea79118d613

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
