// Dragnet [Ransomware]: dragnet-ransomware-2024-5987 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: c55bdb4a-1642-5412-86c0-5a6283aa5ff1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
