// Dragnet [Ransomware]: dragnet-ransomware-2023-5153 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 7ef4b42a-9923-5bc5-80ee-16cc81a4d22b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
