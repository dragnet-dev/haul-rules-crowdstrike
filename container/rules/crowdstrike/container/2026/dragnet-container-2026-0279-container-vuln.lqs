// Dragnet [Container]: dragnet-container-2026-0279 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 5cf0a228-6af5-5e6c-bf4b-cf95b1814ff9

#event_simpleName=*
| (ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10* OR ImageFileName = *ubuntu:13.04* OR ImageFileName = *ubuntu:13.10*)
| table([timestamp, ComputerName])
| limit(1000)
