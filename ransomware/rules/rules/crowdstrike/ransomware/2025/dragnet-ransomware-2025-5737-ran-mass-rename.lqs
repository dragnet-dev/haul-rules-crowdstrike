// Dragnet [Ransomware]: dragnet-ransomware-2025-5737 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 445249dc-27b1-5bdd-b836-b2544ed43a9a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
