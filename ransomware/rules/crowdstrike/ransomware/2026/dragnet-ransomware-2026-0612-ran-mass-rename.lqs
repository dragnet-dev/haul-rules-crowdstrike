// Dragnet [Ransomware]: dragnet-ransomware-2026-0612 — Mass File Rename (payoutsking)
// Status: test | Level: high | ID: 0026d57d-bb94-5fa4-94e5-b104d0799f8d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
