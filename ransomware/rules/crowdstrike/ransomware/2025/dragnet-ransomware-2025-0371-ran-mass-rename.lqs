// Dragnet [Ransomware]: dragnet-ransomware-2025-0371 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 33225d49-62d4-537f-9510-d575463ec55c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
