// Dragnet [Container]: dragnet-container-2026-2400 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 765f5c15-97e1-50e9-bf8d-f25781270131

#event_simpleName=*
| (ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *ubuntu:12.04*)
| table([timestamp, ComputerName])
| limit(1000)
