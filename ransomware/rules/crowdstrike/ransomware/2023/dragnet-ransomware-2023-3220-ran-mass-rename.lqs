// Dragnet [Ransomware]: dragnet-ransomware-2023-3220 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 8a255aee-931f-52ff-9f59-dcf13a3f24e8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
