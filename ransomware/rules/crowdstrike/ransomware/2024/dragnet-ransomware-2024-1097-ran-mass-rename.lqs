// Dragnet [Ransomware]: dragnet-ransomware-2024-1097 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 27996229-5416-57a5-be05-09e2d6920750

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
