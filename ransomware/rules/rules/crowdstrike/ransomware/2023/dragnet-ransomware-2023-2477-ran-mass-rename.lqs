// Dragnet [Ransomware]: dragnet-ransomware-2023-2477 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: acdd24e7-bf8e-56df-a88d-752b115b930a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
