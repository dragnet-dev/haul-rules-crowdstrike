// Dragnet [Ransomware]: dragnet-ransomware-2025-6921 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 65a21bba-09d7-5a85-b47e-f09887127204

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
