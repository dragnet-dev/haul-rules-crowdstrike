// Dragnet [Ransomware]: dragnet-ransomware-2025-5785 — Mass File Rename (flocker)
// Status: experimental | Level: high | ID: 136b6bf7-1096-5238-8bef-a240fcea7000

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
