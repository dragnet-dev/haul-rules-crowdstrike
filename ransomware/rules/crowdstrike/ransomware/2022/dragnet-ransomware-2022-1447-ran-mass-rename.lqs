// Dragnet [Ransomware]: dragnet-ransomware-2022-1447 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: edc11ee0-a45e-5fe8-a82f-14b9ffc5cf92

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
