// Dragnet [Ransomware]: dragnet-ransomware-2025-5738 — Mass File Rename (kairos)
// Status: experimental | Level: high | ID: 18dabd7d-bdb1-54cb-9f75-f7ba697c95b0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
