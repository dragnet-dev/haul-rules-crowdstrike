// Dragnet [Ransomware]: dragnet-ransomware-2023-3273 — Mass File Rename (rhysida)
// Status: experimental | Level: high | ID: 360d610f-b3ae-5d5d-abfc-b852cc405912

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
