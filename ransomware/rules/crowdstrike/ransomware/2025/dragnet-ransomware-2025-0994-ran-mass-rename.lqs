// Dragnet [Ransomware]: dragnet-ransomware-2025-0994 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: d8735b6e-1d7a-58a5-937a-f3217ac41a70

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
