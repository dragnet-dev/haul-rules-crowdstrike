// Dragnet [Ransomware]: dragnet-ransomware-2025-0841 — Mass File Rename (nitrogen)
// Status: experimental | Level: high | ID: 4f277539-6739-5254-af74-0d5343205283

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
