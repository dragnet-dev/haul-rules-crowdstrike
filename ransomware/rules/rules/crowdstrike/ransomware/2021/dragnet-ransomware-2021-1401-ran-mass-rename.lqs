// Dragnet [Ransomware]: dragnet-ransomware-2021-1401 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 32f0ce8a-9e7b-566e-8dc4-a773ebfa6243

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
