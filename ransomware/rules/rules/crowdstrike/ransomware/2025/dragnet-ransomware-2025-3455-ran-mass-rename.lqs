// Dragnet [Ransomware]: dragnet-ransomware-2025-3455 — Mass File Rename (GDLockerSec)
// Status: experimental | Level: high | ID: df77d56d-8177-501c-b0d8-fa3a889e6cc7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
