// Dragnet [Ransomware]: dragnet-ransomware-2025-3783 — Mass File Rename (BrainCipher)
// Status: experimental | Level: high | ID: cac5a1bf-e0db-5e66-aa3e-b53c5a0b61a0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
