// Dragnet [Ransomware]: dragnet-ransomware-2025-5183 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: c9f4a599-56bd-5665-923f-e0f3211b72a1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
