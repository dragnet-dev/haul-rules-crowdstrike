// Dragnet [Ransomware]: dragnet-ransomware-2025-3345 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: f8fb4c54-5a18-547a-b64c-03e7c0004739

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
