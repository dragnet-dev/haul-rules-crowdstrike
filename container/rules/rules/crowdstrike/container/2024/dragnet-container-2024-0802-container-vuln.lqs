// Dragnet [Container]: dragnet-container-2024-0802 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 49100e94-76c7-5f88-b7f8-702aac43bb68

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:8* OR ImageFileName = *debian:9* OR ImageFileName = *ubuntu:18.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
