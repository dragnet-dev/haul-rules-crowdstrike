// Dragnet [Ransomware]: dragnet-ransomware-2022-0796 — Mass File Rename (everest)
// Status: deprecated | Level: high | ID: 2acf67be-2f5c-5fab-a5f9-f5ed643965d9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
