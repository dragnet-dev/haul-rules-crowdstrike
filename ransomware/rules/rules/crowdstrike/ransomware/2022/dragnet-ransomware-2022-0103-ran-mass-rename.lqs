// Dragnet [Ransomware]: dragnet-ransomware-2022-0103 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 23394623-c417-5e47-ac46-8ab96969b21f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
