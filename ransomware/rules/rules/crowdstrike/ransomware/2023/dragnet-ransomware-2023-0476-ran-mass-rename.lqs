// Dragnet [Ransomware]: dragnet-ransomware-2023-0476 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 262e5623-f4f4-5f59-afe7-57d6dfe2958f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
