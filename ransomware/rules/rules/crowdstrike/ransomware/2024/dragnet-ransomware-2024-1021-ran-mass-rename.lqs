// Dragnet [Ransomware]: dragnet-ransomware-2024-1021 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 49ca87d3-7df3-573f-8f45-b21e2adf8424

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
