// Dragnet [Ransomware]: dragnet-ransomware-2025-6030 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: 781d618d-60fc-5d67-9d46-173744b282c2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
