// Dragnet [Ransomware]: dragnet-ransomware-2023-1507 — Mass File Rename (rhysida)
// Status: experimental | Level: high | ID: 1f24af99-217f-5e5e-90c8-7f839e0ed9a5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
