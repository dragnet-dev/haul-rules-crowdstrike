// Dragnet [Ransomware]: dragnet-ransomware-2023-2205 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: a4202eff-b59b-556e-b3a1-86afb6d9da0b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
