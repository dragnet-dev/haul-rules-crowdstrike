// Dragnet [Ransomware]: dragnet-ransomware-2023-0297 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: c6fa5cd4-df0e-5b34-8b32-5a74ea5735ba

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
