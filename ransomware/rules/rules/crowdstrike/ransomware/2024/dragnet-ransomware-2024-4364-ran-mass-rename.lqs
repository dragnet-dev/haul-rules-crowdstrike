// Dragnet [Ransomware]: dragnet-ransomware-2024-4364 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: d108e673-3613-58e6-bfe0-2e0b3700e7d5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
