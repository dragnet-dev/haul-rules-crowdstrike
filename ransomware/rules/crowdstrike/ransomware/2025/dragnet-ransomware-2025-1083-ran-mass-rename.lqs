// Dragnet [Ransomware]: dragnet-ransomware-2025-1083 — Mass File Rename (spacebears)
// Status: experimental | Level: high | ID: 8bfed314-0646-5a53-b57a-8521feed59a1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
