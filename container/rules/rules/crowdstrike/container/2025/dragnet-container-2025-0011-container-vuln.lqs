// Dragnet [Container]: dragnet-container-2025-0011 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 7f3229fa-cf88-5839-ba9f-9abbbdb7f261

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:9*)
| table([timestamp, ComputerName])
| limit(1000)
