// Dragnet [Ransomware]: dragnet-ransomware-2024-0515 — Mass File Rename (cloak)
// Status: deprecated | Level: high | ID: ccc0249a-cd98-5ce1-9602-ee84e24683df

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
