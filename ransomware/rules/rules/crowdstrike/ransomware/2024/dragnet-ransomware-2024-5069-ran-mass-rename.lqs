// Dragnet [Ransomware]: dragnet-ransomware-2024-5069 — Mass File Rename (spacebears)
// Status: experimental | Level: high | ID: 13c70eed-29b7-5ed7-943e-fb89135b2bf3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
