// Dragnet [Ransomware]: dragnet-ransomware-2024-4559 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: fb3d9213-8978-50fc-96ee-a8822e9e403e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
