// Dragnet [Ransomware]: dragnet-ransomware-2025-7243 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 8da2dbd4-a61b-5cfb-a0aa-d3dbb826eb5f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
