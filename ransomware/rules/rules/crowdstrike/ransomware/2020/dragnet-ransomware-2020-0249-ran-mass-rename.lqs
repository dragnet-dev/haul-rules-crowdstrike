// Dragnet [Ransomware]: dragnet-ransomware-2020-0249 — Mass File Rename (ragnarlocker)
// Status: deprecated | Level: high | ID: 73810f89-63c8-52dc-93a4-629ebd5cc05c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
