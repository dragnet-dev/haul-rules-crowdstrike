// Dragnet [Ransomware]: dragnet-ransomware-2023-5065 — Mass File Rename (siegedsec)
// Status: experimental | Level: high | ID: fb6f2400-2cb2-54e7-8701-219182d33155

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
