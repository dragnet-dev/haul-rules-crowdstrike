// Dragnet [Ransomware]: dragnet-ransomware-2024-5103 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: bd653c4b-5d03-51cc-9b13-693986ad9f0b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
