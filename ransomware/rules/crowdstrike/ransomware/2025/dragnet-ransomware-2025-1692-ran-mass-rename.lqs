// Dragnet [Ransomware]: dragnet-ransomware-2025-1692 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 9ef3e6a0-7b31-555a-b2b7-5248b8d40426

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
