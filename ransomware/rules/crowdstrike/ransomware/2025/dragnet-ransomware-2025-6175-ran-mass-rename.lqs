// Dragnet [Ransomware]: dragnet-ransomware-2025-6175 — Mass File Rename (worldleaks)
// Status: experimental | Level: high | ID: 5298b3a3-f9db-53e3-993a-2a5b890af958

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
