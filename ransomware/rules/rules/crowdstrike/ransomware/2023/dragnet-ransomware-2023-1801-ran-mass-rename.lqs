// Dragnet [Ransomware]: dragnet-ransomware-2023-1801 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: cf10c619-cfad-508e-9c75-fd2c7070aac4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
