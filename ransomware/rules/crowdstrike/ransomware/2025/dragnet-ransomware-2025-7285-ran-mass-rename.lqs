// Dragnet [Ransomware]: dragnet-ransomware-2025-7285 — Mass File Rename (spacebears)
// Status: experimental | Level: high | ID: 0783985e-477c-5d99-93c6-df7f997c1e98

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
