// Dragnet [Ransomware]: dragnet-ransomware-2024-4230 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: aab33bd6-23a5-5c88-83db-6047ce6b24dd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
