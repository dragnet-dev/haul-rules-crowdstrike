// Dragnet [Container]: dragnet-container-2024-0320 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 8e94e754-9aa4-54cb-b34e-8d5c241ebf30

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:8* OR ImageFileName = *debian:9*)
| table([timestamp, ComputerName])
| limit(1000)
