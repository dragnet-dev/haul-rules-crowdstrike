// Dragnet [Ransomware]: dragnet-ransomware-2022-2516 — Mass File Rename (everest)
// Status: deprecated | Level: high | ID: a2af773d-12c9-5da4-a0b9-6d2c7ae09d47

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
