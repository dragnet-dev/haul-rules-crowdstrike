// Dragnet [Ransomware]: dragnet-ransomware-2025-2528 — Mass File Rename (pear)
// Status: experimental | Level: high | ID: 461c2c62-7494-5a8c-b702-18baccce873e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
