// Dragnet [Ransomware]: dragnet-ransomware-2023-4124 — Mass File Rename (threeam)
// Status: experimental | Level: high | ID: c8e6a93f-eafb-5194-b029-d8d615c8faff

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
