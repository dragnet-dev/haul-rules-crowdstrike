// Dragnet [Ransomware]: dragnet-ransomware-2022-2332 — Mass File Rename (suncrypt)
// Status: deprecated | Level: high | ID: bcfc15d8-5cee-523f-b918-22086ffe181d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
