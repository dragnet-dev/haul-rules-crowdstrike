// Dragnet [Ransomware]: dragnet-ransomware-2023-0095 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: c76ceefd-94d4-549f-bbb8-c9273b751a65

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
