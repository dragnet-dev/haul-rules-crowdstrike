// Dragnet [Ransomware]: dragnet-ransomware-2025-1104 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: 27cc3732-b410-52ad-a439-d9a6f50611c5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
