// Dragnet [Ransomware]: dragnet-ransomware-2025-7686 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: a67a2e0b-5b0d-5a25-b800-dd755aac5df0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
