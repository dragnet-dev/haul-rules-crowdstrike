// Dragnet [Ransomware]: dragnet-ransomware-2022-0818 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 51b53c41-49e3-5e03-b9a2-7169a6178bbd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
