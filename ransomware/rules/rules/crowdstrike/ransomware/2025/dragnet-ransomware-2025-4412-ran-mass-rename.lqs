// Dragnet [Ransomware]: dragnet-ransomware-2025-4412 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 6aa36f14-d9e5-5433-8841-f90febe312e4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
