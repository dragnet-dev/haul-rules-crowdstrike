// Dragnet [Ransomware]: dragnet-ransomware-2020-0114 — Mass File Rename (revil)
// Status: deprecated | Level: high | ID: a54dc9f8-c406-5d1a-b657-a6cbf9d6f3ab

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
