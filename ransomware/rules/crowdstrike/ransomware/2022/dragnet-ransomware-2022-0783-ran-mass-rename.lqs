// Dragnet [Ransomware]: dragnet-ransomware-2022-0783 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 718356ec-b291-5fb6-b801-22aff4dfba97

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
