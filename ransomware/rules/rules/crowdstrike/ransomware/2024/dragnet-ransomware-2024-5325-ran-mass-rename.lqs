// Dragnet [Ransomware]: dragnet-ransomware-2024-5325 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 0fb3ca12-3d94-566a-9851-5c6f79ef9c4e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
