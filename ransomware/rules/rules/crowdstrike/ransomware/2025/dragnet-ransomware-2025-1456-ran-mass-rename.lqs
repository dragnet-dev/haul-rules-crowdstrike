// Dragnet [Ransomware]: dragnet-ransomware-2025-1456 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: ff7a0317-27ee-557c-9968-d594285f9dbf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
