// Dragnet [Ransomware]: dragnet-ransomware-2025-1150 — Mass File Rename (worldleaks)
// Status: experimental | Level: high | ID: 39737cdf-d02d-552b-8536-3d473da5c8f3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
