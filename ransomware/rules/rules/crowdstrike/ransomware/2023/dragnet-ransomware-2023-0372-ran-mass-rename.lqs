// Dragnet [Ransomware]: dragnet-ransomware-2023-0372 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: a6fcd820-43d2-5434-908d-da0ca2627ad6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
