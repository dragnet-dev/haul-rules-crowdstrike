// Dragnet [Ransomware]: dragnet-ransomware-2025-6213 — Mass File Rename (play)
// Status: experimental | Level: high | ID: a73a8c14-e6a8-5c10-9888-e5854ea607f0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
