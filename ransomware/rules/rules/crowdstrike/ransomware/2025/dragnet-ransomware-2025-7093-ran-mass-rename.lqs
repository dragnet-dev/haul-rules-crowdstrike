// Dragnet [Ransomware]: dragnet-ransomware-2025-7093 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 97e234d9-2894-5ff1-ac6c-ffc2e5136fdf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
