// Dragnet [Ransomware]: dragnet-ransomware-2023-2293 — Mass File Rename (royal)
// Status: deprecated | Level: high | ID: bdb5fa9e-cc59-5cf2-ae3e-23fe075dfd26

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
