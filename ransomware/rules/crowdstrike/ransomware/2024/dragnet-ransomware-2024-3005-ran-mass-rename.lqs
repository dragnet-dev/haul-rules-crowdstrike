// Dragnet [Ransomware]: dragnet-ransomware-2024-3005 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 1728d94c-11b2-5292-ae28-516158d01311

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
