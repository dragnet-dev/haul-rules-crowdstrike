// Dragnet [Ransomware]: dragnet-ransomware-2024-1055 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: eb0cdb68-acf3-5ece-ba76-26dd817258ef

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
