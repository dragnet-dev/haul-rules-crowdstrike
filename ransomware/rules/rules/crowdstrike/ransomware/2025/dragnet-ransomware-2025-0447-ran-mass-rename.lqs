// Dragnet [Ransomware]: dragnet-ransomware-2025-0447 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 314aea73-7e37-51a6-a1c9-1be82d77b479

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
