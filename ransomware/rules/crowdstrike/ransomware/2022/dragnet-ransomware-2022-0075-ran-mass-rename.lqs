// Dragnet [Ransomware]: dragnet-ransomware-2022-0075 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 42f554d4-c1e5-52f6-868c-1856b192e9cd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
