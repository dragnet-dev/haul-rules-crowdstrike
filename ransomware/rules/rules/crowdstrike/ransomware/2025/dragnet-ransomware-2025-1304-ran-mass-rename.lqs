// Dragnet [Ransomware]: dragnet-ransomware-2025-1304 — Mass File Rename (direwolf)
// Status: experimental | Level: high | ID: a0dcc18b-6ec7-5714-a716-af75936bc3aa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
