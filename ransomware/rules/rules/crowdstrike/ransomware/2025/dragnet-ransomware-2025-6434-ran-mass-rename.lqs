// Dragnet [Ransomware]: dragnet-ransomware-2025-6434 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 00fd3f6d-b6df-599d-9b95-88f1edcdd948

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
