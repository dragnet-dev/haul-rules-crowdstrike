// Dragnet [Ransomware]: dragnet-ransomware-2025-1198 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 9a3a5b85-d358-570e-a4c6-e2f95bbf42cc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
