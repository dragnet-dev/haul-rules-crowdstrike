// Dragnet [Ransomware]: dragnet-ransomware-2022-2674 — Mass File Rename (dataleak)
// Status: deprecated | Level: high | ID: e658e512-b8a0-5893-844a-2c04de0cb4df

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
