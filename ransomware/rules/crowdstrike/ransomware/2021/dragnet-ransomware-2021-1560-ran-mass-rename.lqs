// Dragnet [Ransomware]: dragnet-ransomware-2021-1560 — Mass File Rename (suncrypt)
// Status: deprecated | Level: high | ID: 1c067826-0f00-5c04-849b-a02ca27f0d14

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
