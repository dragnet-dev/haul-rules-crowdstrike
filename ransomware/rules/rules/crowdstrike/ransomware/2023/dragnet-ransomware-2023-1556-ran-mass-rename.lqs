// Dragnet [Ransomware]: dragnet-ransomware-2023-1556 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 72e855b0-1213-5a06-8bac-c1f99184b40d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
