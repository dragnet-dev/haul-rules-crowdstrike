// Dragnet [Ransomware]: dragnet-ransomware-2025-5918 — Mass File Rename (tridentlocker)
// Status: experimental | Level: high | ID: 119a6f0c-4072-5f90-a8d8-1cae656975da

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
