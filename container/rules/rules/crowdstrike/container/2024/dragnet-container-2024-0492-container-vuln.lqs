// Dragnet [Container]: dragnet-container-2024-0492 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 7337ddd6-1a39-55bf-942c-dc7debc022b2

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *ubuntu:20.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
