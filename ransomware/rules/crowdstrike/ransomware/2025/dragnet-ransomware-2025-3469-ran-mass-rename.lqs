// Dragnet [Ransomware]: dragnet-ransomware-2025-3469 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: 0fe90b17-630a-58c1-8a09-e5c2f9d1d3f6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
