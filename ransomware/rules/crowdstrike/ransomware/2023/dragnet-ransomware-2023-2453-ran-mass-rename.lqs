// Dragnet [Ransomware]: dragnet-ransomware-2023-2453 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: c5bf2f8d-7dee-50a6-974d-17255fda1363

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
