// Dragnet [Ransomware]: dragnet-ransomware-2025-3367 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 32371f1a-43e5-56fd-ac72-a3b800a1d64f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
