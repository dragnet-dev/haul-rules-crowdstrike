// Dragnet [Ransomware]: dragnet-ransomware-2025-6941 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: c028d423-1a27-5451-8c3f-dd300fed7396

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
