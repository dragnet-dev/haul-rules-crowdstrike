// Dragnet [Ransomware]: dragnet-ransomware-2025-6656 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 6a40664a-4dfb-5035-a4b9-35d73b1ed7c3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
