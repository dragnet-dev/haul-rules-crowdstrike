// Dragnet [Ransomware]: dragnet-ransomware-2021-0243 — Mass File Rename (avaddon)
// Status: deprecated | Level: high | ID: 398a134b-7c54-57cc-87dd-6c2191ece06f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
