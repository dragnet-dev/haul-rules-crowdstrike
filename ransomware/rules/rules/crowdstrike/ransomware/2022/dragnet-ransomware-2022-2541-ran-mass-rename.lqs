// Dragnet [Ransomware]: dragnet-ransomware-2022-2541 — Mass File Rename (blackbasta)
// Status: deprecated | Level: high | ID: da2a4def-3a37-5eff-a60e-efe875f3e658

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
