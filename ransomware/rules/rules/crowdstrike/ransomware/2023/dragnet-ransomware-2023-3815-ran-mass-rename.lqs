// Dragnet [Ransomware]: dragnet-ransomware-2023-3815 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 79a46ca0-5c0f-5e60-8b95-382ed6e5ed18

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
