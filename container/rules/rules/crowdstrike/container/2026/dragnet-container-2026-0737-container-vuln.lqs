// Dragnet [Container]: dragnet-container-2026-0737 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 34ad36ff-1d77-5e10-9408-72fbb6718f58

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:5*)
| table([timestamp, ComputerName])
| limit(1000)
