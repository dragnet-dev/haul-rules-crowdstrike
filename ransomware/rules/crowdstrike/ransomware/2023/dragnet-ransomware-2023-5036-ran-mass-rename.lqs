// Dragnet [Ransomware]: dragnet-ransomware-2023-5036 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 6df707f7-186c-5b80-80f6-b037051194e0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
