// Dragnet [Ransomware]: dragnet-ransomware-2024-5367 — Mass File Rename (cloak)
// Status: deprecated | Level: high | ID: 8c3c7d8c-8cf5-5009-9ab0-71fb0d78cb69

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
