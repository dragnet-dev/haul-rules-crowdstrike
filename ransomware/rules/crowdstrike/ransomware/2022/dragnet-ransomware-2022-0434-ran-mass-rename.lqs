// Dragnet [Ransomware]: dragnet-ransomware-2022-0434 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 2ce6b0f3-2f22-5018-891c-2aae01e31467

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
