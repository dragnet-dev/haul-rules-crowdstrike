// Dragnet [Ransomware]: dragnet-ransomware-2025-3223 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 4d5ecd73-43b4-584f-a402-d16035b868a6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
