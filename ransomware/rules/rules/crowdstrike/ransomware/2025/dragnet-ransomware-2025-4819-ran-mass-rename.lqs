// Dragnet [Ransomware]: dragnet-ransomware-2025-4819 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: 43cc5ca6-081a-5a7b-bd45-0d0af915d4c8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
