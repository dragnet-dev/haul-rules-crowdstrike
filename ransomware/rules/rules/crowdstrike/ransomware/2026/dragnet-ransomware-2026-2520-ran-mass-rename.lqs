// Dragnet [Ransomware]: dragnet-ransomware-2026-2520 — Mass File Rename (incransom)
// Status: stable | Level: high | ID: f3f3cf4a-e0d8-5b4a-b115-965d0d3dc4d3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
