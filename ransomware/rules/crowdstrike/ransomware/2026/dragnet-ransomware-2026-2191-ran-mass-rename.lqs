// Dragnet [Ransomware]: dragnet-ransomware-2026-2191 — Mass File Rename (handala)
// Status: stable | Level: high | ID: a912e45d-329b-5fcb-aed6-77680862989d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
