// Dragnet [Ransomware]: dragnet-ransomware-2025-1274 — Mass File Rename (sinobi)
// Status: experimental | Level: high | ID: 7372b025-d59f-5c0f-b6ab-2f5ac312d0e6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
