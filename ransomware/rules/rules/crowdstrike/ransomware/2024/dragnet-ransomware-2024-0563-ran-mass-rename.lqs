// Dragnet [Ransomware]: dragnet-ransomware-2024-0563 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: a12deec6-139c-529d-8442-e71e10ff456d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
