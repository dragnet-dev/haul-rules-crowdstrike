// Dragnet [Ransomware]: dragnet-ransomware-2023-5197 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: cc58b8d8-56fe-5654-ae9a-8ff7fca8b633

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
