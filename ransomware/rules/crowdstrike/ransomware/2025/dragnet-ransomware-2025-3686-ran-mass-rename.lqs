// Dragnet [Ransomware]: dragnet-ransomware-2025-3686 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: c311ee6d-e80f-5f56-a22b-b52554b5ce82

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
