// Dragnet [Ransomware]: dragnet-ransomware-2022-0232 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: ee2cfd1c-71f5-51be-8e99-ac359defcc98

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
