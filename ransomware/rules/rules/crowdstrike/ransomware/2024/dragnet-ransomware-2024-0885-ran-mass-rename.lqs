// Dragnet [Ransomware]: dragnet-ransomware-2024-0885 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: af57898d-817b-5961-a7e5-381fd7d91e99

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
