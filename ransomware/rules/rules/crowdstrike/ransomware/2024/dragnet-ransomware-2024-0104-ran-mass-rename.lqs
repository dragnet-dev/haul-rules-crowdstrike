// Dragnet [Ransomware]: dragnet-ransomware-2024-0104 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 61901686-b6d4-5c54-90a6-3e4cbdf02145

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
