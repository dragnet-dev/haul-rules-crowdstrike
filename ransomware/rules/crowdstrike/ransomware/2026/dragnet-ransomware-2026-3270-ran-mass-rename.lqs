// Dragnet [Ransomware]: dragnet-ransomware-2026-3270 — Mass File Rename (sinobi)
// Status: stable | Level: high | ID: 4e9e63b1-6f53-57ca-8e96-a85b8d5b8392

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
