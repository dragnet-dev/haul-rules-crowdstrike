// Dragnet [Ransomware]: dragnet-ransomware-2024-5193 — Mass File Rename (darkvault)
// Status: experimental | Level: high | ID: 2aa6ed21-aad1-5f80-a63d-7f1c49003981

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
