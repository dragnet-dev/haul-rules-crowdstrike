// Dragnet [Ransomware]: dragnet-ransomware-2023-0147 — Mass File Rename (cyclops)
// Status: deprecated | Level: high | ID: e7cc500a-bf35-5f60-a7f1-b5efedc197b8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
