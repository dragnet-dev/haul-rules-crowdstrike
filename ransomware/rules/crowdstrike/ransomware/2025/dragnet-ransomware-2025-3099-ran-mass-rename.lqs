// Dragnet [Ransomware]: dragnet-ransomware-2025-3099 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 68abfb8f-9dd0-58bf-8586-76dd2a58a774

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
