// Dragnet [Ransomware]: dragnet-ransomware-2023-2865 — Mass File Rename (malas)
// Status: experimental | Level: high | ID: 9df0a5ae-c057-5908-b3bd-869d75fc2a72

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
