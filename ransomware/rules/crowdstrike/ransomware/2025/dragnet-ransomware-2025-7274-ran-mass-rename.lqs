// Dragnet [Ransomware]: dragnet-ransomware-2025-7274 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 16dd5d05-9811-5dbd-86ca-976e4f6c4d9a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
