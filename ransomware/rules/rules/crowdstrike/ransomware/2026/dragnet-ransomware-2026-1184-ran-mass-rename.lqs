// Dragnet [Ransomware]: dragnet-ransomware-2026-1184 — Mass File Rename (blacknevas)
// Status: stable | Level: high | ID: 617db669-1926-534c-84c2-655678f5b651

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
