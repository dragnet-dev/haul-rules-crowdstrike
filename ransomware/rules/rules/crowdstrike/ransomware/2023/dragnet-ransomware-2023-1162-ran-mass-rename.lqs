// Dragnet [Ransomware]: dragnet-ransomware-2023-1162 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 5d60b936-d54d-50f1-b405-79a6cccb2b77

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
