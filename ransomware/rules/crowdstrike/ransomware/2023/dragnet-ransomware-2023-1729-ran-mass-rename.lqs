// Dragnet [Ransomware]: dragnet-ransomware-2023-1729 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: aab3af66-a604-571f-9d3b-d45abf477621

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
