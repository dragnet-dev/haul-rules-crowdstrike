// Dragnet [Ransomware]: dragnet-ransomware-2024-0133 — Mass File Rename (cloak)
// Status: experimental | Level: high | ID: 422b3604-ad5b-5608-a234-c4e9898e1abf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
