// Dragnet [Container]: dragnet-container-2026-0144 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 497dc5ba-75af-5e1c-8aad-dbedf584754c

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
