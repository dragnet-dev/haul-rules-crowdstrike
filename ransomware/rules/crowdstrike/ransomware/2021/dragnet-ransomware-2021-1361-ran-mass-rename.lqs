// Dragnet [Ransomware]: dragnet-ransomware-2021-1361 — Mass File Rename (karma)
// Status: deprecated | Level: high | ID: 46485cd9-8878-535b-ae36-303c34799ceb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
