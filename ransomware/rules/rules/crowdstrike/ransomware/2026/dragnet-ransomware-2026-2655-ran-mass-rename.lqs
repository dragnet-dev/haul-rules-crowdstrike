// Dragnet [Ransomware]: dragnet-ransomware-2026-2655 — Mass File Rename (handala)
// Status: stable | Level: high | ID: ddaffb10-f12b-509d-8305-ed44b0cb856d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
