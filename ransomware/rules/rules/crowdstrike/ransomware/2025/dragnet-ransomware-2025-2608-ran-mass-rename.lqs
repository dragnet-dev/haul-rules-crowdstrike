// Dragnet [Ransomware]: dragnet-ransomware-2025-2608 — Mass File Rename (payoutsking)
// Status: test | Level: high | ID: 065bcb4a-75cf-5281-a1e7-dcebae427871

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
