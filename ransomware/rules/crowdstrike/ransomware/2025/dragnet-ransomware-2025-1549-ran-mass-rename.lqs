// Dragnet [Ransomware]: dragnet-ransomware-2025-1549 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 1c1e7749-72a8-5ff2-acad-313b146ab366

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
