// Dragnet [Ransomware]: dragnet-ransomware-2023-0882 — Mass File Rename (cuba)
// Status: experimental | Level: high | ID: a3860626-0d26-51e4-af0b-b96441d78013

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
