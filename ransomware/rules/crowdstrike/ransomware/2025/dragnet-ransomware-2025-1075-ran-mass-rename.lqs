// Dragnet [Ransomware]: dragnet-ransomware-2025-1075 — Mass File Rename (chaos)
// Status: experimental | Level: high | ID: 86f53e2c-3b86-574a-a28b-a748e771bfff

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
