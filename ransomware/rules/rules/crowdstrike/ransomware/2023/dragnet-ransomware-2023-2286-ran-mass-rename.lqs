// Dragnet [Ransomware]: dragnet-ransomware-2023-2286 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 7ed4e839-fbc5-5f5e-9769-1d469b6d5502

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
