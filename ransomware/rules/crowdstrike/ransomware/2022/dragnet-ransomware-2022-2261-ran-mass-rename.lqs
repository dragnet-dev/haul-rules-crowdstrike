// Dragnet [Ransomware]: dragnet-ransomware-2022-2261 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: e7aa2174-69cc-5880-9239-ff9140516f73

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
