// Dragnet [Ransomware]: dragnet-ransomware-2025-4383 — Mass File Rename (handala)
// Status: experimental | Level: high | ID: 1e275643-0866-54d3-9f49-9c52fababc0e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
