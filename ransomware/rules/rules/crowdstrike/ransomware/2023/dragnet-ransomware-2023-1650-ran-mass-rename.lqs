// Dragnet [Ransomware]: dragnet-ransomware-2023-1650 — Mass File Rename (meow)
// Status: experimental | Level: high | ID: b5e24fa8-740c-5d3e-a7c7-7f9743c69e7e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
