// Dragnet [Container]: dragnet-container-2026-0941 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: b7494d73-c8b2-5a2e-ae46-d9706dfb2fd3

#event_simpleName=*
| (ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10* OR ImageFileName = *ubuntu:13.04* OR ImageFileName = *ubuntu:13.10*)
| table([timestamp, ComputerName])
| limit(1000)
