// Dragnet [Ransomware]: dragnet-ransomware-2022-1561 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: 88b38747-e7a1-5c13-af23-0f0e77f4860d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
