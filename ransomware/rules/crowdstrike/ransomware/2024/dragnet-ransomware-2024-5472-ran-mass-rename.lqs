// Dragnet [Ransomware]: dragnet-ransomware-2024-5472 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 685c643f-32fb-5416-bccf-6791c9193c1d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
