// Dragnet [Container]: dragnet-container-2024-0319 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 025565cf-514c-5c00-b907-03f68fc7fe07

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:9* OR ImageFileName = *ubuntu:17.10*)
| table([timestamp, ComputerName])
| limit(1000)
