// Dragnet [Ransomware]: dragnet-ransomware-2021-0946 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 76c0799d-32a1-5ab5-b650-1845061a32f7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
