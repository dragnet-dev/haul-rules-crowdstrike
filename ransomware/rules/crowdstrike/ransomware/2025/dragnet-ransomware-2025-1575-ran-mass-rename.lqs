// Dragnet [Ransomware]: dragnet-ransomware-2025-1575 — Mass File Rename (interlock)
// Status: experimental | Level: high | ID: e9d1731a-d714-5372-b98f-a17a3bf9f871

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
