// Dragnet [Ransomware]: dragnet-ransomware-2025-2074 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: e3ffb8b5-013b-5f7a-b7db-36774bdd52d0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
