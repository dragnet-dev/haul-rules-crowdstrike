// Dragnet [Ransomware]: dragnet-ransomware-2021-1680 — Mass File Rename (marketo)
// Status: deprecated | Level: high | ID: 0aa5aa15-710c-5738-9890-59cd0dfdf954

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
