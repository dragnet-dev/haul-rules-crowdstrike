// Dragnet [Ransomware]: dragnet-ransomware-2025-7013 — Mass File Rename (securotrop)
// Status: experimental | Level: high | ID: ad860013-0f02-5af2-9a55-c7995e2e15ff

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
