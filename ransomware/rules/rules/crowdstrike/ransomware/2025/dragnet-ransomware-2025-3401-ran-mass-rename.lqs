// Dragnet [Ransomware]: dragnet-ransomware-2025-3401 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: c2526090-fe24-5fc0-885c-098c6acdeb18

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
