// Dragnet [Ransomware]: dragnet-ransomware-2024-2167 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 4cefaa97-fa42-51c5-a33d-fe99c16a0271

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
