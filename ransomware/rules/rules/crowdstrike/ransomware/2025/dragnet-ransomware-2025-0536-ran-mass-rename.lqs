// Dragnet [Ransomware]: dragnet-ransomware-2025-0536 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: ea809f1c-80a8-5618-a6c5-698ab33942a5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
