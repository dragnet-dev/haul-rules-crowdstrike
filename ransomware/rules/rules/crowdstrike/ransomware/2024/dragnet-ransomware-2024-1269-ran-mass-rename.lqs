// Dragnet [Ransomware]: dragnet-ransomware-2024-1269 — Mass File Rename (arcusmedia)
// Status: experimental | Level: high | ID: 327864bf-4a3d-5143-9fd4-baf5ab7dd0b9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
