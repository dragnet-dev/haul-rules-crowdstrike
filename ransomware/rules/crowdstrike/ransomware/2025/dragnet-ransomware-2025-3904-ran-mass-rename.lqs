// Dragnet [Ransomware]: dragnet-ransomware-2025-3904 — Mass File Rename (flocker)
// Status: experimental | Level: high | ID: f675213d-1811-5247-bb6a-1929651c2e5a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
