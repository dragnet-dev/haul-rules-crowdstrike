// Dragnet [Ransomware]: dragnet-ransomware-2025-7025 — Mass File Rename (kairos)
// Status: experimental | Level: high | ID: 7e9ae7da-1bb0-5b56-be13-ac2dd83788a5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
