// Dragnet [Ransomware]: dragnet-ransomware-2023-0001 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: bc3283bf-abec-5ce2-9a2f-2eb4619485a7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
