// Dragnet [Ransomware]: dragnet-ransomware-2021-1783 — Mass File Rename (revil)
// Status: deprecated | Level: high | ID: 64993ef5-a18f-5999-82b5-1f28a0b42328

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
