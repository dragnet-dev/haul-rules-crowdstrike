// Dragnet [Ransomware]: dragnet-ransomware-2023-1788 — Mass File Rename (nokoyawa)
// Status: experimental | Level: high | ID: 635b35f8-7054-5cbf-8384-ba508cf84a67

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
