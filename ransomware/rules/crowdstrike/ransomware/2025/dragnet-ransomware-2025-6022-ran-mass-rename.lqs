// Dragnet [Ransomware]: dragnet-ransomware-2025-6022 — Mass File Rename (lockbit5)
// Status: test | Level: high | ID: 30b8deae-c130-513d-ab4e-670a62c44b77

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
