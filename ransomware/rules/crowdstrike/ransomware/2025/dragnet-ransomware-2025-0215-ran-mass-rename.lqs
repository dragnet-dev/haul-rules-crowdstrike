// Dragnet [Ransomware]: dragnet-ransomware-2025-0215 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: afd146b7-0821-55f2-a5c0-58fef85d6cde

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
