// Dragnet [Ransomware]: dragnet-ransomware-2025-4433 — Mass File Rename (devman)
// Status: deprecated | Level: high | ID: 1ea0406b-20c1-598d-b3e6-9bb18375fcbd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
