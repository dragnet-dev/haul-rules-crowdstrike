// Dragnet [Ransomware]: dragnet-ransomware-2026-1153 — Mass File Rename (thegentlemen)
// Status: stable | Level: high | ID: c7cc5ab6-2069-5093-a8d9-16d1bb19cb81

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
