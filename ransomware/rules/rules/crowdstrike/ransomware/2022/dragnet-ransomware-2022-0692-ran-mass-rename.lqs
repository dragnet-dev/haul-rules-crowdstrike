// Dragnet [Ransomware]: dragnet-ransomware-2022-0692 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: ee2cd35c-ecb4-5da2-9f4f-bf9f67fefb0a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
