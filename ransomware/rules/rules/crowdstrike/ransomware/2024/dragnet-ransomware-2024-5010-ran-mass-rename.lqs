// Dragnet [Ransomware]: dragnet-ransomware-2024-5010 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 850d9ce3-1223-5dba-b753-34e1ce2007dd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
