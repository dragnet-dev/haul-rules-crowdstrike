// Dragnet [Ransomware]: dragnet-ransomware-2025-4085 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: fa1bf596-d845-5fb4-970e-fd2cd9ad0362

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
