// Dragnet [Ransomware]: dragnet-ransomware-2023-3731 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: fd677282-2524-5076-a8e6-f266ccd6a122

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
