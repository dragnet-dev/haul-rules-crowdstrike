// Dragnet [Container]: dragnet-container-2025-0541 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 8867e6c6-9009-5ba5-b566-de4640453f38

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:16.04* OR ImageFileName = *ubuntu:16.04-ESM* OR ImageFileName = *ubuntu:18.04* OR ImageFileName = *ubuntu:18.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
