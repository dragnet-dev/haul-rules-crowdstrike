// Dragnet [Ransomware]: dragnet-ransomware-2023-5133 — Mass File Rename (play)
// Status: deprecated | Level: high | ID: 8ca2161e-e6e8-5e9e-89a8-bf8cccf5920a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
