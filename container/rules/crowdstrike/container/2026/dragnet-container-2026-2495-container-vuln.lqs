// Dragnet [Container]: dragnet-container-2026-2495 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 358e2263-06d8-5e8a-b7c6-792d0701a258

#event_simpleName=*
| (ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *ubuntu:24.04* OR ImageFileName = *ubuntu:25.10* OR ImageFileName = *ubuntu:26.04*)
| table([timestamp, ComputerName])
| limit(1000)
