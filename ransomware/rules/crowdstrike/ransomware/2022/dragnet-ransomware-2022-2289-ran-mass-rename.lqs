// Dragnet [Ransomware]: dragnet-ransomware-2022-2289 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 5b5e1556-29d7-5a31-81fe-b38842512c2f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
