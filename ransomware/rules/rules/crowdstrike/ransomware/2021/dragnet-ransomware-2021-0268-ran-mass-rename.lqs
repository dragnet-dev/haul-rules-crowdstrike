// Dragnet [Ransomware]: dragnet-ransomware-2021-0268 — Mass File Rename (midas)
// Status: deprecated | Level: high | ID: 519f3292-c8f4-53d5-a0c5-7dd12640bf27

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
