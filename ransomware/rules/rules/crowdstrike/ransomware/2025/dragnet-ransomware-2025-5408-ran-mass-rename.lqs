// Dragnet [Ransomware]: dragnet-ransomware-2025-5408 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 23073559-4e00-572e-91e4-a133b19e44dc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
