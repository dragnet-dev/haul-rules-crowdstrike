// Dragnet [Ransomware]: dragnet-ransomware-2025-2363 — Mass File Rename (AiLock)
// Status: deprecated | Level: high | ID: ab8c9557-5988-559d-8d1c-b744421c86f0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
