// Dragnet [Ransomware]: dragnet-ransomware-2023-2850 — Mass File Rename (malas)
// Status: experimental | Level: high | ID: ddc7b61a-5f0f-5e87-93da-1e9b0c5be75e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
