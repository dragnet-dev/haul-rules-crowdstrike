// Dragnet [Ransomware]: dragnet-ransomware-2021-1350 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 71f40d6c-7275-52c4-9d20-75acd859ed2f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
