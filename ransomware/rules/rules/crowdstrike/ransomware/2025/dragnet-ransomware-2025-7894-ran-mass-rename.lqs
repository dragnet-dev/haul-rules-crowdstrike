// Dragnet [Ransomware]: dragnet-ransomware-2025-7894 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: b2793712-1e99-5c03-8f06-b9d4eadf20b6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
