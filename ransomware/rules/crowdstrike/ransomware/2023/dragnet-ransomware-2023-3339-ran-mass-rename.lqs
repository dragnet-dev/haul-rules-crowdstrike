// Dragnet [Ransomware]: dragnet-ransomware-2023-3339 — Mass File Rename (play)
// Status: experimental | Level: high | ID: a3bcd569-a6e6-5914-9555-d7e539fc9113

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
