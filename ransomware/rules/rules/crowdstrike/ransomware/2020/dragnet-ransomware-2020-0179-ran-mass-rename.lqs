// Dragnet [Ransomware]: dragnet-ransomware-2020-0179 — Mass File Rename (wastedlocker)
// Status: deprecated | Level: high | ID: b9d5bd09-b4da-55c2-b8aa-ae5203961895

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
