// Dragnet [Container]: dragnet-container-2026-1340 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: aeb0b048-64bb-5823-b091-021300defdec

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:7* OR ImageFileName = *debian:8*)
| table([timestamp, ComputerName])
| limit(1000)
