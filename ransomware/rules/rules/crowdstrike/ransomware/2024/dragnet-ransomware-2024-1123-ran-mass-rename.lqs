// Dragnet [Ransomware]: dragnet-ransomware-2024-1123 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: fa075a5d-a286-5b6d-8b45-dd9f14d8c367

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
