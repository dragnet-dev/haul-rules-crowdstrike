// Dragnet [Ransomware]: dragnet-ransomware-2025-0830 — Mass File Rename (blackshrantac)
// Status: experimental | Level: high | ID: 3f811299-91b0-5af9-b6ac-63e8577b4a44

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
