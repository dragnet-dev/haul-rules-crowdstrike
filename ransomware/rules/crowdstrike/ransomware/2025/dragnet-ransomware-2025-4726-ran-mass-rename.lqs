// Dragnet [Ransomware]: dragnet-ransomware-2025-4726 — Mass File Rename (play)
// Status: experimental | Level: high | ID: ed2ef9e2-b96f-546e-8059-85b659f227e6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
