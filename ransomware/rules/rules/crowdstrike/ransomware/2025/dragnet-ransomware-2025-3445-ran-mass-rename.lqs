// Dragnet [Ransomware]: dragnet-ransomware-2025-3445 — Mass File Rename (sinobi)
// Status: experimental | Level: high | ID: db986007-307a-5862-85ef-b32f75f71e15

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
