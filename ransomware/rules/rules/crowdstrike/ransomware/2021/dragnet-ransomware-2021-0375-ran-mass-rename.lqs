// Dragnet [Ransomware]: dragnet-ransomware-2021-0375 — Mass File Rename (midas)
// Status: deprecated | Level: high | ID: 7d8ecca2-c1c2-5279-9d57-c9703c69a9c1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
