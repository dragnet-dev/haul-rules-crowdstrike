// Dragnet [Ransomware]: dragnet-ransomware-2026-0795 — Mass File Rename (incransom)
// Status: stable | Level: high | ID: 57a93ac9-8004-50f2-92aa-909f59dc4a83

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
