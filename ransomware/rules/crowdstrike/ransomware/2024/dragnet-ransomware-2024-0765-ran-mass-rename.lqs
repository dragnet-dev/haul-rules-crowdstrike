// Dragnet [Ransomware]: dragnet-ransomware-2024-0765 — Mass File Rename (dragonransomware)
// Status: experimental | Level: high | ID: c34dfb41-64e8-5384-aa1a-1fe00826bd48

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
