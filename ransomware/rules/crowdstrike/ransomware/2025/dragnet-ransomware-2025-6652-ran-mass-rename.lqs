// Dragnet [Ransomware]: dragnet-ransomware-2025-6652 — Mass File Rename (blackshrantac)
// Status: experimental | Level: high | ID: c16ed85d-4a05-534f-bf2e-e3ab6306290b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
