// Dragnet [Container]: dragnet-container-2026-0365 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: f2e6492d-3805-58db-8a8c-ecba3d15473b

#event_simpleName=*
| (ImageFileName = *alpine edge:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
