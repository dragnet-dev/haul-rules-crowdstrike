// Dragnet [Ransomware]: dragnet-ransomware-2024-3496 — Mass File Rename (cloak)
// Status: deprecated | Level: high | ID: 0ce47ab3-1219-5312-85da-2cdb1dc18a7e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
