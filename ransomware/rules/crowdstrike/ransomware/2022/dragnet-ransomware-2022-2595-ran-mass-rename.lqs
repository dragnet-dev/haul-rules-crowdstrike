// Dragnet [Ransomware]: dragnet-ransomware-2022-2595 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 01454e14-4275-5a70-82c9-f5b1b099ee98

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
