// Dragnet [Ransomware]: dragnet-ransomware-2021-1468 — Mass File Rename (avaddon)
// Status: deprecated | Level: high | ID: 4e463f25-2b01-548a-ac4b-d5e03f35ba79

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
