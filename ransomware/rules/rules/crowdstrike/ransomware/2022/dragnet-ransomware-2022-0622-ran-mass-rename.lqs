// Dragnet [Ransomware]: dragnet-ransomware-2022-0622 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: d083991a-383e-5b52-96ed-d47bc0a6a72b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
