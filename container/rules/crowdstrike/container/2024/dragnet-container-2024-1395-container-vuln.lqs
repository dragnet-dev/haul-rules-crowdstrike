// Dragnet [Container]: dragnet-container-2024-1395 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 75ab147e-0a0f-51dd-be16-3da3d90020f0

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:7*)
| table([timestamp, ComputerName])
| limit(1000)
