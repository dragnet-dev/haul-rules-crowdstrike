// Dragnet [Ransomware]: dragnet-ransomware-2026-3209 — Mass File Rename (incransom)
// Status: stable | Level: high | ID: 41ef23da-77cf-5887-8d4b-e81d75d9d847

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
