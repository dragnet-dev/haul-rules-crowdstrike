// Dragnet [Ransomware]: dragnet-ransomware-2025-2174 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 3ed52c22-880a-5a2a-b4f0-bb424c011491

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
