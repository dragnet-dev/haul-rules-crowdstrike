// Dragnet [Ransomware]: dragnet-ransomware-2025-6572 — Mass File Rename (ransomhouse)
// Status: experimental | Level: high | ID: 1ff9ae82-3bed-5fbb-8b8f-e5b73e0b1d84

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
