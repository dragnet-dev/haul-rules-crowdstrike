// Dragnet [Ransomware]: dragnet-ransomware-2022-0440 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: aa7c858a-fafd-5c98-be06-07913e0841f5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
