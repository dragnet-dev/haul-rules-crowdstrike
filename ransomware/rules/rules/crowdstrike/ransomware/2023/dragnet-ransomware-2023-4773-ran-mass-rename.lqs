// Dragnet [Ransomware]: dragnet-ransomware-2023-4773 — Mass File Rename (rhysida)
// Status: experimental | Level: high | ID: 75ea8b9b-16a3-56d3-9241-3d9e4f640c19

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
