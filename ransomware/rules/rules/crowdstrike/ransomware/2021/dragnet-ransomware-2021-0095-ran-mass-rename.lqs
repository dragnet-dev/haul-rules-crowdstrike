// Dragnet [Ransomware]: dragnet-ransomware-2021-0095 — Mass File Rename (avaddon)
// Status: deprecated | Level: high | ID: 08298c8c-fde5-582e-b361-224376ab4215

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
