// Dragnet [Ransomware]: dragnet-ransomware-2022-1572 — Mass File Rename (lv)
// Status: deprecated | Level: high | ID: ba3b87d3-7ee1-5be4-9ea3-d08660802dde

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
