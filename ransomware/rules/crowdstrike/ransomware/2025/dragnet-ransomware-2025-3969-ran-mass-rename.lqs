// Dragnet [Ransomware]: dragnet-ransomware-2025-3969 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: 6498513d-d9c8-5089-8828-c2fc3579a584

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
