// Dragnet [Ransomware]: dragnet-ransomware-2025-6815 — Mass File Rename (worldleaks)
// Status: experimental | Level: high | ID: a629eb4c-e4f3-5735-ac5a-4b1dcfe508c1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
