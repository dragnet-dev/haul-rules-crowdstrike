// Dragnet [Ransomware]: dragnet-ransomware-2022-1362 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 643466d3-c810-5ae7-bd38-05f8434df8dc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
