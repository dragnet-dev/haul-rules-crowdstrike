// Dragnet [Ransomware]: dragnet-ransomware-2024-3652 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: fe8e5699-f584-51a3-90a2-882ae64b4aa9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
