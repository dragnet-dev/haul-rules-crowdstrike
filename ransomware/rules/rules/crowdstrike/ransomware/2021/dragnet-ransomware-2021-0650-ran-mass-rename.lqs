// Dragnet [Ransomware]: dragnet-ransomware-2021-0650 — Mass File Rename (avaddon)
// Status: deprecated | Level: high | ID: 5f1d984f-a88f-53b7-84d7-0244f87a5b61

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
