// Dragnet [Ransomware]: dragnet-ransomware-2025-3386 — Mass File Rename (sinobi)
// Status: experimental | Level: high | ID: fe318126-e5d6-53eb-8c96-b7e768c9fa5d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
