// Dragnet [Container]: dragnet-container-2025-0503 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 694c7e60-b649-5fbd-8074-0003d3e58280

#event_simpleName=*
| (ImageFileName = *azure linux:3.0* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
