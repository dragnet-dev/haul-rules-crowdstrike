// Dragnet [Ransomware]: dragnet-ransomware-2025-0591 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: 3d9dd510-6fd4-5b56-ad06-a0e9b808959a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
