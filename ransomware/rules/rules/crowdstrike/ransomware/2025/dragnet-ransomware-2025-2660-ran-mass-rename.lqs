// Dragnet [Ransomware]: dragnet-ransomware-2025-2660 — Mass File Rename (devman)
// Status: deprecated | Level: high | ID: 4b4c8fbe-bfa8-516b-b168-2d98fc3b0cf2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
