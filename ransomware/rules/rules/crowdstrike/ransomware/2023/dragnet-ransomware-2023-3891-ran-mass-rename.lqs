// Dragnet [Ransomware]: dragnet-ransomware-2023-3891 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: 70b02395-8ca6-5a81-9351-16680397de2e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
