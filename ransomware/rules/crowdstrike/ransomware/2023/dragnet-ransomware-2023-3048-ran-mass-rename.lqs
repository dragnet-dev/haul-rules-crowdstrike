// Dragnet [Ransomware]: dragnet-ransomware-2023-3048 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: d12e088e-1eb1-5dce-b900-7e56fd8969b2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
