// Dragnet [Ransomware]: dragnet-ransomware-2024-1080 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 52722e6e-1528-57f4-8f71-efd153a07bf7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
