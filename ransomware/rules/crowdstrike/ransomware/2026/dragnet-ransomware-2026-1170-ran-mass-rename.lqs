// Dragnet [Ransomware]: dragnet-ransomware-2026-1170 — Mass File Rename (thegentlemen)
// Status: stable | Level: high | ID: da0179b8-5f24-5fab-b0a2-f6a220eab966

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
