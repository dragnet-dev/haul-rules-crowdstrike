// Dragnet [Ransomware]: dragnet-ransomware-2024-4512 — Mass File Rename (cloak)
// Status: deprecated | Level: high | ID: 9678b296-45e0-59e7-8b25-8ab9103d14f1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
