// Dragnet [Ransomware]: dragnet-ransomware-2023-4051 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 057e78e9-aec0-5578-b14a-a88d144420fd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
