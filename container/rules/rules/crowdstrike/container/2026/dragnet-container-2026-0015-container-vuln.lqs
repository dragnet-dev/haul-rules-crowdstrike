// Dragnet [Container]: dragnet-container-2026-0015 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: e7dc99e9-9b34-5be3-a3da-467c1fc6dabb

#event_simpleName=*
| (ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10* OR ImageFileName = *ubuntu:13.04*)
| table([timestamp, ComputerName])
| limit(1000)
