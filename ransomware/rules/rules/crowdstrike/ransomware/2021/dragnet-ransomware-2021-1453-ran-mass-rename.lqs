// Dragnet [Ransomware]: dragnet-ransomware-2021-1453 — Mass File Rename (darkside)
// Status: deprecated | Level: high | ID: 7739a0f9-8d53-5356-9d6b-a183854520f1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
