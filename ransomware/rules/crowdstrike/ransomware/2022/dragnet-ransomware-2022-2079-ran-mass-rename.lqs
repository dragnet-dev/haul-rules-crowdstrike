// Dragnet [Ransomware]: dragnet-ransomware-2022-2079 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 03cdf034-259a-567a-83f2-325755c28bc1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
