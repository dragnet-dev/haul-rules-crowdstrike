// Dragnet [Ransomware]: dragnet-ransomware-2022-0078 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: d796af6f-ad84-5e1e-93d9-d55eb71ecf93

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
