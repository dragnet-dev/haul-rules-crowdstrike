// Dragnet [Ransomware]: dragnet-ransomware-2025-0027 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: e281ffe8-ddc0-50ae-8a7e-1efeab72e635

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
