// Dragnet [Ransomware]: dragnet-ransomware-2024-0586 — Mass File Rename (arcusmedia)
// Status: experimental | Level: high | ID: 8b57f328-edd1-5604-8190-59342139682f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
