// Dragnet [Ransomware]: dragnet-ransomware-2022-2605 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: eb3ba2f1-1c3a-5281-90fa-0b1cae533deb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
