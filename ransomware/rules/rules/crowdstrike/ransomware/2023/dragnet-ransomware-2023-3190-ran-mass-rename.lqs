// Dragnet [Ransomware]: dragnet-ransomware-2023-3190 — Mass File Rename (monti)
// Status: experimental | Level: high | ID: 31170276-33c5-5ce6-a2ed-6ab34276d8d1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
