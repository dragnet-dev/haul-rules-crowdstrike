// Dragnet [Ransomware]: dragnet-ransomware-2022-3139 — Mass File Rename (mallox)
// Status: deprecated | Level: high | ID: 8587db88-df68-552f-944f-6a795e16108a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
