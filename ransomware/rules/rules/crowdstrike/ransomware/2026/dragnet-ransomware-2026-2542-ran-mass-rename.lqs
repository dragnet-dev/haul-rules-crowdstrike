// Dragnet [Ransomware]: dragnet-ransomware-2026-2542 — Mass File Rename (vect)
// Status: deprecated | Level: high | ID: 9aeb4a7a-dbff-5f4f-87f9-3236cc864aaf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
