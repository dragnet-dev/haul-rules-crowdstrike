// Dragnet [Ransomware]: dragnet-ransomware-2022-2555 — Mass File Rename (lv)
// Status: deprecated | Level: high | ID: c22623b5-da54-564c-ab2c-1a6e080af04e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
