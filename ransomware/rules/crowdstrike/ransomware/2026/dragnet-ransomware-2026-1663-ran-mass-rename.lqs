// Dragnet [Ransomware]: dragnet-ransomware-2026-1663 — Mass File Rename (tridentlocker)
// Status: test | Level: high | ID: 40914635-4614-5306-90e0-d3c192682ecd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
