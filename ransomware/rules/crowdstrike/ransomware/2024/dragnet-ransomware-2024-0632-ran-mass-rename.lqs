// Dragnet [Ransomware]: dragnet-ransomware-2024-0632 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: dd0f5f07-47bb-51f1-8c3c-4171e1146375

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
