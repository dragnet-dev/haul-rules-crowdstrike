// Dragnet [Ransomware]: dragnet-ransomware-2025-4657 — Mass File Rename (play)
// Status: experimental | Level: high | ID: a32d7767-8cee-5f67-a06f-268472b0b086

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
