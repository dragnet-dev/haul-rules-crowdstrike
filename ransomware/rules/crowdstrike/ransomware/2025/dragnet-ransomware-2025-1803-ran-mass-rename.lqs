// Dragnet [Ransomware]: dragnet-ransomware-2025-1803 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 4a3afb3d-22fc-5c5a-974a-803c9fdbc633

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
