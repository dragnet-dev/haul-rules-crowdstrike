// Dragnet [Ransomware]: dragnet-ransomware-2025-7464 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 0e7db47f-3500-5f07-b269-733070c6d2ba

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
