// Dragnet [Ransomware]: dragnet-ransomware-2024-6004 — Mass File Rename (arcusmedia)
// Status: experimental | Level: high | ID: 612efc23-7cef-54dc-a292-790bde3971dd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
