// Dragnet [Ransomware]: dragnet-ransomware-2024-5937 — Mass File Rename (interlock)
// Status: experimental | Level: high | ID: bc7fce9e-e487-51bb-8aa3-d9214193466a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
