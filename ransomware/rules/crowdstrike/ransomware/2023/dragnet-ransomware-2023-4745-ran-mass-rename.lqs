// Dragnet [Ransomware]: dragnet-ransomware-2023-4745 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: ddbe13fe-ac4c-5c03-9a92-96a6b3f89127

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
