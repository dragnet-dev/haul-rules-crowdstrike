// Dragnet [Ransomware]: dragnet-ransomware-2023-3384 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: fda5878c-0528-550a-8ff1-1e1c204549f5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
