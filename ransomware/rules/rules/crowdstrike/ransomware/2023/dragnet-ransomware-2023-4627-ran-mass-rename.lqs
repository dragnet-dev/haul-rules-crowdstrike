// Dragnet [Ransomware]: dragnet-ransomware-2023-4627 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 3ebd3688-3c69-5d79-96e0-fa7f459b6c28

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
