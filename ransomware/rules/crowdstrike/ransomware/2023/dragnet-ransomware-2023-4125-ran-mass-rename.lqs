// Dragnet [Ransomware]: dragnet-ransomware-2023-4125 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 601f49e3-24f3-58b3-b693-1b745291bf7a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
