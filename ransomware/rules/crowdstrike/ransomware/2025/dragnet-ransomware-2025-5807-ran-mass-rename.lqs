// Dragnet [Ransomware]: dragnet-ransomware-2025-5807 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 446f2560-ca0a-5998-98b0-be78eb7a7340

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
