// Dragnet [Ransomware]: dragnet-ransomware-2024-4269 — Mass File Rename (knight)
// Status: experimental | Level: high | ID: 2b8196fe-5920-5e38-90e5-2887be328f94

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
