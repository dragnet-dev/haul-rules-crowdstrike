// Dragnet [Container]: dragnet-container-2026-1108 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 6ce93f7b-abe2-5b37-a67a-80467fa012cf

#event_simpleName=*
| (ImageFileName = *amazonlinux:2023* OR ImageFileName = *chainguard:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
