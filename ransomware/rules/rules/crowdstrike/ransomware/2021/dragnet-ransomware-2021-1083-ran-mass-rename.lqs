// Dragnet [Ransomware]: dragnet-ransomware-2021-1083 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: a9b9e822-5dd4-572a-887b-5ed84b9dd2aa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
