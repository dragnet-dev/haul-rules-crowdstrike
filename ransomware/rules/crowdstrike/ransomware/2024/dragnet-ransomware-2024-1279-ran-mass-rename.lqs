// Dragnet [Ransomware]: dragnet-ransomware-2024-1279 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 399f953b-1ae2-56c7-918b-04f43504fb58

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
