// Dragnet [Ransomware]: dragnet-ransomware-2023-5236 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: e5e9423e-e09c-57c0-bfa9-858a22444b9c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
