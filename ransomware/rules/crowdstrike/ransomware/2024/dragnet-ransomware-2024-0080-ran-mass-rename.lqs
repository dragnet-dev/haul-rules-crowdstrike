// Dragnet [Ransomware]: dragnet-ransomware-2024-0080 — Mass File Rename (underground)
// Status: experimental | Level: high | ID: 632e786c-3944-5ddc-8a99-4c132d585c83

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
