// Dragnet [Ransomware]: dragnet-ransomware-2025-6943 — Mass File Rename (nightspire)
// Status: deprecated | Level: high | ID: e34bc4c4-6f07-5fb7-b8a5-384d7c3d67cc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
