// Dragnet [Ransomware]: dragnet-ransomware-2023-3798 — Mass File Rename (werewolves)
// Status: experimental | Level: high | ID: 6f8d6b8b-df72-5467-9c98-4d61aaa56b96

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
