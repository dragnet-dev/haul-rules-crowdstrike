// Dragnet [Ransomware]: dragnet-ransomware-2024-4094 — Mass File Rename (play)
// Status: experimental | Level: high | ID: ccb87f28-f956-5dca-af4f-cd775293e2b1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
