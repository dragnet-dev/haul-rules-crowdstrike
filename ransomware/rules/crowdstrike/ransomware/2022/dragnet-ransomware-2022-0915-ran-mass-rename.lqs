// Dragnet [Ransomware]: dragnet-ransomware-2022-0915 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 2ade91b8-0e8d-58b7-8ca3-e0f0beb2e066

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
