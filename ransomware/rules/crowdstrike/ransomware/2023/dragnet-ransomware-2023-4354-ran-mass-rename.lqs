// Dragnet [Ransomware]: dragnet-ransomware-2023-4354 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 9708906d-5b50-5d56-905a-ba2a44dd6e0a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
