// Dragnet [Ransomware]: dragnet-ransomware-2025-4530 — Mass File Rename (blackshrantac)
// Status: experimental | Level: high | ID: 1ee18cee-620d-54af-b302-9ca93b002ea2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
