// Dragnet [Ransomware]: dragnet-ransomware-2026-0692 — Mass File Rename (vect)
// Status: deprecated | Level: high | ID: d49504fb-55ef-55bf-b04c-7358c4928694

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
