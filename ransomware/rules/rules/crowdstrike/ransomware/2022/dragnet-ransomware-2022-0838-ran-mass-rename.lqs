// Dragnet [Ransomware]: dragnet-ransomware-2022-0838 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: aebb200f-8f4f-5c8e-94de-a4d1299bb135

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
