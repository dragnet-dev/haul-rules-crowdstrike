// Dragnet [Ransomware]: dragnet-ransomware-2025-5436 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: c37374d4-1415-5f4f-af65-0731ca97fff7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
