// Dragnet [Ransomware]: dragnet-ransomware-2023-4469 — Mass File Rename (trigona)
// Status: deprecated | Level: high | ID: d5d3a848-1aa3-5977-a820-ddfe5febaa34

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
