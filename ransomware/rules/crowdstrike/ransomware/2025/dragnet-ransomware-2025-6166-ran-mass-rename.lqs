// Dragnet [Ransomware]: dragnet-ransomware-2025-6166 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: c19a3e83-9ae0-5550-a809-4d6f993504ef

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
