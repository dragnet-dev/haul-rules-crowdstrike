// Dragnet [Ransomware]: dragnet-ransomware-2025-5027 — Mass File Rename (gunra)
// Status: experimental | Level: high | ID: 533e1764-0c83-59bf-8e2f-5f9c6d39d573

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
