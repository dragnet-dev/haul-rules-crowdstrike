// Dragnet [Ransomware]: dragnet-ransomware-2022-0549 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 72d2ebc1-17b5-51d7-b54b-1174258485a4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
