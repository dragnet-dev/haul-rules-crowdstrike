// Dragnet [Ransomware]: dragnet-ransomware-2022-2597 — Mass File Rename (royal)
// Status: deprecated | Level: high | ID: fdc7cd44-b150-5f6b-9ef7-e9374ad15b5a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
