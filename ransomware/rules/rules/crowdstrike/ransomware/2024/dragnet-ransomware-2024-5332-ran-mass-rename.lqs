// Dragnet [Ransomware]: dragnet-ransomware-2024-5332 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 65108828-7620-57bc-b80f-918ca23540ba

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
