// Dragnet [Ransomware]: dragnet-ransomware-2025-1521 — Mass File Rename (J)
// Status: experimental | Level: high | ID: b5da9ef2-3616-5e1a-8fce-532c48fbd023

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
