// Dragnet [Ransomware]: dragnet-ransomware-2024-1749 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: b077c2d6-05db-5acb-88d1-c907146c9553

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
