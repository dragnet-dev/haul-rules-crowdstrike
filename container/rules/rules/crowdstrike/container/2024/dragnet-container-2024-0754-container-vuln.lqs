// Dragnet [Container]: dragnet-container-2024-0754 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: f8e515d8-aafc-5e4d-97da-76a037647e70

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:9*)
| table([timestamp, ComputerName])
| limit(1000)
