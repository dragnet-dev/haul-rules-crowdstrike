// Dragnet [Ransomware]: dragnet-ransomware-2024-0822 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 7a1e8e59-d80b-5bda-bf10-605df0e3ad21

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
