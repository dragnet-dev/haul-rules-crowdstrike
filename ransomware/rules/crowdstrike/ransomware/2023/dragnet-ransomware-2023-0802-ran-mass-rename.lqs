// Dragnet [Ransomware]: dragnet-ransomware-2023-0802 — Mass File Rename (stormous)
// Status: experimental | Level: high | ID: 45c0b0a8-67a6-53a5-b87d-f79d710420a1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
