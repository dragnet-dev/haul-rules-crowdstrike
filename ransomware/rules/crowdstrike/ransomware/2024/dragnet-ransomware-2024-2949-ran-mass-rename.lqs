// Dragnet [Ransomware]: dragnet-ransomware-2024-2949 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 9f49bb1e-be2f-5f46-8a57-8f5bd94bd6cf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
