// Dragnet [Ransomware]: dragnet-ransomware-2025-1505 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: a615d3a6-1a8e-5101-a60f-a7edfc3ae7e8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
