// Dragnet [Ransomware]: dragnet-ransomware-2023-2957 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: d13d332b-f3ee-5e2d-8f9e-c62ea299cc85

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
