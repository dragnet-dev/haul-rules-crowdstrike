// Dragnet [Ransomware]: dragnet-ransomware-2022-1069 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: a09530f7-d3d6-58e0-b149-9478a3090872

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
