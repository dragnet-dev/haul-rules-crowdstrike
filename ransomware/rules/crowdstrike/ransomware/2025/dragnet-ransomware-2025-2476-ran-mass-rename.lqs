// Dragnet [Ransomware]: dragnet-ransomware-2025-2476 — Mass File Rename (thegentlemen)
// Status: experimental | Level: high | ID: c516569f-277a-5a24-b9d8-e1bf6e465600

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
