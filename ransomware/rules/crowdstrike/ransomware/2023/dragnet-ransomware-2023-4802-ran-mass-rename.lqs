// Dragnet [Ransomware]: dragnet-ransomware-2023-4802 — Mass File Rename (play)
// Status: experimental | Level: high | ID: f5330243-7f13-5812-8c05-75f109d883be

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
