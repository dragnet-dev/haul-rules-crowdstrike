// Dragnet [Ransomware]: dragnet-ransomware-2025-0031 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 1db4934a-b415-5e60-9b59-24cb651bcce8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
