// Dragnet [Ransomware]: dragnet-ransomware-2026-2192 — Mass File Rename (nightspire)
// Status: deprecated | Level: high | ID: 9e4b0899-b4e6-5cf1-b593-899e29f312f2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
