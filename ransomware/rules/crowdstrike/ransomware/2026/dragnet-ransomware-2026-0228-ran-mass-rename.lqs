// Dragnet [Ransomware]: dragnet-ransomware-2026-0228 — Mass File Rename (incransom)
// Status: stable | Level: high | ID: d1200007-277f-5075-92d7-7698d7fb6d76

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
