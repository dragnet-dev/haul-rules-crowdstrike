// Dragnet [Ransomware]: dragnet-ransomware-2023-4289 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 1f2955d3-cba1-5b15-889b-2cae562cb0e0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
