// Dragnet [Ransomware]: dragnet-ransomware-2024-4854 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 8fab544b-bdb3-5bb1-aba0-ddb50ae506c1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
