// Dragnet [Ransomware]: dragnet-ransomware-2023-4312 — Mass File Rename (monti)
// Status: experimental | Level: high | ID: 5a3a2664-f150-5e64-a0fc-3e245001d7c8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
