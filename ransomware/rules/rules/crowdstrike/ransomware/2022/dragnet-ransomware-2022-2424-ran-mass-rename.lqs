// Dragnet [Ransomware]: dragnet-ransomware-2022-2424 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: b0450c26-ca0c-53ed-970b-62dd4cd37a51

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
