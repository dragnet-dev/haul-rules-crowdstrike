// Dragnet [Ransomware]: dragnet-ransomware-2024-0802 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 75bfd3a1-a278-5ddc-bca8-63e3572da511

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
