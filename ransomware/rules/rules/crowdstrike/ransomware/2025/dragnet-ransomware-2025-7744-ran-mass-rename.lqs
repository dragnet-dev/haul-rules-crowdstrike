// Dragnet [Ransomware]: dragnet-ransomware-2025-7744 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 6b89be8c-fdeb-50a0-83f1-9ec221f7a7e3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
