// Dragnet [Ransomware]: dragnet-ransomware-2025-4610 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: ae254d2f-a9af-5650-bf51-5173897e6d80

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
