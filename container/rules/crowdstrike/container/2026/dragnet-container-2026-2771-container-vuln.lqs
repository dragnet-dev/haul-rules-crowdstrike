// Dragnet [Container]: dragnet-container-2026-2771 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 4cd6a0a5-b29a-5383-b950-7d310f65fb6c

#event_simpleName=*
| (ImageFileName = *alpine edge:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
