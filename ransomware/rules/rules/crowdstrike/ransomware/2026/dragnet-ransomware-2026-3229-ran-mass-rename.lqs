// Dragnet [Ransomware]: dragnet-ransomware-2026-3229 — Mass File Rename (incransom)
// Status: stable | Level: high | ID: 46723787-e20a-5c4f-b9ce-bb4d0210d274

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
