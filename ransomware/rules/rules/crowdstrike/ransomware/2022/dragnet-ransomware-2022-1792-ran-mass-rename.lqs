// Dragnet [Ransomware]: dragnet-ransomware-2022-1792 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 7783778e-163c-55cb-9985-b9b9bb01d9f0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
