// Dragnet [Ransomware]: dragnet-ransomware-2025-4018 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 4909924b-ca8c-5a86-9023-98d947ab9c9c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
