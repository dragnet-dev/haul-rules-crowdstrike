// Dragnet [Ransomware]: dragnet-ransomware-2026-2220 — Mass File Rename (incransom)
// Status: stable | Level: high | ID: 8cb0f9f3-a8f6-5c8d-b2dd-6ef4109b158e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
