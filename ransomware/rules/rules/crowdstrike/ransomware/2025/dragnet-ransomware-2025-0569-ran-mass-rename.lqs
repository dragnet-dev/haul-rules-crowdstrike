// Dragnet [Ransomware]: dragnet-ransomware-2025-0569 — Mass File Rename (spacebears)
// Status: experimental | Level: high | ID: 782e8858-d369-55c4-8705-1b95ba24a334

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
