// Dragnet [Ransomware]: dragnet-ransomware-2022-2844 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: e06e855b-c1ac-5835-9f4f-b05960ad13ff

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
