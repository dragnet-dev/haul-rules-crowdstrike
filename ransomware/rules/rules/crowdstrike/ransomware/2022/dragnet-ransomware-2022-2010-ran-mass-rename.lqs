// Dragnet [Ransomware]: dragnet-ransomware-2022-2010 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: d3c2f49c-e675-5166-b675-2ea653eee99a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
