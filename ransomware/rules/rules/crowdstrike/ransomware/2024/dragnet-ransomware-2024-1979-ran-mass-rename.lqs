// Dragnet [Ransomware]: dragnet-ransomware-2024-1979 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 8ca54fdb-4e98-5fe4-a17e-458a4aa3c3fb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
