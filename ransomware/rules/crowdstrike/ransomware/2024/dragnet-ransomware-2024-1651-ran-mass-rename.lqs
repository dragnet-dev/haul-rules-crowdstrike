// Dragnet [Ransomware]: dragnet-ransomware-2024-1651 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: b3bb8c3f-79f4-54ba-be21-3b7989ac6378

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
