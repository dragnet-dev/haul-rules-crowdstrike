// Dragnet [Ransomware]: dragnet-ransomware-2022-2825 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 0e92c008-9798-593f-a93d-63d52e1bc47a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
