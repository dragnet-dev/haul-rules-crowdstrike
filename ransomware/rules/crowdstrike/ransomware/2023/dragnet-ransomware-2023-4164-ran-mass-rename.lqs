// Dragnet [Ransomware]: dragnet-ransomware-2023-4164 — Mass File Rename (ransomhouse)
// Status: experimental | Level: high | ID: f99fc43c-ed06-5e16-a611-4dd7b6bc48fc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
