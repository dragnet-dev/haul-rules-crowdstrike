// Dragnet [Ransomware]: dragnet-ransomware-2025-3587 — Mass File Rename (interlock)
// Status: test | Level: high | ID: e03b523f-598d-5618-a607-045c3d18da84

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
