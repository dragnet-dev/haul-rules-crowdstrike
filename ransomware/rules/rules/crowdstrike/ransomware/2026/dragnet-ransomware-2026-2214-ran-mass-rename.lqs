// Dragnet [Ransomware]: dragnet-ransomware-2026-2214 — Mass File Rename (medusalocker)
// Status: stable | Level: high | ID: 13aa0423-85af-54a1-9f36-b3d0bddae483

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
