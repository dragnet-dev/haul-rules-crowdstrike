// Dragnet [Ransomware]: dragnet-ransomware-2024-1167 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: ab5a687c-1f36-5794-a2dd-b52a89c319c6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
