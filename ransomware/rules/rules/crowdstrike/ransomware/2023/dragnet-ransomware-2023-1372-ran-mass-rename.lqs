// Dragnet [Ransomware]: dragnet-ransomware-2023-1372 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 5b399e4f-c788-592c-a5f9-ae0131473fdb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
