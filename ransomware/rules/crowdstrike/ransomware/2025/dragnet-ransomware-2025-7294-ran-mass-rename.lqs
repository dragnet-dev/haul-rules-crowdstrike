// Dragnet [Ransomware]: dragnet-ransomware-2025-7294 — Mass File Rename (SilentRansomGroup)
// Status: deprecated | Level: high | ID: e5d56e7f-6176-5fe6-9b24-89ed522205cb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
