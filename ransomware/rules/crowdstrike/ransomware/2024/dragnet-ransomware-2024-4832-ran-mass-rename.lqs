// Dragnet [Ransomware]: dragnet-ransomware-2024-4832 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 7f14fd60-e899-5261-83d5-942c12dd0b79

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
