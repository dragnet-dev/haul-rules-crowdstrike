// Dragnet [Ransomware]: dragnet-ransomware-2025-2110 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 35cd2a09-4c92-59ba-b090-445fad12f13d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
