// Dragnet [Ransomware]: dragnet-ransomware-2026-0028 — Mass File Rename (BrainCipher)
// Status: stable | Level: high | ID: 1f4be15d-5c9c-5bc0-a3b5-36089c3b9bea

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
