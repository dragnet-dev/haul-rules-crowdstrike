// Dragnet [Ransomware]: dragnet-ransomware-2022-3044 — Mass File Rename (cuba)
// Status: deprecated | Level: high | ID: 054c1042-113b-513a-badf-c56257f31d80

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
