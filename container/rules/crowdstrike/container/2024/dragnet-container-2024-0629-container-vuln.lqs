// Dragnet [Container]: dragnet-container-2024-0629 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 12f643ce-dc22-563d-ad48-e7915056d466

#event_simpleName=*
| (ImageFileName = *amazonlinux:1* OR ImageFileName = *amazonlinux:2* OR ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *oraclelinux:7* OR ImageFileName = *redhat/ubi9:*)
| table([timestamp, ComputerName])
| limit(1000)
