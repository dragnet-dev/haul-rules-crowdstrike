// Dragnet [Ransomware]: dragnet-ransomware-2026-2339 — Mass File Rename (handala)
// Status: stable | Level: high | ID: d62437eb-7415-56bb-ac3e-ff67f90f1c0e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
