// Dragnet [Ransomware]: dragnet-ransomware-2025-7788 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 68720bd2-e9f8-5497-8dc5-75c7e262f544

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
