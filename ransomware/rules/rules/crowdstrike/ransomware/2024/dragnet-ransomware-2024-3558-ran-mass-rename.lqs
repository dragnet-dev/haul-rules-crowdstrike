// Dragnet [Ransomware]: dragnet-ransomware-2024-3558 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 851c9cd6-c7cc-541e-9bed-f55b391aa0f7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
