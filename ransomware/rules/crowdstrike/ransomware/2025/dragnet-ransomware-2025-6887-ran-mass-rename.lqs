// Dragnet [Ransomware]: dragnet-ransomware-2025-6887 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: ed589873-5eda-596c-b13b-03a433fee6b7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
