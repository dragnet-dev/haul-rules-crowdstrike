// Dragnet [Ransomware]: dragnet-ransomware-2025-5353 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 5e56a580-f83c-5053-ac26-dbf25daa81d7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
