// Dragnet [Ransomware]: dragnet-ransomware-2025-5808 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 6f9a9d38-4098-5013-8fd4-5155f3fbefc7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
