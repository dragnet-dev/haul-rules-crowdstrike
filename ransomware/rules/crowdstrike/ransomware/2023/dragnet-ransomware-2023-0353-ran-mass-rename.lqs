// Dragnet [Ransomware]: dragnet-ransomware-2023-0353 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 47a17b38-dfc1-5ae7-8a9f-5a0e07b78ee8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
