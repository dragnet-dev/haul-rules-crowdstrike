// Dragnet [Ransomware]: dragnet-ransomware-2023-4763 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 2993f940-baa5-591e-915a-c95373f7add9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
