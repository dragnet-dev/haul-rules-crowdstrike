// Dragnet [Container]: dragnet-container-2025-0652 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: eda94e58-8b9b-5a86-a72e-f064a9828320

#event_simpleName=*
| (ImageFileName = *chainguard:* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *ubuntu:24.04* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
