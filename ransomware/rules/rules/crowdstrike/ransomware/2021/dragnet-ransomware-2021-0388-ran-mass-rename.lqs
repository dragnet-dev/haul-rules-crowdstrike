// Dragnet [Ransomware]: dragnet-ransomware-2021-0388 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 38bf6ed6-a190-507d-9c32-f1da34eb3167

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
