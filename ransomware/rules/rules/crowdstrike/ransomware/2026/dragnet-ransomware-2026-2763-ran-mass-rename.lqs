// Dragnet [Ransomware]: dragnet-ransomware-2026-2763 — Mass File Rename (aurora)
// Status: stable | Level: high | ID: 42048b83-7eb0-5fa7-8341-015d821ba055

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
