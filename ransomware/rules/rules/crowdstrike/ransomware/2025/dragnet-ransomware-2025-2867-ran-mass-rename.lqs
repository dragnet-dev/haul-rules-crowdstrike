// Dragnet [Ransomware]: dragnet-ransomware-2025-2867 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: ea6594d9-d23e-5cdc-8486-0ae980ad8220

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
