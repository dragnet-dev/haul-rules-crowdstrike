// Dragnet [Container]: dragnet-container-2025-0066 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: e8b93cf8-6a7e-5069-8370-cab07784b1bf

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
