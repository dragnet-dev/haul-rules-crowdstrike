// Dragnet [Ransomware]: dragnet-ransomware-2022-2167 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: b73255cd-b93d-5c08-97ce-495e3f83867d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
