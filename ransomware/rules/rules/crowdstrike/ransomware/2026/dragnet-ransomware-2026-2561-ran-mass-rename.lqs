// Dragnet [Ransomware]: dragnet-ransomware-2026-2561 — Mass File Rename (dragonforce)
// Status: stable | Level: high | ID: ef6dc30d-6d05-5525-9b27-5f161ffa7b9d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
