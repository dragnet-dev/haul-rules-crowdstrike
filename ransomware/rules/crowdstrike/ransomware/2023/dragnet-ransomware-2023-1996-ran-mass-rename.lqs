// Dragnet [Ransomware]: dragnet-ransomware-2023-1996 — Mass File Rename (karakurt)
// Status: experimental | Level: high | ID: c79999b3-0f55-5c89-9214-bc8526683aab

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
