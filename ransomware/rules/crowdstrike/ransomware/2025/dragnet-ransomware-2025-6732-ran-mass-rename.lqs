// Dragnet [Ransomware]: dragnet-ransomware-2025-6732 — Mass File Rename (coinbasecartel)
// Status: experimental | Level: high | ID: c91be00a-b5f5-5695-aea6-68b413d52b36

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
