// Dragnet [Ransomware]: dragnet-ransomware-2024-2388 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 97f98aff-866a-5ff8-8255-e93fd52e0752

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
