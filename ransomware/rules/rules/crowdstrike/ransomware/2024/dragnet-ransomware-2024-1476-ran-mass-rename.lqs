// Dragnet [Ransomware]: dragnet-ransomware-2024-1476 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 659d9220-c752-5935-806d-c0c743fcbb70

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
