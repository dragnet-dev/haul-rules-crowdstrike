// Dragnet [Ransomware]: dragnet-ransomware-2024-0377 — Mass File Rename (play)
// Status: experimental | Level: high | ID: a037cb7c-16d5-5aa5-beb3-7f6285c1eca1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
