// Dragnet [Ransomware]: dragnet-ransomware-2025-6089 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 3509a3cd-2134-581f-8f69-3749200f153a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
