// Dragnet [Ransomware]: dragnet-ransomware-2025-0732 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 91d3e65f-c5d8-513c-9e6d-673c8fc72679

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
