// Dragnet [Ransomware]: dragnet-ransomware-2022-1535 — Mass File Rename (everest)
// Status: deprecated | Level: high | ID: e5bfb444-3cfc-51b5-bea2-21dabc702d7e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
