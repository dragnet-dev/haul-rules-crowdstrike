// Dragnet [Ransomware]: dragnet-ransomware-2023-0286 — Mass File Rename (cloak)
// Status: deprecated | Level: high | ID: 3c4ed931-e1a2-5b39-ab6b-925beee2431f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
