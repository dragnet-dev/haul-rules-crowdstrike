// Dragnet [Ransomware]: dragnet-ransomware-2024-4264 — Mass File Rename (safepay)
// Status: deprecated | Level: high | ID: 435e79cd-34a0-548d-879e-3b1b753b84ce

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
