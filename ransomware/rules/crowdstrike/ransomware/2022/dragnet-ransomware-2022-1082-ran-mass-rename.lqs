// Dragnet [Ransomware]: dragnet-ransomware-2022-1082 — Mass File Rename (everest)
// Status: deprecated | Level: high | ID: ca0f4a22-9736-5f0f-a6a1-009bc13a7f69

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
