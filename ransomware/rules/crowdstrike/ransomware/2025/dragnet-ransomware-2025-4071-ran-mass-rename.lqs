// Dragnet [Ransomware]: dragnet-ransomware-2025-4071 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: ebe4bf06-7d50-58e6-a3a4-c923448fab96

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
