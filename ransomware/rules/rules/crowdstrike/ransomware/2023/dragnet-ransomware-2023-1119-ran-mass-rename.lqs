// Dragnet [Ransomware]: dragnet-ransomware-2023-1119 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 4e81dae8-bbac-5bc9-a966-85b01fcc2156

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
