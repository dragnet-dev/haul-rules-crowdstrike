// Dragnet [Ransomware]: dragnet-ransomware-2025-2990 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 46f64459-83d8-58ed-abb1-d8bff9ae0f94

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
