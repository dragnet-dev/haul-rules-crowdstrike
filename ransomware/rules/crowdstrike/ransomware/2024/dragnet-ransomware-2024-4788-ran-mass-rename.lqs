// Dragnet [Ransomware]: dragnet-ransomware-2024-4788 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 20420444-a2ba-58ec-83ad-f42dca8670a2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
