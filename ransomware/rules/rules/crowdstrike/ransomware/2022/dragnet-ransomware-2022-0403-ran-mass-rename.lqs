// Dragnet [Ransomware]: dragnet-ransomware-2022-0403 — Mass File Rename (blackbasta)
// Status: deprecated | Level: high | ID: 27968ced-08c8-5a82-89c6-3de6465d7166

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
