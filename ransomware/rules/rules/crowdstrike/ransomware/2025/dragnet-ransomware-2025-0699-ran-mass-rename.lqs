// Dragnet [Ransomware]: dragnet-ransomware-2025-0699 — Mass File Rename (devman)
// Status: experimental | Level: high | ID: ec7011dd-e60b-58be-8429-66ad93990ab5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
