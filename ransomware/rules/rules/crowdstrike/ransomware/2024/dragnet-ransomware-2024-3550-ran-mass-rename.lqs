// Dragnet [Ransomware]: dragnet-ransomware-2024-3550 — Mass File Rename (threeam)
// Status: experimental | Level: high | ID: e794367b-18ac-5d39-b2a3-ba4c67971efc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
