// Dragnet [Container]: dragnet-container-2026-2225 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: b92648a2-ffdd-5955-93ec-95421b307411

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:6*)
| table([timestamp, ComputerName])
| limit(1000)
