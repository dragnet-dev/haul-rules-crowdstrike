// Dragnet [Ransomware]: dragnet-ransomware-2023-3401 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 0888b167-fa91-5d29-b595-b580e18c2722

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
