// Dragnet [Ransomware]: dragnet-ransomware-2023-4070 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 9515cb91-7b9f-53af-8a69-d8b1fe80bac5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
