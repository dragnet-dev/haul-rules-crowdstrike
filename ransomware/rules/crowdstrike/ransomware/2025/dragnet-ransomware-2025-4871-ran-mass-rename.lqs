// Dragnet [Ransomware]: dragnet-ransomware-2025-4871 — Mass File Rename (play)
// Status: experimental | Level: high | ID: a0ffb0ff-799c-57bc-8d43-7ddc6436e696

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
