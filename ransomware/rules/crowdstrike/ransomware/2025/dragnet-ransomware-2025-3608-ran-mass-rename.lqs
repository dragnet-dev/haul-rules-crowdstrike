// Dragnet [Ransomware]: dragnet-ransomware-2025-3608 — Mass File Rename (warlock)
// Status: deprecated | Level: high | ID: 51db614f-998a-52d2-b183-0d4ca3692ec3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
