// Dragnet [Ransomware]: dragnet-ransomware-2025-0934 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 818866e2-9b22-5a8c-9deb-493a6afdbac9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
