// Dragnet [Ransomware]: dragnet-ransomware-2022-0462 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 2ec5fbcc-97f2-58e4-bef8-4e088f3e2633

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
