// Dragnet [Ransomware]: dragnet-ransomware-2024-1277 — Mass File Rename (safepay)
// Status: deprecated | Level: high | ID: 19798327-029c-5cca-a805-62d02ef1d1f9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
