// Dragnet [Ransomware]: dragnet-ransomware-2023-1167 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 601b6ba3-3855-5c9e-b7c3-94e380541d7c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
