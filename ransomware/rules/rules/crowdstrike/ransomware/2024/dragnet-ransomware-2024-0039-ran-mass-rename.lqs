// Dragnet [Ransomware]: dragnet-ransomware-2024-0039 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 78657923-c0e1-5d11-bee7-736e740a4a5a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
