// Dragnet [Ransomware]: dragnet-ransomware-2025-5907 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 0ab1bb1b-d1cb-56bf-a6cb-9f001c72e916

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
