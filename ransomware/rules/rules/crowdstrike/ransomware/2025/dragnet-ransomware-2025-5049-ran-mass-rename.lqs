// Dragnet [Ransomware]: dragnet-ransomware-2025-5049 — Mass File Rename (coinbasecartel)
// Status: test | Level: high | ID: 557e2be7-7ece-5a0b-b189-718213d36ca1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
