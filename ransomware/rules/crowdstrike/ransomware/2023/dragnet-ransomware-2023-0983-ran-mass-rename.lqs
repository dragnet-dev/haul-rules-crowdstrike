// Dragnet [Ransomware]: dragnet-ransomware-2023-0983 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 78575fbb-1e54-5ebf-892a-1901ddaba006

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
