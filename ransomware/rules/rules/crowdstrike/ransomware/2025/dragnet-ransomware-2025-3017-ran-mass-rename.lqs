// Dragnet [Ransomware]: dragnet-ransomware-2025-3017 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 511d343d-fd3c-5d04-993f-16779c3efbba

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
