// Dragnet [Ransomware]: dragnet-ransomware-2025-7864 — Mass File Rename (direwolf)
// Status: experimental | Level: high | ID: e776ab2b-d4f5-5be2-b406-6c9b970bc115

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
