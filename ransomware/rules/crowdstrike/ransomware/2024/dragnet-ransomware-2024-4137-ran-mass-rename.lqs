// Dragnet [Ransomware]: dragnet-ransomware-2024-4137 — Mass File Rename (raworld)
// Status: experimental | Level: high | ID: 1942836b-b613-5038-86d4-26493b12a776

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
