// Dragnet [Ransomware]: dragnet-ransomware-2023-2416 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: e3deb5b4-8024-5125-85d2-875adec8c35e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
