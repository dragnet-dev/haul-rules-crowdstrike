// Dragnet [Ransomware]: dragnet-ransomware-2025-7562 — Mass File Rename (nova)
// Status: experimental | Level: high | ID: a265136b-c960-5e48-b21a-644baccbccfe

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
