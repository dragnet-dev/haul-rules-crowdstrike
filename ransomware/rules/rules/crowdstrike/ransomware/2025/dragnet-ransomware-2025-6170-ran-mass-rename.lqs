// Dragnet [Ransomware]: dragnet-ransomware-2025-6170 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 7955b8da-a0ce-5ab4-8d61-4cac981c3ab3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
