// Dragnet [Ransomware]: dragnet-ransomware-2025-3175 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: d1526897-d254-58bd-920a-c0ffae0c36a8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
