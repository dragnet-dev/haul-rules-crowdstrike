// Dragnet [Container]: dragnet-container-2026-0345 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: ffc57e0d-ef33-5834-8147-c2238e7dc5d7

#event_simpleName=*
| (ImageFileName = *debian:7* OR ImageFileName = *debian:8* OR ImageFileName = *ubuntu:14.04* OR ImageFileName = *ubuntu:16.04* OR ImageFileName = *ubuntu:16.04-ESM* OR ImageFileName = *ubuntu:16.10*)
| table([timestamp, ComputerName])
| limit(1000)
