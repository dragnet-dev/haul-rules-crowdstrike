// Dragnet [Ransomware]: dragnet-ransomware-2021-0740 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: f9ed56e7-ace0-5fb6-b3aa-f5036260558e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
