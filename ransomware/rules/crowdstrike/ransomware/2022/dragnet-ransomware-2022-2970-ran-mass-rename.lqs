// Dragnet [Ransomware]: dragnet-ransomware-2022-2970 — Mass File Rename (royal)
// Status: deprecated | Level: high | ID: 5d0205a2-d3a9-5f24-a0b5-e8f855a09b80

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
