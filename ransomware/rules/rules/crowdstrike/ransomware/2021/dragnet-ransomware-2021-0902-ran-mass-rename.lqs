// Dragnet [Ransomware]: dragnet-ransomware-2021-0902 — Mass File Rename (lv)
// Status: deprecated | Level: high | ID: 47091a58-21a2-555f-8710-3ea229e1147d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
