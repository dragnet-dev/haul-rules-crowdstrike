// Dragnet [Ransomware]: dragnet-ransomware-2022-1832 — Mass File Rename (blackbasta)
// Status: deprecated | Level: high | ID: 8a1a7a83-d740-5e1d-a7e7-af86b90c7053

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
