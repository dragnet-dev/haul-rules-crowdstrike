// Dragnet [Ransomware]: dragnet-ransomware-2025-0457 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: b68bd0ed-fd3d-5abc-b80d-42c2ea12c73e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
