// Dragnet [Ransomware]: dragnet-ransomware-2022-1497 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 1b6c9b0a-7c22-51be-96b2-737681a0ed45

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
