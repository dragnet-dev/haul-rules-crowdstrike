// Dragnet [Ransomware]: dragnet-ransomware-2023-0846 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 4b8927d4-bf24-5a16-8d5f-416dd79cb664

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
