// Dragnet [Ransomware]: dragnet-ransomware-2023-4383 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 7bc73c35-a619-50f8-ae3b-5665cbcc237b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
