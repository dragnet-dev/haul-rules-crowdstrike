// Dragnet [Ransomware]: dragnet-ransomware-2024-0460 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 2f592e4d-a5a8-5224-bb85-28b75e70a2e5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
