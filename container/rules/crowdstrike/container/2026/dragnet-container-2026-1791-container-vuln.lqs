// Dragnet [Container]: dragnet-container-2026-1791 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 7db360ed-ac50-5c70-9567-a8646cc05fe8

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
