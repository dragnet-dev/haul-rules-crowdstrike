// Dragnet [Ransomware]: dragnet-ransomware-2023-0877 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 0750c2a6-8a3a-5265-9cda-8b104ffb0bcb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
