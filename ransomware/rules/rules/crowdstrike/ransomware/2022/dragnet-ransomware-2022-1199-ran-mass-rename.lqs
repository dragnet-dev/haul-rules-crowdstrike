// Dragnet [Ransomware]: dragnet-ransomware-2022-1199 — Mass File Rename (play)
// Status: deprecated | Level: high | ID: 61ea0dfa-9513-5981-adc9-c06e20375013

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
