// Dragnet [Container]: dragnet-container-2026-2434 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 3284f515-68b8-5b8a-b0e4-499d89d11786

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:5*)
| table([timestamp, ComputerName])
| limit(1000)
