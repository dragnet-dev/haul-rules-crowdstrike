// Dragnet [Ransomware]: dragnet-ransomware-2021-0779 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: ed04b327-83c8-55a2-ba2f-cddc9d04f67b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
