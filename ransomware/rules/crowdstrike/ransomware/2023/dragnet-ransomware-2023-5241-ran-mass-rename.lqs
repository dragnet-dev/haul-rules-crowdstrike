// Dragnet [Ransomware]: dragnet-ransomware-2023-5241 — Mass File Rename (abyss)
// Status: deprecated | Level: high | ID: b31ea519-7775-54b4-adc7-29cf9e6915d8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
