// Dragnet [Ransomware]: dragnet-ransomware-2021-1500 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 866b7538-6f7f-5c96-bafc-31a4d60c90b2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
