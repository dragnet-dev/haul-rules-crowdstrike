// Dragnet [Ransomware]: dragnet-ransomware-2024-2249 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 6396fdcf-e2cf-50fe-a500-b96da0acd62d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
