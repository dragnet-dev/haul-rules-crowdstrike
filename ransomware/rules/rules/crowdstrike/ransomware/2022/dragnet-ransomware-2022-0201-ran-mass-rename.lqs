// Dragnet [Ransomware]: dragnet-ransomware-2022-0201 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 0104017d-6623-5771-826d-01ac4b05bcfc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
