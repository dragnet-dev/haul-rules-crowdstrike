// Dragnet [Ransomware]: dragnet-ransomware-2023-3987 — Mass File Rename (royal)
// Status: deprecated | Level: high | ID: 35605aa7-e76b-57c8-afe9-ce0a74ab2642

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
