// Dragnet [Ransomware]: dragnet-ransomware-2024-2767 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 53f1ee56-36f9-525c-9654-df77c0bf832b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
