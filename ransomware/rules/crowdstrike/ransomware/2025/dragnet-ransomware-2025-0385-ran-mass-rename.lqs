// Dragnet [Ransomware]: dragnet-ransomware-2025-0385 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: a7d6de51-5ff0-5adf-ae27-4bdc50f4b665

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
