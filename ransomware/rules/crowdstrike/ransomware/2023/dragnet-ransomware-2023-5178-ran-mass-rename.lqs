// Dragnet [Ransomware]: dragnet-ransomware-2023-5178 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: e277f844-0396-5b28-a614-2487b6020485

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
