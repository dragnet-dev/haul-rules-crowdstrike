// Dragnet [Ransomware]: dragnet-ransomware-2025-7395 — Mass File Rename (embargo)
// Status: experimental | Level: high | ID: 33b72bcb-aa39-5cf4-ba03-c57dcb8f2865

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
