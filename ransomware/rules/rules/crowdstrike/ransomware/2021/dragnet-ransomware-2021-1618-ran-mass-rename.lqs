// Dragnet [Ransomware]: dragnet-ransomware-2021-1618 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 08073cf3-2f31-5d8e-8284-5e9d7cf42e1f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
