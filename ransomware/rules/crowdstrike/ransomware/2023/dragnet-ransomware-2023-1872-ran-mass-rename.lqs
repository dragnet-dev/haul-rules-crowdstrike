// Dragnet [Ransomware]: dragnet-ransomware-2023-1872 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 4467779c-39a3-5c67-a1ab-d7d15b598c18

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
