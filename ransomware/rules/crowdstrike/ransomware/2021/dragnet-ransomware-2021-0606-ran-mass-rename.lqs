// Dragnet [Ransomware]: dragnet-ransomware-2021-0606 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 235d7aa3-b677-5d6f-9f3a-cdb144d2734b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
