// Dragnet [Ransomware]: dragnet-ransomware-2025-2569 — Mass File Rename (rhysida)
// Status: deprecated | Level: high | ID: ae13efa0-9ab9-5fee-8553-2a64112e8b2d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
