// Dragnet [Ransomware]: dragnet-ransomware-2024-2219 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: 4fb4bc40-be15-56ab-9f68-cd607f0ab8da

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
