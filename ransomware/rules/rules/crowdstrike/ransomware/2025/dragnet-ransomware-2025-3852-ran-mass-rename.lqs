// Dragnet [Ransomware]: dragnet-ransomware-2025-3852 — Mass File Rename (play)
// Status: experimental | Level: high | ID: c119fdd3-e99b-5277-b328-a9dcd40737f3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
