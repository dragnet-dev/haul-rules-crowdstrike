// Dragnet [Ransomware]: dragnet-ransomware-2022-0371 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 51ec24b5-d7b1-5867-9604-9d838b256029

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
