// Dragnet [Ransomware]: dragnet-ransomware-2024-5397 — Mass File Rename (cloak)
// Status: deprecated | Level: high | ID: 428c7f0e-0461-502b-8135-3b15b7e44439

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
