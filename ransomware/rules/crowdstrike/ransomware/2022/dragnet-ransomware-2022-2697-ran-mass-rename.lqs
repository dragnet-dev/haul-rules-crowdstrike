// Dragnet [Ransomware]: dragnet-ransomware-2022-2697 — Mass File Rename (lv)
// Status: deprecated | Level: high | ID: cdc72471-f8d8-53b1-bd07-dc87ad489459

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
