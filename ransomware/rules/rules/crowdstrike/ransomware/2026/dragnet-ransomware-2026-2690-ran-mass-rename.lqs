// Dragnet [Ransomware]: dragnet-ransomware-2026-2690 — Mass File Rename (lockbit5)
// Status: stable | Level: high | ID: 234f24f0-d61f-5418-a9a3-53b863ac67fd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
