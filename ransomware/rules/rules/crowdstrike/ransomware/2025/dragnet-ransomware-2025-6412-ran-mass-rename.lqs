// Dragnet [Ransomware]: dragnet-ransomware-2025-6412 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 35c44989-c00b-5a0b-bc8d-6fa350ff414e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
