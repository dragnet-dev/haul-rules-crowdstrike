// Dragnet [Ransomware]: dragnet-ransomware-2023-3353 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 261e3796-4d13-5d6a-99af-f2238aa9f0f6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
