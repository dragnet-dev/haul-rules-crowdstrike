// Dragnet [Ransomware]: dragnet-ransomware-2024-3394 — Mass File Rename (play)
// Status: experimental | Level: high | ID: e2fdc90b-b1c2-50e9-bc67-0461be54a5a0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
