// Dragnet [Ransomware]: dragnet-ransomware-2023-3966 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 1f793bc2-e42f-5e6a-af4a-98fb790ee81b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
