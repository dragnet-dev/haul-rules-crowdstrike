// Dragnet [Ransomware]: dragnet-ransomware-2023-0186 — Mass File Rename (donutleaks)
// Status: experimental | Level: high | ID: 6eb1e87b-46b8-5ba5-ac12-59aa2e04ce95

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
