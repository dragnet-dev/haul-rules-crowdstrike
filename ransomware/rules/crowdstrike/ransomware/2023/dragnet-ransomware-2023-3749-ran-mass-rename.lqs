// Dragnet [Ransomware]: dragnet-ransomware-2023-3749 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 28e86c0a-d44f-5186-93aa-627935f9ee85

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
