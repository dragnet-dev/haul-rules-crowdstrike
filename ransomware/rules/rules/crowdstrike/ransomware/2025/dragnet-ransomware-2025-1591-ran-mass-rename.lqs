// Dragnet [Ransomware]: dragnet-ransomware-2025-1591 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: b9dbf7c7-7592-5c3b-b04f-9beb491571dc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
