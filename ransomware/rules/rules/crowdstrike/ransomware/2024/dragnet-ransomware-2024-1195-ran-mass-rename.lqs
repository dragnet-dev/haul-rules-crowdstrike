// Dragnet [Ransomware]: dragnet-ransomware-2024-1195 — Mass File Rename (nitrogen)
// Status: experimental | Level: high | ID: 4c646c8b-315f-5dc7-9b75-db3a18034ece

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
