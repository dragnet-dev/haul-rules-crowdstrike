// Dragnet [Ransomware]: dragnet-ransomware-2025-6804 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 83f52aca-3766-5ac3-8d86-4d1f5ecf4985

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
