// Dragnet [Ransomware]: dragnet-ransomware-2022-1359 — Mass File Rename (vicesociety)
// Status: deprecated | Level: high | ID: d23f72e5-8c12-5345-8b14-8c954b3b24bd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
