// Dragnet [Ransomware]: dragnet-ransomware-2023-0608 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 580325f4-d79d-5426-945f-952262ba8595

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
