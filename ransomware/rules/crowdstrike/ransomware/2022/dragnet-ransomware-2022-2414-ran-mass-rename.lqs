// Dragnet [Ransomware]: dragnet-ransomware-2022-2414 — Mass File Rename (kelvinsecurity)
// Status: deprecated | Level: high | ID: 9bf8f672-8d4d-54e7-b130-26078c9ddf9f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
