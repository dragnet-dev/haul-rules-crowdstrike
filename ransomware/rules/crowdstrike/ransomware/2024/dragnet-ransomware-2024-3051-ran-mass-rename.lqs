// Dragnet [Ransomware]: dragnet-ransomware-2024-3051 — Mass File Rename (ElDorado)
// Status: deprecated | Level: high | ID: 042dba8c-a3d2-5c38-9a6d-1867dbc82666

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
