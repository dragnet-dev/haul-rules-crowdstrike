// Dragnet [Ransomware]: dragnet-ransomware-2024-0121 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 5f618667-2b33-5ec9-b57e-4fe5d6cc4e0c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
