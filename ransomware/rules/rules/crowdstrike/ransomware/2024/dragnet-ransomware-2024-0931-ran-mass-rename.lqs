// Dragnet [Ransomware]: dragnet-ransomware-2024-0931 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 1eeec618-a91c-532e-80fc-17e877098a2c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
