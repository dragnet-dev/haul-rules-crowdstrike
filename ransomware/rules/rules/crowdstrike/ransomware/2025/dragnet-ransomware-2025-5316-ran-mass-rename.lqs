// Dragnet [Ransomware]: dragnet-ransomware-2025-5316 — Mass File Rename (SilentRansomGroup)
// Status: deprecated | Level: high | ID: 354b4b34-a3ee-5818-b235-a5e9931c880a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
