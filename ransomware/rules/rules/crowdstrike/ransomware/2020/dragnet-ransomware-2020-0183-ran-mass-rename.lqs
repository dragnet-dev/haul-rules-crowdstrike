// Dragnet [Ransomware]: dragnet-ransomware-2020-0183 — Mass File Rename (doppelpaymer)
// Status: deprecated | Level: high | ID: ffc6b896-5477-5c89-b5d3-cbde9c8c9957

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
