// Dragnet [Ransomware]: dragnet-ransomware-2025-7799 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 2330c6c8-8396-5bf0-98d2-3e89f7ac547f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
