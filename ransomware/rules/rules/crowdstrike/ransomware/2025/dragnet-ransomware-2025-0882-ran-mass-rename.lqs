// Dragnet [Ransomware]: dragnet-ransomware-2025-0882 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 008c94d8-0577-5ff5-b2fa-f7d038089817

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
