// Dragnet [Container]: dragnet-container-2026-2008 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 8c8d4041-db00-5681-b94c-bb184a983369

#event_simpleName=*
| (ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10* OR ImageFileName = *ubuntu:13.04* OR ImageFileName = *ubuntu:13.10*)
| table([timestamp, ComputerName])
| limit(1000)
