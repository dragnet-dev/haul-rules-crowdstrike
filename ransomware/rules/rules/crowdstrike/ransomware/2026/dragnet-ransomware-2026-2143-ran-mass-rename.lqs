// Dragnet [Ransomware]: dragnet-ransomware-2026-2143 — Mass File Rename (incransom)
// Status: test | Level: high | ID: 2c69fb5f-6adc-5b6f-9ef1-49a62c44325b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
