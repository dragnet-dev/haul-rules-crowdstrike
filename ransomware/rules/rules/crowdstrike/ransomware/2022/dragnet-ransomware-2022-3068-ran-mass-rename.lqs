// Dragnet [Ransomware]: dragnet-ransomware-2022-3068 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: cc595784-c58d-5d30-9660-e55025cd1ee8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
