// Dragnet [Ransomware]: dragnet-ransomware-2025-5132 — Mass File Rename (spacebears)
// Status: experimental | Level: high | ID: b26b1aa1-a7c4-5e42-8846-e1fd3f611cb3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
