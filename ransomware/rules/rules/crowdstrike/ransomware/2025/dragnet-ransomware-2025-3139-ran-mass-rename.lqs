// Dragnet [Ransomware]: dragnet-ransomware-2025-3139 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 847a2e46-04c5-53cb-af18-06269d55afc8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
