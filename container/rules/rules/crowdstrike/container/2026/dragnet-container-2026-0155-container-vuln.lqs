// Dragnet [Container]: dragnet-container-2026-0155 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: d54be3a0-f095-5105-84dd-4c7a2cbe98df

#event_simpleName=*
| (ImageFileName = *debian:7* OR ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10* OR ImageFileName = *ubuntu:13.10* OR ImageFileName = *ubuntu:14.04*)
| table([timestamp, ComputerName])
| limit(1000)
