// Dragnet [Ransomware]: dragnet-ransomware-2024-0618 — Mass File Rename (qiulong)
// Status: experimental | Level: high | ID: a4ddfbd3-b90b-5a88-afb3-c65493e006ca

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
