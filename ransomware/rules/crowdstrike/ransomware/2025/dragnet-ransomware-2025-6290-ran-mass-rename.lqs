// Dragnet [Ransomware]: dragnet-ransomware-2025-6290 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: faa8a438-5978-5531-8ca4-f6e133aa3caf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
