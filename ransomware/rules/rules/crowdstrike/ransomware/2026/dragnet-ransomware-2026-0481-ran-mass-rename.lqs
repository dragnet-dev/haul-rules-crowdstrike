// Dragnet [Ransomware]: dragnet-ransomware-2026-0481 — Mass File Rename (safepay)
// Status: stable | Level: high | ID: a0b23ab2-6767-58c7-af42-84a037443888

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
