// Dragnet [Ransomware]: dragnet-ransomware-2025-5095 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 2422b33d-2c9e-5841-8513-3b942d1e8ed8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
