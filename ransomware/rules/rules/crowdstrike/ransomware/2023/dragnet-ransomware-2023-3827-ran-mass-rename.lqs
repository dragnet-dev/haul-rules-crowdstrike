// Dragnet [Ransomware]: dragnet-ransomware-2023-3827 — Mass File Rename (siegedsec)
// Status: experimental | Level: high | ID: 3ec85c3d-8187-5cb8-9337-4a4fc11d61ab

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
