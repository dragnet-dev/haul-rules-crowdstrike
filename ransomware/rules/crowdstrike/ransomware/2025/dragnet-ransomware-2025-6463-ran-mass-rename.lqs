// Dragnet [Ransomware]: dragnet-ransomware-2025-6463 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: cf54024a-f37a-5246-b62d-856ef7e1ef9a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
