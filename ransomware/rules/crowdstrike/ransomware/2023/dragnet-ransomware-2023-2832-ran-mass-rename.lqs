// Dragnet [Ransomware]: dragnet-ransomware-2023-2832 — Mass File Rename (malas)
// Status: experimental | Level: high | ID: d5c003a7-5882-57fb-bebc-5fc14b90b3a6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
