// Dragnet [Ransomware]: dragnet-ransomware-2023-2046 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: de53913d-6f44-5c26-b658-c0a495d1e4a4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
