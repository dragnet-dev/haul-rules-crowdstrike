// Dragnet [Ransomware]: dragnet-ransomware-2025-2848 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: caf006cf-4868-5c70-a017-01917fa11c8a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
