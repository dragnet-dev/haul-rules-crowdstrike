// Dragnet [Ransomware]: dragnet-ransomware-2025-5193 — Mass File Rename (pear)
// Status: experimental | Level: high | ID: 00d52913-5bf1-5e17-90ac-6dde8efb79a0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
