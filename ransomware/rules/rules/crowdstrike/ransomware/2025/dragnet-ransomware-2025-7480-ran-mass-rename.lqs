// Dragnet [Ransomware]: dragnet-ransomware-2025-7480 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: b29b0e1b-05a8-537f-96f3-2c5fa1424021

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
