// Dragnet [Ransomware]: dragnet-ransomware-2025-5894 — Mass File Rename (kairos)
// Status: experimental | Level: high | ID: b5e867ad-2c14-55e0-94e5-5dd3df30eca5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
