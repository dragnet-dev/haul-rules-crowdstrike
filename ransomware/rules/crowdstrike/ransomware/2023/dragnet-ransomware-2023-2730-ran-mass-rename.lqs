// Dragnet [Ransomware]: dragnet-ransomware-2023-2730 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 2048d0d6-6564-5636-a0cb-67165fc2d45e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
