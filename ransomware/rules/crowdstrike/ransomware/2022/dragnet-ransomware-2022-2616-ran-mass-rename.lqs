// Dragnet [Ransomware]: dragnet-ransomware-2022-2616 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 9152746e-6de5-5ba4-8431-9b7896167651

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
