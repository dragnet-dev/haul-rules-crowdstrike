// Dragnet [Ransomware]: dragnet-ransomware-2025-0788 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 8e50b2cb-c307-5241-b3fc-5f9bd6f3f11f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
