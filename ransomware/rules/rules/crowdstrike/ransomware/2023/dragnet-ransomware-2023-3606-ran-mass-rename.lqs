// Dragnet [Ransomware]: dragnet-ransomware-2023-3606 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 0fa643fd-57f5-5d97-9ba6-10bfae5a858f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
