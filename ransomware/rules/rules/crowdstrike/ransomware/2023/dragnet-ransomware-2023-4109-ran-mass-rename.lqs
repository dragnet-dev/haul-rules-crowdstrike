// Dragnet [Ransomware]: dragnet-ransomware-2023-4109 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 2562e532-e936-565d-9697-f38f4238eafc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
