// Dragnet [Ransomware]: dragnet-ransomware-2026-2335 — Mass File Rename (aurora)
// Status: stable | Level: high | ID: 47160bb3-e147-52dd-a07a-4b34aadc9559

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
