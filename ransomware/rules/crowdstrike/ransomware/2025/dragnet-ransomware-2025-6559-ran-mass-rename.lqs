// Dragnet [Ransomware]: dragnet-ransomware-2025-6559 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: f4b4b64b-60cd-54af-8bca-1839bb5d0fc6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
