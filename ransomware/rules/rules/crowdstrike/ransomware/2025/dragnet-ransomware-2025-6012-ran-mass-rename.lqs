// Dragnet [Ransomware]: dragnet-ransomware-2025-6012 — Mass File Rename (chaos)
// Status: experimental | Level: high | ID: 2ee1fe03-16fd-52bd-9f38-d36c67eea397

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
