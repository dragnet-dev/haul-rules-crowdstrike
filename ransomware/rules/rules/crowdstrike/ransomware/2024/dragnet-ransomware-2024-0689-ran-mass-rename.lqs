// Dragnet [Ransomware]: dragnet-ransomware-2024-0689 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 83370ac2-6e17-5829-aa1e-d05b608f9584

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
