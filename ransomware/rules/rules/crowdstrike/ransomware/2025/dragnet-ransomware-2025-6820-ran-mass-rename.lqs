// Dragnet [Ransomware]: dragnet-ransomware-2025-6820 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: c44d9c03-b354-520f-bfe0-aa85152e3719

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
