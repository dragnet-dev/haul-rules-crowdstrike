// Dragnet [Ransomware]: dragnet-ransomware-2022-1145 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 9e24dc92-b364-5685-a202-cd13c3178781

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
