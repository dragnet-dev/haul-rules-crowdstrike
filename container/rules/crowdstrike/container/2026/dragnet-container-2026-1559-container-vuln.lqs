// Dragnet [Container]: dragnet-container-2026-1559 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 8d028fa3-e143-5d30-9f32-bc33b587e1ce

#event_simpleName=*
| (ImageFileName = *alpine:3.4* OR ImageFileName = *amazonlinux:1* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:7* OR ImageFileName = *debian:8* OR ImageFileName = *oraclelinux:7* OR ImageFileName = *ubuntu:14.04* OR ImageFileName = *ubuntu:14.04-ESM* OR ImageFileName = *ubuntu:15.10*)
| table([timestamp, ComputerName])
| limit(1000)
