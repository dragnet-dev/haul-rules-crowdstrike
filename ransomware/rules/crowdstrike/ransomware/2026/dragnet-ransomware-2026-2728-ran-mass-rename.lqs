// Dragnet [Ransomware]: dragnet-ransomware-2026-2728 — Mass File Rename (sinobi)
// Status: stable | Level: high | ID: b384eb53-b224-5bd7-847f-e49555e62adb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
