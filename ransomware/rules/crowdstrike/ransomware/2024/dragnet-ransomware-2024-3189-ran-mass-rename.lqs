// Dragnet [Ransomware]: dragnet-ransomware-2024-3189 — Mass File Rename (dragonransomware)
// Status: experimental | Level: high | ID: d1cad43e-16d8-5b22-9712-856e0d46b1d2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
