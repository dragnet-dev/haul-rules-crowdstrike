// Dragnet [Container]: dragnet-container-2026-0455 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 43ff7806-9d76-5736-8228-6ea5cd77f1ee

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:5*)
| table([timestamp, ComputerName])
| limit(1000)
