// Dragnet [Ransomware]: dragnet-ransomware-2024-5493 — Mass File Rename (apt73)
// Status: experimental | Level: high | ID: f846de50-27f1-584d-8016-5d3ff7119928

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
