// Dragnet [Ransomware]: dragnet-ransomware-2025-0152 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 73baef2c-0583-5cc1-8655-90a9a98c8b50

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
