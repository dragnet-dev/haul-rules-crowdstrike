// Dragnet [Ransomware]: dragnet-ransomware-2021-0935 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: fee2704e-3de9-5218-acef-d921761c0dc7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
