// Dragnet [Ransomware]: dragnet-ransomware-2025-1932 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 8ba88480-3f32-5e16-82c1-45c29dce6d7d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
