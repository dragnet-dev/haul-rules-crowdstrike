// Dragnet [Ransomware]: dragnet-ransomware-2022-2149 — Mass File Rename (quantum)
// Status: deprecated | Level: high | ID: d5f6f9b5-e781-55c4-962d-4598775c781a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
