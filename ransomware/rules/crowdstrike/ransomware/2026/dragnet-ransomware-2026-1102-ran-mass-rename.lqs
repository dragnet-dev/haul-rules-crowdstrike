// Dragnet [Ransomware]: dragnet-ransomware-2026-1102 — Mass File Rename (thegentlemen)
// Status: test | Level: high | ID: 768deec2-21e6-58d9-80f2-e918e5e4402f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
