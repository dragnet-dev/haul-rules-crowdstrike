// Dragnet [Ransomware]: dragnet-ransomware-2026-1904 — Mass File Rename (dragonforce)
// Status: test | Level: high | ID: a8b4ade7-66d9-5754-8be5-f940cc2be8c1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
