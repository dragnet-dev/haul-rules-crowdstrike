// Dragnet [Ransomware]: dragnet-ransomware-2024-0852 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 73b6d4c9-8843-597b-b062-6b65c6e633ce

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
