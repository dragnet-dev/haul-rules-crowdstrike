// Dragnet [Container]: dragnet-container-2026-2088 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: def6e460-8dbe-5edb-be72-2228f89a3d5b

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:5*)
| table([timestamp, ComputerName])
| limit(1000)
