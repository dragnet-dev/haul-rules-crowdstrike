// Dragnet [Ransomware]: dragnet-ransomware-2023-2845 — Mass File Rename (malas)
// Status: experimental | Level: high | ID: 97a800b3-30e2-5614-8e64-9f9200b4138a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
