// Dragnet [Ransomware]: dragnet-ransomware-2020-0025 — Mass File Rename (ragnarlocker)
// Status: deprecated | Level: high | ID: 9577d8d4-6a52-5614-8e0c-d473d6f3844e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
