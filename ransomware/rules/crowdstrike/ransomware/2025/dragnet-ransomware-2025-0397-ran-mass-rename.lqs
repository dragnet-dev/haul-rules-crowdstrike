// Dragnet [Ransomware]: dragnet-ransomware-2025-0397 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: c2a30777-a44c-50de-b3e8-16ab05a218d6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
