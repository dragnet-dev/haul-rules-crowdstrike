// Dragnet [Ransomware]: dragnet-ransomware-2025-7580 — Mass File Rename (GDLockerSec)
// Status: experimental | Level: high | ID: bb26edd0-ca19-5f9f-bd7b-26284ea2a7f5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
