// Dragnet [Ransomware]: dragnet-ransomware-2025-0228 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: 67a843eb-21bb-5ec2-915c-e1d670915fae

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
