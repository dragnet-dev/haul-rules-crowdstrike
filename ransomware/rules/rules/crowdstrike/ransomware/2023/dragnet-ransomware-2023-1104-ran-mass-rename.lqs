// Dragnet [Ransomware]: dragnet-ransomware-2023-1104 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 14ea218c-92a4-5b2c-adae-4fc3ad7388c8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
