// Dragnet [Ransomware]: dragnet-ransomware-2022-0927 — Mass File Rename (onyx)
// Status: deprecated | Level: high | ID: fa0b89f5-f457-5228-a9df-cd65aa3a0f85

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
