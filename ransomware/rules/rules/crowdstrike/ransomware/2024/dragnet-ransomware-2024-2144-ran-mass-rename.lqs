// Dragnet [Ransomware]: dragnet-ransomware-2024-2144 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 12adf52e-8dc9-5674-b6f3-179fa1495ef4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
