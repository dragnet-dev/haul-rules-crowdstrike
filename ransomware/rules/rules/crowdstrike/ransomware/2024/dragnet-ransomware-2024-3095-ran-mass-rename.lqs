// Dragnet [Ransomware]: dragnet-ransomware-2024-3095 — Mass File Rename (arcusmedia)
// Status: experimental | Level: high | ID: e834cd5c-fb2c-5cb1-9dbe-0a560823d331

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
