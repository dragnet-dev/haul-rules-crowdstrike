// Dragnet [Ransomware]: dragnet-ransomware-2025-7256 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 9e54da6a-1d4e-5e37-ab18-b34a21c5b72e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
