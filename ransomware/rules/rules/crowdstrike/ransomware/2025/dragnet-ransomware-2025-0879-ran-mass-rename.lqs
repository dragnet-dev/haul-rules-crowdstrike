// Dragnet [Ransomware]: dragnet-ransomware-2025-0879 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: fba7aa3f-cc6f-5617-98e6-7465320c9f02

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
