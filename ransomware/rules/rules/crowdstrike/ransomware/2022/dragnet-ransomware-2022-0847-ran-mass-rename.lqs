// Dragnet [Ransomware]: dragnet-ransomware-2022-0847 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 1906a80f-9944-5ed7-99ba-e040afeb0815

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
