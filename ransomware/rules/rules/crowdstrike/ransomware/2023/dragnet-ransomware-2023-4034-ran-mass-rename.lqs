// Dragnet [Ransomware]: dragnet-ransomware-2023-4034 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 09e401ae-5948-5c63-af33-a2fa33ab0cb3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
