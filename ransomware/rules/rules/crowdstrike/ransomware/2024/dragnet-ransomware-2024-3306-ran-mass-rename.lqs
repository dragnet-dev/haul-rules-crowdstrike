// Dragnet [Ransomware]: dragnet-ransomware-2024-3306 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 3474144d-672a-56ae-9391-c67ee066bab4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
