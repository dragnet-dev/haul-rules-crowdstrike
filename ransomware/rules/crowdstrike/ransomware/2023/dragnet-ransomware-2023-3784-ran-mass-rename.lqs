// Dragnet [Ransomware]: dragnet-ransomware-2023-3784 — Mass File Rename (trigona)
// Status: experimental | Level: high | ID: bad72aaf-52a6-5548-ae4e-0249ceb7c0b7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
