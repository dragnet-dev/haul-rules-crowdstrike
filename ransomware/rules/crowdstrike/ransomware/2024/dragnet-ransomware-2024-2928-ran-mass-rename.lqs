// Dragnet [Ransomware]: dragnet-ransomware-2024-2928 — Mass File Rename (spacebears)
// Status: experimental | Level: high | ID: 652e9cb7-85bb-51e3-8d9b-23020bcd58f5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
