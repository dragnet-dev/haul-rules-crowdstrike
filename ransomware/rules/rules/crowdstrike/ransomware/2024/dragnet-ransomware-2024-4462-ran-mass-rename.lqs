// Dragnet [Ransomware]: dragnet-ransomware-2024-4462 — Mass File Rename (ciphbit)
// Status: deprecated | Level: high | ID: 5904f892-9964-5f9d-a5e7-776fa40c1ed4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
