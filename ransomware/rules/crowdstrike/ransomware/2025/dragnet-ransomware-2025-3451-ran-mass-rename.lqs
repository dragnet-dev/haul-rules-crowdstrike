// Dragnet [Ransomware]: dragnet-ransomware-2025-3451 — Mass File Rename (incransom)
// Status: test | Level: high | ID: 3c04785b-8b26-537f-8b80-e4065e5ed390

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
