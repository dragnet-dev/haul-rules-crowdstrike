// Dragnet [Ransomware]: dragnet-ransomware-2024-4235 — Mass File Rename (termite)
// Status: experimental | Level: high | ID: 0d8416ef-6980-5357-ae5e-867fe0142302

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
