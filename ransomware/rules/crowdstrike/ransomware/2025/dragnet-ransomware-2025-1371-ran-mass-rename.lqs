// Dragnet [Ransomware]: dragnet-ransomware-2025-1371 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 7c665b03-246d-5031-aca6-0519188e05c7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
