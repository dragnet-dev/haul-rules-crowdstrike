// Dragnet [Container]: dragnet-container-2024-1404 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: aa846562-4151-5f3f-9198-6197a4ece387

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:7* OR ImageFileName = *ubuntu:14.04-ESM* OR ImageFileName = *ubuntu:16.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
