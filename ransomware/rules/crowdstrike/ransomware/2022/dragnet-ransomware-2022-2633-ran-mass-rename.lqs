// Dragnet [Ransomware]: dragnet-ransomware-2022-2633 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 47d2f348-3d4e-5bf1-9fc8-1e833b393372

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
