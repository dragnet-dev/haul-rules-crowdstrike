// Dragnet [Ransomware]: dragnet-ransomware-2024-0168 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 6aa83b9e-5d9e-537a-a06b-13e49bd7872e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
