// Dragnet [Ransomware]: dragnet-ransomware-2025-0683 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: 0b23fdc3-fba4-5176-adc9-1b1eff4f4404

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
