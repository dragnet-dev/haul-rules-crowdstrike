// Dragnet [Ransomware]: dragnet-ransomware-2021-0812 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 6828d1eb-de13-5186-8170-edba8b9c9635

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
