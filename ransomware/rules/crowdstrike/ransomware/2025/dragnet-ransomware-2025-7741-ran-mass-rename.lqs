// Dragnet [Ransomware]: dragnet-ransomware-2025-7741 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 689effd3-8b5d-5440-aad2-419837e58f59

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
