// Dragnet [Ransomware]: dragnet-ransomware-2025-2067 — Mass File Rename (lockbit5)
// Status: experimental | Level: high | ID: 67f8a7e5-b927-52e7-bc28-34cea41e8ce4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
