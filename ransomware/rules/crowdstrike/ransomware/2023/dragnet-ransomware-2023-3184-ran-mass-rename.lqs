// Dragnet [Ransomware]: dragnet-ransomware-2023-3184 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 6caccf78-eb47-530a-8623-557c732ca329

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
