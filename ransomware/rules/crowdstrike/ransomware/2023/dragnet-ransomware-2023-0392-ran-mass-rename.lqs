// Dragnet [Ransomware]: dragnet-ransomware-2023-0392 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 522621c6-33ea-51a7-9ade-ba92c5114947

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
