// Dragnet [Ransomware]: dragnet-ransomware-2024-5131 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 3e3fb72d-9ada-5323-8a5f-f28fbcd2254d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
