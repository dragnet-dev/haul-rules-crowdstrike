// Dragnet [Ransomware]: dragnet-ransomware-2024-2132 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 7d9fba50-84cd-5264-ad90-74e4764c317d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
