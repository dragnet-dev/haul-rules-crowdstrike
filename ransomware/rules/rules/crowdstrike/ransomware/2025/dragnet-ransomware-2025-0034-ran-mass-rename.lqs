// Dragnet [Ransomware]: dragnet-ransomware-2025-0034 — Mass File Rename (global)
// Status: deprecated | Level: high | ID: 40ed3696-aa46-5ee6-b081-95cb4b8daacc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
