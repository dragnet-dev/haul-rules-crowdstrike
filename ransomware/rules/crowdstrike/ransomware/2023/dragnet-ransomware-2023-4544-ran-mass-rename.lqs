// Dragnet [Ransomware]: dragnet-ransomware-2023-4544 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 15411840-1d02-5ac3-925e-4ddab37add70

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
