// Dragnet [Ransomware]: dragnet-ransomware-2024-3751 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 6f037552-e1ef-5c7f-93ea-97b069d1b18c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
