// Dragnet [Ransomware]: dragnet-ransomware-2024-1657 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 838bed22-b4e3-542e-a584-1070758c50b0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
