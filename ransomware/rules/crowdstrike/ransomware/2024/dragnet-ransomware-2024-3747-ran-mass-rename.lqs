// Dragnet [Ransomware]: dragnet-ransomware-2024-3747 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: f6faf415-02cf-55be-ae77-94388dc1472b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
