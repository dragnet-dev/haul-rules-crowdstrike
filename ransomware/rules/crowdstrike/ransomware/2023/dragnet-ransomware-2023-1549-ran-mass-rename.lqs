// Dragnet [Ransomware]: dragnet-ransomware-2023-1549 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 759dbb59-9106-5fa4-b08d-4f39635e32a7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
