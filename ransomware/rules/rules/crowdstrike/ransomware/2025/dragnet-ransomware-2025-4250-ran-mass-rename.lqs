// Dragnet [Ransomware]: dragnet-ransomware-2025-4250 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 7860a221-a436-5f1c-8f28-582a5beca63a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
