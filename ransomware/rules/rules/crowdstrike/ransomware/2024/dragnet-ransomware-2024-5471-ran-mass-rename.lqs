// Dragnet [Ransomware]: dragnet-ransomware-2024-5471 — Mass File Rename (dAn0n)
// Status: experimental | Level: high | ID: d3354d1e-c333-5281-912e-e0ffb4fb1846

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
