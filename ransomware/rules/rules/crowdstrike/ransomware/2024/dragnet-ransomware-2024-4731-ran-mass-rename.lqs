// Dragnet [Ransomware]: dragnet-ransomware-2024-4731 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: a0af2688-ac1c-57f5-83ef-b760bcbcbe0a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
