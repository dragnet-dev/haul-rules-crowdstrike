// Dragnet [Ransomware]: dragnet-ransomware-2024-0293 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 2ceabfe7-94f0-5f2c-ab63-c22299923b55

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
