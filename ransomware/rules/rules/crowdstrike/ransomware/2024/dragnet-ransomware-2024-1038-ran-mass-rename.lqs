// Dragnet [Ransomware]: dragnet-ransomware-2024-1038 — Mass File Rename (ransomhouse)
// Status: experimental | Level: high | ID: c2edf450-e190-552c-97d5-714d103bbc21

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
