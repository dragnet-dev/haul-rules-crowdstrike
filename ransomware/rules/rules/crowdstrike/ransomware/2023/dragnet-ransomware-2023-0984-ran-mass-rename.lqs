// Dragnet [Ransomware]: dragnet-ransomware-2023-0984 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 9b3c47b5-e9a9-5509-8d3b-33decdc4e098

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
