// Dragnet [Ransomware]: dragnet-ransomware-2021-1764 — Mass File Rename (atomsilo)
// Status: experimental | Level: high | ID: 29d158be-9f00-56c0-b365-6f735dbc2218

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
