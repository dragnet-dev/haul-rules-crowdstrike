// Dragnet [Ransomware]: dragnet-ransomware-2024-2484 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 79d7bcf6-99c9-5ca6-a102-3f7c3e81d12c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
