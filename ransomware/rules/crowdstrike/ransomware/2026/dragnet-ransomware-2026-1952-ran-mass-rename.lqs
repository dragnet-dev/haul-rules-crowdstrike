// Dragnet [Ransomware]: dragnet-ransomware-2026-1952 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: f2ef6839-552b-52ec-997f-6420b94e6452

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
