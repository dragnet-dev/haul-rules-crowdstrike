// Dragnet [Ransomware]: dragnet-ransomware-2025-7221 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: ff9012cf-e045-568b-8d50-6e7e0450e2f2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
