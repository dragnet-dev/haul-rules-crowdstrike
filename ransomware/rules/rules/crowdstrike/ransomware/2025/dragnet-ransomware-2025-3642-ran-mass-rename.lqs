// Dragnet [Ransomware]: dragnet-ransomware-2025-3642 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: 457336e5-448b-5b62-ab56-d7df93ec93d1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
