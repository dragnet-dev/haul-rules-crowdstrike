// Dragnet [Ransomware]: dragnet-ransomware-2025-7640 — Mass File Rename (nova)
// Status: experimental | Level: high | ID: 4a711495-e0e8-5016-bb78-d37f62946847

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
