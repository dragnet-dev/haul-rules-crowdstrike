// Dragnet [Ransomware]: dragnet-ransomware-2025-6457 — Mass File Rename (sinobi)
// Status: experimental | Level: high | ID: 54b7395c-4c94-5036-842c-3ffc2adf685c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
