// Dragnet [Ransomware]: dragnet-ransomware-2022-2882 — Mass File Rename (karakurt)
// Status: deprecated | Level: high | ID: 09d1e140-13c0-512a-874c-85f3552266d1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
