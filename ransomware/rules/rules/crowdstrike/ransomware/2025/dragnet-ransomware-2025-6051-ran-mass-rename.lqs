// Dragnet [Ransomware]: dragnet-ransomware-2025-6051 — Mass File Rename (insomnia)
// Status: experimental | Level: high | ID: b4c832ec-38f5-5686-b262-00be79956d3f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
