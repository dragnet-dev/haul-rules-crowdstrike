// Dragnet [Ransomware]: dragnet-ransomware-2025-7600 — Mass File Rename (chaos)
// Status: experimental | Level: high | ID: 5d8d7409-3363-5166-ab0a-7752bf14e2e4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
