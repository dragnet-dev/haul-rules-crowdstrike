// Dragnet [Ransomware]: dragnet-ransomware-2025-6948 — Mass File Rename (cephalus)
// Status: experimental | Level: high | ID: 6b184245-2f37-56a5-b8db-58b2b922dd7a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
