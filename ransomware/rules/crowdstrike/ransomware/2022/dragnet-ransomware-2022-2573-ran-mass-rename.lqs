// Dragnet [Ransomware]: dragnet-ransomware-2022-2573 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: bd26ffa9-6249-50cc-b685-1d84823d4e2c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
