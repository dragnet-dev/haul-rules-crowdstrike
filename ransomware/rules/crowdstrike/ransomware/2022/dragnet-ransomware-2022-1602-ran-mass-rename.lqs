// Dragnet [Ransomware]: dragnet-ransomware-2022-1602 — Mass File Rename (everest)
// Status: deprecated | Level: high | ID: 0f6dbf6d-4ea1-5da6-9a54-b39746fad8f6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
