// Dragnet [Ransomware]: dragnet-ransomware-2024-0763 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: 4cc435da-e937-5870-b6ff-3b9eaa8b3017

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
