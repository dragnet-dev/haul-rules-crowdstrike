// Dragnet [Ransomware]: dragnet-ransomware-2023-3351 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: eca71ff5-83f0-5659-ac48-514e518ca5e7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
