// Dragnet [Ransomware]: dragnet-ransomware-2024-0606 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: b161dc63-a7f1-5720-9a03-31ae0f90ee76

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
