// Dragnet [Ransomware]: dragnet-ransomware-2025-2722 — Mass File Rename (handala)
// Status: experimental | Level: high | ID: a0e04048-15af-5ac9-9696-27fd8ab86867

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
