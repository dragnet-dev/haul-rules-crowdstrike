// Dragnet [Ransomware]: dragnet-ransomware-2025-7812 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 501e908d-0e7c-584d-a293-8e6b3bf80edf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
