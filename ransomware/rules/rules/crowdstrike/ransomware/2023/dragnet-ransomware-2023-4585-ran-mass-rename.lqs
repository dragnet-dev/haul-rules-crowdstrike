// Dragnet [Ransomware]: dragnet-ransomware-2023-4585 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 5507fc02-5f4f-5d2e-9601-1bd4583751be

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
