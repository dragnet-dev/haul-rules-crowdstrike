// Dragnet [Ransomware]: dragnet-ransomware-2024-3965 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 116c01ea-7aff-5a12-a9d2-86fc8613bd0e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
