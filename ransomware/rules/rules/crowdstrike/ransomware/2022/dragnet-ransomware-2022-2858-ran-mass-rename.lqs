// Dragnet [Ransomware]: dragnet-ransomware-2022-2858 — Mass File Rename (blackbasta)
// Status: deprecated | Level: high | ID: 1f45779f-b16d-50ae-982f-03f5877ba563

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
