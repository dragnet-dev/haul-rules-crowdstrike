// Dragnet [Ransomware]: dragnet-ransomware-2022-0226 — Mass File Rename (everest)
// Status: deprecated | Level: high | ID: c053e1ff-f0b5-51fb-ae7c-5cae0670fa1b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
