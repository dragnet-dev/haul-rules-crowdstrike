// Dragnet [Container]: dragnet-container-2026-2531 — Vulnerable Base Image Pull
// Status: deprecated | Level: low | ID: 58aad303-b7b2-5fd5-a06f-4f23c464a91a

#event_simpleName=*
| (ImageFileName = *chainguard:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
