// Dragnet [Ransomware]: dragnet-ransomware-2025-3263 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: a0f6288a-10e2-5eb7-9fbd-ad07da2d016e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
