// Dragnet [Ransomware]: dragnet-ransomware-2025-3013 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: fcd8b246-3bce-5579-bfe3-dc90373f64d5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
