// Dragnet [Container]: dragnet-container-2024-1426 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 146aa9e5-920f-582f-b8d0-2239522a2b43

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:9* OR ImageFileName = *ubuntu:18.04*)
| table([timestamp, ComputerName])
| limit(1000)
