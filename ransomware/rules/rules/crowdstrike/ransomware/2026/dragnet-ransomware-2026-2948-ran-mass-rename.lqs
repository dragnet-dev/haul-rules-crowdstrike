// Dragnet [Ransomware]: dragnet-ransomware-2026-2948 — Mass File Rename (dragonforce)
// Status: stable | Level: high | ID: 6b115b3f-c1cd-57b5-9232-9191a008473c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
