// Dragnet [Ransomware]: dragnet-ransomware-2025-0687 — Mass File Rename (spacebears)
// Status: experimental | Level: high | ID: 50066f3b-c061-5d4f-8da9-aaadd20afe59

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
