// Dragnet [Ransomware]: dragnet-ransomware-2023-0296 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 4ea3f974-6aa5-5bd4-8087-5d2067008114

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
