// Dragnet [Ransomware]: dragnet-ransomware-2025-3115 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 64177d23-28c7-594d-8e89-dafc6454e8df

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
