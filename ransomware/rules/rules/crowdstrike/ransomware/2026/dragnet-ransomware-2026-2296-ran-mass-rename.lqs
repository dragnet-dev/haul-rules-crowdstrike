// Dragnet [Ransomware]: dragnet-ransomware-2026-2296 — Mass File Rename (medusalocker)
// Status: stable | Level: high | ID: 220131fe-8cdf-5257-b516-f06ee42eac79

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
