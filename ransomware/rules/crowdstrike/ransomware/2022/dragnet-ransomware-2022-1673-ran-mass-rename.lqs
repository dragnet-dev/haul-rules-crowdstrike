// Dragnet [Ransomware]: dragnet-ransomware-2022-1673 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: b85646b4-7375-5a72-bf6f-961e8e09fd26

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
