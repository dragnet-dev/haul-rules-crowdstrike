// Dragnet [Ransomware]: dragnet-ransomware-2025-4361 — Mass File Rename (ransomexx)
// Status: experimental | Level: high | ID: de08fcec-8bea-51d3-82d6-7fb101f180d3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
