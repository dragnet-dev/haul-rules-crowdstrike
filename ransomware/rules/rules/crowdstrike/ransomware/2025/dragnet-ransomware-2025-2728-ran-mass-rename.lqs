// Dragnet [Ransomware]: dragnet-ransomware-2025-2728 — Mass File Rename (lunalock)
// Status: experimental | Level: high | ID: 3b46165b-40a3-5399-8ce5-1429640b1a15

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
