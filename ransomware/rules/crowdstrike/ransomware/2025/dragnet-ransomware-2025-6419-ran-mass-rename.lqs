// Dragnet [Ransomware]: dragnet-ransomware-2025-6419 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 5402a952-604b-5f32-b333-9c007234857c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
