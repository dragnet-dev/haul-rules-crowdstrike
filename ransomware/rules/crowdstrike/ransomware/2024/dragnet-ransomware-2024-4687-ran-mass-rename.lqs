// Dragnet [Ransomware]: dragnet-ransomware-2024-4687 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: d299a98a-d1e0-593e-b6ef-b0720e03d242

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
