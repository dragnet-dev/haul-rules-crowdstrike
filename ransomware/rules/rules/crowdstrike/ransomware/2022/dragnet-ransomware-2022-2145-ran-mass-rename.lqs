// Dragnet [Ransomware]: dragnet-ransomware-2022-2145 — Mass File Rename (daixin)
// Status: deprecated | Level: high | ID: 2d02c3fb-fce4-58b4-b9c9-bb84cebf4d14

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
