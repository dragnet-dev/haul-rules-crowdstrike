// Dragnet [Ransomware]: dragnet-ransomware-2023-4649 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 69d80da0-4d91-5691-8eb3-84759687ce34

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
