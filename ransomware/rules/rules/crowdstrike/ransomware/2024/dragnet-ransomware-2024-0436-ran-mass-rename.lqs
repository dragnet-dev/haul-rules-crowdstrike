// Dragnet [Ransomware]: dragnet-ransomware-2024-0436 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: e436ac86-e11e-5809-9f0a-1670cc5244d9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
