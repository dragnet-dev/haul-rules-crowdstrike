// Dragnet [Ransomware]: dragnet-ransomware-2022-2460 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 07066a1b-ff45-5814-aa14-fd89de1ac880

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
