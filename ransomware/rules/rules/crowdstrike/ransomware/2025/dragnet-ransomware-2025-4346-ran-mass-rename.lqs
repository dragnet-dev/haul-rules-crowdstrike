// Dragnet [Ransomware]: dragnet-ransomware-2025-4346 — Mass File Rename (ransomhouse)
// Status: experimental | Level: high | ID: 96831646-54ba-5ca7-834f-143b03dfe0dd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
