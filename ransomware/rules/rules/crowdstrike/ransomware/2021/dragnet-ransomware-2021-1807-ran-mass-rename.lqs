// Dragnet [Ransomware]: dragnet-ransomware-2021-1807 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 6dd8f760-3d93-512c-baea-1a5580b6c5ed

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
