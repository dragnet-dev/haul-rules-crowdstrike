// Dragnet [Ransomware]: dragnet-ransomware-2025-1462 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 18d90d4e-a42d-5fda-998c-c163dc75c955

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
