// Dragnet [Ransomware]: dragnet-ransomware-2025-7079 — Mass File Rename (pear)
// Status: experimental | Level: high | ID: 02d0701f-a278-5441-89c0-46eb47be5571

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
