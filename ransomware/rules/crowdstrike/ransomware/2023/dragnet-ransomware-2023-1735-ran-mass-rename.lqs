// Dragnet [Ransomware]: dragnet-ransomware-2023-1735 — Mass File Rename (knight)
// Status: experimental | Level: high | ID: 40dca7c2-1489-55f5-aed0-5f4c277d93d0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
