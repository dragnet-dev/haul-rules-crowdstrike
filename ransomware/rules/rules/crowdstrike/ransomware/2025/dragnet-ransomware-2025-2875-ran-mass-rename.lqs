// Dragnet [Ransomware]: dragnet-ransomware-2025-2875 — Mass File Rename (apt73)
// Status: experimental | Level: high | ID: 992224f6-3515-571a-80b2-6517a416fbc8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
