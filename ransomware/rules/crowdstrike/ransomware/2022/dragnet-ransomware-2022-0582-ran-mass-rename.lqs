// Dragnet [Ransomware]: dragnet-ransomware-2022-0582 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: e5646059-bb1b-5f0b-b5e4-00659be738ce

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
