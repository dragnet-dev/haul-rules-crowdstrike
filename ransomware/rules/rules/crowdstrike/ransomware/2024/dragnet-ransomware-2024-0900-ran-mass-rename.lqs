// Dragnet [Ransomware]: dragnet-ransomware-2024-0900 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: e357876c-ea4c-5b4e-a854-9d98fe7ab306

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
