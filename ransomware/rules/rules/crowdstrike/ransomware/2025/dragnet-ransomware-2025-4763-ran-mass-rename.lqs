// Dragnet [Ransomware]: dragnet-ransomware-2025-4763 — Mass File Rename (medusa)
// Status: deprecated | Level: high | ID: 268c427e-b091-54bc-9aee-e83e3cecff57

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
