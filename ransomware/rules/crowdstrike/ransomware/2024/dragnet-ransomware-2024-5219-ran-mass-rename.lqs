// Dragnet [Ransomware]: dragnet-ransomware-2024-5219 — Mass File Rename (dragonforce)
// Status: deprecated | Level: high | ID: 8c5f09c8-c9a0-596c-8649-3bcfafa66904

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
