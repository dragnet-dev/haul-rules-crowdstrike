// Dragnet [Ransomware]: dragnet-ransomware-2023-0755 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 29727aff-dadc-551e-be5f-ab049281e892

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
