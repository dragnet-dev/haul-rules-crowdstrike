// Dragnet [Ransomware]: dragnet-ransomware-2023-1573 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 74331852-b89b-536d-afd4-d046592aec58

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
