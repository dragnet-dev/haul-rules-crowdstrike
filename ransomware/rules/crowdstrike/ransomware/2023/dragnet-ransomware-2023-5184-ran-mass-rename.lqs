// Dragnet [Ransomware]: dragnet-ransomware-2023-5184 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: 6e8a1e63-ecf7-5cf2-b62f-3bdd42f75473

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
