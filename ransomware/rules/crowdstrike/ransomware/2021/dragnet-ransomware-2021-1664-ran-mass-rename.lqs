// Dragnet [Ransomware]: dragnet-ransomware-2021-1664 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: a4a116a4-699b-53ad-bca4-125563099d8d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
