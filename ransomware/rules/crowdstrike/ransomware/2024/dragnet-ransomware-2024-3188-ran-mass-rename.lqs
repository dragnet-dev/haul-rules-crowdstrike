// Dragnet [Ransomware]: dragnet-ransomware-2024-3188 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 35cebfda-949b-58fa-bb15-ed7b2b18ebb2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
