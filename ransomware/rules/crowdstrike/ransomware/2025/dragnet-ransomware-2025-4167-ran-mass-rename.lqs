// Dragnet [Ransomware]: dragnet-ransomware-2025-4167 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 96ff4391-43f4-56c9-913f-b3002c7c7f83

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
