// Dragnet [Ransomware]: dragnet-ransomware-2021-0894 — Mass File Rename (payloadbin)
// Status: deprecated | Level: high | ID: c3d1b604-f5f2-5b8c-acd1-a3084dbd25a2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
