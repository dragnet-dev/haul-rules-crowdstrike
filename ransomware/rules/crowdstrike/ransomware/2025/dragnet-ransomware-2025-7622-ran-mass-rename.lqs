// Dragnet [Ransomware]: dragnet-ransomware-2025-7622 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 9dcc544a-c3c8-5a3f-8fb7-0f340a0e3c7a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
