// Dragnet [Ransomware]: dragnet-ransomware-2024-0452 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 5e2ebd9c-bbe5-54f4-b350-c0307ddc5064

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
