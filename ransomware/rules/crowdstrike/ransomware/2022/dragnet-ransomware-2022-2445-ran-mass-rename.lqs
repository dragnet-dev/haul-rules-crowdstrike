// Dragnet [Ransomware]: dragnet-ransomware-2022-2445 — Mass File Rename (royal)
// Status: deprecated | Level: high | ID: 7c79ccdf-761e-5c41-a0d4-023d7e837d28

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
