// Dragnet [Container]: dragnet-container-2024-0231 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 65153a24-d741-5a1e-9df2-0572effe7af7

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:8* OR ImageFileName = *debian:9*)
| table([timestamp, ComputerName])
| limit(1000)
