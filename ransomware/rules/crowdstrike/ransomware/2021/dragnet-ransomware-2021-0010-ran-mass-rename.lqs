// Dragnet [Ransomware]: dragnet-ransomware-2021-0010 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: e7db72da-74d0-5de6-8fae-4b95fba34d6f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
