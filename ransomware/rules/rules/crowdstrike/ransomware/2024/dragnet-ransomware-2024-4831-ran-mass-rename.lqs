// Dragnet [Ransomware]: dragnet-ransomware-2024-4831 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 4111a715-dd9c-5f30-8f2e-d84e96eb60d5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
