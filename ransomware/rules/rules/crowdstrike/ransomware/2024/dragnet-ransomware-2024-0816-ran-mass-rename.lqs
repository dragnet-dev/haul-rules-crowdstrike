// Dragnet [Ransomware]: dragnet-ransomware-2024-0816 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 14c08e90-6be7-505c-8af0-a56368932cbd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
