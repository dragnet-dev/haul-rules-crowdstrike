// Dragnet [Ransomware]: dragnet-ransomware-2025-4401 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: b4e80527-431e-52b3-b8d7-07e722c5fbd6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
