// Dragnet [Ransomware]: dragnet-ransomware-2025-4190 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 6cce24a5-a33c-582e-b712-92eb6721f3b8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
