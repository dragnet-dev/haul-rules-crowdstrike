// Dragnet [Ransomware]: dragnet-ransomware-2024-2770 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 64185963-d908-55bc-9674-fd878ba612b7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
