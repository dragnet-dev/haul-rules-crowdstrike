// Dragnet [Container]: dragnet-container-2026-1625 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 0455126b-d8c4-5780-bb74-386428d11644

#event_simpleName=*
| (ImageFileName = *chainguard:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *redhat/ubi9:*)
| table([timestamp, ComputerName])
| limit(1000)
