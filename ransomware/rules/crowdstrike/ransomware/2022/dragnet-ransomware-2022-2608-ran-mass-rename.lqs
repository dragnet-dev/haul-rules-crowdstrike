// Dragnet [Ransomware]: dragnet-ransomware-2022-2608 — Mass File Rename (everest)
// Status: deprecated | Level: high | ID: 80ff8ad1-43b0-553f-8ec6-2af5de47f069

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
