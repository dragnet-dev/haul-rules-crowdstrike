// Dragnet [Ransomware]: dragnet-ransomware-2021-1040 — Mass File Rename (blacktor)
// Status: deprecated | Level: high | ID: b114047c-66bb-5c51-9dc9-1a8008f3cc09

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
