// Dragnet [Ransomware]: dragnet-ransomware-2022-2453 — Mass File Rename (blackbasta)
// Status: deprecated | Level: high | ID: e6d0f11a-436a-5a8d-a9d4-d1f4b50fc142

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
