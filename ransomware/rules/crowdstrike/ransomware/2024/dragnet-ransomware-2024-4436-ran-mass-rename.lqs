// Dragnet [Ransomware]: dragnet-ransomware-2024-4436 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 9759e15c-2aef-5e66-8674-a02910840a4c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
