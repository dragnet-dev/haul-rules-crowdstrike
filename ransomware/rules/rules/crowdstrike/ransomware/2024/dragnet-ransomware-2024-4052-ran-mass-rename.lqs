// Dragnet [Ransomware]: dragnet-ransomware-2024-4052 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: bdd1328f-3f0c-5318-87f8-0c606b42f2f3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
