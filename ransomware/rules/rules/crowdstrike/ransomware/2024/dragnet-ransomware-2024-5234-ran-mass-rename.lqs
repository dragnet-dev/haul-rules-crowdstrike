// Dragnet [Ransomware]: dragnet-ransomware-2024-5234 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 2c8da47b-5d48-5642-88a8-67c6915b5b6e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
