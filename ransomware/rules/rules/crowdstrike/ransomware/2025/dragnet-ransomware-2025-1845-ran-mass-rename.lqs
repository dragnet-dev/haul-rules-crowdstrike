// Dragnet [Ransomware]: dragnet-ransomware-2025-1845 — Mass File Rename (brotherhood)
// Status: experimental | Level: high | ID: ae6dd66f-2b11-56aa-850b-a9eedb088f79

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
