// Dragnet [Ransomware]: dragnet-ransomware-2022-2198 — Mass File Rename (blackbasta)
// Status: deprecated | Level: high | ID: 30bddcf2-3cef-5796-b788-b51dd4928238

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
