// Dragnet [Ransomware]: dragnet-ransomware-2022-2535 — Mass File Rename (stormous)
// Status: deprecated | Level: high | ID: 7788f908-fb20-5f23-b45d-32e401223081

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
