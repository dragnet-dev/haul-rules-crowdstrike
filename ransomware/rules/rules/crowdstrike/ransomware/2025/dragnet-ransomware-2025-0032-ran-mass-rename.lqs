// Dragnet [Ransomware]: dragnet-ransomware-2025-0032 — Mass File Rename (spacebears)
// Status: experimental | Level: high | ID: a9185b38-8121-539b-b809-bb540a9af11d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
