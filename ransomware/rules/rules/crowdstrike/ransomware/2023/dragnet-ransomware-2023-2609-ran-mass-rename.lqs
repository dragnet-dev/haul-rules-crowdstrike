// Dragnet [Ransomware]: dragnet-ransomware-2023-2609 — Mass File Rename (ragnarlocker)
// Status: experimental | Level: high | ID: 44d1668e-0b40-5b09-b5a8-39bd0ef66dc2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
