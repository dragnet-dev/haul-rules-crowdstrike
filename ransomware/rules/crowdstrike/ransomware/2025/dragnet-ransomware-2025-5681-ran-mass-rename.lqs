// Dragnet [Ransomware]: dragnet-ransomware-2025-5681 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: e9eeba24-4d12-5b09-8943-a3a03e34e858

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
