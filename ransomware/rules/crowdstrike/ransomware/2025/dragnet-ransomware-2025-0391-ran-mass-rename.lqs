// Dragnet [Ransomware]: dragnet-ransomware-2025-0391 — Mass File Rename (lockbit5)
// Status: test | Level: high | ID: 134de5ca-b4f1-5145-8f0e-0f6f110ead96

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
