// Dragnet [Ransomware]: dragnet-ransomware-2025-2101 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 8b0f68be-e0ad-5db7-8b85-45f7e7717c21

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
