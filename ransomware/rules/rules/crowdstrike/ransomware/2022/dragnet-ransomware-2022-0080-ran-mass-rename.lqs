// Dragnet [Ransomware]: dragnet-ransomware-2022-0080 — Mass File Rename (stormous)
// Status: deprecated | Level: high | ID: 7fa4868a-5bc8-51f5-b79a-dbc779edae77

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
