// Dragnet [Ransomware]: dragnet-ransomware-2025-4915 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: e4eaa33a-bfd2-5abf-b56e-4efd2683ab5c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
