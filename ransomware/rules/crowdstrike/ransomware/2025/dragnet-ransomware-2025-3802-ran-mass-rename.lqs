// Dragnet [Ransomware]: dragnet-ransomware-2025-3802 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: a28da5ce-9aa8-5582-b14a-39bb683bcd26

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
