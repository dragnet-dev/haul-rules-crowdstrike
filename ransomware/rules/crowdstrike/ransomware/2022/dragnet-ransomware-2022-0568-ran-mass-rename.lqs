// Dragnet [Ransomware]: dragnet-ransomware-2022-0568 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: e1785ac4-bec7-5651-a733-e18098114007

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
