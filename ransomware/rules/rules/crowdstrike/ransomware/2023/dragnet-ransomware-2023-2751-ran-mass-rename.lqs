// Dragnet [Ransomware]: dragnet-ransomware-2023-2751 — Mass File Rename (malas)
// Status: experimental | Level: high | ID: 21ff074b-e5cb-5507-b69a-a6fac8a3fa18

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
