// Dragnet [Ransomware]: dragnet-ransomware-2024-3698 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: cb5325e1-a3ac-5589-ae4e-afb572ceeabf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
