// Dragnet [Ransomware]: dragnet-ransomware-2025-1276 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: 27b8bbbd-222a-561f-813c-59cc6ac135f5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
