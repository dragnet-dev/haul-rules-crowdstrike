// Dragnet [Ransomware]: dragnet-ransomware-2023-3635 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 81aa4c90-f9b1-541d-bf39-7f3abbd1fde7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
