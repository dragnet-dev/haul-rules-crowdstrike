// Dragnet [Ransomware]: dragnet-ransomware-2022-0212 — Mass File Rename (lv)
// Status: deprecated | Level: high | ID: f24babb5-966c-5769-bd14-0bdaf3a2ee25

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
