// Dragnet [Ransomware]: dragnet-ransomware-2025-6191 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: dce8b067-d645-53bc-9037-396b68ce2d34

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
