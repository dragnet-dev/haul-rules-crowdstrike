// Dragnet [Ransomware]: dragnet-ransomware-2023-2884 — Mass File Rename (malas)
// Status: experimental | Level: high | ID: 10696d8f-a988-54e2-b3c7-fafdb2f50e9b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
