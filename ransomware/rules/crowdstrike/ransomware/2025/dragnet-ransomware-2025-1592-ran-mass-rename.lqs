// Dragnet [Ransomware]: dragnet-ransomware-2025-1592 — Mass File Rename (play)
// Status: experimental | Level: high | ID: b0b30ea2-d236-5267-986d-e7e69e5d6a65

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
