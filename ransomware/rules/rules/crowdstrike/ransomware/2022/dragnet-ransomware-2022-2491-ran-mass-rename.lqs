// Dragnet [Ransomware]: dragnet-ransomware-2022-2491 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 27e6ac80-725f-52a0-b6c0-3113785cb1d9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
