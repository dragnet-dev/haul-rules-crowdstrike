// Dragnet [Ransomware]: dragnet-ransomware-2022-2012 — Mass File Rename (lv)
// Status: deprecated | Level: high | ID: ea0ba458-5fc3-5256-a42c-67caf4ca0089

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
