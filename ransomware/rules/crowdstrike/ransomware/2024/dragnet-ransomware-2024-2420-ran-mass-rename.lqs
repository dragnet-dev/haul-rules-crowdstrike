// Dragnet [Ransomware]: dragnet-ransomware-2024-2420 — Mass File Rename (lockbit5)
// Status: experimental | Level: high | ID: 698bbf58-ea00-5c94-a7e3-963a5c1c8127

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
