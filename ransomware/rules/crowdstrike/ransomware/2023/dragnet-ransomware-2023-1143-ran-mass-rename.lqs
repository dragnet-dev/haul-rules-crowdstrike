// Dragnet [Ransomware]: dragnet-ransomware-2023-1143 — Mass File Rename (raworld)
// Status: experimental | Level: high | ID: 94a227e4-588e-5a18-b676-74f9afd0daf3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
