// Dragnet [Ransomware]: dragnet-ransomware-2025-1955 — Mass File Rename (nova)
// Status: experimental | Level: high | ID: aa0273f6-3291-5e04-ac1f-e87248c9dff7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
