// Dragnet [Ransomware]: dragnet-ransomware-2023-5038 — Mass File Rename (toufan)
// Status: deprecated | Level: high | ID: c104d78a-b049-5206-aafe-0bb2e7a5e1b2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
