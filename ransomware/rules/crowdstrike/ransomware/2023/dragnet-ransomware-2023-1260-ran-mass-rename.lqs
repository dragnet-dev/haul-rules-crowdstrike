// Dragnet [Ransomware]: dragnet-ransomware-2023-1260 — Mass File Rename (trigona)
// Status: experimental | Level: high | ID: 8a93a786-5fd6-5f41-baaa-2a86ad9b3d1b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
