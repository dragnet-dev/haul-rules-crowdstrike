// Dragnet [Container]: dragnet-container-2026-1970 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: b88e90e3-ea8c-5dcf-a7cf-6a6b7ffec537

#event_simpleName=*
| (ImageFileName = *amazonlinux:1* OR ImageFileName = *chainguard:* OR ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10* OR ImageFileName = *ubuntu:13.04*)
| table([timestamp, ComputerName])
| limit(1000)
