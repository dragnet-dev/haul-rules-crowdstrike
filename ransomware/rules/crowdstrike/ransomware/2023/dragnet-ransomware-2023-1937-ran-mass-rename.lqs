// Dragnet [Ransomware]: dragnet-ransomware-2023-1937 — Mass File Rename (knight)
// Status: experimental | Level: high | ID: 8a2b27c7-eb99-5eea-a7ed-d2a5cf86ab32

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
