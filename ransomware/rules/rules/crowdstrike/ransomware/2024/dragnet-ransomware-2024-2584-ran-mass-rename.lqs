// Dragnet [Ransomware]: dragnet-ransomware-2024-2584 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 45d887f7-9995-55aa-90e1-3dde123d78b9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
