// Dragnet [Ransomware]: dragnet-ransomware-2023-3637 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: dec1ba9e-7ab2-546c-928b-6939fcfe152c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
