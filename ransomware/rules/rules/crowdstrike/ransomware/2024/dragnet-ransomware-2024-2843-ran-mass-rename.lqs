// Dragnet [Ransomware]: dragnet-ransomware-2024-2843 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 024f971f-1ff5-5aea-b02f-b9934e83f4ef

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
