// Dragnet [Ransomware]: dragnet-ransomware-2025-5246 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 5425fb28-aa9b-5b66-8b3b-3d36bfbd9ea5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
