// Dragnet [Ransomware]: dragnet-ransomware-2025-1597 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: d948f219-89d3-55d1-b53a-199ceb6b9b38

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
