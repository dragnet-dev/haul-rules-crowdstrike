// Dragnet [Ransomware]: dragnet-ransomware-2024-5789 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: 78b55991-aa84-5624-ba0f-0ce5f15f239c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
