// Dragnet [Ransomware]: dragnet-ransomware-2026-0202 — Mass File Rename (dragonforce)
// Status: stable | Level: high | ID: 011b488e-c8b2-52c7-8bb5-be6924adaf56

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
