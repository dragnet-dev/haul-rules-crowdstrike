// Dragnet [Ransomware]: dragnet-ransomware-2025-1364 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: fb0eba09-dbf2-5abf-9dab-7bbcde65fdd0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
