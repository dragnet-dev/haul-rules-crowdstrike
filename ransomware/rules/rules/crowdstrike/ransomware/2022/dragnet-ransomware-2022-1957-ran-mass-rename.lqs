// Dragnet [Ransomware]: dragnet-ransomware-2022-1957 — Mass File Rename (stormous)
// Status: deprecated | Level: high | ID: 9027ee0c-bb45-57d8-aa33-b07b87e2fde5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
