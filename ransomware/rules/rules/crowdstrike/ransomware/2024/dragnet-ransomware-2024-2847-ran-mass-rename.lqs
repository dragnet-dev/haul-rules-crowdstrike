// Dragnet [Ransomware]: dragnet-ransomware-2024-2847 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: c260694a-06a8-5504-8b0c-3736d067bb56

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
