// Dragnet [Ransomware]: dragnet-ransomware-2024-0348 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: d9984c9a-4a45-5129-82af-7615797a8a13

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
