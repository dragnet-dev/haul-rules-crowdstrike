// Dragnet [Ransomware]: dragnet-ransomware-2025-5648 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 5479d45b-c3af-5725-b899-006577849cf6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
