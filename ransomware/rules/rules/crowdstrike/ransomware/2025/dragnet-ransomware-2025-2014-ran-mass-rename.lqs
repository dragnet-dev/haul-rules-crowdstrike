// Dragnet [Ransomware]: dragnet-ransomware-2025-2014 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: f5395935-de15-52a5-932e-527b094a02bf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
