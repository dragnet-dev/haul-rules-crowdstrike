// Dragnet [Ransomware]: dragnet-ransomware-2023-5064 — Mass File Rename (play)
// Status: experimental | Level: high | ID: d0ae3ad2-14b2-5c84-ae38-75349a828315

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
