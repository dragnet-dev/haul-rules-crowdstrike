// Dragnet [Ransomware]: dragnet-ransomware-2023-4866 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 565f8ae2-aba9-5d5c-9eb4-e404b9487e6a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
