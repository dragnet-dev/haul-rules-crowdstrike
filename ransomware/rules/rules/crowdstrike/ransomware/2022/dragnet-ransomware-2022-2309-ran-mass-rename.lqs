// Dragnet [Ransomware]: dragnet-ransomware-2022-2309 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 5f3427c1-1802-5d97-bf29-b2924932760d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
