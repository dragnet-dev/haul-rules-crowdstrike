// Dragnet [Ransomware]: dragnet-ransomware-2022-0702 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 18610207-e575-547b-9d0d-9a4c0e4e4da2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
