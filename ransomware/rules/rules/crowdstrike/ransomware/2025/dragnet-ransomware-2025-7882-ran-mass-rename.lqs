// Dragnet [Ransomware]: dragnet-ransomware-2025-7882 — Mass File Rename (interlock)
// Status: experimental | Level: high | ID: e6c1b495-8872-5baf-a89f-f1180f5837c2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
