// Dragnet [Ransomware]: dragnet-ransomware-2026-1183 — Mass File Rename (anubis)
// Status: stable | Level: high | ID: f0f52f2d-98c9-5a16-809f-1e15209ebd53

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
