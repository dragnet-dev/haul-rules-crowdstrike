// Dragnet [Ransomware]: dragnet-ransomware-2023-1467 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: db225776-f56f-5f54-a08a-2692d42931b6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
