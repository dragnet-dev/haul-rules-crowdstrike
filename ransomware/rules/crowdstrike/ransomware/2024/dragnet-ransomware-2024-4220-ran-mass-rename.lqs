// Dragnet [Ransomware]: dragnet-ransomware-2024-4220 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 48c74a18-b377-5a9d-8d9a-844423709591

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
