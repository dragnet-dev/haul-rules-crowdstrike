// Dragnet [Ransomware]: dragnet-ransomware-2022-0785 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 4b5463a5-1b45-5433-a90b-a5d356c2a06f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
