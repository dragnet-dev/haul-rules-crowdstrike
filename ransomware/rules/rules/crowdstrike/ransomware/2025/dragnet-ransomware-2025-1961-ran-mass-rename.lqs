// Dragnet [Ransomware]: dragnet-ransomware-2025-1961 — Mass File Rename (direwolf)
// Status: experimental | Level: high | ID: 1ab92948-3589-55c2-a1f7-e2b1387ec0e6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
