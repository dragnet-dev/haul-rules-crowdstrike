// Dragnet [Ransomware]: dragnet-ransomware-2024-0522 — Mass File Rename (cicada3301)
// Status: experimental | Level: high | ID: e85f9638-8c3a-50d9-b306-3c863f57df92

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
