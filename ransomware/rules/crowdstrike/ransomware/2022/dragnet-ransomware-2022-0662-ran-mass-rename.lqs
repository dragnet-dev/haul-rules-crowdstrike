// Dragnet [Ransomware]: dragnet-ransomware-2022-0662 — Mass File Rename (blackbasta)
// Status: deprecated | Level: high | ID: 40b1ef33-f61b-532c-b16c-0582a8e0f5fb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
