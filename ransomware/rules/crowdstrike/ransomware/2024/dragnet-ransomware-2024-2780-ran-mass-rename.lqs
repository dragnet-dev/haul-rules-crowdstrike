// Dragnet [Ransomware]: dragnet-ransomware-2024-2780 — Mass File Rename (threeam)
// Status: experimental | Level: high | ID: 03f4a7de-068c-5dd2-ad1b-65f3028fce41

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
