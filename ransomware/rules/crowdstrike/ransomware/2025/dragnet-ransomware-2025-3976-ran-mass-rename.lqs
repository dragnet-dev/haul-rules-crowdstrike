// Dragnet [Ransomware]: dragnet-ransomware-2025-3976 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: cc77f728-2f8b-5321-8446-0c881299a1ef

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
