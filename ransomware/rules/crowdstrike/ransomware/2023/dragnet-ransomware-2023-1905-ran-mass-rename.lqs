// Dragnet [Ransomware]: dragnet-ransomware-2023-1905 — Mass File Rename (royal)
// Status: experimental | Level: high | ID: 2e398e06-8aa4-5a1f-bb3c-2bf22d36f1ae

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
