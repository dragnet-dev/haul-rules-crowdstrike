// Dragnet [Ransomware]: dragnet-ransomware-2025-6588 — Mass File Rename (payoutsking)
// Status: deprecated | Level: high | ID: 9414ecae-ba2c-5a3e-9bdd-83c18e9ef15a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
