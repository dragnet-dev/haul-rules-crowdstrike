// Dragnet [Ransomware]: dragnet-ransomware-2024-2134 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 5a5988ed-9cf7-5dae-aabb-e20309becd73

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
