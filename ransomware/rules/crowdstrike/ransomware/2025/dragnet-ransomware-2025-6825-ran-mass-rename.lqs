// Dragnet [Ransomware]: dragnet-ransomware-2025-6825 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: eb12da08-d6d5-5b31-81de-b21fe22224d4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
