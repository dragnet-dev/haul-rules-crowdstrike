// Dragnet [Ransomware]: dragnet-ransomware-2026-0107 — Mass File Rename (handala)
// Status: stable | Level: high | ID: d4b04a3e-15ba-5a41-90a0-f8d6e13c92d7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
