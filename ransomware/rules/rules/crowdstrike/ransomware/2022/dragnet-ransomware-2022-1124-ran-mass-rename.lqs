// Dragnet [Ransomware]: dragnet-ransomware-2022-1124 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: ef71fbbc-bbc5-5a5f-8677-90b6d61ddf63

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
