// Dragnet [Ransomware]: dragnet-ransomware-2024-3164 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 2fae95ca-bfde-5448-b769-bea6cc4c8531

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
