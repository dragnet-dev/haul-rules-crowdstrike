// Dragnet [Ransomware]: dragnet-ransomware-2022-2693 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 77e48916-4c5a-52bd-a5d1-2389dc7a06b8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
