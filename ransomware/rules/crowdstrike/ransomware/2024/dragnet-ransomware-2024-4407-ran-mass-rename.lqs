// Dragnet [Ransomware]: dragnet-ransomware-2024-4407 — Mass File Rename (raworld)
// Status: experimental | Level: high | ID: 9b57d726-f927-529d-9dcf-b6c621b151e9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
