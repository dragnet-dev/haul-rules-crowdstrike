// Dragnet [Ransomware]: dragnet-ransomware-2025-7103 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 4f6e8a5e-7f75-57e7-8ac3-284653802c23

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
