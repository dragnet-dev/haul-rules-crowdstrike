// Dragnet [Ransomware]: dragnet-ransomware-2026-3529 — Mass File Rename (krybit)
// Status: stable | Level: high | ID: 240cdb50-0e65-568e-9f27-0290cb83cfa3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
