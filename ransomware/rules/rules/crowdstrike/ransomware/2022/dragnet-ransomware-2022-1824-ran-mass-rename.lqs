// Dragnet [Ransomware]: dragnet-ransomware-2022-1824 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: d1aceccb-945b-5178-9611-a7543e5f68a6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
