// Dragnet [Ransomware]: dragnet-ransomware-2022-1135 — Mass File Rename (lv)
// Status: deprecated | Level: high | ID: eb90b731-21b4-5869-bc07-976868fa172d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
