// Dragnet [Ransomware]: dragnet-ransomware-2025-4853 — Mass File Rename (IMNCrew)
// Status: experimental | Level: high | ID: 1a813ba2-3ff0-5c83-be97-4ec8f1fdb812

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
