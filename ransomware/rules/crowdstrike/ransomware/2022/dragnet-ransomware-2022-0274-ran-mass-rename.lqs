// Dragnet [Ransomware]: dragnet-ransomware-2022-0274 — Mass File Rename (stormous)
// Status: deprecated | Level: high | ID: b82dbd08-6441-5601-bd0d-7ecf37d57428

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
