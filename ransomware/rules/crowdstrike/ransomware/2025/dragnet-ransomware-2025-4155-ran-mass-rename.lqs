// Dragnet [Ransomware]: dragnet-ransomware-2025-4155 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 7e0b13c0-71f1-5382-9fea-bb4d627b1d2e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
