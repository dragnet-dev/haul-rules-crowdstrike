// Dragnet [Ransomware]: dragnet-ransomware-2025-1478 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 2998c69c-85a3-5350-a48f-2ae35fa0b81e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
