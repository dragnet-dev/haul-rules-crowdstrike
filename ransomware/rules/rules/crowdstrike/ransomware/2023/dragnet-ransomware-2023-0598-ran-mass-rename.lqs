// Dragnet [Ransomware]: dragnet-ransomware-2023-0598 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: 0792ab36-0b49-57ce-9b9c-73fb1bbe7cde

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
