// Dragnet [Ransomware]: dragnet-ransomware-2023-4781 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: a08f8edb-43e0-5f32-9555-a7f71668be20

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
