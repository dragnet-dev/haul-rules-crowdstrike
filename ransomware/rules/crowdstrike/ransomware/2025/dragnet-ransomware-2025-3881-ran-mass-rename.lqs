// Dragnet [Ransomware]: dragnet-ransomware-2025-3881 — Mass File Rename (worldleaks)
// Status: experimental | Level: high | ID: dbe70017-c14c-5ce8-a77e-d3f9c0c7a9ce

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
