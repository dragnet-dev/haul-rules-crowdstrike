// Dragnet [Ransomware]: dragnet-ransomware-2025-4047 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: 9e5341bc-bda9-56a2-b6b8-10ff45b8de32

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
