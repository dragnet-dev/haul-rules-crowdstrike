// Dragnet [Ransomware]: dragnet-ransomware-2025-4166 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 47ca2087-ae89-5b23-b2e5-cb9566a6826f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
