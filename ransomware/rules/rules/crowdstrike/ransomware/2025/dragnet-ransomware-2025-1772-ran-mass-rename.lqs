// Dragnet [Ransomware]: dragnet-ransomware-2025-1772 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 5ae140eb-e668-5b03-a371-47f3f9c22dc0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
