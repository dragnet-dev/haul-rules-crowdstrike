// Dragnet [Ransomware]: dragnet-ransomware-2025-0601 — Mass File Rename (handala)
// Status: experimental | Level: high | ID: d92a403d-ce2b-57b4-b845-d1ca8ad97bb9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
