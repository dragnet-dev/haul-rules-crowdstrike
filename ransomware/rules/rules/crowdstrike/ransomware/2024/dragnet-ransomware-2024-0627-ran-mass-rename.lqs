// Dragnet [Ransomware]: dragnet-ransomware-2024-0627 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: 69ea5adf-f508-5e5f-a07c-294f812dd7a0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
