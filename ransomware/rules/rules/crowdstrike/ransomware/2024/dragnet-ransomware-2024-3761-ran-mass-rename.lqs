// Dragnet [Ransomware]: dragnet-ransomware-2024-3761 — Mass File Rename (meow)
// Status: experimental | Level: high | ID: 5bff5dc6-eb64-59da-84f1-6f575f2a774b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
