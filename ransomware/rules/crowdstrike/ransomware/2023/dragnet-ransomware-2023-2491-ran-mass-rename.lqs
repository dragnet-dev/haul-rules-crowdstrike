// Dragnet [Ransomware]: dragnet-ransomware-2023-2491 — Mass File Rename (cloak)
// Status: deprecated | Level: high | ID: 651f0014-7ac8-57af-bfb5-263dc62f3646

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
