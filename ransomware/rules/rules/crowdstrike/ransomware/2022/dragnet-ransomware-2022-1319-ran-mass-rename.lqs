// Dragnet [Ransomware]: dragnet-ransomware-2022-1319 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: 0ae2d018-4ba6-5e25-85c0-a0adc33a0a06

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
