// Dragnet [Ransomware]: dragnet-ransomware-2024-5792 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: f84a5d4b-cab9-582b-aaf5-55fc11f11179

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
