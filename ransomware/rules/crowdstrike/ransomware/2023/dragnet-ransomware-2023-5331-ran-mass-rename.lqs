// Dragnet [Ransomware]: dragnet-ransomware-2023-5331 — Mass File Rename (dunghill)
// Status: experimental | Level: high | ID: 776e4a43-6a82-5026-ae36-28a6bff32022

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
