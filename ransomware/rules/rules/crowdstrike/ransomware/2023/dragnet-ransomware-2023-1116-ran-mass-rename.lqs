// Dragnet [Ransomware]: dragnet-ransomware-2023-1116 — Mass File Rename (arvinclub)
// Status: experimental | Level: high | ID: fc5c3701-9ad1-5213-b455-c05b6fef8ef0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
