// Dragnet [Ransomware]: dragnet-ransomware-2023-1095 — Mass File Rename (snatch)
// Status: experimental | Level: high | ID: 94c0c818-c846-52b8-ac45-3a2b27fdcba8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
