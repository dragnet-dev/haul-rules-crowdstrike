// Dragnet [Ransomware]: dragnet-ransomware-2024-3808 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: ab6caa4e-eda0-5c13-8c63-38426f0723af

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
