// Dragnet [Ransomware]: dragnet-ransomware-2025-1296 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: fb2c008e-7947-5641-bd8d-90a5506c0186

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
