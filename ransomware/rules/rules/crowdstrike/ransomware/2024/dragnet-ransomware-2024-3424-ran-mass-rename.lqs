// Dragnet [Ransomware]: dragnet-ransomware-2024-3424 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: f86084c3-9c45-5feb-925c-f797ae9dbef2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
