// Dragnet [Ransomware]: dragnet-ransomware-2023-1952 — Mass File Rename (stormous)
// Status: experimental | Level: high | ID: 1999b866-4d23-5b70-9b6d-780cb9f761c7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
