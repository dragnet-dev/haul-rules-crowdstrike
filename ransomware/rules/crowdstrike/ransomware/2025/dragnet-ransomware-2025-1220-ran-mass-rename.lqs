// Dragnet [Ransomware]: dragnet-ransomware-2025-1220 — Mass File Rename (handala)
// Status: experimental | Level: high | ID: 19a99dc0-4d6c-5490-90a4-cc1307b5b768

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
