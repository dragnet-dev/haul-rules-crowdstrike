// Dragnet [Container]: dragnet-container-2024-1328 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 9895318e-1b94-5edc-a481-e8531e5577a8

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:9* OR ImageFileName = *ubuntu:18.04*)
| table([timestamp, ComputerName])
| limit(1000)
