// Dragnet [Ransomware]: dragnet-ransomware-2025-7213 — Mass File Rename (sarcoma)
// Status: deprecated | Level: high | ID: 924eaa81-a520-52d1-989c-a6595145fb38

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
