// Dragnet [Ransomware]: dragnet-ransomware-2023-0815 — Mass File Rename (nokoyawa)
// Status: experimental | Level: high | ID: bb24414c-2493-5c78-ae23-90719e890d86

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
