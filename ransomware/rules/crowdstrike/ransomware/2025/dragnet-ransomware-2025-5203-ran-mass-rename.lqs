// Dragnet [Ransomware]: dragnet-ransomware-2025-5203 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: ef52461f-830c-5839-8a0a-d0c2bb6c7a8d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
