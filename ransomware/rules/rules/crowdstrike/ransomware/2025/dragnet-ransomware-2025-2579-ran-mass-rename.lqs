// Dragnet [Ransomware]: dragnet-ransomware-2025-2579 — Mass File Rename (beast)
// Status: experimental | Level: high | ID: 63ba964e-1b7d-575d-96d4-5e4ddeb3f6e2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
