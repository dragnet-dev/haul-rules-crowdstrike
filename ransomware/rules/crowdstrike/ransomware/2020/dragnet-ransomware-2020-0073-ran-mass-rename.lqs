// Dragnet [Ransomware]: dragnet-ransomware-2020-0073 — Mass File Rename (ransomexx)
// Status: deprecated | Level: high | ID: 3ed611ee-5ac9-52dc-bcc2-2850d0d21af2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
