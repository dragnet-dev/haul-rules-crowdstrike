// Dragnet [Ransomware]: dragnet-ransomware-2024-2814 — Mass File Rename (dragonforce)
// Status: deprecated | Level: high | ID: 882a5129-ba82-5a27-a95e-20a4116fe160

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
