// Dragnet [Ransomware]: dragnet-ransomware-2024-2914 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 15cfb8f4-c6b0-5976-b5e8-8f71150a5f1b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
