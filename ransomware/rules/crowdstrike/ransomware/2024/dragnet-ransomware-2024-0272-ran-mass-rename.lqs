// Dragnet [Ransomware]: dragnet-ransomware-2024-0272 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: c33c91bf-e270-56b8-b167-de466414d205

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
