// Dragnet [Ransomware]: dragnet-ransomware-2023-1287 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: b32cdafb-b931-57c1-9a50-ad91a83ee648

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
