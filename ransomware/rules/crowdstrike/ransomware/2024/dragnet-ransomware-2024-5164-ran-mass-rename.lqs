// Dragnet [Ransomware]: dragnet-ransomware-2024-5164 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 3b7cf824-8629-57c7-9f3f-0a15044a343c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
