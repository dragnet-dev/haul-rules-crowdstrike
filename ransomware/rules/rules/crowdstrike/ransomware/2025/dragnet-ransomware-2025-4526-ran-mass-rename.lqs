// Dragnet [Ransomware]: dragnet-ransomware-2025-4526 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 975d3b12-e353-52a5-a00d-b3e441b993d4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
