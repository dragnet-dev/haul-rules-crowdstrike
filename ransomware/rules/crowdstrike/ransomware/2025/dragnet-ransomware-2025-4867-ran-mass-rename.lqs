// Dragnet [Ransomware]: dragnet-ransomware-2025-4867 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: dc4a82ea-6c8f-5fe3-a821-88119337a19b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
