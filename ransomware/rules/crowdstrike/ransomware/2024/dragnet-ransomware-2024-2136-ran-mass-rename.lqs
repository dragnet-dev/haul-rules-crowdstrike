// Dragnet [Ransomware]: dragnet-ransomware-2024-2136 — Mass File Rename (meow)
// Status: experimental | Level: high | ID: f649efb3-02af-554e-b3fe-ef0a663491a9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
