// Dragnet [Ransomware]: dragnet-ransomware-2025-7805 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: eb0cbf6a-6751-50d2-9a40-4ddfa292484d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
