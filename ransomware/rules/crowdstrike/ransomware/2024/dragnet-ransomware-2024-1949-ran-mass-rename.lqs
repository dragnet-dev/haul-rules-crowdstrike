// Dragnet [Ransomware]: dragnet-ransomware-2024-1949 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 7a3bf022-ebeb-5cd5-ab91-8d1c08839ea0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
