// Dragnet [Ransomware]: dragnet-ransomware-2025-0878 — Mass File Rename (incransom)
// Status: test | Level: high | ID: d752637e-33a4-5d4e-b276-3707810a1d39

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
