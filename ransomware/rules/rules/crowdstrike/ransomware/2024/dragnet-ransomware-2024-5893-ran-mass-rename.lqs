// Dragnet [Ransomware]: dragnet-ransomware-2024-5893 — Mass File Rename (monti)
// Status: experimental | Level: high | ID: 5d093c65-23e0-5363-8ec7-52e7397734f5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
