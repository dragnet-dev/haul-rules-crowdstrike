// Dragnet [Ransomware]: dragnet-ransomware-2025-5329 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: d4ee311e-7112-517e-827e-2322244d9696

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
