// Dragnet [Ransomware]: dragnet-ransomware-2022-2284 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: a4ea64a1-c1d3-558d-9629-89970fc3fcc2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
