// Dragnet [Ransomware]: dragnet-ransomware-2024-0696 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 5118d6bd-3b28-568f-9242-0eaa9e886fb9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
