// Dragnet [Ransomware]: dragnet-ransomware-2026-3516 — Mass File Rename (dragonforce)
// Status: test | Level: high | ID: 4af24f2a-dec1-517c-946e-357a12e323d9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
