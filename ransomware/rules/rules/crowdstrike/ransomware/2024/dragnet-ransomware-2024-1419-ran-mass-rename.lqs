// Dragnet [Ransomware]: dragnet-ransomware-2024-1419 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: d51e4a14-5222-5aa1-b478-c509444dfadd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
