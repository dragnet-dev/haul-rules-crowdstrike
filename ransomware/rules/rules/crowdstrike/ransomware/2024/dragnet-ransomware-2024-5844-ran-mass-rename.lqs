// Dragnet [Ransomware]: dragnet-ransomware-2024-5844 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 888549a6-ded7-5b30-966c-5a422c2e77a4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
