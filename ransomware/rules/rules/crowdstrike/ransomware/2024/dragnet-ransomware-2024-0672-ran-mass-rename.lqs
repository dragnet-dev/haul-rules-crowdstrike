// Dragnet [Ransomware]: dragnet-ransomware-2024-0672 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: edd9a3fb-239a-5843-8217-91758e5521df

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
