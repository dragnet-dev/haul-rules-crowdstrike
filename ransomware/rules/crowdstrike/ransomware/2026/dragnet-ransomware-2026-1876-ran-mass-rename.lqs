// Dragnet [Ransomware]: dragnet-ransomware-2026-1876 — Mass File Rename (lockbit5)
// Status: stable | Level: high | ID: a023f650-f218-5756-ac91-18329a99bacb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
