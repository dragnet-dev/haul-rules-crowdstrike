// Dragnet [Ransomware]: dragnet-ransomware-2021-1496 — Mass File Rename (revil)
// Status: deprecated | Level: high | ID: 442b79ae-015c-5c1e-b782-9a45cd6b8fa1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
