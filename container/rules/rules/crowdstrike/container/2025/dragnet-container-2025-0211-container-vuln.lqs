// Dragnet [Container]: dragnet-container-2025-0211 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: f8ec86ea-3a09-532e-b9f8-f1269342551d

#event_simpleName=*
| (ImageFileName = *amazonlinux:2* OR ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *redhat/ubi9:*)
| table([timestamp, ComputerName])
| limit(1000)
