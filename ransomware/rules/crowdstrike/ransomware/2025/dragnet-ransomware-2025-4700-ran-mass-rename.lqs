// Dragnet [Ransomware]: dragnet-ransomware-2025-4700 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 20830e26-7da8-583d-8329-042f4b79eefc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
