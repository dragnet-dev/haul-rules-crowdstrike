// Dragnet [Ransomware]: dragnet-ransomware-2025-5743 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 884cfd73-f7a8-59c6-9563-d8f6d00be01a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
