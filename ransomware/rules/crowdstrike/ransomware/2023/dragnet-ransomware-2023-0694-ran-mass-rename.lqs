// Dragnet [Ransomware]: dragnet-ransomware-2023-0694 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 85ba03e7-88bd-508e-919b-34f637be6c50

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
