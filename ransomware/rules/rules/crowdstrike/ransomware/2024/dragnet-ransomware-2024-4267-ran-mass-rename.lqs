// Dragnet [Ransomware]: dragnet-ransomware-2024-4267 — Mass File Rename (play)
// Status: experimental | Level: high | ID: fe428a74-6b35-5da8-8950-bda505ac87a0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
