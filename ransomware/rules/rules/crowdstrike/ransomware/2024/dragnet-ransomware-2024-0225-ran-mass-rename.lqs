// Dragnet [Ransomware]: dragnet-ransomware-2024-0225 — Mass File Rename (trigona)
// Status: experimental | Level: high | ID: 73def847-1e32-5fc8-81bc-54b5a966f259

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
