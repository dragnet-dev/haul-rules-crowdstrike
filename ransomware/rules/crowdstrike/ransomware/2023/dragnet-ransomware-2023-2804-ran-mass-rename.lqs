// Dragnet [Ransomware]: dragnet-ransomware-2023-2804 — Mass File Rename (malas)
// Status: experimental | Level: high | ID: 0a67ec28-7c43-524f-8872-fb3e640e1369

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
