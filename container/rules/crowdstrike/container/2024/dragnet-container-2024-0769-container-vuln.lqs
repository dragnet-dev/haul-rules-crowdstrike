// Dragnet [Container]: dragnet-container-2024-0769 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 82a43682-3804-5eab-b394-03242f51ca41

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:9* OR ImageFileName = *photon os:4.0* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:18.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
