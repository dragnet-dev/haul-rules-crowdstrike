// Dragnet [Ransomware]: dragnet-ransomware-2025-4717 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: a97c4953-d063-5fad-b56e-cffa1851d7e1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
