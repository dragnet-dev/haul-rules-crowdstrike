// Dragnet [Ransomware]: dragnet-ransomware-2024-0087 — Mass File Rename (raworld)
// Status: experimental | Level: high | ID: d6bdbe09-9549-5ac9-96c9-6a001999c2bc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
