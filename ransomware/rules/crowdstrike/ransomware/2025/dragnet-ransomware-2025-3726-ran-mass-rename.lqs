// Dragnet [Ransomware]: dragnet-ransomware-2025-3726 — Mass File Rename (spacebears)
// Status: experimental | Level: high | ID: a06d6e8d-fc97-55cd-bdce-41903df43abd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
