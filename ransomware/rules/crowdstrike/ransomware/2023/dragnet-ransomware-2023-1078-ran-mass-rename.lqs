// Dragnet [Ransomware]: dragnet-ransomware-2023-1078 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 37b57024-6519-5455-9f5b-069a32b39157

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
