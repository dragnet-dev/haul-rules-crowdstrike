// Dragnet [Ransomware]: dragnet-ransomware-2025-7085 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: a71e5ace-602f-548f-8cc5-93af2e3f6548

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
