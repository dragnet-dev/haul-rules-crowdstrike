// Dragnet [Ransomware]: dragnet-ransomware-2025-1400 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: e814e043-679d-50aa-866f-070fba371ec0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
