// Dragnet [Ransomware]: dragnet-ransomware-2023-4291 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 860be0bd-4a69-5e9d-837f-3adbf5394083

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
