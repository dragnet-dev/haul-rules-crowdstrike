// Dragnet [Ransomware]: dragnet-ransomware-2025-0919 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: a8f64087-9e3a-5376-ad94-a6bd784b9093

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
