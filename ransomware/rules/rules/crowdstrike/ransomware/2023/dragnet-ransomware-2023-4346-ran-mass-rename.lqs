// Dragnet [Ransomware]: dragnet-ransomware-2023-4346 — Mass File Rename (cuba)
// Status: deprecated | Level: high | ID: f44d0c69-3e22-5076-b918-85b600e17db5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
