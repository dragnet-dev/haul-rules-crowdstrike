// Dragnet [Ransomware]: dragnet-ransomware-2022-2531 — Mass File Rename (lv)
// Status: deprecated | Level: high | ID: 65814823-3d14-55c5-a921-0f3d9860c234

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
