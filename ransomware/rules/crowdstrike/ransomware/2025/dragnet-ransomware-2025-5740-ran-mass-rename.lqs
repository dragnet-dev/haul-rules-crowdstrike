// Dragnet [Ransomware]: dragnet-ransomware-2025-5740 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 6fa5e6d4-458e-5e71-bd72-82e79c8dd15d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
