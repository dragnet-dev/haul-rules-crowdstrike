// Dragnet [Ransomware]: dragnet-ransomware-2026-1753 — Mass File Rename (AiLock)
// Status: deprecated | Level: high | ID: c1f539cb-096e-5489-882f-fc68a1b847b9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
