// Dragnet [Ransomware]: dragnet-ransomware-2025-4646 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: e18c7a7b-4c08-588f-b56c-b756cb58f220

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
