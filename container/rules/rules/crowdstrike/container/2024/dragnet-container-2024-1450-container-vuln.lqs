// Dragnet [Container]: dragnet-container-2024-1450 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 013b589a-2e61-5d5b-8c60-ef023685fe4e

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:7* OR ImageFileName = *debian:8* OR ImageFileName = *oraclelinux:7* OR ImageFileName = *ubuntu:16.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
