// Dragnet [Ransomware]: dragnet-ransomware-2021-0015 — Mass File Rename (quantum)
// Status: deprecated | Level: high | ID: 749d429f-0d44-5411-8261-02b2f3749496

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
