// Dragnet [Ransomware]: dragnet-ransomware-2023-2338 — Mass File Rename (darkrace)
// Status: experimental | Level: high | ID: 6afc1ac1-889b-5d62-9225-3fd7cf0a75f1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
