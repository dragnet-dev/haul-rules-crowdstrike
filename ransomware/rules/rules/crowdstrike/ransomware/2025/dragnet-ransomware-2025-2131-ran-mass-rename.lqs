// Dragnet [Ransomware]: dragnet-ransomware-2025-2131 — Mass File Rename (blacknevas)
// Status: experimental | Level: high | ID: d84f73a7-9bff-5a34-87b1-7ea1e6d7eca9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
