// Dragnet [Ransomware]: dragnet-ransomware-2025-1644 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 6f7b6a0b-1240-5db2-9a33-b17def28490b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
