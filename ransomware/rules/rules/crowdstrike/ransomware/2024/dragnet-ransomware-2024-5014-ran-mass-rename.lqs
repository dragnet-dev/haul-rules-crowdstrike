// Dragnet [Ransomware]: dragnet-ransomware-2024-5014 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 7310979e-a776-519a-822c-e82b8b2a1677

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
