// Dragnet [Ransomware]: dragnet-ransomware-2025-4156 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: eda30aef-0c67-5bad-af0d-9b1ac1fa3a28

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
