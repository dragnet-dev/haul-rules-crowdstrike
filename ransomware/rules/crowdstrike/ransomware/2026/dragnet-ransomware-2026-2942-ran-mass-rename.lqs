// Dragnet [Ransomware]: dragnet-ransomware-2026-2942 — Mass File Rename (spacebears)
// Status: test | Level: high | ID: 51fb1d4f-bd8c-522e-bb33-eb3833f73bec

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
