// Dragnet [Ransomware]: dragnet-ransomware-2024-1240 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: e515e5ae-188c-5cfc-a03c-8be5dcd99ef3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
