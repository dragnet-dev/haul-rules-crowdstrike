// Dragnet [Ransomware]: dragnet-ransomware-2026-2073 — Mass File Rename (payload)
// Status: stable | Level: high | ID: a242a823-3b52-5767-ba98-3229d648d5b9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
