// Dragnet [Ransomware]: dragnet-ransomware-2025-0284 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: f540c094-d93b-51a4-a7ea-b4053203a1d5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
