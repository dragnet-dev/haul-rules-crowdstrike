// Dragnet [Ransomware]: dragnet-ransomware-2025-7297 — Mass File Rename (embargo)
// Status: experimental | Level: high | ID: a3e6f558-a719-5f3f-a359-5a99afd4e2a0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
