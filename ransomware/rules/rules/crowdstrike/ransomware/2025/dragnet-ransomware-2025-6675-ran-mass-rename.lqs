// Dragnet [Ransomware]: dragnet-ransomware-2025-6675 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 05e8cc59-759c-51a7-867c-514e75d0076f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
