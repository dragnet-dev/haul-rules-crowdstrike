// Dragnet [Ransomware]: dragnet-ransomware-2025-6670 — Mass File Rename (devman)
// Status: deprecated | Level: high | ID: b7c46655-2dc6-559c-bad8-faddd50eba15

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
