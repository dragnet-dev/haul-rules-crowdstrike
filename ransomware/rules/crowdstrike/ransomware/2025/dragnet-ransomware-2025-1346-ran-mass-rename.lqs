// Dragnet [Ransomware]: dragnet-ransomware-2025-1346 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: f1b1c3fe-6ecd-5f1b-9fe5-97158a810194

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
