// Dragnet [Container]: dragnet-container-2024-0811 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: f75b5268-6e7c-57eb-ad37-e571f23e3cb1

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:8* OR ImageFileName = *debian:9* OR ImageFileName = *ubuntu:18.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
