// Dragnet [Ransomware]: dragnet-ransomware-2025-7790 — Mass File Rename (warlock)
// Status: deprecated | Level: high | ID: ad5a56b5-f4a6-5378-ab5e-f4f9a28f8389

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
