// Dragnet [Ransomware]: dragnet-ransomware-2024-0472 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: d8883c3d-bb5d-5d57-b780-fef059fd7177

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
