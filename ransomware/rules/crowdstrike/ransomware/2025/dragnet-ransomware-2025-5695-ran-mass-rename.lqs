// Dragnet [Ransomware]: dragnet-ransomware-2025-5695 — Mass File Rename (blacklock)
// Status: experimental | Level: high | ID: 275cf9f2-5ab0-5d50-85cb-7cee04e5433b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
