// Dragnet [Ransomware]: dragnet-ransomware-2025-6873 — Mass File Rename (nightspire)
// Status: deprecated | Level: high | ID: 04110345-e1a0-5e33-b5d9-dbf36a032e27

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
