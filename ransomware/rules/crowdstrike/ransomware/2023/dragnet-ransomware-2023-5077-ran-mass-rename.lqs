// Dragnet [Ransomware]: dragnet-ransomware-2023-5077 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 8f9e18c8-cfb5-540f-b504-477005feccb5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
