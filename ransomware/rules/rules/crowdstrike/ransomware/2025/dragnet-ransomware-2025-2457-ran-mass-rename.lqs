// Dragnet [Ransomware]: dragnet-ransomware-2025-2457 — Mass File Rename (thegentlemen)
// Status: experimental | Level: high | ID: d12cc0d3-46ab-5315-85a8-4d27c4665272

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
