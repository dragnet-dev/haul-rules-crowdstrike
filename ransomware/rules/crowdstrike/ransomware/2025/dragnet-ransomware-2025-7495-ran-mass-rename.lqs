// Dragnet [Ransomware]: dragnet-ransomware-2025-7495 — Mass File Rename (handala)
// Status: experimental | Level: high | ID: 6406b63f-4dd1-5547-b325-52ba1f58daa0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
