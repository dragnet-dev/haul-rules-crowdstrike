// Dragnet [Ransomware]: dragnet-ransomware-2023-1333 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 7fc69907-c42e-540e-bf21-a2821f120b83

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
