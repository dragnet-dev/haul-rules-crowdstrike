// Dragnet [Ransomware]: dragnet-ransomware-2023-1367 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 0842020e-60d7-5ebd-a53f-29b8109ed0b1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
