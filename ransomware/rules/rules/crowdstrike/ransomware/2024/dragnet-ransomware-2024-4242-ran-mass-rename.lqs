// Dragnet [Ransomware]: dragnet-ransomware-2024-4242 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 78c8b78a-b323-5437-9a26-3eed9c5b5d16

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
