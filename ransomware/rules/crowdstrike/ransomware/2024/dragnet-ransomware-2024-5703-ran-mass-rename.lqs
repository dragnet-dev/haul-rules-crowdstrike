// Dragnet [Ransomware]: dragnet-ransomware-2024-5703 — Mass File Rename (underground)
// Status: experimental | Level: high | ID: 2e83f008-3f90-546c-a7d9-b5fd564599da

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
