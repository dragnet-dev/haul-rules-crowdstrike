// Dragnet [Ransomware]: dragnet-ransomware-2022-0655 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 87e7ceef-dc47-5146-b93d-3ba7c087c3bc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
