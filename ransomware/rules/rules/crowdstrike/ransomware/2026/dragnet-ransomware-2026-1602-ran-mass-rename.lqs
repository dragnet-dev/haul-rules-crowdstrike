// Dragnet [Ransomware]: dragnet-ransomware-2026-1602 — Mass File Rename (dragonforce)
// Status: stable | Level: high | ID: ed393512-8a2f-5760-b826-9814c0187071

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
