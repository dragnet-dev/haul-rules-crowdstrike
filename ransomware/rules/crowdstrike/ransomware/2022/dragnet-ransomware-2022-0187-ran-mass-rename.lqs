// Dragnet [Ransomware]: dragnet-ransomware-2022-0187 — Mass File Rename (blackbasta)
// Status: deprecated | Level: high | ID: 9669aa6a-b2dd-5237-8c47-e190fe9f13df

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
