// Dragnet [Ransomware]: dragnet-ransomware-2024-2732 — Mass File Rename (stormous)
// Status: deprecated | Level: high | ID: f884701b-014b-5794-99d2-e415be0b88ce

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
