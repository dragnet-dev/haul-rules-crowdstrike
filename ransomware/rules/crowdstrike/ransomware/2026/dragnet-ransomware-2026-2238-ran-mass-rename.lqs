// Dragnet [Ransomware]: dragnet-ransomware-2026-2238 — Mass File Rename (benzona)
// Status: deprecated | Level: high | ID: d7ae099b-ef92-5cdf-ac4b-5fe2a829cffe

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
