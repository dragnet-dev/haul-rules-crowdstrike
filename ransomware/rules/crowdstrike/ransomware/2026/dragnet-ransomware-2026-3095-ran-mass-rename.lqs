// Dragnet [Ransomware]: dragnet-ransomware-2026-3095 — Mass File Rename (securotrop)
// Status: stable | Level: high | ID: 00906e50-e86f-5dc3-a047-653889d6690b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
