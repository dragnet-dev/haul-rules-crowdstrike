// Dragnet [Ransomware]: dragnet-ransomware-2025-6536 — Mass File Rename (play)
// Status: experimental | Level: high | ID: ac387c1e-e41c-5934-9ceb-64acebbe34cb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
