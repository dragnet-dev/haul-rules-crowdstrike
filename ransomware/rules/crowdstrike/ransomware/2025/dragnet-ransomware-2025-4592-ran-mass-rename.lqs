// Dragnet [Ransomware]: dragnet-ransomware-2025-4592 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: 5a156b19-3777-5de7-8a04-60ab4685fa5b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
