// Dragnet [Ransomware]: dragnet-ransomware-2025-5558 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 90dfc65b-765e-511a-a885-8035d1ada996

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
