// Dragnet [Ransomware]: dragnet-ransomware-2025-1943 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 69898beb-117c-5b92-b964-1c0fff8480ec

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
