// Dragnet [Ransomware]: dragnet-ransomware-2025-0419 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 60ef437e-9378-575b-adbd-b504808c38a3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
