// Dragnet [Ransomware]: dragnet-ransomware-2024-0242 — Mass File Rename (helldown)
// Status: experimental | Level: high | ID: 4ad13204-3b7f-5059-bdb7-7525a3bb0841

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
