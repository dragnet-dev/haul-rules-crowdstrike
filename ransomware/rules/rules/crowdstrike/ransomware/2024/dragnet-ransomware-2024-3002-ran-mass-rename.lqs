// Dragnet [Ransomware]: dragnet-ransomware-2024-3002 — Mass File Rename (ElDorado)
// Status: deprecated | Level: high | ID: a1b961ae-d269-50c5-9398-52c66914087f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
