// Dragnet [Ransomware]: dragnet-ransomware-2024-3182 — Mass File Rename (BrainCipher)
// Status: experimental | Level: high | ID: 3581c082-cbb9-54ec-a095-03c767d145bf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
