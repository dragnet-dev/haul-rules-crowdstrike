// Dragnet [Ransomware]: dragnet-ransomware-2023-3767 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: ad393d32-338f-5973-a939-34c033d0052d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
