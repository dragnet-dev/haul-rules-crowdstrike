// Dragnet [Ransomware]: dragnet-ransomware-2023-1475 — Mass File Rename (raworld)
// Status: experimental | Level: high | ID: 3bc8965f-7ffa-5b9b-b28d-c6ea2ba98d34

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
