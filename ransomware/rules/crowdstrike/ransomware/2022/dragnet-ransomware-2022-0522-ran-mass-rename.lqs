// Dragnet [Ransomware]: dragnet-ransomware-2022-0522 — Mass File Rename (cuba)
// Status: deprecated | Level: high | ID: 34fb069b-b8da-56c7-b35e-0bac7d32bccf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
