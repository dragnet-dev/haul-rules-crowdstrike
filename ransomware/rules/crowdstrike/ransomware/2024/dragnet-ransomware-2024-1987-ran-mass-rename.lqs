// Dragnet [Ransomware]: dragnet-ransomware-2024-1987 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 82a6730b-8923-5775-b76c-bd7b3efd2623

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
