// Dragnet [Ransomware]: dragnet-ransomware-2025-2289 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: cfc2c740-a472-563b-8126-9a1639a68935

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
