// Dragnet [Ransomware]: dragnet-ransomware-2023-3128 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 49da4df0-fec9-5272-ad2c-530cfc1a4560

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
