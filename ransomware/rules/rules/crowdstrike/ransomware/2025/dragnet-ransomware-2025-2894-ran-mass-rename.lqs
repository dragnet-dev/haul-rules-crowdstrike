// Dragnet [Ransomware]: dragnet-ransomware-2025-2894 — Mass File Rename (play)
// Status: experimental | Level: high | ID: cd7bf4e6-be23-51da-89f0-49fa91bdef12

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
