// Dragnet [Ransomware]: dragnet-ransomware-2024-3185 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: dd9ed405-0256-574d-bc60-9ee2d0186c3e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
