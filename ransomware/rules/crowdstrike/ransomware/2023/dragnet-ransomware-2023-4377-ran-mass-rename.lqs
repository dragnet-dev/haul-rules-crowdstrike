// Dragnet [Ransomware]: dragnet-ransomware-2023-4377 — Mass File Rename (ransomed)
// Status: deprecated | Level: high | ID: 59f138c5-48d4-54eb-9aaa-9d19b10b0d08

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
