// Dragnet [Ransomware]: dragnet-ransomware-2022-2959 — Mass File Rename (blackbasta)
// Status: deprecated | Level: high | ID: d05df5e4-2c13-558d-85d9-d29931f19a0d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
