// Dragnet [Ransomware]: dragnet-ransomware-2022-1123 — Mass File Rename (quantum)
// Status: deprecated | Level: high | ID: 05819e92-468e-50a1-a0ee-c87baf23b597

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
