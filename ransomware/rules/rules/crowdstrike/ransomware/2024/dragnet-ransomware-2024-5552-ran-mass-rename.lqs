// Dragnet [Ransomware]: dragnet-ransomware-2024-5552 — Mass File Rename (dragonforce)
// Status: deprecated | Level: high | ID: 45bc5d79-532e-561d-a7a4-f11a92325c51

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
