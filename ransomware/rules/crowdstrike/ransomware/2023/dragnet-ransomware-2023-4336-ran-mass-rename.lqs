// Dragnet [Ransomware]: dragnet-ransomware-2023-4336 — Mass File Rename (royal)
// Status: experimental | Level: high | ID: ea3a7ff4-f743-58c3-b9ae-1d7cd36d7128

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
