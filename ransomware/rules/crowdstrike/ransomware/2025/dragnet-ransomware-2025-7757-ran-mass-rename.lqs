// Dragnet [Ransomware]: dragnet-ransomware-2025-7757 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 6e01b687-c4f4-5947-bc8e-cf0155722832

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
