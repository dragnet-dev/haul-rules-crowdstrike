// Dragnet [Ransomware]: dragnet-ransomware-2025-7813 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: a3e4e5a8-c9b9-5765-a787-678f27bdc448

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
