// Dragnet [Ransomware]: dragnet-ransomware-2023-0754 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: fe761f5f-de0f-57b5-961d-579f08a75359

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
