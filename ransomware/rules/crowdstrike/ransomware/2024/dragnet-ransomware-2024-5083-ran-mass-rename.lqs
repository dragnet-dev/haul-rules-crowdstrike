// Dragnet [Ransomware]: dragnet-ransomware-2024-5083 — Mass File Rename (dragonforce)
// Status: deprecated | Level: high | ID: 88930d06-d477-5448-a65c-f39e5c8fd1d7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
