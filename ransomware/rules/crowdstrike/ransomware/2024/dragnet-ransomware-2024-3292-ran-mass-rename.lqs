// Dragnet [Ransomware]: dragnet-ransomware-2024-3292 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 970668ce-73a2-5ad3-90ba-49be9809ca69

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
