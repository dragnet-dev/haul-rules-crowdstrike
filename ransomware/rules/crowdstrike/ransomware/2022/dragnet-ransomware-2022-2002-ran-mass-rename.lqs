// Dragnet [Ransomware]: dragnet-ransomware-2022-2002 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 73372ac0-eddf-573f-bfbd-5f2216000340

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
