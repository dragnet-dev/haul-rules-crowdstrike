// Dragnet [Ransomware]: dragnet-ransomware-2025-0310 — Mass File Rename (payoutsking)
// Status: experimental | Level: high | ID: 93536c8b-e0e4-5cc2-8fad-d869acc13496

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
