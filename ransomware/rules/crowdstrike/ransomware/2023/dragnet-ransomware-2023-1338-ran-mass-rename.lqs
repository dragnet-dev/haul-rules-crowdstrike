// Dragnet [Ransomware]: dragnet-ransomware-2023-1338 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: b67714fe-a712-5af9-8dc5-c4a8c87bde78

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
