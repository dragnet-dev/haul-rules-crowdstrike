// Dragnet [Ransomware]: dragnet-ransomware-2025-3341 — Mass File Rename (termite)
// Status: experimental | Level: high | ID: 02d0d870-2a0b-57f7-9d6c-1ae3af7f324c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
