// Dragnet [Ransomware]: dragnet-ransomware-2021-0577 — Mass File Rename (everest)
// Status: deprecated | Level: high | ID: aedc1e11-239d-57d9-a875-8f1ebfbd0e2f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
