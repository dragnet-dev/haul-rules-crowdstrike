// Dragnet [Ransomware]: dragnet-ransomware-2023-1802 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 2468820c-223f-5d4c-aca9-558c0fa43e84

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
