// Dragnet [Ransomware]: dragnet-ransomware-2026-3496 — Mass File Rename (everest)
// Status: stable | Level: high | ID: a0e6eff3-3ea2-53fc-854b-506042c805b8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
