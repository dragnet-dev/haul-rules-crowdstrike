// Dragnet [Ransomware]: dragnet-ransomware-2023-0921 — Mass File Rename (snatch)
// Status: experimental | Level: high | ID: d8a1e26f-1c40-572c-ab90-eb7e3d0ac287

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
