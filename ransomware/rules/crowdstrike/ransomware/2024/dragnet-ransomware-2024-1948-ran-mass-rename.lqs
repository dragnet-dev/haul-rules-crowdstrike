// Dragnet [Ransomware]: dragnet-ransomware-2024-1948 — Mass File Rename (helldown)
// Status: experimental | Level: high | ID: e43a1370-8281-5f48-8e99-7517cbb088ff

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
