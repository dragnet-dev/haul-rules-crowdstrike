// Dragnet [Ransomware]: dragnet-ransomware-2024-4460 — Mass File Rename (alphalocker)
// Status: experimental | Level: high | ID: eb26b0f6-1eb5-5893-bacd-ff730546c8d6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
