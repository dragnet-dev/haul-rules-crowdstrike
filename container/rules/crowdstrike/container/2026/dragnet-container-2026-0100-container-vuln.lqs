// Dragnet [Container]: dragnet-container-2026-0100 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 045fa693-0dd5-567d-b3ba-650622ff20bc

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
