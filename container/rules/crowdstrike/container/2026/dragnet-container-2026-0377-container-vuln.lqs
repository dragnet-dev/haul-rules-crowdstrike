// Dragnet [Container]: dragnet-container-2026-0377 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 2671c5fc-9f5d-50a7-8471-c362717ff8f9

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:5*)
| table([timestamp, ComputerName])
| limit(1000)
