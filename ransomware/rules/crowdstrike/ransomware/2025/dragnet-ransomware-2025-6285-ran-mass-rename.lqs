// Dragnet [Ransomware]: dragnet-ransomware-2025-6285 — Mass File Rename (tridentlocker)
// Status: experimental | Level: high | ID: 0ca2beac-7e68-5c4c-a17d-086dd3bc461a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
