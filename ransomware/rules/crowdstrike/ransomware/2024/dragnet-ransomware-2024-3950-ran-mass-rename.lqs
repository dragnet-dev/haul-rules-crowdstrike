// Dragnet [Ransomware]: dragnet-ransomware-2024-3950 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: deaff300-226b-5856-bece-c38d5de003b3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
