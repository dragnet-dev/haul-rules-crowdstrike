// Dragnet [Ransomware]: dragnet-ransomware-2022-2940 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 390f0339-7b32-510f-98b9-c3eda8fd987a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
