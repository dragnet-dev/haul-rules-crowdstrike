// Dragnet [Ransomware]: dragnet-ransomware-2023-2605 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: a1f2bfdc-f8b1-5406-9ca2-cc7ede5cbcb9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
