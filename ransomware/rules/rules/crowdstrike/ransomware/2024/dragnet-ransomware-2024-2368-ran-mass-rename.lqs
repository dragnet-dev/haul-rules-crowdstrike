// Dragnet [Ransomware]: dragnet-ransomware-2024-2368 — Mass File Rename (ransomhouse)
// Status: experimental | Level: high | ID: ce438e93-4747-5c1f-ae1d-a5d6909e71c1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
