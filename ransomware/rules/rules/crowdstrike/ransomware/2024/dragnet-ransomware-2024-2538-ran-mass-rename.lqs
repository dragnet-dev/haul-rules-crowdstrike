// Dragnet [Ransomware]: dragnet-ransomware-2024-2538 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: b3dba412-ed0a-526a-9bf0-bd59df4a99b8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
