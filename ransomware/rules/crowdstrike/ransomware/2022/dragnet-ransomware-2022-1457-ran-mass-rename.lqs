// Dragnet [Ransomware]: dragnet-ransomware-2022-1457 — Mass File Rename (onyx)
// Status: deprecated | Level: high | ID: 54891ad2-13b2-5112-9be3-7b6784d163ae

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
