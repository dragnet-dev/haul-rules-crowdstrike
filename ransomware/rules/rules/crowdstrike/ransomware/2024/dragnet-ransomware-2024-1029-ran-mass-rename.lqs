// Dragnet [Ransomware]: dragnet-ransomware-2024-1029 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: abc242ae-5dd4-52ee-b26c-ccd7b05995dc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
