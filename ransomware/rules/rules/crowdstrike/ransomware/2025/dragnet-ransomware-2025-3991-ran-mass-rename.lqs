// Dragnet [Ransomware]: dragnet-ransomware-2025-3991 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 127dc113-397f-57fa-86de-95fa117e8bcd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
