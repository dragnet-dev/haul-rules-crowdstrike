// Dragnet [Ransomware]: dragnet-ransomware-2024-1070 — Mass File Rename (qilin)
// Status: deprecated | Level: high | ID: 2658c14c-03dc-5094-ac51-98d2e441a58f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
