// Dragnet [Ransomware]: dragnet-ransomware-2024-1913 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 8133fe9d-6e54-52a0-b4c2-47e546032b79

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
