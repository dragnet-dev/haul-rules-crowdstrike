// Dragnet [Ransomware]: dragnet-ransomware-2025-2896 — Mass File Rename (blacknevas)
// Status: experimental | Level: high | ID: 2d3c8ae9-af03-5620-ac52-7403f5a95174

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
