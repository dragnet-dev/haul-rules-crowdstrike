// Dragnet [Container]: dragnet-container-2026-1737 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 6f88d260-d11d-568c-8463-9aa6e2967345

#event_simpleName=*
| (ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10*)
| table([timestamp, ComputerName])
| limit(1000)
