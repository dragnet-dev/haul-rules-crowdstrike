// Dragnet [Ransomware]: dragnet-ransomware-2023-3259 — Mass File Rename (monti)
// Status: experimental | Level: high | ID: d8aad36f-ad0c-5903-a474-8074cb32aca4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
