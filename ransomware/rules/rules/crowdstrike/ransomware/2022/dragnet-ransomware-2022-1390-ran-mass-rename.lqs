// Dragnet [Ransomware]: dragnet-ransomware-2022-1390 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: db60fe70-61f5-5f13-9994-c37c509191c0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
