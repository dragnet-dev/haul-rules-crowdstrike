// Dragnet [Ransomware]: dragnet-ransomware-2024-0814 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: 823a2d1e-996a-5aa8-a6a4-a0b9002f63c8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
