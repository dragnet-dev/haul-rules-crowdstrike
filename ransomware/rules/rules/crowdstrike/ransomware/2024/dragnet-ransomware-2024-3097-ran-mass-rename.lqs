// Dragnet [Ransomware]: dragnet-ransomware-2024-3097 — Mass File Rename (blacklock)
// Status: experimental | Level: high | ID: 74f77561-f014-5593-ab2e-3d1336489be6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
