// Dragnet [Container]: dragnet-container-2025-0324 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 8feb2f69-ec57-5488-b7f9-90251213b9d5

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *ubuntu:20.04* OR ImageFileName = *ubuntu:20.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
