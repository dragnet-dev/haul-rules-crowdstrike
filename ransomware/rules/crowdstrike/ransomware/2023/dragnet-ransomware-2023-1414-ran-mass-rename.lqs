// Dragnet [Ransomware]: dragnet-ransomware-2023-1414 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 35bd6d58-1b6d-5cc7-95bc-239c7f8f64d2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
