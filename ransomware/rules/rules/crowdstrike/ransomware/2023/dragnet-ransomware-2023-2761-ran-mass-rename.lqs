// Dragnet [Ransomware]: dragnet-ransomware-2023-2761 — Mass File Rename (malas)
// Status: experimental | Level: high | ID: 76a10ea5-4092-5343-a663-237ad1836d0f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
