// Dragnet [Ransomware]: dragnet-ransomware-2022-2538 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 1ea06a03-b6b0-54e2-ba7b-478f12fe1bdc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
