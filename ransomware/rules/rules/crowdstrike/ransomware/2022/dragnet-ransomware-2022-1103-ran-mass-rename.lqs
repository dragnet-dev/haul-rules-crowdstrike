// Dragnet [Ransomware]: dragnet-ransomware-2022-1103 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: dc74fb9e-ad21-5e70-a7ce-57b19ccd4441

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
