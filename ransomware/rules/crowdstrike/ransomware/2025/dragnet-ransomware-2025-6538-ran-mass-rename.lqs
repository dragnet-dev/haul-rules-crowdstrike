// Dragnet [Ransomware]: dragnet-ransomware-2025-6538 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: b21c1975-4c7b-5099-88a9-9771239dba14

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
