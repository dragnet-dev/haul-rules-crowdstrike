// Dragnet [Ransomware]: dragnet-ransomware-2025-6009 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: bb7dcd52-25c1-560d-b9d7-bbfb10f4f952

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
