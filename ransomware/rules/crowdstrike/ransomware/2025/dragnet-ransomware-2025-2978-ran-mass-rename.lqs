// Dragnet [Ransomware]: dragnet-ransomware-2025-2978 — Mass File Rename (nightspire)
// Status: deprecated | Level: high | ID: 53151950-0a98-5250-83b5-5ea2791036c1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
