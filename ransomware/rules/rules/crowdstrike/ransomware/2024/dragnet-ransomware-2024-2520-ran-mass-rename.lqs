// Dragnet [Ransomware]: dragnet-ransomware-2024-2520 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 777faf97-5e4e-5a61-b16a-6d8f72a7c5a2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
