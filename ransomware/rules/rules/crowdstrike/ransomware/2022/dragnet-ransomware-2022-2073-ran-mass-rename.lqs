// Dragnet [Ransomware]: dragnet-ransomware-2022-2073 — Mass File Rename (cuba)
// Status: deprecated | Level: high | ID: 94e045af-fd7b-5848-a776-5e7f55b45ddd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
