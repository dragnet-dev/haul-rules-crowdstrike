// Dragnet [Ransomware]: dragnet-ransomware-2025-5788 — Mass File Rename (sinobi)
// Status: experimental | Level: high | ID: 9db823ae-89a4-5423-810f-874c8d982934

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
