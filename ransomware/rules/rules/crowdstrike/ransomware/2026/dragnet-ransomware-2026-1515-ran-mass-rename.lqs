// Dragnet [Ransomware]: dragnet-ransomware-2026-1515 — Mass File Rename (killsec)
// Status: deprecated | Level: high | ID: 4689629b-f6dd-51a9-ab64-b68e2fd31f9e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
