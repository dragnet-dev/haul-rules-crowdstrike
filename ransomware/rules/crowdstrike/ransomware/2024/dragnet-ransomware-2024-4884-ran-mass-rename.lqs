// Dragnet [Ransomware]: dragnet-ransomware-2024-4884 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: d14be170-d314-5fed-b261-252b93fc23d5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
