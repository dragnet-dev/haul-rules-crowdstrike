// Dragnet [Ransomware]: dragnet-ransomware-2025-7199 — Mass File Rename (rhysida)
// Status: deprecated | Level: high | ID: 07023cff-10e9-5a9b-a48c-e6dac12cf19b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
