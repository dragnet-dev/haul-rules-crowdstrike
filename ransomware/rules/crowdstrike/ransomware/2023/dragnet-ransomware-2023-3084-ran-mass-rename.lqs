// Dragnet [Ransomware]: dragnet-ransomware-2023-3084 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 41ad609a-108d-5c19-860e-652c32da8b1d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
