// Dragnet [Ransomware]: dragnet-ransomware-2024-2016 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: fa5eac15-445f-5b6e-b90b-2bc924d4789b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
