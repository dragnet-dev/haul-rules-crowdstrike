// Dragnet [Ransomware]: dragnet-ransomware-2024-3748 — Mass File Rename (rhysida)
// Status: deprecated | Level: high | ID: 6386b8bf-fa5b-5438-a235-2dcb886d55d4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
