// Dragnet [Ransomware]: dragnet-ransomware-2025-3465 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 2f47d1fa-8bc0-5a45-861d-928057f3bc8e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
