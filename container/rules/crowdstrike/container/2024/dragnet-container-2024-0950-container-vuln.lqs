// Dragnet [Container]: dragnet-container-2024-0950 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 64f9ba04-8cb4-56f8-baf5-0785d725f92e

#event_simpleName=*
| (ImageFileName = *almalinux:8* OR ImageFileName = *amazonlinux:2* OR ImageFileName = *amazonlinux:2022* OR ImageFileName = *amazonlinux:2023* OR ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:9* OR ImageFileName = *oraclelinux:7* OR ImageFileName = *oraclelinux:8* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:14.04-ESM* OR ImageFileName = *ubuntu:16.04-ESM* OR ImageFileName = *ubuntu:18.04-ESM* OR ImageFileName = *ubuntu:20.04* OR ImageFileName = *ubuntu:20.04-ESM* OR ImageFileName = *ubuntu:22.04*)
| table([timestamp, ComputerName])
| limit(1000)
