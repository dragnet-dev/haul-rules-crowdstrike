// Dragnet [Ransomware]: dragnet-ransomware-2023-2064 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 79cf165f-4568-5b1c-bad2-b98bee341b08

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
