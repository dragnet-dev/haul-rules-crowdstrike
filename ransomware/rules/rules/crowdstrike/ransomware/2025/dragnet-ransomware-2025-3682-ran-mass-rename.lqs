// Dragnet [Ransomware]: dragnet-ransomware-2025-3682 — Mass File Rename (SilentRansomGroup)
// Status: deprecated | Level: high | ID: dfb7e21e-2774-57f0-87c6-fba44c74ed29

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
