// Dragnet [Ransomware]: dragnet-ransomware-2025-2529 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 20820039-cb8b-5e83-8b3d-7692c7a2a3ec

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
