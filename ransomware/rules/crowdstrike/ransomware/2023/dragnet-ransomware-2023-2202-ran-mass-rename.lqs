// Dragnet [Ransomware]: dragnet-ransomware-2023-2202 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 0d4bcd98-229f-5037-a210-63ce34548108

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
