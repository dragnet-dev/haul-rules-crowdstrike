// Dragnet [Ransomware]: dragnet-ransomware-2022-1026 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: b5cc2fff-be1e-5d1d-bedc-157a069fcc1b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
