// Dragnet [Ransomware]: dragnet-ransomware-2023-0776 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: f3f846bd-8b23-5720-a722-0598e5f9926e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
