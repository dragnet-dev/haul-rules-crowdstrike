// Dragnet [Container]: dragnet-container-2026-0169 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: d48b280d-4a4e-52a0-bca1-a5c59515ae48

#event_simpleName=*
| (ImageFileName = *almalinux:10* OR ImageFileName = *almalinux:8* OR ImageFileName = *almalinux:9* OR ImageFileName = *amazonlinux:2* OR ImageFileName = *amazonlinux:2023* OR ImageFileName = *chainguard:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:8* OR ImageFileName = *oraclelinux:9* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:22.04* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
