// Dragnet [Ransomware]: dragnet-ransomware-2023-1560 — Mass File Rename (play)
// Status: experimental | Level: high | ID: b4207e1e-ef7e-5729-aca8-ea384b065792

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
