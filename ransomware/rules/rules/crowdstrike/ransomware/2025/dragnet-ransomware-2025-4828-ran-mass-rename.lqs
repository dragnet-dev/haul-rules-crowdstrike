// Dragnet [Ransomware]: dragnet-ransomware-2025-4828 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 02d77d0b-f40d-5266-9368-e4ea1672cfa8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
