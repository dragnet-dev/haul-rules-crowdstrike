// Dragnet [Ransomware]: dragnet-ransomware-2025-3701 — Mass File Rename (devman)
// Status: experimental | Level: high | ID: 4a22995f-3849-5112-8f04-03f15f2e05c6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
