// Dragnet [Ransomware]: dragnet-ransomware-2021-0588 — Mass File Rename (xinglocker)
// Status: deprecated | Level: high | ID: 42b39ae3-c541-5f16-b000-afc589a920b2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
