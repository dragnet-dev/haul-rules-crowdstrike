// Dragnet [Ransomware]: dragnet-ransomware-2025-3406 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 9ffdf58c-a286-5555-bd42-14ee96768002

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
