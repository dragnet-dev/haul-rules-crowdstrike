// Dragnet [Ransomware]: dragnet-ransomware-2025-2100 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 88956cba-d8a2-5364-bf76-9f4b04dd27ca

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
