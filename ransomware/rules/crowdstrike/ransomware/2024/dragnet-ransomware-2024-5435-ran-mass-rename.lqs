// Dragnet [Ransomware]: dragnet-ransomware-2024-5435 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 18e6c036-41ce-54f2-acc5-e3dd2694c50c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
