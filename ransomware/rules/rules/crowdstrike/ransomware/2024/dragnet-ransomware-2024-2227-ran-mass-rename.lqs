// Dragnet [Ransomware]: dragnet-ransomware-2024-2227 — Mass File Rename (safepay)
// Status: deprecated | Level: high | ID: c6489d80-9199-5732-93d1-7410afe4eaa3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
