// Dragnet [Ransomware]: dragnet-ransomware-2024-1328 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: bc6940f6-dd9c-526b-9848-b7059bc043fd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
