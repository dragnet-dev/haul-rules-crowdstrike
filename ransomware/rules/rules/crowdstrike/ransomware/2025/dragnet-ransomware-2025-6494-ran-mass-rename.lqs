// Dragnet [Ransomware]: dragnet-ransomware-2025-6494 — Mass File Rename (termite)
// Status: experimental | Level: high | ID: 97397089-2325-5b8d-aaf2-db68e8eeefd4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
