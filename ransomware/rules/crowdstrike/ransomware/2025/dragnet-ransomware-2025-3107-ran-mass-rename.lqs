// Dragnet [Ransomware]: dragnet-ransomware-2025-3107 — Mass File Rename (beast)
// Status: experimental | Level: high | ID: 23a43018-c50e-5426-a990-722ecf1246c1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
