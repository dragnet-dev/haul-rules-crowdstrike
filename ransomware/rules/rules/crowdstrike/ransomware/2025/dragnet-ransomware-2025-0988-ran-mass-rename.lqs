// Dragnet [Ransomware]: dragnet-ransomware-2025-0988 — Mass File Rename (ransomhouse)
// Status: experimental | Level: high | ID: 3b84ef16-31af-56e2-a22b-7a3eb08db68b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
