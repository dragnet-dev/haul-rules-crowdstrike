// Dragnet [Ransomware]: dragnet-ransomware-2024-5982 — Mass File Rename (dragonforce)
// Status: deprecated | Level: high | ID: 7ecd1675-a76f-5840-a35d-80202c52fc44

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
