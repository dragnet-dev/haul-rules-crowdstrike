// Dragnet [Ransomware]: dragnet-ransomware-2023-1691 — Mass File Rename (noescape)
// Status: experimental | Level: high | ID: cb1bbbb6-fdd1-5ffc-afd6-e3086292eae6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
