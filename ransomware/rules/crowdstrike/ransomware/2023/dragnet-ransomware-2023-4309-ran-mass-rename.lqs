// Dragnet [Ransomware]: dragnet-ransomware-2023-4309 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 6f1a8353-f2eb-5f86-875e-8b5cfe4fcd90

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
