// Dragnet [Ransomware]: dragnet-ransomware-2020-0017 — Mass File Rename (doppelpaymer)
// Status: deprecated | Level: high | ID: 38d8c4a8-7b2b-50d7-814a-d7a24524ca85

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
