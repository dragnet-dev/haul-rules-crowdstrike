// Dragnet [Ransomware]: dragnet-ransomware-2025-1406 — Mass File Rename (kawa4096)
// Status: deprecated | Level: high | ID: 76c3d782-f1ba-5c67-82b3-8f11b0aff582

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
