// Dragnet [Ransomware]: dragnet-ransomware-2023-2923 — Mass File Rename (ransomhouse)
// Status: experimental | Level: high | ID: 8b90e4c8-f2a7-57b2-a187-eb461f9cfd20

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
