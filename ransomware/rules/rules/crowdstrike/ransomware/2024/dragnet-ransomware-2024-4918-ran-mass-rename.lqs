// Dragnet [Ransomware]: dragnet-ransomware-2024-4918 — Mass File Rename (snatch)
// Status: experimental | Level: high | ID: 57948fa8-be31-55cb-9dcb-80615fe7d9e9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
