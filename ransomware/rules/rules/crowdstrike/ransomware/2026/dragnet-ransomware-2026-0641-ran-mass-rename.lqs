// Dragnet [Ransomware]: dragnet-ransomware-2026-0641 — Mass File Rename (genesis)
// Status: stable | Level: high | ID: fe64fd4e-d978-5ac8-bcbb-c3f38de84a0e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
