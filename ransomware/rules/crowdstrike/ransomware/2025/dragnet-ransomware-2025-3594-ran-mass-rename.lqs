// Dragnet [Ransomware]: dragnet-ransomware-2025-3594 — Mass File Rename (beast)
// Status: experimental | Level: high | ID: daa4d76e-3a2f-5ecf-9b57-f5f614728677

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
