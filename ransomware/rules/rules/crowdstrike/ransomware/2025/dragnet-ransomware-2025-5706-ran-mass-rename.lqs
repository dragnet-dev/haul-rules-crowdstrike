// Dragnet [Ransomware]: dragnet-ransomware-2025-5706 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 17a59c48-9245-525e-9f5e-c75679796875

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
