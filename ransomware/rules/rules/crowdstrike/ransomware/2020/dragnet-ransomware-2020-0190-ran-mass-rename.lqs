// Dragnet [Ransomware]: dragnet-ransomware-2020-0190 — Mass File Rename (ryuk)
// Status: deprecated | Level: high | ID: c04cb6cf-5442-58f6-8be9-85baf3a3be60

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
