// Dragnet [Ransomware]: dragnet-ransomware-2026-1566 — Mass File Rename (nightspire)
// Status: deprecated | Level: high | ID: 448d5840-04b8-52db-a775-913693aad331

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
