// Dragnet [Ransomware]: dragnet-ransomware-2024-0449 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 3002fb04-f0a6-5f08-94f9-3332d92aed38

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
