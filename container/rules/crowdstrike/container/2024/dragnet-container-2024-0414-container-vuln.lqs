// Dragnet [Container]: dragnet-container-2024-0414 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 4eb3a0a6-dd93-5430-b777-e8416d1f00cf

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *ubuntu:20.04* OR ImageFileName = *ubuntu:20.04-ESM* OR ImageFileName = *ubuntu:22.04*)
| table([timestamp, ComputerName])
| limit(1000)
