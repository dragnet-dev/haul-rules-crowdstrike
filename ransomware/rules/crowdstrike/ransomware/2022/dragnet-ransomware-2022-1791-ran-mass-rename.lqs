// Dragnet [Ransomware]: dragnet-ransomware-2022-1791 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 3f68fd43-1eb0-5e3f-a859-ab517b9e8a1f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
