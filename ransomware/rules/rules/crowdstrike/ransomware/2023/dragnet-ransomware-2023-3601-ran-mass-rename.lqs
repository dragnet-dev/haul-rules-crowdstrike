// Dragnet [Ransomware]: dragnet-ransomware-2023-3601 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 3356ff3f-d256-5337-93e5-cb2d5986ce38

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
