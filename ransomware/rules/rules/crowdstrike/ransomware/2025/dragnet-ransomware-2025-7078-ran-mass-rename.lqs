// Dragnet [Ransomware]: dragnet-ransomware-2025-7078 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 6a6274f0-3064-5b95-9266-cfa60fd438c9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
