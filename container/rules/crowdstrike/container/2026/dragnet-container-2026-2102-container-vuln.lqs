// Dragnet [Container]: dragnet-container-2026-2102 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 6840e515-da38-5dbb-9206-bb1a21740412

#event_simpleName=*
| (ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10* OR ImageFileName = *ubuntu:13.04* OR ImageFileName = *ubuntu:13.10*)
| table([timestamp, ComputerName])
| limit(1000)
