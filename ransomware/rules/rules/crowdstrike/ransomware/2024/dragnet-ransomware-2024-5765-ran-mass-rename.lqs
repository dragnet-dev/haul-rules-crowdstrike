// Dragnet [Ransomware]: dragnet-ransomware-2024-5765 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 9dd84803-495f-52e6-88ad-d0be5bf84a37

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
