// Dragnet [Ransomware]: dragnet-ransomware-2026-0590 — Mass File Rename (incransom)
// Status: test | Level: high | ID: 3fa049db-7391-531f-a4e0-f8ee29b04d75

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
