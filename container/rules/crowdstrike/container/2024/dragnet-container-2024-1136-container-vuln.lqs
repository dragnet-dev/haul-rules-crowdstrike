// Dragnet [Container]: dragnet-container-2024-1136 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: d2012c8f-a2c6-5d2f-bca4-ff74114f85f8

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:9*)
| table([timestamp, ComputerName])
| limit(1000)
