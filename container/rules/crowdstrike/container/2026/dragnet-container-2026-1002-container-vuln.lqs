// Dragnet [Container]: dragnet-container-2026-1002 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 2306c818-cb55-51db-962c-2b0770a6a373

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6*)
| table([timestamp, ComputerName])
| limit(1000)
