// Dragnet [Ransomware]: dragnet-ransomware-2024-3425 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: e3ea9514-02c9-59b5-97b1-72df7ed93da6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
