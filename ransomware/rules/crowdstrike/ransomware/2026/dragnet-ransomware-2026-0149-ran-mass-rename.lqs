// Dragnet [Ransomware]: dragnet-ransomware-2026-0149 — Mass File Rename (ransomhouse)
// Status: stable | Level: high | ID: c0d13238-2772-52c2-9469-d4a0149f3b4b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
