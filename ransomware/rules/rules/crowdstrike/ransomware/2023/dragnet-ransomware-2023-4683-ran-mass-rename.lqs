// Dragnet [Ransomware]: dragnet-ransomware-2023-4683 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: fd3522ff-ffff-57fd-8096-08f9e4476298

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
