// Dragnet [Ransomware]: dragnet-ransomware-2023-1702 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: b5a0e9c6-c489-51c6-99bf-055252a15b43

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
