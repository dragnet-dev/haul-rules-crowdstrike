// Dragnet [Ransomware]: dragnet-ransomware-2021-1227 — Mass File Rename (marketo)
// Status: deprecated | Level: high | ID: e1328b6b-9ddf-52e8-b32c-3fcd03358e7c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
