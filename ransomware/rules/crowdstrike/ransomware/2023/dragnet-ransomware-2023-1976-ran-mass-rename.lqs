// Dragnet [Ransomware]: dragnet-ransomware-2023-1976 — Mass File Rename (knight)
// Status: experimental | Level: high | ID: 910a274f-aec0-5c29-b949-108d49c29aa3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
