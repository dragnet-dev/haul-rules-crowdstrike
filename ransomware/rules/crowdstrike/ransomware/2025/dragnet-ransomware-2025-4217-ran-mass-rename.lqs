// Dragnet [Ransomware]: dragnet-ransomware-2025-4217 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: feff3bea-62c0-534b-b197-b75ff911e905

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
