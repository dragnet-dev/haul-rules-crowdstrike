// Dragnet [Ransomware]: dragnet-ransomware-2024-3595 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 8bd1dcbc-7cd2-5767-a23d-068fdc277317

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
