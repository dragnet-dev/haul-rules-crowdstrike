// Dragnet [Ransomware]: dragnet-ransomware-2025-0102 — Mass File Rename (worldleaks)
// Status: experimental | Level: high | ID: 2f03ab69-71dd-5c41-aedc-fe23094c454c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
