// Dragnet [Ransomware]: dragnet-ransomware-2024-1823 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 7cc66474-b91b-56ba-b4a5-601603ac3f9f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
