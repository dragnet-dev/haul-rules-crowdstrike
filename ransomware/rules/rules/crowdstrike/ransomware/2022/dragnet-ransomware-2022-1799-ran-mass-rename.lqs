// Dragnet [Ransomware]: dragnet-ransomware-2022-1799 — Mass File Rename (ransomhouse)
// Status: deprecated | Level: high | ID: df51e2db-a271-5406-adf1-a5a750022bd7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
