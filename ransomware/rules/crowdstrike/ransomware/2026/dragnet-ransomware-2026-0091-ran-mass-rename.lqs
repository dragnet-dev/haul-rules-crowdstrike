// Dragnet [Ransomware]: dragnet-ransomware-2026-0091 — Mass File Rename (genesis)
// Status: stable | Level: high | ID: a13797f5-eb32-57e9-a370-de4905be98c4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
