// Dragnet [Ransomware]: dragnet-ransomware-2024-3231 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 6e4de2e4-3c74-567e-9eab-d45f19c30cf9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
