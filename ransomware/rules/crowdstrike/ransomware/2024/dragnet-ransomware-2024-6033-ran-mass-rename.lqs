// Dragnet [Ransomware]: dragnet-ransomware-2024-6033 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 5e27382d-d48a-5e9a-92ee-9d9cdbe57779

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
