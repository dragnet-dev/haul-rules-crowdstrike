// Dragnet [Container]: dragnet-container-2026-3064 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 7cfa872e-c500-532b-87e7-ab64fb25163d

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
