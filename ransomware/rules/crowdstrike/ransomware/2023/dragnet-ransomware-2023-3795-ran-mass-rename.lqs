// Dragnet [Ransomware]: dragnet-ransomware-2023-3795 — Mass File Rename (metaencryptor)
// Status: experimental | Level: high | ID: 78173100-ca5e-5cdc-bddb-5897141e38a2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
