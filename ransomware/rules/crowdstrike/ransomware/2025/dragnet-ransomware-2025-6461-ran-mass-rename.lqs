// Dragnet [Ransomware]: dragnet-ransomware-2025-6461 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: b9153a11-6f82-5f9c-b1af-91259736e26d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
