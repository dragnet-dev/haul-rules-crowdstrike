// Dragnet [Ransomware]: dragnet-ransomware-2023-2796 — Mass File Rename (malas)
// Status: experimental | Level: high | ID: 11896423-a184-5277-aace-40e1a4d7fe4e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
