// Dragnet [Ransomware]: dragnet-ransomware-2025-2671 — Mass File Rename (play)
// Status: experimental | Level: high | ID: fb066173-bdef-5141-b97b-bc053bf17877

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
