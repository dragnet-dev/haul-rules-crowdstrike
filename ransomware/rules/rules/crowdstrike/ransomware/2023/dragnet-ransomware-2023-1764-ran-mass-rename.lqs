// Dragnet [Ransomware]: dragnet-ransomware-2023-1764 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: f19724b9-39d6-5019-a84a-e6e10c6adea9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
