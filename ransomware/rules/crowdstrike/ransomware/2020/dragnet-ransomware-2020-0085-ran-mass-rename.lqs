// Dragnet [Ransomware]: dragnet-ransomware-2020-0085 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: be686281-b1fb-52b0-a8a9-1809d3b9efd1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
