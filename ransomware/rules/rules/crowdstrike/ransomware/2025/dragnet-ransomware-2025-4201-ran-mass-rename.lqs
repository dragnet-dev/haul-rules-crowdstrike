// Dragnet [Ransomware]: dragnet-ransomware-2025-4201 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: 09971eaf-1389-54ae-8db0-183ef2e0fb78

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
