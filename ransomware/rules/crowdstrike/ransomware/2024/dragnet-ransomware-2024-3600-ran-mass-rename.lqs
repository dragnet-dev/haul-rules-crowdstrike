// Dragnet [Ransomware]: dragnet-ransomware-2024-3600 — Mass File Rename (SilentRansomGroup)
// Status: deprecated | Level: high | ID: d33aae69-6c06-5abd-918b-62a3032a526b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
