// Dragnet [Ransomware]: dragnet-ransomware-2023-1158 — Mass File Rename (cactus)
// Status: deprecated | Level: high | ID: 929b05b6-786d-5761-a65c-0d75283a806a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
