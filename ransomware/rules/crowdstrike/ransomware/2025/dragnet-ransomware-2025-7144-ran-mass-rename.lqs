// Dragnet [Ransomware]: dragnet-ransomware-2025-7144 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 7a78ad56-e3cf-5e23-908b-feafd57a93a3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
