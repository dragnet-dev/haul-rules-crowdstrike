// Dragnet [Ransomware]: dragnet-ransomware-2024-3015 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 73bea813-2aee-5064-8372-c4dbc34fa4fb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
