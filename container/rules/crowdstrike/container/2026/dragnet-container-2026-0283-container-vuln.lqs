// Dragnet [Container]: dragnet-container-2026-0283 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 6093981d-2d33-5a0f-86c1-62283246d31c

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
