// Dragnet [Ransomware]: dragnet-ransomware-2024-0503 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 9b50cf34-4f81-5845-b399-ccac57af9b00

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
