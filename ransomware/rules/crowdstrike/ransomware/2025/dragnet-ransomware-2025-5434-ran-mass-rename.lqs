// Dragnet [Ransomware]: dragnet-ransomware-2025-5434 — Mass File Rename (arcusmedia)
// Status: experimental | Level: high | ID: 52409adc-0abc-5e21-86ca-257b92b8b076

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
