// Dragnet [Ransomware]: dragnet-ransomware-2022-2869 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 00574f03-e631-5db9-ab7e-17160d9f468c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
