// Dragnet [Ransomware]: dragnet-ransomware-2023-5345 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 6ed769e8-7725-56ff-ba70-7e1088d8a95b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
