// Dragnet [Ransomware]: dragnet-ransomware-2023-3933 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 7a6e1d41-6c71-5ce6-bee3-346fd138cc9c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
