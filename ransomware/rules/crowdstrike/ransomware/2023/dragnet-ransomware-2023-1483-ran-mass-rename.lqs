// Dragnet [Ransomware]: dragnet-ransomware-2023-1483 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 82f7ca89-c708-5289-b4c4-85f6896a3658

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
