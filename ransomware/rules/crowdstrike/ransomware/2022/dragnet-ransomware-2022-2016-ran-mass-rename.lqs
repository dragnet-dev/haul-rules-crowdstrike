// Dragnet [Ransomware]: dragnet-ransomware-2022-2016 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 2882da41-6b7f-5cd2-b32a-4b22a08c4014

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
