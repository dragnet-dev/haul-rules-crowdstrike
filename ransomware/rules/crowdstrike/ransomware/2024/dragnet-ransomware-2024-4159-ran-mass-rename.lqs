// Dragnet [Ransomware]: dragnet-ransomware-2024-4159 — Mass File Rename (arcusmedia)
// Status: experimental | Level: high | ID: dca3560f-5c2a-58d3-9982-e03eacc80864

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
