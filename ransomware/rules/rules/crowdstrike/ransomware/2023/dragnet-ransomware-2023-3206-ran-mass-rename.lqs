// Dragnet [Ransomware]: dragnet-ransomware-2023-3206 — Mass File Rename (royal)
// Status: deprecated | Level: high | ID: 97376106-bd1d-56ca-a633-6d9858976cf7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
