// Dragnet [Ransomware]: dragnet-ransomware-2025-7611 — Mass File Rename (global)
// Status: deprecated | Level: high | ID: a643b7ef-f59f-54b0-9fd2-de7450907acd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
