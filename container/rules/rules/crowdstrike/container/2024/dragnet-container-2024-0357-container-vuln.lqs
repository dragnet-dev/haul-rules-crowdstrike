// Dragnet [Container]: dragnet-container-2024-0357 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 4b71b36b-b819-55a5-b62c-3c405174db9a

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:8* OR ImageFileName = *debian:9* OR ImageFileName = *ubuntu:18.04* OR ImageFileName = *ubuntu:18.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
