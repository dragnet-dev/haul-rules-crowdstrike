// Dragnet [Ransomware]: dragnet-ransomware-2024-4031 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 8c0b0a4f-cfd4-5e37-b641-9a483727411a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
