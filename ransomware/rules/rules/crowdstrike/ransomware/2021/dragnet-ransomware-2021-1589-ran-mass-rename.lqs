// Dragnet [Ransomware]: dragnet-ransomware-2021-1589 — Mass File Rename (midas)
// Status: deprecated | Level: high | ID: cc1daebe-a556-502c-8d30-0493783368ae

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
