// Dragnet [Container]: dragnet-container-2026-1451 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: e7fbaaed-1b12-5760-873e-4bfafa6b8d88

#event_simpleName=*
| (ImageFileName = *alpine:3.20* OR ImageFileName = *alpine:3.21* OR ImageFileName = *alpine:3.22* OR ImageFileName = *alpine:3.23* OR ImageFileName = *alpine edge:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *redhat/ubi9:*)
| table([timestamp, ComputerName])
| limit(1000)
