// Dragnet [Ransomware]: dragnet-ransomware-2025-0332 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: f5a7e9ef-39f0-5b60-a389-2c6cfb873576

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
