// Dragnet [Ransomware]: dragnet-ransomware-2021-0856 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 916930fd-9d44-528b-a2c3-98158ff2c2f8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
