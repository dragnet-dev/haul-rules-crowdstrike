// Dragnet [Ransomware]: dragnet-ransomware-2021-1539 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: ace85284-46b3-5aa2-9c3e-96118971d9b9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
