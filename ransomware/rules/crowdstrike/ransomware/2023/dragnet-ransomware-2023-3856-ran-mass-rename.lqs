// Dragnet [Ransomware]: dragnet-ransomware-2023-3856 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: ec016240-9baa-56bb-b022-f296d2a01098

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
