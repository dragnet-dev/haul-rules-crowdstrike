// Dragnet [Ransomware]: dragnet-ransomware-2023-3876 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: f024086d-221f-5924-af92-d038ea386f90

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
