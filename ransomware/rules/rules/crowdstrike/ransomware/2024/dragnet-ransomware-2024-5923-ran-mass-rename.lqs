// Dragnet [Ransomware]: dragnet-ransomware-2024-5923 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: e0524102-0bb2-5030-9ee3-943528ba9f1d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
