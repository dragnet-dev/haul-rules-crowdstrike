// Dragnet [Ransomware]: dragnet-ransomware-2023-3638 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 13ac3ddf-c877-5651-88b5-75b00cd7c12b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
