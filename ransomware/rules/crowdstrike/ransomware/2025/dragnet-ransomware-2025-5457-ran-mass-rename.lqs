// Dragnet [Ransomware]: dragnet-ransomware-2025-5457 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 5a6af51b-029f-563b-b805-cd613dc387f5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
