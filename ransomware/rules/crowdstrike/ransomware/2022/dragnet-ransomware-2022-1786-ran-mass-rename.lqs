// Dragnet [Ransomware]: dragnet-ransomware-2022-1786 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 97a44c20-7865-5ce0-a42c-26dd74b1320c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
