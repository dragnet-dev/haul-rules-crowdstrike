// Dragnet [Ransomware]: dragnet-ransomware-2024-4466 — Mass File Rename (dragonforce)
// Status: deprecated | Level: high | ID: ca8e3152-d033-5c21-874f-ae94dbb1aaa1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
