// Dragnet [Ransomware]: dragnet-ransomware-2026-0678 — Mass File Rename (SilentRansomGroup)
// Status: deprecated | Level: high | ID: 24c9242d-9319-5fe3-aecb-ab831cadce20

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
