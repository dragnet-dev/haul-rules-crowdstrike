// Dragnet [Ransomware]: dragnet-ransomware-2022-1890 — Mass File Rename (medusalocker)
// Status: deprecated | Level: high | ID: 05fd1c95-e8f6-517c-adcd-cd15a1e8b051

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
