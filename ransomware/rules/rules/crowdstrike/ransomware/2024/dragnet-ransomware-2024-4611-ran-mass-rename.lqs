// Dragnet [Ransomware]: dragnet-ransomware-2024-4611 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 9d59370d-0655-5282-afd0-d7ac9e7574e3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
