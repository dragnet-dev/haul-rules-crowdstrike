// Dragnet [Ransomware]: dragnet-ransomware-2024-0505 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: e1cfab04-9f91-5c7e-88ce-891cdfa0b5e5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
