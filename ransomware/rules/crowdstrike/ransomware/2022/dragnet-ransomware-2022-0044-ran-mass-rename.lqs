// Dragnet [Ransomware]: dragnet-ransomware-2022-0044 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 8d194fe0-ea4f-54e0-aef6-aa238db77085

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
