// Dragnet [Ransomware]: dragnet-ransomware-2023-3342 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: b9d05c37-c8e2-5008-88e9-f1d1f37c6beb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
