// Dragnet [Ransomware]: dragnet-ransomware-2021-1345 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 03c5690f-d708-5ab3-a11d-c0b6759bbd83

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
