// Dragnet [Ransomware]: dragnet-ransomware-2021-1673 — Mass File Rename (avaddon)
// Status: deprecated | Level: high | ID: 4f7b3002-a827-5f0e-ba3f-e9470f2ccb80

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
