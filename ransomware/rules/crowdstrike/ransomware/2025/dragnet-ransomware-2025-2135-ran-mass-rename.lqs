// Dragnet [Ransomware]: dragnet-ransomware-2025-2135 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: b7a645d6-a6f0-57ea-b7fa-539bc1738c3c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
