// Dragnet [Ransomware]: dragnet-ransomware-2024-4009 — Mass File Rename (play)
// Status: experimental | Level: high | ID: fc0812eb-83a7-5c66-85f9-49ba55002705

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
