// Dragnet [Ransomware]: dragnet-ransomware-2024-3166 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 7b0a6c0a-8ec0-5889-8120-04b656e2ff5e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
