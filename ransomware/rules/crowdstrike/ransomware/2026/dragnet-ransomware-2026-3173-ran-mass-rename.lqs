// Dragnet [Ransomware]: dragnet-ransomware-2026-3173 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: b93add77-3acf-5750-a8e4-0073879ace98

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
