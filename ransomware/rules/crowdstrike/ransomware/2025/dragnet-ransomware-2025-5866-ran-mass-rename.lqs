// Dragnet [Ransomware]: dragnet-ransomware-2025-5866 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: cf64e318-e381-5ae5-aa7d-a425e2d55c66

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
