// Dragnet [Ransomware]: dragnet-ransomware-2025-7576 — Mass File Rename (nova)
// Status: experimental | Level: high | ID: d3778bec-38f9-5f3c-8e4a-93b93caca7ac

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
