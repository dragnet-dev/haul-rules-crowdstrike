// Dragnet [Container]: dragnet-container-2026-0157 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: a01ec519-d162-55df-adb4-3216e8566791

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:8*)
| table([timestamp, ComputerName])
| limit(1000)
