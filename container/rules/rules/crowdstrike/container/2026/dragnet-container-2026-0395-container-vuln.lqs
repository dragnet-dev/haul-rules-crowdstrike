// Dragnet [Container]: dragnet-container-2026-0395 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: aa3a2e88-89bf-518b-807b-a07f1bb94a73

#event_simpleName=*
| (ImageFileName = *debian:7* OR ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10*)
| table([timestamp, ComputerName])
| limit(1000)
