// Dragnet [Ransomware]: dragnet-ransomware-2024-3847 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: 15974d32-eebb-545c-8651-a8ab4a200bb8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
