// Dragnet [Ransomware]: dragnet-ransomware-2025-1012 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 760f5b58-b756-555e-925d-b43239d7887d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
