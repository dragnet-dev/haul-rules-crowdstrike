// Dragnet [Ransomware]: dragnet-ransomware-2025-2491 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: d18451d1-e1cf-5f4d-9f12-4c1f32bff2f7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
