// Dragnet [Ransomware]: dragnet-ransomware-2023-4232 — Mass File Rename (play)
// Status: experimental | Level: high | ID: e22728a6-6e89-5a8e-ac0f-a43746b6b8ea

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
