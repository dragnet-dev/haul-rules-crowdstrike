// Dragnet [Container]: dragnet-container-2025-0147 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: dd85012c-c144-5379-b6d0-77b6ec6b6dff

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
