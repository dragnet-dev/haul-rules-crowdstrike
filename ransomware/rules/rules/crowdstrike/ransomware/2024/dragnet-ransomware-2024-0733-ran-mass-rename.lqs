// Dragnet [Ransomware]: dragnet-ransomware-2024-0733 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 25816968-2029-5cb4-bf5b-126d71e4b8ad

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
