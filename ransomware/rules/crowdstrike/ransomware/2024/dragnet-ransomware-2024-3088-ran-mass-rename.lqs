// Dragnet [Ransomware]: dragnet-ransomware-2024-3088 — Mass File Rename (moneymessage)
// Status: experimental | Level: high | ID: be5c4ed7-9110-5264-aa39-b096a74c77b4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
