// Dragnet [Ransomware]: dragnet-ransomware-2023-4012 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 5f7d4bb6-57ba-5077-b195-f1d8a377a14c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
