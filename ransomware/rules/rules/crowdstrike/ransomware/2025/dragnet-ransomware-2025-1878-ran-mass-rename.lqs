// Dragnet [Ransomware]: dragnet-ransomware-2025-1878 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 1263a054-86d2-543d-9007-d75a36c1bbf5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
