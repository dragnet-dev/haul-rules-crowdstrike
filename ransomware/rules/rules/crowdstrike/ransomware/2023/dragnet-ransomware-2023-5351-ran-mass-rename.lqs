// Dragnet [Ransomware]: dragnet-ransomware-2023-5351 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 4125b95c-5f4b-5f73-bd4b-ccb1489b399a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
