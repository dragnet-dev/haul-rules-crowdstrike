// Dragnet [Ransomware]: dragnet-ransomware-2026-0151 — Mass File Rename (dragonforce)
// Status: stable | Level: high | ID: 7b82d7b7-6405-5924-9b57-c8b0fb654fa2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
