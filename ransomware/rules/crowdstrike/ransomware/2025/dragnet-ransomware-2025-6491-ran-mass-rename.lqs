// Dragnet [Ransomware]: dragnet-ransomware-2025-6491 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 71167949-a936-5644-bdef-fc2e8ae1b581

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
