// Dragnet [Ransomware]: dragnet-ransomware-2024-2824 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 44256cef-82c5-55e1-a249-03d36bec5693

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
