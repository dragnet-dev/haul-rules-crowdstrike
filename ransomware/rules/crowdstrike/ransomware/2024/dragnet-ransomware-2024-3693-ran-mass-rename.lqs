// Dragnet [Ransomware]: dragnet-ransomware-2024-3693 — Mass File Rename (ElDorado)
// Status: deprecated | Level: high | ID: 936f94f6-7485-5c9c-8f51-7a284781d704

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
