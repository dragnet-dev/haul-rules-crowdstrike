// Dragnet [Ransomware]: dragnet-ransomware-2024-1130 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 0e834708-bb89-54e9-973a-e3291039a00a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
