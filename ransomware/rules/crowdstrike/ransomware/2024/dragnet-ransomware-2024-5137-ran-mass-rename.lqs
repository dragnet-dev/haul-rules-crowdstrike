// Dragnet [Ransomware]: dragnet-ransomware-2024-5137 — Mass File Rename (arcusmedia)
// Status: experimental | Level: high | ID: ae63dda6-3244-5561-bc1e-862bf01246a6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
