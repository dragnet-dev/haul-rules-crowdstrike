// Dragnet [Ransomware]: dragnet-ransomware-2026-0239 — Mass File Rename (aurora)
// Status: stable | Level: high | ID: 4a383131-ca5d-5f06-8c90-b16d9a179632

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
