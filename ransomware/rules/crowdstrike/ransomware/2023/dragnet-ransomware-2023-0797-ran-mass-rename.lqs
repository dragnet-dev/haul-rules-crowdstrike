// Dragnet [Ransomware]: dragnet-ransomware-2023-0797 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: a8872d84-47c6-5cf0-b3c1-278176eddb1f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
