// Dragnet [Ransomware]: dragnet-ransomware-2024-0701 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 2e601dc7-d851-583a-8472-5e29300ba1bc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
