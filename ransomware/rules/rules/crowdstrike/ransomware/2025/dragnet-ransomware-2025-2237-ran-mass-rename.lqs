// Dragnet [Ransomware]: dragnet-ransomware-2025-2237 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: de65f88f-b49c-5ed1-95f9-d5433463e346

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
