// Dragnet [Ransomware]: dragnet-ransomware-2025-0221 — Mass File Rename (coinbasecartel)
// Status: test | Level: high | ID: f186a0fa-6d33-5da4-880d-5f14643bfff1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
