// Dragnet [Container]: dragnet-container-2024-0132 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 604e320d-86f9-52b2-964a-cd654f25fe8b

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:9*)
| table([timestamp, ComputerName])
| limit(1000)
