// Dragnet [Ransomware]: dragnet-ransomware-2024-2977 — Mass File Rename (helldown)
// Status: experimental | Level: high | ID: 53d556a0-ead1-50c1-95d9-52b9ec9c2898

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
