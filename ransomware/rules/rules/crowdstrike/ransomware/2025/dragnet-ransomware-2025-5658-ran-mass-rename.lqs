// Dragnet [Ransomware]: dragnet-ransomware-2025-5658 — Mass File Rename (SilentRansomGroup)
// Status: deprecated | Level: high | ID: e76dab48-d8a6-57b4-b9aa-fdcdaa55fd16

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
