// Dragnet [Ransomware]: dragnet-ransomware-2024-1997 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 0ea52a43-3ba1-5749-ab4a-29dc7394cd3b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
