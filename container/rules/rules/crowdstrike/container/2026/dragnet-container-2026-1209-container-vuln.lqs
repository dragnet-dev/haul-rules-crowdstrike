// Dragnet [Container]: dragnet-container-2026-1209 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: b8024b12-0330-54bc-9cca-0230dd383efd

#event_simpleName=*
| (ImageFileName = *debian:7* OR ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10* OR ImageFileName = *ubuntu:13.04*)
| table([timestamp, ComputerName])
| limit(1000)
