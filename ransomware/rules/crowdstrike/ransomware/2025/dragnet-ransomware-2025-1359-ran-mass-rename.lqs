// Dragnet [Ransomware]: dragnet-ransomware-2025-1359 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 923c96d8-c451-5279-953e-ab1f72a86ade

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
