// Dragnet [Ransomware]: dragnet-ransomware-2022-1642 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 42bd66c0-02fe-57e2-beb9-49875905f1d5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
