// Dragnet [Ransomware]: dragnet-ransomware-2022-2286 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: bd2e8e8d-69a9-5f16-a7d9-5f4524b3e104

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
