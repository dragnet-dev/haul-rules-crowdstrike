// Dragnet [Ransomware]: dragnet-ransomware-2022-2720 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 7cec2936-dff0-561b-a51a-0f5bce802bbb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
