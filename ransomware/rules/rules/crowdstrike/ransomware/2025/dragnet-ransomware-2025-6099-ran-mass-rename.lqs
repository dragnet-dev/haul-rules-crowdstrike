// Dragnet [Ransomware]: dragnet-ransomware-2025-6099 — Mass File Rename (flocker)
// Status: experimental | Level: high | ID: 7686d8e0-e1e1-5f01-a547-5faab1bdb396

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
