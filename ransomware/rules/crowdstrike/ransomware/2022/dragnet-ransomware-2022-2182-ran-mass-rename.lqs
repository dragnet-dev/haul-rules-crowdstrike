// Dragnet [Ransomware]: dragnet-ransomware-2022-2182 — Mass File Rename (snatch)
// Status: deprecated | Level: high | ID: d21e3397-f5f3-5e18-9734-ce850ea8fc6e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
