// Dragnet [Ransomware]: dragnet-ransomware-2022-2890 — Mass File Rename (avoslocker)
// Status: deprecated | Level: high | ID: 02c07f6a-1a13-5bd1-9336-2addbdcc750e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
