// Dragnet [Ransomware]: dragnet-ransomware-2021-0803 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 4d63b25f-aa0a-5f4f-8ae6-46db0c39d401

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
