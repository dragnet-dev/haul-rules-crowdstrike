// Dragnet [Ransomware]: dragnet-ransomware-2024-5048 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: 80e344a5-6a39-5907-bc68-1fbd47985ce8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
