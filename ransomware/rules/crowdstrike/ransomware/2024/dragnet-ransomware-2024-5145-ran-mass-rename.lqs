// Dragnet [Ransomware]: dragnet-ransomware-2024-5145 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 0e949269-76c9-5edd-a5ff-b4e0f9f5295f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
