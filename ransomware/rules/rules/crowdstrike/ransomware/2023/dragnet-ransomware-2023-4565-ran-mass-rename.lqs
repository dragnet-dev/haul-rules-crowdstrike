// Dragnet [Ransomware]: dragnet-ransomware-2023-4565 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: c4c5415d-9a1d-58a3-963c-d85757dba4ba

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
