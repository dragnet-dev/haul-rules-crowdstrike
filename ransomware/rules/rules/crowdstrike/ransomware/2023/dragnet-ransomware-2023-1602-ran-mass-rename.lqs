// Dragnet [Ransomware]: dragnet-ransomware-2023-1602 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: eb711d69-9388-5da4-a3bc-9b361fe117f5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
