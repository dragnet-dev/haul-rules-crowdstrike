// Dragnet [Ransomware]: dragnet-ransomware-2025-0826 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: dabf14bc-8d1f-500d-9a9a-910c8cbb636f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
