// Dragnet [Ransomware]: dragnet-ransomware-2024-4167 — Mass File Rename (ValenciaLeaks)
// Status: experimental | Level: high | ID: f7225914-dd31-520b-adb7-46a92d4c6d44

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
