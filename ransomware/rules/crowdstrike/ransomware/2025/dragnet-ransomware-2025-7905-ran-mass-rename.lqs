// Dragnet [Ransomware]: dragnet-ransomware-2025-7905 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 4c002d67-5153-5ba7-99ce-cf2ba1e137e4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
