// Dragnet [Ransomware]: dragnet-ransomware-2025-7494 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 9e4efd4e-7007-5996-9701-27bf6a8b4186

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
