// Dragnet [Container]: dragnet-container-2026-0152 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: c7673f64-e2de-5627-a311-28b734bbc57c

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
