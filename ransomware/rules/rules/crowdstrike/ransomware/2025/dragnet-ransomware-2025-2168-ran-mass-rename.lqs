// Dragnet [Ransomware]: dragnet-ransomware-2025-2168 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: 08d46bc8-ee21-566c-b02c-6617ec30d04f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
