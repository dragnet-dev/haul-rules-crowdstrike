// Dragnet [Ransomware]: dragnet-ransomware-2024-3869 — Mass File Rename (qilin)
// Status: deprecated | Level: high | ID: 9fa44553-e133-5a50-802b-c810d62291e3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
