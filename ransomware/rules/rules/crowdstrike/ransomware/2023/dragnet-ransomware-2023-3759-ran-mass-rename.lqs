// Dragnet [Ransomware]: dragnet-ransomware-2023-3759 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: d47f2ce2-ccd2-5f2f-9e27-45ffe78344a2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
