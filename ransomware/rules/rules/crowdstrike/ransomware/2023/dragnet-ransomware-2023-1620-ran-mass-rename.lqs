// Dragnet [Ransomware]: dragnet-ransomware-2023-1620 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 4863c8bd-9aba-58b1-9ae6-fec29eff7659

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
