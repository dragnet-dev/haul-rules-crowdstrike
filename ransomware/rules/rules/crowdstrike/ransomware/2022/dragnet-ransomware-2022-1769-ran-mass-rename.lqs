// Dragnet [Ransomware]: dragnet-ransomware-2022-1769 — Mass File Rename (quantum)
// Status: deprecated | Level: high | ID: 98be36c7-4191-5e8d-9c29-64533942c232

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
