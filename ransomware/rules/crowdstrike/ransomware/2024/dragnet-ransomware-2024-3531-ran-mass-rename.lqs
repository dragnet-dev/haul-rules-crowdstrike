// Dragnet [Ransomware]: dragnet-ransomware-2024-3531 — Mass File Rename (cicada3301)
// Status: experimental | Level: high | ID: a067c0dc-0d44-5c5b-9bc4-5d7adc775576

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
