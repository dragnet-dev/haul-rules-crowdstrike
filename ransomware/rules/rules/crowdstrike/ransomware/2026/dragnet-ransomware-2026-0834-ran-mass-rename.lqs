// Dragnet [Ransomware]: dragnet-ransomware-2026-0834 — Mass File Rename (AiLock)
// Status: deprecated | Level: high | ID: d50f5514-eb74-55a1-9ef3-5f78d38b2558

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
