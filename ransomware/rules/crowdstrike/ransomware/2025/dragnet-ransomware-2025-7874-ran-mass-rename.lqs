// Dragnet [Ransomware]: dragnet-ransomware-2025-7874 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 35949ad5-0767-509f-a625-bfa29eaf8004

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
