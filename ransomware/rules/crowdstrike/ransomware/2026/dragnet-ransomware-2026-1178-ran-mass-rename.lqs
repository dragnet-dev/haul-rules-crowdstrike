// Dragnet [Ransomware]: dragnet-ransomware-2026-1178 — Mass File Rename (thegentlemen)
// Status: deprecated | Level: high | ID: 9dc7d30f-5ea6-57e5-91a4-3d09399fd3f3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
