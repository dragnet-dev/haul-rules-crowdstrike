// Dragnet [Ransomware]: dragnet-ransomware-2021-1278 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: f02f744b-328a-55af-8019-7c8aba318481

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
