// Dragnet [Container]: dragnet-container-2025-0133 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 94194cf6-d9da-5574-a3c6-82790e624059

#event_simpleName=*
| (ImageFileName = *cbl-mariner:2.0* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *redhat/ubi9:*)
| table([timestamp, ComputerName])
| limit(1000)
