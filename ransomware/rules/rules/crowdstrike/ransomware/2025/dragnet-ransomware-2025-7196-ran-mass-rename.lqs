// Dragnet [Ransomware]: dragnet-ransomware-2025-7196 — Mass File Rename (desolator)
// Status: experimental | Level: high | ID: e44c59b6-07a5-58d9-a6d2-82ae11db8243

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
