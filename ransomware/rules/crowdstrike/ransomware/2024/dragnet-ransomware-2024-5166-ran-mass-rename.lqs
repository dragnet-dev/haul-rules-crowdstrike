// Dragnet [Ransomware]: dragnet-ransomware-2024-5166 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 42bf30fe-868e-5a0c-b035-3c6cebd101b4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
