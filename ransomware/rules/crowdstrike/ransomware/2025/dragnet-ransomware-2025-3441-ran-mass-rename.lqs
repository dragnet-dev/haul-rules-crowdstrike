// Dragnet [Ransomware]: dragnet-ransomware-2025-3441 — Mass File Rename (incransom)
// Status: test | Level: high | ID: 5cae9c3a-922e-5b07-b24c-c1da9696ef09

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
