// Dragnet [Ransomware]: dragnet-ransomware-2024-2846 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 03d7b1a4-2c53-5bd4-abaa-2e4a5cc65d18

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
