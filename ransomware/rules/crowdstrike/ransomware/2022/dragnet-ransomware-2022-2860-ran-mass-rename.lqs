// Dragnet [Ransomware]: dragnet-ransomware-2022-2860 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 0d9daf9c-1cd1-53cd-a888-1f0c21297c3e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
