// Dragnet [Ransomware]: dragnet-ransomware-2023-0100 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 5db578ae-9b3f-5c48-97a6-9ce9cc010400

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
