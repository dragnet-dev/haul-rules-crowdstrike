// Dragnet [Ransomware]: dragnet-ransomware-2023-2576 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 69e52397-136b-50f5-b1f2-39bf9a529d16

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
