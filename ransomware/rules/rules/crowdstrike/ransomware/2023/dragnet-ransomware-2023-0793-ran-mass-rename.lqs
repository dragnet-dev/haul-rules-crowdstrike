// Dragnet [Ransomware]: dragnet-ransomware-2023-0793 — Mass File Rename (werewolves)
// Status: experimental | Level: high | ID: 641f0556-893f-5e7c-ad93-94760d864edf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
