// Dragnet [Ransomware]: dragnet-ransomware-2022-1788 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 1925a2f7-fd6a-5312-8ae5-84705c5e34c6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
