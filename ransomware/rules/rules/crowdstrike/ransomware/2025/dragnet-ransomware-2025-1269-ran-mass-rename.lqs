// Dragnet [Ransomware]: dragnet-ransomware-2025-1269 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: f37f624e-4667-553d-87b7-2c215ef954c8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
