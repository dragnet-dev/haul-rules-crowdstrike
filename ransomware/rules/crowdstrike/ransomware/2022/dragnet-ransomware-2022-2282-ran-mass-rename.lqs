// Dragnet [Ransomware]: dragnet-ransomware-2022-2282 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 16488c69-e7a1-5023-aa54-96e786e005ce

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
