// Dragnet [Ransomware]: dragnet-ransomware-2023-0300 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 4c697470-c3d6-5645-8840-57e3e717949c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
