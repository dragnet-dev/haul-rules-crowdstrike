// Dragnet [Ransomware]: dragnet-ransomware-2023-1963 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: d00b87f4-359f-546b-a7e5-0b94034e6d18

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
