// Dragnet [Ransomware]: dragnet-ransomware-2025-5257 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: db4e9d7b-ba7d-56eb-877b-062097bfef37

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
