// Dragnet [Ransomware]: dragnet-ransomware-2024-0998 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: b63756d3-cdb2-5ea5-b30c-d6d0da8188eb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
