// Dragnet [Ransomware]: dragnet-ransomware-2025-1920 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 88a3a255-6cc6-561a-8c62-9a70d34d2ada

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
