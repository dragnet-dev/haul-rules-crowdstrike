// Dragnet [Ransomware]: dragnet-ransomware-2024-1676 — Mass File Rename (raworld)
// Status: experimental | Level: high | ID: 5e76eee3-32f1-5623-8c41-16ef023e1c41

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
