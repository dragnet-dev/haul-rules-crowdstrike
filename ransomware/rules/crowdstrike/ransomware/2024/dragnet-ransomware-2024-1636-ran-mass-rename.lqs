// Dragnet [Ransomware]: dragnet-ransomware-2024-1636 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: d2ef3773-3f62-5c43-8080-69c528f8138f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
