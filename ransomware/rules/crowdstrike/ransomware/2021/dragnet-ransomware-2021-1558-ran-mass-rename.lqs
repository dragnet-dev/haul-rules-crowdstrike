// Dragnet [Ransomware]: dragnet-ransomware-2021-1558 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: e10f7186-e4dc-50be-80b7-08ea40f46ca0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
