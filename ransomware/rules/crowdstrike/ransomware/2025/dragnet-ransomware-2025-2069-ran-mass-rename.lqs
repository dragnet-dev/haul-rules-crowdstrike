// Dragnet [Ransomware]: dragnet-ransomware-2025-2069 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: d64d0a6c-42c1-5c44-bf63-12ff6a1d6f27

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
