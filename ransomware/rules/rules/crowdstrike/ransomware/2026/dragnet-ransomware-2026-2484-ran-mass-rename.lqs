// Dragnet [Ransomware]: dragnet-ransomware-2026-2484 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: aed99372-7647-5397-85ab-ae5dfab1bb5e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
