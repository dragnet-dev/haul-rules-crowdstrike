// Dragnet [Ransomware]: dragnet-ransomware-2024-3209 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 136722e5-5ddb-5471-a38d-e8686242b891

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
