// Dragnet [Ransomware]: dragnet-ransomware-2022-1302 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 4f5154a6-3ebc-5dd8-94ad-5bf83827b2bc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
