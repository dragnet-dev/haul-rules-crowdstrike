// Dragnet [Ransomware]: dragnet-ransomware-2023-1655 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 20c40355-d805-5a0d-9c99-d3d5e0327f36

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
