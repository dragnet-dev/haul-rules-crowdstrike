// Dragnet [Ransomware]: dragnet-ransomware-2025-4774 — Mass File Rename (beast)
// Status: experimental | Level: high | ID: f805efe8-b1d0-5b68-9877-858132c75d6f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
