// Dragnet [Ransomware]: dragnet-ransomware-2021-1603 — Mass File Rename (avaddon)
// Status: deprecated | Level: high | ID: 7a507ff4-cb09-58c4-8d0d-d0abf5ca9a73

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
