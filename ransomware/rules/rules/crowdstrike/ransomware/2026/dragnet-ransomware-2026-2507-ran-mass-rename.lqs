// Dragnet [Ransomware]: dragnet-ransomware-2026-2507 — Mass File Rename (dragonforce)
// Status: stable | Level: high | ID: 9318702c-1d9a-577f-9a67-0aead68ed72e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
