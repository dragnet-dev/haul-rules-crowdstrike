// Dragnet [Container]: dragnet-container-2024-0009 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 528c4440-a55a-5573-b195-d6853e7048da

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:7* OR ImageFileName = *debian:8* OR ImageFileName = *ubuntu:14.04-ESM* OR ImageFileName = *ubuntu:16.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
