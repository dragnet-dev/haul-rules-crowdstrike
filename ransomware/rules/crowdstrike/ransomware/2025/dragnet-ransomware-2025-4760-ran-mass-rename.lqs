// Dragnet [Ransomware]: dragnet-ransomware-2025-4760 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 1490dc9e-4095-55ef-8010-9ef378fb8814

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
