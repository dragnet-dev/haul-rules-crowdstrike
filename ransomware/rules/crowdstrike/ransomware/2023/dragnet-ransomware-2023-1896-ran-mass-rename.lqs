// Dragnet [Ransomware]: dragnet-ransomware-2023-1896 — Mass File Rename (losttrust)
// Status: deprecated | Level: high | ID: 5e6d52e3-a422-5108-8956-3e6827ce6ef4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
