// Dragnet [Ransomware]: dragnet-ransomware-2025-5023 — Mass File Rename (radar)
// Status: deprecated | Level: high | ID: d40f129b-519a-5c58-9d9e-d3ab14ad45e4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
