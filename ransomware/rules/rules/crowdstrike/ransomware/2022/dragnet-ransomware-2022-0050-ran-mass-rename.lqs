// Dragnet [Ransomware]: dragnet-ransomware-2022-0050 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: ca6f0820-d901-579a-a485-30877d5821ff

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
