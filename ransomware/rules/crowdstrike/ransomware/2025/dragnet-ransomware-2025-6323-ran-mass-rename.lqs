// Dragnet [Ransomware]: dragnet-ransomware-2025-6323 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 1947c790-916d-5000-9ad3-d3a97ee36307

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
