// Dragnet [Ransomware]: dragnet-ransomware-2024-5129 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: 0dbb52ab-6578-5b57-837e-960178d59d32

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
