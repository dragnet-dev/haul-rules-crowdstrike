// Dragnet [Ransomware]: dragnet-ransomware-2026-1965 — Mass File Rename (blackshrantac)
// Status: test | Level: high | ID: 6e900760-dfbe-5a1c-93ce-3e21b7e14f78

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
