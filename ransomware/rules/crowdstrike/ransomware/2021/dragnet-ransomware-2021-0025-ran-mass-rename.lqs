// Dragnet [Ransomware]: dragnet-ransomware-2021-0025 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 6fc43e1a-3d55-5156-a7ae-fcfcbd4b09eb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
