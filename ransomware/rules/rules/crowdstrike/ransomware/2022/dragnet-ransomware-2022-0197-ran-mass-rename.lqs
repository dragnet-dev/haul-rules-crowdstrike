// Dragnet [Ransomware]: dragnet-ransomware-2022-0197 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: bda193e6-8002-5a4c-ab06-a039e1f7a15d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
