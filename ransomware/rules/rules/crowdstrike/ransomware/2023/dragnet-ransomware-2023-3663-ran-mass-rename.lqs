// Dragnet [Ransomware]: dragnet-ransomware-2023-3663 — Mass File Rename (werewolves)
// Status: experimental | Level: high | ID: 6fd71015-9652-5a80-b83c-716f57b041db

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
