// Dragnet [Ransomware]: dragnet-ransomware-2023-5328 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 8cb3c463-506c-5618-ad11-22b54e16b6d3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
