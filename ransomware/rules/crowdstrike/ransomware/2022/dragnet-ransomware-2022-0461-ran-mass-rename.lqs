// Dragnet [Ransomware]: dragnet-ransomware-2022-0461 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: f8f607fa-f15e-53d4-8c8a-237867a7abed

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
