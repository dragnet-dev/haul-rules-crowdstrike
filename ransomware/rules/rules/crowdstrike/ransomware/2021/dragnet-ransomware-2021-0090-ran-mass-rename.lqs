// Dragnet [Ransomware]: dragnet-ransomware-2021-0090 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: d836366e-091c-50a0-83cd-3bff0c039709

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
