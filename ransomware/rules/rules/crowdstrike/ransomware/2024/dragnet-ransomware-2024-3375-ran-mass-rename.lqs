// Dragnet [Ransomware]: dragnet-ransomware-2024-3375 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: aa2d4fec-cb8e-54de-898b-7530ce297a18

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
