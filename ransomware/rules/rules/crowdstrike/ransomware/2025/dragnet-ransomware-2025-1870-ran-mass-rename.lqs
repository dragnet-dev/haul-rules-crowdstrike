// Dragnet [Ransomware]: dragnet-ransomware-2025-1870 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: 77829420-d02e-562d-8828-055a50eb936c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
