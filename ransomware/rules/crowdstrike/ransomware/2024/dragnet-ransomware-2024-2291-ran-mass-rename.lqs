// Dragnet [Ransomware]: dragnet-ransomware-2024-2291 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: dba910c3-9b3a-5c68-831d-8721e23a9b52

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
