// Dragnet [Container]: dragnet-container-2026-1007 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: a40ebe70-67d8-5ad8-94d2-7958ce4c93bc

#event_simpleName=*
| (ImageFileName = *debian:7* OR ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10* OR ImageFileName = *ubuntu:13.10*)
| table([timestamp, ComputerName])
| limit(1000)
