// Dragnet [Ransomware]: dragnet-ransomware-2020-0071 — Mass File Rename (revil)
// Status: deprecated | Level: high | ID: 1e684bcb-8965-5def-aff4-71554d026d6c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
