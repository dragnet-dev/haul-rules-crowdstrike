// Dragnet [Ransomware]: dragnet-ransomware-2022-2738 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 413293e1-2ea3-58a5-bc22-f89a973e7dba

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
