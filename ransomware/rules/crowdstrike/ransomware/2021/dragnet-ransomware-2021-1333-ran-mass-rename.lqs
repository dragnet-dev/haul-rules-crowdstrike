// Dragnet [Ransomware]: dragnet-ransomware-2021-1333 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 0e9f009c-1592-56c9-a856-87de149d25ae

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
