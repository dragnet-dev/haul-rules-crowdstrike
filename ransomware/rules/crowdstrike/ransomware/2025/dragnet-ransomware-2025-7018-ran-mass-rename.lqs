// Dragnet [Ransomware]: dragnet-ransomware-2025-7018 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 6f805fcc-0e33-5f5d-bd26-4a92f4bd538c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
