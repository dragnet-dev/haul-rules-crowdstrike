// Dragnet [Ransomware]: dragnet-ransomware-2024-2628 — Mass File Rename (redransomware)
// Status: deprecated | Level: high | ID: 71271afa-b3f6-5fd8-8b7b-51fafcb4cc14

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
