// Dragnet [Ransomware]: dragnet-ransomware-2025-7132 — Mass File Rename (cicada3301)
// Status: experimental | Level: high | ID: eb0eed1e-ccaf-5c66-a296-81079b64c9e1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
