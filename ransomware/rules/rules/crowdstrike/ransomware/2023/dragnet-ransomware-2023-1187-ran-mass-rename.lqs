// Dragnet [Ransomware]: dragnet-ransomware-2023-1187 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 8316dd9e-05ce-5e7b-947b-b52fd384e9e6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
