// Dragnet [Ransomware]: dragnet-ransomware-2022-0851 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 8c5a4d06-2d3b-5fec-8618-e1d5df63f6da

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
