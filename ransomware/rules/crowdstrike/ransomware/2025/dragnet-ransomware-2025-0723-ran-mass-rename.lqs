// Dragnet [Ransomware]: dragnet-ransomware-2025-0723 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: ff18363f-0854-5269-8d98-572064240913

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
