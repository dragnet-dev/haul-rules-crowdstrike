// Dragnet [Ransomware]: dragnet-ransomware-2025-4193 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 2f6d152f-6c40-5c55-91f0-3f9b648727af

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
