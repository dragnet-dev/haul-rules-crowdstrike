// Dragnet [Ransomware]: dragnet-ransomware-2021-0852 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 183d0f72-46e9-50c2-8b41-2e22776dbbfa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
