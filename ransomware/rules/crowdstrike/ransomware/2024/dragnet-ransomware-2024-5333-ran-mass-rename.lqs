// Dragnet [Ransomware]: dragnet-ransomware-2024-5333 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: ded6ac4f-d2a4-56b4-84ef-8298578c7fe6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
