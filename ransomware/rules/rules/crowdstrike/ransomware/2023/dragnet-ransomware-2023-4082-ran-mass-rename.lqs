// Dragnet [Ransomware]: dragnet-ransomware-2023-4082 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: aa1ab5ce-1213-581b-b28d-d4eae8e208e1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
