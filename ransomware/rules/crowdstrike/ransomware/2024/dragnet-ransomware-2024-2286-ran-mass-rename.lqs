// Dragnet [Ransomware]: dragnet-ransomware-2024-2286 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 0c7a2e38-9aa1-54d6-929a-4c435b39f01c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
