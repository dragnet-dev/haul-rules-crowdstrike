// Dragnet [Ransomware]: dragnet-ransomware-2025-6160 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 8c4a2039-b91c-595e-8e47-523c5cc87672

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
