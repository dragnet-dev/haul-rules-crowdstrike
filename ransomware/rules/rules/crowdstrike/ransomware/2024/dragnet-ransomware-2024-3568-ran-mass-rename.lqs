// Dragnet [Ransomware]: dragnet-ransomware-2024-3568 — Mass File Rename (play)
// Status: experimental | Level: high | ID: bdc94db2-ac93-5deb-bfa5-d32f0eae2dd0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
