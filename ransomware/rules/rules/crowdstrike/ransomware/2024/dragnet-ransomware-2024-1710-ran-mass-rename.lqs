// Dragnet [Ransomware]: dragnet-ransomware-2024-1710 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 55660019-d146-54b7-a5f4-2cab28913854

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
