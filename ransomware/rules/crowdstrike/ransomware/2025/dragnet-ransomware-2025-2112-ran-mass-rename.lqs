// Dragnet [Ransomware]: dragnet-ransomware-2025-2112 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 152a18e8-1755-5e39-92fc-26715ef19699

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
