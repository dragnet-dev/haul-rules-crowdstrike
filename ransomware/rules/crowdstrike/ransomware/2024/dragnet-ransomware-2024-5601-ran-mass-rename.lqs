// Dragnet [Ransomware]: dragnet-ransomware-2024-5601 — Mass File Rename (arcusmedia)
// Status: experimental | Level: high | ID: 12f252fa-6aad-58ea-ae98-4986c4ec3c2d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
