// Dragnet [Ransomware]: dragnet-ransomware-2025-7792 — Mass File Rename (blackshrantac)
// Status: test | Level: high | ID: 59d013bc-8dda-5196-a658-1580987fa92c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
