// Dragnet [Ransomware]: dragnet-ransomware-2024-5037 — Mass File Rename (dragonforce)
// Status: deprecated | Level: high | ID: a5d92caf-d8c3-579a-997a-5b7da546851d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
