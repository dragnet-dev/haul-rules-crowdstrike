// Dragnet [Ransomware]: dragnet-ransomware-2024-0576 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: 4b33718f-e8a8-5b73-9455-fcdde955ea45

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
