// Dragnet [Container]: dragnet-container-2026-1536 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 58e429a6-cab1-5642-a615-d0e69367ca8d

#event_simpleName=*
| (ImageFileName = *chainguard:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
