// Dragnet [Ransomware]: dragnet-ransomware-2024-2372 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 4faa38a0-2c22-59eb-91b5-e0e39853758c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
