// Dragnet [Ransomware]: dragnet-ransomware-2023-1975 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: f704134e-08eb-5723-80ae-f0ccc33f4f8b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
