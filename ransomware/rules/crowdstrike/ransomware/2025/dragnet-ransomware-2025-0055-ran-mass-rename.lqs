// Dragnet [Ransomware]: dragnet-ransomware-2025-0055 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 2f37eb53-da3b-56be-a880-07e190774ed9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
