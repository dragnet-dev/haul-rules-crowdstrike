// Dragnet [Ransomware]: dragnet-ransomware-2024-0880 — Mass File Rename (threeam)
// Status: experimental | Level: high | ID: b6f872cc-59c0-56d5-b58a-842f97585c65

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
