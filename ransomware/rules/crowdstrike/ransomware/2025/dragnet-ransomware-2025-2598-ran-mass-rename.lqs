// Dragnet [Ransomware]: dragnet-ransomware-2025-2598 — Mass File Rename (handala)
// Status: experimental | Level: high | ID: f43e4710-7405-54b2-85f9-b84347d75c1d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
