// Dragnet [Ransomware]: dragnet-ransomware-2022-0408 — Mass File Rename (lv)
// Status: deprecated | Level: high | ID: 277f1e45-6e30-5bea-89b9-b335e7603c4f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
