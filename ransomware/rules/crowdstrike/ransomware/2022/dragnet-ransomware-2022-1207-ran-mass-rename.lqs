// Dragnet [Ransomware]: dragnet-ransomware-2022-1207 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 68a44f35-e3ec-5503-9de0-5801f7a5a2a3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
