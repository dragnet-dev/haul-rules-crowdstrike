// Dragnet [Container]: dragnet-container-2026-2272 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 4e30aeaa-2bf0-58ec-a634-ce5e0e765631

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
