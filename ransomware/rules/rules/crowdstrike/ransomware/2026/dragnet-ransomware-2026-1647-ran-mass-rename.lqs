// Dragnet [Ransomware]: dragnet-ransomware-2026-1647 — Mass File Rename (lockbit5)
// Status: test | Level: high | ID: e52d7ef7-395f-535b-8d1c-4b630501b824

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
