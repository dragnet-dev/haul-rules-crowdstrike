// Dragnet [Ransomware]: dragnet-ransomware-2023-0018 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 338e0cae-e35b-5583-8634-6d9ad6edbe82

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
