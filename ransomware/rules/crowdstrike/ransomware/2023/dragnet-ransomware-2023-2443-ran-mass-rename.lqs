// Dragnet [Ransomware]: dragnet-ransomware-2023-2443 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 4fd89d53-ce43-52cb-811d-2ecdf4b8f741

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
