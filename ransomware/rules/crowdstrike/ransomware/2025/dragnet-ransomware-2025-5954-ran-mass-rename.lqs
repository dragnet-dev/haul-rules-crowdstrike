// Dragnet [Ransomware]: dragnet-ransomware-2025-5954 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: 7a12c055-e9bd-50fa-afa4-5f394b735409

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
