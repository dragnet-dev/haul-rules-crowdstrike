// Dragnet [Container]: dragnet-container-2024-1391 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 091d6f03-09ee-5ac2-99ef-5a507324f174

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:8* OR ImageFileName = *debian:9* OR ImageFileName = *redhat/ubi9:*)
| table([timestamp, ComputerName])
| limit(1000)
