// Dragnet [Ransomware]: dragnet-ransomware-2023-0896 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 6af51c63-88c8-5bb7-bf0d-05d047dcd6fa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
