// Dragnet [Ransomware]: dragnet-ransomware-2021-1066 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 062420fe-401e-5dcd-a305-4397f6837f1e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
