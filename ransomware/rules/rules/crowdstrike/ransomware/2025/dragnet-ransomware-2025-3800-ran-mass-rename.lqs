// Dragnet [Ransomware]: dragnet-ransomware-2025-3800 — Mass File Rename (blackshrantac)
// Status: experimental | Level: high | ID: 355f08cf-974f-5350-aeaf-f8797b9853c5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
