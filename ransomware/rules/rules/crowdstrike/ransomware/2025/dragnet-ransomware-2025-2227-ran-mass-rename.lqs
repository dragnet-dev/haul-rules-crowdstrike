// Dragnet [Ransomware]: dragnet-ransomware-2025-2227 — Mass File Rename (direwolf)
// Status: experimental | Level: high | ID: 70e4c601-bd21-518c-83cc-76c48f165c52

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
