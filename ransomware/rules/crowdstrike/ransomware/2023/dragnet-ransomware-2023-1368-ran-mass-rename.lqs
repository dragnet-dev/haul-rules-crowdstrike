// Dragnet [Ransomware]: dragnet-ransomware-2023-1368 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: cbc2292d-4d0b-54aa-be92-0848f1c8bf1d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
