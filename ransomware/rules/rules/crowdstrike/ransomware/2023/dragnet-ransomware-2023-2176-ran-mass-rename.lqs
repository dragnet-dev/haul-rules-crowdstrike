// Dragnet [Ransomware]: dragnet-ransomware-2023-2176 — Mass File Rename (monti)
// Status: experimental | Level: high | ID: 04efb498-413a-5dad-92d8-393fafad703a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
