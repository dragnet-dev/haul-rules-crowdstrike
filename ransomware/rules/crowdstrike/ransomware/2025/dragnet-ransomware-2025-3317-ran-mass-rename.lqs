// Dragnet [Ransomware]: dragnet-ransomware-2025-3317 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: fd443235-886e-5d7d-b4ef-ddf138de7695

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
