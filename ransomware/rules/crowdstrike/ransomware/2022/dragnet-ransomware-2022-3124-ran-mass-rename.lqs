// Dragnet [Ransomware]: dragnet-ransomware-2022-3124 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 2b969a6b-e61b-5b4e-88f1-d32741cefb69

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
