// Dragnet [Ransomware]: dragnet-ransomware-2024-1637 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 89a406b7-5db0-5a77-9a77-646dcdfd9f87

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
