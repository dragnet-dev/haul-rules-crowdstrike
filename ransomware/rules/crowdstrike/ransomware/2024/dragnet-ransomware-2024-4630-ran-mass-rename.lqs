// Dragnet [Ransomware]: dragnet-ransomware-2024-4630 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: f5d6a00e-8318-55c7-a1fd-637ec106596b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
