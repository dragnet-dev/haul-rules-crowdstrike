// Dragnet [Ransomware]: dragnet-ransomware-2024-2218 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: 2f028c76-3271-52e3-a792-239b435b45c2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
