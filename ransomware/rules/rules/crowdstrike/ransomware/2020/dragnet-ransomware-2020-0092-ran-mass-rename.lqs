// Dragnet [Ransomware]: dragnet-ransomware-2020-0092 — Mass File Rename (maze)
// Status: deprecated | Level: high | ID: 53a31080-0ad8-58c3-a22f-8c759aec476f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
