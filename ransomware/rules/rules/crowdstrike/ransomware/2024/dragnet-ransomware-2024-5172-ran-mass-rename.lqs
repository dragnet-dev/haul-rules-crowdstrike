// Dragnet [Ransomware]: dragnet-ransomware-2024-5172 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: e0f9e7a6-ecbd-50b7-9273-33539bc164eb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
