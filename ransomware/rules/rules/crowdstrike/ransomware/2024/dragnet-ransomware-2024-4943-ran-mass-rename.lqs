// Dragnet [Ransomware]: dragnet-ransomware-2024-4943 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 6cd83ed9-519d-5801-b827-151b9b9ec55b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
