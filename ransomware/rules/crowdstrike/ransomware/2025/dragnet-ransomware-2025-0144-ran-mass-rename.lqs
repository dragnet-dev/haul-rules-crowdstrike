// Dragnet [Ransomware]: dragnet-ransomware-2025-0144 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: b0bf0e3e-bb52-5a40-b79c-28a9f6432876

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
