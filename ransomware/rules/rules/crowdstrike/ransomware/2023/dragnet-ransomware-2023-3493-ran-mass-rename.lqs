// Dragnet [Ransomware]: dragnet-ransomware-2023-3493 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: bdd994d9-5728-5872-8903-cf58acb22171

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
