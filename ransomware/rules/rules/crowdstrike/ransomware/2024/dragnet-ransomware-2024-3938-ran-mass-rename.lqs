// Dragnet [Ransomware]: dragnet-ransomware-2024-3938 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: cda4ef5d-2412-5d0f-9ed4-7455d8128753

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
