// Dragnet [Ransomware]: dragnet-ransomware-2024-5036 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: adbb8d16-3f8b-5122-a7bb-7a0c4d2616fc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
