// Dragnet [Ransomware]: dragnet-ransomware-2022-0480 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 65d93158-fb1a-5f23-8bfa-1234ec704ad7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
