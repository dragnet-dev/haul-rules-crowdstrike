// Dragnet [Ransomware]: dragnet-ransomware-2024-3391 — Mass File Rename (play)
// Status: experimental | Level: high | ID: a0154a36-22f3-5b12-bbda-d610be27a7e5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
