// Dragnet [Ransomware]: dragnet-ransomware-2026-1824 — Mass File Rename (lockbit5)
// Status: test | Level: high | ID: affa1b44-b397-53a5-82a1-f9b83babe917

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
