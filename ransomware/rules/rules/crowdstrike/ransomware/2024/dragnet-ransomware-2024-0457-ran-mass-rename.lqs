// Dragnet [Ransomware]: dragnet-ransomware-2024-0457 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: c078e961-8d23-5b75-ab1f-7060f1721ed8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
