// Dragnet [Ransomware]: dragnet-ransomware-2025-3308 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: a689d4e3-5a6a-5856-94fe-5cf3fc90536c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
