// Dragnet [Ransomware]: dragnet-ransomware-2025-1167 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: 14d67ca9-f97c-5882-aaab-8ac4c8727958

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
