// Dragnet [Ransomware]: dragnet-ransomware-2025-1551 — Mass File Rename (lockbit5)
// Status: experimental | Level: high | ID: d08227ba-5ea7-573c-95af-b66645769944

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
