// Dragnet [Ransomware]: dragnet-ransomware-2024-1191 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: f8a3867b-554b-5a40-af32-4c0dff5985ac

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
