// Dragnet [Ransomware]: dragnet-ransomware-2022-1193 — Mass File Rename (leaktheanalyst)
// Status: deprecated | Level: high | ID: 871273b8-6426-5483-89ac-0f1e7971c25c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
