// Dragnet [Ransomware]: dragnet-ransomware-2024-2859 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 064c5639-2b6e-5ed4-80c3-23f87822abdf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
