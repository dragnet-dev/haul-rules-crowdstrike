// Dragnet [Ransomware]: dragnet-ransomware-2024-3280 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 92575726-3dfb-59f4-b4d3-99c2f7699d1a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
