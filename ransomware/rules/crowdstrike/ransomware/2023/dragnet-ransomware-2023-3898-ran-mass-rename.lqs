// Dragnet [Ransomware]: dragnet-ransomware-2023-3898 — Mass File Rename (trigona)
// Status: experimental | Level: high | ID: d98e8349-ab31-5294-a51c-aa23eb0e75b1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
