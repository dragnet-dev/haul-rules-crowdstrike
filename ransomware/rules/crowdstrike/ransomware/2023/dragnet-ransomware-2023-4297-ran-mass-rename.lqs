// Dragnet [Ransomware]: dragnet-ransomware-2023-4297 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 2848f839-7771-5df1-b7d8-146e3a2277aa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
