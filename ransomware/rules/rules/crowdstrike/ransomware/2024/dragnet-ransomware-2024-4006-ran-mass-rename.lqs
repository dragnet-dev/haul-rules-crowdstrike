// Dragnet [Ransomware]: dragnet-ransomware-2024-4006 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 6af9c370-cb67-5166-91db-6f8804c0170b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
