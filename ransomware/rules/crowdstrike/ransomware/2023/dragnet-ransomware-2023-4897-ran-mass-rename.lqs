// Dragnet [Ransomware]: dragnet-ransomware-2023-4897 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 19928f3f-75f5-5dcb-80ea-bbe8092a1041

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
