// Dragnet [Ransomware]: dragnet-ransomware-2023-2590 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 3d5af6f4-9c10-5728-883d-76d0237f92c4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
