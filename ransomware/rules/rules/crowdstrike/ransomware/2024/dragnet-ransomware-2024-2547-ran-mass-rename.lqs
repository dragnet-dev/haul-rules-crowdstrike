// Dragnet [Ransomware]: dragnet-ransomware-2024-2547 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 7e17575f-38e1-5a8c-b1e9-047040cd655e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
