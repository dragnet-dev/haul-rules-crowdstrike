// Dragnet [Ransomware]: dragnet-ransomware-2023-0747 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 71ec2931-e6fe-52a1-95fe-f6450a3ec4bd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
