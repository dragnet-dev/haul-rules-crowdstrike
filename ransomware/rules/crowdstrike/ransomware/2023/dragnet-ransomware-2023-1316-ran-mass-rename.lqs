// Dragnet [Ransomware]: dragnet-ransomware-2023-1316 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: 7994769e-2f46-5e91-9fdc-8e5bf299f642

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
