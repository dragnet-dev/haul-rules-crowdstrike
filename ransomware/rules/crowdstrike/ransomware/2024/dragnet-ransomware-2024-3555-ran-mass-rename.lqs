// Dragnet [Ransomware]: dragnet-ransomware-2024-3555 — Mass File Rename (helldown)
// Status: experimental | Level: high | ID: 727ae409-b1b2-58d7-90b2-09b01971b6f3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
