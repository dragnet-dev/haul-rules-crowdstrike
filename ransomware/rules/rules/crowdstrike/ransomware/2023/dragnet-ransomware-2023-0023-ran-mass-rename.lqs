// Dragnet [Ransomware]: dragnet-ransomware-2023-0023 — Mass File Rename (losttrust)
// Status: deprecated | Level: high | ID: 44f65fed-8193-57ad-bba1-7c722cf3bcfd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
