// Dragnet [Ransomware]: dragnet-ransomware-2025-0582 — Mass File Rename (play)
// Status: experimental | Level: high | ID: d9753726-54bb-5470-b198-04069b97135d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
