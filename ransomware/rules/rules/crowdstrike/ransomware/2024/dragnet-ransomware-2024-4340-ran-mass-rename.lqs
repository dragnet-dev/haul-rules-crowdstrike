// Dragnet [Ransomware]: dragnet-ransomware-2024-4340 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: eb9a6bb6-3e92-5bae-b666-15566a31ee54

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
