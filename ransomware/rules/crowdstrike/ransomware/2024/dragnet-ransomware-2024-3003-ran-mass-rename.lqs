// Dragnet [Ransomware]: dragnet-ransomware-2024-3003 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 0722a637-d32c-5141-827d-22c2f8c48936

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
