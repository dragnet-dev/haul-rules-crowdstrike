// Dragnet [Ransomware]: dragnet-ransomware-2026-3375 — Mass File Rename (handala)
// Status: stable | Level: high | ID: 3e739165-d57c-5b99-968c-c885101da9a2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
