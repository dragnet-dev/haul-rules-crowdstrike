// Dragnet [Ransomware]: dragnet-ransomware-2023-4319 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 1e9f065c-47ff-56be-9641-fd083f2c539f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
