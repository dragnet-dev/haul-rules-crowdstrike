// Dragnet [Ransomware]: dragnet-ransomware-2021-1044 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: b09e5f41-4fde-5967-a6cb-8e28796e60cd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
