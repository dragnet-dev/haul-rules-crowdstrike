// Dragnet [Ransomware]: dragnet-ransomware-2023-1433 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 6552428a-bffd-5e4f-8650-e0709ba62b59

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
