// Dragnet [Ransomware]: dragnet-ransomware-2021-1008 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 980ac7f1-cc47-5c1e-9ba0-d9e7cd7c8e8a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
