// Dragnet [Ransomware]: dragnet-ransomware-2025-4960 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 9c3d7f8d-c47f-549d-8c4b-6dbe08330125

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
