// Dragnet [Ransomware]: dragnet-ransomware-2026-2966 — Mass File Rename (AuditTeam)
// Status: stable | Level: high | ID: 24cd7961-a053-5e9a-881e-c3103921040e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
