// Dragnet [Container]: dragnet-container-2026-2294 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: cbdb6cc5-f1f8-59e9-8fec-0d57859253a4

#event_simpleName=*
| (ImageFileName = *amazonlinux:1* OR ImageFileName = *debian:7* OR ImageFileName = *debian:8* OR ImageFileName = *oraclelinux:7* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:14.04* OR ImageFileName = *ubuntu:14.04-ESM* OR ImageFileName = *ubuntu:16.04* OR ImageFileName = *ubuntu:16.04-ESM* OR ImageFileName = *ubuntu:17.04*)
| table([timestamp, ComputerName])
| limit(1000)
