// Dragnet [Ransomware]: dragnet-ransomware-2024-5513 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 291bfafb-b736-5c44-b16b-5f7c968df0f0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
