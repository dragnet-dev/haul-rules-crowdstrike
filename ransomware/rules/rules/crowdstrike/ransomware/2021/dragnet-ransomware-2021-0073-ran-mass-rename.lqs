// Dragnet [Ransomware]: dragnet-ransomware-2021-0073 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: d98cdb26-8eb0-5d2e-9973-4cfad2d15521

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
