// Dragnet [Ransomware]: dragnet-ransomware-2024-4534 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 88113df6-436a-5150-bf00-b5058ecf893c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
