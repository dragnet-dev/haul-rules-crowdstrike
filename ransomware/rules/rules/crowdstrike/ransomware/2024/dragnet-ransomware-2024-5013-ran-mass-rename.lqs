// Dragnet [Ransomware]: dragnet-ransomware-2024-5013 — Mass File Rename (stormous)
// Status: deprecated | Level: high | ID: ed158bfd-8b00-59c8-8a27-7fde1ddf56b2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
