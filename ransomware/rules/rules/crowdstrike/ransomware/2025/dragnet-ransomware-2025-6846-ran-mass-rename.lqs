// Dragnet [Ransomware]: dragnet-ransomware-2025-6846 — Mass File Rename (nova)
// Status: experimental | Level: high | ID: b966b607-671e-5503-aa30-b4e1c95e02a2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
