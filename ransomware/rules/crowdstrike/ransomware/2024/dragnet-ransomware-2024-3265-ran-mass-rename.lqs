// Dragnet [Ransomware]: dragnet-ransomware-2024-3265 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: 4837985e-3799-511f-89e1-ef8ce0893048

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
