// Dragnet [Ransomware]: dragnet-ransomware-2023-2284 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 839c7d6d-a18d-5f50-b87e-cd458676f02e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
