// Dragnet [Ransomware]: dragnet-ransomware-2025-1315 — Mass File Rename (anubis)
// Status: experimental | Level: high | ID: 6d8cbf38-2909-5ca9-8757-b2d0baacff5e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
