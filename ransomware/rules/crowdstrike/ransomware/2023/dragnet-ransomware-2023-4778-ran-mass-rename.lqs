// Dragnet [Ransomware]: dragnet-ransomware-2023-4778 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 3a8b831b-5ce3-534a-8120-39bf0fede39f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
