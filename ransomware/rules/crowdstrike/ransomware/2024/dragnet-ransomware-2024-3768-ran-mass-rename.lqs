// Dragnet [Ransomware]: dragnet-ransomware-2024-3768 — Mass File Rename (helldown)
// Status: experimental | Level: high | ID: 4e43c72b-238a-5f1c-b4dd-09fa810f259b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
