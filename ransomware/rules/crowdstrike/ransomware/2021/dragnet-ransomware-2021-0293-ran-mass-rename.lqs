// Dragnet [Ransomware]: dragnet-ransomware-2021-0293 — Mass File Rename (avaddon)
// Status: deprecated | Level: high | ID: 3a0a451a-9771-519a-bf5f-730ec1cfae0c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
