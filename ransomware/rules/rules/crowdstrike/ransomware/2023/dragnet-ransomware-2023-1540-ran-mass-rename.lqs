// Dragnet [Ransomware]: dragnet-ransomware-2023-1540 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 8304dda2-20d6-5aa7-99d8-c7c1eef02526

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
