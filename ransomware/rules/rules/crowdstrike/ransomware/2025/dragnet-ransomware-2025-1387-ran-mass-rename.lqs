// Dragnet [Ransomware]: dragnet-ransomware-2025-1387 — Mass File Rename (sinobi)
// Status: experimental | Level: high | ID: 7aed183f-9433-587c-ac2a-24b5738b7fa6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
