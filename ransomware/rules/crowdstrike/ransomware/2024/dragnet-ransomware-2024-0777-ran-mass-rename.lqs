// Dragnet [Ransomware]: dragnet-ransomware-2024-0777 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: 09a16db5-afeb-5fb6-ad1e-5934f5db8530

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
