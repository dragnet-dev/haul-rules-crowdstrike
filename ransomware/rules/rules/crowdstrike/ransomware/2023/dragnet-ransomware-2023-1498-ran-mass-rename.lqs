// Dragnet [Ransomware]: dragnet-ransomware-2023-1498 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 6f2d9c86-16d2-58ee-889a-b97c4bdae530

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
