// Dragnet [Ransomware]: dragnet-ransomware-2022-0346 — Mass File Rename (everest)
// Status: deprecated | Level: high | ID: fe8bfb03-a19b-5521-9835-97016d8c6566

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
