// Dragnet [Ransomware]: dragnet-ransomware-2024-4114 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 04b1f18c-8cc1-5adc-a3ee-054c2e632fa7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
