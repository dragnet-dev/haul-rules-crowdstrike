// Dragnet [Ransomware]: dragnet-ransomware-2024-5735 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 38487471-f985-5017-8aa2-54b921be9231

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
