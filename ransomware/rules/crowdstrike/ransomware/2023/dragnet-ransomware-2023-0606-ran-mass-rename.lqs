// Dragnet [Ransomware]: dragnet-ransomware-2023-0606 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 07a4029c-ad3c-548a-93a2-80c09f29b232

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
