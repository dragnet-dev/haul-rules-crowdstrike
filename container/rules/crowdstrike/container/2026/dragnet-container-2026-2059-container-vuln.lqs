// Dragnet [Container]: dragnet-container-2026-2059 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 79e4f75f-57f1-53b0-84c2-dcb1d73eb8ae

#event_simpleName=*
| (ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *redhat/ubi9:*)
| table([timestamp, ComputerName])
| limit(1000)
