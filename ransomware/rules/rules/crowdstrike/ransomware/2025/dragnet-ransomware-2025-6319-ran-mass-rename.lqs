// Dragnet [Ransomware]: dragnet-ransomware-2025-6319 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 1847a7c9-d01c-5e5d-aa71-c90aa08fd252

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
