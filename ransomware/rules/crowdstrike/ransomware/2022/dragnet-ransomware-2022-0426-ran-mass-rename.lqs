// Dragnet [Ransomware]: dragnet-ransomware-2022-0426 — Mass File Rename (ragnarlocker)
// Status: deprecated | Level: high | ID: 2b4777aa-dc85-56c2-a628-ddb61cea1031

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
