// Dragnet [Ransomware]: dragnet-ransomware-2025-3104 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 2bf7a1e3-6b2e-5277-8cea-c3442b2d96cf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
