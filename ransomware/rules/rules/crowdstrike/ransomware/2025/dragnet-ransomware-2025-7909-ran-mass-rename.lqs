// Dragnet [Ransomware]: dragnet-ransomware-2025-7909 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: a6de5bf7-d57c-5a9d-8a55-ac2640007254

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
