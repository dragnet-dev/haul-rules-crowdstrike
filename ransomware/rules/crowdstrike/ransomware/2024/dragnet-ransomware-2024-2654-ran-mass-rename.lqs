// Dragnet [Ransomware]: dragnet-ransomware-2024-2654 — Mass File Rename (dragonransomware)
// Status: experimental | Level: high | ID: 4f0d589b-41a7-5383-860d-32b843f98f94

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
