// Dragnet [Ransomware]: dragnet-ransomware-2024-2443 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: 02041319-a6b2-5c86-b69d-6b27f76b82ee

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
