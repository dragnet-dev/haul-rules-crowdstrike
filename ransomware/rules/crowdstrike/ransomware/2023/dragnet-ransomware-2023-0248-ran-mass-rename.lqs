// Dragnet [Ransomware]: dragnet-ransomware-2023-0248 — Mass File Rename (cyclops)
// Status: deprecated | Level: high | ID: 2917ba4c-be51-5165-93c3-4814fc6079b4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
