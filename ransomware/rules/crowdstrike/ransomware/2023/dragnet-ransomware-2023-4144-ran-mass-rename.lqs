// Dragnet [Ransomware]: dragnet-ransomware-2023-4144 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: d1c90448-73a5-5ebd-ba28-374e14439d37

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
