// Dragnet [Ransomware]: dragnet-ransomware-2023-4394 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: ebdf1ee7-124e-5449-9d26-765175774599

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
