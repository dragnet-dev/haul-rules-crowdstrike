// Dragnet [Ransomware]: dragnet-ransomware-2025-5532 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: d108d5b4-11e8-548e-a5d0-3067c9d14ec0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
