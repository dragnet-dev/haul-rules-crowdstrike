// Dragnet [Ransomware]: dragnet-ransomware-2021-1121 — Mass File Rename (astroteam)
// Status: deprecated | Level: high | ID: 2e0249a5-1fc9-5134-befc-c1cbc7b350c4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
