// Dragnet [Ransomware]: dragnet-ransomware-2024-1724 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 81e2e15a-165a-5330-bf4a-bc566afd6047

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
