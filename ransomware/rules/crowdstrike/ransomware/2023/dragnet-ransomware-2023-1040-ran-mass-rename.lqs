// Dragnet [Ransomware]: dragnet-ransomware-2023-1040 — Mass File Rename (play)
// Status: experimental | Level: high | ID: d56ffe39-6925-57f5-b34c-0d2728613ef7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
