// Dragnet [Ransomware]: dragnet-ransomware-2024-5091 — Mass File Rename (beast)
// Status: experimental | Level: high | ID: f2047179-c557-5b78-be2b-5048e4cf7d2d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
