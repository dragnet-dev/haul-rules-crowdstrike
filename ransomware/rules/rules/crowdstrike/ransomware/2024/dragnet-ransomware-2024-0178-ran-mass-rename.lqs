// Dragnet [Ransomware]: dragnet-ransomware-2024-0178 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 53639d3e-5ccf-5d59-a399-0e52f53a4fd0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
