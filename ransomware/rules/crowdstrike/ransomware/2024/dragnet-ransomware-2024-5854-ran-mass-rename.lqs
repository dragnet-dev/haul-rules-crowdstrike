// Dragnet [Ransomware]: dragnet-ransomware-2024-5854 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 6fc16792-b188-5cb2-bd7e-5700c06789d0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
