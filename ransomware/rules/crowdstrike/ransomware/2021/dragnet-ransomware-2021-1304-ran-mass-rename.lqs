// Dragnet [Ransomware]: dragnet-ransomware-2021-1304 — Mass File Rename (everest)
// Status: deprecated | Level: high | ID: ff8f67fd-33d9-5fd9-b17f-4d7ff51f0b08

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
