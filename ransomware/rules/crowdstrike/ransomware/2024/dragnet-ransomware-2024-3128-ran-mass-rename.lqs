// Dragnet [Ransomware]: dragnet-ransomware-2024-3128 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: d946e653-f163-57b0-b8c1-355293164309

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
