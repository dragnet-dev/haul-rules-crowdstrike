// Dragnet [Ransomware]: dragnet-ransomware-2024-1235 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: 62a0385f-ff98-5a08-b4b0-01125d84a4dc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
