// Dragnet [Ransomware]: dragnet-ransomware-2025-7527 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 61a0a92e-1411-5cc6-9828-fdbf1267d824

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
