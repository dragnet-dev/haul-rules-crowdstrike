// Dragnet [Ransomware]: dragnet-ransomware-2025-1729 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: d0060c13-0bd1-5011-8add-d0dfcfd3868a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
