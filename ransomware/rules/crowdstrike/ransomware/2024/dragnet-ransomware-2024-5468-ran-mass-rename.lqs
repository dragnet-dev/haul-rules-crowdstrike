// Dragnet [Ransomware]: dragnet-ransomware-2024-5468 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: 9e38943c-8d5b-55bf-9e94-1eb012f083ed

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
