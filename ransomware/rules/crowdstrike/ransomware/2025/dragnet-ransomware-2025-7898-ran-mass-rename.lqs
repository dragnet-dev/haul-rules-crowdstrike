// Dragnet [Ransomware]: dragnet-ransomware-2025-7898 — Mass File Rename (interlock)
// Status: experimental | Level: high | ID: 0671e296-f381-5df0-9788-98b289632445

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
