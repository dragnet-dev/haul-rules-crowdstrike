// Dragnet [Ransomware]: dragnet-ransomware-2024-2049 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 99e5e8f0-7d5a-5101-90e0-7ffd8cbe12b9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
