// Dragnet [Ransomware]: dragnet-ransomware-2023-4499 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 6ec3491f-068e-57ba-b465-70e2f6feb4f7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
