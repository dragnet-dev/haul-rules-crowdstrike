// Dragnet [Ransomware]: dragnet-ransomware-2025-0119 — Mass File Rename (sinobi)
// Status: experimental | Level: high | ID: 2caceb4e-1faa-53a7-bae9-4abec890260c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
