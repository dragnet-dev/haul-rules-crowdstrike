// Dragnet [Ransomware]: dragnet-ransomware-2025-1475 — Mass File Rename (kairos)
// Status: experimental | Level: high | ID: 36eebd82-2ad6-579b-ace1-2831065fc92a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
