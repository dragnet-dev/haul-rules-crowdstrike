// Dragnet [Ransomware]: dragnet-ransomware-2025-0515 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 1fe6a050-5d29-5f35-ad01-9efe5311f491

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
