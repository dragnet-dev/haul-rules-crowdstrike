// Dragnet [Ransomware]: dragnet-ransomware-2025-6092 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 49dd3c60-65fa-5774-b89b-5d3e4fb05380

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
