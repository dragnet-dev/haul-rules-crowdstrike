// Dragnet [Ransomware]: dragnet-ransomware-2026-2018 — Mass File Rename (LeakBazaar)
// Status: stable | Level: high | ID: ba7eb310-bfcd-5a6f-b4e3-f5a530e3276c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
