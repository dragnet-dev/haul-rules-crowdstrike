// Dragnet [Ransomware]: dragnet-ransomware-2025-7825 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: fa14f5c2-2e02-5d9e-9d78-921c1426dfb4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
