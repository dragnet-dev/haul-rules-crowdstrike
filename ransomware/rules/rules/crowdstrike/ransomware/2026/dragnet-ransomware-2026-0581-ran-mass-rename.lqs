// Dragnet [Ransomware]: dragnet-ransomware-2026-0581 — Mass File Rename (incransom)
// Status: stable | Level: high | ID: 8719067e-4700-5963-866d-3c0bba522ab4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
