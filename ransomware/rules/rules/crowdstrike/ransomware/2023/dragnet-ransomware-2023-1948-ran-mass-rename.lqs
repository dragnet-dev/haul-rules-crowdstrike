// Dragnet [Ransomware]: dragnet-ransomware-2023-1948 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: e8b5e23b-cb36-5dec-b10b-54067f38fcc5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
