// Dragnet [Ransomware]: dragnet-ransomware-2025-1179 — Mass File Rename (cicada3301)
// Status: experimental | Level: high | ID: 4efcefd2-fcbd-59d7-b7b9-7ca86304df1f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
