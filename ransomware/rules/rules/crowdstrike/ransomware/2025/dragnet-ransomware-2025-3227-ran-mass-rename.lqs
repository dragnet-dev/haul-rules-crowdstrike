// Dragnet [Ransomware]: dragnet-ransomware-2025-3227 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 2a4ff306-ecf3-5009-ac0e-e91e54a63df1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
