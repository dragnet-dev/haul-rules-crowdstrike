// Dragnet [Ransomware]: dragnet-ransomware-2024-5486 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: c5d3b064-436f-5780-af3b-5cad37a7c106

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
