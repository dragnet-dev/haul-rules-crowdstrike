// Dragnet [Ransomware]: dragnet-ransomware-2022-1727 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 28fc97bd-bc19-5e93-82f3-4fd22357f92d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
