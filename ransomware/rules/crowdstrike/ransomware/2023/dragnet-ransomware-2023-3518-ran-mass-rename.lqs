// Dragnet [Ransomware]: dragnet-ransomware-2023-3518 — Mass File Rename (play)
// Status: experimental | Level: high | ID: e0c6d64b-eebc-5fc2-a87f-d8ba154e62d7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
