// Dragnet [Ransomware]: dragnet-ransomware-2026-0426 — Mass File Rename (incransom)
// Status: stable | Level: high | ID: c976963a-4466-5f3b-8727-45b24f2a1f83

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
