// Dragnet [Ransomware]: dragnet-ransomware-2024-3683 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: e11f6c0c-31ab-52d2-a83d-257d2af23091

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
