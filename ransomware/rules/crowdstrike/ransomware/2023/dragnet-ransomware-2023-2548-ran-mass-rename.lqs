// Dragnet [Ransomware]: dragnet-ransomware-2023-2548 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 65a82c1d-a8f0-55a0-8de7-031b50e4bd06

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
