// Dragnet [Ransomware]: dragnet-ransomware-2023-2457 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 56259ded-6739-5279-9fe6-6499ffbe197d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
