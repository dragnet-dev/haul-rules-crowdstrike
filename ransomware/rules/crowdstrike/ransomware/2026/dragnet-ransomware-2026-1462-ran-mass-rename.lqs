// Dragnet [Ransomware]: dragnet-ransomware-2026-1462 — Mass File Rename (dragonforce)
// Status: stable | Level: high | ID: a85a18b3-6460-5142-b752-c630d31f1271

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
