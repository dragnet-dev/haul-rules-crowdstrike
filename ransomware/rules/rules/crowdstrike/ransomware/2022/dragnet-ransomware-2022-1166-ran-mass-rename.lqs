// Dragnet [Ransomware]: dragnet-ransomware-2022-1166 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 935fd23c-8ff1-5ed4-9318-9e9ba10dbec6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
