// Dragnet [Ransomware]: dragnet-ransomware-2025-5766 — Mass File Rename (direwolf)
// Status: experimental | Level: high | ID: b87dca4c-64a8-565f-9f98-e3b960e13a07

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
