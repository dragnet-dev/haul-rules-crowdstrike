// Dragnet [Ransomware]: dragnet-ransomware-2026-2517 — Mass File Rename (lockbit5)
// Status: stable | Level: high | ID: 6f7f151a-ea42-512d-a9b1-78cc9797f685

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
