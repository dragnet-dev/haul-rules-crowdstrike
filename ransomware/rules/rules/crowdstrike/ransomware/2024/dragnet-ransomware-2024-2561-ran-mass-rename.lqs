// Dragnet [Ransomware]: dragnet-ransomware-2024-2561 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: ea0d01be-5fd3-5bdd-8836-6b2d760fd098

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
