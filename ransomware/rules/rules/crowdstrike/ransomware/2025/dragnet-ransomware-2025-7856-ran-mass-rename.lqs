// Dragnet [Ransomware]: dragnet-ransomware-2025-7856 — Mass File Rename (beast)
// Status: experimental | Level: high | ID: 986ec776-9c1c-503c-bb40-a0796bbd84ea

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
