// Dragnet [Ransomware]: dragnet-ransomware-2022-2352 — Mass File Rename (quantum)
// Status: deprecated | Level: high | ID: 2e104c8d-26b9-53f4-a0b6-d0e3519304e2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
