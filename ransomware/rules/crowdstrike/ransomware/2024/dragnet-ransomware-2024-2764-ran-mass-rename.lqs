// Dragnet [Ransomware]: dragnet-ransomware-2024-2764 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: aa9d3c23-66bc-59df-9b18-3ca5a4b92960

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
