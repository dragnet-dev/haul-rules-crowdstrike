// Dragnet [Ransomware]: dragnet-ransomware-2020-0107 — Mass File Rename (maze)
// Status: experimental | Level: high | ID: 6d6ef5d2-783a-515e-9dad-04b22f083c02

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
