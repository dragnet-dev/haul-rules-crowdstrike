// Dragnet [Ransomware]: dragnet-ransomware-2024-3058 — Mass File Rename (kairos)
// Status: experimental | Level: high | ID: 235e3f0b-91a4-5954-b25d-fc26f5314e82

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
