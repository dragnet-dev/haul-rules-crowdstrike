// Dragnet [Ransomware]: dragnet-ransomware-2021-1793 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 50fdb0bb-454c-5400-a204-93c5a2fbd57a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
