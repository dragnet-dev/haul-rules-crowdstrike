// Dragnet [Ransomware]: dragnet-ransomware-2024-1983 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 62692adb-b9fd-52de-8762-055d691be514

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
