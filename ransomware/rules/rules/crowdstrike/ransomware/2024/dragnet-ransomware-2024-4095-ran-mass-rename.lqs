// Dragnet [Ransomware]: dragnet-ransomware-2024-4095 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 0dc19cd0-09c2-56dc-acf7-c1b74325968b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
