// Dragnet [Ransomware]: dragnet-ransomware-2023-3261 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 7f52f5e7-1ae5-53ab-9be4-646ee08e46a6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
