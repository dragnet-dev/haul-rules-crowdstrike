// Dragnet [Ransomware]: dragnet-ransomware-2023-1562 — Mass File Rename (mallox)
// Status: experimental | Level: high | ID: 4632a8c3-07e1-56a2-a104-f0b29892c132

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
