// Dragnet [Ransomware]: dragnet-ransomware-2024-3307 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: b986aefb-07a4-57dc-ba1a-eb7097a1d1f0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
