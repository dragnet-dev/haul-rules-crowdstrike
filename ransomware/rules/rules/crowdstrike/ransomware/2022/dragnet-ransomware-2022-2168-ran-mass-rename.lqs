// Dragnet [Ransomware]: dragnet-ransomware-2022-2168 — Mass File Rename (royal)
// Status: deprecated | Level: high | ID: 0f89acca-b09f-5163-b3bc-dd0b33fea3d2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
