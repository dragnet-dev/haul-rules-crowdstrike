// Dragnet [Ransomware]: dragnet-ransomware-2024-1451 — Mass File Rename (dragonforce)
// Status: deprecated | Level: high | ID: cc57ed27-75e4-591d-84c5-5c7c53c47c33

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
