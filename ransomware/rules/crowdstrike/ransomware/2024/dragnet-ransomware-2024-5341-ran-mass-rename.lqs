// Dragnet [Ransomware]: dragnet-ransomware-2024-5341 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 2401fb86-1a2a-5b37-9039-396bd0f7ee66

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
