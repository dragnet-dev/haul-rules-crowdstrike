// Dragnet [Ransomware]: dragnet-ransomware-2025-3703 — Mass File Rename (embargo)
// Status: experimental | Level: high | ID: 5a43090f-61d3-51d2-aee0-ba67126232bb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
