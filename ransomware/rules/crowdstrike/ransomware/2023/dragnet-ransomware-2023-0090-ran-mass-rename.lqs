// Dragnet [Ransomware]: dragnet-ransomware-2023-0090 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: efac3b06-ff64-5bde-b3fb-d6d8e7e28499

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
