// Dragnet [Ransomware]: dragnet-ransomware-2022-2914 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 3b823161-6737-5291-b16b-81080f8add6f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
