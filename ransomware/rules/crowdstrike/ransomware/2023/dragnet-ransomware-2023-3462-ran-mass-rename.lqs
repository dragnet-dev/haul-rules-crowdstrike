// Dragnet [Ransomware]: dragnet-ransomware-2023-3462 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: b38bdf6f-f935-51d6-b9a2-10552479f854

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
