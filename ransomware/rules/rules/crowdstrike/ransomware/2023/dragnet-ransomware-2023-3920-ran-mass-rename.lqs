// Dragnet [Ransomware]: dragnet-ransomware-2023-3920 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 642ae86e-dd06-5510-9780-61417092d6fa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
