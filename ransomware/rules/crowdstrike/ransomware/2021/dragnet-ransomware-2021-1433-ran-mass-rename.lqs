// Dragnet [Ransomware]: dragnet-ransomware-2021-1433 — Mass File Rename (avaddon)
// Status: deprecated | Level: high | ID: 2733318b-6b1c-5eaf-bc97-0b80be9012b7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
