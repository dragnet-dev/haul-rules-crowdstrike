// Dragnet [Ransomware]: dragnet-ransomware-2023-0131 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: d83ab5e9-09bc-5691-a2e4-eb05699d2ac3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
