// Dragnet [Ransomware]: dragnet-ransomware-2021-0635 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: d25c32ff-3a5f-5eda-a6ef-0e04df3c0f43

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
