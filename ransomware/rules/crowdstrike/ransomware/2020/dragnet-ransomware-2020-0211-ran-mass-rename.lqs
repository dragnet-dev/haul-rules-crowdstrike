// Dragnet [Ransomware]: dragnet-ransomware-2020-0211 — Mass File Rename (ragnarlocker)
// Status: deprecated | Level: high | ID: 0fc1c7a2-85cb-5ca1-97ea-882147c0ef62

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
