// Dragnet [Ransomware]: dragnet-ransomware-2025-4184 — Mass File Rename (play)
// Status: experimental | Level: high | ID: fdbefadb-b196-5490-94c4-d62de4ecd14c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
