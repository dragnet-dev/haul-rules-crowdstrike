// Dragnet [Ransomware]: dragnet-ransomware-2025-1809 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 99816f44-b248-5f34-b800-4a6b00682efe

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
