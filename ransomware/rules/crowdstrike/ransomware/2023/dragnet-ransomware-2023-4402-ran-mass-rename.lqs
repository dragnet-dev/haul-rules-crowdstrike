// Dragnet [Ransomware]: dragnet-ransomware-2023-4402 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 07433e2f-0fe1-5748-9d48-757cd0901646

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
