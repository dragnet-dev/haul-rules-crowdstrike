// Dragnet [Ransomware]: dragnet-ransomware-2024-5713 — Mass File Rename (meow)
// Status: experimental | Level: high | ID: d27b6394-a9e3-5c2c-aca1-2e806aabc4a4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
