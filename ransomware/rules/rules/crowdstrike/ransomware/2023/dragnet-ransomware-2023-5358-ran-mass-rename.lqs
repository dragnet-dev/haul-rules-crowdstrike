// Dragnet [Ransomware]: dragnet-ransomware-2023-5358 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: ff35efa0-beba-58b9-aae2-e27235bbe9c4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
