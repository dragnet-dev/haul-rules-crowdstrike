// Dragnet [Ransomware]: dragnet-ransomware-2025-0703 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: b503fbbe-de25-5cf4-ae58-3df37f590fe2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
