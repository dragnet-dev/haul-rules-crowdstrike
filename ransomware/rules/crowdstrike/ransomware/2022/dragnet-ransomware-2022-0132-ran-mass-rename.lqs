// Dragnet [Ransomware]: dragnet-ransomware-2022-0132 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 7d5a705b-e0f1-5cd5-9700-7f960faefb81

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
