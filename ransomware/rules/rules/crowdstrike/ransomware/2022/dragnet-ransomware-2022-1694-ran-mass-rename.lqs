// Dragnet [Ransomware]: dragnet-ransomware-2022-1694 — Mass File Rename (ragnarlocker)
// Status: deprecated | Level: high | ID: b9aae1e7-5543-5f74-9859-ecc92588d8a7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
