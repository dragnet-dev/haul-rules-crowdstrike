// Dragnet [Ransomware]: dragnet-ransomware-2022-2619 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: d094bd7c-aa20-56f4-b2d9-f17235ab4704

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
