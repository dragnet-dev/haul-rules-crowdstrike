// Dragnet [Ransomware]: dragnet-ransomware-2022-2680 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: a005ac9b-a889-5ac0-bf62-db6f676b63c1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
