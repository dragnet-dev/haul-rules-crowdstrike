// Dragnet [Ransomware]: dragnet-ransomware-2026-3108 — Mass File Rename (tridentlocker)
// Status: test | Level: high | ID: b0fca718-f34b-5195-8bc9-6fb0877ec6fc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
