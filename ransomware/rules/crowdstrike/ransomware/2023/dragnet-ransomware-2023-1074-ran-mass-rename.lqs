// Dragnet [Ransomware]: dragnet-ransomware-2023-1074 — Mass File Rename (royal)
// Status: experimental | Level: high | ID: a43d3824-80e9-5fec-b6e7-e770c6a04e61

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
