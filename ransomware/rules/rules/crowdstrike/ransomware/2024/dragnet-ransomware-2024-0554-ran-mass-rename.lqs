// Dragnet [Ransomware]: dragnet-ransomware-2024-0554 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 755080d2-4abd-5daf-b337-1c6365f49627

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
