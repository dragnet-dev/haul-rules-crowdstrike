// Dragnet [Ransomware]: dragnet-ransomware-2025-2093 — Mass File Rename (SilentRansomGroup)
// Status: deprecated | Level: high | ID: fcf96df3-9bb4-5f49-aa47-723178ce1694

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
