// Dragnet [Ransomware]: dragnet-ransomware-2026-3188 — Mass File Rename (dragonforce)
// Status: stable | Level: high | ID: 2b89b354-0b42-55a0-bf6f-53ec698a7e0d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
