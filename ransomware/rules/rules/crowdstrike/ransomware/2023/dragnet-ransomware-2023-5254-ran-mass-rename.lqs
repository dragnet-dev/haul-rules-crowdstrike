// Dragnet [Ransomware]: dragnet-ransomware-2023-5254 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 52e0c67f-aa80-51e2-90b1-1f25cac739af

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
