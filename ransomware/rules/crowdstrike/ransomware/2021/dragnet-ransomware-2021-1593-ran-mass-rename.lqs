// Dragnet [Ransomware]: dragnet-ransomware-2021-1593 — Mass File Rename (revil)
// Status: deprecated | Level: high | ID: 7ece24d2-fc6e-5d74-94fd-dd7693162a89

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
