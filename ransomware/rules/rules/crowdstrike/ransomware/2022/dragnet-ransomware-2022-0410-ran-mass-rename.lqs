// Dragnet [Ransomware]: dragnet-ransomware-2022-0410 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: bfaf93d5-4851-52ce-9699-ca9705c67494

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
