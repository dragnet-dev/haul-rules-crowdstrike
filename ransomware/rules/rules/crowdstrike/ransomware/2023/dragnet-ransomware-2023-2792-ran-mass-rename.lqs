// Dragnet [Ransomware]: dragnet-ransomware-2023-2792 — Mass File Rename (malas)
// Status: experimental | Level: high | ID: 18c6f2c5-9ded-502f-b898-6b780c0840ae

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
