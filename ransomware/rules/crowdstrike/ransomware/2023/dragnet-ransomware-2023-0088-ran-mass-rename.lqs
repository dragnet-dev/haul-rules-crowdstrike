// Dragnet [Ransomware]: dragnet-ransomware-2023-0088 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 70834a43-c299-5e49-bd36-58849899cd25

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
