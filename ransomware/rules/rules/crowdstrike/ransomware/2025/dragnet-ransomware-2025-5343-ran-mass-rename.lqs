// Dragnet [Ransomware]: dragnet-ransomware-2025-5343 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 5ed0acf9-b735-53c1-b9cd-c7270c26a8a4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
