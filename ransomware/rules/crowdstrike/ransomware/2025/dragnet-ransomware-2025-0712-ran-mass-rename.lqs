// Dragnet [Ransomware]: dragnet-ransomware-2025-0712 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: e9a2d424-3d87-5099-8f0b-b6a18439c1d9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
