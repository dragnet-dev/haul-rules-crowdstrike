// Dragnet [Ransomware]: dragnet-ransomware-2024-2758 — Mass File Rename (knight)
// Status: experimental | Level: high | ID: 56105447-2369-51ca-9043-6d37b6e4dfbf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
