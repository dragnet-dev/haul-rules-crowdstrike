// Dragnet [Ransomware]: dragnet-ransomware-2024-5736 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 3ea443a8-35f2-5e00-a493-1213c035db6a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
