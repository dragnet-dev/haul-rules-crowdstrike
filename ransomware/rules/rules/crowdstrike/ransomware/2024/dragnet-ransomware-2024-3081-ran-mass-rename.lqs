// Dragnet [Ransomware]: dragnet-ransomware-2024-3081 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 304fdbaa-6ce4-5db5-adb3-450c3c0d36cb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
