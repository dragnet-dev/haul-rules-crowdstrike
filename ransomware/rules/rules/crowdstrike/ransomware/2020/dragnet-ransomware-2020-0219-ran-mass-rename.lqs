// Dragnet [Ransomware]: dragnet-ransomware-2020-0219 — Mass File Rename (doppelpaymer)
// Status: deprecated | Level: high | ID: f328b046-48e9-5d0b-9610-83623686e999

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
