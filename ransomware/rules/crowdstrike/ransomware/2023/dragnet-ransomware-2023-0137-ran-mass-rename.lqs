// Dragnet [Ransomware]: dragnet-ransomware-2023-0137 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: aba67fef-b2e8-5bdb-821c-3f905c8dbfa7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
