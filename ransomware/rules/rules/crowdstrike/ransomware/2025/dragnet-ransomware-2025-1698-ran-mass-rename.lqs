// Dragnet [Ransomware]: dragnet-ransomware-2025-1698 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: 2e0a3d55-6691-561f-be59-f62fe8b244ee

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
