// Dragnet [Ransomware]: dragnet-ransomware-2025-0738 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 70571f67-ee4c-5f96-8c57-65ead7b0df4d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
