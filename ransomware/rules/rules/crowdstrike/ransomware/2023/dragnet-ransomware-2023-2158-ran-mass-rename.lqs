// Dragnet [Ransomware]: dragnet-ransomware-2023-2158 — Mass File Rename (play)
// Status: experimental | Level: high | ID: feecac86-35ce-5618-ab93-aa01e39435f5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
