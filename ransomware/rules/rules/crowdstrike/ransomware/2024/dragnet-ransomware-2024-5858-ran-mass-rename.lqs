// Dragnet [Ransomware]: dragnet-ransomware-2024-5858 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: 5ad6b1fe-3942-57f9-b6cd-356b25d4876e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
