// Dragnet [Ransomware]: dragnet-ransomware-2023-3073 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 32b8517f-d56e-56bf-992e-06086e41782d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
