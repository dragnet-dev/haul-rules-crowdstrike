// Dragnet [Ransomware]: dragnet-ransomware-2022-0443 — Mass File Rename (vicesociety)
// Status: deprecated | Level: high | ID: 09b30b5c-beec-5d57-8bc5-2abf20f59a2e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
