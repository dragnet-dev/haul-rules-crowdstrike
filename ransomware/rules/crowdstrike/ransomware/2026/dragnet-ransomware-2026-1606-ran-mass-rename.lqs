// Dragnet [Ransomware]: dragnet-ransomware-2026-1606 — Mass File Rename (nightspire)
// Status: deprecated | Level: high | ID: 723060a4-a0c8-5bb0-a85c-77ed10fbfbc6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
