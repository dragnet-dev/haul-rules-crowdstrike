// Dragnet [Ransomware]: dragnet-ransomware-2023-1558 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 76b48ad8-1489-5e0b-b2e6-e60a4afec83c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
