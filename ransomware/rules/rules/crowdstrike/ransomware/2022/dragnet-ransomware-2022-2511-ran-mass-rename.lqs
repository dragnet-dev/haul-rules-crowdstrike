// Dragnet [Ransomware]: dragnet-ransomware-2022-2511 — Mass File Rename (kelvinsecurity)
// Status: deprecated | Level: high | ID: 12f18d80-2816-50dc-a418-ef5979ef605c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
