// Dragnet [Ransomware]: dragnet-ransomware-2025-1153 — Mass File Rename (stormous)
// Status: experimental | Level: high | ID: e21378e3-0930-5635-83a6-f253e004e8a2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
