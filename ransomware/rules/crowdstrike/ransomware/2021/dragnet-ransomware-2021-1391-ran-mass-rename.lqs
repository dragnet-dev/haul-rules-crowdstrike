// Dragnet [Ransomware]: dragnet-ransomware-2021-1391 — Mass File Rename (avaddon)
// Status: deprecated | Level: high | ID: 67acebd2-f66a-548c-bb8f-9472f094cefb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
