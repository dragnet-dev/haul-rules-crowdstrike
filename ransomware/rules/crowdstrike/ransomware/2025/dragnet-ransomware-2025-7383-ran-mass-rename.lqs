// Dragnet [Ransomware]: dragnet-ransomware-2025-7383 — Mass File Rename (blackshrantac)
// Status: experimental | Level: high | ID: a31b3ff9-c140-5591-940f-093d271a826a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
