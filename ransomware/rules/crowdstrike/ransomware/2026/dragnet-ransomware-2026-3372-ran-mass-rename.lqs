// Dragnet [Ransomware]: dragnet-ransomware-2026-3372 — Mass File Rename (lockbit5)
// Status: stable | Level: high | ID: 8862cb34-4fa8-5ea9-a0e2-0badcab51c32

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
