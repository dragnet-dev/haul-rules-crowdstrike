// Dragnet [Ransomware]: dragnet-ransomware-2024-2822 — Mass File Rename (meow)
// Status: experimental | Level: high | ID: ead45989-c92d-5312-8266-2468ff4b6c61

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
