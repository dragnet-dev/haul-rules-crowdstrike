// Dragnet [Ransomware]: dragnet-ransomware-2024-5195 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 5ba6c576-bb02-581d-9fec-4eaa1aa774e2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
