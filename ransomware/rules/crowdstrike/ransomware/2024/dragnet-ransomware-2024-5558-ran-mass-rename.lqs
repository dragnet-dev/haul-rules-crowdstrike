// Dragnet [Ransomware]: dragnet-ransomware-2024-5558 — Mass File Rename (ElDorado)
// Status: experimental | Level: high | ID: 9985dd11-476b-5e0e-8f84-7f5ef50fa5a4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
