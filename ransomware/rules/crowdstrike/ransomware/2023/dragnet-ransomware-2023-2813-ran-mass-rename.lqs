// Dragnet [Ransomware]: dragnet-ransomware-2023-2813 — Mass File Rename (malas)
// Status: experimental | Level: high | ID: 277cf58b-412a-5cb9-90aa-2d06516a37ab

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
