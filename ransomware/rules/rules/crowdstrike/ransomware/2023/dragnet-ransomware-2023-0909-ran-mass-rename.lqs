// Dragnet [Ransomware]: dragnet-ransomware-2023-0909 — Mass File Rename (raworld)
// Status: experimental | Level: high | ID: 2ed82c1b-ad1c-5fc5-9425-be9b400b6e56

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
