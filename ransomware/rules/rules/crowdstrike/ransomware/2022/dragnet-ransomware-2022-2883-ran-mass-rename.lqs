// Dragnet [Ransomware]: dragnet-ransomware-2022-2883 — Mass File Rename (leaktheanalyst)
// Status: deprecated | Level: high | ID: 749a9435-a3a3-5b84-b6e0-bc88eaef67b5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
