// Dragnet [Ransomware]: dragnet-ransomware-2023-3846 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 5f8468e6-2eb2-5184-b3ea-266e2ecb888d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
