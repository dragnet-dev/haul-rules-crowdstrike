// Dragnet [Ransomware]: dragnet-ransomware-2026-3515 — Mass File Rename (sinobi)
// Status: stable | Level: high | ID: 4b6abc58-0cce-5edd-9b17-6363b6035d30

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
