// Dragnet [Ransomware]: dragnet-ransomware-2025-6046 — Mass File Rename (nitrogen)
// Status: experimental | Level: high | ID: dd4484d4-5115-589d-8650-f66c26da4306

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
