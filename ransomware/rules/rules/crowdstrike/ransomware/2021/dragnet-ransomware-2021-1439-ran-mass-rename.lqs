// Dragnet [Ransomware]: dragnet-ransomware-2021-1439 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 5da71eeb-0a26-5a4d-a8c3-51c812d4d2d3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
