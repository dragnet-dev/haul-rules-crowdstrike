// Dragnet [Ransomware]: dragnet-ransomware-2021-1425 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 68213259-e4ab-5787-a598-9bd29bb1167b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
