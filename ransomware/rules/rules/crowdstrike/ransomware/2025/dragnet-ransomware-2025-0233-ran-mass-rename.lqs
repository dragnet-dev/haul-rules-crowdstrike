// Dragnet [Ransomware]: dragnet-ransomware-2025-0233 — Mass File Rename (sinobi)
// Status: experimental | Level: high | ID: 06d3886a-491a-51f2-b25f-a52ed93cecdd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
