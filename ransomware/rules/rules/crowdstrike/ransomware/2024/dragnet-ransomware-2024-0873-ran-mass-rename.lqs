// Dragnet [Ransomware]: dragnet-ransomware-2024-0873 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: f79ada19-7008-5fba-9455-fe7d43979a17

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
