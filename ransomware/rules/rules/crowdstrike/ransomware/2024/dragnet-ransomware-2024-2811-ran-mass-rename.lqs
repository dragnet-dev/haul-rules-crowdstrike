// Dragnet [Ransomware]: dragnet-ransomware-2024-2811 — Mass File Rename (meow)
// Status: experimental | Level: high | ID: 32e2fd0b-bc51-513a-90b5-c186e43bfd67

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
