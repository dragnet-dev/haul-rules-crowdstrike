// Dragnet [Ransomware]: dragnet-ransomware-2023-1053 — Mass File Rename (threeam)
// Status: experimental | Level: high | ID: eb18ce47-6b90-5592-8ddc-181b4693331e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
