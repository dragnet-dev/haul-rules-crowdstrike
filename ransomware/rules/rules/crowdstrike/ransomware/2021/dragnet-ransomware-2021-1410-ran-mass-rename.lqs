// Dragnet [Ransomware]: dragnet-ransomware-2021-1410 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: c84bca89-b0bb-5066-add7-7eaabc071608

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
