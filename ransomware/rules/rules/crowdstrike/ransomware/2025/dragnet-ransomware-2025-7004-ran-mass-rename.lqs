// Dragnet [Ransomware]: dragnet-ransomware-2025-7004 — Mass File Rename (devman)
// Status: deprecated | Level: high | ID: 5f18797a-421c-5eaf-808d-b15a387343d2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
