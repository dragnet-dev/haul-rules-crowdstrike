// Dragnet [Ransomware]: dragnet-ransomware-2022-0366 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 06c378ab-7f09-5014-8753-8fa8bab12013

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
