// Dragnet [Ransomware]: dragnet-ransomware-2025-1900 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 359807e3-49e6-5f8f-86ce-f2d654d0ebdf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
