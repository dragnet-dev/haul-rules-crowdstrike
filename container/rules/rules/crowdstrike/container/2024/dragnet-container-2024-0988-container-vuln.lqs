// Dragnet [Container]: dragnet-container-2024-0988 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: a3cc9366-a9fe-5287-8597-34bea35fd280

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *ubuntu:20.04* OR ImageFileName = *ubuntu:20.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
