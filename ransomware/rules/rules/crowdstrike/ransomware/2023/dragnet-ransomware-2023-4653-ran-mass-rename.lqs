// Dragnet [Ransomware]: dragnet-ransomware-2023-4653 — Mass File Rename (snatch)
// Status: experimental | Level: high | ID: 8dcc283a-55d5-5b8a-a2a1-b1f8e5f5ea57

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
