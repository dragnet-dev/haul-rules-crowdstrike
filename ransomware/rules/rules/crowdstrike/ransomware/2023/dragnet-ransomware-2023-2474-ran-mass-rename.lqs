// Dragnet [Ransomware]: dragnet-ransomware-2023-2474 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: e9caa795-e8ee-536e-a0b2-55e9d9896bba

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
