// Dragnet [Ransomware]: dragnet-ransomware-2025-6570 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: a1def10c-79b7-58d8-9c59-1f3977d675c8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
