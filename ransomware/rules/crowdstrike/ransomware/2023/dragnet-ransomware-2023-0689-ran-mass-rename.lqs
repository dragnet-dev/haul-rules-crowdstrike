// Dragnet [Ransomware]: dragnet-ransomware-2023-0689 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 1da66887-eda4-59ca-b116-c2575b13e764

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
