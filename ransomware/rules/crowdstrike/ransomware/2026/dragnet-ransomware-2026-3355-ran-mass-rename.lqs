// Dragnet [Ransomware]: dragnet-ransomware-2026-3355 — Mass File Rename (payload)
// Status: stable | Level: high | ID: a26d7aac-2c2b-5b33-af02-3dbd4c418e38

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
