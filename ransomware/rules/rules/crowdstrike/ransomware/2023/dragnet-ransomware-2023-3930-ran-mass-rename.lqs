// Dragnet [Ransomware]: dragnet-ransomware-2023-3930 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: f2b688a7-8398-56df-96fc-7b0405646f13

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
