// Dragnet [Ransomware]: dragnet-ransomware-2022-2093 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 5489edfe-89fc-5302-9278-3031d0acb6c7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
