// Dragnet [Ransomware]: dragnet-ransomware-2026-2411 — Mass File Rename (payoutsking)
// Status: stable | Level: high | ID: 30d607ab-cb52-504e-a425-3aed191a021a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
