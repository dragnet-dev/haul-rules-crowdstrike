// Dragnet [Ransomware]: dragnet-ransomware-2021-0451 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: e919f618-ddc5-57ee-84bc-06ff0db886a9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
