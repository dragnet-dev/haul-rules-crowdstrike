// Dragnet [Ransomware]: dragnet-ransomware-2025-3894 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: ab2f5f9f-a4d1-5012-b101-c43fbcdef3d0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
