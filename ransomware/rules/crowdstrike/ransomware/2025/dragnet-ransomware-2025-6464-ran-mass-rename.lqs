// Dragnet [Ransomware]: dragnet-ransomware-2025-6464 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: ef9ded56-cc42-5128-b326-1ad6a941874c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
