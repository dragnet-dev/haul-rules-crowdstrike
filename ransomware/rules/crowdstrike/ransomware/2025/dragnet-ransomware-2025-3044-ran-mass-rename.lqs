// Dragnet [Ransomware]: dragnet-ransomware-2025-3044 — Mass File Rename (spacebears)
// Status: experimental | Level: high | ID: ec175d64-2c44-55b6-b147-b93b3a856494

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
