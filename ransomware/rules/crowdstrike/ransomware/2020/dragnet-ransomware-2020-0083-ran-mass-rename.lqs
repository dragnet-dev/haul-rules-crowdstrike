// Dragnet [Ransomware]: dragnet-ransomware-2020-0083 — Mass File Rename (maze)
// Status: deprecated | Level: high | ID: ea98b544-4b3c-573b-aa62-ebe5b8d69710

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
