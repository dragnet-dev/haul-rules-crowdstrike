// Dragnet [Ransomware]: dragnet-ransomware-2023-1259 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 99aea83c-fe52-524d-89f9-0326a4b64bc4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
