// Dragnet [Ransomware]: dragnet-ransomware-2022-0534 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: b63c88e6-5013-5ea6-8fdd-c4ed8f4f6d7f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
