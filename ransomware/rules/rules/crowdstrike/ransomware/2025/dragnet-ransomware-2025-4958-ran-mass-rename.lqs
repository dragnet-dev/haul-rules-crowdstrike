// Dragnet [Ransomware]: dragnet-ransomware-2025-4958 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: d146a362-97af-5432-b3ef-9a1f1e44f970

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
