// Dragnet [Ransomware]: dragnet-ransomware-2021-1351 — Mass File Rename (ransomexx)
// Status: deprecated | Level: high | ID: b53286e9-558c-56bb-b480-722f2234bcc5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
