// Dragnet [Ransomware]: dragnet-ransomware-2023-2671 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 74187c75-559e-522d-8e13-d0cbd219286e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
