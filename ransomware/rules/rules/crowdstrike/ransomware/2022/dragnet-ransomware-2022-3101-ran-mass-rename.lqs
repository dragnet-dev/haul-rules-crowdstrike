// Dragnet [Ransomware]: dragnet-ransomware-2022-3101 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 42b83885-7846-577d-bc3e-5eecf3132b84

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
