// Dragnet [Ransomware]: dragnet-ransomware-2024-5609 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 75526222-bc9c-5cfb-97f7-8f99e87ded32

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
