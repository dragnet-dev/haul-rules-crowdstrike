// Dragnet [Ransomware]: dragnet-ransomware-2022-2549 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: e179e595-f328-5cf3-9997-1fca9b1481eb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
