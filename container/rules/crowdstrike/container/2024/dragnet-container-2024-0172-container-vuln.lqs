// Dragnet [Container]: dragnet-container-2024-0172 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 615add1a-3f37-5a19-b422-3d1a1c9b0db7

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:7*)
| table([timestamp, ComputerName])
| limit(1000)
