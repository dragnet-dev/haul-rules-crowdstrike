// Dragnet [Ransomware]: dragnet-ransomware-2026-2776 — Mass File Rename (everest)
// Status: stable | Level: high | ID: 72ce8f17-987a-5588-966c-f9d169c4ec07

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
