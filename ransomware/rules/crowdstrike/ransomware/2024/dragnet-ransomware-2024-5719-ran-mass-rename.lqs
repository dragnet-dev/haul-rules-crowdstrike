// Dragnet [Ransomware]: dragnet-ransomware-2024-5719 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: d2cfb93c-84ed-53ef-8bf6-7264c7bc6c67

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
