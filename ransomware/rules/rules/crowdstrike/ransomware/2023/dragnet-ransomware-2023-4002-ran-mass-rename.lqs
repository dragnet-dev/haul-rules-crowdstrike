// Dragnet [Ransomware]: dragnet-ransomware-2023-4002 — Mass File Rename (underground)
// Status: experimental | Level: high | ID: 290b2075-8337-5d90-b1c0-107da70153e1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
