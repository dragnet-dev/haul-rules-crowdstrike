// Dragnet [Ransomware]: dragnet-ransomware-2022-1783 — Mass File Rename (play)
// Status: deprecated | Level: high | ID: 7b998e87-33d5-565e-9e34-bd7211e7c26d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
