// Dragnet [Ransomware]: dragnet-ransomware-2023-3135 — Mass File Rename (cloak)
// Status: experimental | Level: high | ID: 5f8b2b7e-a8fe-5234-9ecd-6ff8dfc53db4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
