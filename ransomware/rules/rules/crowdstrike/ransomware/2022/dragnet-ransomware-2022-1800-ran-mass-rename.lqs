// Dragnet [Ransomware]: dragnet-ransomware-2022-1800 — Mass File Rename (ragnarlocker)
// Status: deprecated | Level: high | ID: cfd28ebe-5b9e-5212-a66e-bfc7b00f9481

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
