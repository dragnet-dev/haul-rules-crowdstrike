// Dragnet [Container]: dragnet-container-2024-1468 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 94f2f821-0588-5649-8612-754a950fc596

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:8* OR ImageFileName = *debian:9* OR ImageFileName = *ubuntu:16.04-ESM* OR ImageFileName = *ubuntu:18.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
