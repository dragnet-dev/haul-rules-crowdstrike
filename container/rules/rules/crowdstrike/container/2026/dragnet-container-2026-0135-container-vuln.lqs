// Dragnet [Container]: dragnet-container-2026-0135 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 2ff5a61c-e105-5276-9482-b8afd97b4605

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:9*)
| table([timestamp, ComputerName])
| limit(1000)
