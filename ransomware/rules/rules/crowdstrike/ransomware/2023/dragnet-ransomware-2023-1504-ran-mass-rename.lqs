// Dragnet [Ransomware]: dragnet-ransomware-2023-1504 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 016a74b6-294e-519a-a9a0-0d62a5d746f0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
