// Dragnet [Ransomware]: dragnet-ransomware-2024-5102 — Mass File Rename (dragonforce)
// Status: deprecated | Level: high | ID: 133e5049-e799-50f7-a2aa-6414b0b86639

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
