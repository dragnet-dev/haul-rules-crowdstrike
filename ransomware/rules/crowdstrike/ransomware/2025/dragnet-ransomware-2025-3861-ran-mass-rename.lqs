// Dragnet [Ransomware]: dragnet-ransomware-2025-3861 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 225a4446-7cd5-5fdb-8834-eaa2475a886c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
