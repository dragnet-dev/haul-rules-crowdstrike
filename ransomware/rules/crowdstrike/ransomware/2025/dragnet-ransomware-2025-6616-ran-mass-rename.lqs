// Dragnet [Ransomware]: dragnet-ransomware-2025-6616 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: ad8f528f-1364-5949-b9e0-aa9fdcf0bc07

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
