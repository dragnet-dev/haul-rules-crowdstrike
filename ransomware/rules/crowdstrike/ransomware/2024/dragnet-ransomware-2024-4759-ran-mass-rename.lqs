// Dragnet [Ransomware]: dragnet-ransomware-2024-4759 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 4c446ea4-be2b-57c8-902f-51d798bd71e0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
