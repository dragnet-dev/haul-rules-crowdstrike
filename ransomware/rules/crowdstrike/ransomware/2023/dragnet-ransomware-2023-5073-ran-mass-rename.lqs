// Dragnet [Ransomware]: dragnet-ransomware-2023-5073 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: 5c996d6e-97fd-5864-83e9-5b2f18fbe276

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
