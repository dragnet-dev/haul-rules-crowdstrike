// Dragnet [Ransomware]: dragnet-ransomware-2026-1612 — Mass File Rename (SilentRansomGroup)
// Status: deprecated | Level: high | ID: 2fc84b7c-b3e1-5892-a4ac-7cd8a760d778

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
