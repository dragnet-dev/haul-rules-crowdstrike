// Dragnet [Ransomware]: dragnet-ransomware-2026-1662 — Mass File Rename (lockbit5)
// Status: test | Level: high | ID: 109dc21c-a3dd-5650-b3f4-e40f8b4f2612

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
