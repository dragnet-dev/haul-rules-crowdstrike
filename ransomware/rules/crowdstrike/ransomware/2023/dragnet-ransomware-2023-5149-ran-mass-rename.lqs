// Dragnet [Ransomware]: dragnet-ransomware-2023-5149 — Mass File Rename (losttrust)
// Status: deprecated | Level: high | ID: 37afb831-b3f6-5494-99f9-fbeb8e4821bb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
