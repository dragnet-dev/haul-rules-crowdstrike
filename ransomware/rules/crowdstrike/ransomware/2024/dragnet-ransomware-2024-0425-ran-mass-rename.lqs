// Dragnet [Ransomware]: dragnet-ransomware-2024-0425 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 0d472be9-90ca-58f3-a4e4-ce78e08ad3ce

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
