// Dragnet [Ransomware]: dragnet-ransomware-2022-0318 — Mass File Rename (ransomexx)
// Status: experimental | Level: high | ID: c3b485f4-4fbb-5a37-b10b-748274a9f943

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
