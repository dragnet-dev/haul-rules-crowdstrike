// Dragnet [Ransomware]: dragnet-ransomware-2024-2650 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: f894e4d4-62ad-5869-b888-0fd5cc07b117

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
