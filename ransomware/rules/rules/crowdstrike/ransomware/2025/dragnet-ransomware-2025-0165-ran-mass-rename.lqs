// Dragnet [Ransomware]: dragnet-ransomware-2025-0165 — Mass File Rename (ransomhouse)
// Status: experimental | Level: high | ID: ef09f852-58bf-5059-814e-65182776c0e8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
