// Dragnet [Ransomware]: dragnet-ransomware-2025-3360 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 879175df-fb8a-597f-944a-427f8f873bea

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
