// Dragnet [Ransomware]: dragnet-ransomware-2025-0654 — Mass File Rename (blacklock)
// Status: experimental | Level: high | ID: f883b7c8-b802-53cb-b727-0c5b9d8891a7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
