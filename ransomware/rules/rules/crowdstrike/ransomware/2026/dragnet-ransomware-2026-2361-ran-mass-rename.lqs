// Dragnet [Ransomware]: dragnet-ransomware-2026-2361 — Mass File Rename (lockbit5)
// Status: stable | Level: high | ID: 3e4e8ad8-6cc6-5807-b107-abd99889a8cf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
