// Dragnet [Container]: dragnet-container-2026-2485 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: e1e895ca-52e2-5cf2-8b38-925e270c26a8

#event_simpleName=*
| (ImageFileName = *alpine edge:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
