// Dragnet [Ransomware]: dragnet-ransomware-2021-0633 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 6dd660e7-8cbf-5588-9714-afc520161765

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
