// Dragnet [Ransomware]: dragnet-ransomware-2023-3627 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 0f4e1dbe-9c0c-5221-a21f-a162d19a99bc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
