// Dragnet [Ransomware]: dragnet-ransomware-2025-1570 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: f93f2a99-427c-52a7-8276-e40619b1cbad

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
