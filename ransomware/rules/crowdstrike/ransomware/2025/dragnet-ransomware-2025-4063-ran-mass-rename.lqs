// Dragnet [Ransomware]: dragnet-ransomware-2025-4063 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: 613607a9-e0d7-5e45-9460-a3ae034b50c1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
