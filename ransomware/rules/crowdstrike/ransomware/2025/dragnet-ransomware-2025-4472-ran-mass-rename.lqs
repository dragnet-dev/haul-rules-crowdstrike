// Dragnet [Ransomware]: dragnet-ransomware-2025-4472 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 88c2d0e7-f75c-556f-a824-62be7029a3f2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
