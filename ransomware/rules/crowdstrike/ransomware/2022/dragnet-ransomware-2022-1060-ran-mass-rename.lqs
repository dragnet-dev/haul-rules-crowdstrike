// Dragnet [Ransomware]: dragnet-ransomware-2022-1060 — Mass File Rename (stormous)
// Status: deprecated | Level: high | ID: 73eb3382-024b-51f0-96bd-0d2beaf15314

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
