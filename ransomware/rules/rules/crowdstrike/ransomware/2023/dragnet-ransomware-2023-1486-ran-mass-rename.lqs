// Dragnet [Ransomware]: dragnet-ransomware-2023-1486 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: ff10de8b-2888-5f52-b4ba-129ab53965c4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
