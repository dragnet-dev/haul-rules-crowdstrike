// Dragnet [Container]: dragnet-container-2024-1398 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 1131eb62-9004-5989-b5b8-ab67299ce51d

#event_simpleName=*
| (ImageFileName = *debian:14* OR ImageFileName = *photon os:1.0* OR ImageFileName = *photon os:2.0* OR ImageFileName = *photon os:3.0* OR ImageFileName = *redhat/ubi9:*)
| table([timestamp, ComputerName])
| limit(1000)
