// Dragnet [Ransomware]: dragnet-ransomware-2024-1225 — Mass File Rename (dAn0n)
// Status: experimental | Level: high | ID: b99d2304-d0ef-5692-9654-9a222cb9325a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
