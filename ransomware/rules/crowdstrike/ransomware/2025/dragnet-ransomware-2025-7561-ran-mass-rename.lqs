// Dragnet [Ransomware]: dragnet-ransomware-2025-7561 — Mass File Rename (nova)
// Status: experimental | Level: high | ID: d86cc9ad-bcf4-5e1a-88f5-f3785b83a26d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
