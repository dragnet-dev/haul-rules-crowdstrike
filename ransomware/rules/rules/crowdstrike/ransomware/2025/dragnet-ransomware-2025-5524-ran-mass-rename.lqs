// Dragnet [Ransomware]: dragnet-ransomware-2025-5524 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 3d7fcb92-c759-5962-81fd-e51536fd3006

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
