// Dragnet [Ransomware]: dragnet-ransomware-2025-6964 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 74f936c6-2161-5b4a-8025-9d57eda7c7ac

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
