// Dragnet [Ransomware]: dragnet-ransomware-2024-2992 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 22f6da1b-305a-5f28-8ee8-05d514cd4772

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
