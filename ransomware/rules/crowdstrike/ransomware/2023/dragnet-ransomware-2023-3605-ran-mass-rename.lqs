// Dragnet [Ransomware]: dragnet-ransomware-2023-3605 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: ffd4beeb-22ab-5238-80de-ed14cb0a0d6d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
