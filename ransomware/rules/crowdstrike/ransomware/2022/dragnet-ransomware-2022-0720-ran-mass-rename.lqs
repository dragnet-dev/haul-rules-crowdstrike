// Dragnet [Ransomware]: dragnet-ransomware-2022-0720 — Mass File Rename (cuba)
// Status: deprecated | Level: high | ID: f3349091-eee9-5528-a133-92f76b32de5c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
