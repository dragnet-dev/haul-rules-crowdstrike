// Dragnet [Ransomware]: dragnet-ransomware-2023-3459 — Mass File Rename (play)
// Status: experimental | Level: high | ID: ba7e28e5-a27c-5509-8d8a-025371ee56e6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
