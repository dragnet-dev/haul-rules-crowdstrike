// Dragnet [Ransomware]: dragnet-ransomware-2024-3953 — Mass File Rename (SilentRansomGroup)
// Status: deprecated | Level: high | ID: a104356b-d042-523f-bdfa-7edbf67671ec

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
