// Dragnet [Ransomware]: dragnet-ransomware-2022-2408 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 56320c93-2e3f-5563-8872-b714e329ea09

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
