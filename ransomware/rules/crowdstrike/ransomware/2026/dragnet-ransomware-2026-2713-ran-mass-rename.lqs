// Dragnet [Ransomware]: dragnet-ransomware-2026-2713 — Mass File Rename (dragonforce)
// Status: test | Level: high | ID: 4f662c3a-58c7-5bed-9ed2-a30aa1be086a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
