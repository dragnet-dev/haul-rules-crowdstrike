// Dragnet [Ransomware]: dragnet-ransomware-2025-2544 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: a52d3c5e-cf40-509c-af16-2fd2ed2baf6c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
