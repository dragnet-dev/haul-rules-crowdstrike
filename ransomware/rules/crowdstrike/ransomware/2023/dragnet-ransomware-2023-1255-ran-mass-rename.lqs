// Dragnet [Ransomware]: dragnet-ransomware-2023-1255 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 1b1909e3-0b3b-5c22-b1bd-617369869c67

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
