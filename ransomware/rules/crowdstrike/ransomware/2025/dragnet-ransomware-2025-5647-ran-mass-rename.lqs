// Dragnet [Ransomware]: dragnet-ransomware-2025-5647 — Mass File Rename (worldleaks)
// Status: experimental | Level: high | ID: d79ae29d-0987-5792-903f-d41c7207a4b7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
