// Dragnet [Ransomware]: dragnet-ransomware-2023-4703 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 5f2ac842-c0c8-5f1e-affb-bd713b8a1de2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
