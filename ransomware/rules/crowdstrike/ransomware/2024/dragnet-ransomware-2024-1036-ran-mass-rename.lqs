// Dragnet [Ransomware]: dragnet-ransomware-2024-1036 — Mass File Rename (ransomhouse)
// Status: experimental | Level: high | ID: a3cdc092-ff14-59f8-9742-a3b60df254d3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
