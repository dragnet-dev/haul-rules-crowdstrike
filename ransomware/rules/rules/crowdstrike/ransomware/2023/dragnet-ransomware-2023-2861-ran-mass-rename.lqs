// Dragnet [Ransomware]: dragnet-ransomware-2023-2861 — Mass File Rename (malas)
// Status: experimental | Level: high | ID: 868131ad-7dba-5088-aef5-eacdf0e3ff83

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
