// Dragnet [Ransomware]: dragnet-ransomware-2023-2110 — Mass File Rename (rhysida)
// Status: experimental | Level: high | ID: a399eb0f-c51d-515c-87f0-cf0314d5e318

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
