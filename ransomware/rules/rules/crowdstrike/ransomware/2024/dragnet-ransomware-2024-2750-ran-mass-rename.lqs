// Dragnet [Ransomware]: dragnet-ransomware-2024-2750 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 47e5a186-e805-5037-b25e-786640d65f3b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
