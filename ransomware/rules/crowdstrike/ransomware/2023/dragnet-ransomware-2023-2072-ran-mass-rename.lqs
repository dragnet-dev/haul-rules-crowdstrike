// Dragnet [Ransomware]: dragnet-ransomware-2023-2072 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: ec6ed4c0-0ed8-5df9-b992-df63f4c92b41

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
