// Dragnet [Container]: dragnet-container-2026-1545 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 8086acb1-4870-5b89-a2ba-113146ec9b42

#event_simpleName=*
| (ImageFileName = *amazonlinux:1* OR ImageFileName = *debian:7* OR ImageFileName = *debian:8* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:14.04* OR ImageFileName = *ubuntu:14.04-ESM* OR ImageFileName = *ubuntu:16.04* OR ImageFileName = *ubuntu:16.04-ESM* OR ImageFileName = *ubuntu:16.10* OR ImageFileName = *ubuntu:17.04* OR ImageFileName = *ubuntu:17.10* OR ImageFileName = *ubuntu:18.04* OR ImageFileName = *ubuntu:18.04-ESM* OR ImageFileName = *ubuntu:18.10*)
| table([timestamp, ComputerName])
| limit(1000)
