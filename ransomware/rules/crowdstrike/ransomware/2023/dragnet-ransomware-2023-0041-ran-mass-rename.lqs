// Dragnet [Ransomware]: dragnet-ransomware-2023-0041 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 373a57da-14c5-5cb3-8466-6af2c0a1f407

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
