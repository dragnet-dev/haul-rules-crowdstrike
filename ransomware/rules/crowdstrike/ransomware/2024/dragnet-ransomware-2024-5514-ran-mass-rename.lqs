// Dragnet [Ransomware]: dragnet-ransomware-2024-5514 — Mass File Rename (flocker)
// Status: experimental | Level: high | ID: 620b0095-dea1-5b4d-b7c8-90c064d20a31

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
