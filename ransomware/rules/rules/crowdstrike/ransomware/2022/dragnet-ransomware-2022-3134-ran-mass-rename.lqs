// Dragnet [Ransomware]: dragnet-ransomware-2022-3134 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 091887b7-ab4e-5568-aed9-524ea0aa4b0f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
