// Dragnet [Container]: dragnet-container-2025-0204 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 3522831f-5787-532e-adb9-ec4d2463f471

#event_simpleName=*
| (ImageFileName = *amazonlinux:2* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
