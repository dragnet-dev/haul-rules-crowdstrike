// Dragnet [Ransomware]: dragnet-ransomware-2022-2518 — Mass File Rename (cheers)
// Status: deprecated | Level: high | ID: bf3398ae-3e69-5970-8bf6-583ccaa3daf0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
