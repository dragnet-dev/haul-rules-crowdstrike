// Dragnet [Ransomware]: dragnet-ransomware-2021-1503 — Mass File Rename (cuba)
// Status: deprecated | Level: high | ID: e744f396-0dd1-5df1-815e-091c26afc0a9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
