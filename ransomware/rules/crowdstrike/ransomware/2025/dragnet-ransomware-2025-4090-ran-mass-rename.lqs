// Dragnet [Ransomware]: dragnet-ransomware-2025-4090 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 9c1c4589-40e0-5dc3-a732-83dc041810d6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
