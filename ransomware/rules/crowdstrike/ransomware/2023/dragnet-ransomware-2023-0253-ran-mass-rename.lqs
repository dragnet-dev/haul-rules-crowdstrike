// Dragnet [Ransomware]: dragnet-ransomware-2023-0253 — Mass File Rename (noescape)
// Status: experimental | Level: high | ID: 333658b8-ad17-572b-8dee-ebe07d595c35

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
