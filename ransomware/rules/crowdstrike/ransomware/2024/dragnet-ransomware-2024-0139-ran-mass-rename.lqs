// Dragnet [Ransomware]: dragnet-ransomware-2024-0139 — Mass File Rename (ransomhouse)
// Status: experimental | Level: high | ID: 67750824-c9ac-5f9d-bfe4-1a931a47117b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
