// Dragnet [Ransomware]: dragnet-ransomware-2025-2190 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: 62e7f42d-5c84-5c11-b8e4-a28077e931c1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
