// Dragnet [Ransomware]: dragnet-ransomware-2022-0937 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 0952e707-a193-5a96-a0c2-df41f0639bad

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
