// Dragnet [Ransomware]: dragnet-ransomware-2025-7427 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 39fce3eb-6d18-5b1e-a36c-3fafae8677d2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
