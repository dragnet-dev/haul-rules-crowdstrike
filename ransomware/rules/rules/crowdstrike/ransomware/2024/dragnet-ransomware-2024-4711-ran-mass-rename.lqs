// Dragnet [Ransomware]: dragnet-ransomware-2024-4711 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 6e2f6fe2-5578-56da-a8df-0bd39d870abd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
