// Dragnet [Ransomware]: dragnet-ransomware-2025-3889 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: bded634c-d35d-5437-a854-e6f20258383d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
