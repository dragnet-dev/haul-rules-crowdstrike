// Dragnet [Ransomware]: dragnet-ransomware-2025-1251 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 9dde6a6f-ac11-56b2-8327-bff9b096fdb1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
