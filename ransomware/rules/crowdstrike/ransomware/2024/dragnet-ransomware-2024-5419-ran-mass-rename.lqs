// Dragnet [Ransomware]: dragnet-ransomware-2024-5419 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: 4cc0c3db-c62b-5193-904b-70e9b4f0a127

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
