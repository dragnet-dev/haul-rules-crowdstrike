// Dragnet [Ransomware]: dragnet-ransomware-2022-0323 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 2ecf94ae-7e43-5dbf-9aac-c6ca0edddbd3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
