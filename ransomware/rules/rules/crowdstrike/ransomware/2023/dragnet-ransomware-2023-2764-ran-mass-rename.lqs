// Dragnet [Ransomware]: dragnet-ransomware-2023-2764 — Mass File Rename (malas)
// Status: experimental | Level: high | ID: aafa91de-b692-5cda-a122-f469818c805d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
