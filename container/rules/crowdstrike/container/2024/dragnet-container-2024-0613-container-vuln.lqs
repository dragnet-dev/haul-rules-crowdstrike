// Dragnet [Container]: dragnet-container-2024-0613 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 49d94efe-8ff2-54b6-8aa8-dfcb85959311

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:7* OR ImageFileName = *debian:8* OR ImageFileName = *debian:9* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:14.04*)
| table([timestamp, ComputerName])
| limit(1000)
