// Dragnet [Ransomware]: dragnet-ransomware-2026-1883 — Mass File Rename (genesis)
// Status: stable | Level: high | ID: c22e8c49-862a-5541-a625-2d93a05cbebf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
