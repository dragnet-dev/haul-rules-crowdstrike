// Dragnet [Ransomware]: dragnet-ransomware-2022-0777 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: fac1091f-8a27-5632-a712-5abf8d51c197

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
