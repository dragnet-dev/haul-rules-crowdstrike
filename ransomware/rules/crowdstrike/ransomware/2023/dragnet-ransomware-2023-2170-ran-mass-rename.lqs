// Dragnet [Ransomware]: dragnet-ransomware-2023-2170 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: ec0470b8-f670-51d3-82c8-03ddf72c3422

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
