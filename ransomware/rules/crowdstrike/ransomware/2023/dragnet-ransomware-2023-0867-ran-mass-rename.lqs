// Dragnet [Ransomware]: dragnet-ransomware-2023-0867 — Mass File Rename (trigona)
// Status: experimental | Level: high | ID: 684ce82d-540d-5304-b2d8-12b88163a335

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
