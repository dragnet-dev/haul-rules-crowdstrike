// Dragnet [Ransomware]: dragnet-ransomware-2023-3612 — Mass File Rename (dragonforce)
// Status: deprecated | Level: high | ID: 7de38b7c-e4ef-530e-b5ed-34c9a6788b1f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
