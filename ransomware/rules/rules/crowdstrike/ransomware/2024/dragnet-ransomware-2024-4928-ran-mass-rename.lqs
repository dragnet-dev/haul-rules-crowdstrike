// Dragnet [Ransomware]: dragnet-ransomware-2024-4928 — Mass File Rename (malekteam)
// Status: experimental | Level: high | ID: e9156958-cc13-55c1-a3d1-8289989bde91

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
