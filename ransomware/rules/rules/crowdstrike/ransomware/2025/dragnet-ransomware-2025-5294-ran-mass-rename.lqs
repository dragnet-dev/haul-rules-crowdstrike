// Dragnet [Ransomware]: dragnet-ransomware-2025-5294 — Mass File Rename (lockbit5)
// Status: experimental | Level: high | ID: 4bfbae1f-c4d2-5038-b108-d80aac8b08af

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
