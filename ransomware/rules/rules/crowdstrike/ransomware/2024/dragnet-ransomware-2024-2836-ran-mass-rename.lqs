// Dragnet [Ransomware]: dragnet-ransomware-2024-2836 — Mass File Rename (apt73)
// Status: experimental | Level: high | ID: 2b7d341c-1ee0-5005-9fbc-ce5657e31784

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
