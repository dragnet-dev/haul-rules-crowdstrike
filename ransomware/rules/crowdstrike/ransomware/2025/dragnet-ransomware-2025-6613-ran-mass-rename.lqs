// Dragnet [Ransomware]: dragnet-ransomware-2025-6613 — Mass File Rename (nightspire)
// Status: deprecated | Level: high | ID: 7c20d9a3-0d91-5d98-9826-5d20f818821b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
