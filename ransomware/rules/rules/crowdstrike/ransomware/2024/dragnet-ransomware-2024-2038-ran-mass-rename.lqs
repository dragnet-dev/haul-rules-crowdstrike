// Dragnet [Ransomware]: dragnet-ransomware-2024-2038 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: faa68164-5643-585e-926d-744e60ea755a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
