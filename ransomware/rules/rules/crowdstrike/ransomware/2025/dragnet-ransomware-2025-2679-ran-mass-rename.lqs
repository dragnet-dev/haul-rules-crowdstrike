// Dragnet [Ransomware]: dragnet-ransomware-2025-2679 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 162e62b7-8afd-5351-aecb-aeeafa6c5442

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
