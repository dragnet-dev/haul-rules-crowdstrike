// Dragnet [Ransomware]: dragnet-ransomware-2022-2175 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 3e06cbe9-9547-50e3-a6bb-f6058b837766

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
