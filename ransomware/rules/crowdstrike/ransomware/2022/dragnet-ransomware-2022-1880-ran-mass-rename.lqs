// Dragnet [Ransomware]: dragnet-ransomware-2022-1880 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 4082dd9f-2f5c-51b8-84dd-491dfadc4dfd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
