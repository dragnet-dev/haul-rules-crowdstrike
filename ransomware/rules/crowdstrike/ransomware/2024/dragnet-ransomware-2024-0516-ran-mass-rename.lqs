// Dragnet [Ransomware]: dragnet-ransomware-2024-0516 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: e860f198-30a2-561b-a452-3c634e80ef08

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
