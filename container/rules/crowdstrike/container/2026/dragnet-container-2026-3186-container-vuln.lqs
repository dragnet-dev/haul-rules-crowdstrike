// Dragnet [Container]: dragnet-container-2026-3186 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: d3914ad5-0cc2-59ad-a8a1-a5e49297e9f8

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *ubuntu:16.04* OR ImageFileName = *ubuntu:16.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
