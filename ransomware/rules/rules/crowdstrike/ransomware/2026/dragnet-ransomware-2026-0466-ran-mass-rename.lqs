// Dragnet [Ransomware]: dragnet-ransomware-2026-0466 — Mass File Rename (incransom)
// Status: stable | Level: high | ID: f5597d84-c611-59c2-852e-2ca855830fde

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
