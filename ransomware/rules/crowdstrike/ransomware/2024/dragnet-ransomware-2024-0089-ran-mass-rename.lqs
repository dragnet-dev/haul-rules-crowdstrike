// Dragnet [Ransomware]: dragnet-ransomware-2024-0089 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: a638e12c-1a69-53ea-91ac-968a472356bf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
