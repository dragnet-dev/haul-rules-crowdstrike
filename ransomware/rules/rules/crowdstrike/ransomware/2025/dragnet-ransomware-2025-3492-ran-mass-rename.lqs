// Dragnet [Ransomware]: dragnet-ransomware-2025-3492 — Mass File Rename (sinobi)
// Status: experimental | Level: high | ID: 41f28948-4814-51c4-8055-1eb6e20cf688

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
