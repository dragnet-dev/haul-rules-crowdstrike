// Dragnet [Ransomware]: dragnet-ransomware-2024-3520 — Mass File Rename (meow)
// Status: experimental | Level: high | ID: c5c5b670-47cf-5b71-a8bb-ae8e6137a7d1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
