// Dragnet [Ransomware]: dragnet-ransomware-2024-5685 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 173b66f1-b239-5579-a28e-bd63656f72a9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
