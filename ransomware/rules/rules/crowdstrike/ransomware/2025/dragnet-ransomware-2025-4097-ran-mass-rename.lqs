// Dragnet [Ransomware]: dragnet-ransomware-2025-4097 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: bb4e785d-f267-5427-8b1d-ff9774e8ec54

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
