// Dragnet [Ransomware]: dragnet-ransomware-2025-1288 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: 58151d97-6166-5193-babb-d51e84f672c7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
