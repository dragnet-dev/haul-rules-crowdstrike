// Dragnet [Ransomware]: dragnet-ransomware-2024-1143 — Mass File Rename (cloak)
// Status: deprecated | Level: high | ID: 35b717f0-5e0c-5422-bcea-c2decd612c9e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
