// Dragnet [Ransomware]: dragnet-ransomware-2022-1651 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: c1327f03-a432-5303-b33b-889faa422c1e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
