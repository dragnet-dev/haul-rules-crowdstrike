// Dragnet [Ransomware]: dragnet-ransomware-2024-2082 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 73ebc899-9173-52a9-8a98-bf86b4943160

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
