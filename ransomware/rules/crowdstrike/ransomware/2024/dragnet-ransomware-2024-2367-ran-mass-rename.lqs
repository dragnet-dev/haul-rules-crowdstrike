// Dragnet [Ransomware]: dragnet-ransomware-2024-2367 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: a8d1ab60-5503-534c-a1dc-b5dc36ee362d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
