// Dragnet [Container]: dragnet-container-2026-1843 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 83699100-9f78-5884-bf73-2e5e1ce647d2

#event_simpleName=*
| (ImageFileName = *chainguard:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
