// Dragnet [Ransomware]: dragnet-ransomware-2025-0753 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: a5c2da93-7fd1-5291-ae7e-77072f094c36

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
