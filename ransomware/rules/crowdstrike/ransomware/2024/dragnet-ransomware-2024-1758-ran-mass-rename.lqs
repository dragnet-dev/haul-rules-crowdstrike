// Dragnet [Ransomware]: dragnet-ransomware-2024-1758 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: f7238ce3-a5d1-5682-97a7-28ab029c5ed9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
