// Dragnet [Ransomware]: dragnet-ransomware-2025-6857 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 99788af7-a907-59a2-b187-d4d2a0f56343

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
