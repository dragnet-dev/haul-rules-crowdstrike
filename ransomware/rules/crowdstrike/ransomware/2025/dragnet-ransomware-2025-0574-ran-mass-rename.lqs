// Dragnet [Ransomware]: dragnet-ransomware-2025-0574 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 78b65512-812c-5449-b2d3-0cee26eafa61

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
