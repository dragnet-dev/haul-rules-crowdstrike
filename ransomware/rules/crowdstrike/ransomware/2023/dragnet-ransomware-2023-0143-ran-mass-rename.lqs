// Dragnet [Ransomware]: dragnet-ransomware-2023-0143 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 0144d7e9-ca59-507e-aa4c-f4615d381121

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
