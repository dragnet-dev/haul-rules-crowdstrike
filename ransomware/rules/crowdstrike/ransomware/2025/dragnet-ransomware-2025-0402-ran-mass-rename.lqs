// Dragnet [Ransomware]: dragnet-ransomware-2025-0402 — Mass File Rename (interlock)
// Status: experimental | Level: high | ID: 94bee95b-4cda-5e81-9814-4b6eb8ed3606

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
