// Dragnet [Ransomware]: dragnet-ransomware-2024-2386 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 71a53216-5c11-5d66-b363-f5f577daf9a7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
