// Dragnet [Ransomware]: dragnet-ransomware-2025-1096 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 1549a850-8883-559a-b965-451b7a6a105e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
