// Dragnet [Ransomware]: dragnet-ransomware-2026-2300 — Mass File Rename (netrunner)
// Status: stable | Level: high | ID: 22fdba62-6c96-5dce-810c-4231adf8d1d5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
