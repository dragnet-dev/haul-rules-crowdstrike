// Dragnet [Ransomware]: dragnet-ransomware-2022-1329 — Mass File Rename (sparta)
// Status: deprecated | Level: high | ID: 65d00b20-c962-57df-ad26-6f406bb6704d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
