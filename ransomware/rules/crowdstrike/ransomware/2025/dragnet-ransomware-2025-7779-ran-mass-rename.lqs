// Dragnet [Ransomware]: dragnet-ransomware-2025-7779 — Mass File Rename (sinobi)
// Status: experimental | Level: high | ID: 5b732c51-faed-5279-b6b8-55cc04e6137c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
