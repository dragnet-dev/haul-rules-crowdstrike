// Dragnet [Ransomware]: dragnet-ransomware-2024-1678 — Mass File Rename (dragonforce)
// Status: deprecated | Level: high | ID: 53cd0667-58cf-5d63-8d0d-8066a317967b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
