// Dragnet [Ransomware]: dragnet-ransomware-2022-2815 — Mass File Rename (royal)
// Status: deprecated | Level: high | ID: 19f786ba-3bd8-54c3-986b-0b21b07d55b3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
