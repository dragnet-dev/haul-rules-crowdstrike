// Dragnet [Ransomware]: dragnet-ransomware-2025-0081 — Mass File Rename (dragonforce)
// Status: test | Level: high | ID: b3d76c0b-563d-5285-bce5-089fff343a4c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
