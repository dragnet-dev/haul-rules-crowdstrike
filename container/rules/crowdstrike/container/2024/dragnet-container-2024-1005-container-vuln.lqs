// Dragnet [Container]: dragnet-container-2024-1005 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 164afd98-8421-5988-88aa-c6d78cc10ca9

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
