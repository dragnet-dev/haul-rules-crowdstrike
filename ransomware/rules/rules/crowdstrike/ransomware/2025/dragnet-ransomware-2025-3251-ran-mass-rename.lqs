// Dragnet [Ransomware]: dragnet-ransomware-2025-3251 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 69cf4356-4303-569a-9350-fa7103d73cc5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
