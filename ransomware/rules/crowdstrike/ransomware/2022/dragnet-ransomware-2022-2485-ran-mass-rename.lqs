// Dragnet [Ransomware]: dragnet-ransomware-2022-2485 — Mass File Rename (ragnarlocker)
// Status: deprecated | Level: high | ID: 86c036c6-5a0b-57c0-979c-5411d5eb00c4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
