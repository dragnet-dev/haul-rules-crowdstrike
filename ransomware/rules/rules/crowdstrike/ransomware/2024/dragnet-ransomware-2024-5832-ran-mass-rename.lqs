// Dragnet [Ransomware]: dragnet-ransomware-2024-5832 — Mass File Rename (arcusmedia)
// Status: experimental | Level: high | ID: 5f7c6b4b-721a-5274-9655-fd398cb3c2e4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
