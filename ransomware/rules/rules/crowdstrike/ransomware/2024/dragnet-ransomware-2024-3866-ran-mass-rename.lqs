// Dragnet [Ransomware]: dragnet-ransomware-2024-3866 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 9b487c41-67d6-5a3f-996c-57a8ac468a6a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
