// Dragnet [Ransomware]: dragnet-ransomware-2023-2091 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 481dabcd-6022-5a70-8900-65869abf5c8f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
