// Dragnet [Ransomware]: dragnet-ransomware-2025-0237 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 940be2cc-be77-5bda-b6d5-d5af629956dc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
