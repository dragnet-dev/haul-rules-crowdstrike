// Dragnet [Ransomware]: dragnet-ransomware-2025-7657 — Mass File Rename (genesis)
// Status: experimental | Level: high | ID: 25dc7035-c1f0-56c9-bafa-16f365c120da

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
