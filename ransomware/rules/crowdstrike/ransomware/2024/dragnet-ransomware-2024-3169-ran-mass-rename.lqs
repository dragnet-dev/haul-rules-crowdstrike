// Dragnet [Ransomware]: dragnet-ransomware-2024-3169 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: db53562b-2463-5506-9a66-0564b424aa0f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
