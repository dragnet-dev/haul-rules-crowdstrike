// Dragnet [Ransomware]: dragnet-ransomware-2025-1789 — Mass File Rename (spacebears)
// Status: experimental | Level: high | ID: b69322e0-6a9a-5f51-8fa6-b1327a0d0c6f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
