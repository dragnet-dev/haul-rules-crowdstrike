// Dragnet [Ransomware]: dragnet-ransomware-2021-0639 — Mass File Rename (avaddon)
// Status: deprecated | Level: high | ID: f4fc6370-e380-5763-98c2-08736c333322

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
