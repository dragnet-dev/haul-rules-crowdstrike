// Dragnet [Ransomware]: dragnet-ransomware-2024-4357 — Mass File Rename (kraken)
// Status: experimental | Level: high | ID: 8a1fef8c-1538-5da4-a40a-d9e546a604f8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
