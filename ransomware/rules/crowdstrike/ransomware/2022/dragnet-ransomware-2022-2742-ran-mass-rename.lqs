// Dragnet [Ransomware]: dragnet-ransomware-2022-2742 — Mass File Rename (ransomhouse)
// Status: deprecated | Level: high | ID: 0daea8ba-2843-5c25-ac1d-6cecbdec6912

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
