// Dragnet [Ransomware]: dragnet-ransomware-2023-0475 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: a6c2b648-d017-5a09-bd2a-9cfe7b49fc44

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
