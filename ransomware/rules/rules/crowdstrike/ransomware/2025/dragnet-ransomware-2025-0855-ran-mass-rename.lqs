// Dragnet [Ransomware]: dragnet-ransomware-2025-0855 — Mass File Rename (lockbit5)
// Status: test | Level: high | ID: e720cc66-65d6-50c7-bab3-5a51fe59d6a6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
