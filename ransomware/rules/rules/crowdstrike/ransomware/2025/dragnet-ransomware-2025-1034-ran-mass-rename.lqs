// Dragnet [Ransomware]: dragnet-ransomware-2025-1034 — Mass File Rename (chaos)
// Status: experimental | Level: high | ID: 649c9d18-9ef1-5085-b914-3f47217741b1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
