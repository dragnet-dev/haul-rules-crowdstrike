// Dragnet [Ransomware]: dragnet-ransomware-2022-3108 — Mass File Rename (kelvinsecurity)
// Status: deprecated | Level: high | ID: 8f24daf3-d9b2-502c-b349-19af272bb45c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
