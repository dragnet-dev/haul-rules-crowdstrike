// Dragnet [Ransomware]: dragnet-ransomware-2022-1591 — Mass File Rename (ransomexx)
// Status: deprecated | Level: high | ID: 6b655fb9-e4e1-5bdc-be1c-48f0fb15a50c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
