// Dragnet [Ransomware]: dragnet-ransomware-2024-2598 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: e3d3530f-d767-59c6-8767-bfba8f6d0594

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
