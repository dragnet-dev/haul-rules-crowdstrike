// Dragnet [Ransomware]: dragnet-ransomware-2025-2701 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 9356e11c-3f01-57fe-b9a4-233edec6db7f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
