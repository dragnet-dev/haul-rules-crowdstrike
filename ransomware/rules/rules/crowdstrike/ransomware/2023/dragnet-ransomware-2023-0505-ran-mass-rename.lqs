// Dragnet [Ransomware]: dragnet-ransomware-2023-0505 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: ab750d92-6446-5c8e-8461-91b04c0286a8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
