// Dragnet [Ransomware]: dragnet-ransomware-2023-4762 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: c7eb1aa6-749a-56dc-9076-410d7d14a892

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
