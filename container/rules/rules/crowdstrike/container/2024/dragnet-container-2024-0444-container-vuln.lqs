// Dragnet [Container]: dragnet-container-2024-0444 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 319a2a9c-be59-5498-93f4-27140e1d9508

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12*)
| table([timestamp, ComputerName])
| limit(1000)
