// Dragnet [Ransomware]: dragnet-ransomware-2026-0388 — Mass File Rename (nightspire)
// Status: deprecated | Level: high | ID: 11fb2342-6fa1-5622-adae-ff1b3d3c57e0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
