// Dragnet [Ransomware]: dragnet-ransomware-2023-3393 — Mass File Rename (royal)
// Status: deprecated | Level: high | ID: 3610313d-55cf-56da-9690-725dca03c327

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
