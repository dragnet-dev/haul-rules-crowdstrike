// Dragnet [Ransomware]: dragnet-ransomware-2025-3744 — Mass File Rename (satanlockv2)
// Status: experimental | Level: high | ID: 40c36e16-2288-5d03-9ac3-87af72314cac

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
