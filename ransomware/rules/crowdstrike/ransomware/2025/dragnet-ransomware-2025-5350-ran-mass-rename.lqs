// Dragnet [Ransomware]: dragnet-ransomware-2025-5350 — Mass File Rename (global)
// Status: deprecated | Level: high | ID: e771c1d8-5037-5121-936c-3b6c9211aad5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
