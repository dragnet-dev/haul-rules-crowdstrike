// Dragnet [Ransomware]: dragnet-ransomware-2023-2570 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 098a4bbc-bcc8-5be2-b2c6-5a0c1b6cb9da

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
