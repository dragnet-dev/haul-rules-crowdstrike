// Dragnet [Ransomware]: dragnet-ransomware-2024-1234 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 4f4b53be-74f8-5efe-ba2a-afb2aef432f6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
