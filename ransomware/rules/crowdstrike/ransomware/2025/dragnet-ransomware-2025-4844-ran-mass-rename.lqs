// Dragnet [Ransomware]: dragnet-ransomware-2025-4844 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 929e3414-1b29-5f34-b046-aeb2287e6aa4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
