// Dragnet [Ransomware]: dragnet-ransomware-2025-2646 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: 33099047-4ebe-5a94-a62e-f2e532a2282d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
