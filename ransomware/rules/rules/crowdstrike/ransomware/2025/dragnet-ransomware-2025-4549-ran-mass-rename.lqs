// Dragnet [Ransomware]: dragnet-ransomware-2025-4549 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 38fa9a88-70ed-5fce-8e86-49742fb3ad1b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
