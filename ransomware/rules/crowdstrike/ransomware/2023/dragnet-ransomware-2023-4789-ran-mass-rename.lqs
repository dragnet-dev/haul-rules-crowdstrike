// Dragnet [Ransomware]: dragnet-ransomware-2023-4789 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 4d6badc3-3a36-5522-b6e7-e661550615a9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
