// Dragnet [Ransomware]: dragnet-ransomware-2022-1860 — Mass File Rename (everest)
// Status: deprecated | Level: high | ID: 76894efa-24c1-5315-8eab-41ed8c33be96

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
