// Dragnet [Ransomware]: dragnet-ransomware-2023-0350 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 41de651b-ecce-5cbf-ac02-8d21ab3a7099

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
