// Dragnet [Container]: dragnet-container-2024-0069 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: c032cfc9-0b34-5565-94eb-a95e9a7efa50

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:8* OR ImageFileName = *redhat/ubi9:*)
| table([timestamp, ComputerName])
| limit(1000)
