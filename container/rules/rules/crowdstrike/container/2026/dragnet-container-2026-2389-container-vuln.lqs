// Dragnet [Container]: dragnet-container-2026-2389 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 2270c413-7ed8-5c1f-9563-5e50fc08e287

#event_simpleName=*
| (ImageFileName = *chainguard:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
