// Dragnet [Ransomware]: dragnet-ransomware-2024-0349 — Mass File Rename (darkvault)
// Status: experimental | Level: high | ID: bd84fed2-e441-5bc2-b972-00eb2888e89b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
