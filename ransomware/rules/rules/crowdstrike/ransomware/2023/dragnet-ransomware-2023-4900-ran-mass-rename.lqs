// Dragnet [Ransomware]: dragnet-ransomware-2023-4900 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 48345671-fda8-5790-9096-e051ce574111

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
