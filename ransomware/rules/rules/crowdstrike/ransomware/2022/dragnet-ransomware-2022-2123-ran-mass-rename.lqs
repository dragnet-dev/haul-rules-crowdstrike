// Dragnet [Ransomware]: dragnet-ransomware-2022-2123 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 801a9606-9b4e-5329-bfce-190a1213a3c4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
