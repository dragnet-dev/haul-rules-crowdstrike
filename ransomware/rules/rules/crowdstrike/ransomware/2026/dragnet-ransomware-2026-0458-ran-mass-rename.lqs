// Dragnet [Ransomware]: dragnet-ransomware-2026-0458 — Mass File Rename (nightspire)
// Status: deprecated | Level: high | ID: 22a4851b-1d39-578f-92cb-7a7a83137824

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
