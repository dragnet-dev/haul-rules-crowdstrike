// Dragnet [Ransomware]: dragnet-ransomware-2022-1588 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 6ef37a9e-7f4d-53c6-ba57-0ecfb5ada81e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
