// Dragnet [Ransomware]: dragnet-ransomware-2024-1668 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 68a63828-4b1c-52a3-a8a2-9fc660645812

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
