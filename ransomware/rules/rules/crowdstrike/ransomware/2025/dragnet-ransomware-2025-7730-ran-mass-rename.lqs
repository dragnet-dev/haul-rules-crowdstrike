// Dragnet [Ransomware]: dragnet-ransomware-2025-7730 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: fc12ef89-4387-54d6-965c-a93361c1cbf4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
