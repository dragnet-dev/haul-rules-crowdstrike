// Dragnet [Ransomware]: dragnet-ransomware-2022-2893 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 8766f0d6-9f5b-553a-b6aa-65a8fff41e2c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
