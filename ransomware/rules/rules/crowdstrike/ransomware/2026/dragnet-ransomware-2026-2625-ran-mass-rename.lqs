// Dragnet [Ransomware]: dragnet-ransomware-2026-2625 — Mass File Rename (termite)
// Status: stable | Level: high | ID: 78ea1dc4-87c9-57cc-aaf5-9b24d0762156

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
