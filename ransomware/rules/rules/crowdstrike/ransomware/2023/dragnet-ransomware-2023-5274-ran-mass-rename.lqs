// Dragnet [Ransomware]: dragnet-ransomware-2023-5274 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: bdc3994d-23d9-587d-a9fc-5849cad64cd2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
