// Dragnet [Ransomware]: dragnet-ransomware-2021-0941 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 14693cbb-2e0d-57c9-8869-9997733a23d4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
