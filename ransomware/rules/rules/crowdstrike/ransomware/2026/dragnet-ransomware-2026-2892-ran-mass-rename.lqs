// Dragnet [Ransomware]: dragnet-ransomware-2026-2892 — Mass File Rename (dragonforce)
// Status: stable | Level: high | ID: 39b4a3ca-a8b2-597f-82d3-3cb119bbb236

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
