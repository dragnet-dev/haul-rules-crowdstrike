// Dragnet [Ransomware]: dragnet-ransomware-2021-0307 — Mass File Rename (cuba)
// Status: deprecated | Level: high | ID: 1c60a987-7b61-5b6a-b84e-20520f2edade

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
