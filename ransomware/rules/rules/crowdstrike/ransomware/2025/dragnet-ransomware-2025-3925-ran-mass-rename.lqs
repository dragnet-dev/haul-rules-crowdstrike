// Dragnet [Ransomware]: dragnet-ransomware-2025-3925 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: d81f3ec0-0b32-54b4-9077-497b54e7b5d0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
