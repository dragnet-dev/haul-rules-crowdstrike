// Dragnet [Ransomware]: dragnet-ransomware-2022-1538 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: c5edba73-6ed2-5a83-ad97-b35eefc399e5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
