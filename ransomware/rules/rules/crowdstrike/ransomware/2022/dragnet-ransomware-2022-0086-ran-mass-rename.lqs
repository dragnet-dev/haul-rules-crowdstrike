// Dragnet [Ransomware]: dragnet-ransomware-2022-0086 — Mass File Rename (ragnarlocker)
// Status: experimental | Level: high | ID: ad4b5889-bcf0-5eb8-bdfe-385b3f9df603

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
