// Dragnet [Ransomware]: dragnet-ransomware-2024-3248 — Mass File Rename (raworld)
// Status: experimental | Level: high | ID: 83bbe7de-babf-5798-ad7f-ffc12595e51c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
