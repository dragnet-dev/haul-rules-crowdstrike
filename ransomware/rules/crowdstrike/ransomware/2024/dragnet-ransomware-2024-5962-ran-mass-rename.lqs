// Dragnet [Ransomware]: dragnet-ransomware-2024-5962 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: 0a4c7794-6450-5105-941c-31dcdb981ad0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
