// Dragnet [Ransomware]: dragnet-ransomware-2024-5738 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: a7c7a3dd-9a6b-5ed3-9672-b23f4184f25b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
