// Dragnet [Ransomware]: dragnet-ransomware-2022-2481 — Mass File Rename (royal)
// Status: deprecated | Level: high | ID: c01122c4-c59b-54e6-b77e-872b6d1f4050

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
