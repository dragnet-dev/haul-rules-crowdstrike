// Dragnet [Ransomware]: dragnet-ransomware-2024-3274 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 9cf65d72-41fb-5d33-bccc-2a3d4bafa895

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
