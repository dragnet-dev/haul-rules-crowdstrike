// Dragnet [Ransomware]: dragnet-ransomware-2021-0417 — Mass File Rename (everest)
// Status: deprecated | Level: high | ID: fd5061f5-2988-5173-b43c-c11e070edc31

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
