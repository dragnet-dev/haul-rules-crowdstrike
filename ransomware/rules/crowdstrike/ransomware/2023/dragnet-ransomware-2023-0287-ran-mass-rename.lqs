// Dragnet [Ransomware]: dragnet-ransomware-2023-0287 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 25032c71-7f39-57ee-88ad-40f9cb58c2f3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
