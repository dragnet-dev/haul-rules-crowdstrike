// Dragnet [Ransomware]: dragnet-ransomware-2024-0935 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 897b0da2-10fd-5d07-9694-3064465bcb65

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
