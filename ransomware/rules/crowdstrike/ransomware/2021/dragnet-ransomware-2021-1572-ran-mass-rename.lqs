// Dragnet [Ransomware]: dragnet-ransomware-2021-1572 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: c242eeac-533c-5bf5-87f2-4803008197d8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
