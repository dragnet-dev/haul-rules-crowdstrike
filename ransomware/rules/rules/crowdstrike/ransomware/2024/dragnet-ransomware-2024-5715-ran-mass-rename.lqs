// Dragnet [Ransomware]: dragnet-ransomware-2024-5715 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 693deb0d-71f3-5b2b-8ca9-877bbabb5c0c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
