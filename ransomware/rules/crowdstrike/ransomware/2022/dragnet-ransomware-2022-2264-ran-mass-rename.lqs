// Dragnet [Ransomware]: dragnet-ransomware-2022-2264 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 8944c53e-ebb3-516e-8ca8-0d55e9829131

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
