// Dragnet [Ransomware]: dragnet-ransomware-2024-3932 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: 2dac40b3-76c1-5952-bd1e-051f9a585a9c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
