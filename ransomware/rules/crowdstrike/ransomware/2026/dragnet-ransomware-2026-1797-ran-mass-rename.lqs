// Dragnet [Ransomware]: dragnet-ransomware-2026-1797 — Mass File Rename (AiLock)
// Status: deprecated | Level: high | ID: 736ed698-5f3c-5cf1-a68b-0c431fa29e1b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
