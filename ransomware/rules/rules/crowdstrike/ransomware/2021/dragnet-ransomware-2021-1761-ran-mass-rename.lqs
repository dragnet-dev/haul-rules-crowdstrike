// Dragnet [Ransomware]: dragnet-ransomware-2021-1761 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: bea8f908-43e8-5cca-8779-d16c940a51d1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
