// Dragnet [Ransomware]: dragnet-ransomware-2025-3415 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: a79c2bee-64f2-5b8c-8120-cae9f791d6e5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
