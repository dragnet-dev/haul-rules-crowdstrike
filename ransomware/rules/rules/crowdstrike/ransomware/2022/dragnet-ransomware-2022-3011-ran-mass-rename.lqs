// Dragnet [Ransomware]: dragnet-ransomware-2022-3011 — Mass File Rename (ransomexx)
// Status: experimental | Level: high | ID: c41f6361-687c-542e-8269-156c31613db4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
