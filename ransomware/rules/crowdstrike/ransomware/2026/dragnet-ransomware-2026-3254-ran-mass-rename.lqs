// Dragnet [Ransomware]: dragnet-ransomware-2026-3254 — Mass File Rename (safepay)
// Status: stable | Level: high | ID: 4464f419-27c5-545a-bc9a-463ce07f4226

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
