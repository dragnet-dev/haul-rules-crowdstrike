// Dragnet [Ransomware]: dragnet-ransomware-2024-4062 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: 13aacce0-6455-560c-b5e3-830b6d9508df

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
