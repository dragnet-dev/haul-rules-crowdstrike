// Dragnet [Ransomware]: dragnet-ransomware-2023-4130 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: aaedeb65-96d7-5fd8-86cf-6355b08a6397

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
