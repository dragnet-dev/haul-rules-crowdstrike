// Dragnet [Ransomware]: dragnet-ransomware-2024-4829 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 326b5348-8ddf-52e2-88af-bdf7d355e57f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
