// Dragnet [Ransomware]: dragnet-ransomware-2021-1571 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 3b497fee-8750-50c6-b7d0-81d9fa16ffc8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
