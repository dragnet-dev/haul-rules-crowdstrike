// Dragnet [Ransomware]: dragnet-ransomware-2024-1805 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 89fa612d-cdc9-5254-b669-7bb2a112cc8d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
