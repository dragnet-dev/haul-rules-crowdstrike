// Dragnet [Ransomware]: dragnet-ransomware-2024-0813 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 1f7f688b-8a17-5f71-83f4-926a862b85dd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
