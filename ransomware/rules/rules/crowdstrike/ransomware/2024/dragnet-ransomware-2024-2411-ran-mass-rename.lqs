// Dragnet [Ransomware]: dragnet-ransomware-2024-2411 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: c94141be-3345-5847-b73f-dfece760c312

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
