// Dragnet [Ransomware]: dragnet-ransomware-2025-7286 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 04a122de-2852-58bc-83c1-93f78295fc5b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
