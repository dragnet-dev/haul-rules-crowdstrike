// Dragnet [Ransomware]: dragnet-ransomware-2025-4202 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: c1848563-fca0-5f05-85dc-b0aa0ae8e9e6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
