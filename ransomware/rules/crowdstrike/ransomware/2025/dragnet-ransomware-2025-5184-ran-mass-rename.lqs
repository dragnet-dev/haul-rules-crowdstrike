// Dragnet [Ransomware]: dragnet-ransomware-2025-5184 — Mass File Rename (direwolf)
// Status: experimental | Level: high | ID: 5e9b1c58-e8b7-53e1-b10f-5067913ec35f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
