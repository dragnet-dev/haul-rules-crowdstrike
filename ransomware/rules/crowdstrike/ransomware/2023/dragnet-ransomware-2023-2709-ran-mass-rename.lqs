// Dragnet [Ransomware]: dragnet-ransomware-2023-2709 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: cd6da8c2-e749-52a5-93a4-265ba2a40aed

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
