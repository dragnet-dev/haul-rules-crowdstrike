// Dragnet [Ransomware]: dragnet-ransomware-2023-1025 — Mass File Rename (losttrust)
// Status: deprecated | Level: high | ID: 43cbf306-47b1-5d05-a7d7-51fc985fe779

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
