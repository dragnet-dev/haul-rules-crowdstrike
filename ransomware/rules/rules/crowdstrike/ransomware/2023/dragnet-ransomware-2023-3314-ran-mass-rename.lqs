// Dragnet [Ransomware]: dragnet-ransomware-2023-3314 — Mass File Rename (dragonforce)
// Status: deprecated | Level: high | ID: 87940f8c-6d82-58a7-9a99-80acf1eed22c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
