// Dragnet [Ransomware]: dragnet-ransomware-2022-0786 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 39679398-3119-5bb7-9928-0fcd93766939

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
