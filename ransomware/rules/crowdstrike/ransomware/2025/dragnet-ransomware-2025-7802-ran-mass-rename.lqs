// Dragnet [Ransomware]: dragnet-ransomware-2025-7802 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 1f157955-9a38-5d03-acf9-a4ac1455a685

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
