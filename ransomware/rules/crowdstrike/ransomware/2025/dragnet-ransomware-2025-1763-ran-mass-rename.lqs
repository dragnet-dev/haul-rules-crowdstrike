// Dragnet [Ransomware]: dragnet-ransomware-2025-1763 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: daacc4d1-60ea-53ee-90ac-200b71058ac4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
