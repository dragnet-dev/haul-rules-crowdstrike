// Dragnet [Ransomware]: dragnet-ransomware-2021-0324 — Mass File Rename (suncrypt)
// Status: deprecated | Level: high | ID: 24610d17-ee70-5a26-8eaa-796a4b6fde98

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
