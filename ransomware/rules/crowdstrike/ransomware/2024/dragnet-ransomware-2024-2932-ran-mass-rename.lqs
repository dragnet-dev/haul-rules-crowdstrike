// Dragnet [Ransomware]: dragnet-ransomware-2024-2932 — Mass File Rename (blacklock)
// Status: experimental | Level: high | ID: 7b846d72-61d7-588e-8272-1e1755256952

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
