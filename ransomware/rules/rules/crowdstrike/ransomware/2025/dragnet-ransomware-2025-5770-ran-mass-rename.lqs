// Dragnet [Ransomware]: dragnet-ransomware-2025-5770 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: e2a2397c-60eb-5df3-af7e-52fee9097e77

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
