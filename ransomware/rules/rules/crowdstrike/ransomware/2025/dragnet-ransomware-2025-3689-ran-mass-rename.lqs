// Dragnet [Ransomware]: dragnet-ransomware-2025-3689 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: f8230fd6-7315-511d-94bd-151823845d06

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
