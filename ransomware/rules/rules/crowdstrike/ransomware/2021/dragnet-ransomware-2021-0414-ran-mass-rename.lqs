// Dragnet [Ransomware]: dragnet-ransomware-2021-0414 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 6ccc0150-33e6-52c2-b5d5-73acc72e5316

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
