// Dragnet [Ransomware]: dragnet-ransomware-2025-4770 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 03f2740f-4299-520c-877e-03085522946f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
