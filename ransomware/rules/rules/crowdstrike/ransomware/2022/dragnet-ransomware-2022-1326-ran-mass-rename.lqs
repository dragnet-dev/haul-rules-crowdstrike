// Dragnet [Ransomware]: dragnet-ransomware-2022-1326 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: ac85a4f1-dbf4-52fd-84de-4f7818db49db

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
