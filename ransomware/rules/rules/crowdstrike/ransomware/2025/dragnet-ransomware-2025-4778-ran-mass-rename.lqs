// Dragnet [Ransomware]: dragnet-ransomware-2025-4778 — Mass File Rename (lockbit5)
// Status: experimental | Level: high | ID: c12fbfd0-cbf6-5186-b00b-9b0ccbe42306

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
