// Dragnet [Ransomware]: dragnet-ransomware-2023-0844 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: c3922b8e-6c2c-5064-ad2c-aef450a13a37

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
