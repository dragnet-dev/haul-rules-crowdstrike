// Dragnet [Ransomware]: dragnet-ransomware-2025-1020 — Mass File Rename (warlock)
// Status: deprecated | Level: high | ID: 11ae2088-c3f5-5f6a-8f6b-9414341d17aa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
