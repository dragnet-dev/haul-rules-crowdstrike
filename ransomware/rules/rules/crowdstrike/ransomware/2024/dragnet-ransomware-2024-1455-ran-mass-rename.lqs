// Dragnet [Ransomware]: dragnet-ransomware-2024-1455 — Mass File Rename (ElDorado)
// Status: deprecated | Level: high | ID: 91ac54a5-8a86-5f15-9cfa-51d218355821

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
