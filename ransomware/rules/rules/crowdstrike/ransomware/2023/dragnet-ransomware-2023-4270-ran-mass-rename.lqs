// Dragnet [Ransomware]: dragnet-ransomware-2023-4270 — Mass File Rename (raworld)
// Status: experimental | Level: high | ID: 33cb4b85-0715-5248-b9e0-173371ed7330

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
