// Dragnet [Ransomware]: dragnet-ransomware-2024-4734 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: aefdc759-ec3c-56d7-9116-e069a79cacfa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
