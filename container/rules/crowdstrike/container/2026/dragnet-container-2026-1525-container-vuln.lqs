// Dragnet [Container]: dragnet-container-2026-1525 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: f43e2f25-b8b4-5dae-a57d-73a927346a62

#event_simpleName=*
| (ImageFileName = *chainguard:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
