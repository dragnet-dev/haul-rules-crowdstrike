// Dragnet [Ransomware]: dragnet-ransomware-2021-0475 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 95b74ae8-9fad-5625-a84d-2f9ca07700fd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
