// Dragnet [Ransomware]: dragnet-ransomware-2023-1109 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: e4f424cd-9db5-5cbd-b6d6-9c6f56da3c34

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
