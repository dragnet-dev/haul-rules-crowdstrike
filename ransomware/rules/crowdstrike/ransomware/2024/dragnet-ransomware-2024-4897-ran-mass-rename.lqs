// Dragnet [Ransomware]: dragnet-ransomware-2024-4897 — Mass File Rename (chort)
// Status: experimental | Level: high | ID: 9032a64e-3876-5b91-ae06-e5b6b568b00f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
