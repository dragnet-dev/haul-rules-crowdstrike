// Dragnet [Ransomware]: dragnet-ransomware-2026-1734 — Mass File Rename (incransom)
// Status: test | Level: high | ID: b5227ccf-6977-5807-a1af-96b9257d889e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
