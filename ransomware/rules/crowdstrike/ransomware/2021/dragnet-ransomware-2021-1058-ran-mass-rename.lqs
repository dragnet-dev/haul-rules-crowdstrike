// Dragnet [Ransomware]: dragnet-ransomware-2021-1058 — Mass File Rename (ransomexx)
// Status: deprecated | Level: high | ID: a05194fb-a168-5145-970b-f084ffb3fe68

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
