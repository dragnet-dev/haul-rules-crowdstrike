// Dragnet [Container]: dragnet-container-2024-1065 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: d4dc016a-ede3-5850-b321-7018f1f779fc

#event_simpleName=*
| (ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *photon os:4.0* OR ImageFileName = *photon os:5.0* OR ImageFileName = *redhat/ubi9:*)
| table([timestamp, ComputerName])
| limit(1000)
