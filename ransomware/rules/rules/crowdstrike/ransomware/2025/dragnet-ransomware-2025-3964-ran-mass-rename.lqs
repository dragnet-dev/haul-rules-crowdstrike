// Dragnet [Ransomware]: dragnet-ransomware-2025-3964 — Mass File Rename (medusalocker)
// Status: experimental | Level: high | ID: 262bff63-b552-5d9e-8ed0-7432f8f3502a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
