// Dragnet [Ransomware]: dragnet-ransomware-2022-2170 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 38931b73-7722-5e55-9948-fa7afbc6d449

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
