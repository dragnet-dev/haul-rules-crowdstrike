// Dragnet [Ransomware]: dragnet-ransomware-2024-3049 — Mass File Rename (dragonransomware)
// Status: experimental | Level: high | ID: e9997367-c367-5e1b-8d83-757dc96b5a7b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
