// Dragnet [Ransomware]: dragnet-ransomware-2024-5813 — Mass File Rename (apt73)
// Status: experimental | Level: high | ID: e5a6115d-cd64-5303-bf03-8c1fb7358dae

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
