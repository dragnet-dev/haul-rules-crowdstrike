// Dragnet [Ransomware]: dragnet-ransomware-2024-4561 — Mass File Rename (play)
// Status: experimental | Level: high | ID: cbf5a662-e620-54f7-a718-53acf72827f7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
