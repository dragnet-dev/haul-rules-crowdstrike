// Dragnet [Ransomware]: dragnet-ransomware-2025-2357 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 556e985d-2bee-583b-9201-09716539e2a0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
