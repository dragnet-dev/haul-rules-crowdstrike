// Dragnet [Ransomware]: dragnet-ransomware-2022-1244 — Mass File Rename (medusalocker)
// Status: deprecated | Level: high | ID: 87df3333-eeb1-5fce-a16d-1fe7a3b11af3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
