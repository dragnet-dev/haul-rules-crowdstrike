// Dragnet [Ransomware]: dragnet-ransomware-2024-0874 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: eb85ee45-c147-5d95-b151-68cde535a51f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
