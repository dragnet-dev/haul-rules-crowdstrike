// Dragnet [Container]: dragnet-container-2025-0346 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 3dfaf16f-5920-57ee-baf3-367f98776483

#event_simpleName=*
| (ImageFileName = *almalinux:8* OR ImageFileName = *almalinux:9* OR ImageFileName = *alpine:3.21* OR ImageFileName = *alpine:3.22* OR ImageFileName = *alpine:3.23* OR ImageFileName = *alpine edge:* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:8* OR ImageFileName = *oraclelinux:9* OR ImageFileName = *ubuntu:24.04* OR ImageFileName = *ubuntu:24.10*)
| table([timestamp, ComputerName])
| limit(1000)
