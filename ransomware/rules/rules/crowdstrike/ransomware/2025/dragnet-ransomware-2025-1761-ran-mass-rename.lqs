// Dragnet [Ransomware]: dragnet-ransomware-2025-1761 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 04264ccf-03fd-55f4-ac58-81b03aa0f4e3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
