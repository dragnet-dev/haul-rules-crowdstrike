// Dragnet [Ransomware]: dragnet-ransomware-2024-1444 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 3884af42-3be8-5942-8edb-8b30d3c6bd0a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
