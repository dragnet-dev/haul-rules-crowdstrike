// Dragnet [Ransomware]: dragnet-ransomware-2026-2044 — Mass File Rename (dragonforce)
// Status: test | Level: high | ID: 43b4c4d9-d537-58a7-89c1-e646f6fd1b90

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
