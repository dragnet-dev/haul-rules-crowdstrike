// Dragnet [Ransomware]: dragnet-ransomware-2023-2300 — Mass File Rename (darkpower)
// Status: experimental | Level: high | ID: f9360c87-8769-55d0-a879-f9a0e8f30174

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
