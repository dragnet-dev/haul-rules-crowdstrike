// Dragnet [Ransomware]: dragnet-ransomware-2024-2190 — Mass File Rename (argonauts)
// Status: experimental | Level: high | ID: d4cafbf8-2b4e-5fad-9b1f-2566e25c92a8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
