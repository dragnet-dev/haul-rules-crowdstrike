// Dragnet [Ransomware]: dragnet-ransomware-2025-6599 — Mass File Rename (kairos)
// Status: deprecated | Level: high | ID: 06f72e03-4883-50c8-aecd-17fe06451371

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
