// Dragnet [Ransomware]: dragnet-ransomware-2025-4956 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 941d2e13-1fea-52e1-8f32-71b32bcf9c9f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
