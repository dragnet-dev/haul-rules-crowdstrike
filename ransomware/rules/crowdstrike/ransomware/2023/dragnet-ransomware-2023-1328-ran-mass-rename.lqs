// Dragnet [Ransomware]: dragnet-ransomware-2023-1328 — Mass File Rename (royal)
// Status: experimental | Level: high | ID: 1804bb5f-1fb1-5d05-9f43-ccfa7cd9a0e8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
