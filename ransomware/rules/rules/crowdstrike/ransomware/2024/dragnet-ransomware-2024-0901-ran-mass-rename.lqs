// Dragnet [Ransomware]: dragnet-ransomware-2024-0901 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 74d0dd96-cb23-56e0-bc06-767e5630a724

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
