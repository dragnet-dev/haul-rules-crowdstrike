// Dragnet [Ransomware]: dragnet-ransomware-2025-4078 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: d3fec035-b1ea-55b1-9028-e5a5be6e2f15

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
