// Dragnet [Ransomware]: dragnet-ransomware-2022-3136 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: ff7aa3cc-bb72-5f87-90ae-bdaae12920b0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
