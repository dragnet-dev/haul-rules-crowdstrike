// Dragnet [Ransomware]: dragnet-ransomware-2024-2661 — Mass File Rename (play)
// Status: experimental | Level: high | ID: a5d30513-4354-5c3a-a4e7-969996743774

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
