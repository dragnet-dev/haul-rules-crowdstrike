// Dragnet [Ransomware]: dragnet-ransomware-2024-3368 — Mass File Rename (handala)
// Status: experimental | Level: high | ID: 5510aa6e-dec6-5e86-b99b-d6d6b0b6460c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
