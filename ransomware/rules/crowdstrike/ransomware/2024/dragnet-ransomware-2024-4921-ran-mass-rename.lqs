// Dragnet [Ransomware]: dragnet-ransomware-2024-4921 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 71e6428d-59da-5cad-b45d-edbafe5b7edc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
