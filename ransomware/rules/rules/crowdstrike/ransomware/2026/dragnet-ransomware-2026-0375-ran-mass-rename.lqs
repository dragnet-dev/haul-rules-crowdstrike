// Dragnet [Ransomware]: dragnet-ransomware-2026-0375 — Mass File Rename (stormous)
// Status: deprecated | Level: high | ID: 28860ff4-2d10-5b5e-8c28-ca708a73351e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
