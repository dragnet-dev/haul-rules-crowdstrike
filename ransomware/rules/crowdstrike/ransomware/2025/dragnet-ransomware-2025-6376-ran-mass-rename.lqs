// Dragnet [Ransomware]: dragnet-ransomware-2025-6376 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: cdbd1e5a-c592-53a5-8f19-10b139693f76

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
