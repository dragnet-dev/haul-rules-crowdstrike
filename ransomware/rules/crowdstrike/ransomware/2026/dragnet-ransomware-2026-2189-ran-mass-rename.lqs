// Dragnet [Ransomware]: dragnet-ransomware-2026-2189 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 57ed4975-5e33-5762-be68-bee26f3fe381

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
