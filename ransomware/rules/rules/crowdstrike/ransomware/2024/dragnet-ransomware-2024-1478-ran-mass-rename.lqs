// Dragnet [Ransomware]: dragnet-ransomware-2024-1478 — Mass File Rename (raworld)
// Status: experimental | Level: high | ID: dd32678d-5219-5334-b264-235b60493771

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
