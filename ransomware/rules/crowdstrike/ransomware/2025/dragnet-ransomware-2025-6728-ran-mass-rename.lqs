// Dragnet [Ransomware]: dragnet-ransomware-2025-6728 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: b0959848-c0b0-56ab-995f-f146fd592ef0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
