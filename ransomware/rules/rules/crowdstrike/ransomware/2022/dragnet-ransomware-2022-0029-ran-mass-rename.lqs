// Dragnet [Ransomware]: dragnet-ransomware-2022-0029 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: ce0fd496-b06b-5b3a-a931-ee7f10433b46

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
