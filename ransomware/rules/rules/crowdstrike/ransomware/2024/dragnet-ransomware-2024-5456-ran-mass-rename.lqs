// Dragnet [Ransomware]: dragnet-ransomware-2024-5456 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: 63ee559a-361b-5b34-8a16-917bb6bae691

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
