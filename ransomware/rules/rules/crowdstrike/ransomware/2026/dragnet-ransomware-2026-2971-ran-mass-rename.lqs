// Dragnet [Ransomware]: dragnet-ransomware-2026-2971 — Mass File Rename (spacebears)
// Status: test | Level: high | ID: e4a90029-752d-575b-8dd9-6063a9568c52

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
