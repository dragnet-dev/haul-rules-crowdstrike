// Dragnet [Ransomware]: dragnet-ransomware-2022-1336 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 2d371ecb-7af4-5a39-9470-5dc6c0093bde

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
