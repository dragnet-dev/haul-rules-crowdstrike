// Dragnet [Ransomware]: dragnet-ransomware-2022-2015 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: ca824dc2-cc3d-55d1-a93e-67a88fd2d492

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
