// Dragnet [Ransomware]: dragnet-ransomware-2024-2069 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 977de8d4-e43c-5590-b305-6a9ac2b5ce1c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
