// Dragnet [Container]: dragnet-container-2024-0153 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 0e383422-358f-57f0-a380-b1760698c3f4

#event_simpleName=*
| (ImageFileName = *alpine:3.4* OR ImageFileName = *alpine:3.5* OR ImageFileName = *alpine:3.6* OR ImageFileName = *alpine:3.7* OR ImageFileName = *alpine:3.8* OR ImageFileName = *amazonlinux:1* OR ImageFileName = *debian:7* OR ImageFileName = *debian:8* OR ImageFileName = *debian:9* OR ImageFileName = *oraclelinux:7* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:14.04* OR ImageFileName = *ubuntu:14.04-ESM* OR ImageFileName = *ubuntu:16.04* OR ImageFileName = *ubuntu:16.04-ESM* OR ImageFileName = *ubuntu:17.10* OR ImageFileName = *ubuntu:18.04* OR ImageFileName = *ubuntu:18.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
