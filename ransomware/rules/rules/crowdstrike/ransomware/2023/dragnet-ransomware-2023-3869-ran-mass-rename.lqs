// Dragnet [Ransomware]: dragnet-ransomware-2023-3869 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 7f93991c-cdcb-56aa-976d-433915420931

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
