// Dragnet [Container]: dragnet-container-2026-1779 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 53e73ee2-cd61-53dd-b629-2a403571014a

#event_simpleName=*
| (ImageFileName = *debian:7* OR ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10* OR ImageFileName = *ubuntu:13.04*)
| table([timestamp, ComputerName])
| limit(1000)
