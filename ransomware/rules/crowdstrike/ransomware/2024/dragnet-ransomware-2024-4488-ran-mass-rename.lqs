// Dragnet [Ransomware]: dragnet-ransomware-2024-4488 — Mass File Rename (madliberator)
// Status: experimental | Level: high | ID: fe65ae39-954b-5c61-8957-717b45332127

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
