// Dragnet [Ransomware]: dragnet-ransomware-2025-1048 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 28d0091b-d071-53e8-9659-f31047b088d5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
