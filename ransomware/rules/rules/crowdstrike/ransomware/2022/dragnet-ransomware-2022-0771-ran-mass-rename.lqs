// Dragnet [Ransomware]: dragnet-ransomware-2022-0771 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 4fd8a147-c252-58c6-9d00-fc0dd2b01c25

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
