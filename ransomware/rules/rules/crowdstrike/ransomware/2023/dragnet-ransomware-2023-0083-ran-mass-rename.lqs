// Dragnet [Ransomware]: dragnet-ransomware-2023-0083 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 7038be75-f07c-5435-b90b-c7aed441e873

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
