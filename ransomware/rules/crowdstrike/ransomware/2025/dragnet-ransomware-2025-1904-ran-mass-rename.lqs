// Dragnet [Ransomware]: dragnet-ransomware-2025-1904 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 46233df1-2a2e-59f9-b1a0-1457f65640f8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
