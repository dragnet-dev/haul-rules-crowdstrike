// Dragnet [Ransomware]: dragnet-ransomware-2020-0038 — Mass File Rename (netwalker)
// Status: deprecated | Level: high | ID: 8c2431e1-397f-5501-828e-6d2de3b43618

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
