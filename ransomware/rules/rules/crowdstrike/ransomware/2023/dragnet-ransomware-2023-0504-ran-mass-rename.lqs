// Dragnet [Ransomware]: dragnet-ransomware-2023-0504 — Mass File Rename (cyclops)
// Status: deprecated | Level: high | ID: 1d823362-67bb-5360-944f-7125dba5ee17

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
