// Dragnet [Ransomware]: dragnet-ransomware-2024-5961 — Mass File Rename (stormous)
// Status: deprecated | Level: high | ID: bc40a65c-0475-530d-a1a6-122911857c81

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
