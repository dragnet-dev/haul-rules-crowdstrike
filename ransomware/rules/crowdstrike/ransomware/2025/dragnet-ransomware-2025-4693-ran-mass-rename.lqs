// Dragnet [Ransomware]: dragnet-ransomware-2025-4693 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: b045f403-5663-57c5-a839-5566e9ac2902

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
