// Dragnet [Ransomware]: dragnet-ransomware-2025-3787 — Mass File Rename (crypto24)
// Status: deprecated | Level: high | ID: 097e023f-2148-5bc5-8829-4ed30e9778f5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
