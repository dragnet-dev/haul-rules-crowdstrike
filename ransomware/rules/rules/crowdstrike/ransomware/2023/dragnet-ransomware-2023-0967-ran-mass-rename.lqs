// Dragnet [Ransomware]: dragnet-ransomware-2023-0967 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 56c8ab2a-8eaa-51ce-b9c3-b8bf3e89499b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
