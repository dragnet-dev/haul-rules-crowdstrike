// Dragnet [Ransomware]: dragnet-ransomware-2024-2005 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 1bdbb9be-dc1b-5676-9013-a1e2f6653e4c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
