// Dragnet [Ransomware]: dragnet-ransomware-2022-0675 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 7b75a9ef-639f-5dfc-8b13-cf838f1349e1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
