// Dragnet [Ransomware]: dragnet-ransomware-2022-1717 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 56ba5343-695f-5ee0-bd73-a95044ae6f1f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
