// Dragnet [Ransomware]: dragnet-ransomware-2022-0094 — Mass File Rename (ragnarlocker)
// Status: experimental | Level: high | ID: 214f23a0-1b6d-50c1-b094-bdae2030cfdf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
