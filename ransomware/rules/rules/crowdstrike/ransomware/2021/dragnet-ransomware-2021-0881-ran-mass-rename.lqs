// Dragnet [Ransomware]: dragnet-ransomware-2021-0881 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 15006960-e882-589f-9fb7-46e2455944f9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
