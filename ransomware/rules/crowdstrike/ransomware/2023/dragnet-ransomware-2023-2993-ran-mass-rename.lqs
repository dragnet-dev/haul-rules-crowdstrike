// Dragnet [Ransomware]: dragnet-ransomware-2023-2993 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: 8c2ad71d-ca8f-596e-92e4-bbad8c957d67

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
