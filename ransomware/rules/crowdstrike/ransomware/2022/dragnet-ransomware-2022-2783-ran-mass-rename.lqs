// Dragnet [Ransomware]: dragnet-ransomware-2022-2783 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: c7168432-c873-589b-bea9-9ec8c95831f4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
