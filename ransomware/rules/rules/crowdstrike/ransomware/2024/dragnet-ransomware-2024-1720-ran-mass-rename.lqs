// Dragnet [Ransomware]: dragnet-ransomware-2024-1720 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: dc32b4ae-3acb-5720-ae6e-690fa04ddea3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
