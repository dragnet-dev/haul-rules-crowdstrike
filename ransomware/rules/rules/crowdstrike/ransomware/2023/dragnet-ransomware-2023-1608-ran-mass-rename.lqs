// Dragnet [Ransomware]: dragnet-ransomware-2023-1608 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 09d38218-2bdd-5794-8640-9c8c582ee0fe

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
