// Dragnet [Ransomware]: dragnet-ransomware-2024-2345 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: dc29d848-840d-5d61-b25c-4709b3fa53e4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
