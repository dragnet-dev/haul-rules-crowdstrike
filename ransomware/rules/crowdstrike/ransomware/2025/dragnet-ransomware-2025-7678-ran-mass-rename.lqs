// Dragnet [Ransomware]: dragnet-ransomware-2025-7678 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 00a51547-58eb-519b-87e6-21aa1366917d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
