// Dragnet [Ransomware]: dragnet-ransomware-2025-3531 — Mass File Rename (direwolf)
// Status: experimental | Level: high | ID: 37b42929-ffdb-5c0e-b35d-035f4012ad25

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
