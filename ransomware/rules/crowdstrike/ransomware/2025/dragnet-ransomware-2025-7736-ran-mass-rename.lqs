// Dragnet [Ransomware]: dragnet-ransomware-2025-7736 — Mass File Rename (direwolf)
// Status: experimental | Level: high | ID: d339b165-985c-51eb-9453-eaffbe19b512

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
