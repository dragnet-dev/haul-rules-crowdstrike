// Dragnet [Ransomware]: dragnet-ransomware-2022-1140 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: dd2c0e17-d317-55c3-8075-bb373e1ed8cc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
