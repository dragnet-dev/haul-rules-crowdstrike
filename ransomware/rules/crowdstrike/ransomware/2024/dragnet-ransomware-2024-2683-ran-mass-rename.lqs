// Dragnet [Ransomware]: dragnet-ransomware-2024-2683 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 43f10acb-51b4-58b5-b9cb-a315ffc962f1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
