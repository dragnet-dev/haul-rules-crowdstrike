// Dragnet [Ransomware]: dragnet-ransomware-2021-1554 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 87106c60-4d3b-5390-91df-35fcbccbbf38

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
