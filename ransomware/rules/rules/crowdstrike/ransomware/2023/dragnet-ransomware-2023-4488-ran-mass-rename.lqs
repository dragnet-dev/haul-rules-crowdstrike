// Dragnet [Ransomware]: dragnet-ransomware-2023-4488 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 6dbec3ff-0553-597f-9c5d-86531ddec7ef

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
