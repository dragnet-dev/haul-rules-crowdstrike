// Dragnet [Ransomware]: dragnet-ransomware-2022-2226 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: a3248d13-bb34-57f3-b7e3-c32c6a54a3af

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
