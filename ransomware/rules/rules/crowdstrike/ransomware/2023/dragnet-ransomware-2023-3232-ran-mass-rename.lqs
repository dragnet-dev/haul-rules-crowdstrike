// Dragnet [Ransomware]: dragnet-ransomware-2023-3232 — Mass File Rename (dragonforce)
// Status: deprecated | Level: high | ID: 86c2e1c9-93e3-5537-83c3-f985d78a877b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
