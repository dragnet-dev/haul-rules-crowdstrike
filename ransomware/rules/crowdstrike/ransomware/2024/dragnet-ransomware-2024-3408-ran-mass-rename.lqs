// Dragnet [Ransomware]: dragnet-ransomware-2024-3408 — Mass File Rename (ElDorado)
// Status: deprecated | Level: high | ID: 29106294-df8e-5ed4-8b91-e729363fc592

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
