// Dragnet [Ransomware]: dragnet-ransomware-2024-1920 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: ccc8abee-2901-5377-8053-41ce1d668f81

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
