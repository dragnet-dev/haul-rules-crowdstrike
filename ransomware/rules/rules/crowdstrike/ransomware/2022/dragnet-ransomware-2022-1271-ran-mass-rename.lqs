// Dragnet [Ransomware]: dragnet-ransomware-2022-1271 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 828b4230-d64e-50b5-b975-75adc8eec781

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
