// Dragnet [Ransomware]: dragnet-ransomware-2025-5677 — Mass File Rename (crypto24)
// Status: deprecated | Level: high | ID: 1daaf2c4-24f9-5a5f-a3d2-b42f779577ed

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
