// Dragnet [Container]: dragnet-container-2024-0973 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 0ea8418e-d266-5850-9858-3dde9823c33f

#event_simpleName=*
| (ImageFileName = *cbl-mariner:1.0* OR ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:9* OR ImageFileName = *oraclelinux:8*)
| table([timestamp, ComputerName])
| limit(1000)
