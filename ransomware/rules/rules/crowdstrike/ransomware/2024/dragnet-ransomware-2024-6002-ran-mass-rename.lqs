// Dragnet [Ransomware]: dragnet-ransomware-2024-6002 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 5e2aa631-7b01-5b24-a9f0-1ed4282a1b8b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
