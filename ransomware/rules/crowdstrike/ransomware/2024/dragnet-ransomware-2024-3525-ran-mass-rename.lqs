// Dragnet [Ransomware]: dragnet-ransomware-2024-3525 — Mass File Rename (ransomhouse)
// Status: experimental | Level: high | ID: 8e4ad9e5-79cd-590f-b691-35ef627fa1bf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
