// Dragnet [Ransomware]: dragnet-ransomware-2022-1874 — Mass File Rename (avoslocker)
// Status: deprecated | Level: high | ID: e4f2a542-fabf-5e3c-865d-9cef77c4415c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
