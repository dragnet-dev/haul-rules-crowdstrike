// Dragnet [Ransomware]: dragnet-ransomware-2025-2489 — Mass File Rename (thegentlemen)
// Status: experimental | Level: high | ID: 79691f41-f719-5936-8062-ef17bdfb8164

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
