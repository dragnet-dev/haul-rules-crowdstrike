// Dragnet [Ransomware]: dragnet-ransomware-2023-3340 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 2bf15ac8-c1b6-53dd-9856-32549bf74eb1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
