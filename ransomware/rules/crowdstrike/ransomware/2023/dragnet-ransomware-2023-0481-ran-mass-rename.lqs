// Dragnet [Ransomware]: dragnet-ransomware-2023-0481 — Mass File Rename (knight)
// Status: experimental | Level: high | ID: 7d740482-7e77-5f4c-9cd0-d328f54c4079

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
