// Dragnet [Ransomware]: dragnet-ransomware-2023-0722 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: c11dcc41-8c47-503f-ba00-45ca78f0d399

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
