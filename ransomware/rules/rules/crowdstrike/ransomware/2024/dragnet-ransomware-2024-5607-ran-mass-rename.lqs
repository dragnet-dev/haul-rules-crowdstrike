// Dragnet [Ransomware]: dragnet-ransomware-2024-5607 — Mass File Rename (play)
// Status: experimental | Level: high | ID: cbd50b6d-6dac-562d-a612-8ce27ccf8aab

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
