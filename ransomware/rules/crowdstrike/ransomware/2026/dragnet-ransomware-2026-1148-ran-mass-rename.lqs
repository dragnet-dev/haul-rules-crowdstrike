// Dragnet [Ransomware]: dragnet-ransomware-2026-1148 — Mass File Rename (thegentlemen)
// Status: stable | Level: high | ID: fac7835a-f789-5f6b-a8d3-8e463c1ba75b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
