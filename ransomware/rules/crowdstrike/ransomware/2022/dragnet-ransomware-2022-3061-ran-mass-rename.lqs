// Dragnet [Ransomware]: dragnet-ransomware-2022-3061 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 7f8f8f9a-be66-5ad1-92cb-597e860889e0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
