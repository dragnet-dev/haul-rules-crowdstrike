// Dragnet [Ransomware]: dragnet-ransomware-2025-4334 — Mass File Rename (sinobi)
// Status: experimental | Level: high | ID: 0d8ec22f-7e9d-5b25-82bb-e3c96abfe2e7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
