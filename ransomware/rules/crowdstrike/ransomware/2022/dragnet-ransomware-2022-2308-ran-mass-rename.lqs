// Dragnet [Ransomware]: dragnet-ransomware-2022-2308 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: a373b160-4757-5174-ba31-719c35c4bfb5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
