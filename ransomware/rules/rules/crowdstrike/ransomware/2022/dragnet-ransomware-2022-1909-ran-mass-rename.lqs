// Dragnet [Ransomware]: dragnet-ransomware-2022-1909 — Mass File Rename (midas)
// Status: deprecated | Level: high | ID: e78c0c02-1c8b-5f73-9e7b-c6a52602c9c1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
