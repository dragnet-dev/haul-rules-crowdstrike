// Dragnet [Ransomware]: dragnet-ransomware-2024-0587 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: 60303378-a3e7-5e78-8b6a-62a595133d11

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
