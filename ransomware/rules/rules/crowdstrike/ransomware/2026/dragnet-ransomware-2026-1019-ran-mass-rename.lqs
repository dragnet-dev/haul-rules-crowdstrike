// Dragnet [Ransomware]: dragnet-ransomware-2026-1019 — Mass File Rename (thegentlemen)
// Status: test | Level: high | ID: 49690a51-8991-5160-9c9c-4db17d3b6e55

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
