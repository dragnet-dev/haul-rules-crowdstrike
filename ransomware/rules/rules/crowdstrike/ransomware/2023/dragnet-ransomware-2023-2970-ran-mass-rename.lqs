// Dragnet [Ransomware]: dragnet-ransomware-2023-2970 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 5a1a5fcc-48a0-5f12-8e53-26f90e44b928

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
