// Dragnet [Ransomware]: dragnet-ransomware-2025-1256 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: 25aa3f9f-bb86-5f8b-86ef-4b11da76833d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
