// Dragnet [Ransomware]: dragnet-ransomware-2023-2136 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 0ad5b968-05ec-510e-bbec-c02aa0808e47

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
