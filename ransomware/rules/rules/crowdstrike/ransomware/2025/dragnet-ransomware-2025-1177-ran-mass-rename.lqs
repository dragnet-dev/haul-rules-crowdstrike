// Dragnet [Ransomware]: dragnet-ransomware-2025-1177 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 93913c09-a574-51ce-a494-e1e753ae07f7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
