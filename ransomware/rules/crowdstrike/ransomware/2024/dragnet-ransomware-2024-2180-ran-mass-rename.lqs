// Dragnet [Ransomware]: dragnet-ransomware-2024-2180 — Mass File Rename (SilentRansomGroup)
// Status: deprecated | Level: high | ID: 42d113ca-535d-541b-875e-c6047fd55e8a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
