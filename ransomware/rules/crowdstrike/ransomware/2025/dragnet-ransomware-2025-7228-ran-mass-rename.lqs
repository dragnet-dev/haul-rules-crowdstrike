// Dragnet [Ransomware]: dragnet-ransomware-2025-7228 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: c00fdcaf-6bd0-513a-abb2-a1ec45ee5efb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
