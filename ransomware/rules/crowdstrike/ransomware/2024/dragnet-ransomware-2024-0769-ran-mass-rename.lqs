// Dragnet [Ransomware]: dragnet-ransomware-2024-0769 — Mass File Rename (arcusmedia)
// Status: experimental | Level: high | ID: c223c0c3-afe1-54bb-8bbc-49b836b07801

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
