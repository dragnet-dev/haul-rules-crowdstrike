// Dragnet [Ransomware]: dragnet-ransomware-2025-1956 — Mass File Rename (warlock)
// Status: deprecated | Level: high | ID: 985b8119-8714-55ac-8423-69d7c1e95bce

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
