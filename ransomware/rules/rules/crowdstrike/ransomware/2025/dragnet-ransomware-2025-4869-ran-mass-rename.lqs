// Dragnet [Ransomware]: dragnet-ransomware-2025-4869 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 8f329c02-e956-5c6a-89b0-96d8593574ad

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
