// Dragnet [Ransomware]: dragnet-ransomware-2024-3420 — Mass File Rename (darkvault)
// Status: experimental | Level: high | ID: f7a0d0d0-03b6-516b-bc35-f29199f5578c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
