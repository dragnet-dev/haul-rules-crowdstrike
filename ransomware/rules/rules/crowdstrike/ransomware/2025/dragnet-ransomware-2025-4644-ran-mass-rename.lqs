// Dragnet [Ransomware]: dragnet-ransomware-2025-4644 — Mass File Rename (play)
// Status: experimental | Level: high | ID: b5bb0306-b84b-5c93-b3c7-fdc9ae1e1c39

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
