// Dragnet [Ransomware]: dragnet-ransomware-2025-0187 — Mass File Rename (crazyhunter)
// Status: experimental | Level: high | ID: 6dc93942-b327-5f2f-82fd-68b67a364f62

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
