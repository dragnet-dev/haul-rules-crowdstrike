// Dragnet [Ransomware]: dragnet-ransomware-2025-6722 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: f6312c0b-0385-5805-b99f-4af34fca08b6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
