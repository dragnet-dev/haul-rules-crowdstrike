// Dragnet [Ransomware]: dragnet-ransomware-2020-0198 — Mass File Rename (darkside)
// Status: deprecated | Level: high | ID: 9c7a8c0e-2838-5d5d-aab0-1c2608ba6150

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
