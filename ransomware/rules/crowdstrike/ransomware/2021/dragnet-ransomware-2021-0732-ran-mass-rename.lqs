// Dragnet [Ransomware]: dragnet-ransomware-2021-0732 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 45ea1b22-12c5-5328-8c39-97b436226161

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
