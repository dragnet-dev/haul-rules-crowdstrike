// Dragnet [Ransomware]: dragnet-ransomware-2025-5802 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 66b83769-6720-522c-bc6c-214745c608e0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
