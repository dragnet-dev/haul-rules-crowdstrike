// Dragnet [Ransomware]: dragnet-ransomware-2025-4251 — Mass File Rename (underground)
// Status: experimental | Level: high | ID: bcde7868-53b6-5f66-a8e1-2843d107a3d3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
