// Dragnet [Ransomware]: dragnet-ransomware-2022-2662 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: d1d04c66-18a2-50e4-b56c-8d27c1769821

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
