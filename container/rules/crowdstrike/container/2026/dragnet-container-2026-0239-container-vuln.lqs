// Dragnet [Container]: dragnet-container-2026-0239 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 03673a0a-5672-5f34-98fd-147f4a93a1e3

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
