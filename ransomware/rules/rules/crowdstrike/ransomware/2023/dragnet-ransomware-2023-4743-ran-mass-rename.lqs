// Dragnet [Ransomware]: dragnet-ransomware-2023-4743 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 55ee80ed-461f-5ecc-8bd1-a43db9b00696

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
