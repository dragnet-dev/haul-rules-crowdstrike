// Dragnet [Ransomware]: dragnet-ransomware-2021-1364 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 383f5086-238e-5fa8-bdbb-5739d5911b2a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
