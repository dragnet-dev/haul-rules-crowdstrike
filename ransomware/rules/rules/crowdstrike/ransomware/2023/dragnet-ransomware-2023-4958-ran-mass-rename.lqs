// Dragnet [Ransomware]: dragnet-ransomware-2023-4958 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 7337816a-462a-5824-ba48-52d2ecec3641

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
