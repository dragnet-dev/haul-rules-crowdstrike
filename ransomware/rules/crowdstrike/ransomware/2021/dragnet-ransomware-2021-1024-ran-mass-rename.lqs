// Dragnet [Ransomware]: dragnet-ransomware-2021-1024 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 37991dcb-ee0b-5b7c-9351-541d65143f8b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
