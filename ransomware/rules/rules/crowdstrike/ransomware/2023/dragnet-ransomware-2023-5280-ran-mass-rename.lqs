// Dragnet [Ransomware]: dragnet-ransomware-2023-5280 — Mass File Rename (losttrust)
// Status: deprecated | Level: high | ID: bccdd69b-d7ca-5d30-9195-54a7015fac1a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
