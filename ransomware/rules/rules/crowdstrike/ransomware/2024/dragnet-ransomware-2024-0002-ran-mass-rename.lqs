// Dragnet [Ransomware]: dragnet-ransomware-2024-0002 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: 19a07cea-b21c-52a3-ae04-ec7dafc12692

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
