// Dragnet [Ransomware]: dragnet-ransomware-2024-0525 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: d5e62d6a-e2d6-5015-8e6a-a14bbbf2851f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
