// Dragnet [Ransomware]: dragnet-ransomware-2026-2534 — Mass File Rename (nightspire)
// Status: deprecated | Level: high | ID: 10486d6e-de55-50f7-b873-7d04dfbe5893

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
