// Dragnet [Ransomware]: dragnet-ransomware-2025-5886 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 5167b141-56e9-5efe-8b24-50cf75204951

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
