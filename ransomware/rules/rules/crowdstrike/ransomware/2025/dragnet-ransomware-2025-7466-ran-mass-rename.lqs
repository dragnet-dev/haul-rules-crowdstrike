// Dragnet [Ransomware]: dragnet-ransomware-2025-7466 — Mass File Rename (beast)
// Status: experimental | Level: high | ID: 9165ae79-7a84-522c-9f25-3da1ff6bea9d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
