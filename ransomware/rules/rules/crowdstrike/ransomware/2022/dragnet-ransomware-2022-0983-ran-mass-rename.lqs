// Dragnet [Ransomware]: dragnet-ransomware-2022-0983 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 411b33f7-0f50-56ad-b053-023d5916469a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
