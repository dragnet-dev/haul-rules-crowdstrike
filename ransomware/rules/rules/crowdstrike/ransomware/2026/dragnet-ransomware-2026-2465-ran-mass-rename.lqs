// Dragnet [Ransomware]: dragnet-ransomware-2026-2465 — Mass File Rename (lockbit5)
// Status: stable | Level: high | ID: d1c25d5f-47ea-52c0-9822-a5137969894b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
