// Dragnet [Ransomware]: dragnet-ransomware-2026-3479 — Mass File Rename (everest)
// Status: stable | Level: high | ID: f552aa73-96c5-5eef-b29a-1adf2bf12831

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
