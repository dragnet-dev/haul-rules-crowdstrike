// Dragnet [Ransomware]: dragnet-ransomware-2024-0958 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 8b63c1ae-b12b-5e88-ba4d-534c7e561eb9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
