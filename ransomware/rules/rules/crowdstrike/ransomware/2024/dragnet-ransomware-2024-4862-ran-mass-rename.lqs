// Dragnet [Ransomware]: dragnet-ransomware-2024-4862 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: d73cd15e-45d5-5e64-9834-b87cd54f9835

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
