// Dragnet [Ransomware]: dragnet-ransomware-2022-2486 — Mass File Rename (blackbasta)
// Status: deprecated | Level: high | ID: a60dc42f-a7af-5a29-994e-5a9cdc1ab8dc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
