// Dragnet [Ransomware]: dragnet-ransomware-2024-0921 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 1e64a9bd-e9fb-5d3d-b352-bb13c5782825

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
