// Dragnet [Ransomware]: dragnet-ransomware-2022-1120 — Mass File Rename (royal)
// Status: deprecated | Level: high | ID: c520fcd2-29bc-556f-bef6-f857e7c642f1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
