// Dragnet [Ransomware]: dragnet-ransomware-2024-4216 — Mass File Rename (threeam)
// Status: experimental | Level: high | ID: 3ddb1015-0f35-54d1-ad78-e3e87eed8276

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
