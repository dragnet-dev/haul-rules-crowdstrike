// Dragnet [Ransomware]: dragnet-ransomware-2022-2684 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 8df44040-47a4-5ff3-9eb3-2bda3a71a576

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
