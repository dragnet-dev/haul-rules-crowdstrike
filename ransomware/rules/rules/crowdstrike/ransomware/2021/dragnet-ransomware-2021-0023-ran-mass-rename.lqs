// Dragnet [Ransomware]: dragnet-ransomware-2021-0023 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: f175e72c-ae7d-5421-8cb9-aff3207ecb9b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
