// Dragnet [Ransomware]: dragnet-ransomware-2023-4401 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: ccb42f73-bea5-59de-9dd5-aba74c9219cb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
