// Dragnet [Ransomware]: dragnet-ransomware-2025-7019 — Mass File Rename (metaencryptor)
// Status: experimental | Level: high | ID: 8a547d6a-0296-5dd8-b90f-4c1dae0e85a9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
