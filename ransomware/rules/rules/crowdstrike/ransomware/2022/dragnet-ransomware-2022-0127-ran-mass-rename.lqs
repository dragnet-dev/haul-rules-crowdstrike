// Dragnet [Ransomware]: dragnet-ransomware-2022-0127 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 8cad35f0-7e2d-5094-ae3f-e10592848ef4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
