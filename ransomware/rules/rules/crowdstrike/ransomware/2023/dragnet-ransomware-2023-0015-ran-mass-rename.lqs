// Dragnet [Ransomware]: dragnet-ransomware-2023-0015 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 1e055f09-7484-567c-a1ed-2d9527bf519f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
