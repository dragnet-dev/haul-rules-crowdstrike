// Dragnet [Ransomware]: dragnet-ransomware-2024-5870 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 4745a52d-f276-5a8f-8cba-3afa3dc831b4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
