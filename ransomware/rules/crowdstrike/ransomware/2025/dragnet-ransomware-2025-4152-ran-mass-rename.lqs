// Dragnet [Ransomware]: dragnet-ransomware-2025-4152 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: a72efd4a-bb55-526d-be82-fbc78d5874e2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
