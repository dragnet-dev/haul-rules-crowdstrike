// Dragnet [Ransomware]: dragnet-ransomware-2021-0956 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 734a7956-779c-5167-b44b-ab771ab7f3b1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
