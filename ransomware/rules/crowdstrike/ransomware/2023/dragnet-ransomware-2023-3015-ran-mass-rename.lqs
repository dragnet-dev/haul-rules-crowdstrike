// Dragnet [Ransomware]: dragnet-ransomware-2023-3015 — Mass File Rename (mallox)
// Status: deprecated | Level: high | ID: 827e811a-9f93-5633-9815-8a5937fb591b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
