// Dragnet [Ransomware]: dragnet-ransomware-2025-5462 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 5aef85da-5aff-53d8-bdb7-26200225cc54

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
