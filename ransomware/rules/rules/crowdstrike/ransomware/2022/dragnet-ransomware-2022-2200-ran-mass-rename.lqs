// Dragnet [Ransomware]: dragnet-ransomware-2022-2200 — Mass File Rename (cheers)
// Status: deprecated | Level: high | ID: 2c9447fd-eb9e-55fe-b3d8-c284e0a0035d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
