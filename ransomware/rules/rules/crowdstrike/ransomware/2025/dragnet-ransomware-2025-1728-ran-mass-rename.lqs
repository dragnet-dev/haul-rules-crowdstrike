// Dragnet [Ransomware]: dragnet-ransomware-2025-1728 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 9f59aeca-9b12-5480-b300-00c0f054b30b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
