// Dragnet [Ransomware]: dragnet-ransomware-2023-3600 — Mass File Rename (medusa)
// Status: deprecated | Level: high | ID: 58142bd9-acc9-5abe-b8e5-5092516cdb38

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
