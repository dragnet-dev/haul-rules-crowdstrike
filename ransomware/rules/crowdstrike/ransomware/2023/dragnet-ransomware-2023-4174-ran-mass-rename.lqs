// Dragnet [Ransomware]: dragnet-ransomware-2023-4174 — Mass File Rename (noescape)
// Status: experimental | Level: high | ID: 3d7310d3-cd71-50c9-9650-8d569e4b0d61

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
