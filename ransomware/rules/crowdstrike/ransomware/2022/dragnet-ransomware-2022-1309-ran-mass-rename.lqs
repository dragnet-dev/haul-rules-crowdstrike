// Dragnet [Ransomware]: dragnet-ransomware-2022-1309 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 172980d2-2d1f-5f45-8bc9-e7f2665ac2c2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
