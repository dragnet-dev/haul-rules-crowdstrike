// Dragnet [Ransomware]: dragnet-ransomware-2024-5495 — Mass File Rename (play)
// Status: experimental | Level: high | ID: a57228a3-20d3-5801-824f-ddfb5817db1f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
