// Dragnet [Ransomware]: dragnet-ransomware-2025-0151 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 1eb0bf12-3096-5ca1-9fb1-b802f9f7b2a4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
