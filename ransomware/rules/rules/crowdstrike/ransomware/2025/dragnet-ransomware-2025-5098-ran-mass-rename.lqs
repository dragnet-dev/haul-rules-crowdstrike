// Dragnet [Ransomware]: dragnet-ransomware-2025-5098 — Mass File Rename (worldleaks)
// Status: experimental | Level: high | ID: fbb60eed-2d12-5d16-8ca4-874b65d99130

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
