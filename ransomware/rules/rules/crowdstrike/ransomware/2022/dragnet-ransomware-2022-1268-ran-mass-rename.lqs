// Dragnet [Ransomware]: dragnet-ransomware-2022-1268 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 46aa73fc-5e2e-589e-bc73-ea4cb881b862

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
