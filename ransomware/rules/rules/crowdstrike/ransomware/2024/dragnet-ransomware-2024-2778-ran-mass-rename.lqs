// Dragnet [Ransomware]: dragnet-ransomware-2024-2778 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: 4377c096-1436-5590-9f87-01cdcca5364b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
