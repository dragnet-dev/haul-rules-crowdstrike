// Dragnet [Ransomware]: dragnet-ransomware-2023-2574 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: 8c2a4149-6996-5946-9515-53fd34cd67f4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
