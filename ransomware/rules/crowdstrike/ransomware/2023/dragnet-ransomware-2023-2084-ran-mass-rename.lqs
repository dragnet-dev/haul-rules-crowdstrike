// Dragnet [Ransomware]: dragnet-ransomware-2023-2084 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 21892566-5188-5c65-a7dd-bd6f2e9ab37f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
