// Dragnet [Ransomware]: dragnet-ransomware-2025-4991 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 8d1b8b93-3337-5022-88e7-e0abf50d5e0f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
