// Dragnet [Ransomware]: dragnet-ransomware-2025-6231 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: dddb108f-d610-5849-aca9-34bd57d84f63

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
