// Dragnet [Ransomware]: dragnet-ransomware-2026-1750 — Mass File Rename (incransom)
// Status: stable | Level: high | ID: 2c764c59-453e-57a4-845d-a69947597de2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
