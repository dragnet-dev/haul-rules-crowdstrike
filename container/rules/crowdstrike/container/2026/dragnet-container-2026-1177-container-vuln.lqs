// Dragnet [Container]: dragnet-container-2026-1177 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 32ebdedb-6705-587a-9f5d-cc20d43fc95a

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
