// Dragnet [Ransomware]: dragnet-ransomware-2024-1568 — Mass File Rename (dragonforce)
// Status: deprecated | Level: high | ID: ef00bf94-9713-53a7-9976-9fd5aa3c5d6b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
