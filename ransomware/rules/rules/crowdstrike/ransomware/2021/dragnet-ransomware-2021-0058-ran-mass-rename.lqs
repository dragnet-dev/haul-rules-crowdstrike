// Dragnet [Ransomware]: dragnet-ransomware-2021-0058 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 550dd337-4e0d-587c-aaf0-9a73ff703700

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
