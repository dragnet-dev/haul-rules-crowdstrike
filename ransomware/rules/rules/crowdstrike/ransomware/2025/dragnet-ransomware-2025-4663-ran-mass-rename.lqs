// Dragnet [Ransomware]: dragnet-ransomware-2025-4663 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 883b1cf7-ad37-59ae-9eec-a6b78d44fa78

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
