// Dragnet [Ransomware]: dragnet-ransomware-2025-6425 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 331baf65-7923-5181-b327-e885d7a3e0c4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
