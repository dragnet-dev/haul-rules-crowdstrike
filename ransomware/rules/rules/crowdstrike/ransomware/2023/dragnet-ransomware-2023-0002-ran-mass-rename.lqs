// Dragnet [Ransomware]: dragnet-ransomware-2023-0002 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: c8033323-48f8-5df1-b243-74634aae6292

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
