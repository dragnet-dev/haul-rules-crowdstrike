// Dragnet [Ransomware]: dragnet-ransomware-2024-5260 — Mass File Rename (orca)
// Status: experimental | Level: high | ID: 4c94c477-9947-5854-a3b9-21d0751dea76

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
