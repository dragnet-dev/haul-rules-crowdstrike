// Dragnet [Ransomware]: dragnet-ransomware-2023-3338 — Mass File Rename (play)
// Status: deprecated | Level: high | ID: 9a8f7952-b0a9-5d25-b6b9-d1e0554d0eaf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
