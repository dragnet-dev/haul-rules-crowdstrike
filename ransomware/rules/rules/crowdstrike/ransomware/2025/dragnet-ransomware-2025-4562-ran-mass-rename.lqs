// Dragnet [Ransomware]: dragnet-ransomware-2025-4562 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 591729a2-0b67-5d25-97b0-de09d6be4189

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
