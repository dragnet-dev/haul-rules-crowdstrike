// Dragnet [Ransomware]: dragnet-ransomware-2024-0725 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 3f9be5df-c300-50f7-8aad-54206557c26d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
