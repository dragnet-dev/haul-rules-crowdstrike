// Dragnet [Ransomware]: dragnet-ransomware-2023-4001 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 307643f9-c115-5786-8ebf-f2e52ff9aa0f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
