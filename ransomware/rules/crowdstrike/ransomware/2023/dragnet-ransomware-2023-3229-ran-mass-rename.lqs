// Dragnet [Ransomware]: dragnet-ransomware-2023-3229 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 63741f10-04b7-57ec-9832-541d6fbcf346

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
