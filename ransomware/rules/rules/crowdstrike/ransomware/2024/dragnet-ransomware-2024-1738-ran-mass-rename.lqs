// Dragnet [Ransomware]: dragnet-ransomware-2024-1738 — Mass File Rename (dragonforce)
// Status: deprecated | Level: high | ID: bff1c4e7-b2f1-55e0-969a-ea632d7492c2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
