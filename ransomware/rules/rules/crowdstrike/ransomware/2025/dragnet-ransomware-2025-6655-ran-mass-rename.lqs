// Dragnet [Ransomware]: dragnet-ransomware-2025-6655 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 72fc7e4a-fdb8-5adf-939f-aaf8ea2d1a8a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
