// Dragnet [Ransomware]: dragnet-ransomware-2025-3604 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: b1535e11-9b3f-5ced-8bcf-43cbae394f33

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
