// Dragnet [Ransomware]: dragnet-ransomware-2026-0512 — Mass File Rename (handala)
// Status: stable | Level: high | ID: ebc35a9d-e885-5ed7-85bc-61c3ad973dce

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
