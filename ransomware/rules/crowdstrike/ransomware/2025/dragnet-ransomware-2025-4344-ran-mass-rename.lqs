// Dragnet [Ransomware]: dragnet-ransomware-2025-4344 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 4aac2801-6341-5756-a242-67eee03f9440

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
