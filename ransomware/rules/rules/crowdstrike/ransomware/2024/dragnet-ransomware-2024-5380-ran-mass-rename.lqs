// Dragnet [Ransomware]: dragnet-ransomware-2024-5380 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: bf2b59bd-c7e3-58ea-b97d-1d0aab55d331

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
