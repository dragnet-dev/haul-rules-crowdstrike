// Dragnet [Ransomware]: dragnet-ransomware-2025-6375 — Mass File Rename (direwolf)
// Status: experimental | Level: high | ID: d9c0c2a5-2202-5f0c-8ad6-54f6003da7be

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
