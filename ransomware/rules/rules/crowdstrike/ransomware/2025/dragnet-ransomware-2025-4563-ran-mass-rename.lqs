// Dragnet [Ransomware]: dragnet-ransomware-2025-4563 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: af7af31a-3051-5804-90b4-f40a3d3ce5ac

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
