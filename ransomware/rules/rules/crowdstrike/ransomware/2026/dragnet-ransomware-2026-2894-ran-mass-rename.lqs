// Dragnet [Ransomware]: dragnet-ransomware-2026-2894 — Mass File Rename (worldleaks)
// Status: stable | Level: high | ID: f862ea9a-b7bf-5d41-87af-56a86e3d920c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
