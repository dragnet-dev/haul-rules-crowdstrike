// Dragnet [Ransomware]: dragnet-ransomware-2025-3807 — Mass File Rename (ciphbit)
// Status: deprecated | Level: high | ID: 22c3077c-d114-53d6-97e2-18001b214ad7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
