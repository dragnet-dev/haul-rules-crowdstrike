// Dragnet [Ransomware]: dragnet-ransomware-2026-3395 — Mass File Rename (medusalocker)
// Status: stable | Level: high | ID: ef323eed-a38e-5ac7-b7ad-d8e7adce2b95

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
