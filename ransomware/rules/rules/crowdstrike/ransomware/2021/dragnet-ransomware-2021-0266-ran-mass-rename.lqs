// Dragnet [Ransomware]: dragnet-ransomware-2021-0266 — Mass File Rename (ragnarlocker)
// Status: deprecated | Level: high | ID: e8d3c4df-b1b9-550a-b759-3a39685e76f7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
