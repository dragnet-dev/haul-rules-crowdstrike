// Dragnet [Ransomware]: dragnet-ransomware-2024-2668 — Mass File Rename (play)
// Status: experimental | Level: high | ID: a5bbeb25-1583-5115-9ecd-ff0cbbe38815

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
