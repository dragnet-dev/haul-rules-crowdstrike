// Dragnet [Ransomware]: dragnet-ransomware-2023-1656 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 96d297e0-3b74-5c71-a628-8167c662b942

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
