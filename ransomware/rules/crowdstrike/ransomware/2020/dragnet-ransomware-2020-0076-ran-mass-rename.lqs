// Dragnet [Ransomware]: dragnet-ransomware-2020-0076 — Mass File Rename (revil)
// Status: deprecated | Level: high | ID: 964c3119-1e70-51ad-86c3-ff7f9e43b867

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
