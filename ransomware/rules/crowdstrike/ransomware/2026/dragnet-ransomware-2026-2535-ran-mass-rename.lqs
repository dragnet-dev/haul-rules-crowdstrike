// Dragnet [Ransomware]: dragnet-ransomware-2026-2535 — Mass File Rename (lockbit5)
// Status: stable | Level: high | ID: 68c10fc6-7864-521a-9d9b-0bf0272572f2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
