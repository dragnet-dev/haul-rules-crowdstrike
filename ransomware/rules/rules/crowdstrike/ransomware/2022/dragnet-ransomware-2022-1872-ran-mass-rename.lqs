// Dragnet [Ransomware]: dragnet-ransomware-2022-1872 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 19ce6846-35be-5a0f-9d21-73c6689c46c8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
