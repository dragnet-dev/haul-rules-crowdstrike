// Dragnet [Ransomware]: dragnet-ransomware-2023-4251 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: d81c4cd9-5c0e-5391-a4e6-554a1601d830

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
