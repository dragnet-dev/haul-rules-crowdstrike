// Dragnet [Ransomware]: dragnet-ransomware-2025-7908 — Mass File Rename (BrainCipher)
// Status: experimental | Level: high | ID: a4bd7032-1e1f-5d48-b78d-47b0208171c8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
