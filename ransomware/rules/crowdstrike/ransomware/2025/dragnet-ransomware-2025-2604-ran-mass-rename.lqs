// Dragnet [Ransomware]: dragnet-ransomware-2025-2604 — Mass File Rename (blacklock)
// Status: experimental | Level: high | ID: 520a2e8c-2669-5dc0-a2ec-ccb3d581c727

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
