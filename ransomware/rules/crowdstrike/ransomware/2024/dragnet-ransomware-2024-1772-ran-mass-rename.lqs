// Dragnet [Ransomware]: dragnet-ransomware-2024-1772 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: 8160c1c5-f61a-51f9-bf6b-5a4fd9aa3c9e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
