// Dragnet [Ransomware]: dragnet-ransomware-2025-6521 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: be97987a-10e0-5fb0-942a-c94a9b645301

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
