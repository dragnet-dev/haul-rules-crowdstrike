// Dragnet [Ransomware]: dragnet-ransomware-2023-1030 — Mass File Rename (noescape)
// Status: experimental | Level: high | ID: 0b0cb8d9-84bc-5730-8353-011be3382a6b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
