// Dragnet [Ransomware]: dragnet-ransomware-2025-3313 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: 34adc749-d50f-5449-8e7b-dd7a85bdd0e9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
