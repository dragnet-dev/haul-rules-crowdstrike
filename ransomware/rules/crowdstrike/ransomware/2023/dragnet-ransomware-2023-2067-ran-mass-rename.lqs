// Dragnet [Ransomware]: dragnet-ransomware-2023-2067 — Mass File Rename (royal)
// Status: experimental | Level: high | ID: 6064d6b3-11e3-5a33-ba50-be1e5bc795cf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
