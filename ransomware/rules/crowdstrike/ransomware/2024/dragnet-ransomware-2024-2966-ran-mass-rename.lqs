// Dragnet [Ransomware]: dragnet-ransomware-2024-2966 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: c8b2cb99-44ac-575c-924a-8bd98f3f4f09

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
