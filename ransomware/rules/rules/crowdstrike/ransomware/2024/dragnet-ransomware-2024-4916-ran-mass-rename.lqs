// Dragnet [Ransomware]: dragnet-ransomware-2024-4916 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 8db7b527-ed85-5f0d-aa8a-15b3ed5f47a4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
