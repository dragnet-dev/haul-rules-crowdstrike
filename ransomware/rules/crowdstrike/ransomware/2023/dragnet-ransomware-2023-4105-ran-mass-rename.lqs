// Dragnet [Ransomware]: dragnet-ransomware-2023-4105 — Mass File Rename (play)
// Status: experimental | Level: high | ID: b43f11ac-655a-5a17-9e23-2074c682c66c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
