// Dragnet [Ransomware]: dragnet-ransomware-2025-2673 — Mass File Rename (chaos)
// Status: experimental | Level: high | ID: 35bc42d6-165c-567d-a101-bc8558b2bf3c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
