// Dragnet [Ransomware]: dragnet-ransomware-2022-0956 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 56b78afc-1fe1-50b0-8edf-d768800ee54b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
