// Dragnet [Ransomware]: dragnet-ransomware-2022-1930 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 459dc9a4-c7b6-5989-820d-ad5704559793

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
