// Dragnet [Ransomware]: dragnet-ransomware-2021-0012 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 65d38113-f8d5-5f76-bda0-e07bfae37a4a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
