// Dragnet [Ransomware]: dragnet-ransomware-2024-2744 — Mass File Rename (SilentRansomGroup)
// Status: deprecated | Level: high | ID: 633db16b-59e5-55d6-85ef-eb3419ad0d1a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
