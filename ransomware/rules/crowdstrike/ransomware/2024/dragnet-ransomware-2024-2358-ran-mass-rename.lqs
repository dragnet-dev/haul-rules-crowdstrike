// Dragnet [Ransomware]: dragnet-ransomware-2024-2358 — Mass File Rename (ransomhouse)
// Status: experimental | Level: high | ID: b4d87a25-0f3f-5339-9580-8ed1e4670217

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
