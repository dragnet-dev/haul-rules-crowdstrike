// Dragnet [Ransomware]: dragnet-ransomware-2024-3459 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 507713e1-37a8-585d-82e3-672836f23eea

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
