// Dragnet [Ransomware]: dragnet-ransomware-2024-1941 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 8a792e9d-95cb-5eec-9a32-46c5c318929e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
