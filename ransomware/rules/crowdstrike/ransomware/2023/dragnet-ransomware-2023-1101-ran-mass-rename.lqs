// Dragnet [Ransomware]: dragnet-ransomware-2023-1101 — Mass File Rename (noescape)
// Status: experimental | Level: high | ID: 8c63fe01-74e4-560d-8c91-ce867fca7198

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
