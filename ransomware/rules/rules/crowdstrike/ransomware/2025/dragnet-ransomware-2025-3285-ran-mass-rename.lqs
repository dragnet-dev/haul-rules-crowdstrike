// Dragnet [Ransomware]: dragnet-ransomware-2025-3285 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: c0df3c89-6c7d-5ea6-8365-20a4a67a3e91

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
