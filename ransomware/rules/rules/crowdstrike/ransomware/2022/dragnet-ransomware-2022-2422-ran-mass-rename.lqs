// Dragnet [Ransomware]: dragnet-ransomware-2022-2422 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: fc6094ea-be44-5ec0-a028-01c71417a276

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
