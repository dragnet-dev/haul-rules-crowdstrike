// Dragnet [Ransomware]: dragnet-ransomware-2023-3325 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 226fdae8-68b2-5449-93a6-8d3574cf92ae

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
