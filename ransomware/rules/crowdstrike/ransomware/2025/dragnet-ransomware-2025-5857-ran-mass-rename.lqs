// Dragnet [Ransomware]: dragnet-ransomware-2025-5857 — Mass File Rename (lockbit5)
// Status: test | Level: high | ID: db65d319-97ca-58b1-ad17-2c9a8f407eb4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
