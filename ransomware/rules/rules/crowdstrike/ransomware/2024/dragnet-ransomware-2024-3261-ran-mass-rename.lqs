// Dragnet [Ransomware]: dragnet-ransomware-2024-3261 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: 879a04ab-9f55-5f46-848c-f0566db8252e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
