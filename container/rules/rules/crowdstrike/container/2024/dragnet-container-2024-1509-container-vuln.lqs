// Dragnet [Container]: dragnet-container-2024-1509 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: eeaf443b-ea09-5701-bc16-7fce8c1f22d8

#event_simpleName=*
| (ImageFileName = *amazonlinux:2* OR ImageFileName = *debian:10* OR ImageFileName = *debian:8* OR ImageFileName = *debian:9* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:16.04* OR ImageFileName = *ubuntu:16.04-ESM* OR ImageFileName = *ubuntu:18.04* OR ImageFileName = *ubuntu:18.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
