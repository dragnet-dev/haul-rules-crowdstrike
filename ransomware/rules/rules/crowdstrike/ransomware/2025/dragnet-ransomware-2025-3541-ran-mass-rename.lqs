// Dragnet [Ransomware]: dragnet-ransomware-2025-3541 — Mass File Rename (SilentRansomGroup)
// Status: deprecated | Level: high | ID: d4c0d66f-592d-50e0-b62c-101bb4dcde33

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
