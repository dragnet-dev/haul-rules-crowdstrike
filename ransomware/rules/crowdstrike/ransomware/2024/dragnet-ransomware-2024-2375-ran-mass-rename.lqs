// Dragnet [Ransomware]: dragnet-ransomware-2024-2375 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 379b7109-98a3-524e-84c0-ccaf437df758

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
