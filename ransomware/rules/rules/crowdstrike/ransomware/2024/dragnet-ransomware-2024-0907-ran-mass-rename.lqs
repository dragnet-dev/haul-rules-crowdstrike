// Dragnet [Ransomware]: dragnet-ransomware-2024-0907 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: b4b7eecb-0295-5306-937d-d51eaecc2425

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
