// Dragnet [Ransomware]: dragnet-ransomware-2025-0708 — Mass File Rename (lockbit5)
// Status: test | Level: high | ID: a06ceb64-99c5-5d9a-94ea-526fbf616c91

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
