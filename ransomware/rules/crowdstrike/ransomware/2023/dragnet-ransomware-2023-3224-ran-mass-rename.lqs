// Dragnet [Ransomware]: dragnet-ransomware-2023-3224 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 6c928401-f8cf-5eab-a71a-86088a265350

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
