// Dragnet [Ransomware]: dragnet-ransomware-2024-2863 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 38cad9ff-5a2a-5b82-a111-f3602ce82105

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
