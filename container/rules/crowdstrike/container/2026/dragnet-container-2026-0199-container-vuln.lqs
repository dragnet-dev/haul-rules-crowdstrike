// Dragnet [Container]: dragnet-container-2026-0199 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: b0232cb5-b5cf-5bf9-bc44-fbc0e685af13

#event_simpleName=*
| (ImageFileName = *chainguard:* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
