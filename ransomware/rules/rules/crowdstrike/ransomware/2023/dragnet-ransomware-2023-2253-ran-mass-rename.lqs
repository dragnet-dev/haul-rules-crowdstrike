// Dragnet [Ransomware]: dragnet-ransomware-2023-2253 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 343ef759-d0af-5634-9a8c-3e0f96085a3f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
