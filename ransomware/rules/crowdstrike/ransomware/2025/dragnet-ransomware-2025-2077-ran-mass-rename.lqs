// Dragnet [Ransomware]: dragnet-ransomware-2025-2077 — Mass File Rename (blackshrantac)
// Status: experimental | Level: high | ID: f529fcf7-e9ab-5954-8a45-af84dcdf1d70

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
