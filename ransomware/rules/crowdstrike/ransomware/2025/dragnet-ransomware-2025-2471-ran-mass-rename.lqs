// Dragnet [Ransomware]: dragnet-ransomware-2025-2471 — Mass File Rename (thegentlemen)
// Status: test | Level: high | ID: 24bc6ec3-e5b2-56d3-8e09-18da322c46d3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
