// Dragnet [Ransomware]: dragnet-ransomware-2025-7782 — Mass File Rename (d4rk4rmy)
// Status: experimental | Level: high | ID: ceccf2f8-33fc-53b4-a941-deeb4bb76945

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
