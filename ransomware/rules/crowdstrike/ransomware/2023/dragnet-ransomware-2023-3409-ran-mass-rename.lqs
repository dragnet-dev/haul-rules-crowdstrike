// Dragnet [Ransomware]: dragnet-ransomware-2023-3409 — Mass File Rename (snatch)
// Status: experimental | Level: high | ID: 5303d14c-1296-5182-a875-c6738dbd7a1a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
