// Dragnet [Ransomware]: dragnet-ransomware-2022-1825 — Mass File Rename (blackbasta)
// Status: deprecated | Level: high | ID: a3b914a5-bfb8-5911-a90d-919178ecbff8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
