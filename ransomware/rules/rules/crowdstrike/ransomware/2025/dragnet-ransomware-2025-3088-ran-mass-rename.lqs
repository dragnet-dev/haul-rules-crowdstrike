// Dragnet [Ransomware]: dragnet-ransomware-2025-3088 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: 5b018a27-65ed-50f4-8b1c-fa2051ab2ebf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
