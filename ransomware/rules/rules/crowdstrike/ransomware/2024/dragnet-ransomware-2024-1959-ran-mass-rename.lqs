// Dragnet [Ransomware]: dragnet-ransomware-2024-1959 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 5fabc9a9-4e1b-51f8-996c-e3c9a0e75f88

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
