// Dragnet [Ransomware]: dragnet-ransomware-2025-6834 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: 53f7864f-c971-5cb5-b400-9bc0a1d78200

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
