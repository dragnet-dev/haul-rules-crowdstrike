// Dragnet [Container]: dragnet-container-2024-1279 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: e702763d-7675-54f1-af59-5b92a5315e3e

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:14* OR ImageFileName = *debian:9*)
| table([timestamp, ComputerName])
| limit(1000)
