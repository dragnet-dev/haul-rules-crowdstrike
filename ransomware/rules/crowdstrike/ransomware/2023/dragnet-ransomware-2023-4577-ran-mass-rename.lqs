// Dragnet [Ransomware]: dragnet-ransomware-2023-4577 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 1fc3e438-dfee-5e25-998c-828f6a9e88da

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
