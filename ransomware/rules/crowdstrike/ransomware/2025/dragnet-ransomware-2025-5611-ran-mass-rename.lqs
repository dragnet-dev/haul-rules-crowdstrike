// Dragnet [Ransomware]: dragnet-ransomware-2025-5611 — Mass File Rename (nova)
// Status: experimental | Level: high | ID: 3c3f3fd4-9763-58d7-9111-08ec8f19c928

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
