// Dragnet [Ransomware]: dragnet-ransomware-2025-1574 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 77877cca-9c5e-5b01-80e5-eaa05215260d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
