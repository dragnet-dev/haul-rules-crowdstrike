// Dragnet [Ransomware]: dragnet-ransomware-2022-2209 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: bd9b7e57-6107-578d-99bc-1733f88c1fd8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
