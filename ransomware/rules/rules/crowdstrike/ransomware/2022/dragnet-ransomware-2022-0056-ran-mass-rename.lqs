// Dragnet [Ransomware]: dragnet-ransomware-2022-0056 — Mass File Rename (mindware)
// Status: deprecated | Level: high | ID: e10697d2-744b-5d11-8617-eee97b9bc7bd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
