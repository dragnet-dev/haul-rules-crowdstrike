// Dragnet [Ransomware]: dragnet-ransomware-2025-0625 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 4b1ecda6-b80e-54f3-9d4b-aa5803d74823

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
