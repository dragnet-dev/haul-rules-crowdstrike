// Dragnet [Ransomware]: dragnet-ransomware-2025-5152 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 4cd311f1-dfc5-5626-a75e-01ddb08f440c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
