// Dragnet [Container]: dragnet-container-2026-1611 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 2a5ce5ee-b862-57be-9734-34bcf0715302

#event_simpleName=*
| (ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10*)
| table([timestamp, ComputerName])
| limit(1000)
