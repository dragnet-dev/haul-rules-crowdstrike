// Dragnet [Ransomware]: dragnet-ransomware-2026-0971 — Mass File Rename (morpheus)
// Status: deprecated | Level: high | ID: da6826b2-5f75-5b46-a6b3-082d1c83aecc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
