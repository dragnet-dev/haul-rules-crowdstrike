// Dragnet [Ransomware]: dragnet-ransomware-2024-1329 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 9e67148c-ca98-5a1f-9fae-f282dc4bed36

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
