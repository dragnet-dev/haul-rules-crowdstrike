// Dragnet [Ransomware]: dragnet-ransomware-2026-2504 — Mass File Rename (Icarus)
// Status: deprecated | Level: high | ID: 3b9548a9-2e8a-5f23-8ff6-beaed7b03e34

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
