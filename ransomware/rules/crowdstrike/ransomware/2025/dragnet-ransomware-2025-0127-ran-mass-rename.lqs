// Dragnet [Ransomware]: dragnet-ransomware-2025-0127 — Mass File Rename (embargo)
// Status: experimental | Level: high | ID: aa9910c3-7f5a-5fee-9d5c-78216bf74760

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
