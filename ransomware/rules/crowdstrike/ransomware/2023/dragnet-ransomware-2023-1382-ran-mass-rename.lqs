// Dragnet [Ransomware]: dragnet-ransomware-2023-1382 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 7d848b7f-4fca-54b6-a98e-b1f446983256

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
