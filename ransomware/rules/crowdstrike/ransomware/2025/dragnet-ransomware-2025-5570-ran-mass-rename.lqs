// Dragnet [Ransomware]: dragnet-ransomware-2025-5570 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: cea95d10-28b2-5fa7-a79b-09dda044729b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
