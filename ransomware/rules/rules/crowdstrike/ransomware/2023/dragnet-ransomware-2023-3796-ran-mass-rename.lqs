// Dragnet [Ransomware]: dragnet-ransomware-2023-3796 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 3ec329fd-24c4-5a3d-a59c-634e580f5e5e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
