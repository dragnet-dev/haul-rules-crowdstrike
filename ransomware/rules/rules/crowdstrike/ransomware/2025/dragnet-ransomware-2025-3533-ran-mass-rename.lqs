// Dragnet [Ransomware]: dragnet-ransomware-2025-3533 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 1ea0d7a8-fa6c-5c1a-9c96-6f7be73521fe

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
