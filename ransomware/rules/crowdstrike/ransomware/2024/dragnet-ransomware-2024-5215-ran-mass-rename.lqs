// Dragnet [Ransomware]: dragnet-ransomware-2024-5215 — Mass File Rename (safepay)
// Status: deprecated | Level: high | ID: dd635238-5447-52c9-8072-32de67667631

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
