// Dragnet [Ransomware]: dragnet-ransomware-2025-4572 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 99f3eabf-81d2-5519-95a6-c962e4fec89a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
