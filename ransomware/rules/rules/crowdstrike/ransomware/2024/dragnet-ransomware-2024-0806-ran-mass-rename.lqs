// Dragnet [Ransomware]: dragnet-ransomware-2024-0806 — Mass File Rename (frag)
// Status: deprecated | Level: high | ID: 5388f89a-d168-5719-92ec-26eb32cc75ea

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
