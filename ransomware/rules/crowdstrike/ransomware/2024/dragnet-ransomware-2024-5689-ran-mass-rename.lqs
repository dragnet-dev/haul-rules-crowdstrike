// Dragnet [Ransomware]: dragnet-ransomware-2024-5689 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 8f757637-730f-55c2-b796-ec0eccd80bbe

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
