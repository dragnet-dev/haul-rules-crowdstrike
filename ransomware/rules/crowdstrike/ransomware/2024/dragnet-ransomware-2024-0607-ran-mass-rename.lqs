// Dragnet [Ransomware]: dragnet-ransomware-2024-0607 — Mass File Rename (play)
// Status: experimental | Level: high | ID: d4abdc15-3659-5d58-8e29-e5d19506d014

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
