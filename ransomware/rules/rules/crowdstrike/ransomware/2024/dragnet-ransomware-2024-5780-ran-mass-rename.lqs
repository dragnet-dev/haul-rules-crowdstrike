// Dragnet [Ransomware]: dragnet-ransomware-2024-5780 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 7ad15bff-7c7b-572c-8595-fa9da4a824b1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
