// Dragnet [Ransomware]: dragnet-ransomware-2026-2521 — Mass File Rename (exitium)
// Status: stable | Level: high | ID: 19a4f7c5-6a3b-5da8-9322-ee08cc7acd1b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
