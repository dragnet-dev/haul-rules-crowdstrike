// Dragnet [Ransomware]: dragnet-ransomware-2025-3934 — Mass File Rename (handala)
// Status: experimental | Level: high | ID: bb712449-d948-59ec-b5cf-a7ec806cf55e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
