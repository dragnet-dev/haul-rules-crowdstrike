// Dragnet [Ransomware]: dragnet-ransomware-2025-7075 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 9c180627-ed9a-5db6-b2ea-af367faa719c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
