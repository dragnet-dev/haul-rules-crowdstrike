// Dragnet [Ransomware]: dragnet-ransomware-2020-0217 — Mass File Rename (maze)
// Status: deprecated | Level: high | ID: 03918764-8111-5e14-a618-b7492f40aea4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
