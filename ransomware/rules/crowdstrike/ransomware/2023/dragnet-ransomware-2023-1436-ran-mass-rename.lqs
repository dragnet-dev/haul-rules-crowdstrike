// Dragnet [Ransomware]: dragnet-ransomware-2023-1436 — Mass File Rename (karakurt)
// Status: experimental | Level: high | ID: 243db8da-0907-589f-ab3a-26f47420a3e3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
