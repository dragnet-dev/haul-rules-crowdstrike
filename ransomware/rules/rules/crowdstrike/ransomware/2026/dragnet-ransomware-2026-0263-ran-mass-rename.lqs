// Dragnet [Ransomware]: dragnet-ransomware-2026-0263 — Mass File Rename (lockbit5)
// Status: test | Level: high | ID: deded507-18c0-5dde-a677-2594d101ce32

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
