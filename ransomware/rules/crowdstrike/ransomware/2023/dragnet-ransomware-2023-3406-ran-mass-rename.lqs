// Dragnet [Ransomware]: dragnet-ransomware-2023-3406 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 2a2c7d01-d592-51f2-a9ee-d1c63b5b3a67

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
