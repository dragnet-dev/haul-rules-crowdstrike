// Dragnet [Ransomware]: dragnet-ransomware-2025-4877 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: fd0c9390-2300-5153-9d16-0f1a508d2734

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
