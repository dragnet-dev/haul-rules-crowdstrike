// Dragnet [Ransomware]: dragnet-ransomware-2020-0259 — Mass File Rename (ragnarlocker)
// Status: deprecated | Level: high | ID: 90083446-daf4-5ad0-87a6-2bfffa52b344

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
