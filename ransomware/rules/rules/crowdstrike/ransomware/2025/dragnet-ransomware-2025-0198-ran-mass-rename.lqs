// Dragnet [Ransomware]: dragnet-ransomware-2025-0198 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: c6430c9f-a7c9-57af-9038-a45608ca1944

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
