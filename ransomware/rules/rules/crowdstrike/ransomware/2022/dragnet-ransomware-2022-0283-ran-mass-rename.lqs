// Dragnet [Ransomware]: dragnet-ransomware-2022-0283 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: acd777f8-4f69-5865-8344-4b2239720377

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
