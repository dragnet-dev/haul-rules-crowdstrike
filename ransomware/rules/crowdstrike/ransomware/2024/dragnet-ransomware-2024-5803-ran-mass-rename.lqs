// Dragnet [Ransomware]: dragnet-ransomware-2024-5803 — Mass File Rename (threeam)
// Status: experimental | Level: high | ID: ac70cf82-a642-57af-b120-38f342674eab

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
