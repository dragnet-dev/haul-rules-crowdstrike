// Dragnet [Ransomware]: dragnet-ransomware-2026-1875 — Mass File Rename (bravox)
// Status: stable | Level: high | ID: 4195b006-7d28-5905-9abf-86ded3f09d7b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
