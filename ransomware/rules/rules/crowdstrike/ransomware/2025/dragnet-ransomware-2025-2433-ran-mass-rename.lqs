// Dragnet [Ransomware]: dragnet-ransomware-2025-2433 — Mass File Rename (thegentlemen)
// Status: experimental | Level: high | ID: 7e2e6469-67ee-5d5c-a36f-9afb5beed868

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
