// Dragnet [Ransomware]: dragnet-ransomware-2026-0491 — Mass File Rename (spacebears)
// Status: stable | Level: high | ID: edd06abb-830c-5f73-a4db-834749e7fe4c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
