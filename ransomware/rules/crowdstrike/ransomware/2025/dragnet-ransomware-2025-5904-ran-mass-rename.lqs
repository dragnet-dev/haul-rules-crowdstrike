// Dragnet [Ransomware]: dragnet-ransomware-2025-5904 — Mass File Rename (worldleaks)
// Status: experimental | Level: high | ID: 5824b92c-69fc-5960-bbed-3ae42cec9af1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
