// Dragnet [Ransomware]: dragnet-ransomware-2024-4491 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 97b632ee-a46e-545c-a316-87dff569d642

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
