// Dragnet [Ransomware]: dragnet-ransomware-2026-1367 — Mass File Rename (payload)
// Status: stable | Level: high | ID: 53df108b-d8ac-57d4-98b2-0ec26f9c6092

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
