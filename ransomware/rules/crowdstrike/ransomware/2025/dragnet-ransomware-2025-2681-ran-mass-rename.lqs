// Dragnet [Ransomware]: dragnet-ransomware-2025-2681 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 279c376e-22aa-5ae2-be89-7a43b45e9818

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
