// Dragnet [Ransomware]: dragnet-ransomware-2021-1557 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: c5d30f2d-9e88-5a6d-a9c0-9f2e0ba5ca23

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
