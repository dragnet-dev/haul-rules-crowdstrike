// Dragnet [Ransomware]: dragnet-ransomware-2024-1627 — Mass File Rename (metaencryptor)
// Status: experimental | Level: high | ID: e6fbaff6-6e6f-5bab-ae54-4f984da791d1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
