// Dragnet [Ransomware]: dragnet-ransomware-2022-2694 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: caedec14-688f-50a8-9d89-8ddcb30962d9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
