// Dragnet [Ransomware]: dragnet-ransomware-2022-1132 — Mass File Rename (vicesociety)
// Status: deprecated | Level: high | ID: f53d4f8d-6656-5aee-9f25-9c5f9328487d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
