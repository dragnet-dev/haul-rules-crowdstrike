// Dragnet [Ransomware]: dragnet-ransomware-2022-1943 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 9db28cbc-a4ef-58cf-a731-eab72838a91e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
