// Dragnet [Container]: dragnet-container-2026-0038 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: e1b12591-aebf-5f37-b3e2-72945fbcfa08

#event_simpleName=*
| (ImageFileName = *amazonlinux:1* OR ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6*)
| table([timestamp, ComputerName])
| limit(1000)
