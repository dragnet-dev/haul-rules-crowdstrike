// Dragnet [Ransomware]: dragnet-ransomware-2024-0923 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 929eba09-7402-50ab-9c0b-ec2697440ab5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
