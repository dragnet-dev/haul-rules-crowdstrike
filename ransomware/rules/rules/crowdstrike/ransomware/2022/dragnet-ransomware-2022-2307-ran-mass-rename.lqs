// Dragnet [Ransomware]: dragnet-ransomware-2022-2307 — Mass File Rename (quantum)
// Status: deprecated | Level: high | ID: 1b33ed93-6398-5fc0-8782-569b22917717

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
