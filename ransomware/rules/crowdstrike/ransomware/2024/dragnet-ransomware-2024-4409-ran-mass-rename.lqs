// Dragnet [Ransomware]: dragnet-ransomware-2024-4409 — Mass File Rename (raworld)
// Status: experimental | Level: high | ID: 1960ab37-2c0e-5da4-a06d-043a6a7e4673

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
