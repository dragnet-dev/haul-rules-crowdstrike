// Dragnet [Ransomware]: dragnet-ransomware-2025-5471 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 9484344a-3ad4-5d79-8d23-da9f407e1334

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
