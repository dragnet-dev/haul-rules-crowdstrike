// Dragnet [Ransomware]: dragnet-ransomware-2023-1190 — Mass File Rename (noescape)
// Status: experimental | Level: high | ID: 51d4d6a6-b510-571e-8b3a-37f4d3bb3b7b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
