// Dragnet [Ransomware]: dragnet-ransomware-2024-4784 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: f07d45c7-6927-5ed3-9630-14f03eb59f55

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
