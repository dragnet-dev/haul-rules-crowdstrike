// Dragnet [Ransomware]: dragnet-ransomware-2026-0497 — Mass File Rename (sinobi)
// Status: stable | Level: high | ID: 281dd68d-eafa-598c-856c-ea41bbc416ed

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
