// Dragnet [Ransomware]: dragnet-ransomware-2025-5231 — Mass File Rename (termite)
// Status: experimental | Level: high | ID: 88650d29-66d0-54a9-a5f0-00bf942e200d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
