// Dragnet [Container]: dragnet-container-2026-3093 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 13dbfc34-f55d-52ed-a433-4b211f118c32

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
