// Dragnet [Ransomware]: dragnet-ransomware-2025-0902 — Mass File Rename (handala)
// Status: experimental | Level: high | ID: 04767ed8-7daf-5950-8e97-8576dbe7dd6d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
