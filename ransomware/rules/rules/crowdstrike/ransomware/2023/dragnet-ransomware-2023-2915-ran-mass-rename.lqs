// Dragnet [Ransomware]: dragnet-ransomware-2023-2915 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: f13135a7-8b01-5fc3-8ff8-b1ed37e3a20f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
