// Dragnet [Ransomware]: dragnet-ransomware-2023-0294 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 2a46343a-1324-5f85-acbf-01b589a45cf2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
