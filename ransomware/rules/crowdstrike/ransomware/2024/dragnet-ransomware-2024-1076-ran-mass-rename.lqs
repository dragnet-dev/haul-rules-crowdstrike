// Dragnet [Ransomware]: dragnet-ransomware-2024-1076 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 78f307a1-2e69-5b3e-b776-d11991fe7348

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
