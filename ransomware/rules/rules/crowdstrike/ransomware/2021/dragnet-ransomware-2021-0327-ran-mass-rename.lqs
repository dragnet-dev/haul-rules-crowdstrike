// Dragnet [Ransomware]: dragnet-ransomware-2021-0327 — Mass File Rename (avaddon)
// Status: deprecated | Level: high | ID: df3af708-89ef-5c0e-8d37-bfc34f549aee

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
