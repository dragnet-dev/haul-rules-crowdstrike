// Dragnet [Ransomware]: dragnet-ransomware-2023-1043 — Mass File Rename (ransomhouse)
// Status: experimental | Level: high | ID: bf260ab4-775a-5527-85e4-51e9dc71c1b8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
