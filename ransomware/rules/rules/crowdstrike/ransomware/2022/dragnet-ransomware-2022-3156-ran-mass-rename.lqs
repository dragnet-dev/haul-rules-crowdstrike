// Dragnet [Ransomware]: dragnet-ransomware-2022-3156 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 26ad37d9-400d-544d-812c-6c31e1099207

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
