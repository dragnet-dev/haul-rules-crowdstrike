// Dragnet [Ransomware]: dragnet-ransomware-2023-2004 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 24941616-a4b6-580f-9224-2984cf385c0b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
