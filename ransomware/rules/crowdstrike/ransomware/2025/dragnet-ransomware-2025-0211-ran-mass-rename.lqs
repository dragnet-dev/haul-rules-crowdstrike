// Dragnet [Ransomware]: dragnet-ransomware-2025-0211 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 06c11817-80ed-55e4-85d4-2e5aaa1912e5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
