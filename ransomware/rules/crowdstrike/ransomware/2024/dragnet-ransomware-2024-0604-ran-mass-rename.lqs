// Dragnet [Ransomware]: dragnet-ransomware-2024-0604 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 75dd64ac-504f-5001-a74c-06b359108525

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
