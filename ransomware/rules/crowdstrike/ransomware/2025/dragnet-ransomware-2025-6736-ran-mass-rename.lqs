// Dragnet [Ransomware]: dragnet-ransomware-2025-6736 — Mass File Rename (apt73)
// Status: experimental | Level: high | ID: b57c1743-36c2-5ae9-a51a-ddf08597bef1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
