// Dragnet [Ransomware]: dragnet-ransomware-2024-1170 — Mass File Rename (embargo)
// Status: experimental | Level: high | ID: 00b4db1f-43f7-5269-afd2-b3f366db6a6c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
