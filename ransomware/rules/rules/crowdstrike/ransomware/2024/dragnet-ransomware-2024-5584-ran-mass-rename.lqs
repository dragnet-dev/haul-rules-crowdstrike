// Dragnet [Ransomware]: dragnet-ransomware-2024-5584 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: a4a8f91b-c90f-5c15-a25a-572be7c74510

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
