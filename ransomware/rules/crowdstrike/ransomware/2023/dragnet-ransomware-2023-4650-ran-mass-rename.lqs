// Dragnet [Ransomware]: dragnet-ransomware-2023-4650 — Mass File Rename (knight)
// Status: experimental | Level: high | ID: ccafcdec-383d-5b86-b086-49c875bbbf21

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
