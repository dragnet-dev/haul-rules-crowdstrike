// Dragnet [Ransomware]: dragnet-ransomware-2022-0525 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 71939fed-9077-5b44-8e6b-35f5e6d1dee4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
