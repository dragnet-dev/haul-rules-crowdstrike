// Dragnet [Ransomware]: dragnet-ransomware-2022-0844 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 65d512d2-7173-55ee-854e-ac533931cbf4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
