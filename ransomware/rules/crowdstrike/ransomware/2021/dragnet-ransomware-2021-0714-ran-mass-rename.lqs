// Dragnet [Ransomware]: dragnet-ransomware-2021-0714 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 60977e26-1ec6-5271-a6e4-6abef9efe0e6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
