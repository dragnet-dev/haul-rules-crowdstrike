// Dragnet [Ransomware]: dragnet-ransomware-2022-2768 — Mass File Rename (avoslocker)
// Status: deprecated | Level: high | ID: 2d6681ed-2d9d-52f1-9d7c-8d85ba3ca2bb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
