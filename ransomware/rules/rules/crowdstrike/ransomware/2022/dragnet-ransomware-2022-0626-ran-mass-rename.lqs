// Dragnet [Ransomware]: dragnet-ransomware-2022-0626 — Mass File Rename (alphv)
// Status: deprecated | Level: high | ID: fe5899fd-2460-5455-9ecc-1c6d7811d4e5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
