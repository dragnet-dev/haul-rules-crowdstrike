// Dragnet [Ransomware]: dragnet-ransomware-2025-5839 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: f0a7b9d1-2ded-53de-a07d-c1f5456162da

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
