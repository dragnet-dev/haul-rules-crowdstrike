// Dragnet [Ransomware]: dragnet-ransomware-2022-1093 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: c1fc638c-7f70-5219-8102-3f8d75a737d6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
