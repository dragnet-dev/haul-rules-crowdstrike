// Dragnet [Ransomware]: dragnet-ransomware-2025-1948 — Mass File Rename (securotrop)
// Status: experimental | Level: high | ID: a9ca6651-f391-5713-a9f2-4886cfe44480

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
