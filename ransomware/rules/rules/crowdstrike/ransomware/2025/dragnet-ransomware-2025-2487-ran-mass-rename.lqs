// Dragnet [Ransomware]: dragnet-ransomware-2025-2487 — Mass File Rename (thegentlemen)
// Status: experimental | Level: high | ID: d8776056-6524-56a6-8497-abad8074b3ca

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
