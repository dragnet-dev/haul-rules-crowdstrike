// Dragnet [Ransomware]: dragnet-ransomware-2023-1265 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 9da01ddf-f87e-5598-86f3-5075044a99ec

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
