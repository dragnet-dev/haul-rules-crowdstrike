// Dragnet [Ransomware]: dragnet-ransomware-2023-4878 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 189ef785-3fc1-5772-b6c3-035c436ee366

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
