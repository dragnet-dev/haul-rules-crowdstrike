// Dragnet [Ransomware]: dragnet-ransomware-2022-2922 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 539ff3af-fdfa-578e-8ffc-e13c73d9faa8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
