// Dragnet [Ransomware]: dragnet-ransomware-2023-3769 — Mass File Rename (ransomhouse)
// Status: experimental | Level: high | ID: 7a8f17db-7088-54f4-8b0d-e41720e18899

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
