// Dragnet [Ransomware]: dragnet-ransomware-2024-4028 — Mass File Rename (threeam)
// Status: experimental | Level: high | ID: bec552bc-8896-5d13-8b3c-75edf2da2a42

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
