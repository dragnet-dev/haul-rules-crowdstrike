// Dragnet [Ransomware]: dragnet-ransomware-2022-0728 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 6a03aff3-0f9b-506b-a447-dcae7a2e6a8c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
