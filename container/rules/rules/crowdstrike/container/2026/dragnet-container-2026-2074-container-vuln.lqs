// Dragnet [Container]: dragnet-container-2026-2074 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 8364599d-aa29-582d-a507-943e73176989

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:5*)
| table([timestamp, ComputerName])
| limit(1000)
