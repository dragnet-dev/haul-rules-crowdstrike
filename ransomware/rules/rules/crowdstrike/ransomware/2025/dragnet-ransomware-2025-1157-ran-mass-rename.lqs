// Dragnet [Ransomware]: dragnet-ransomware-2025-1157 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: 686997c3-28c2-5a60-ae94-a2845ec0ce4b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
