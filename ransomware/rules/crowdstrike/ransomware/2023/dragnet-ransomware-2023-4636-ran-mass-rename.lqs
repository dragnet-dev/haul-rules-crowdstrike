// Dragnet [Ransomware]: dragnet-ransomware-2023-4636 — Mass File Rename (vendetta)
// Status: deprecated | Level: high | ID: 94d670f8-413a-5f7c-9922-05d52214c8da

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
