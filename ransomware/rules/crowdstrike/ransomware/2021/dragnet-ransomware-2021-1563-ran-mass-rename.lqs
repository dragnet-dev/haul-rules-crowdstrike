// Dragnet [Ransomware]: dragnet-ransomware-2021-1563 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: d176925e-33a1-59db-99af-14060d5b1b44

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
