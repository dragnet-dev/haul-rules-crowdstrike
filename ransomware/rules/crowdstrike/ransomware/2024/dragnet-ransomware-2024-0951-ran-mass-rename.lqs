// Dragnet [Ransomware]: dragnet-ransomware-2024-0951 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: 87edf90c-d5b1-5e3e-a4aa-4b17787e4d97

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
