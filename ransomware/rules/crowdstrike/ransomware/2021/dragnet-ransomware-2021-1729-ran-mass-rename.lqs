// Dragnet [Ransomware]: dragnet-ransomware-2021-1729 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 487758b0-5b13-5a34-acaf-390d49126e8d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
