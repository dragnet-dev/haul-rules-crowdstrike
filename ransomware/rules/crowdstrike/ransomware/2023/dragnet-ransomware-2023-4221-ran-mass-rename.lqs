// Dragnet [Ransomware]: dragnet-ransomware-2023-4221 — Mass File Rename (cloak)
// Status: deprecated | Level: high | ID: 967d860b-dc3b-51e4-accd-54443baf5c9e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
