// Dragnet [Ransomware]: dragnet-ransomware-2022-0686 — Mass File Rename (medusalocker)
// Status: deprecated | Level: high | ID: 20bdbaf2-b858-5984-a038-d0f09624762a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
