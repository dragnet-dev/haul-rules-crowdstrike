// Dragnet [Ransomware]: dragnet-ransomware-2024-4853 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 6c74757c-c424-5e01-8be9-76f36dd67bd1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
