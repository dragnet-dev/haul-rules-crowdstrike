// Dragnet [Container]: dragnet-container-2026-2578 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 888e9c67-4ab7-531a-8d9b-321f8d42d0e1

#event_simpleName=*
| (ImageFileName = *ubuntu:14.04* OR ImageFileName = *ubuntu:16.04* OR ImageFileName = *ubuntu:16.04-ESM* OR ImageFileName = *ubuntu:16.10* OR ImageFileName = *ubuntu:17.04*)
| table([timestamp, ComputerName])
| limit(1000)
