// Dragnet [Ransomware]: dragnet-ransomware-2025-6404 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: c9ec9801-485b-5104-8ab3-a8a3e88e2ba4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
