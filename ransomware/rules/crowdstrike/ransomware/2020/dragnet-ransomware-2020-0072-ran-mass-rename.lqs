// Dragnet [Ransomware]: dragnet-ransomware-2020-0072 — Mass File Rename (revil)
// Status: deprecated | Level: high | ID: b44f1164-5468-5879-b5a1-1e96c9222b41

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
