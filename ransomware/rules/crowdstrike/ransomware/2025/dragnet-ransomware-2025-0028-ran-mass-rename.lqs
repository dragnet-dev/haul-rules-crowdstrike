// Dragnet [Ransomware]: dragnet-ransomware-2025-0028 — Mass File Rename (cicada3301)
// Status: experimental | Level: high | ID: 42c275dc-7853-591e-a1d2-dd1478718783

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
