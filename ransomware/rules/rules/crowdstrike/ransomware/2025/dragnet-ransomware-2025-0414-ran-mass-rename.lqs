// Dragnet [Ransomware]: dragnet-ransomware-2025-0414 — Mass File Rename (payoutsking)
// Status: deprecated | Level: high | ID: 88d63c17-8c54-5ff5-87c8-5ff1db7a264b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
