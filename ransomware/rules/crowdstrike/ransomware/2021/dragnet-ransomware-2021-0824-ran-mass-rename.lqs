// Dragnet [Ransomware]: dragnet-ransomware-2021-0824 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 4a7fd249-b9eb-516e-86f9-4f83bfc22359

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
