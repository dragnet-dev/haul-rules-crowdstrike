// Dragnet [Ransomware]: dragnet-ransomware-2026-3542 — Mass File Rename (payload)
// Status: stable | Level: high | ID: 5cfec16b-36c0-5710-b133-1b0549f1cdd5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
