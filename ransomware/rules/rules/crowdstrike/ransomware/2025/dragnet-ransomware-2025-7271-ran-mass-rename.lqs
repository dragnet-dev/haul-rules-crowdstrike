// Dragnet [Ransomware]: dragnet-ransomware-2025-7271 — Mass File Rename (sinobi)
// Status: experimental | Level: high | ID: 13b92e21-7f91-5ff1-85fc-ccde7b2f9f1e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
