// Dragnet [Ransomware]: dragnet-ransomware-2023-0986 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: c81d92e1-7486-5559-bc1b-d6362b6b3fc2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
