// Dragnet [Ransomware]: dragnet-ransomware-2025-1283 — Mass File Rename (lockbit5)
// Status: test | Level: high | ID: d45f32e0-d97f-5159-b59a-0b3b63777301

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
