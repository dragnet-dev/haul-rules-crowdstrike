// Dragnet [Ransomware]: dragnet-ransomware-2021-1687 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: d2406818-2099-5bb2-aa5a-1d0fcacb5cf2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
