// Dragnet [Ransomware]: dragnet-ransomware-2023-3607 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: ad98dd31-46fa-506f-b6e4-f1a10186c29b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
