// Dragnet [Ransomware]: dragnet-ransomware-2024-4319 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 1e1b9314-513e-5251-8056-6cb49263c48d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
