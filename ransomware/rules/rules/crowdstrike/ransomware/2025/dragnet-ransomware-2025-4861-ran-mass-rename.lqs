// Dragnet [Ransomware]: dragnet-ransomware-2025-4861 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 5147a1df-b557-5b50-86a1-b2aba65cfd8e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
