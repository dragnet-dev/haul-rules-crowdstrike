// Dragnet [Ransomware]: dragnet-ransomware-2026-0577 — Mass File Rename (dragonforce)
// Status: stable | Level: high | ID: dcee0eea-2e90-5f4e-8e47-ade10ba51d99

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
