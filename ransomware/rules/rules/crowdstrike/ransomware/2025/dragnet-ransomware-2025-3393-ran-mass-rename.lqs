// Dragnet [Ransomware]: dragnet-ransomware-2025-3393 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: a54957b1-cdfb-5062-bc00-2f305ba100d7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
