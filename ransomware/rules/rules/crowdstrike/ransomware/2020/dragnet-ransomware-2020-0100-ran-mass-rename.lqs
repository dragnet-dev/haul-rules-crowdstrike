// Dragnet [Ransomware]: dragnet-ransomware-2020-0100 — Mass File Rename (ryuk)
// Status: deprecated | Level: high | ID: 6877355d-4bdd-5c13-b018-881dc3b0cb1b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
