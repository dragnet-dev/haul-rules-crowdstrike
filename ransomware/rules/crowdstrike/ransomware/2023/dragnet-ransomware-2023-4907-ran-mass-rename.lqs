// Dragnet [Ransomware]: dragnet-ransomware-2023-4907 — Mass File Rename (ElDorado)
// Status: deprecated | Level: high | ID: d319c21c-85d5-5ee5-b58f-3df921bdc18a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
