// Dragnet [Container]: dragnet-container-2026-0225 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 8662b5a1-5714-5bfd-b765-2412a89701e8

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *ubuntu:12.04*)
| table([timestamp, ComputerName])
| limit(1000)
