// Dragnet [Ransomware]: dragnet-ransomware-2022-1079 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 91329c6f-c66b-51b6-a3af-004c2f3f2f99

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
