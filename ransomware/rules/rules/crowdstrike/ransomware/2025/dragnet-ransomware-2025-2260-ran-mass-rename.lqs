// Dragnet [Ransomware]: dragnet-ransomware-2025-2260 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 6bf2e2bf-2727-5ad2-a9c1-8536e9b6aecd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
