// Dragnet [Ransomware]: dragnet-ransomware-2024-0306 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 50bf1412-2ac3-5eaf-9a82-6cefb319a7a4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
