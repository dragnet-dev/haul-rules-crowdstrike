// Dragnet [Ransomware]: dragnet-ransomware-2022-2409 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 8d070e7c-7122-5cc0-9c87-b99a7c2da5d0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
