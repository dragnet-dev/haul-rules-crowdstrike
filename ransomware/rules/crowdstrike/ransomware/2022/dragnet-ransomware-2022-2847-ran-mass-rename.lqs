// Dragnet [Ransomware]: dragnet-ransomware-2022-2847 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: a499a481-5b84-51a1-bebb-1cddfed8cf3f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
