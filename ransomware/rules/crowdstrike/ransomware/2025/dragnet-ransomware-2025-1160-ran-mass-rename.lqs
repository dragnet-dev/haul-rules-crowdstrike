// Dragnet [Ransomware]: dragnet-ransomware-2025-1160 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: b01d2036-76dc-5a80-93ae-c93c2f127daa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
