// Dragnet [Ransomware]: dragnet-ransomware-2023-3132 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: d94c12f8-1163-5d46-904c-0921200866b5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
