// Dragnet [Ransomware]: dragnet-ransomware-2025-6117 — Mass File Rename (sarcoma)
// Status: deprecated | Level: high | ID: c3807a3d-ec3f-5b35-acd1-acd308f24767

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
