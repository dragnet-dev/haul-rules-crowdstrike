// Dragnet [Ransomware]: dragnet-ransomware-2025-0500 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 2cf3075c-5ba0-5bc9-addd-e77fcfd7e6c8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
