// Dragnet [Ransomware]: dragnet-ransomware-2024-0017 — Mass File Rename (darkvault)
// Status: experimental | Level: high | ID: d9e305b3-c28a-59fe-86e5-beec07301527

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
