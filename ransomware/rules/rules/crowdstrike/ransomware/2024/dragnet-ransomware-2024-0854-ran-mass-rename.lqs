// Dragnet [Ransomware]: dragnet-ransomware-2024-0854 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 465eafd6-96e8-5c35-b9df-a500d23a7d2b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
