// Dragnet [Ransomware]: dragnet-ransomware-2024-4091 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: f0ff7dec-563d-5ff0-ba6a-4af77ddc7678

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
