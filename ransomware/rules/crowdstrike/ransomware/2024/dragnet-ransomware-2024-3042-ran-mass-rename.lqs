// Dragnet [Ransomware]: dragnet-ransomware-2024-3042 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 52a000b7-d157-5d47-b306-9299ad5e1e09

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
