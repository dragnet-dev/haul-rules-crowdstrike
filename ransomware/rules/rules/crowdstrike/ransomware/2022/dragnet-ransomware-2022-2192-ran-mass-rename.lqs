// Dragnet [Ransomware]: dragnet-ransomware-2022-2192 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: a7e0a4f7-6f5f-5c45-9a33-fcc6d40e76af

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
