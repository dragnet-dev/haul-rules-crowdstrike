// Dragnet [Ransomware]: dragnet-ransomware-2024-3054 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: b354d905-fafc-539a-b1ee-6b3c5049c4c7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
