// Dragnet [Ransomware]: dragnet-ransomware-2025-4123 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: ef1960df-c5df-5e95-8174-4590e984e576

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
