// Dragnet [Ransomware]: dragnet-ransomware-2021-1360 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 9622c042-3e9c-5cf7-a306-f525b258b012

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
