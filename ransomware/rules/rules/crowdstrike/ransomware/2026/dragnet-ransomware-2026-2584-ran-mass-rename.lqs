// Dragnet [Ransomware]: dragnet-ransomware-2026-2584 — Mass File Rename (safepay)
// Status: stable | Level: high | ID: 345df246-3545-5952-8a0d-45d11db28596

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
