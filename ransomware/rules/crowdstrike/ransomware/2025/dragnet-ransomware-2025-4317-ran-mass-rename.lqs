// Dragnet [Ransomware]: dragnet-ransomware-2025-4317 — Mass File Rename (rhysida)
// Status: experimental | Level: high | ID: d47d7ea6-ac0d-5939-a0a4-158118a04699

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
