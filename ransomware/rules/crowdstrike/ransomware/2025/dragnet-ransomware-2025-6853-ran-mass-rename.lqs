// Dragnet [Ransomware]: dragnet-ransomware-2025-6853 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 9cb5aca0-1502-5ac7-a281-9080eee10932

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
