// Dragnet [Ransomware]: dragnet-ransomware-2023-3793 — Mass File Rename (ransomhouse)
// Status: experimental | Level: high | ID: 7d096fb3-94b6-5d9a-9a0c-52e2121c20ac

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
