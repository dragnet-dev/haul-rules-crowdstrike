// Dragnet [Container]: dragnet-container-2024-1247 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 924975bc-58ed-5ff8-af36-6d8a5681516b

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
