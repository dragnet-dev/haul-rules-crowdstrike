// Dragnet [Ransomware]: dragnet-ransomware-2022-0642 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: a42e3009-4fd1-5c0b-a943-24227333d851

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
