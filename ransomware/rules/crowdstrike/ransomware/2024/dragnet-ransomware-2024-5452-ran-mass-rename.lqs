// Dragnet [Ransomware]: dragnet-ransomware-2024-5452 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: ea681129-06ef-58f1-a633-6896033738b7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
