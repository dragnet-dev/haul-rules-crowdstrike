// Dragnet [Ransomware]: dragnet-ransomware-2023-3550 — Mass File Rename (cuba)
// Status: deprecated | Level: high | ID: 701136d0-053d-5a4f-bb2b-8eef9528068c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
