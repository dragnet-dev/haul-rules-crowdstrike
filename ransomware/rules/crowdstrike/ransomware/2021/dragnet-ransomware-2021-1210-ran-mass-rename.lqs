// Dragnet [Ransomware]: dragnet-ransomware-2021-1210 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 183f61f4-439b-52ac-bde6-55849f56cbfa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
