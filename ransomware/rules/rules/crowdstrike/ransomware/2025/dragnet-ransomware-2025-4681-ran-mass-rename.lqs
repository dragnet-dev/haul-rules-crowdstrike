// Dragnet [Ransomware]: dragnet-ransomware-2025-4681 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 009c0c52-1188-55e0-b372-32e256f47b8b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
