// Dragnet [Ransomware]: dragnet-ransomware-2022-2716 — Mass File Rename (medusalocker)
// Status: deprecated | Level: high | ID: 8eec5065-665c-56a8-99a5-8c280cf53eef

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
