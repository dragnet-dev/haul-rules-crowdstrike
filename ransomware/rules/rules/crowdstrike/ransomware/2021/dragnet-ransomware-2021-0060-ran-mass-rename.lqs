// Dragnet [Ransomware]: dragnet-ransomware-2021-0060 — Mass File Rename (everest)
// Status: deprecated | Level: high | ID: 90fd10c2-af07-5558-bd79-8506de39cde5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
