// Dragnet [Ransomware]: dragnet-ransomware-2024-4037 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 6e9f2e67-5d57-5fb6-8cb5-b3ab6cb03f0c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
