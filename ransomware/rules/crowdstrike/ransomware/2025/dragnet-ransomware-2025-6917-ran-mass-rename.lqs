// Dragnet [Ransomware]: dragnet-ransomware-2025-6917 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: e1f291e2-5e96-5f73-aaff-951d8ca1e2d8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
