// Dragnet [Ransomware]: dragnet-ransomware-2025-1902 — Mass File Rename (rhysida)
// Status: deprecated | Level: high | ID: c8f8a545-39bb-5828-adbe-886693828517

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
