// Dragnet [Ransomware]: dragnet-ransomware-2026-0483 — Mass File Rename (medusalocker)
// Status: stable | Level: high | ID: 4bfe12b9-9c0b-5a21-b55f-085e16a94c58

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
