// Dragnet [Ransomware]: dragnet-ransomware-2023-3429 — Mass File Rename (royal)
// Status: experimental | Level: high | ID: 307535c1-3330-55c0-ab3c-552304134acd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
