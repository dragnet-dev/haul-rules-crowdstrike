// Dragnet [Container]: dragnet-container-2026-2661 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 233d0ba9-aa2d-5904-831d-149a13290f8f

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:7* OR ImageFileName = *debian:8* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:14.04*)
| table([timestamp, ComputerName])
| limit(1000)
