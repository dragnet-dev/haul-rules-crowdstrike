// Dragnet [Ransomware]: dragnet-ransomware-2022-0816 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: a9224626-b55d-5add-baf9-81116c6ce86a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
