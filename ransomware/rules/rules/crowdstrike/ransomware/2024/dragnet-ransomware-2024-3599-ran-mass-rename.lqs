// Dragnet [Ransomware]: dragnet-ransomware-2024-3599 — Mass File Rename (handala)
// Status: experimental | Level: high | ID: 992ec755-f69f-51d8-a588-2ddc929923f9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
