// Dragnet [Ransomware]: dragnet-ransomware-2024-4691 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 88a2f49b-593a-5d4c-96fa-1429ae19adce

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
