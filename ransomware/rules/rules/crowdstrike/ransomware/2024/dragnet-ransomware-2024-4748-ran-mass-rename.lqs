// Dragnet [Ransomware]: dragnet-ransomware-2024-4748 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: fe499f68-08bf-569b-9526-3c9082dc178d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
