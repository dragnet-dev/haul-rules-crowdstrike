// Dragnet [Ransomware]: dragnet-ransomware-2023-1796 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 59a12552-8206-5673-a405-9f3b3a307e78

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
