// Dragnet [Ransomware]: dragnet-ransomware-2025-2586 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: aa801899-e118-5dc0-a566-bd02897b32e0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
