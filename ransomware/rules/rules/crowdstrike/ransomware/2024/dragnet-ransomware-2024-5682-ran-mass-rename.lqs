// Dragnet [Ransomware]: dragnet-ransomware-2024-5682 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 8f238855-cf9e-546f-a7a4-15ff361cbb43

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
