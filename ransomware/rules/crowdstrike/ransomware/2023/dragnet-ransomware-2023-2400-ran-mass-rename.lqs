// Dragnet [Ransomware]: dragnet-ransomware-2023-2400 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: d18c05df-468d-5104-9d73-b626ed13724e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
