// Dragnet [Ransomware]: dragnet-ransomware-2025-7318 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 87209c63-cfe5-5a60-8d4f-52086e34c2bc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
