// Dragnet [Ransomware]: dragnet-ransomware-2021-1686 — Mass File Rename (sabbath)
// Status: deprecated | Level: high | ID: d74175e4-9fbb-5a7d-a0f8-e467afb521a9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
