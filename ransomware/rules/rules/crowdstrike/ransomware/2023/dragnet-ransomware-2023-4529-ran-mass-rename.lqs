// Dragnet [Ransomware]: dragnet-ransomware-2023-4529 — Mass File Rename (ransomed)
// Status: experimental | Level: high | ID: 92f478fe-09f4-5689-aea2-27962af51543

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
