// Dragnet [Ransomware]: dragnet-ransomware-2024-2382 — Mass File Rename (cloak)
// Status: deprecated | Level: high | ID: a6811949-29b8-5518-be0b-97dc2af84713

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
