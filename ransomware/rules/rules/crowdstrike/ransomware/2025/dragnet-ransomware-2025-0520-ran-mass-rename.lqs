// Dragnet [Ransomware]: dragnet-ransomware-2025-0520 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: d099630f-3eb6-5811-bf4b-98d7c42d425c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
