// Dragnet [Ransomware]: dragnet-ransomware-2024-4492 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: 241d8c5c-8026-5fe9-b4d7-958bea5132f9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
