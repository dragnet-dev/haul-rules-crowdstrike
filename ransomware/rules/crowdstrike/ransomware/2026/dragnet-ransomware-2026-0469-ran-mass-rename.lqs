// Dragnet [Ransomware]: dragnet-ransomware-2026-0469 — Mass File Rename (coinbasecartel)
// Status: stable | Level: high | ID: 50e22c0e-f8c7-57f8-bfaf-090a6d02ed1c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
