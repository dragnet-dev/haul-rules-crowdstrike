// Dragnet [Ransomware]: dragnet-ransomware-2025-0017 — Mass File Rename (sarcoma)
// Status: deprecated | Level: high | ID: e15eefcc-b099-5709-be86-6212993809b7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
