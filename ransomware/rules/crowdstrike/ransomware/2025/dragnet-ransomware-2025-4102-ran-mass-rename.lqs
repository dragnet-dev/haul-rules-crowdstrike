// Dragnet [Ransomware]: dragnet-ransomware-2025-4102 — Mass File Rename (moneymessage)
// Status: experimental | Level: high | ID: 28e0f075-3fbf-536d-9988-0b104dcfee0c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
