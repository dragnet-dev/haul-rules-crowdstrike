// Dragnet [Ransomware]: dragnet-ransomware-2026-2155 — Mass File Rename (dragonforce)
// Status: test | Level: high | ID: 3634a7dc-5720-5cd9-8819-be50ce6bc648

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
