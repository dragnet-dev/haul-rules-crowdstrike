// Dragnet [Ransomware]: dragnet-ransomware-2023-3860 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 9d63de35-1756-5d13-b186-512bc5c86a45

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
