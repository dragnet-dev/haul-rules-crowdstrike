// Dragnet [Ransomware]: dragnet-ransomware-2026-1713 — Mass File Rename (spacebears)
// Status: stable | Level: high | ID: a569affb-2cb0-57f5-91d4-36493979de9a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
