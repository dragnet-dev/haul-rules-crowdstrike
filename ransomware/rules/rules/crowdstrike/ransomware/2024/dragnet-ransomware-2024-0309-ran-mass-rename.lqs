// Dragnet [Ransomware]: dragnet-ransomware-2024-0309 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 73cf2f40-07fb-553e-bca2-a350291b9a06

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
