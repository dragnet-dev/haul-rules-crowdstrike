// Dragnet [Ransomware]: dragnet-ransomware-2023-1940 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 5f28b0c3-38dc-56d0-bb5f-3e99f67fe983

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
