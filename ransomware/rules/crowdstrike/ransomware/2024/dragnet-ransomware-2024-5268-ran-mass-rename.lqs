// Dragnet [Ransomware]: dragnet-ransomware-2024-5268 — Mass File Rename (kairos)
// Status: experimental | Level: high | ID: e8bff666-bec5-5378-8cbf-9ed7b073bdfc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
