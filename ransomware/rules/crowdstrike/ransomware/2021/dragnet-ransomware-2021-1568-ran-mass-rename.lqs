// Dragnet [Ransomware]: dragnet-ransomware-2021-1568 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: a92ea79e-9bad-5f22-a97f-b6956a05b1f4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
