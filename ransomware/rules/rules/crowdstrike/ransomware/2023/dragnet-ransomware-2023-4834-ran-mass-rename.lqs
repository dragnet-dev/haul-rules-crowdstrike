// Dragnet [Ransomware]: dragnet-ransomware-2023-4834 — Mass File Rename (play)
// Status: experimental | Level: high | ID: a2a2f44c-2f2b-56b1-bef7-917f8093e1c4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
