// Dragnet [Ransomware]: dragnet-ransomware-2023-3164 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 4058e378-73e9-501b-a41e-926d47c1d504

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
