// Dragnet [Ransomware]: dragnet-ransomware-2026-2558 — Mass File Rename (lockbit5)
// Status: stable | Level: high | ID: 0294632d-8a30-5fe7-8de6-a16aba74c0da

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
