// Dragnet [Ransomware]: dragnet-ransomware-2024-1138 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: 08af244f-9721-5d6f-9d13-af0d69b7fe87

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
