// Dragnet [Ransomware]: dragnet-ransomware-2026-3318 — Mass File Rename (payload)
// Status: stable | Level: high | ID: 40275b29-d1f8-5e9a-a252-b28e2c5be01a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
