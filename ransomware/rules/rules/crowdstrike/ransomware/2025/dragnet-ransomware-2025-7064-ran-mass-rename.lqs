// Dragnet [Ransomware]: dragnet-ransomware-2025-7064 — Mass File Rename (SilentRansomGroup)
// Status: deprecated | Level: high | ID: 70f25661-e6d9-5b4a-9f95-77fe853f92cd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
