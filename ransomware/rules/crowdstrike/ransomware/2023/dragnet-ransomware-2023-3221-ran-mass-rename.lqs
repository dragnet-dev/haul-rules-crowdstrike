// Dragnet [Ransomware]: dragnet-ransomware-2023-3221 — Mass File Rename (karakurt)
// Status: experimental | Level: high | ID: 6e939cc2-7885-5c18-a4be-f3999b8d5fb8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
