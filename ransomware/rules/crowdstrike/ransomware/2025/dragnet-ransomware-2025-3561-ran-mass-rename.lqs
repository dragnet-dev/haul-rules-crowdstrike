// Dragnet [Ransomware]: dragnet-ransomware-2025-3561 — Mass File Rename (interlock)
// Status: test | Level: high | ID: 1423f707-6ce2-52b4-83b5-e82a62827cee

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
