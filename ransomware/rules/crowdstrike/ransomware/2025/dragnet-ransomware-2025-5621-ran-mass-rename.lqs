// Dragnet [Ransomware]: dragnet-ransomware-2025-5621 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 2f59430e-23f9-5005-85b4-19e1a1eb2315

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
