// Dragnet [Ransomware]: dragnet-ransomware-2025-1007 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 9a0a0443-6d08-56a7-893e-72e79967a4e1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
