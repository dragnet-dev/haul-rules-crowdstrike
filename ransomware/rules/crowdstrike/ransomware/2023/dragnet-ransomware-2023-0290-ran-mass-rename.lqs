// Dragnet [Ransomware]: dragnet-ransomware-2023-0290 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 16b59e7b-1dae-5ce4-917a-4ce4e50a79db

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
