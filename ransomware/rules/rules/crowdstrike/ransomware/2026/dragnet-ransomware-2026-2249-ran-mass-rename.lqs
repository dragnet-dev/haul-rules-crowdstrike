// Dragnet [Ransomware]: dragnet-ransomware-2026-2249 — Mass File Rename (dragonforce)
// Status: stable | Level: high | ID: 969666ff-9097-580d-9c11-315d6d48b0d3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
