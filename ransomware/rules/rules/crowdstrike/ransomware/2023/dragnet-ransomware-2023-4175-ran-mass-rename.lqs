// Dragnet [Ransomware]: dragnet-ransomware-2023-4175 — Mass File Rename (noescape)
// Status: experimental | Level: high | ID: d3fa4cd4-253d-5805-a81f-32c2674c913f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
