// Dragnet [Ransomware]: dragnet-ransomware-2024-2716 — Mass File Rename (flocker)
// Status: experimental | Level: high | ID: b4092623-9c53-52da-8fb3-549c80f7ded8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
