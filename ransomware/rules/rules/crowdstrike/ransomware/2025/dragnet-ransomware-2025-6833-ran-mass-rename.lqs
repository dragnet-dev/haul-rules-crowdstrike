// Dragnet [Ransomware]: dragnet-ransomware-2025-6833 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 0afe2ea6-9db1-5020-b82a-d9a87a5a0416

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
