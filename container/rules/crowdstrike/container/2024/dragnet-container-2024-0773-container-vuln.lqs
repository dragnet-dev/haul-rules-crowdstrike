// Dragnet [Container]: dragnet-container-2024-0773 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 9b2d683c-730a-5c31-8926-c50a964d7f28

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *ubuntu:18.04* OR ImageFileName = *ubuntu:18.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
