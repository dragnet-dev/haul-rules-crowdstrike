// Dragnet [Ransomware]: dragnet-ransomware-2025-5341 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 27bb953a-96cc-5b87-9eb8-4358ee2ac125

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
