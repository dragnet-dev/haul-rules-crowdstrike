// Dragnet [Ransomware]: dragnet-ransomware-2022-2046 — Mass File Rename (royal)
// Status: deprecated | Level: high | ID: f2d35ff5-d9ae-57d0-bf07-97e7af02b4ff

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
