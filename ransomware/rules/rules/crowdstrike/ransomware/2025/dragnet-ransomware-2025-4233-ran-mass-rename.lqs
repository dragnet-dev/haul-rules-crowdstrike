// Dragnet [Ransomware]: dragnet-ransomware-2025-4233 — Mass File Rename (datacarry)
// Status: deprecated | Level: high | ID: 7199e7c0-95bb-50bb-ace3-f4c30841f22a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
