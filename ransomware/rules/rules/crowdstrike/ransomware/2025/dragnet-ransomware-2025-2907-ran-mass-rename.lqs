// Dragnet [Ransomware]: dragnet-ransomware-2025-2907 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: fdbfe7d2-2cab-5a53-98ac-0c772e823f3e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
