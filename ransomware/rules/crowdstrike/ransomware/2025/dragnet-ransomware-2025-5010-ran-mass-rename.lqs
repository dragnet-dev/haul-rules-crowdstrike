// Dragnet [Ransomware]: dragnet-ransomware-2025-5010 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 41ef9ad2-137a-5c3d-ad7a-05302a7f440c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
