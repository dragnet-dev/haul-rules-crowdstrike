// Dragnet [Ransomware]: dragnet-ransomware-2022-0591 — Mass File Rename (mindware)
// Status: deprecated | Level: high | ID: 7290a1cb-219c-5830-ba1e-5bf9e83938ef

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
