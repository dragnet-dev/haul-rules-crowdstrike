// Dragnet [Ransomware]: dragnet-ransomware-2026-1068 — Mass File Rename (thegentlemen)
// Status: stable | Level: high | ID: 71206a6f-b8d6-5c51-a300-73ac22af9f8b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
