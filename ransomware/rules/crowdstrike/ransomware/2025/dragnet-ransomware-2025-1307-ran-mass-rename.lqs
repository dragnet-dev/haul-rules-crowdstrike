// Dragnet [Ransomware]: dragnet-ransomware-2025-1307 — Mass File Rename (kraken)
// Status: experimental | Level: high | ID: 0d55603e-9ac9-5689-bf4f-3c7cd3a63591

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
