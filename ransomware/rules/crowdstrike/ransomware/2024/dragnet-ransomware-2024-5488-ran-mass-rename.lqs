// Dragnet [Ransomware]: dragnet-ransomware-2024-5488 — Mass File Rename (donutleaks)
// Status: experimental | Level: high | ID: 95a32340-905a-54fc-940e-06b097b3beb2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
