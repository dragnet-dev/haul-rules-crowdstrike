// Dragnet [Ransomware]: dragnet-ransomware-2022-2880 — Mass File Rename (icefire)
// Status: deprecated | Level: high | ID: 833a36a1-f614-58a7-951f-0a24f5d7101d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
