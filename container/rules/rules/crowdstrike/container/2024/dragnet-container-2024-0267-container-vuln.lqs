// Dragnet [Container]: dragnet-container-2024-0267 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 03d3dd40-7f0f-571c-bf22-3162c227072c

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *ubuntu:22.04*)
| table([timestamp, ComputerName])
| limit(1000)
