// Dragnet [Ransomware]: dragnet-ransomware-2025-2439 — Mass File Rename (thegentlemen)
// Status: experimental | Level: high | ID: f631d7bd-4d8b-571e-ad4a-858c16f252ec

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
