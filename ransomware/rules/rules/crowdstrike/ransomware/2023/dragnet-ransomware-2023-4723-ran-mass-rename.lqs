// Dragnet [Ransomware]: dragnet-ransomware-2023-4723 — Mass File Rename (snatch)
// Status: experimental | Level: high | ID: d9111130-cecb-597c-a518-92b457c1cda6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
