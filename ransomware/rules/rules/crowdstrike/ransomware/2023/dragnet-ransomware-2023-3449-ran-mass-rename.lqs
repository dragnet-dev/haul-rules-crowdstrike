// Dragnet [Ransomware]: dragnet-ransomware-2023-3449 — Mass File Rename (qilin)
// Status: deprecated | Level: high | ID: f9736443-248e-55a1-a4ba-e43538230e2e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
