// Dragnet [Ransomware]: dragnet-ransomware-2021-0921 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 0dde4c04-72f1-5be1-aa44-6be872755c0d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
