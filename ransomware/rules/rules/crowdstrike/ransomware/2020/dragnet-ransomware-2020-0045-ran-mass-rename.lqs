// Dragnet [Ransomware]: dragnet-ransomware-2020-0045 — Mass File Rename (ransomexx)
// Status: deprecated | Level: high | ID: ecc4c193-ccee-5de1-8b2a-7cbcdb17fa2f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
