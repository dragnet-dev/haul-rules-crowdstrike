// Dragnet [Ransomware]: dragnet-ransomware-2025-2371 — Mass File Rename (monti)
// Status: experimental | Level: high | ID: 3cefa09e-ff82-5d16-8ef3-6316047f22bc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
