// Dragnet [Ransomware]: dragnet-ransomware-2023-3830 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 683e2915-9aa0-5b4b-a71a-1fab51132414

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
