// Dragnet [Ransomware]: dragnet-ransomware-2026-2573 — Mass File Rename (medusalocker)
// Status: stable | Level: high | ID: 33f97173-4d13-5c58-bc77-8c3b76aac667

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
