// Dragnet [Ransomware]: dragnet-ransomware-2021-1460 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: ecb9f6d5-bed0-52e1-b4d0-da05d1a39c98

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
