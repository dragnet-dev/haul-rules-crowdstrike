// Dragnet [Container]: dragnet-container-2025-0444 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 5a197067-f8da-5c25-8329-e38d6476fcb4

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
