// Dragnet [Ransomware]: dragnet-ransomware-2026-2555 — Mass File Rename (aurora)
// Status: stable | Level: high | ID: e7d53bd1-ad65-58b9-81cb-885fc0519daa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
