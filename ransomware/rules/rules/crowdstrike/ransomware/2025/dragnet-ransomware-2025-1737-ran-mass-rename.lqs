// Dragnet [Ransomware]: dragnet-ransomware-2025-1737 — Mass File Rename (BrainCipher)
// Status: experimental | Level: high | ID: e4048abc-9d76-5a09-8d7d-dedb2d2dcb6b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
