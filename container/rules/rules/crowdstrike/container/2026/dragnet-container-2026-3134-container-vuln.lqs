// Dragnet [Container]: dragnet-container-2026-3134 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 26814d60-0ee6-511d-86e0-e4f370c5c7c1

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:7* OR ImageFileName = *debian:8* OR ImageFileName = *photon os:3.0* OR ImageFileName = *photon os:4.0* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:16.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
