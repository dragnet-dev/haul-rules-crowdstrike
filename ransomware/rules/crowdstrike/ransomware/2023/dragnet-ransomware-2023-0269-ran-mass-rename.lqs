// Dragnet [Ransomware]: dragnet-ransomware-2023-0269 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 0daae3d5-93af-5fd5-bc4c-6beb4c0f1eae

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
