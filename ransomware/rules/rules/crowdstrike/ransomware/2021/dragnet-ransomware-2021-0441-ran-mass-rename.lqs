// Dragnet [Ransomware]: dragnet-ransomware-2021-0441 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 64ce819f-74c3-531b-b409-bde1da9c75a5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
