// Dragnet [Ransomware]: dragnet-ransomware-2025-5061 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 44555c26-bea9-578b-a50f-c4933e8b05db

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
