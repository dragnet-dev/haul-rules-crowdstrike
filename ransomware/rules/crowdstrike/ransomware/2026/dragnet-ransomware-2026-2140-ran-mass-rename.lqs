// Dragnet [Ransomware]: dragnet-ransomware-2026-2140 — Mass File Rename (AiLock)
// Status: deprecated | Level: high | ID: 7ed253df-d936-5955-8530-f11ff608690c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
