// Dragnet [Ransomware]: dragnet-ransomware-2025-4074 — Mass File Rename (lockbit5)
// Status: test | Level: high | ID: 86b5b3d1-505d-5bce-8b20-a3952c48b797

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
