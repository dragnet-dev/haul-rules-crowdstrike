// Dragnet [Ransomware]: dragnet-ransomware-2024-3161 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: eba13946-e489-50b1-99cd-c839c49c120e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
