// Dragnet [Ransomware]: dragnet-ransomware-2026-2466 — Mass File Rename (BrainCipher)
// Status: stable | Level: high | ID: c352ef68-0edf-5284-978e-577563111da8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
