// Dragnet [Ransomware]: dragnet-ransomware-2025-7472 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 957bf80c-c9fc-5829-9dd0-9cc221587d85

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
