// Dragnet [Ransomware]: dragnet-ransomware-2026-3177 — Mass File Rename (nightspire)
// Status: deprecated | Level: high | ID: 4d464282-a627-5746-a5ec-40b336b5076a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
