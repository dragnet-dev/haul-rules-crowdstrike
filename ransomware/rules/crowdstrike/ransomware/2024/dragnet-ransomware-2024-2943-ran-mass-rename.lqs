// Dragnet [Ransomware]: dragnet-ransomware-2024-2943 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 19632df0-c453-551c-a252-dd17a4f1f8d8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
