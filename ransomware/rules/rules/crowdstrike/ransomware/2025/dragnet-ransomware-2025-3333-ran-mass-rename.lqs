// Dragnet [Ransomware]: dragnet-ransomware-2025-3333 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 5e40b095-fab4-54c9-815d-31fe93ebf89c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
