// Dragnet [Ransomware]: dragnet-ransomware-2026-3150 — Mass File Rename (incransom)
// Status: test | Level: high | ID: 0e49371c-3dca-5fd6-bdd8-3440ce0663cf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
