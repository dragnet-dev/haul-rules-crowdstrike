// Dragnet [Ransomware]: dragnet-ransomware-2025-3399 — Mass File Rename (dragonforce)
// Status: test | Level: high | ID: 3690d50a-0e7c-5c12-a30c-caa8afd3473d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
