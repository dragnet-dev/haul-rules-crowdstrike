// Dragnet [Ransomware]: dragnet-ransomware-2022-0479 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: c46a1514-8b54-5255-a44e-6a53ad934e30

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
