// Dragnet [Ransomware]: dragnet-ransomware-2023-2466 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 3f7493e3-55f6-5999-bd3d-d00bb17ab98d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
