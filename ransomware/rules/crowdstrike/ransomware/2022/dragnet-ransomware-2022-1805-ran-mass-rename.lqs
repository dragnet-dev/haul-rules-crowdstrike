// Dragnet [Ransomware]: dragnet-ransomware-2022-1805 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 2c5e24f7-9fba-5109-a837-48a136b6b483

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
