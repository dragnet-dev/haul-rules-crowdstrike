// Dragnet [Ransomware]: dragnet-ransomware-2026-0210 — Mass File Rename (incransom)
// Status: test | Level: high | ID: d557312d-4283-563c-8692-29023404d36e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
