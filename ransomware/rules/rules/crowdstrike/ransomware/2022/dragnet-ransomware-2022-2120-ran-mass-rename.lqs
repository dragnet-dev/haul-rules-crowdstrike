// Dragnet [Ransomware]: dragnet-ransomware-2022-2120 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 1bfa0e6d-73dc-5640-94c6-97ddb4d5d268

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
