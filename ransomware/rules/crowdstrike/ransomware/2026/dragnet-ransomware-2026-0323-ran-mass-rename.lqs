// Dragnet [Ransomware]: dragnet-ransomware-2026-0323 — Mass File Rename (genesis)
// Status: stable | Level: high | ID: b2df5977-472d-531d-87a9-1bc1f26b5069

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
