// Dragnet [Ransomware]: dragnet-ransomware-2023-2954 — Mass File Rename (ragnarlocker)
// Status: experimental | Level: high | ID: def302b6-863f-5c08-afdf-f29150f754a0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
