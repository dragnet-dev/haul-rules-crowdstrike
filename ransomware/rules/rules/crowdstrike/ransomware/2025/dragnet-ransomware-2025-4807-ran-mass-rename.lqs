// Dragnet [Ransomware]: dragnet-ransomware-2025-4807 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 01fd533b-574a-524a-accf-05ab2d4b5145

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
