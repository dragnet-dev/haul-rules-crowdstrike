// Dragnet [Ransomware]: dragnet-ransomware-2025-7581 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 9e452eb6-d060-54ea-803c-53bded2d8252

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
