// Dragnet [Ransomware]: dragnet-ransomware-2021-0314 — Mass File Rename (mountlocker)
// Status: deprecated | Level: high | ID: 36f112ac-db3e-593b-9992-a7e9e8a478d7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
