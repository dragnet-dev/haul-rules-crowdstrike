// Dragnet [Ransomware]: dragnet-ransomware-2023-4408 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 3f8462b6-496a-5204-bb81-d62cde8b8b8c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
