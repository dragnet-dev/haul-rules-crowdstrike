// Dragnet [Ransomware]: dragnet-ransomware-2023-3872 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: 65fec74e-34d5-5bf1-952c-dfc7f1fc343c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
