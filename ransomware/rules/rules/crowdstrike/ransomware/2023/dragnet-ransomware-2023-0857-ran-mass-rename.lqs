// Dragnet [Ransomware]: dragnet-ransomware-2023-0857 — Mass File Rename (knight)
// Status: experimental | Level: high | ID: ee8d0719-b90d-5a18-b9ff-4c71f67981ec

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
