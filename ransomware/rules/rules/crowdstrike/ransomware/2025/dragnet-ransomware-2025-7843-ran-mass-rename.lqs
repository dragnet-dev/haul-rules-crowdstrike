// Dragnet [Ransomware]: dragnet-ransomware-2025-7843 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: affd8388-c5d4-5ee8-bf77-edab4a650ed8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
