// Dragnet [Ransomware]: dragnet-ransomware-2022-1646 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 552db520-93c0-5245-a4e4-08016face1da

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
