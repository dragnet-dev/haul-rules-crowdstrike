// Dragnet [Ransomware]: dragnet-ransomware-2025-4739 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 9aaed409-bd36-557f-82c4-4cb27498d0e8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
