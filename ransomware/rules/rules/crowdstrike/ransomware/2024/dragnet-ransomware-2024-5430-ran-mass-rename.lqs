// Dragnet [Ransomware]: dragnet-ransomware-2024-5430 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 4b437be9-9d19-541a-9cba-a221cf10c63d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
