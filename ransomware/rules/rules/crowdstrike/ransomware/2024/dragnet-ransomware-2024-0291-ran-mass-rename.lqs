// Dragnet [Ransomware]: dragnet-ransomware-2024-0291 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 86ddb9b0-8b35-521f-aa5f-a5ffe4a64a91

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
