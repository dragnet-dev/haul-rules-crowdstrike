// Dragnet [Ransomware]: dragnet-ransomware-2023-1494 — Mass File Rename (nokoyawa)
// Status: experimental | Level: high | ID: b9e36092-a451-5043-944b-322c972736dc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
