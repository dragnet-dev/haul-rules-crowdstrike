// Dragnet [Ransomware]: dragnet-ransomware-2025-3832 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 04246025-a0c7-59d6-8c75-38969dbe4b91

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
