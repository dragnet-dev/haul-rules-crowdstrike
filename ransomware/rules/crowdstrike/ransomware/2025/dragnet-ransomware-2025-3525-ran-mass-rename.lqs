// Dragnet [Ransomware]: dragnet-ransomware-2025-3525 — Mass File Rename (cloak)
// Status: deprecated | Level: high | ID: 616128a1-7534-59b6-99c0-84168fab89ef

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
