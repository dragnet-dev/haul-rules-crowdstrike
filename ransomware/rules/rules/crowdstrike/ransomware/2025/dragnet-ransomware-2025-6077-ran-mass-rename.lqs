// Dragnet [Ransomware]: dragnet-ransomware-2025-6077 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 6842208e-bcd7-56a1-a764-d6cfe50a8805

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
