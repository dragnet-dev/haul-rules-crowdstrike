// Dragnet [Ransomware]: dragnet-ransomware-2024-5462 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: 6d979e4b-7ab5-5106-9572-cbac1ff9a0de

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
