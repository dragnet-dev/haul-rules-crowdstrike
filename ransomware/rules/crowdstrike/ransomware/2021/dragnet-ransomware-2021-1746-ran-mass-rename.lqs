// Dragnet [Ransomware]: dragnet-ransomware-2021-1746 — Mass File Rename (alphv)
// Status: deprecated | Level: high | ID: cca4f7d1-c25b-55a2-858d-aff1771f715a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
