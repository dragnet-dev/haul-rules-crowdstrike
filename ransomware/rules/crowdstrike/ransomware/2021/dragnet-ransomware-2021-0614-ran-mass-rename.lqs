// Dragnet [Ransomware]: dragnet-ransomware-2021-0614 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: 777dfb23-9340-519e-a817-57c1e8993849

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
