// Dragnet [Ransomware]: dragnet-ransomware-2024-2766 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 6c6bc75e-be40-54da-9fd5-cdcde6183534

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
