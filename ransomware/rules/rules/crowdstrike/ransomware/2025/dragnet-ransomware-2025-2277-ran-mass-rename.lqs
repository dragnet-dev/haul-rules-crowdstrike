// Dragnet [Ransomware]: dragnet-ransomware-2025-2277 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 177947fb-e617-50e5-96bf-ceb0babf2682

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
