// Dragnet [Ransomware]: dragnet-ransomware-2022-1581 — Mass File Rename (play)
// Status: deprecated | Level: high | ID: de7bfcd4-54c1-542e-bed1-44879a0eb8fc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
