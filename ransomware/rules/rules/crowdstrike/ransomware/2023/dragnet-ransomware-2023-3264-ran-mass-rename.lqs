// Dragnet [Ransomware]: dragnet-ransomware-2023-3264 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: cbee3ebf-ed53-5fad-91ce-4d17aa3bae6f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
