// Dragnet [Ransomware]: dragnet-ransomware-2025-2284 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 73be480b-efe5-5948-8a37-c6653c7b96f5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
