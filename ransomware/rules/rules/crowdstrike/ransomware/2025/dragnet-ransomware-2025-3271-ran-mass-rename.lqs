// Dragnet [Ransomware]: dragnet-ransomware-2025-3271 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 523ed7c0-8ba2-5934-a08b-6d79df1dce2c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
