// Dragnet [Ransomware]: dragnet-ransomware-2021-1177 — Mass File Rename (payloadbin)
// Status: deprecated | Level: high | ID: c4f28d80-19e6-504f-b06c-8057a004cf2d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
