// Dragnet [Ransomware]: dragnet-ransomware-2023-3026 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 7aa629cf-4e1b-5d24-99a4-baae89943271

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
