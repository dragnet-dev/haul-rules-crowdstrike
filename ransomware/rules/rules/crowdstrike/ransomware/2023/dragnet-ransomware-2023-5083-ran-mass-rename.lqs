// Dragnet [Ransomware]: dragnet-ransomware-2023-5083 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 51b67e7c-fa91-563c-bfaf-e94d781c448c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
