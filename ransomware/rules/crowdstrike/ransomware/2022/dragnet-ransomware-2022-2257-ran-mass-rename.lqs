// Dragnet [Ransomware]: dragnet-ransomware-2022-2257 — Mass File Rename (snatch)
// Status: deprecated | Level: high | ID: 7de1f9df-9fa5-501e-8f98-d9af265365ba

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
