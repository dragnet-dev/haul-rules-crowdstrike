// Dragnet [Ransomware]: dragnet-ransomware-2025-1451 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 21f7fb11-c4e4-53a8-8435-974fcac78b09

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
