// Dragnet [Ransomware]: dragnet-ransomware-2025-2202 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: bbb61472-f51a-54e1-806f-e4e611729c91

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
