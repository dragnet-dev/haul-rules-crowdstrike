// Dragnet [Ransomware]: dragnet-ransomware-2025-6875 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 59a94a55-d7a9-5187-9d2f-2a9181d5febc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
