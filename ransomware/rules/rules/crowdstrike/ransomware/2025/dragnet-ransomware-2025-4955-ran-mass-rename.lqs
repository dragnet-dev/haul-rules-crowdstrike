// Dragnet [Ransomware]: dragnet-ransomware-2025-4955 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 950cdc9c-79cc-5110-a2dd-a436467fed46

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
