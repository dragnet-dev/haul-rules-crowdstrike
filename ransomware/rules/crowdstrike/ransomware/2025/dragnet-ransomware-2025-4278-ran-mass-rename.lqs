// Dragnet [Ransomware]: dragnet-ransomware-2025-4278 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 09e90554-8c21-5a79-b3cc-9b641a8e807c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
