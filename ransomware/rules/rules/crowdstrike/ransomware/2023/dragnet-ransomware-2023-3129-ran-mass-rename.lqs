// Dragnet [Ransomware]: dragnet-ransomware-2023-3129 — Mass File Rename (threeam)
// Status: experimental | Level: high | ID: b07ba980-00ad-5954-a526-93e1d11e1a3b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
