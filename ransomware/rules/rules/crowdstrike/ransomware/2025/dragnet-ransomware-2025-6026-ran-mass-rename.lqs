// Dragnet [Ransomware]: dragnet-ransomware-2025-6026 — Mass File Rename (sinobi)
// Status: experimental | Level: high | ID: 02927240-ddda-505b-a007-3a835c0544ff

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
