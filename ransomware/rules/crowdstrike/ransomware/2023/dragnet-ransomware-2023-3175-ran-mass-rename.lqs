// Dragnet [Ransomware]: dragnet-ransomware-2023-3175 — Mass File Rename (stormous)
// Status: deprecated | Level: high | ID: 1c82fdbf-7338-5178-a1b3-826577e0fd35

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
