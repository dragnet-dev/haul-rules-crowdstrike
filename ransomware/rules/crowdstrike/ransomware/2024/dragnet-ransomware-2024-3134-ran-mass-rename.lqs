// Dragnet [Ransomware]: dragnet-ransomware-2024-3134 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: a2950140-b778-560b-9ac9-8f6f65bf902b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
