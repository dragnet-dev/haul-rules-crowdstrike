// Dragnet [Ransomware]: dragnet-ransomware-2024-0952 — Mass File Rename (sarcoma)
// Status: deprecated | Level: high | ID: 7996f231-0959-5582-90af-5b19eca0e198

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
