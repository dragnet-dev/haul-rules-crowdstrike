// Dragnet [Ransomware]: dragnet-ransomware-2025-3273 — Mass File Rename (shinyhunters)
// Status: experimental | Level: high | ID: 73281c89-c69d-5a75-8688-e8b07cdc6e9b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
