// Dragnet [Ransomware]: dragnet-ransomware-2024-3705 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 4f337d83-b84b-59d6-83ae-cd8dfbff076e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
