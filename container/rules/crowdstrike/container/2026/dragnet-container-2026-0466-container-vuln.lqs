// Dragnet [Container]: dragnet-container-2026-0466 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: f77f0acf-208d-54a1-aff8-f84c55e4ff36

#event_simpleName=*
| (ImageFileName = *chainguard:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
