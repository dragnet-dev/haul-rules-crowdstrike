// Dragnet [Ransomware]: dragnet-ransomware-2026-3307 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: e6fe3bd5-d010-584e-afa4-0ce6f1f75c3c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
