// Dragnet [Ransomware]: dragnet-ransomware-2020-0115 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 95e4f434-5553-5be2-acc5-5f0d9fb6089b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
