// Dragnet [Ransomware]: dragnet-ransomware-2021-0755 — Mass File Rename (avaddon)
// Status: deprecated | Level: high | ID: 28b21023-e8c2-5185-8d47-d82d9d3ea426

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
