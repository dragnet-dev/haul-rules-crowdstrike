// Dragnet [Ransomware]: dragnet-ransomware-2022-2114 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 5b18aa1c-7dd7-533b-9831-00ea452379ce

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
