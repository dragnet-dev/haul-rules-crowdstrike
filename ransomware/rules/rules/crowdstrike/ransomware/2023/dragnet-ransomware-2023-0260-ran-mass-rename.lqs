// Dragnet [Ransomware]: dragnet-ransomware-2023-0260 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 01bb9c66-6e14-53b2-b9aa-65e28e35b2c2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
