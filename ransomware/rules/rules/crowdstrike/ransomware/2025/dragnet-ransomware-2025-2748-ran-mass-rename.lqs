// Dragnet [Ransomware]: dragnet-ransomware-2025-2748 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 8456f485-657f-504c-a02a-7f065890e6e8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
