// Dragnet [Ransomware]: dragnet-ransomware-2024-5174 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: ac29f4aa-2d40-5385-bd43-6999ebeea83d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
