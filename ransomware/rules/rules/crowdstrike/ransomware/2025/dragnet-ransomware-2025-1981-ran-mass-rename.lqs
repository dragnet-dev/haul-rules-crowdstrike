// Dragnet [Ransomware]: dragnet-ransomware-2025-1981 — Mass File Rename (killsec)
// Status: deprecated | Level: high | ID: 438b9dfd-eca2-5e77-be4c-5680454172a9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
