// Dragnet [Ransomware]: dragnet-ransomware-2025-3806 — Mass File Rename (devman)
// Status: experimental | Level: high | ID: 679a756c-19a4-54e0-81d8-9ffa35655ea1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
