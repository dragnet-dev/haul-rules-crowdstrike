// Dragnet [Ransomware]: dragnet-ransomware-2025-5979 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: 587b8328-80bc-5d0f-a5c7-3aceff36afca

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
