// Dragnet [Ransomware]: dragnet-ransomware-2023-5367 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 540cf493-e599-5590-b4b5-f3173d0fbb78

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
