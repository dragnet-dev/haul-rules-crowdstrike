// Dragnet [Ransomware]: dragnet-ransomware-2026-0137 — Mass File Rename (nitrogen)
// Status: test | Level: high | ID: adaa00ac-0e70-58d9-9b4f-adc59d09848e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
