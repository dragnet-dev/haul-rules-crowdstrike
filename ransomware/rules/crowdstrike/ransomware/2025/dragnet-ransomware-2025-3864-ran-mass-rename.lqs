// Dragnet [Ransomware]: dragnet-ransomware-2025-3864 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 62cfbb3f-6b3a-53c1-b78f-65ac35895d23

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
