// Dragnet [Container]: dragnet-container-2025-0017 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: b66e9559-1a65-59ae-9d65-3715732d5152

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
