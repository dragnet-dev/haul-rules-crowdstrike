// Dragnet [Ransomware]: dragnet-ransomware-2025-5307 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 9fa36d68-15bd-5e24-9024-fb1837c6de92

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
