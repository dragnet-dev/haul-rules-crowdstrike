// Dragnet [Ransomware]: dragnet-ransomware-2025-7404 — Mass File Rename (worldleaks)
// Status: experimental | Level: high | ID: b52e34f5-b336-5a88-9e4e-2c2263e5c981

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
