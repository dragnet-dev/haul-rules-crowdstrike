// Dragnet [Ransomware]: dragnet-ransomware-2023-2977 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: dd5dbea6-2a37-57e6-86ad-0c55e2c6e69e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
