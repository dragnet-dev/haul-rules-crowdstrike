// Dragnet [Container]: dragnet-container-2024-0496 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 02427067-2f74-55ee-adcc-312918395eee

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *redhat/ubi9:*)
| table([timestamp, ComputerName])
| limit(1000)
