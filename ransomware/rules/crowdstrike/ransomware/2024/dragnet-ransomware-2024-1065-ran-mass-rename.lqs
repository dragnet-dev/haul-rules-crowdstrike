// Dragnet [Ransomware]: dragnet-ransomware-2024-1065 — Mass File Rename (apos)
// Status: experimental | Level: high | ID: c38dac1c-d55b-5d36-a218-6413176f490b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
