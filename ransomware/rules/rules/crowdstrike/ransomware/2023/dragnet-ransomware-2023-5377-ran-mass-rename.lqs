// Dragnet [Ransomware]: dragnet-ransomware-2023-5377 — Mass File Rename (dragonforce)
// Status: deprecated | Level: high | ID: ab68a99a-6f72-59a1-9d69-bb50c326edcb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
