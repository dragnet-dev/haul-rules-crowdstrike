// Dragnet [Ransomware]: dragnet-ransomware-2025-4113 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: a98ca43f-3865-5243-b543-9e24800922d0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
