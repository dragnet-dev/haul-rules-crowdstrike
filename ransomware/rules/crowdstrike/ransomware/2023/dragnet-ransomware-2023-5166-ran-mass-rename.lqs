// Dragnet [Ransomware]: dragnet-ransomware-2023-5166 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 2f3146be-699f-501b-9f4c-3409ff056648

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
