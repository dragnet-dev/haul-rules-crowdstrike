// Dragnet [Ransomware]: dragnet-ransomware-2025-6596 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 926b1dd9-67b8-56bb-ade2-4469acf5ebec

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
