// Dragnet [Ransomware]: dragnet-ransomware-2024-2864 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 4bfb4c22-67a8-5ecb-b4e3-4158ea7f7f40

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
