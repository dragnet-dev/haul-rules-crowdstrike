// Dragnet [Ransomware]: dragnet-ransomware-2021-1459 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 6af7e5e0-fc4b-5a43-b2ef-0eee161e456c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
