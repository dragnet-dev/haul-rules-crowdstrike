// Dragnet [Ransomware]: dragnet-ransomware-2022-1100 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 10d018d4-8697-52a4-8eea-f82d04b8413a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
