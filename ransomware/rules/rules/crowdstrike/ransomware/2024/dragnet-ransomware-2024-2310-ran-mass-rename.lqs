// Dragnet [Ransomware]: dragnet-ransomware-2024-2310 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 32301b29-2e6b-5192-8e73-84439b5849f9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
