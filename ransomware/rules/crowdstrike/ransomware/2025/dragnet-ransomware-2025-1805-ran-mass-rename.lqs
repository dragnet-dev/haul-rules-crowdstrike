// Dragnet [Ransomware]: dragnet-ransomware-2025-1805 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 0f87ab0c-aa7c-55aa-995d-1c90013b8ff2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
