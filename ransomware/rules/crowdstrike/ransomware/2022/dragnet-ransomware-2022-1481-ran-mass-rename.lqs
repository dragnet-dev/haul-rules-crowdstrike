// Dragnet [Ransomware]: dragnet-ransomware-2022-1481 — Mass File Rename (lorenz)
// Status: deprecated | Level: high | ID: 5910d0c4-ff27-522d-8e87-bbeed5eb483c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
