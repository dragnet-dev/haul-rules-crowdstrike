// Dragnet [Ransomware]: dragnet-ransomware-2023-4841 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: bfa21e69-06b5-5457-8a60-e82383a089eb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
