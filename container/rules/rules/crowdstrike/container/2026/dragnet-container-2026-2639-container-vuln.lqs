// Dragnet [Container]: dragnet-container-2026-2639 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: cc204df9-a88c-5825-be8e-e20e03b21800

#event_simpleName=*
| (ImageFileName = *debian:7* OR ImageFileName = *debian:8* OR ImageFileName = *ubuntu:14.04* OR ImageFileName = *ubuntu:16.04* OR ImageFileName = *ubuntu:16.10*)
| table([timestamp, ComputerName])
| limit(1000)
