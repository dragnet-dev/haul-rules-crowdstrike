// Dragnet [Ransomware]: dragnet-ransomware-2022-2151 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 7c0729b9-f33c-5e8a-bda5-1b636f6a9018

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
