// Dragnet [Ransomware]: dragnet-ransomware-2026-1422 — Mass File Rename (gunra)
// Status: deprecated | Level: high | ID: cfec336f-2daf-5865-9ced-ff0f0b40407d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
