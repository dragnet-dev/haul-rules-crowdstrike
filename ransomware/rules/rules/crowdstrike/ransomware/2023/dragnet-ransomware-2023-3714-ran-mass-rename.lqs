// Dragnet [Ransomware]: dragnet-ransomware-2023-3714 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 629b00b2-4d63-5280-a819-fc0cb85663d1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
