// Dragnet [Ransomware]: dragnet-ransomware-2024-0837 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 11da4629-035f-5c97-9fa9-cfd32031be0e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
