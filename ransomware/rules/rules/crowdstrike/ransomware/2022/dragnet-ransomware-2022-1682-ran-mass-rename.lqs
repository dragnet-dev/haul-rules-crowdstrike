// Dragnet [Ransomware]: dragnet-ransomware-2022-1682 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 23b8a179-f98d-5ade-97b2-4abcfc304a89

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
