// Dragnet [Ransomware]: dragnet-ransomware-2024-5890 — Mass File Rename (sarcoma)
// Status: deprecated | Level: high | ID: 868a6597-d873-5791-8bfd-df5abe6cb671

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
