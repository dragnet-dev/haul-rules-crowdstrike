// Dragnet [Ransomware]: dragnet-ransomware-2024-4450 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: eb391584-9640-5a03-b68b-3f8c7e5d0dc3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
