// Dragnet [Ransomware]: dragnet-ransomware-2022-0425 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 27d4a06f-ab99-5175-9d6f-2decfd1221e3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
