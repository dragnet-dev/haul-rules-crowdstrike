// Dragnet [Ransomware]: dragnet-ransomware-2025-3628 — Mass File Rename (nova)
// Status: experimental | Level: high | ID: 8b4dfb7e-5165-5962-9c49-244caa7fa29a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
