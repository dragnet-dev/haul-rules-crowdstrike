// Dragnet [Ransomware]: dragnet-ransomware-2022-1301 — Mass File Rename (blackbasta)
// Status: deprecated | Level: high | ID: 4ba3b755-9a00-55d5-84dc-3334329d7d5a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
