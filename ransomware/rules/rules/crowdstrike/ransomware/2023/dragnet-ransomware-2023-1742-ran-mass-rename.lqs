// Dragnet [Ransomware]: dragnet-ransomware-2023-1742 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: d5dc1115-a812-53a3-8859-d4daf52c6bd2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
