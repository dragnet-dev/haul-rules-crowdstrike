// Dragnet [Ransomware]: dragnet-ransomware-2024-2380 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 48edb837-c804-5c9b-bcd9-c77659f76d28

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
