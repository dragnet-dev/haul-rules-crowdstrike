// Dragnet [Ransomware]: dragnet-ransomware-2024-0803 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: 0fc950b6-115f-5385-a070-78b6ff89837a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
