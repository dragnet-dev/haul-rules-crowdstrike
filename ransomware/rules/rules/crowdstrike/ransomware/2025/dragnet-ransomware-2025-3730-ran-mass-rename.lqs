// Dragnet [Ransomware]: dragnet-ransomware-2025-3730 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 25989dff-8aee-5a9a-96e0-e63068126962

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
