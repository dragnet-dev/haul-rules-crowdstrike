// Dragnet [Ransomware]: dragnet-ransomware-2022-1878 — Mass File Rename (play)
// Status: deprecated | Level: high | ID: 4ca9607a-8f59-5f83-ab75-f7416abf90e6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
