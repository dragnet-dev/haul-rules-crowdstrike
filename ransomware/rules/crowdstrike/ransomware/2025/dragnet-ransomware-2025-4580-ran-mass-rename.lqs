// Dragnet [Ransomware]: dragnet-ransomware-2025-4580 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: d98da8e0-bdf4-502c-82e4-b3b8f7ecae59

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
