// Dragnet [Ransomware]: dragnet-ransomware-2024-4754 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 7b5b225a-8107-5372-972c-aa523ef67a26

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
