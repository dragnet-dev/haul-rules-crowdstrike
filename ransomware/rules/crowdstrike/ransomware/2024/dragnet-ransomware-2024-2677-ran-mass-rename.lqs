// Dragnet [Ransomware]: dragnet-ransomware-2024-2677 — Mass File Rename (meow)
// Status: experimental | Level: high | ID: 26bd0899-66be-5f12-996c-c10b10815a18

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
