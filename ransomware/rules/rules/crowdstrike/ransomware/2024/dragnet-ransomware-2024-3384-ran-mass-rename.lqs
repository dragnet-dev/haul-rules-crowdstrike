// Dragnet [Ransomware]: dragnet-ransomware-2024-3384 — Mass File Rename (ElDorado)
// Status: deprecated | Level: high | ID: cb0f9549-d045-5f0f-9233-e12e156c2244

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
