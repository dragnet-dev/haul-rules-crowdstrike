// Dragnet [Ransomware]: dragnet-ransomware-2025-6719 — Mass File Rename (direwolf)
// Status: experimental | Level: high | ID: d373cd09-44d0-52ad-ad18-e9d14f06a44c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
