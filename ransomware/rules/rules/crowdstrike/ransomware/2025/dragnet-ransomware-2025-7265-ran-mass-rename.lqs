// Dragnet [Ransomware]: dragnet-ransomware-2025-7265 — Mass File Rename (spacebears)
// Status: experimental | Level: high | ID: f2b039eb-58c6-5afc-8d0e-f1c6910efbd3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
