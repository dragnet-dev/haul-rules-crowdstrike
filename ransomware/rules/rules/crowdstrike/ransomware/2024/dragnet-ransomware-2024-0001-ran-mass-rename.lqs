// Dragnet [Ransomware]: dragnet-ransomware-2024-0001 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 387b55d5-a1be-523b-b363-554ed12d7cd1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
