// Dragnet [Ransomware]: dragnet-ransomware-2023-4327 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: ce53f892-5d21-5839-a9ec-0e41bab97d7a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
