// Dragnet [Ransomware]: dragnet-ransomware-2024-5157 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: 91543270-97e3-5088-b9b6-d46cd132fdd1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
