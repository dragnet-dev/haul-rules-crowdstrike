// Dragnet [Ransomware]: dragnet-ransomware-2025-2068 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 97001828-e1ef-5ae4-b741-4f56370d1d5e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
