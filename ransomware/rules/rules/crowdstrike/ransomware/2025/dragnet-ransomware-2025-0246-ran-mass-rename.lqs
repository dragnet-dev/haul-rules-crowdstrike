// Dragnet [Ransomware]: dragnet-ransomware-2025-0246 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 39525815-17b4-51ea-811c-e94bc4db8096

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
