// Dragnet [Ransomware]: dragnet-ransomware-2025-7251 — Mass File Rename (play)
// Status: experimental | Level: high | ID: dcd94521-6f28-59e1-8471-118ff52dbfc5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
