// Dragnet [Ransomware]: dragnet-ransomware-2024-2714 — Mass File Rename (dragonforce)
// Status: deprecated | Level: high | ID: f09a92b6-b5a5-5722-949e-4266522ab026

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
