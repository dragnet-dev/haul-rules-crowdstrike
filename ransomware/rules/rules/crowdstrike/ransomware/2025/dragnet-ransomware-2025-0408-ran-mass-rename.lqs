// Dragnet [Ransomware]: dragnet-ransomware-2025-0408 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 90e05d4d-81aa-53c3-8e8a-f28ffdb8123d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
