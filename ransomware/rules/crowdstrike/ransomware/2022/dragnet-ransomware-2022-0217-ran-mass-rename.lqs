// Dragnet [Ransomware]: dragnet-ransomware-2022-0217 — Mass File Rename (blackbasta)
// Status: deprecated | Level: high | ID: b41f8544-b551-501e-bb16-ea8704a373cf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
