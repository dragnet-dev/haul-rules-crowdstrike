// Dragnet [Ransomware]: dragnet-ransomware-2025-4593 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: 578c83f4-be50-5652-930c-ba1c4dc8338d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
