// Dragnet [Ransomware]: dragnet-ransomware-2026-0991 — Mass File Rename (dragonforce)
// Status: stable | Level: high | ID: 5fd97d3b-bc08-5c40-b484-220aeebd1724

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
