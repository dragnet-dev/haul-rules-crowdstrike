// Dragnet [Ransomware]: dragnet-ransomware-2021-1482 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: cfa3cd6d-2bae-5cc0-a61e-3dbaabd8bcdf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
