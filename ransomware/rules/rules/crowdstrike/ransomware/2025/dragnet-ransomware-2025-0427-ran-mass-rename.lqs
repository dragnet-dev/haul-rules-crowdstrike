// Dragnet [Ransomware]: dragnet-ransomware-2025-0427 — Mass File Rename (ransomhouse)
// Status: experimental | Level: high | ID: 2a552da5-fedc-5543-92cf-93443c2925c1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
