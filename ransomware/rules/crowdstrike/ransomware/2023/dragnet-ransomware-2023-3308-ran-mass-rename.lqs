// Dragnet [Ransomware]: dragnet-ransomware-2023-3308 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 63584c4f-7083-5151-ae3b-226afd88738e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
