// Dragnet [Ransomware]: dragnet-ransomware-2020-0042 — Mass File Rename (revil)
// Status: deprecated | Level: high | ID: a524c6ee-def9-530b-947b-b6eff767bb68

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
