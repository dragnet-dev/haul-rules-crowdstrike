// Dragnet [Ransomware]: dragnet-ransomware-2024-5337 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 260bb8ee-6e77-5589-9386-7eb05756d4bb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
