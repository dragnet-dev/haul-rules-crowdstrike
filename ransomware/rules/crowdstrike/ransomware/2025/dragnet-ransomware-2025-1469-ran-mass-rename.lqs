// Dragnet [Ransomware]: dragnet-ransomware-2025-1469 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: d6c75271-2ff4-508a-9961-223bc4e2c220

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
