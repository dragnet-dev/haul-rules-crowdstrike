// Dragnet [Ransomware]: dragnet-ransomware-2022-2338 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: eb9ef53a-db01-5a60-8a82-0b45e7ebefce

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
