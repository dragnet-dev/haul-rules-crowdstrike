// Dragnet [Ransomware]: dragnet-ransomware-2022-2992 — Mass File Rename (lapsus$)
// Status: deprecated | Level: high | ID: 28e7acec-cbad-5f5c-98be-39fa7aa53ad4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
