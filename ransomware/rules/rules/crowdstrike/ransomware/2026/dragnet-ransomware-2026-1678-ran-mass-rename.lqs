// Dragnet [Ransomware]: dragnet-ransomware-2026-1678 — Mass File Rename (dragonforce)
// Status: stable | Level: high | ID: e041fac7-6358-5de6-8ff4-1153b77a05a7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
