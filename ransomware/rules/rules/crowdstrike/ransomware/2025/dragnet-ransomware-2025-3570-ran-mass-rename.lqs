// Dragnet [Ransomware]: dragnet-ransomware-2025-3570 — Mass File Rename (blackshrantac)
// Status: experimental | Level: high | ID: 710e2d10-cc59-51b9-b265-15a67ea8c3d2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
