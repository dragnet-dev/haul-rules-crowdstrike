// Dragnet [Ransomware]: dragnet-ransomware-2026-0553 — Mass File Rename (nightspire)
// Status: deprecated | Level: high | ID: e75691e8-b1a3-5ec6-a745-86c4dc2a80be

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
