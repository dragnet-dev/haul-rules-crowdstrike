// Dragnet [Container]: dragnet-container-2025-0474 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 8a64595b-74d0-583e-b819-9d5280c185ff

#event_simpleName=*
| (ImageFileName = *chainguard:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
