// Dragnet [Ransomware]: dragnet-ransomware-2025-0603 — Mass File Rename (handala)
// Status: experimental | Level: high | ID: 2f11ecb8-6ca9-524e-9c86-b4a899a85eec

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
