// Dragnet [Ransomware]: dragnet-ransomware-2025-7569 — Mass File Rename (nova)
// Status: experimental | Level: high | ID: 82f3eb9a-e004-5319-9263-45d7f4579372

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
