// Dragnet [Ransomware]: dragnet-ransomware-2022-2468 — Mass File Rename (blackbasta)
// Status: deprecated | Level: high | ID: 946bddef-98d2-5e72-aa13-5bee1163b5e3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
