// Dragnet [Ransomware]: dragnet-ransomware-2025-3713 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: a3efebb7-64c8-5d53-bb65-d2a0ac943d95

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
