// Dragnet [Ransomware]: dragnet-ransomware-2023-4708 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 06f7bd15-2156-5a96-932b-87ef787f767c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
