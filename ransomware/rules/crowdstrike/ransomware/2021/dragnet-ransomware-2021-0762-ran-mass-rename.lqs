// Dragnet [Ransomware]: dragnet-ransomware-2021-0762 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 4d25242a-0d0c-5a88-a297-a6345903912e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
