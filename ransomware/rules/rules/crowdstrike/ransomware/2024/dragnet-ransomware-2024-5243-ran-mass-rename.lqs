// Dragnet [Ransomware]: dragnet-ransomware-2024-5243 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 2e7451e2-f62b-59fb-9a38-659c22d1f38a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
