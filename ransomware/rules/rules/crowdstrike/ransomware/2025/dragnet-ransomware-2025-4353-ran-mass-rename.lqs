// Dragnet [Ransomware]: dragnet-ransomware-2025-4353 — Mass File Rename (payoutsking)
// Status: experimental | Level: high | ID: 5c391fe6-2ec7-5dfb-98a4-af25a510e123

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
