// Dragnet [Ransomware]: dragnet-ransomware-2024-2230 — Mass File Rename (meow)
// Status: experimental | Level: high | ID: f3d2e17c-6d46-5d38-8852-af4a26f6f55c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
