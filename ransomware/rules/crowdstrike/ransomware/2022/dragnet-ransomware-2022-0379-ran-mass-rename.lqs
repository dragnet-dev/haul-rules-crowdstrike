// Dragnet [Ransomware]: dragnet-ransomware-2022-0379 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: c3ed2448-37a0-5acc-aa46-6c0cf62b17fb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
