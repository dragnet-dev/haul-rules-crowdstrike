// Dragnet [Ransomware]: dragnet-ransomware-2025-1999 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: f1116aea-8432-5fb5-996e-c280b0e15313

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
