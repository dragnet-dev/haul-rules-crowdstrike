// Dragnet [Ransomware]: dragnet-ransomware-2024-3043 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: b52ea8bc-7c2a-5480-9b9a-55c4814af0ac

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
