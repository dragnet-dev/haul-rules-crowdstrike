// Dragnet [Ransomware]: dragnet-ransomware-2024-0281 — Mass File Rename (unsafe)
// Status: deprecated | Level: high | ID: 76899290-a7e3-584c-903e-aeab380ea441

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
