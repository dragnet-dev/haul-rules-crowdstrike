// Dragnet [Ransomware]: dragnet-ransomware-2024-0896 — Mass File Rename (spacebears)
// Status: experimental | Level: high | ID: 537c937d-3f02-5f64-b381-3f6e9d9ff803

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
