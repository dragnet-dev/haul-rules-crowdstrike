// Dragnet [Ransomware]: dragnet-ransomware-2025-0243 — Mass File Rename (dragonforce)
// Status: test | Level: high | ID: d0fb0e82-c245-5411-97cd-eb862c7afee2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
