// Dragnet [Ransomware]: dragnet-ransomware-2024-3677 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: 06ad8ddb-17f9-5101-9a24-372647248789

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
