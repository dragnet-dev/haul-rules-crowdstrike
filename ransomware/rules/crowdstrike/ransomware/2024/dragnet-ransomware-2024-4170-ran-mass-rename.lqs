// Dragnet [Ransomware]: dragnet-ransomware-2024-4170 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: c7bbf37a-0d1c-53eb-88e8-1184b926dcba

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
