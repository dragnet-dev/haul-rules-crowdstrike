// Dragnet [Ransomware]: dragnet-ransomware-2024-4876 — Mass File Rename (dragonforce)
// Status: deprecated | Level: high | ID: c8d49974-0650-595f-b48e-ee13a5c05f9f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
