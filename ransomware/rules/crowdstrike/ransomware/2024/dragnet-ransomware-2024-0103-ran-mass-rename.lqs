// Dragnet [Ransomware]: dragnet-ransomware-2024-0103 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 6860803a-1495-5b7a-8caa-5613e5b848ae

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
