// Dragnet [Ransomware]: dragnet-ransomware-2022-0963 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: c96e49d4-950d-51c7-bbd2-696dd5fcd069

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
