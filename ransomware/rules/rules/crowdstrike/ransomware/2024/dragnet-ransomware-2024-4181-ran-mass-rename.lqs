// Dragnet [Ransomware]: dragnet-ransomware-2024-4181 — Mass File Rename (trinity)
// Status: experimental | Level: high | ID: 321f675f-0ba5-5a7d-8ecf-9e755ac0dcf2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
