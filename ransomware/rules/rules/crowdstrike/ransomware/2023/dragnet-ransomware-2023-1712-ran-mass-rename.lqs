// Dragnet [Ransomware]: dragnet-ransomware-2023-1712 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 72c64299-fdb3-5d29-a46c-83fe03b60e3e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
