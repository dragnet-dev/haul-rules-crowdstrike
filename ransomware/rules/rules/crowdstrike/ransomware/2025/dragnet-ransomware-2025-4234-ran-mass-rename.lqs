// Dragnet [Ransomware]: dragnet-ransomware-2025-4234 — Mass File Rename (nova)
// Status: experimental | Level: high | ID: 0866cb6e-f6ec-5a47-a11a-49368b3d6ad4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
