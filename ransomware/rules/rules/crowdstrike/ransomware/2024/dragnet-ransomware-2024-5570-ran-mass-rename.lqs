// Dragnet [Ransomware]: dragnet-ransomware-2024-5570 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: c0129289-a8a4-55ee-a641-d03752c27889

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
