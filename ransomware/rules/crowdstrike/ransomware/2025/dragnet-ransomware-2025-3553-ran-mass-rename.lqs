// Dragnet [Ransomware]: dragnet-ransomware-2025-3553 — Mass File Rename (lockbit5)
// Status: experimental | Level: high | ID: 907b2d8a-1e6c-5451-b50c-4e548512ae64

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
