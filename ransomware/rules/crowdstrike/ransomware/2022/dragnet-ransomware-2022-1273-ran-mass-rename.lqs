// Dragnet [Ransomware]: dragnet-ransomware-2022-1273 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: c81682a2-e2b1-5463-b4cf-2fec257efdfe

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
