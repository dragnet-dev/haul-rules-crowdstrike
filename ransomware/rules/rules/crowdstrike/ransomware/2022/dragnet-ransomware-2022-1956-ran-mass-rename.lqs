// Dragnet [Ransomware]: dragnet-ransomware-2022-1956 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 823ab8a5-08cb-5a73-aa52-50901d744377

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
