// Dragnet [Ransomware]: dragnet-ransomware-2022-1367 — Mass File Rename (pandora)
// Status: deprecated | Level: high | ID: 6bda84f2-e567-53a2-a97f-ebd4cd99f6a5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
