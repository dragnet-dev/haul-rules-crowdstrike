// Dragnet [Ransomware]: dragnet-ransomware-2025-2164 — Mass File Rename (nova)
// Status: experimental | Level: high | ID: d1dcfddd-465e-575a-ba45-b2bffce2860e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
