// Dragnet [Ransomware]: dragnet-ransomware-2025-6475 — Mass File Rename (play)
// Status: experimental | Level: high | ID: ee4198de-87f6-5656-8ed1-72f664448739

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
