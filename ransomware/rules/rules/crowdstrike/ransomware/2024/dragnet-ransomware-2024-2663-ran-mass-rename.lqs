// Dragnet [Ransomware]: dragnet-ransomware-2024-2663 — Mass File Rename (qilin)
// Status: deprecated | Level: high | ID: dccc49d6-2d73-5951-b1fd-5d5107160921

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
