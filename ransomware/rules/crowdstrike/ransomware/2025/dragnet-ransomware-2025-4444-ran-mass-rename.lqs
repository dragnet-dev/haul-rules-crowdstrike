// Dragnet [Ransomware]: dragnet-ransomware-2025-4444 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: bde99036-7393-5f8f-9794-ba4916c84217

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
