// Dragnet [Ransomware]: dragnet-ransomware-2025-7379 — Mass File Rename (morpheus)
// Status: deprecated | Level: high | ID: 8e57d7ce-adfb-5636-9c97-e38bf4a997d7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
