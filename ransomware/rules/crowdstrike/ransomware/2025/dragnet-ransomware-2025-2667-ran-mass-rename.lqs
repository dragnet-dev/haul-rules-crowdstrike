// Dragnet [Ransomware]: dragnet-ransomware-2025-2667 — Mass File Rename (warlock)
// Status: deprecated | Level: high | ID: a66f887e-229c-5fc8-9cad-9c1fc319a0c1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
