// Dragnet [Ransomware]: dragnet-ransomware-2024-1928 — Mass File Rename (argonauts)
// Status: experimental | Level: high | ID: 91864b3e-63dd-586f-a93a-48b5ab7441e4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
