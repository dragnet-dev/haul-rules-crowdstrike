// Dragnet [Ransomware]: dragnet-ransomware-2024-2515 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: dc73772e-aadb-58d9-95f1-1dac0d4a1c60

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
