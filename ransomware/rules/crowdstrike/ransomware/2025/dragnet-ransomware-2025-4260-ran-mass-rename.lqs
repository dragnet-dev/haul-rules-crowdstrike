// Dragnet [Ransomware]: dragnet-ransomware-2025-4260 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 270a6a04-9799-516f-a3fa-6f09621bd0ae

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
