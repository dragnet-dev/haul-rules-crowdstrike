// Dragnet [Ransomware]: dragnet-ransomware-2024-2795 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: df6df6db-8a19-5e87-aeb6-0f6a80cd0fc5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
