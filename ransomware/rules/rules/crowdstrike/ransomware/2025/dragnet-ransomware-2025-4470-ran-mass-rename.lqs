// Dragnet [Ransomware]: dragnet-ransomware-2025-4470 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: a33ec632-5418-5e41-9393-5789a5364dc3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
