// Dragnet [Ransomware]: dragnet-ransomware-2025-7451 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: c42ce439-68cf-5e85-babd-60cab8890078

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
