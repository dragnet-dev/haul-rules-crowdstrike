// Dragnet [Ransomware]: dragnet-ransomware-2026-1424 — Mass File Rename (embargo)
// Status: stable | Level: high | ID: 28c4ff64-9337-570f-bafa-f8931c4f370e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
