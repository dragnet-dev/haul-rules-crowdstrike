// Dragnet [Ransomware]: dragnet-ransomware-2024-4967 — Mass File Rename (qilin)
// Status: deprecated | Level: high | ID: a70b26d7-000f-551d-a2ce-219ee5779227

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
