// Dragnet [Ransomware]: dragnet-ransomware-2022-0848 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 3ffc413c-e81e-59f8-baa8-efb89c438f70

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
