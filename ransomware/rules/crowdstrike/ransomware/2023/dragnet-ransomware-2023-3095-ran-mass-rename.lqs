// Dragnet [Ransomware]: dragnet-ransomware-2023-3095 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: a8e29645-641f-5f0b-a68e-b13dd9290747

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
