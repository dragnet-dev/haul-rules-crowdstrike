// Dragnet [Ransomware]: dragnet-ransomware-2020-0011 — Mass File Rename (ragnarlocker)
// Status: deprecated | Level: high | ID: 17a36600-9737-54a1-8c41-2899252c3d85

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
