// Dragnet [Ransomware]: dragnet-ransomware-2024-4656 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 12da9978-3613-593b-b2f9-004ea8a34626

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
