// Dragnet [Ransomware]: dragnet-ransomware-2025-2632 — Mass File Rename (AiLock)
// Status: deprecated | Level: high | ID: e4645ccc-0a1e-5707-a266-8e246e3a3115

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
