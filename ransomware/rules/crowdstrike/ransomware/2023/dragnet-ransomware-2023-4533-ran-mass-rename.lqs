// Dragnet [Ransomware]: dragnet-ransomware-2023-4533 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: bc766544-6ced-5ba3-a2e2-25f3c9a9eedf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
