// Dragnet [Ransomware]: dragnet-ransomware-2021-0456 — Mass File Rename (rook)
// Status: deprecated | Level: high | ID: e0e34f5a-ad0f-5d40-8ef3-71e41ce2b183

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
