// Dragnet [Ransomware]: dragnet-ransomware-2025-2887 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: f3130f08-ed0a-5065-8f9f-aec7a9e691ed

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
