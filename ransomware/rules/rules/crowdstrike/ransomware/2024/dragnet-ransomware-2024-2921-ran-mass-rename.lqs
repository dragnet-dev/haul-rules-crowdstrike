// Dragnet [Ransomware]: dragnet-ransomware-2024-2921 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 51316176-e741-55d1-89e0-eff319a2652c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
