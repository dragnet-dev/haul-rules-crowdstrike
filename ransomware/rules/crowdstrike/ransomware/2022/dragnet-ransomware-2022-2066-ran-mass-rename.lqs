// Dragnet [Ransomware]: dragnet-ransomware-2022-2066 — Mass File Rename (bianlian)
// Status: deprecated | Level: high | ID: 864a0a42-9ef3-57f3-9de1-25f460414cf0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
