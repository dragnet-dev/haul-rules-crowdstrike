// Dragnet [Ransomware]: dragnet-ransomware-2023-4460 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: f89ebda2-b9ea-5ae5-b9f2-66678500469e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
