// Dragnet [Ransomware]: dragnet-ransomware-2025-5537 — Mass File Rename (teamxxx)
// Status: experimental | Level: high | ID: c5846620-b1b3-502e-be5a-651301f7135b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
