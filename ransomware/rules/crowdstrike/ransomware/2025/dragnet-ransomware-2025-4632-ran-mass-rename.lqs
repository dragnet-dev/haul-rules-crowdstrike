// Dragnet [Ransomware]: dragnet-ransomware-2025-4632 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 043e0892-87a9-5262-aecc-bf6ba96f7626

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
