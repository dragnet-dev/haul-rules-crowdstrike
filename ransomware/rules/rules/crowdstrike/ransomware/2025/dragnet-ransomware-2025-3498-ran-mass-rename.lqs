// Dragnet [Ransomware]: dragnet-ransomware-2025-3498 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 15c86798-5cb4-5954-b933-8d2910770914

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
