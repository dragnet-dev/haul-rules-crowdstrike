// Dragnet [Ransomware]: dragnet-ransomware-2023-1072 — Mass File Rename (metaencryptor)
// Status: experimental | Level: high | ID: 1e4a57b4-a1c1-51e4-81da-1022a6f8dcdf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
