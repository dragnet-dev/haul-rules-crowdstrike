// Dragnet [Container]: dragnet-container-2026-1943 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 14805b15-460c-58cf-9f7b-3f91c93c16bb

#event_simpleName=*
| (ImageFileName = *chainguard:* OR ImageFileName = *debian:14* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
