// Dragnet [Ransomware]: dragnet-ransomware-2026-0318 — Mass File Rename (payload)
// Status: stable | Level: high | ID: 3f13c549-57c8-5f15-881e-89fef60a3d57

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
