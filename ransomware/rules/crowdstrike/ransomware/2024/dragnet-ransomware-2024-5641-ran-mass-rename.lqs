// Dragnet [Ransomware]: dragnet-ransomware-2024-5641 — Mass File Rename (apt73)
// Status: experimental | Level: high | ID: 01ed6355-342e-5716-9dee-03d56e8f2e73

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
