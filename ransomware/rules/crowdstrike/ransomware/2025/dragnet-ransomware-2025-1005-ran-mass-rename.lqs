// Dragnet [Ransomware]: dragnet-ransomware-2025-1005 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: d3190dbb-3621-52df-a2f8-4a879fb1e8ba

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
