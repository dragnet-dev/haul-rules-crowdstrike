// Dragnet [Ransomware]: dragnet-ransomware-2023-3522 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 0f976f1a-a62c-541e-9831-034b756ad025

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
