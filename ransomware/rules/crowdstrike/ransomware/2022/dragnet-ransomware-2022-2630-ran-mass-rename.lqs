// Dragnet [Ransomware]: dragnet-ransomware-2022-2630 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: d167c628-56f3-5a08-afa3-5b53514de541

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
