// Dragnet [Ransomware]: dragnet-ransomware-2024-3151 — Mass File Rename (SilentRansomGroup)
// Status: deprecated | Level: high | ID: bbeeb717-b0b0-5c8e-8cb5-2a9885881187

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
