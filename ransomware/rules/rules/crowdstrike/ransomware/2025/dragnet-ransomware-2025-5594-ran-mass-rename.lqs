// Dragnet [Ransomware]: dragnet-ransomware-2025-5594 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: ce8ffe4c-5294-5628-aa08-b31de10bcbe1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
