// Dragnet [Ransomware]: dragnet-ransomware-2025-5618 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 0f3dab18-1930-5386-9b28-963019bbf727

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
