// Dragnet [Ransomware]: dragnet-ransomware-2026-3534 — Mass File Rename (krybit)
// Status: stable | Level: high | ID: c83d9766-3695-5f80-b5b9-7ac7b33b93eb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
