// Dragnet [Ransomware]: dragnet-ransomware-2023-0241 — Mass File Rename (ransomhouse)
// Status: experimental | Level: high | ID: 14372e48-f710-554d-a36e-14cc44b6ed46

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
