// Dragnet [Ransomware]: dragnet-ransomware-2021-0550 — Mass File Rename (avaddon)
// Status: deprecated | Level: high | ID: c5bc79c6-c5f5-56f7-a627-0f054901a656

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
