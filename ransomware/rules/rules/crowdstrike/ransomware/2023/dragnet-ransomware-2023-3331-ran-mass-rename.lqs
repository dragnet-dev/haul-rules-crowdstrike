// Dragnet [Ransomware]: dragnet-ransomware-2023-3331 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 647ead98-db8d-5ee5-95cc-93ee19969537

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
