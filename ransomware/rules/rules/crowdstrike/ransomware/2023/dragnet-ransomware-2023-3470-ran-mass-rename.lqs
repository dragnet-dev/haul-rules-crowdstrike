// Dragnet [Ransomware]: dragnet-ransomware-2023-3470 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 3802fb0a-2df6-5d7b-a72f-68cf6d1b0011

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
