// Dragnet [Ransomware]: dragnet-ransomware-2024-1611 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 1a299f35-835a-53c3-94d3-ed475f0cca82

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
