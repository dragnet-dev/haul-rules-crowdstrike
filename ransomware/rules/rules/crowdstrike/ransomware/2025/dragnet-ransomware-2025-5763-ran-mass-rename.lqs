// Dragnet [Ransomware]: dragnet-ransomware-2025-5763 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: da2638cc-044d-5445-8799-352f321ffb3d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
