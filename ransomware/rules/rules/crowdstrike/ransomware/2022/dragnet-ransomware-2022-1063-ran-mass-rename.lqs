// Dragnet [Ransomware]: dragnet-ransomware-2022-1063 — Mass File Rename (stormous)
// Status: deprecated | Level: high | ID: 1a6b5489-2046-5073-9791-e89fa4d8f3bb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
