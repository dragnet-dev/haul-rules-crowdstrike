// Dragnet [Ransomware]: dragnet-ransomware-2025-4394 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: cef55476-9c75-5bca-9650-da420d6137fb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
