// Dragnet [Ransomware]: dragnet-ransomware-2025-2473 — Mass File Rename (thegentlemen)
// Status: experimental | Level: high | ID: 4b67a025-9b8d-5881-af5a-6ad1ac286bcc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
