// Dragnet [Ransomware]: dragnet-ransomware-2024-2385 — Mass File Rename (arcusmedia)
// Status: experimental | Level: high | ID: 874ad06e-81c5-534a-bf53-718a64ec975c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
