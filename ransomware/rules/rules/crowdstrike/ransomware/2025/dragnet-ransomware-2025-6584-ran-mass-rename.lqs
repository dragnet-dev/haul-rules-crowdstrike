// Dragnet [Ransomware]: dragnet-ransomware-2025-6584 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 1f006112-dc21-557d-9052-b7c27eb38f9e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
