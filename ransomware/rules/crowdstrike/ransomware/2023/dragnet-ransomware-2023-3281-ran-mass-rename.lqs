// Dragnet [Ransomware]: dragnet-ransomware-2023-3281 — Mass File Rename (play)
// Status: experimental | Level: high | ID: b09e2f1c-f948-5592-8e5f-0ffde06f32b6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
