// Dragnet [Ransomware]: dragnet-ransomware-2023-5325 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 2a544c9c-2b01-5c1c-a12e-4fca40417055

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
