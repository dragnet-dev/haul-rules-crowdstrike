// Dragnet [Ransomware]: dragnet-ransomware-2025-4131 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 4d57700b-5fed-5f46-90ff-692f79972441

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
