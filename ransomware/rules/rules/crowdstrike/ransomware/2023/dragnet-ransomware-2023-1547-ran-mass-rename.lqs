// Dragnet [Ransomware]: dragnet-ransomware-2023-1547 — Mass File Rename (qilin)
// Status: deprecated | Level: high | ID: ba2c90ee-1970-5daa-bbf5-81be92757177

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
