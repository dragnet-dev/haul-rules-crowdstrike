// Dragnet [Ransomware]: dragnet-ransomware-2021-1438 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 9de46f08-dab2-50b2-8e10-e2cd0a1f46f0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
