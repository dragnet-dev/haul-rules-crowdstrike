// Dragnet [Ransomware]: dragnet-ransomware-2023-3284 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: e85c9d6a-ce4f-5bb2-ad97-433022575ef3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
