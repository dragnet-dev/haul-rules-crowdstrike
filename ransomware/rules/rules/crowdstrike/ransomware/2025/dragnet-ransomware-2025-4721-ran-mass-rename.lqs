// Dragnet [Ransomware]: dragnet-ransomware-2025-4721 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 651c0b97-2f66-5ee2-bc04-e6b610090b02

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
