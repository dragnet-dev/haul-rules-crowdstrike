// Dragnet [Ransomware]: dragnet-ransomware-2023-0123 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 05d6b392-6049-5bf1-898f-065bef076a84

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
