// Dragnet [Ransomware]: dragnet-ransomware-2025-2776 — Mass File Rename (lockbit5)
// Status: experimental | Level: high | ID: ab088105-fbad-5611-9588-4bf533efa7a2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
