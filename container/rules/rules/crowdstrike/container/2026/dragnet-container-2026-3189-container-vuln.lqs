// Dragnet [Container]: dragnet-container-2026-3189 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 30262b87-d4aa-5395-ac8e-8c2290fd50b8

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
