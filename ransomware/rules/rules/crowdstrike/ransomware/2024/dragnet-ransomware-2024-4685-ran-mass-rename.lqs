// Dragnet [Ransomware]: dragnet-ransomware-2024-4685 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: bee88ac5-d2b5-5b75-9465-93a2197e8bc7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
