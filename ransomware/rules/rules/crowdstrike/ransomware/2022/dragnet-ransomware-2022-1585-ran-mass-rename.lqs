// Dragnet [Ransomware]: dragnet-ransomware-2022-1585 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: e605cbdf-f98e-5dfe-8da8-bcd74a2ea1ab

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
