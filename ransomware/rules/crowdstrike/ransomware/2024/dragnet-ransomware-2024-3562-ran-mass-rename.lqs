// Dragnet [Ransomware]: dragnet-ransomware-2024-3562 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: dd4c164b-b4e8-562e-abb2-7bed3be3fd63

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
