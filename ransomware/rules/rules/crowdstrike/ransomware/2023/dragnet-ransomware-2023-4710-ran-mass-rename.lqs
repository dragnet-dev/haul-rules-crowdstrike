// Dragnet [Ransomware]: dragnet-ransomware-2023-4710 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: f673e740-b19a-5db1-b1c5-4a8dcb520a7c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
