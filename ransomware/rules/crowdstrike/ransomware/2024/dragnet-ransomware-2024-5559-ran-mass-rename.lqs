// Dragnet [Ransomware]: dragnet-ransomware-2024-5559 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: de9a9919-fa50-51e7-86b1-c0fe5ec4a5c7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
