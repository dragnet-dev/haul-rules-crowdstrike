// Dragnet [Container]: dragnet-container-2025-0493 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 8e2c407a-c5e0-5864-b90e-c13eec83a81d

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
