// Dragnet [Ransomware]: dragnet-ransomware-2025-1972 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: a4979916-e958-50f2-a0fd-309249a286b7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
