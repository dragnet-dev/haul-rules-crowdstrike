// Dragnet [Ransomware]: dragnet-ransomware-2024-4214 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: 6142e6bb-884b-5970-a07a-05800ea2544b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
