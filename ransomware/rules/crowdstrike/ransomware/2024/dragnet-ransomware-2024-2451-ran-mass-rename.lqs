// Dragnet [Ransomware]: dragnet-ransomware-2024-2451 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 87ecdb0c-cdf5-5077-87e4-a9eba78a0b4d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
