// Dragnet [Ransomware]: dragnet-ransomware-2025-7202 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: d8d7fa76-3dea-5815-b84c-e06054578d9f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
