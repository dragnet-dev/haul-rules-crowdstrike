// Dragnet [Container]: dragnet-container-2026-1498 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 597c3003-79b2-5ab1-998b-043232440a17

#event_simpleName=*
| (ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10* OR ImageFileName = *ubuntu:13.04* OR ImageFileName = *ubuntu:13.10*)
| table([timestamp, ComputerName])
| limit(1000)
