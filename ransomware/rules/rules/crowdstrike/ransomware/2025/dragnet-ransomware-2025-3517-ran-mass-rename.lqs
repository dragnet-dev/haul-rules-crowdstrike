// Dragnet [Ransomware]: dragnet-ransomware-2025-3517 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 461a235c-b84f-5a10-a736-974256b29544

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
