// Dragnet [Ransomware]: dragnet-ransomware-2023-4182 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 777d11ac-1f8a-59e9-8a26-08a3ae33b476

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
