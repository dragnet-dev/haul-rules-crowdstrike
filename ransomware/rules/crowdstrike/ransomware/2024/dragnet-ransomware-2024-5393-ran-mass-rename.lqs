// Dragnet [Ransomware]: dragnet-ransomware-2024-5393 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 13d0889f-85d7-5f0f-91a6-d9fa80c2c735

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
