// Dragnet [Ransomware]: dragnet-ransomware-2024-5785 — Mass File Rename (metaencryptor)
// Status: experimental | Level: high | ID: 6b53fd9e-4c0b-5d7f-b441-92642a3e5e79

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
