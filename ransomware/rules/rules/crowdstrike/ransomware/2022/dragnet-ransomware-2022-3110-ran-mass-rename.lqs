// Dragnet [Ransomware]: dragnet-ransomware-2022-3110 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: b84c554a-02aa-5026-85f7-abe4e48308ee

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
