// Dragnet [Ransomware]: dragnet-ransomware-2025-3127 — Mass File Rename (anubis)
// Status: experimental | Level: high | ID: c4e3aa5d-d3a6-567d-9e91-67017cd03e5e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
