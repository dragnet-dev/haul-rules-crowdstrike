// Dragnet [Container]: dragnet-container-2026-0039 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 15eab73c-dcd6-5354-b807-6d2801b74e11

#event_simpleName=*
| (ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:14.04* OR ImageFileName = *ubuntu:15.04* OR ImageFileName = *ubuntu:15.10*)
| table([timestamp, ComputerName])
| limit(1000)
