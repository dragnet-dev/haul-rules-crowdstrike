// Dragnet [Ransomware]: dragnet-ransomware-2023-4742 — Mass File Rename (meow)
// Status: experimental | Level: high | ID: 102dc04d-6490-59ab-8920-c2696b2baa8a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
