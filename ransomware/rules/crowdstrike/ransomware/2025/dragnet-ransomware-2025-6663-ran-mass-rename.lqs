// Dragnet [Ransomware]: dragnet-ransomware-2025-6663 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: e9da0bf3-0f94-587d-b9ba-8d0e6ed2ecc5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
