// Dragnet [Container]: dragnet-container-2024-0605 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: a74f3f63-f648-542d-807d-35d6cd342fa3

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:7* OR ImageFileName = *redhat/ubi9:*)
| table([timestamp, ComputerName])
| limit(1000)
