// Dragnet [Ransomware]: dragnet-ransomware-2026-1324 — Mass File Rename (incransom)
// Status: stable | Level: high | ID: 17132ad3-3f03-5e24-b8e2-e3cb4a3c3f62

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
