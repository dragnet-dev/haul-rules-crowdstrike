// Dragnet [Container]: dragnet-container-2026-0137 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 92cfa20e-52d9-5617-ad7f-9bc8b7c7c6d6

#event_simpleName=*
| (ImageFileName = *alpine edge:* OR ImageFileName = *chainguard:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
