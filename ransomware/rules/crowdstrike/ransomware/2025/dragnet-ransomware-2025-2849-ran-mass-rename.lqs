// Dragnet [Ransomware]: dragnet-ransomware-2025-2849 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 8db80c59-71a8-59b2-89ab-727469635e7c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
