// Dragnet [Ransomware]: dragnet-ransomware-2023-4589 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 4d445faf-9569-5a23-a4dc-21999b6bb157

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
