// Dragnet [Ransomware]: dragnet-ransomware-2022-3132 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 29b0fa04-7a03-5705-a9ea-a016d693fb01

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
