// Dragnet [Container]: dragnet-container-2025-0235 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: e6c57cf5-15ec-53cd-a730-909e0c5ee972

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
