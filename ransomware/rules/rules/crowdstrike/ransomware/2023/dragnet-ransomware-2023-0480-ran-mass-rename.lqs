// Dragnet [Ransomware]: dragnet-ransomware-2023-0480 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: b9cbc8d3-1a00-5266-aa8c-2193f7c43962

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
