// Dragnet [Ransomware]: dragnet-ransomware-2022-1496 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 99b4859b-e81d-5fdc-a147-e54fff9927b2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
