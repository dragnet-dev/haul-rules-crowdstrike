// Dragnet [Ransomware]: dragnet-ransomware-2023-4227 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: f44cb771-1962-5c21-af19-1b97bfcdcd1a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
