// Dragnet [Ransomware]: dragnet-ransomware-2022-0370 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: c31a1293-fd8b-51fe-8298-0e8b4a221d2b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
