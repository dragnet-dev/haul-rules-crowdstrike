// Dragnet [Ransomware]: dragnet-ransomware-2020-0235 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 70eb444a-8b41-5d1d-8968-6a7051eaaed0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
