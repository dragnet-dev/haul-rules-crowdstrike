// Dragnet [Ransomware]: dragnet-ransomware-2025-0531 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 2cbfd4dc-8f78-5678-b788-e06b29a37d0b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
