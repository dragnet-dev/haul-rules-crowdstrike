// Dragnet [Ransomware]: dragnet-ransomware-2022-0010 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: caff0111-4445-5e6b-a10a-c833240bfc16

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
