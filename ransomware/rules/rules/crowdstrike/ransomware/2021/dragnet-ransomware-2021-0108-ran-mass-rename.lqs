// Dragnet [Ransomware]: dragnet-ransomware-2021-0108 — Mass File Rename (avaddon)
// Status: deprecated | Level: high | ID: 7ee1d5f7-c5f3-5b4d-875a-e684dd0988da

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
