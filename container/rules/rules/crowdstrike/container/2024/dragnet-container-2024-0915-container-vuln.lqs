// Dragnet [Container]: dragnet-container-2024-0915 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: d396bab9-fd7a-5aa6-9996-b46553cb8f51

#event_simpleName=*
| (ImageFileName = *amazonlinux:1* OR ImageFileName = *amazonlinux:2* OR ImageFileName = *chainguard:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:7* OR ImageFileName = *redhat/ubi9:*)
| table([timestamp, ComputerName])
| limit(1000)
