// Dragnet [Ransomware]: dragnet-ransomware-2024-4848 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 7a91e4d7-85b8-5889-bada-8a8ada1e5e3a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
