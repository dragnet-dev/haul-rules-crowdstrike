// Dragnet [Ransomware]: dragnet-ransomware-2025-2564 — Mass File Rename (blacknevas)
// Status: experimental | Level: high | ID: 09276817-ebea-5eb1-a97e-d2e589906ec4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
