// Dragnet [Ransomware]: dragnet-ransomware-2023-3578 — Mass File Rename (noescape)
// Status: experimental | Level: high | ID: 7b9fcead-ff93-5291-ba75-7acd9f993ff3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
