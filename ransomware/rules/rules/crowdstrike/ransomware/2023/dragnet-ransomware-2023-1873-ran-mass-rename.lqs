// Dragnet [Ransomware]: dragnet-ransomware-2023-1873 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 4e3c4f3f-941c-539c-a660-671fae945a8f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
