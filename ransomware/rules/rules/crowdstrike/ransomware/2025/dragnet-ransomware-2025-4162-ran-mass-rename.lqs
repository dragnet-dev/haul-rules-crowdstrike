// Dragnet [Ransomware]: dragnet-ransomware-2025-4162 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: 7b2c3525-8f54-556d-bc6c-03262a2bae15

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
