// Dragnet [Ransomware]: dragnet-ransomware-2023-2690 — Mass File Rename (royal)
// Status: experimental | Level: high | ID: 072857a4-1f59-5946-9bff-03874664284d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
