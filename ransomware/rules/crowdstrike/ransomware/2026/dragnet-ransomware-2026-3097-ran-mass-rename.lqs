// Dragnet [Ransomware]: dragnet-ransomware-2026-3097 — Mass File Rename (securotrop)
// Status: stable | Level: high | ID: cd27a980-d489-51c9-853a-98a4a9260a02

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
