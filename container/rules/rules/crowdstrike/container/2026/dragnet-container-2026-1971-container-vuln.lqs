// Dragnet [Container]: dragnet-container-2026-1971 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: d3e064cc-6ca9-59af-9484-46bc0620eda2

#event_simpleName=*
| (ImageFileName = *debian:7* OR ImageFileName = *debian:8* OR ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *oraclelinux:7* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:14.04* OR ImageFileName = *ubuntu:15.04*)
| table([timestamp, ComputerName])
| limit(1000)
