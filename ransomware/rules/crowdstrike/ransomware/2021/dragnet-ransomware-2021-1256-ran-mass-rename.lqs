// Dragnet [Ransomware]: dragnet-ransomware-2021-1256 — Mass File Rename (midas)
// Status: deprecated | Level: high | ID: 8f11e6e6-ff19-5c2a-ad1d-436ef8a14201

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
