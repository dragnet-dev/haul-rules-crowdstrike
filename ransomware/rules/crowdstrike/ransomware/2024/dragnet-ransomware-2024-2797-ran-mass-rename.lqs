// Dragnet [Ransomware]: dragnet-ransomware-2024-2797 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 9d8f748b-2ce2-5e5e-bc24-b5710a6afdbc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
