// Dragnet [Ransomware]: dragnet-ransomware-2024-1239 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 99608123-2da7-5a62-90c3-3799b0565637

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
