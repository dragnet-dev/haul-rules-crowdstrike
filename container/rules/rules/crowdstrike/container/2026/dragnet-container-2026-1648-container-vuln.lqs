// Dragnet [Container]: dragnet-container-2026-1648 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 8ff88e61-da42-5637-adda-15adbd5ad8b5

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:7* OR ImageFileName = *debian:8* OR ImageFileName = *debian:9* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:16.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
