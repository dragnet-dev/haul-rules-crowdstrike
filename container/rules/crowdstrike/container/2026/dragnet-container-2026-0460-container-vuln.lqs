// Dragnet [Container]: dragnet-container-2026-0460 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 6cd2101e-2d0c-531f-b921-1994b2240d04

#event_simpleName=*
| (ImageFileName = *debian:7* OR ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10* OR ImageFileName = *ubuntu:13.04*)
| table([timestamp, ComputerName])
| limit(1000)
