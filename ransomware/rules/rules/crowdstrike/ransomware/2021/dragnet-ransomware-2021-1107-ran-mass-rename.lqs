// Dragnet [Ransomware]: dragnet-ransomware-2021-1107 — Mass File Rename (spook)
// Status: deprecated | Level: high | ID: 692fafe1-4ec6-5142-9664-614e1997a907

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
