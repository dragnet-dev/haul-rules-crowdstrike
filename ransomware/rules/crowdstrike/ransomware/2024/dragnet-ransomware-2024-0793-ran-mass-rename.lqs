// Dragnet [Ransomware]: dragnet-ransomware-2024-0793 — Mass File Rename (ciphbit)
// Status: deprecated | Level: high | ID: 4cabfc32-5f6d-5a25-9aa9-3ec13f35a894

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
