// Dragnet [Ransomware]: dragnet-ransomware-2025-6587 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 7468ed1e-e543-5073-ad9f-3399d1165866

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
