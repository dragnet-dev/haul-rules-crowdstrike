// Dragnet [Ransomware]: dragnet-ransomware-2025-5144 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: c08fe604-561d-55cb-bef8-e7c7a0b82a32

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
