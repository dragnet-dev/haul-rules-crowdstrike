// Dragnet [Ransomware]: dragnet-ransomware-2023-3355 — Mass File Rename (play)
// Status: experimental | Level: high | ID: ec4653f1-e0a8-5300-b91a-6a8792085a05

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
