// Dragnet [Ransomware]: dragnet-ransomware-2024-4451 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 21013773-0308-50c5-bb88-0c264e0e4e3b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
