// Dragnet [Ransomware]: dragnet-ransomware-2022-0529 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 2381cef3-8ac2-5675-8b25-c6bddf952efb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
