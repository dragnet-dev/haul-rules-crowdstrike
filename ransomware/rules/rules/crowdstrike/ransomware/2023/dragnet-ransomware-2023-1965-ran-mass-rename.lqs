// Dragnet [Ransomware]: dragnet-ransomware-2023-1965 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 8a6a3639-ea66-51cf-aab5-fb0826a2b2ea

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
