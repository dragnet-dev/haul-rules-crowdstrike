// Dragnet [Ransomware]: dragnet-ransomware-2023-0395 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: a985dc5f-32e3-5bd1-99e3-9afa31ae7d82

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
