// Dragnet [Ransomware]: dragnet-ransomware-2021-1047 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 5eed8ba3-bff2-5810-acd1-80386e91074a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
