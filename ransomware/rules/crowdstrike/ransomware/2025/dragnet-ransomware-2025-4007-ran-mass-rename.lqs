// Dragnet [Ransomware]: dragnet-ransomware-2025-4007 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 9c982dbb-bb69-5f90-93a4-78851858550b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
