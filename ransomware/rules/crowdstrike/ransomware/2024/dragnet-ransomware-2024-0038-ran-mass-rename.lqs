// Dragnet [Ransomware]: dragnet-ransomware-2024-0038 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 592f5d44-e220-5daa-8e37-833d7e81266a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
