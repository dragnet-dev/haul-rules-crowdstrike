// Dragnet [Ransomware]: dragnet-ransomware-2024-1466 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: 6b99f55f-b679-5d42-9ff1-278ca66cac13

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
