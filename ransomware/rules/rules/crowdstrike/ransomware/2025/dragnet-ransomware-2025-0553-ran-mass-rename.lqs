// Dragnet [Ransomware]: dragnet-ransomware-2025-0553 — Mass File Rename (genesis)
// Status: experimental | Level: high | ID: 939b92c8-068a-5e9a-8016-d56fd6a14dcd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
