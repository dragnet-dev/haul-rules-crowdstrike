// Dragnet [Ransomware]: dragnet-ransomware-2022-1305 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: d437c6d6-cffa-5947-947f-54c0ba1fe86a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
