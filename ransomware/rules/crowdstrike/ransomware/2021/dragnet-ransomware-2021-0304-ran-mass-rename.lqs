// Dragnet [Ransomware]: dragnet-ransomware-2021-0304 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: adb1ef46-a3ae-53b9-925b-602a9bb0a216

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
