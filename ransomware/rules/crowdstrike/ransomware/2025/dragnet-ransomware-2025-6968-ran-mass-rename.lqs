// Dragnet [Ransomware]: dragnet-ransomware-2025-6968 — Mass File Rename (spacebears)
// Status: experimental | Level: high | ID: 80a36772-4f29-510d-8e76-cf6069bb9d0b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
