// Dragnet [Container]: dragnet-container-2026-1270 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 423163f5-721a-5172-9e69-0b80da30b410

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:5*)
| table([timestamp, ComputerName])
| limit(1000)
