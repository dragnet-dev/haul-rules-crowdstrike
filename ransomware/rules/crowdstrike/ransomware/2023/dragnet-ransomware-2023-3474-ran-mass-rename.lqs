// Dragnet [Ransomware]: dragnet-ransomware-2023-3474 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: f35a5326-1e03-5b28-9786-8319085f9c62

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
