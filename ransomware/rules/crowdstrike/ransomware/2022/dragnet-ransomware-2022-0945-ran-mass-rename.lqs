// Dragnet [Ransomware]: dragnet-ransomware-2022-0945 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 4537f6a7-d131-5a91-9322-75a142edf2f9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
