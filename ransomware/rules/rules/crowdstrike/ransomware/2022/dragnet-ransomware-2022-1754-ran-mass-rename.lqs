// Dragnet [Ransomware]: dragnet-ransomware-2022-1754 — Mass File Rename (cuba)
// Status: deprecated | Level: high | ID: 9952a987-babc-57f9-9817-4c164c765c52

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
