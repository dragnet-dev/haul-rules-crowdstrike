// Dragnet [Ransomware]: dragnet-ransomware-2022-1685 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 6c75a861-8fa1-54d5-b317-e5070a04a09c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
