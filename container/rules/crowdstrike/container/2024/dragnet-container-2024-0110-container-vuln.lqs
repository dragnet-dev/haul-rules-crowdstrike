// Dragnet [Container]: dragnet-container-2024-0110 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 7538b3aa-5c6e-5327-aca7-d17a5422d6e3

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:9*)
| table([timestamp, ComputerName])
| limit(1000)
