// Dragnet [Ransomware]: dragnet-ransomware-2025-0778 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: c3f11294-be15-578c-8d30-8f0607546d78

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
