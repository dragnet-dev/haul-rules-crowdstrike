// Dragnet [Ransomware]: dragnet-ransomware-2026-0568 — Mass File Rename (AiLock)
// Status: deprecated | Level: high | ID: 37c2fc4e-3256-5b05-9d40-36ecc7ef0623

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
