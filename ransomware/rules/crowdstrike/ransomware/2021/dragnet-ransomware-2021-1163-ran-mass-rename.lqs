// Dragnet [Ransomware]: dragnet-ransomware-2021-1163 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: d76b12e3-356e-57ee-ad41-3294171cc3de

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
