// Dragnet [Ransomware]: dragnet-ransomware-2025-1795 — Mass File Rename (genesis)
// Status: experimental | Level: high | ID: d9e43cca-8610-56a2-9699-1b8f19cda2fa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
