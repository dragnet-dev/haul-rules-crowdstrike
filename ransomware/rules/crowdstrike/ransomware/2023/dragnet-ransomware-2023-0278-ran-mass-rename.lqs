// Dragnet [Ransomware]: dragnet-ransomware-2023-0278 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 0ab0840b-2814-56b0-9e74-86e3c3fe8b97

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
