// Dragnet [Ransomware]: dragnet-ransomware-2024-5741 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 2d8b313f-01c8-5930-a647-3b3d8089c6b2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
