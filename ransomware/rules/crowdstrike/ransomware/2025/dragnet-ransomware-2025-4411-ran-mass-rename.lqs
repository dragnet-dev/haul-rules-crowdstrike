// Dragnet [Ransomware]: dragnet-ransomware-2025-4411 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 4e41f27c-19b5-5ce1-ae6e-a98ed23ad394

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
