// Dragnet [Ransomware]: dragnet-ransomware-2024-3378 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: a1aa2f14-72eb-5a45-b739-31c858a7018b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
