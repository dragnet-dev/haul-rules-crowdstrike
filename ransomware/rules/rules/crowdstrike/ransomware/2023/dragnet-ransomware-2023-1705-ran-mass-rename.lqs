// Dragnet [Ransomware]: dragnet-ransomware-2023-1705 — Mass File Rename (royal)
// Status: experimental | Level: high | ID: d0b666bc-576e-5a64-84c9-aa103569cd5d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
