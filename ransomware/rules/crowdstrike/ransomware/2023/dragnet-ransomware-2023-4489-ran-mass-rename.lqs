// Dragnet [Ransomware]: dragnet-ransomware-2023-4489 — Mass File Rename (rhysida)
// Status: experimental | Level: high | ID: 1245fb41-7cd8-5e34-b014-b84295b6640f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
