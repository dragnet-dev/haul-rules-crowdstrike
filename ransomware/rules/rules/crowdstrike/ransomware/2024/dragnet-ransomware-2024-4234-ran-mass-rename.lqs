// Dragnet [Ransomware]: dragnet-ransomware-2024-4234 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: 286963a7-ec3b-5f8e-87d0-f6747ddd1ad6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
