// Dragnet [Ransomware]: dragnet-ransomware-2022-1241 — Mass File Rename (ransomhouse)
// Status: deprecated | Level: high | ID: 23cbf264-01c4-5e97-8e79-94c6e1410e41

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
