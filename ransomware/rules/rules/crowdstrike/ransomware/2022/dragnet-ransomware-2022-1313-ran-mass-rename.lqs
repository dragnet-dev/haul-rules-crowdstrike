// Dragnet [Ransomware]: dragnet-ransomware-2022-1313 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 4c14de19-5da7-5d9e-8447-d0be75f4eaa0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
