// Dragnet [Ransomware]: dragnet-ransomware-2024-4827 — Mass File Rename (dragonforce)
// Status: deprecated | Level: high | ID: 5a0cd3b7-a2a9-5314-8985-d78d0502262d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
