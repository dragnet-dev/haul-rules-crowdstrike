// Dragnet [Ransomware]: dragnet-ransomware-2026-1011 — Mass File Rename (thegentlemen)
// Status: test | Level: high | ID: 424c5d1f-d4cb-5394-b64d-658fe92ce733

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
