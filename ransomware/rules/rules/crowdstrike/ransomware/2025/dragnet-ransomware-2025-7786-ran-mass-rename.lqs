// Dragnet [Ransomware]: dragnet-ransomware-2025-7786 — Mass File Rename (sinobi)
// Status: experimental | Level: high | ID: 64b4526e-fcca-52b1-9980-2f9c664b7197

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
