// Dragnet [Ransomware]: dragnet-ransomware-2024-4259 — Mass File Rename (meow)
// Status: experimental | Level: high | ID: 57e071cc-8a02-5bd0-b6bf-5a1c19669e22

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
