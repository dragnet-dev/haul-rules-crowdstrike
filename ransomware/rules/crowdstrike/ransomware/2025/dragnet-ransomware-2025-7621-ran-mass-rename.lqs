// Dragnet [Ransomware]: dragnet-ransomware-2025-7621 — Mass File Rename (devman)
// Status: experimental | Level: high | ID: cb7086b5-a2c4-5846-98bf-f92bb08ff35c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
