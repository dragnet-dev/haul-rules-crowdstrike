// Dragnet [Ransomware]: dragnet-ransomware-2023-5332 — Mass File Rename (dunghill)
// Status: experimental | Level: high | ID: abd561f5-c99e-50cf-b5ed-ea4f74dd1650

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
