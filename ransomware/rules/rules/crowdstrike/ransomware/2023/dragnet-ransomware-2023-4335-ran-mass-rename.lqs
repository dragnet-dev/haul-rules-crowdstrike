// Dragnet [Ransomware]: dragnet-ransomware-2023-4335 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 27cdfff1-5511-571f-99f2-13b8e3e15e9d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
