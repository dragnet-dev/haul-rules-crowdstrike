// Dragnet [Ransomware]: dragnet-ransomware-2025-2585 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: 3abb2e83-4ec0-5cbe-ba38-18665fc6b380

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
