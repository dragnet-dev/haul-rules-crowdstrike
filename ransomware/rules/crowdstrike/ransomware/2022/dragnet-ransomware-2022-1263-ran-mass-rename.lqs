// Dragnet [Ransomware]: dragnet-ransomware-2022-1263 — Mass File Rename (sparta)
// Status: deprecated | Level: high | ID: 50456d6e-85bc-5442-8145-008d1347efde

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
