// Dragnet [Ransomware]: dragnet-ransomware-2024-3571 — Mass File Rename (blackout)
// Status: experimental | Level: high | ID: 9ad8cc37-c940-5fc6-88f4-3e7c421202b8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
