// Dragnet [Ransomware]: dragnet-ransomware-2022-0948 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: e8ed6919-4310-57fa-b9eb-8e7db1867075

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
