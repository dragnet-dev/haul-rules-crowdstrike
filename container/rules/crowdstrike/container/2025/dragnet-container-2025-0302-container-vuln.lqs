// Dragnet [Container]: dragnet-container-2025-0302 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 5573c231-05e7-54ef-92cf-4923750c887d

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *photon os:4.0* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:16.04-ESM* OR ImageFileName = *ubuntu:18.04-ESM* OR ImageFileName = *ubuntu:20.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
