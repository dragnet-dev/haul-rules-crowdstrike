// Dragnet [Ransomware]: dragnet-ransomware-2021-0869 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 3d2196f0-75f8-576e-9d02-cb1c18a90fd6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
