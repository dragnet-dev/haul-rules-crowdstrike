// Dragnet [Ransomware]: dragnet-ransomware-2021-1737 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: daaf4842-6cd0-5181-8c0a-3dd92df280b3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
