// Dragnet [Ransomware]: dragnet-ransomware-2023-4055 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: f0774af6-3b3f-596b-9516-c268bd8cf91a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
