// Dragnet [Ransomware]: dragnet-ransomware-2020-0253 — Mass File Rename (revil)
// Status: deprecated | Level: high | ID: e063b667-a9c3-508c-8e4f-b4224ab1fd9c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
