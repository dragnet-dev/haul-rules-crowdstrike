// Dragnet [Ransomware]: dragnet-ransomware-2024-1380 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 8199d1f2-2292-5b56-a98a-77264d9f5353

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
