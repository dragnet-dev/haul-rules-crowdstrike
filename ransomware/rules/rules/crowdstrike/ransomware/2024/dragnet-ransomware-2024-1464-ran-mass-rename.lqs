// Dragnet [Ransomware]: dragnet-ransomware-2024-1464 — Mass File Rename (sarcoma)
// Status: deprecated | Level: high | ID: 103b6e22-1cd6-52b1-a558-841c5cdf1860

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
