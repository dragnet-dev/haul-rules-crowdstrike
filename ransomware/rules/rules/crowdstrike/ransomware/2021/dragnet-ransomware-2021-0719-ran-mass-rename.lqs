// Dragnet [Ransomware]: dragnet-ransomware-2021-0719 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 922f0181-2f17-5a0a-b324-c48bfd7f43df

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
