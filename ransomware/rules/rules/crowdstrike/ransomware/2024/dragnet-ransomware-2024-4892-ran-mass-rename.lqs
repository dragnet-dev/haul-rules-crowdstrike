// Dragnet [Ransomware]: dragnet-ransomware-2024-4892 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: a8270a3b-1404-53a5-a52c-0fbbcb983a0e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
