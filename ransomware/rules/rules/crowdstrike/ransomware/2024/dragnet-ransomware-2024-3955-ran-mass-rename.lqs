// Dragnet [Ransomware]: dragnet-ransomware-2024-3955 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 28a149da-3d0d-505f-843d-00f6bfcd8d33

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
