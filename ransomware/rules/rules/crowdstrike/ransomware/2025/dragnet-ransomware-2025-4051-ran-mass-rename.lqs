// Dragnet [Ransomware]: dragnet-ransomware-2025-4051 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 11c0d5ff-da5b-5d0a-b4cf-7370ec77db40

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
