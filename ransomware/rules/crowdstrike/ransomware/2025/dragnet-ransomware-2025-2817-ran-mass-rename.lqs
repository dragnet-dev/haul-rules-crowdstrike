// Dragnet [Ransomware]: dragnet-ransomware-2025-2817 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 3e3ecb29-da4f-557f-a83e-be9557829e2b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
