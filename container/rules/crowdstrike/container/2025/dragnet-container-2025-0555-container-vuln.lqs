// Dragnet [Container]: dragnet-container-2025-0555 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 874da10b-fd08-5bb1-bd54-06c4d09c2e8d

#event_simpleName=*
| (ImageFileName = *alpine:3.20* OR ImageFileName = *alpine:3.21* OR ImageFileName = *alpine:3.22* OR ImageFileName = *alpine:3.23* OR ImageFileName = *alpine edge:*)
| table([timestamp, ComputerName])
| limit(1000)
