// Dragnet [Ransomware]: dragnet-ransomware-2023-3678 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 3ca6def5-2d8c-50d1-a217-704f8ef9b3d2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
