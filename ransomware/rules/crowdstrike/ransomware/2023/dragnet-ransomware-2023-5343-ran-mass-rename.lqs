// Dragnet [Ransomware]: dragnet-ransomware-2023-5343 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: c21257a9-783a-52b0-b86c-f6a7c64a6f99

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
