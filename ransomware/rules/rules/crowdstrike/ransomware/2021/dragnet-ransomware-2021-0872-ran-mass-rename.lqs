// Dragnet [Ransomware]: dragnet-ransomware-2021-0872 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: cde00828-7904-5c9e-99ea-7edcd3739aa5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
