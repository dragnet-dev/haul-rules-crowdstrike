// Dragnet [Ransomware]: dragnet-ransomware-2025-5606 — Mass File Rename (J)
// Status: experimental | Level: high | ID: a7f2d6ca-e20e-5c16-8e40-7f57d90ab5ea

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
