// Dragnet [Ransomware]: dragnet-ransomware-2025-0224 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: 408a5ae8-74c4-5223-a1d3-599e2e4d5ff6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
