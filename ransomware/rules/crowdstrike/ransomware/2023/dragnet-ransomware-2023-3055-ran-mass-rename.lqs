// Dragnet [Ransomware]: dragnet-ransomware-2023-3055 — Mass File Rename (cactus)
// Status: deprecated | Level: high | ID: 2d1be74d-6ce0-5eb7-9b02-e73c450b7c47

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
