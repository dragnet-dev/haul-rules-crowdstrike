// Dragnet [Ransomware]: dragnet-ransomware-2024-3415 — Mass File Rename (meow)
// Status: experimental | Level: high | ID: a3988378-c5e9-5282-8780-e2def9a8ba2e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
