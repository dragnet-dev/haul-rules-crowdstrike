// Dragnet [Ransomware]: dragnet-ransomware-2025-1863 — Mass File Rename (sinobi)
// Status: experimental | Level: high | ID: 26a93ed3-2b9d-5d2b-a7f8-d02d639416a6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
