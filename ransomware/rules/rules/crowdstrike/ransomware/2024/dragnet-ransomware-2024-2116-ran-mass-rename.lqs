// Dragnet [Ransomware]: dragnet-ransomware-2024-2116 — Mass File Rename (play)
// Status: experimental | Level: high | ID: d20fe1f5-ea19-5ec9-9470-568a63347c4d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
