// Dragnet [Ransomware]: dragnet-ransomware-2025-0091 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 3693ad19-88e7-5a1a-afad-3ed1fc84b50c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
