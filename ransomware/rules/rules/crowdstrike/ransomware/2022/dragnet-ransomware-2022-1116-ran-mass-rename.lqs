// Dragnet [Ransomware]: dragnet-ransomware-2022-1116 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: b453f780-155c-5b15-a747-c0f5372500f5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
