// Dragnet [Ransomware]: dragnet-ransomware-2025-4615 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: a22d4e2a-9d29-5ef0-b47e-81c041c945f1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
