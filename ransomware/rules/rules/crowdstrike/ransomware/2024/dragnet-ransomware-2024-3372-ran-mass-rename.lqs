// Dragnet [Ransomware]: dragnet-ransomware-2024-3372 — Mass File Rename (spacebears)
// Status: experimental | Level: high | ID: a3102fbc-7d42-5804-81a6-3cb7357b44eb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
