// Dragnet [Ransomware]: dragnet-ransomware-2024-4361 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 84739add-11a7-50fd-a18a-ffc62c68f967

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
