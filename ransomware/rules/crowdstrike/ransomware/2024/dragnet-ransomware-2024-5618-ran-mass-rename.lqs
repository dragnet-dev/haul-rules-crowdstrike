// Dragnet [Ransomware]: dragnet-ransomware-2024-5618 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: 899adcbb-ded2-56dc-866c-9077de18b3bd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
