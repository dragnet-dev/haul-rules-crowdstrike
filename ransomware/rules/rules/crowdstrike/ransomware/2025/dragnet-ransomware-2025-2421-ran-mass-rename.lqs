// Dragnet [Ransomware]: dragnet-ransomware-2025-2421 — Mass File Rename (thegentlemen)
// Status: experimental | Level: high | ID: f64a276a-ff28-5913-9b2c-8218ef71b642

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
