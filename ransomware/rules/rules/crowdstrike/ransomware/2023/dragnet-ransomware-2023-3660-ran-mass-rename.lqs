// Dragnet [Ransomware]: dragnet-ransomware-2023-3660 — Mass File Rename (ragnarlocker)
// Status: experimental | Level: high | ID: f07ffacc-7f4e-50ae-89c9-cb86ae3b76a5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
