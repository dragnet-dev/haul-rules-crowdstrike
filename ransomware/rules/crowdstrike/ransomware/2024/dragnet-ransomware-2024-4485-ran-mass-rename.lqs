// Dragnet [Ransomware]: dragnet-ransomware-2024-4485 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 1fa5e91f-f4c7-5aa2-8d12-251c3570edb7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
