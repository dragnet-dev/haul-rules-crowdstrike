// Dragnet [Ransomware]: dragnet-ransomware-2025-3148 — Mass File Rename (spacebears)
// Status: experimental | Level: high | ID: 39b08088-dffe-5183-8cbb-ce2f54c9f121

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
