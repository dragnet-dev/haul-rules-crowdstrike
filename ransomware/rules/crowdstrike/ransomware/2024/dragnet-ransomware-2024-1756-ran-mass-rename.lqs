// Dragnet [Ransomware]: dragnet-ransomware-2024-1756 — Mass File Rename (play)
// Status: experimental | Level: high | ID: b555972c-7c5f-5d4e-b9ae-20e4ca7f7551

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
