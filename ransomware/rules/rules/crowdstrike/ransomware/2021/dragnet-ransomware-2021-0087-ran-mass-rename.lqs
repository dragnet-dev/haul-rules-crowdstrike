// Dragnet [Ransomware]: dragnet-ransomware-2021-0087 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: fdc2c4d8-d70f-5870-b61f-2619341cc52a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
