// Dragnet [Ransomware]: dragnet-ransomware-2025-2504 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 3e77ce71-a83e-5dd8-97f2-f168cf92ccd9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
