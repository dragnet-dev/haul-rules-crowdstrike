// Dragnet [Ransomware]: dragnet-ransomware-2024-4428 — Mass File Rename (raworld)
// Status: experimental | Level: high | ID: 9d33fb47-48bb-51a2-8809-c60b6f933cd5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
