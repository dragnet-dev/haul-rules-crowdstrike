// Dragnet [Ransomware]: dragnet-ransomware-2023-4531 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 24c1e5c4-d630-5cd4-8308-2e9921c3ce06

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
