// Dragnet [Ransomware]: dragnet-ransomware-2021-1706 — Mass File Rename (cuba)
// Status: deprecated | Level: high | ID: e094820e-007f-537c-9cae-f58306dd8eca

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
