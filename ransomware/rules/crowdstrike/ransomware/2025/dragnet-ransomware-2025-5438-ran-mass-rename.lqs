// Dragnet [Ransomware]: dragnet-ransomware-2025-5438 — Mass File Rename (tridentlocker)
// Status: experimental | Level: high | ID: 10a2be81-7121-5d5f-9cbb-effdf44aff17

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
