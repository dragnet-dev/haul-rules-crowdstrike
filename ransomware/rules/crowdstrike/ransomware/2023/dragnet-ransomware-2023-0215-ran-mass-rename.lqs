// Dragnet [Ransomware]: dragnet-ransomware-2023-0215 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: de86b9bd-4648-5ed5-b9c3-48e228d80c40

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
