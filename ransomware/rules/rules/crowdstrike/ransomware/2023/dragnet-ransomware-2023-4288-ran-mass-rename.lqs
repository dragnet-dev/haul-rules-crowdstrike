// Dragnet [Ransomware]: dragnet-ransomware-2023-4288 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 45fad6e4-5f28-5caa-bcb2-e15f9a30a844

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
