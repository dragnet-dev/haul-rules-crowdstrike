// Dragnet [Ransomware]: dragnet-ransomware-2021-1118 — Mass File Rename (rook)
// Status: deprecated | Level: high | ID: 44afacfb-3acd-54d8-85f5-7ad372717f22

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
