// Dragnet [Ransomware]: dragnet-ransomware-2025-1642 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 7f31c19f-b031-55da-9c65-e86f6f67c0d8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
