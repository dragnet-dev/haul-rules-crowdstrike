// Dragnet [Ransomware]: dragnet-ransomware-2025-1299 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: dce1437b-2745-5f94-96f7-a56f62f2b2a8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
