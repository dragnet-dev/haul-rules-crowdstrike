// Dragnet [Ransomware]: dragnet-ransomware-2022-1230 — Mass File Rename (onyx)
// Status: deprecated | Level: high | ID: 502c7f8c-0d0c-5310-8652-aa9692791efe

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
