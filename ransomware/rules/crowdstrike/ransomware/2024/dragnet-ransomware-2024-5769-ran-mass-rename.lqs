// Dragnet [Ransomware]: dragnet-ransomware-2024-5769 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: b4a17f8d-5816-529f-a0c2-816f2a728e03

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
