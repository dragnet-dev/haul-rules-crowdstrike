// Dragnet [Ransomware]: dragnet-ransomware-2023-0203 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 15cef827-2462-5bf3-8b18-17d0fb061ce0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
