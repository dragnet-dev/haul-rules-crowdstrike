// Dragnet [Ransomware]: dragnet-ransomware-2025-3705 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 5b179696-55fd-5f5c-ac9f-0a6ca8c3abbd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
