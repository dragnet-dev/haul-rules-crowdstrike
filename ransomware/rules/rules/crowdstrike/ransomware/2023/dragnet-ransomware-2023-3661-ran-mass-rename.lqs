// Dragnet [Ransomware]: dragnet-ransomware-2023-3661 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 99bf0e0a-4122-52e9-a5f6-1e882e63906d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
