// Dragnet [Ransomware]: dragnet-ransomware-2024-3784 — Mass File Rename (dAn0n)
// Status: experimental | Level: high | ID: 65361eca-dedc-53e6-a991-edfc0e989327

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
