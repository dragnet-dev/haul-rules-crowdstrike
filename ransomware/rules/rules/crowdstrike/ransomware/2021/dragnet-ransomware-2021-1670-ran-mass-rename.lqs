// Dragnet [Ransomware]: dragnet-ransomware-2021-1670 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: b90b3d69-adf0-531c-a873-278b43251fdb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
