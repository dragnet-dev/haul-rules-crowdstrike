// Dragnet [Ransomware]: dragnet-ransomware-2024-2535 — Mass File Rename (monti)
// Status: experimental | Level: high | ID: 0bd8b14e-85cc-52a4-83bc-86d836d68d92

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
