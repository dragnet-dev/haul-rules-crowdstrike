// Dragnet [Ransomware]: dragnet-ransomware-2023-2853 — Mass File Rename (malas)
// Status: experimental | Level: high | ID: f5ee48e2-c459-52c7-8f0c-b3bff81cd5bc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
