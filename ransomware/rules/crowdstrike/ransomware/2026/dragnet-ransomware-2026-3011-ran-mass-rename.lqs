// Dragnet [Ransomware]: dragnet-ransomware-2026-3011 — Mass File Rename (spacebears)
// Status: stable | Level: high | ID: eb5d50d6-9b9d-54f9-92c8-5421e6efbfe9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
