// Dragnet [Ransomware]: dragnet-ransomware-2023-4038 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 7d333544-c64a-510c-b6e0-006db5af1186

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
