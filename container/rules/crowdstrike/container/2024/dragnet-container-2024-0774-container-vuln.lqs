// Dragnet [Container]: dragnet-container-2024-0774 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 16779766-bc66-5d0f-8495-827eb6063158

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
