// Dragnet [Ransomware]: dragnet-ransomware-2021-1464 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 84f22f24-9ddf-526a-9e74-3b2f1825e7f0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
