// Dragnet [Ransomware]: dragnet-ransomware-2025-6248 — Mass File Rename (spacebears)
// Status: test | Level: high | ID: 91b7999c-57d8-55e1-89a2-e807f555d643

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
