// Dragnet [Ransomware]: dragnet-ransomware-2025-2302 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 81a9e832-e89f-53f7-b9f0-a07a74311d49

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
