// Dragnet [Ransomware]: dragnet-ransomware-2022-2071 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 07a64110-dd21-5278-a796-116778e381f4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
