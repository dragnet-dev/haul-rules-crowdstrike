// Dragnet [Ransomware]: dragnet-ransomware-2025-4105 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 7abefecd-05ff-51e7-baa9-cf41c6e5b14a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
