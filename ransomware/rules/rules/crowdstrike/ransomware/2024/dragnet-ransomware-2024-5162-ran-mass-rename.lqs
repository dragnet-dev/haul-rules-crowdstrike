// Dragnet [Ransomware]: dragnet-ransomware-2024-5162 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 2e6713e1-73ef-5735-b0c5-3c585989e5eb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
