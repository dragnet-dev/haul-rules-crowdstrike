// Dragnet [Ransomware]: dragnet-ransomware-2022-3114 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: d8eadd64-6a38-585b-b22f-ccfa2b22ccf8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
