// Dragnet [Ransomware]: dragnet-ransomware-2025-0579 — Mass File Rename (dragonforce)
// Status: test | Level: high | ID: 6944a755-7ec3-5767-ab54-c0384f70284d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
