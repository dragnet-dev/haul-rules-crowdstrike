// Dragnet [Container]: dragnet-container-2026-0820 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: aa155ade-6fba-5214-8441-a31cc48349a0

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:5*)
| table([timestamp, ComputerName])
| limit(1000)
