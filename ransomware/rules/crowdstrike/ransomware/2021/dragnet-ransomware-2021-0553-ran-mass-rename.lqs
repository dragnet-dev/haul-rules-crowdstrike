// Dragnet [Ransomware]: dragnet-ransomware-2021-0553 — Mass File Rename (darkleakmarket)
// Status: deprecated | Level: high | ID: 32a6e3f3-8976-58ac-8caa-811898d5cf5a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
