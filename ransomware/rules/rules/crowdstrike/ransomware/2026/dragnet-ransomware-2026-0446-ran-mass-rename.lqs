// Dragnet [Ransomware]: dragnet-ransomware-2026-0446 — Mass File Rename (incransom)
// Status: test | Level: high | ID: c97355b5-a8ad-5206-bb61-eec5b5a8e192

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
