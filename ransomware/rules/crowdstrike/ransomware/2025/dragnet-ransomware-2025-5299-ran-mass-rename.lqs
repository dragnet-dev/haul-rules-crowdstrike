// Dragnet [Ransomware]: dragnet-ransomware-2025-5299 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: e32c0ca9-a5f3-59aa-b3b2-dbd1704b2ed5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
