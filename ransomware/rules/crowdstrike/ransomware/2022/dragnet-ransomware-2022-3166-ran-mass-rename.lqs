// Dragnet [Ransomware]: dragnet-ransomware-2022-3166 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: f9ee54a6-cc97-5970-bbaf-7bb8ecd0bba5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
