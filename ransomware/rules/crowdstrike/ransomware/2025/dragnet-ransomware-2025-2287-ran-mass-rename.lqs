// Dragnet [Ransomware]: dragnet-ransomware-2025-2287 — Mass File Rename (dragonforce)
// Status: test | Level: high | ID: 2d0f61c0-f289-51d5-b774-aa0b65771bd4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
