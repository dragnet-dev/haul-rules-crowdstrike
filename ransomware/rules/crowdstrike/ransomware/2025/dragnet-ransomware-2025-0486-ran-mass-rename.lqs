// Dragnet [Ransomware]: dragnet-ransomware-2025-0486 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: c4f0c858-3bf1-51b3-b7f5-52fce234625e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
