// Dragnet [Ransomware]: dragnet-ransomware-2025-6618 — Mass File Rename (play)
// Status: experimental | Level: high | ID: d8ab2305-129c-5058-8a8d-f4cbc4c776fa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
