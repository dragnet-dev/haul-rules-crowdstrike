// Dragnet [Ransomware]: dragnet-ransomware-2023-1133 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 481fb161-55ae-58c5-9c16-9ebd51789199

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
