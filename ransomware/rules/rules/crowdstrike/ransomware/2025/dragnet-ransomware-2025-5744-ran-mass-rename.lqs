// Dragnet [Ransomware]: dragnet-ransomware-2025-5744 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 94804e07-d507-5a7d-a43a-84e9246c8cd9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
