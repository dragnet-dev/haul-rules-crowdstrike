// Dragnet [Ransomware]: dragnet-ransomware-2024-4900 — Mass File Rename (qilin)
// Status: deprecated | Level: high | ID: 3200c609-4ccf-57c9-866f-7598bc00d04b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
