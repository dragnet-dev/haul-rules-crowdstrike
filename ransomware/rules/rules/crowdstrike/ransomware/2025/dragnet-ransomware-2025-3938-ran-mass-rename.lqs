// Dragnet [Ransomware]: dragnet-ransomware-2025-3938 — Mass File Rename (warlock)
// Status: deprecated | Level: high | ID: 57cabcf1-db7d-5c2c-a50e-1947dca9677f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
