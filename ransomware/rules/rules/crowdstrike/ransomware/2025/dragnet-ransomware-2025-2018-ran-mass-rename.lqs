// Dragnet [Ransomware]: dragnet-ransomware-2025-2018 — Mass File Rename (lockbit5)
// Status: experimental | Level: high | ID: 8bc10042-b1ee-56c1-908c-f1a1ffd269a9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
