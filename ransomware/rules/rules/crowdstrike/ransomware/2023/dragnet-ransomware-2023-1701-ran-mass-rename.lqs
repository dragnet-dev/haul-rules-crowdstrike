// Dragnet [Ransomware]: dragnet-ransomware-2023-1701 — Mass File Rename (ragnarlocker)
// Status: experimental | Level: high | ID: 69eb585d-279a-54a2-be0f-0b4893f4d0f0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
