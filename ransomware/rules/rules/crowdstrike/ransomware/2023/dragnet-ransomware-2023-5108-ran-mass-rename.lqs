// Dragnet [Ransomware]: dragnet-ransomware-2023-5108 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 018c381e-a262-5ca2-8e26-be8c7e1e14ef

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
