// Dragnet [Ransomware]: dragnet-ransomware-2022-0611 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 709a57ae-bfb3-59ba-8556-584dbb2cc52a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
