// Dragnet [Ransomware]: dragnet-ransomware-2025-7244 — Mass File Rename (rhysida)
// Status: experimental | Level: high | ID: 317e7b57-8c72-51fb-ae07-ad8d87aa590a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
