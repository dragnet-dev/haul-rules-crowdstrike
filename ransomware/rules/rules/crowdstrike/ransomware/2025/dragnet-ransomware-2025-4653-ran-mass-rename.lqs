// Dragnet [Ransomware]: dragnet-ransomware-2025-4653 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 32db3962-5225-524c-b0af-7c4f9c267cda

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
