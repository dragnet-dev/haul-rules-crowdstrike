// Dragnet [Ransomware]: dragnet-ransomware-2025-5850 — Mass File Rename (gunra)
// Status: experimental | Level: high | ID: c8568625-59ee-5969-8e06-e689a307cb59

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
