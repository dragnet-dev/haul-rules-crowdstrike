// Dragnet [Ransomware]: dragnet-ransomware-2021-0278 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 4134504d-d1ce-5863-b7b6-00b8ba036a8d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
