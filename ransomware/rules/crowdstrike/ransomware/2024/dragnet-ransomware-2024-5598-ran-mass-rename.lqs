// Dragnet [Ransomware]: dragnet-ransomware-2024-5598 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: 5cf4755a-bcce-5cea-8f30-f56de062231b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
