// Dragnet [Ransomware]: dragnet-ransomware-2020-0066 — Mass File Rename (maze)
// Status: deprecated | Level: high | ID: d2972ab0-efc0-5f08-a8f0-2f050284d4ec

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
