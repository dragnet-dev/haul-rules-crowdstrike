// Dragnet [Ransomware]: dragnet-ransomware-2022-1991 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 9fb24106-6e21-5175-af33-4bb49ea8c59f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
