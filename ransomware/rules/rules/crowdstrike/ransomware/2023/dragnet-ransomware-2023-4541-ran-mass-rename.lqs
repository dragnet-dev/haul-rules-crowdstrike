// Dragnet [Ransomware]: dragnet-ransomware-2023-4541 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: 0d1344dd-6a36-58c1-aa81-40367d146650

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
