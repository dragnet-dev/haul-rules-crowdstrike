// Dragnet [Ransomware]: dragnet-ransomware-2023-1097 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 7fab5714-27ec-5b39-85e8-730aa9f559bc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
