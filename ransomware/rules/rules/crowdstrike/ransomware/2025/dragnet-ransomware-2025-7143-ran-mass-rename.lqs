// Dragnet [Ransomware]: dragnet-ransomware-2025-7143 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 66e90493-97cd-5cd9-8b81-eec8e5939d9f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
