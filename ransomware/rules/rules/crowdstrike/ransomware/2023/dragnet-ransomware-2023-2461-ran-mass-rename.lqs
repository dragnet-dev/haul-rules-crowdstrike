// Dragnet [Ransomware]: dragnet-ransomware-2023-2461 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: f00fd2a1-7dbd-530b-8ac0-b1c1497f89bc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
