// Dragnet [Ransomware]: dragnet-ransomware-2023-2167 — Mass File Rename (ragnarlocker)
// Status: experimental | Level: high | ID: e044019d-ef4c-58c6-b1de-fafea5368fbc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
