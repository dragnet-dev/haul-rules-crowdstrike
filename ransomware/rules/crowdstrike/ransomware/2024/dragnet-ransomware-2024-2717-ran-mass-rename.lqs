// Dragnet [Ransomware]: dragnet-ransomware-2024-2717 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 5959f9bd-58c5-54d3-bfbc-92c21329eff4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
