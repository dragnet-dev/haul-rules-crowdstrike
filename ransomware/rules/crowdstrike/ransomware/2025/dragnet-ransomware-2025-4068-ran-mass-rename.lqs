// Dragnet [Ransomware]: dragnet-ransomware-2025-4068 — Mass File Rename (fog)
// Status: deprecated | Level: high | ID: 27cc755b-951c-5570-bb0f-6f11025882e4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
