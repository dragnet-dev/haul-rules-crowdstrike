// Dragnet [Ransomware]: dragnet-ransomware-2024-1316 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 396e802d-1f4b-5df9-b7fa-4adee3de70e4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
