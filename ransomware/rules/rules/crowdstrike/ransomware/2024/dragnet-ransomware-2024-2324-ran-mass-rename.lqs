// Dragnet [Ransomware]: dragnet-ransomware-2024-2324 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: c47b5c1a-d570-595b-a339-7d1fdd86dee3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
