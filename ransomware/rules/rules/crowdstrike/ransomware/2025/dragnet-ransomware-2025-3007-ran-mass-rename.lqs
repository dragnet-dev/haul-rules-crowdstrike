// Dragnet [Ransomware]: dragnet-ransomware-2025-3007 — Mass File Rename (spacebears)
// Status: experimental | Level: high | ID: c1a2b53f-fc06-5bb2-a6fe-ce1e0578b5bf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
