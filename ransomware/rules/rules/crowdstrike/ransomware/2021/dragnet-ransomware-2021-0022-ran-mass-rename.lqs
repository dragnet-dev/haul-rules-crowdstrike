// Dragnet [Ransomware]: dragnet-ransomware-2021-0022 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 0f2b9a15-e535-596d-891f-6c759d410572

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
