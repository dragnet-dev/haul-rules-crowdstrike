// Dragnet [Ransomware]: dragnet-ransomware-2025-4848 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: 1851f038-70f0-5617-8192-8ffb1ca1a7b6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
