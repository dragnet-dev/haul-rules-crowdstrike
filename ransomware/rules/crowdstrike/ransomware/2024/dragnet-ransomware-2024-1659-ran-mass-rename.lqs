// Dragnet [Ransomware]: dragnet-ransomware-2024-1659 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 08e9b79b-dff3-5a74-83bf-e05e9dcc3c5d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
