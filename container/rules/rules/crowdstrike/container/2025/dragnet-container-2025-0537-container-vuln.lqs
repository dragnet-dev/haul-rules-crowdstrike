// Dragnet [Container]: dragnet-container-2025-0537 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: c9a87122-3ee2-513b-aa0f-483fafc34189

#event_simpleName=*
| (ImageFileName = *almalinux:8* OR ImageFileName = *debian:8* OR ImageFileName = *oraclelinux:8* OR ImageFileName = *redhat/ubi9:*)
| table([timestamp, ComputerName])
| limit(1000)
