// Dragnet [Ransomware]: dragnet-ransomware-2025-3814 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 7ad8308a-8063-5192-90c0-5a68dfe990a9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
