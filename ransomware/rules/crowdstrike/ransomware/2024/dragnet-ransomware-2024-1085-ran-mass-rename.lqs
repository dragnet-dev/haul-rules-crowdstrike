// Dragnet [Ransomware]: dragnet-ransomware-2024-1085 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 0f63f097-107c-5546-a407-4ebe0e943425

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
