// Dragnet [Ransomware]: dragnet-ransomware-2025-3069 — Mass File Rename (blacklock)
// Status: experimental | Level: high | ID: 4cc94e36-38dd-5144-acc7-54662fac6d9e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
