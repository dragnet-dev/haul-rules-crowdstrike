// Dragnet [Ransomware]: dragnet-ransomware-2025-6998 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: d77c2342-cecb-5fa3-8ddd-1e87519d7f34

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
