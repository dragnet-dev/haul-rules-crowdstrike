// Dragnet [Ransomware]: dragnet-ransomware-2023-0681 — Mass File Rename (ragnarlocker)
// Status: experimental | Level: high | ID: f6b52538-8175-50a2-83aa-1423c87cc2e0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
