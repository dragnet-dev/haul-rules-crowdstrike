// Dragnet [Ransomware]: dragnet-ransomware-2024-2075 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 37fb81a8-bcad-5145-a4f6-68453c99fb5f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
