// Dragnet [Ransomware]: dragnet-ransomware-2025-1813 — Mass File Rename (incransom)
// Status: test | Level: high | ID: d2326eef-1d6e-5ec6-a139-cd568672f2c9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
