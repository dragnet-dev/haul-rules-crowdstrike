// Dragnet [Ransomware]: dragnet-ransomware-2025-6284 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 47d14115-f2bf-5d65-b5f4-53c8388daab8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
