// Dragnet [Ransomware]: dragnet-ransomware-2024-2259 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: f95f43cf-e3ec-5c39-9123-9d4d85079a81

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
