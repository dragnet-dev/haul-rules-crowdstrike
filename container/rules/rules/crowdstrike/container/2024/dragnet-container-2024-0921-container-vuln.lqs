// Dragnet [Container]: dragnet-container-2024-0921 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 5b4eef2a-aec6-59d4-9b2b-8fc51ca27211

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:9* OR ImageFileName = *photon os:3.0* OR ImageFileName = *redhat/ubi9:*)
| table([timestamp, ComputerName])
| limit(1000)
