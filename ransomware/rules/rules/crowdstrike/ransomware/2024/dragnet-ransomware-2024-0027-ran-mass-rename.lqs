// Dragnet [Ransomware]: dragnet-ransomware-2024-0027 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: 3693e150-56c0-516d-9be0-f9ee5984e521

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
