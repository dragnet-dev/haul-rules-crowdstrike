// Dragnet [Ransomware]: dragnet-ransomware-2023-3562 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 60dcf9ef-816e-5ef0-8f47-424d3c1a1a32

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
