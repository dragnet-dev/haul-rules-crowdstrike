// Dragnet [Ransomware]: dragnet-ransomware-2024-3624 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: fb16caae-eae4-5f53-b7d7-e64726a84df6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
