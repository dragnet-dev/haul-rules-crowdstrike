// Dragnet [Ransomware]: dragnet-ransomware-2022-1240 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 649da1aa-3f4f-5737-b47a-c0c6068149c2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
