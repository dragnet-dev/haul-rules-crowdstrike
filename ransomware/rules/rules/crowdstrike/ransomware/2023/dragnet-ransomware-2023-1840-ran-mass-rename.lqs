// Dragnet [Ransomware]: dragnet-ransomware-2023-1840 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 5cf0290b-0f84-5a04-9d77-7638408bead7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
