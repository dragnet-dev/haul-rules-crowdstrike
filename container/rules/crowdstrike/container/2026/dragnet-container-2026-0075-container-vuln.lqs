// Dragnet [Container]: dragnet-container-2026-0075 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: efab270e-5af6-5e67-b77c-f2e62ad7c020

#event_simpleName=*
| (ImageFileName = *amazonlinux:1* OR ImageFileName = *debian:11* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10*)
| table([timestamp, ComputerName])
| limit(1000)
