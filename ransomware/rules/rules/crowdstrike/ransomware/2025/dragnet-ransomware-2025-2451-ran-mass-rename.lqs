// Dragnet [Ransomware]: dragnet-ransomware-2025-2451 — Mass File Rename (thegentlemen)
// Status: experimental | Level: high | ID: e15e93f0-4410-581c-a3b5-21ccd6eb88e6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
