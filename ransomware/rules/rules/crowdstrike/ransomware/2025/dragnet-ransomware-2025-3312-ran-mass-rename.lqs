// Dragnet [Ransomware]: dragnet-ransomware-2025-3312 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 15ed7194-a983-5b58-a92f-5fb71c190736

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
