// Dragnet [Ransomware]: dragnet-ransomware-2024-4516 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 324a97bb-83c6-5f49-98e2-981e16886ab7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
