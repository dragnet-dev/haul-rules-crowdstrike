// Dragnet [Ransomware]: dragnet-ransomware-2024-3142 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 2085a3fc-877a-594f-9294-6117adcc8c67

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
