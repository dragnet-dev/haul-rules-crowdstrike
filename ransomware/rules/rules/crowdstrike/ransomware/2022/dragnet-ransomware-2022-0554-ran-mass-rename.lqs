// Dragnet [Ransomware]: dragnet-ransomware-2022-0554 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 5be4a93e-bbfa-5ed5-aff9-97b81f0f9027

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
