// Dragnet [Container]: dragnet-container-2024-1558 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: f0ee0304-79ab-5bc2-800e-22b0a16deccb

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:8* OR ImageFileName = *debian:9* OR ImageFileName = *ubuntu:18.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
