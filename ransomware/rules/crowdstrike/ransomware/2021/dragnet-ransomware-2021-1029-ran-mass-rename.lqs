// Dragnet [Ransomware]: dragnet-ransomware-2021-1029 — Mass File Rename (alphv)
// Status: deprecated | Level: high | ID: 53cf199b-0e86-5ee4-90dc-f70675df4572

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
