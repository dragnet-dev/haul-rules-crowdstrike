// Dragnet [Ransomware]: dragnet-ransomware-2023-1778 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: d5a47e17-8d46-52ee-836b-5ca5f93b7802

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
