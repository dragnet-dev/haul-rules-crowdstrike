// Dragnet [Ransomware]: dragnet-ransomware-2022-2269 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 59bd677f-de53-54ec-a693-536a28f92b38

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
