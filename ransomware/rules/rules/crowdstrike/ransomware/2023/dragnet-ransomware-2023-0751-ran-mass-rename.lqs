// Dragnet [Ransomware]: dragnet-ransomware-2023-0751 — Mass File Rename (vicesociety)
// Status: experimental | Level: high | ID: 3a4c6513-4349-55c3-80b2-32203a341e92

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
