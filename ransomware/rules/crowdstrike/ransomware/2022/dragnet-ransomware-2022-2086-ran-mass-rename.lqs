// Dragnet [Ransomware]: dragnet-ransomware-2022-2086 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 299ece90-a6e3-57ed-a50d-a4019b9e28be

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
