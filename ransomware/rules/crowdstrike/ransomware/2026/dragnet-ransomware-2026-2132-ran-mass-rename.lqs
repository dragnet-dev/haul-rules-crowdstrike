// Dragnet [Ransomware]: dragnet-ransomware-2026-2132 — Mass File Rename (lockbit5)
// Status: stable | Level: high | ID: aac4021d-733d-5f0d-a3a7-8614a5c78310

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
