// Dragnet [Ransomware]: dragnet-ransomware-2021-1609 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 92b2e0b5-0dc2-5ab6-8cde-5c9c42890267

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
