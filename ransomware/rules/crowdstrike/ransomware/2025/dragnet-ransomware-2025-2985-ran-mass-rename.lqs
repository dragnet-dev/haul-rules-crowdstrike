// Dragnet [Ransomware]: dragnet-ransomware-2025-2985 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 48c9d1fc-30a8-5001-92bc-87b190e0b10b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
