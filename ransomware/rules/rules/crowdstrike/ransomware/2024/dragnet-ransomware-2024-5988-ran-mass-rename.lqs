// Dragnet [Ransomware]: dragnet-ransomware-2024-5988 — Mass File Rename (meow)
// Status: experimental | Level: high | ID: 1718a296-b644-562a-970e-fff5eccb10d8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
