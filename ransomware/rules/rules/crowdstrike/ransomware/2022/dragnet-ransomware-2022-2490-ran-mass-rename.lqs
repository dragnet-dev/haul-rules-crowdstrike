// Dragnet [Ransomware]: dragnet-ransomware-2022-2490 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: edaececc-dfae-5704-8e5f-2a45c1a95582

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
