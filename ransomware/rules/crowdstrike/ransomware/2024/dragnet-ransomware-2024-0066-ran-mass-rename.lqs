// Dragnet [Ransomware]: dragnet-ransomware-2024-0066 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 6d23f51f-f50e-598c-80c2-f09e7fb70bf0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
