// Dragnet [Ransomware]: dragnet-ransomware-2024-2996 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 702fd371-0aae-5087-aec5-aaac9fcd6217

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
