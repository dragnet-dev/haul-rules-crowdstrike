// Dragnet [Ransomware]: dragnet-ransomware-2023-4356 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: ce35e46c-ef48-5401-b690-a3eaabf92f65

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
