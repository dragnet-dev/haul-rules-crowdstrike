// Dragnet [Ransomware]: dragnet-ransomware-2024-1819 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 98b21f05-bb55-5e98-89e7-0d7c88393af3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
