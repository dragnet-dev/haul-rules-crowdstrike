// Dragnet [Ransomware]: dragnet-ransomware-2022-2521 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: c3110f8a-e1e6-50f3-80fa-87e354f76ef5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
