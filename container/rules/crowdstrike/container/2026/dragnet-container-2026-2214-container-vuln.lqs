// Dragnet [Container]: dragnet-container-2026-2214 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 054dab27-4b85-566a-a6ff-adc2542f9547

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:7* OR ImageFileName = *debian:8* OR ImageFileName = *ubuntu:14.04* OR ImageFileName = *ubuntu:16.04* OR ImageFileName = *ubuntu:16.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
