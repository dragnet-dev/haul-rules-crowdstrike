// Dragnet [Ransomware]: dragnet-ransomware-2022-1808 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 70a19db1-f636-599d-876b-b0dafe0bed82

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
