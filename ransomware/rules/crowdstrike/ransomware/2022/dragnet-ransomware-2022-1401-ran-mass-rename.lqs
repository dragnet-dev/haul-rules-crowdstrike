// Dragnet [Ransomware]: dragnet-ransomware-2022-1401 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: f50497fc-dbe2-5a63-ba22-52d152d1ba2f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
