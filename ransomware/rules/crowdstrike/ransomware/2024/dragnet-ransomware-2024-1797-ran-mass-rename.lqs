// Dragnet [Ransomware]: dragnet-ransomware-2024-1797 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 3243ded3-2d24-573c-8c71-6e9f21d6fe29

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
