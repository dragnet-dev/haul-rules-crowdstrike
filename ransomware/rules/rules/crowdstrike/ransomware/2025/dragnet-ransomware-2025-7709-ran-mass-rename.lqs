// Dragnet [Ransomware]: dragnet-ransomware-2025-7709 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: d6653332-df48-543c-bb7c-b4eb14c2f992

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
