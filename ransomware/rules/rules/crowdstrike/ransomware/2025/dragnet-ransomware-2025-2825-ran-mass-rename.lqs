// Dragnet [Ransomware]: dragnet-ransomware-2025-2825 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 7caac93e-c782-596c-add0-ff9e6eab8220

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
