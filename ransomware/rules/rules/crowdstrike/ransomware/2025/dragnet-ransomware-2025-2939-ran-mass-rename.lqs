// Dragnet [Ransomware]: dragnet-ransomware-2025-2939 — Mass File Rename (underground)
// Status: experimental | Level: high | ID: 48d30b0c-c534-5fc3-a5f0-2ba963245f7a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
