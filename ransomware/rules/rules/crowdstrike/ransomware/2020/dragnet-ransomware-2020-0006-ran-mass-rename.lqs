// Dragnet [Ransomware]: dragnet-ransomware-2020-0006 — Mass File Rename (maze)
// Status: deprecated | Level: high | ID: 359be7b3-fe43-5d1b-b8d8-5ec778774bfd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
