// Dragnet [Ransomware]: dragnet-ransomware-2024-3381 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: e1af3954-7e18-5af1-97d2-4cd0ea9ec03a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
