// Dragnet [Ransomware]: dragnet-ransomware-2022-2586 — Mass File Rename (onyx)
// Status: deprecated | Level: high | ID: 20fa0492-f842-5a64-8894-43b70d946e61

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
