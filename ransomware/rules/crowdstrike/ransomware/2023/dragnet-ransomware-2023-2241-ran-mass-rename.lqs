// Dragnet [Ransomware]: dragnet-ransomware-2023-2241 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: c1716843-4600-5cfc-aaa7-cddb18726b31

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
