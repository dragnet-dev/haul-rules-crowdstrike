// Dragnet [Ransomware]: dragnet-ransomware-2021-0572 — Mass File Rename (avaddon)
// Status: deprecated | Level: high | ID: c1aa630f-e9f2-5fc6-97ab-b667e53e606c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
