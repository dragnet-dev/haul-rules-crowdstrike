// Dragnet [Ransomware]: dragnet-ransomware-2022-1165 — Mass File Rename (blackbasta)
// Status: deprecated | Level: high | ID: 85ef0de1-b1f5-5b89-9dbe-a39388c7a4c7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
