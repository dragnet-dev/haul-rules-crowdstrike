// Dragnet [Ransomware]: dragnet-ransomware-2023-0823 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: 9ae6ece8-c3d4-57d7-bd72-ceb56f4c51f9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
