// Dragnet [Ransomware]: dragnet-ransomware-2024-3362 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: de27653a-13b1-5651-949d-8886d9bf0587

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
