// Dragnet [Ransomware]: dragnet-ransomware-2022-1960 — Mass File Rename (onyx)
// Status: deprecated | Level: high | ID: 8d74f25a-55cb-5a4c-8a95-e943b4fef48e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
