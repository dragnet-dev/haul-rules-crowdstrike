// Dragnet [Ransomware]: dragnet-ransomware-2025-7001 — Mass File Rename (akira)
// Status: experimental | Level: high | ID: 29cd8118-2ec3-50e3-bce4-78400ee364fb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
