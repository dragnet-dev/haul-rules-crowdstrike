// Dragnet [Container]: dragnet-container-2024-0279 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: f49a472b-4829-5611-b1c2-51617b4943f0

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *ubuntu:19.10*)
| table([timestamp, ComputerName])
| limit(1000)
