// Dragnet [Ransomware]: dragnet-ransomware-2023-3906 — Mass File Rename (royal)
// Status: experimental | Level: high | ID: 88a9bf92-42b7-57e7-8c9a-518f9d69cee9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
