// Dragnet [Ransomware]: dragnet-ransomware-2025-0030 — Mass File Rename (sarcoma)
// Status: deprecated | Level: high | ID: bf2dd17b-b88d-52aa-b47e-35253a3bfda3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
