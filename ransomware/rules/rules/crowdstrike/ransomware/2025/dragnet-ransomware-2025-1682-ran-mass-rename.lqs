// Dragnet [Ransomware]: dragnet-ransomware-2025-1682 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: a097d38f-1b2e-58d0-9971-7e42d4d1f6a7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
