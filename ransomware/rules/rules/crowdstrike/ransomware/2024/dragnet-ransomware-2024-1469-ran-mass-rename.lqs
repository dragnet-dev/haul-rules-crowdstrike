// Dragnet [Ransomware]: dragnet-ransomware-2024-1469 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 33991db1-89d7-521c-ba58-c479304e800d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
