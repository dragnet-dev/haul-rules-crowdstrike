// Dragnet [Ransomware]: dragnet-ransomware-2026-2234 — Mass File Rename (shinyhunters)
// Status: deprecated | Level: high | ID: 11bd3984-64d5-54ce-b1fc-df8b57eab756

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
