// Dragnet [Ransomware]: dragnet-ransomware-2023-1249 — Mass File Rename (royal)
// Status: experimental | Level: high | ID: 22b8c675-07e5-5aaa-a35b-be82174e5172

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
