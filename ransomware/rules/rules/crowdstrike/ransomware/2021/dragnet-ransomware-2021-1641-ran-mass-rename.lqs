// Dragnet [Ransomware]: dragnet-ransomware-2021-1641 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 28fd8f63-a681-5060-af76-84b84505d8cb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
