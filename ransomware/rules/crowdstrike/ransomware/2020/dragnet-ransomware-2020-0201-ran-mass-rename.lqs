// Dragnet [Ransomware]: dragnet-ransomware-2020-0201 — Mass File Rename (ryuk)
// Status: deprecated | Level: high | ID: 634462e1-46e9-5158-bae0-be9c8e384c4a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
