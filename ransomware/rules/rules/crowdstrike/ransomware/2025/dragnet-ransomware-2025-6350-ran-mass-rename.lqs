// Dragnet [Ransomware]: dragnet-ransomware-2025-6350 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 4be3503d-945b-5cfe-9cba-c1c399082a98

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
