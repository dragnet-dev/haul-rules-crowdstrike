// Dragnet [Ransomware]: dragnet-ransomware-2023-5082 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 9934e36e-1790-5d4a-8a5c-b59b6b7d445c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
