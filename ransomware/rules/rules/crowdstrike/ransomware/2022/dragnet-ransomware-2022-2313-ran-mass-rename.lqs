// Dragnet [Ransomware]: dragnet-ransomware-2022-2313 — Mass File Rename (lapsus$)
// Status: deprecated | Level: high | ID: 95f9349f-8ce8-59f8-adcc-5f780676f11d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
