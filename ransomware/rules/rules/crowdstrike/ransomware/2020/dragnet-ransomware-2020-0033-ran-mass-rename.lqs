// Dragnet [Ransomware]: dragnet-ransomware-2020-0033 — Mass File Rename (netwalker)
// Status: deprecated | Level: high | ID: 232c57a6-e134-5a8c-9d64-0df5d826902b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
