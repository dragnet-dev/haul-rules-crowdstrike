// Dragnet [Ransomware]: dragnet-ransomware-2024-2611 — Mass File Rename (dragonforce)
// Status: deprecated | Level: high | ID: 3588a665-7e21-5884-a3cd-ef799ab1d5d0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
