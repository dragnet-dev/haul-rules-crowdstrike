// Dragnet [Ransomware]: dragnet-ransomware-2024-3150 — Mass File Rename (apt73)
// Status: experimental | Level: high | ID: aa41abe0-3671-501e-82f8-ad6d5277cbbb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
