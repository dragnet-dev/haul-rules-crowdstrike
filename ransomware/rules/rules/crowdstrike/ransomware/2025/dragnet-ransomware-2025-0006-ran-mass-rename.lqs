// Dragnet [Ransomware]: dragnet-ransomware-2025-0006 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 97b31f79-d71d-5ff0-813d-46b4efa64163

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
