// Dragnet [Ransomware]: dragnet-ransomware-2022-0351 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 0ff1298f-dff1-5768-a2d2-ed84fa7dd599

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
