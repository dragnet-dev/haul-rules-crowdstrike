// Dragnet [Ransomware]: dragnet-ransomware-2025-3494 — Mass File Rename (rhysida)
// Status: deprecated | Level: high | ID: b896c1f2-5d14-5cd9-b67a-2093bddbb725

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
