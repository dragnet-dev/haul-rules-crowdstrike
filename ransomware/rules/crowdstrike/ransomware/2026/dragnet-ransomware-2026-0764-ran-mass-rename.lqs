// Dragnet [Ransomware]: dragnet-ransomware-2026-0764 — Mass File Rename (TiMc)
// Status: deprecated | Level: high | ID: 21a198f6-e026-5daf-88d7-f201d00dfac8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
