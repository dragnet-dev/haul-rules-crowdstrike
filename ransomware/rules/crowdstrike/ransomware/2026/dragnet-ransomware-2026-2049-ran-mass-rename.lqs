// Dragnet [Ransomware]: dragnet-ransomware-2026-2049 — Mass File Rename (shinyhunters)
// Status: deprecated | Level: high | ID: ab156c04-1e58-5b01-a7f6-fd7e2c09dec2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
