// Dragnet [Ransomware]: dragnet-ransomware-2025-2707 — Mass File Rename (ransomhouse)
// Status: test | Level: high | ID: c4be2044-b9d7-50a9-b152-0170d1a2ae13

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
