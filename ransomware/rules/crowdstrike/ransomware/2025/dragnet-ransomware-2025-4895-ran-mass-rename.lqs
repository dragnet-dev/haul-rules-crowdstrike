// Dragnet [Ransomware]: dragnet-ransomware-2025-4895 — Mass File Rename (SilentRansomGroup)
// Status: deprecated | Level: high | ID: 2cb0972a-bbb6-55fa-a98d-0ef8a6ac2a1c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
