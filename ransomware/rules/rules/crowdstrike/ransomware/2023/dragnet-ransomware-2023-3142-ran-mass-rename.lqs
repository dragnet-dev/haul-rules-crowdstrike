// Dragnet [Ransomware]: dragnet-ransomware-2023-3142 — Mass File Rename (meow)
// Status: experimental | Level: high | ID: d233d4fc-9f35-5b76-a333-f60532b5ed2a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
