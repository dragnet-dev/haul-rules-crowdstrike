// Dragnet [Ransomware]: dragnet-ransomware-2022-0189 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 5562e589-ccf5-5b01-b232-9e8be2f58ca0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
