// Dragnet [Ransomware]: dragnet-ransomware-2021-1065 — Mass File Rename (spook)
// Status: deprecated | Level: high | ID: b16ea2e3-b8ae-5fda-8f1f-008fc3268be2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
