// Dragnet [Ransomware]: dragnet-ransomware-2024-2782 — Mass File Rename (embargo)
// Status: experimental | Level: high | ID: 99053d1f-1945-5605-9e1b-ec73a94851cf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
