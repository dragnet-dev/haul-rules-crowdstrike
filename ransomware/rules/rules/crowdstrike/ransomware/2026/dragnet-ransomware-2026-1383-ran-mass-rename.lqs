// Dragnet [Ransomware]: dragnet-ransomware-2026-1383 — Mass File Rename (dragonforce)
// Status: stable | Level: high | ID: 37ae4966-fd7f-54dd-9845-bbd0adfcc4b7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
