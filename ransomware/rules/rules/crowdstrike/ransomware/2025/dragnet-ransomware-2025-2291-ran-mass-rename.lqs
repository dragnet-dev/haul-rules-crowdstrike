// Dragnet [Ransomware]: dragnet-ransomware-2025-2291 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: d894ebce-691d-5674-84bb-8cc1d7cf7eb8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
