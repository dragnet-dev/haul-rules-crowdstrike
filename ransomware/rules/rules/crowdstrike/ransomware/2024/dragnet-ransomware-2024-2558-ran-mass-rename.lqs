// Dragnet [Ransomware]: dragnet-ransomware-2024-2558 — Mass File Rename (snatch)
// Status: experimental | Level: high | ID: daa43cc2-cdf7-52cf-b44d-b38aedda4132

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
