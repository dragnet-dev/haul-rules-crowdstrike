// Dragnet [Ransomware]: dragnet-ransomware-2025-7089 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: a85ba642-688c-54b6-a67e-55e5ffdbd612

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
