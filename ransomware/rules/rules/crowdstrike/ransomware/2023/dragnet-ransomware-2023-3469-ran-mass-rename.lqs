// Dragnet [Ransomware]: dragnet-ransomware-2023-3469 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: c81ea0e7-e682-5801-a193-8a8dab8c4b3b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
