// Dragnet [Ransomware]: dragnet-ransomware-2023-5229 — Mass File Rename (medusalocker)
// Status: experimental | Level: high | ID: 065a2322-3706-5e85-acb0-d585df75a596

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
