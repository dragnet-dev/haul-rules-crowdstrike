// Dragnet [Ransomware]: dragnet-ransomware-2024-3303 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 1ceb2051-b955-5a84-8385-8ea962cf426a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
