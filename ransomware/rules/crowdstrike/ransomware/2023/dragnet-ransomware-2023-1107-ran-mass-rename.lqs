// Dragnet [Ransomware]: dragnet-ransomware-2023-1107 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 3a56d84e-8436-5587-9b19-8549624a15d0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
