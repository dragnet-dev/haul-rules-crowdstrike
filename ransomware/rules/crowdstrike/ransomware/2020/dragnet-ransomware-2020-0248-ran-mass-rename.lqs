// Dragnet [Ransomware]: dragnet-ransomware-2020-0248 — Mass File Rename (pay2key)
// Status: deprecated | Level: high | ID: 03164c2f-7e52-5611-9007-9624c64f6a22

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
