// Dragnet [Ransomware]: dragnet-ransomware-2024-2559 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 86aff4c1-8d0e-5848-9e45-2713eac28e1f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
