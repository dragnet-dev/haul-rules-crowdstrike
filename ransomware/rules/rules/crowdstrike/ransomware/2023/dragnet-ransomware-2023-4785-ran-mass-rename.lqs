// Dragnet [Ransomware]: dragnet-ransomware-2023-4785 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: e5f0ae2b-94df-51ed-b8d9-7d4730ee38b4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
