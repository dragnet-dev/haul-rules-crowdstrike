// Dragnet [Ransomware]: dragnet-ransomware-2023-0836 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: e19093b8-90d1-5eb2-a6a1-ade318188b2c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
