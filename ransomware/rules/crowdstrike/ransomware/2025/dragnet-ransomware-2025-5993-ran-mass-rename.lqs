// Dragnet [Ransomware]: dragnet-ransomware-2025-5993 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: d7d91728-893d-5e76-9ad4-881f7e5faca2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
