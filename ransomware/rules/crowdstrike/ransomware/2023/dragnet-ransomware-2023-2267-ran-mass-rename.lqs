// Dragnet [Ransomware]: dragnet-ransomware-2023-2267 — Mass File Rename (royal)
// Status: experimental | Level: high | ID: 41d38818-d84d-52b4-9566-96916d0da096

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
