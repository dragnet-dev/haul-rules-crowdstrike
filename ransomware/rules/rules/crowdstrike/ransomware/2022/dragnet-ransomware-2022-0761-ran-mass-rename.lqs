// Dragnet [Ransomware]: dragnet-ransomware-2022-0761 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 32a1f33d-20ad-5738-8bce-c307fefee0cd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
