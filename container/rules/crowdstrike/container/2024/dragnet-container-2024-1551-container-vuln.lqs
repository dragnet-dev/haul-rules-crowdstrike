// Dragnet [Container]: dragnet-container-2024-1551 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 26565ddf-8ad7-5d1f-a204-0855363422c2

#event_simpleName=*
| (ImageFileName = *alpine:3.18* OR ImageFileName = *alpine:3.19* OR ImageFileName = *alpine:3.20* OR ImageFileName = *alpine:3.21* OR ImageFileName = *alpine:3.22* OR ImageFileName = *alpine:3.23* OR ImageFileName = *alpine edge:* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *ubuntu:23.04* OR ImageFileName = *ubuntu:23.10*)
| table([timestamp, ComputerName])
| limit(1000)
