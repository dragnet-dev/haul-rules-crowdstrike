// Dragnet [Ransomware]: dragnet-ransomware-2025-5146 — Mass File Rename (shinyhunters)
// Status: experimental | Level: high | ID: 872110c3-6cea-5d9a-85d0-8597e4b388e1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
