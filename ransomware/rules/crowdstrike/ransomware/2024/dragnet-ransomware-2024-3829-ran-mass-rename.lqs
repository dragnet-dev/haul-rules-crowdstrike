// Dragnet [Ransomware]: dragnet-ransomware-2024-3829 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: d8870045-5958-58d5-bb59-8292488fef7b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
