// Dragnet [Ransomware]: dragnet-ransomware-2025-6159 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: ac52e25d-50c9-5eaf-92dd-fad7f1f69230

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
