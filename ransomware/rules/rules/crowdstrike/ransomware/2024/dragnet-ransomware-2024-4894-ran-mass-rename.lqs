// Dragnet [Ransomware]: dragnet-ransomware-2024-4894 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 8561ac63-0869-5c2d-910f-6ac74e5b1406

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
