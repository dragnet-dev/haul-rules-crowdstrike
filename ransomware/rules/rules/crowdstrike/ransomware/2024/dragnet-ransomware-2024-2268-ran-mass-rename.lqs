// Dragnet [Ransomware]: dragnet-ransomware-2024-2268 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: d382d6e3-cdc7-58e2-bf3f-414ca450b793

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
