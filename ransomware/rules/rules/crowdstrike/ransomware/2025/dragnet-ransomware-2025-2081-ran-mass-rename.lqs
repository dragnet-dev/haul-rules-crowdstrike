// Dragnet [Ransomware]: dragnet-ransomware-2025-2081 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: c37dc54f-10e8-58c2-add7-8c33294981f8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
