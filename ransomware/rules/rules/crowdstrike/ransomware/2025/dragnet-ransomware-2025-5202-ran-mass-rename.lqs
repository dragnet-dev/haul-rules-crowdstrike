// Dragnet [Ransomware]: dragnet-ransomware-2025-5202 — Mass File Rename (cicada3301)
// Status: experimental | Level: high | ID: e0e66204-2dc3-5eee-ae9f-789f0c299670

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
