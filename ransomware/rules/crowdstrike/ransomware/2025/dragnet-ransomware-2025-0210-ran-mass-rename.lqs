// Dragnet [Ransomware]: dragnet-ransomware-2025-0210 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 319adaf7-0c6c-58af-b2cb-dcf9ed08f644

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
