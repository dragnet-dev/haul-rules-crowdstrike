// Dragnet [Ransomware]: dragnet-ransomware-2025-0253 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 5ef08060-cbad-5c84-8c63-b67ce8f5599a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
