// Dragnet [Ransomware]: dragnet-ransomware-2022-0117 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 446ebb24-b101-5d6d-b2f3-6ce5886dd265

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
