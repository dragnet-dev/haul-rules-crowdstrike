// Dragnet [Ransomware]: dragnet-ransomware-2022-1014 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: d7567099-0441-5f4d-bf14-3690bb23a777

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
