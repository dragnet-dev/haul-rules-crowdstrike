// Dragnet [Ransomware]: dragnet-ransomware-2023-2819 — Mass File Rename (malas)
// Status: experimental | Level: high | ID: e58413e2-af67-5a20-885d-11f20f84e9b1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
