// Dragnet [Ransomware]: dragnet-ransomware-2025-4529 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 4e84b8f9-9dd8-5b40-a124-7a0442e7e039

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
