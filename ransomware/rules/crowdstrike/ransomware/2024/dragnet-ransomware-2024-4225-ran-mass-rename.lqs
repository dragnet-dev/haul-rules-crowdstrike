// Dragnet [Ransomware]: dragnet-ransomware-2024-4225 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: c7e66048-9bc4-5491-9d0a-6123342b7e74

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
