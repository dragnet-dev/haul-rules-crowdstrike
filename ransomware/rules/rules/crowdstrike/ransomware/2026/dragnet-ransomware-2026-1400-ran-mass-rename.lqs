// Dragnet [Ransomware]: dragnet-ransomware-2026-1400 — Mass File Rename (everest)
// Status: stable | Level: high | ID: ea313e57-f224-5491-942c-a29166160256

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
