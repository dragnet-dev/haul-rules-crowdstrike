// Dragnet [Ransomware]: dragnet-ransomware-2024-3297 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: c4bb7d2b-4add-5fb1-81cb-a9f708626a98

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
