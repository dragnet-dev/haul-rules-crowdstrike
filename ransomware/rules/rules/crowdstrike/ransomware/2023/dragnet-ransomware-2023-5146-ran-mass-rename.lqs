// Dragnet [Ransomware]: dragnet-ransomware-2023-5146 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 9ffa52b6-3a3a-508d-8ad6-b313339c4227

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
