// Dragnet [Ransomware]: dragnet-ransomware-2026-2990 — Mass File Rename (vect)
// Status: deprecated | Level: high | ID: 71511cdb-2ebe-5641-8f07-61287a8a96d6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
