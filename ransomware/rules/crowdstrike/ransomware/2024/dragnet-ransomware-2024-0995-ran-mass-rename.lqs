// Dragnet [Ransomware]: dragnet-ransomware-2024-0995 — Mass File Rename (dragonforce)
// Status: deprecated | Level: high | ID: 5bf10aad-eefc-5c4d-8022-79d6028820f9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
