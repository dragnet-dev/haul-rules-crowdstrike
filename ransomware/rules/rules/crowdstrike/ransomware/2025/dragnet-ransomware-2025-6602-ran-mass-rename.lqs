// Dragnet [Ransomware]: dragnet-ransomware-2025-6602 — Mass File Rename (securotrop)
// Status: experimental | Level: high | ID: f01a9d72-b64e-568c-820f-65dfdafb59e8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
