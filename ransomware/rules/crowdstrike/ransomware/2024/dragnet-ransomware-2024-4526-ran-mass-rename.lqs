// Dragnet [Ransomware]: dragnet-ransomware-2024-4526 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: eb5f4f25-6020-5e1a-8ab9-0c268da93479

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
