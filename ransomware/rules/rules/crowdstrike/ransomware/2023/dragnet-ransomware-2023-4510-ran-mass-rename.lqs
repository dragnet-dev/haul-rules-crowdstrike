// Dragnet [Ransomware]: dragnet-ransomware-2023-4510 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 25a73727-170f-537e-bfde-22c5e43b14d9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
