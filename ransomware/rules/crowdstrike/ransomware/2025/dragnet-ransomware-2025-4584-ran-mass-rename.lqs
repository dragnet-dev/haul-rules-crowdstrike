// Dragnet [Ransomware]: dragnet-ransomware-2025-4584 — Mass File Rename (direwolf)
// Status: experimental | Level: high | ID: d59c317c-fc03-5c23-9e92-a936b99dcd09

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
