// Dragnet [Ransomware]: dragnet-ransomware-2026-1635 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 61a1e8aa-43c6-56e8-9806-f25de1cce749

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
