// Dragnet [Ransomware]: dragnet-ransomware-2023-3816 — Mass File Rename (dragonforce)
// Status: deprecated | Level: high | ID: 0670fe60-c973-5a9f-8715-3d40e14c6b94

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
