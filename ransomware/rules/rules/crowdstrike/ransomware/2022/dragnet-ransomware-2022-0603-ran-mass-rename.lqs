// Dragnet [Ransomware]: dragnet-ransomware-2022-0603 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 5f6cddbb-6c9e-524f-98f4-927a06a34c79

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
