// Dragnet [Ransomware]: dragnet-ransomware-2022-2127 — Mass File Rename (quantum)
// Status: deprecated | Level: high | ID: c30aaf92-5f03-50b0-99ed-b11265e32e83

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
