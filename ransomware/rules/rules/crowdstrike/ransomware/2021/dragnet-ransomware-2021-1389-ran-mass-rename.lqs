// Dragnet [Ransomware]: dragnet-ransomware-2021-1389 — Mass File Rename (ransomexx)
// Status: deprecated | Level: high | ID: 9f26ef1c-bf45-57ca-ad4a-88d2e85caea3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
