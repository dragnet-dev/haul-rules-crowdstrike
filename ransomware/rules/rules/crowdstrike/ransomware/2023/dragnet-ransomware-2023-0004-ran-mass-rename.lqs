// Dragnet [Ransomware]: dragnet-ransomware-2023-0004 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 6339087c-2096-5489-8a76-e2729ba57ea3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
