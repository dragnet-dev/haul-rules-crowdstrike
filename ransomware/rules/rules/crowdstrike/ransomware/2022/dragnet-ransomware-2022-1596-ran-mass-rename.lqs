// Dragnet [Ransomware]: dragnet-ransomware-2022-1596 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 9994e20f-ea59-56ba-9956-1e71898a3dad

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
