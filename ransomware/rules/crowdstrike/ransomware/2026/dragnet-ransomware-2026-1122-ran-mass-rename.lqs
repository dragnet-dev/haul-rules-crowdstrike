// Dragnet [Ransomware]: dragnet-ransomware-2026-1122 — Mass File Rename (thegentlemen)
// Status: test | Level: high | ID: f59fcb8b-c675-5700-8c20-cc17062e1de5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
