// Dragnet [Ransomware]: dragnet-ransomware-2023-3825 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: c0c61dee-9013-55fd-905b-e2307193b1bb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
