// Dragnet [Ransomware]: dragnet-ransomware-2023-5091 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: e1dce877-a234-5c64-b911-a348a65e76cb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
