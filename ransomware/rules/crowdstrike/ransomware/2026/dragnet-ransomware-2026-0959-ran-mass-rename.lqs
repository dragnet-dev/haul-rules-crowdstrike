// Dragnet [Ransomware]: dragnet-ransomware-2026-0959 — Mass File Rename (krybit)
// Status: stable | Level: high | ID: 6bb1d72f-81ff-50f0-bebb-00576244e5bc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
