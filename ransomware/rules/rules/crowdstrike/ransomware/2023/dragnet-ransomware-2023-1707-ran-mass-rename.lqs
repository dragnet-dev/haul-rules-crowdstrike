// Dragnet [Ransomware]: dragnet-ransomware-2023-1707 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 5ca9a0e1-9c48-5caf-b52f-bec1a619d146

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
