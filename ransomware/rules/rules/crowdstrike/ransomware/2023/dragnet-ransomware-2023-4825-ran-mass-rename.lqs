// Dragnet [Ransomware]: dragnet-ransomware-2023-4825 — Mass File Rename (vicesociety)
// Status: experimental | Level: high | ID: ff51b3c9-caea-5ea8-8001-647bd10db9d5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
