// Dragnet [Ransomware]: dragnet-ransomware-2026-1644 — Mass File Rename (anubis)
// Status: stable | Level: high | ID: bde4808c-95a9-5bf6-9752-66ed51dd7a6c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
