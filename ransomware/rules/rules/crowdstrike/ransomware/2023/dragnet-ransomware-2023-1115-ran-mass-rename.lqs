// Dragnet [Ransomware]: dragnet-ransomware-2023-1115 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 6e61702f-403e-58c3-bbd6-b1bce45808ba

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
