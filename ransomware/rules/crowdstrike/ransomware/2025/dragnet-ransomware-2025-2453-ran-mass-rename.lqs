// Dragnet [Ransomware]: dragnet-ransomware-2025-2453 — Mass File Rename (thegentlemen)
// Status: experimental | Level: high | ID: c1ac0e68-5a6f-52fe-8ba5-10a8e0e7dcba

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
