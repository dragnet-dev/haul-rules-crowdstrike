// Dragnet [Ransomware]: dragnet-ransomware-2024-0850 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 74c84d70-cf16-5ebe-b467-68f47abcf913

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
