// Dragnet [Ransomware]: dragnet-ransomware-2025-4876 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 06ba1487-2865-5ed8-9084-3617f18199c2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
