// Dragnet [Ransomware]: dragnet-ransomware-2025-7482 — Mass File Rename (morpheus)
// Status: deprecated | Level: high | ID: 2b7a62dc-3c0b-5ec7-a570-102723417c7c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
