// Dragnet [Ransomware]: dragnet-ransomware-2023-1010 — Mass File Rename (ransomexx)
// Status: experimental | Level: high | ID: 1deb6a26-50eb-5183-af81-513f66201cb6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
