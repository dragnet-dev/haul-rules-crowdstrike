// Dragnet [Ransomware]: dragnet-ransomware-2021-0890 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 58d28863-d36b-5ae1-b029-b25933bc6710

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
