// Dragnet [Ransomware]: dragnet-ransomware-2021-0194 — Mass File Rename (pay2key)
// Status: deprecated | Level: high | ID: 22629b68-74ab-5075-8740-8cb3245b3d16

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
