// Dragnet [Ransomware]: dragnet-ransomware-2025-2892 — Mass File Rename (cloak)
// Status: deprecated | Level: high | ID: 2c16fc34-647e-5e23-8659-3af228b62445

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
