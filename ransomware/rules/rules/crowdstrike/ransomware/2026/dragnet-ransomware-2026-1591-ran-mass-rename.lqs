// Dragnet [Ransomware]: dragnet-ransomware-2026-1591 — Mass File Rename (incransom)
// Status: stable | Level: high | ID: 2bc09a34-1d62-5698-9a60-d4bcffabd18d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
