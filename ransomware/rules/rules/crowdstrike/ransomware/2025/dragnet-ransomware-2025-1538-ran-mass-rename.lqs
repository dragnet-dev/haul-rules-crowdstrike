// Dragnet [Ransomware]: dragnet-ransomware-2025-1538 — Mass File Rename (direwolf)
// Status: test | Level: high | ID: ae0a30a2-a9df-5552-8702-0f453faa4d72

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
