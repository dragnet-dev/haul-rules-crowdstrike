// Dragnet [Ransomware]: dragnet-ransomware-2023-4522 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: f3c42c32-ba47-5f36-871b-b8e5aa96b6f1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
