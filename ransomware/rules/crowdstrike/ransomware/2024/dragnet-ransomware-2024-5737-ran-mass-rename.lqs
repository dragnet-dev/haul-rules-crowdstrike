// Dragnet [Ransomware]: dragnet-ransomware-2024-5737 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: ded1044e-d282-5ae2-ad41-307d4309e833

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
