// Dragnet [Ransomware]: dragnet-ransomware-2020-0263 — Mass File Rename (ransomexx)
// Status: deprecated | Level: high | ID: 4e609c8a-c9a7-521f-afb0-50b080d4f84f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
