// Dragnet [Ransomware]: dragnet-ransomware-2024-4138 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: f9876b93-cc82-5b45-bc80-444f003dfbd2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
