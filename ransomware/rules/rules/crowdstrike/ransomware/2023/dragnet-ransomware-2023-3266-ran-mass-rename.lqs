// Dragnet [Ransomware]: dragnet-ransomware-2023-3266 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: cda3b4e2-3f98-5b47-9a8f-96eef94718b3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
