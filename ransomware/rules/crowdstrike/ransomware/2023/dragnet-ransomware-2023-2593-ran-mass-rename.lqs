// Dragnet [Ransomware]: dragnet-ransomware-2023-2593 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 3c0c7b5a-ca90-5848-acc1-2533b502d2c8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
