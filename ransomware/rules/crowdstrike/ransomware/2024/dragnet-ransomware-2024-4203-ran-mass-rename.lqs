// Dragnet [Ransomware]: dragnet-ransomware-2024-4203 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 93b9fd8a-f21a-5cf7-be94-d24d345b905f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
