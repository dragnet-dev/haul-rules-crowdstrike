// Dragnet [Ransomware]: dragnet-ransomware-2025-2548 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: b33a0d8e-f8c7-5f1b-b56f-1f2451b69942

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
