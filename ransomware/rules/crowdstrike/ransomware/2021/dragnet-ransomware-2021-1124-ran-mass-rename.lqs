// Dragnet [Ransomware]: dragnet-ransomware-2021-1124 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 62c3042b-a4cb-5641-9196-d56426c87c8a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
