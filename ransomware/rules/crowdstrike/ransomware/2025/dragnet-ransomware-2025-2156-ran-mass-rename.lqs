// Dragnet [Ransomware]: dragnet-ransomware-2025-2156 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 1416bdca-0d1d-5c01-af59-e6880038cc09

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
