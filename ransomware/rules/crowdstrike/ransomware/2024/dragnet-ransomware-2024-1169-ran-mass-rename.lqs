// Dragnet [Ransomware]: dragnet-ransomware-2024-1169 — Mass File Rename (BrainCipher)
// Status: experimental | Level: high | ID: 4fae4c84-1dd7-5ca6-a3de-7832851c9f3a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
