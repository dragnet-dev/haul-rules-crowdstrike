// Dragnet [Ransomware]: dragnet-ransomware-2022-2980 — Mass File Rename (ransomexx)
// Status: experimental | Level: high | ID: b3397915-41b4-518a-8230-922ddd595c0c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
