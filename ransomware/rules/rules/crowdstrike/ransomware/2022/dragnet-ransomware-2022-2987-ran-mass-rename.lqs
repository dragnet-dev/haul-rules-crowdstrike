// Dragnet [Ransomware]: dragnet-ransomware-2022-2987 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 165275c8-7cbd-5411-b53f-63122a78f575

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
