// Dragnet [Ransomware]: dragnet-ransomware-2025-0966 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: f57bb4d9-63e4-570b-a3f0-3bfdec7bfc25

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
