// Dragnet [Ransomware]: dragnet-ransomware-2022-1686 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 63288bde-1658-550f-a81b-37a189f2e5a5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
