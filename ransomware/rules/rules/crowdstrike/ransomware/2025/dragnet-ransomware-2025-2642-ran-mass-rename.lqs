// Dragnet [Ransomware]: dragnet-ransomware-2025-2642 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: b07af84c-e854-5964-a302-e41bd53ba06a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
