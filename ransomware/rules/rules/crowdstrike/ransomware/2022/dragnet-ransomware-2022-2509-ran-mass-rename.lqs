// Dragnet [Ransomware]: dragnet-ransomware-2022-2509 — Mass File Rename (everest)
// Status: deprecated | Level: high | ID: bc115e91-45bd-5119-b9e8-a157d6023e24

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
