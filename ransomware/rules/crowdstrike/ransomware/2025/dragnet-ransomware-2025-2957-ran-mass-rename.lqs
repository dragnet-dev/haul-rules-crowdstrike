// Dragnet [Ransomware]: dragnet-ransomware-2025-2957 — Mass File Rename (radar)
// Status: deprecated | Level: high | ID: fcc3656e-4eb1-5af3-b3c2-1e4650ae5f51

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
