// Dragnet [Ransomware]: dragnet-ransomware-2025-6349 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: a6ec8f41-2aa5-55e4-a73b-e106289dc3a7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
