// Dragnet [Ransomware]: dragnet-ransomware-2023-0205 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 1300e2f7-7bfa-50dd-9c33-dc1caeda7feb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
