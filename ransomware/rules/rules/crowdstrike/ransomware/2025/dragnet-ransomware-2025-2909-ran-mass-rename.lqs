// Dragnet [Ransomware]: dragnet-ransomware-2025-2909 — Mass File Rename (nitrogen)
// Status: experimental | Level: high | ID: 2f1026e2-2b7a-597b-bebf-90a76cce668d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
