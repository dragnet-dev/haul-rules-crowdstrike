// Dragnet [Ransomware]: dragnet-ransomware-2021-1337 — Mass File Rename (ransomexx)
// Status: deprecated | Level: high | ID: c28d9254-e197-512c-ad61-b4e5aad47b7c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
