// Dragnet [Ransomware]: dragnet-ransomware-2024-0195 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: b2c02a2a-6554-5dd8-a4e0-cca80a8ed4d5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
