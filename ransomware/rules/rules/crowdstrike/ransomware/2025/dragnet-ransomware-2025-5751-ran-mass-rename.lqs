// Dragnet [Ransomware]: dragnet-ransomware-2025-5751 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: e9a3b169-0d13-5f0e-8b96-8a96c561bdfa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
