// Dragnet [Ransomware]: dragnet-ransomware-2022-0840 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: 57e34c36-6561-5ab0-b322-61a0c554d0a6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
