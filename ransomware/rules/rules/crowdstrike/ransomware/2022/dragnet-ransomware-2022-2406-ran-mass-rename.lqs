// Dragnet [Ransomware]: dragnet-ransomware-2022-2406 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 0cdea7f4-8c97-52e6-a9dd-fb7e662d4ba2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
