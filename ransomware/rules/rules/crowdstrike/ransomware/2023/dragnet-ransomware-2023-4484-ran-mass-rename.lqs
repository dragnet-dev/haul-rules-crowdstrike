// Dragnet [Ransomware]: dragnet-ransomware-2023-4484 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: ad8ecf99-cb6c-5deb-b09e-2a0bcbd2629e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
