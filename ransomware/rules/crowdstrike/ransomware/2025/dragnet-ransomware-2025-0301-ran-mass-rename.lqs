// Dragnet [Ransomware]: dragnet-ransomware-2025-0301 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: c0e80e4e-78c7-51fd-a7c2-d0ed8348e27d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
