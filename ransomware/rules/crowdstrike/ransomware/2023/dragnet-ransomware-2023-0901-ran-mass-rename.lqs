// Dragnet [Ransomware]: dragnet-ransomware-2023-0901 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: d1140e29-b2c1-595b-b94f-e856bd8dc800

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
