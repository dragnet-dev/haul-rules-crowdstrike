// Dragnet [Ransomware]: dragnet-ransomware-2024-4447 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 25a964a1-fd19-57c6-9c7c-5b6852a87c94

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
