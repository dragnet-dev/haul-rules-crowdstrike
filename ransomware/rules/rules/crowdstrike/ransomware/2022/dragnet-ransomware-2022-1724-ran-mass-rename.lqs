// Dragnet [Ransomware]: dragnet-ransomware-2022-1724 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 862b0abe-ada1-53f5-8eab-ab0e3b71640f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
