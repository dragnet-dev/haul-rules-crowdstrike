// Dragnet [Ransomware]: dragnet-ransomware-2023-1313 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 3f8eed41-56ad-53b5-a6b3-4fd69ea4c4b4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
