// Dragnet [Ransomware]: dragnet-ransomware-2025-3269 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 24d537f2-09d7-50ce-baa8-5680337f7ac8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
