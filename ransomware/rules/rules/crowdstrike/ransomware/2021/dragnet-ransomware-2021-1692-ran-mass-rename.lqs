// Dragnet [Ransomware]: dragnet-ransomware-2021-1692 — Mass File Rename (revil)
// Status: deprecated | Level: high | ID: 5cc7ba2b-1f14-5093-84e8-066f96b34ebb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
