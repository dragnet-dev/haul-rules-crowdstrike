// Dragnet [Ransomware]: dragnet-ransomware-2024-2705 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 59e8ec98-1335-5ae6-a4f6-1c98f7127b19

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
