// Dragnet [Container]: dragnet-container-2026-2087 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: d9a8433a-4663-5c51-bcf3-22bd5033d794

#event_simpleName=*
| (ImageFileName = *chainguard:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
