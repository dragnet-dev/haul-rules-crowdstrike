// Dragnet [Ransomware]: dragnet-ransomware-2025-6543 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 0871d166-1e35-5fc3-aeb6-b4c6d98435b8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
