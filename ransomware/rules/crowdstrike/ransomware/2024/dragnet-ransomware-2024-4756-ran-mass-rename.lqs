// Dragnet [Ransomware]: dragnet-ransomware-2024-4756 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 9fa6e7f2-1d28-5e8c-9866-dd8c4e034d68

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
