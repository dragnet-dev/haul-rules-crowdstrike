// Dragnet [Ransomware]: dragnet-ransomware-2021-0228 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: aef585c7-e8de-513e-9a65-1a27a0e6f4dc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
