// Dragnet [Ransomware]: dragnet-ransomware-2023-3957 — Mass File Rename (snatch)
// Status: experimental | Level: high | ID: e13d4d74-f5cd-5142-807e-a77cd4f38199

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
