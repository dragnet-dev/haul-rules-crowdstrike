// Dragnet [Container]: dragnet-container-2026-0969 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 521af8c1-3696-5e4b-b849-8414666a8374

#event_simpleName=*
| (ImageFileName = *chainguard:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
