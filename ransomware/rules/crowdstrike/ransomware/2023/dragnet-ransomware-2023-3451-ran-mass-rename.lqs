// Dragnet [Ransomware]: dragnet-ransomware-2023-3451 — Mass File Rename (toufan)
// Status: deprecated | Level: high | ID: cc4b1bdb-cb13-58ab-be6f-dfa4d3f6b468

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
