// Dragnet [Ransomware]: dragnet-ransomware-2025-1530 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 78bf1b4e-8c70-5db6-beae-a2fbc4cf33c8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
