// Dragnet [Ransomware]: dragnet-ransomware-2025-0559 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 55a82c03-870a-528d-95da-8efba70484e3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
