// Dragnet [Ransomware]: dragnet-ransomware-2020-0244 — Mass File Rename (revil)
// Status: deprecated | Level: high | ID: 91b65584-8371-555c-a2bb-f0cf52a9abe5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
