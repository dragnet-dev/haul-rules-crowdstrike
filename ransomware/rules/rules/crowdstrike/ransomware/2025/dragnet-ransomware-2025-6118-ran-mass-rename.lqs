// Dragnet [Ransomware]: dragnet-ransomware-2025-6118 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: a83c8bc5-0255-530f-aef5-a934109343ed

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
