// Dragnet [Ransomware]: dragnet-ransomware-2024-3565 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: 1bb1097a-0bdb-533a-b579-eaff47330980

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
