// Dragnet [Ransomware]: dragnet-ransomware-2026-1046 — Mass File Rename (thegentlemen)
// Status: stable | Level: high | ID: b20b808d-50d3-54fb-b49e-4cdc5389c73f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
