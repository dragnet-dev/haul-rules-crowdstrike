// Dragnet [Ransomware]: dragnet-ransomware-2025-5143 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 7a4fe850-407a-58e1-a762-b56561ce953c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
