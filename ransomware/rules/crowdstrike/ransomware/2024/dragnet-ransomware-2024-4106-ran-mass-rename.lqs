// Dragnet [Ransomware]: dragnet-ransomware-2024-4106 — Mass File Rename (lockbit5)
// Status: experimental | Level: high | ID: cc6d2d08-868e-50a3-9316-e716db4be9f2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
