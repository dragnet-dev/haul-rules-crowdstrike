// Dragnet [Ransomware]: dragnet-ransomware-2024-5079 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 8a606f6c-f65e-5011-ae66-ee35d4c1d3cc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
