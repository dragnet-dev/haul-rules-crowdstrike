// Dragnet [Ransomware]: dragnet-ransomware-2024-2531 — Mass File Rename (termite)
// Status: experimental | Level: high | ID: 91d0556b-f23a-537e-92cf-dc425b972e77

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
