// Dragnet [Ransomware]: dragnet-ransomware-2023-1281 — Mass File Rename (raworld)
// Status: experimental | Level: high | ID: d50fe45c-60f8-5923-a234-e8331d2518d9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
