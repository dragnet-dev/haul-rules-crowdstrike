// Dragnet [Ransomware]: dragnet-ransomware-2025-0271 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: e2cc5c06-265e-52cc-8a3b-b78d76ce0fa4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
