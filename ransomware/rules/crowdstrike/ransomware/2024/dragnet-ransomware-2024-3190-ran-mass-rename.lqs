// Dragnet [Ransomware]: dragnet-ransomware-2024-3190 — Mass File Rename (dragonransomware)
// Status: experimental | Level: high | ID: 458f746a-cbf2-5d58-a71c-fa5d12dbb337

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
