// Dragnet [Ransomware]: dragnet-ransomware-2022-2686 — Mass File Rename (vicesociety)
// Status: deprecated | Level: high | ID: 267e7a7a-ab39-5194-80d8-c1134bb873c7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
