// Dragnet [Ransomware]: dragnet-ransomware-2023-3776 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 1f956f69-9984-59cd-83d3-3ac3a24b6436

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
