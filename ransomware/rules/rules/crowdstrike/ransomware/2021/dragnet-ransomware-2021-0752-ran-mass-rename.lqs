// Dragnet [Ransomware]: dragnet-ransomware-2021-0752 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: a20d72b6-167e-5e24-9c32-2f810d80dd4f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
