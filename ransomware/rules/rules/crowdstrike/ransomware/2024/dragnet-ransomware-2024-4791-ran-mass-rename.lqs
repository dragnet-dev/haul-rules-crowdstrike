// Dragnet [Ransomware]: dragnet-ransomware-2024-4791 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 5a0b459b-913a-5212-bd94-5e6305568807

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
