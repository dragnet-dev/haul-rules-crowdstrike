// Dragnet [Ransomware]: dragnet-ransomware-2023-4945 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 4483fa48-ac64-575e-ab9a-76c4b65794cd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
