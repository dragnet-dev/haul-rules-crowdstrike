// Dragnet [Ransomware]: dragnet-ransomware-2025-5022 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 633e1f56-9b8f-56f9-ac0a-6b5e60c87a73

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
