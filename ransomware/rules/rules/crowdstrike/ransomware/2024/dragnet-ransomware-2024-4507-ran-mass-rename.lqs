// Dragnet [Ransomware]: dragnet-ransomware-2024-4507 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 32c4f7d9-44c2-5a4e-99ab-e8ab01f994f2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
