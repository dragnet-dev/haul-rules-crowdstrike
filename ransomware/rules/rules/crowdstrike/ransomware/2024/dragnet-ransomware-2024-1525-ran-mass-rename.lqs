// Dragnet [Ransomware]: dragnet-ransomware-2024-1525 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 38e33994-9586-5e6e-8098-6a5b096732de

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
