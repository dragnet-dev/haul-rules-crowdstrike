// Dragnet [Ransomware]: dragnet-ransomware-2025-1907 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: 5a903e4f-25b7-5e05-be3d-632dd5923024

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
