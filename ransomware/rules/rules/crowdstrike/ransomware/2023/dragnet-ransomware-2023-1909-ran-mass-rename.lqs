// Dragnet [Ransomware]: dragnet-ransomware-2023-1909 — Mass File Rename (noescape)
// Status: experimental | Level: high | ID: 205d82aa-9d8f-583b-b740-b28573fe23f9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
