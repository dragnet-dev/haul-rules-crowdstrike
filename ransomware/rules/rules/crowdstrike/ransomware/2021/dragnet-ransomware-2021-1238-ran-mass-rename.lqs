// Dragnet [Ransomware]: dragnet-ransomware-2021-1238 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 71f8eac5-b68a-5dd7-8d9a-1db25b0e752b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
