// Dragnet [Ransomware]: dragnet-ransomware-2025-5734 — Mass File Rename (handala)
// Status: experimental | Level: high | ID: e11b6445-3ca0-518d-9a72-84c63713b001

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
