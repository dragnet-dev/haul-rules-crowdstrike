// Dragnet [Ransomware]: dragnet-ransomware-2023-3721 — Mass File Rename (mallox)
// Status: experimental | Level: high | ID: dd926d20-fe66-5db4-a3dd-ed1b8526e7a2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
