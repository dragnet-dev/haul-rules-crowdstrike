// Dragnet [Ransomware]: dragnet-ransomware-2023-2925 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: fbe7de56-8fc0-5bf0-9f47-ddaafc2053d3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
