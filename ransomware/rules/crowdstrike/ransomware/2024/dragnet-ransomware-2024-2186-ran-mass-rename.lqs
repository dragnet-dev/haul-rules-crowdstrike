// Dragnet [Ransomware]: dragnet-ransomware-2024-2186 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 576b62dd-177b-5336-aa3d-f31eff35d11e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
