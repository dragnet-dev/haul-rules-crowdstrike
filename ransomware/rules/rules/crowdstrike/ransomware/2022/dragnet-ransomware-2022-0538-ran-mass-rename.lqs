// Dragnet [Ransomware]: dragnet-ransomware-2022-0538 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 7535c69f-5437-5310-bbef-2d0fbe0811dc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
