// Dragnet [Ransomware]: dragnet-ransomware-2022-1310 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 333a4ab9-b9dc-5933-b260-ab091238f11a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
