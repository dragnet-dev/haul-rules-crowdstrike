// Dragnet [Ransomware]: dragnet-ransomware-2024-4637 — Mass File Rename (medusalocker)
// Status: experimental | Level: high | ID: 6b63eac7-b687-592b-863d-4ef932556540

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
