// Dragnet [Ransomware]: dragnet-ransomware-2024-2143 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 69aa5b14-5dcf-52e2-892f-58932a4f80c8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
