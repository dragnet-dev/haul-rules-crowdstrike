// Dragnet [Ransomware]: dragnet-ransomware-2024-5324 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: bc4e7d7a-f58c-5ddd-9282-a060d8fe8a6e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
