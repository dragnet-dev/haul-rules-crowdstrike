// Dragnet [Ransomware]: dragnet-ransomware-2025-4577 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 85a6e594-9967-53d5-8317-ddc75141a23b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
