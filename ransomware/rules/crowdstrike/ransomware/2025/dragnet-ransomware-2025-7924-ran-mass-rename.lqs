// Dragnet [Ransomware]: dragnet-ransomware-2025-7924 — Mass File Rename (arcusmedia)
// Status: experimental | Level: high | ID: ec72bd43-1dfd-594b-a187-6d0f0ee80d4a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
