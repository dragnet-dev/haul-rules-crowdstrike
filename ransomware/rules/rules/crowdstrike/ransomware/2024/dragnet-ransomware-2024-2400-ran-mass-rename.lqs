// Dragnet [Ransomware]: dragnet-ransomware-2024-2400 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 2ca555f7-caba-557e-8986-93cb736fdaf7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
