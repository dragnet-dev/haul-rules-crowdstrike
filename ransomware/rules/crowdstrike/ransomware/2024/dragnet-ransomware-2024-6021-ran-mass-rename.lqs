// Dragnet [Ransomware]: dragnet-ransomware-2024-6021 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: aeed57c4-2719-567c-9559-b10930811d62

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
