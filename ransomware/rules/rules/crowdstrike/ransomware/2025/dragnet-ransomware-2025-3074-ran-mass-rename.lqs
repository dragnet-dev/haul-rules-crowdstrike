// Dragnet [Ransomware]: dragnet-ransomware-2025-3074 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 9dc42c13-fb6c-574b-a7c8-dfdf5debb769

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
