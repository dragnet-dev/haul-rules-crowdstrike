// Dragnet [Ransomware]: dragnet-ransomware-2026-0898 — Mass File Rename (shinyhunters)
// Status: deprecated | Level: high | ID: 6b4e047e-11e0-50d0-a54a-893f4b3f1690

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
