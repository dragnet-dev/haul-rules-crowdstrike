// Dragnet [Ransomware]: dragnet-ransomware-2023-4641 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 909ef3a2-1dd1-51e9-94ef-61f5a4780557

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
