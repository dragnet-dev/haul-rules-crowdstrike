// Dragnet [Ransomware]: dragnet-ransomware-2021-0738 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: ff88eaf4-774b-52bc-aea2-180663a49827

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
