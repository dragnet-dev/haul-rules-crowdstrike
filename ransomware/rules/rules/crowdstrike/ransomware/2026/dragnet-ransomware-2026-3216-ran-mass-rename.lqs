// Dragnet [Ransomware]: dragnet-ransomware-2026-3216 — Mass File Rename (handala)
// Status: stable | Level: high | ID: 8084e256-6033-58d7-b8fc-cf1787aa8753

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
