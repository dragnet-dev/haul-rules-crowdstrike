// Dragnet [Ransomware]: dragnet-ransomware-2025-0472 — Mass File Rename (monti)
// Status: experimental | Level: high | ID: 49b2aad2-9a49-5bdd-b212-69d8587a95b5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
