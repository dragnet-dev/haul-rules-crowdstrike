// Dragnet [Ransomware]: dragnet-ransomware-2022-1503 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 4f1d1af5-24f0-56bb-9907-88928f2cd146

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
