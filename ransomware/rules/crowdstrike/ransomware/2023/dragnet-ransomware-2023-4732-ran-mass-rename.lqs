// Dragnet [Ransomware]: dragnet-ransomware-2023-4732 — Mass File Rename (dragonforce)
// Status: deprecated | Level: high | ID: dd1ee4ed-0a5b-5442-8ef9-9f28206a2da1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
