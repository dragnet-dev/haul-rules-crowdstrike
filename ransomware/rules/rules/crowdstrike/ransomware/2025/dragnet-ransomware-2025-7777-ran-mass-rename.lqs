// Dragnet [Ransomware]: dragnet-ransomware-2025-7777 — Mass File Rename (d4rk4rmy)
// Status: experimental | Level: high | ID: afa63e48-3eb4-5a7a-96e1-03a548f9dea0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
