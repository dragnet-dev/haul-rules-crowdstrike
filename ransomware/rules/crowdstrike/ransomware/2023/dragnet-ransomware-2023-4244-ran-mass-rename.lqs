// Dragnet [Ransomware]: dragnet-ransomware-2023-4244 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 69d6d9c3-5752-5133-bb6a-9236155f020c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
