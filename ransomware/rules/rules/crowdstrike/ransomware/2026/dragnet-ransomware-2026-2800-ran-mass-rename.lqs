// Dragnet [Ransomware]: dragnet-ransomware-2026-2800 — Mass File Rename (dragonforce)
// Status: stable | Level: high | ID: 8ef126a7-b0f5-5b69-9461-8adb43309c22

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
