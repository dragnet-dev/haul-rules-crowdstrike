// Dragnet [Ransomware]: dragnet-ransomware-2023-4946 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 82487aad-672a-52bf-b57e-5c9a57108d36

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
