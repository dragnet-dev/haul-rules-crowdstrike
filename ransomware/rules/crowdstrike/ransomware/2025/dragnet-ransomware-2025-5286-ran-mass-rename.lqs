// Dragnet [Ransomware]: dragnet-ransomware-2025-5286 — Mass File Rename (ralord)
// Status: experimental | Level: high | ID: dbf9039f-8e0f-52db-a694-25d4db6ccd3e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
