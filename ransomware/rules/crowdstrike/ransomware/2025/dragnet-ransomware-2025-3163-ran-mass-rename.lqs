// Dragnet [Ransomware]: dragnet-ransomware-2025-3163 — Mass File Rename (satanlockv2)
// Status: experimental | Level: high | ID: 43af33ed-7fda-5a7c-83dc-ee99e690959f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
