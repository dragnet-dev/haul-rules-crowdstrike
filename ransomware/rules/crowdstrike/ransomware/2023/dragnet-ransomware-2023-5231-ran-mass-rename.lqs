// Dragnet [Ransomware]: dragnet-ransomware-2023-5231 — Mass File Rename (play)
// Status: experimental | Level: high | ID: d72b2c02-01b3-5d50-ba2a-272eff9df3d3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
