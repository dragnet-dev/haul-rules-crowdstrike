// Dragnet [Ransomware]: dragnet-ransomware-2026-1469 — Mass File Rename (nightspire)
// Status: deprecated | Level: high | ID: 50471671-e20a-5cdd-8453-41133e454c47

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
