// Dragnet [Ransomware]: dragnet-ransomware-2024-0943 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: cbc5a12d-2d9e-52f4-9050-95263ea4af42

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
