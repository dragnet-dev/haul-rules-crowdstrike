// Dragnet [Container]: dragnet-container-2024-1110 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 74e57849-4006-59c5-a5ae-5c3f0065becb

#event_simpleName=*
| (ImageFileName = *oraclelinux:8* OR ImageFileName = *redhat/ubi9:*)
| table([timestamp, ComputerName])
| limit(1000)
