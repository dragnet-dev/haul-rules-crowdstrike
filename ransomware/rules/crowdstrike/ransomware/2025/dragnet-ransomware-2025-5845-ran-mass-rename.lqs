// Dragnet [Ransomware]: dragnet-ransomware-2025-5845 — Mass File Rename (gunra)
// Status: experimental | Level: high | ID: ea3d34d8-6301-5117-be38-9a25610243d9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
