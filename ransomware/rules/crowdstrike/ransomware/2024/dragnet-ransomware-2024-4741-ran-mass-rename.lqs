// Dragnet [Ransomware]: dragnet-ransomware-2024-4741 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: 389c15e4-f8f4-51fc-aa85-14fe57a74ced

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
