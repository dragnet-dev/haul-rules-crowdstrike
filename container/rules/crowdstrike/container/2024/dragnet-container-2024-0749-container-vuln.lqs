// Dragnet [Container]: dragnet-container-2024-0749 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: bc940c49-6370-5f38-8294-da9da3bdc2d0

#event_simpleName=*
| (ImageFileName = *amazonlinux:2* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *photon os:1.0* OR ImageFileName = *photon os:2.0*)
| table([timestamp, ComputerName])
| limit(1000)
