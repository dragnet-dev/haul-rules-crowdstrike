// Dragnet [Ransomware]: dragnet-ransomware-2025-1182 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 32a979ed-b0ec-5247-854c-a10030898c6f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
