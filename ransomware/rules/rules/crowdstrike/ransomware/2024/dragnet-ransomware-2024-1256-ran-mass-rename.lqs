// Dragnet [Ransomware]: dragnet-ransomware-2024-1256 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 48a05b19-3ec8-55cd-a2bc-5c1dfa629260

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
