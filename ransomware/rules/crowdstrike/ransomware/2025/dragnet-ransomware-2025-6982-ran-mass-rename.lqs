// Dragnet [Ransomware]: dragnet-ransomware-2025-6982 — Mass File Rename (securotrop)
// Status: experimental | Level: high | ID: a4fddbdc-f5cd-52be-b943-de9bddfe77e3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
