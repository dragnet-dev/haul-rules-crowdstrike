// Dragnet [Ransomware]: dragnet-ransomware-2023-0463 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: eaeb62f5-6c93-5f4c-9e24-7636c7135b70

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
