// Dragnet [Ransomware]: dragnet-ransomware-2025-1502 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 5efa12a7-57e0-5249-9299-cdda8780ced3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
