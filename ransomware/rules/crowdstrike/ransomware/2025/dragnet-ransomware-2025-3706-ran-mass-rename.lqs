// Dragnet [Ransomware]: dragnet-ransomware-2025-3706 — Mass File Rename (incransom)
// Status: test | Level: high | ID: c7ecc910-021a-5f2f-b0e1-c50da9d8e5d4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
