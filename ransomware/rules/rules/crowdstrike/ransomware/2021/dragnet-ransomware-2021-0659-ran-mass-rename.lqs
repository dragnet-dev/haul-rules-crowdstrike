// Dragnet [Ransomware]: dragnet-ransomware-2021-0659 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: 75ef4309-7a94-514b-8df0-6cd483ac0478

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
