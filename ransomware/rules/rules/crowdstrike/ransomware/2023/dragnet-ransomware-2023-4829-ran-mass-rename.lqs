// Dragnet [Ransomware]: dragnet-ransomware-2023-4829 — Mass File Rename (play)
// Status: experimental | Level: high | ID: c671d55f-c96a-5468-b223-c7b15b06d399

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
