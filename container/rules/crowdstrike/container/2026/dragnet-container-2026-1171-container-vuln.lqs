// Dragnet [Container]: dragnet-container-2026-1171 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 710089fd-2079-5e8b-b223-29cb73737f1f

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10*)
| table([timestamp, ComputerName])
| limit(1000)
