// Dragnet [Ransomware]: dragnet-ransomware-2022-1965 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 9a28a241-f90d-5515-a6bb-0801df31d997

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
