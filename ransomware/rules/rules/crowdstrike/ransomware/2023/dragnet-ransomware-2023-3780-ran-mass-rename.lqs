// Dragnet [Ransomware]: dragnet-ransomware-2023-3780 — Mass File Rename (monti)
// Status: experimental | Level: high | ID: c50fabae-a9b4-57f3-b26e-49ca8d754f73

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
