// Dragnet [Ransomware]: dragnet-ransomware-2025-7922 — Mass File Rename (ransomhouse)
// Status: test | Level: high | ID: 077c19bd-e572-5358-a004-0054368c6ed2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
