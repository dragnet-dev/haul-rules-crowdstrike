// Dragnet [Ransomware]: dragnet-ransomware-2023-4922 — Mass File Rename (noescape)
// Status: experimental | Level: high | ID: bb7f1bbb-41ab-51e5-a6f1-033a480cccae

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
