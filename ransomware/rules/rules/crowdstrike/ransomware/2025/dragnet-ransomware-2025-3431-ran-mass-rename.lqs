// Dragnet [Ransomware]: dragnet-ransomware-2025-3431 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 4fbcdcbe-9424-5927-a0e9-4c9a41f2a508

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
