// Dragnet [Ransomware]: dragnet-ransomware-2022-0968 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 9d1f879a-1416-5a12-b90b-7f583eead822

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
