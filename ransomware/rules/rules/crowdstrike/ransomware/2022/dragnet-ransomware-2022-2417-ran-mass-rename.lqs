// Dragnet [Ransomware]: dragnet-ransomware-2022-2417 — Mass File Rename (royal)
// Status: deprecated | Level: high | ID: bc0b7a24-7d14-5882-ba9d-b29a76c5d8bb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
