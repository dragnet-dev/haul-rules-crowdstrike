// Dragnet [Ransomware]: dragnet-ransomware-2026-0287 — Mass File Rename (incransom)
// Status: stable | Level: high | ID: feb6af20-8eea-56d6-8608-66fdb25b0c56

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
