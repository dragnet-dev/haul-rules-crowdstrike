// Dragnet [Container]: dragnet-container-2024-0982 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 8616451b-ea50-5b8a-8a9d-869b6c33ccd1

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:9*)
| table([timestamp, ComputerName])
| limit(1000)
