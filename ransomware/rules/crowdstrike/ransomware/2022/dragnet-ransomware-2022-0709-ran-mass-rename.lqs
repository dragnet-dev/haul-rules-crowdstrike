// Dragnet [Ransomware]: dragnet-ransomware-2022-0709 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 82138f30-eef1-564a-86de-cbe147e7a163

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
