// Dragnet [Container]: dragnet-container-2024-0333 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: f877c8c8-64cf-59b4-a022-554415577f68

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *ubuntu:20.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
