// Dragnet [Ransomware]: dragnet-ransomware-2023-1160 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: eab8cf41-719e-5ec8-b0a4-5768aa068937

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
