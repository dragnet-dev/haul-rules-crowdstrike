// Dragnet [Ransomware]: dragnet-ransomware-2023-0907 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 992c2bee-69f1-582e-9b3e-41fcc0164b9b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
