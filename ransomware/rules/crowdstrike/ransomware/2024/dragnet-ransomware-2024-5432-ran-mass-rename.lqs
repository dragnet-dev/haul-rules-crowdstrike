// Dragnet [Ransomware]: dragnet-ransomware-2024-5432 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: 2ef057d0-1315-5012-ab58-ba8c47b43f92

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
