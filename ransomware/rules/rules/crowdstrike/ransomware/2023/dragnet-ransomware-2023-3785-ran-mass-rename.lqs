// Dragnet [Ransomware]: dragnet-ransomware-2023-3785 — Mass File Rename (cactus)
// Status: deprecated | Level: high | ID: adedc0bb-1ee4-50be-a1aa-b72398cc4ef9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
