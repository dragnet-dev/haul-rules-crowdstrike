// Dragnet [Ransomware]: dragnet-ransomware-2023-5275 — Mass File Rename (play)
// Status: experimental | Level: high | ID: ae782328-7716-5eb0-b288-d0b8b2565db4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
