// Dragnet [Ransomware]: dragnet-ransomware-2023-0199 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 69fb9ec2-4ba2-5bd5-99dd-304174d06e58

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
