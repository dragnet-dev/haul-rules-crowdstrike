// Dragnet [Ransomware]: dragnet-ransomware-2022-0055 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: c463f2c8-6366-5350-8e4e-f06ca8cc18e7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
