// Dragnet [Ransomware]: dragnet-ransomware-2023-0340 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: fb3f4273-9f30-5a61-90e6-43e309872c92

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
