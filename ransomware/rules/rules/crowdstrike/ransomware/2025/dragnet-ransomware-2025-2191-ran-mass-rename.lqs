// Dragnet [Ransomware]: dragnet-ransomware-2025-2191 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: 5a92dcfe-9138-5b61-87bf-4553b50d8f1e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
