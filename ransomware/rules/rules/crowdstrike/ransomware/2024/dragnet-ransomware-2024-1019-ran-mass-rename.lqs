// Dragnet [Ransomware]: dragnet-ransomware-2024-1019 — Mass File Rename (qilin)
// Status: deprecated | Level: high | ID: 0e06f21e-a449-53c6-a8a4-56ee3a0d3f64

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
