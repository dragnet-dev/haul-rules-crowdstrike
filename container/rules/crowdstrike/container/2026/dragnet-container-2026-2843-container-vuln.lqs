// Dragnet [Container]: dragnet-container-2026-2843 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: a6630abc-f829-5867-942b-15627df3edc2

#event_simpleName=*
| (ImageFileName = *alpine edge:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
