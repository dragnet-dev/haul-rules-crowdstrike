// Dragnet [Ransomware]: dragnet-ransomware-2025-6848 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: fe819f43-cfc6-5f26-8567-549e14d22653

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
