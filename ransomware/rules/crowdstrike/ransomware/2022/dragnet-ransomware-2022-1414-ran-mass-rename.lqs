// Dragnet [Ransomware]: dragnet-ransomware-2022-1414 — Mass File Rename (revil)
// Status: deprecated | Level: high | ID: 99db9658-4aab-5db8-ac59-33b0eece2f72

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
