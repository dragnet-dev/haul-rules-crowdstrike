// Dragnet [Ransomware]: dragnet-ransomware-2023-2767 — Mass File Rename (malas)
// Status: experimental | Level: high | ID: c3d5f496-19ff-5fdf-86b7-25b865b43346

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
