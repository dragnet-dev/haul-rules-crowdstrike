// Dragnet [Ransomware]: dragnet-ransomware-2023-0847 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 75ec2195-7643-5d7b-9fd2-4d73113dc41f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
