// Dragnet [Ransomware]: dragnet-ransomware-2024-4323 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 07441dc0-5e12-5db5-a1e1-36664f8c54d3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
