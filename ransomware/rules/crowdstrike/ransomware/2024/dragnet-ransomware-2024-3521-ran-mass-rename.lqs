// Dragnet [Ransomware]: dragnet-ransomware-2024-3521 — Mass File Rename (sarcoma)
// Status: deprecated | Level: high | ID: aeaeb2cc-d9f4-5d34-8cb6-ec7d1496dac9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
