// Dragnet [Ransomware]: dragnet-ransomware-2022-2749 — Mass File Rename (alphv)
// Status: deprecated | Level: high | ID: 6e0a31e5-0608-53f0-a249-4a1f453a0698

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
