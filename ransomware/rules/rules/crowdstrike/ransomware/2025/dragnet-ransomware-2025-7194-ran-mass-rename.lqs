// Dragnet [Ransomware]: dragnet-ransomware-2025-7194 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 65f14ce2-a995-507c-a2e4-0004873d2a96

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
