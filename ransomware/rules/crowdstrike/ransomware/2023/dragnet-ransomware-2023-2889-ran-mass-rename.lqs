// Dragnet [Ransomware]: dragnet-ransomware-2023-2889 — Mass File Rename (monti)
// Status: experimental | Level: high | ID: 03bc0f40-6c76-5a61-891d-b171ef201b29

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
