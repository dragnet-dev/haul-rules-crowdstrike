// Dragnet [Container]: dragnet-container-2026-2271 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 91e621ca-1160-5c63-b466-12a05bc8707f

#event_simpleName=*
| (ImageFileName = *alpine edge:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
