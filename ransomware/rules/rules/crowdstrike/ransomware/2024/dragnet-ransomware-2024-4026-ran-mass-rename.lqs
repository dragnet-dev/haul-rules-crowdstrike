// Dragnet [Ransomware]: dragnet-ransomware-2024-4026 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: c4af6a5f-24d9-5204-b211-3c03d9f98067

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
