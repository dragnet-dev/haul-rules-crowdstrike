// Dragnet [Ransomware]: dragnet-ransomware-2021-1660 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: b672ff19-f638-5ee1-b6c6-c3ad26914338

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
