// Dragnet [Ransomware]: dragnet-ransomware-2025-5407 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 5fab5f80-f7c5-5022-991a-83c22a7b2017

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
