// Dragnet [Ransomware]: dragnet-ransomware-2025-4103 — Mass File Rename (moneymessage)
// Status: experimental | Level: high | ID: f719b49c-55c1-55ce-968b-3870dbbd6412

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
