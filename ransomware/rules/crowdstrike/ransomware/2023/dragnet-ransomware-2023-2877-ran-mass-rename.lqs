// Dragnet [Ransomware]: dragnet-ransomware-2023-2877 — Mass File Rename (malas)
// Status: experimental | Level: high | ID: 70fa827a-8724-5c5c-b714-1a3e2af3f9f2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
