// Dragnet [Ransomware]: dragnet-ransomware-2024-5155 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: defdccec-435d-533f-ae00-75c390bb138a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
