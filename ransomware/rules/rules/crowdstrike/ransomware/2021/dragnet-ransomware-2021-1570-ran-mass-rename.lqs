// Dragnet [Ransomware]: dragnet-ransomware-2021-1570 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 67aaab0d-b162-509e-ad73-d47c5c114b57

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
