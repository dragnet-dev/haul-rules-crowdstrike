// Dragnet [Ransomware]: dragnet-ransomware-2024-3676 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: 0732eeeb-97a8-58e6-855b-d6d92e76caaf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
