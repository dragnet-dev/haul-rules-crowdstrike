// Dragnet [Ransomware]: dragnet-ransomware-2023-3950 — Mass File Rename (play)
// Status: experimental | Level: high | ID: af190ec1-0d93-5737-8d32-1d2bb4fd6451

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
