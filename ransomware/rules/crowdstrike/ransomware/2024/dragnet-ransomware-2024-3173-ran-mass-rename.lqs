// Dragnet [Ransomware]: dragnet-ransomware-2024-3173 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 18c74750-3a09-5075-aee5-d8e84c9f687d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
