// Dragnet [Ransomware]: dragnet-ransomware-2025-0345 — Mass File Rename (J)
// Status: experimental | Level: high | ID: 9b633321-126d-5996-8157-db4e0a111b7f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
