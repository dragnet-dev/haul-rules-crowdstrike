// Dragnet [Ransomware]: dragnet-ransomware-2025-3968 — Mass File Rename (pear)
// Status: experimental | Level: high | ID: 43db8d52-bf53-5f0f-9c65-bedb8aefef91

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
