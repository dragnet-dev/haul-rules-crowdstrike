// Dragnet [Ransomware]: dragnet-ransomware-2021-0190 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 0874ecdd-734d-5e32-a88a-89720a6f15d1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
