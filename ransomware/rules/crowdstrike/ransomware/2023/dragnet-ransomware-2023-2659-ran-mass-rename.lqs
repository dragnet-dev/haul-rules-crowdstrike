// Dragnet [Ransomware]: dragnet-ransomware-2023-2659 — Mass File Rename (donutleaks)
// Status: experimental | Level: high | ID: 05ae4924-3640-5037-a25f-61f7821f89f0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
