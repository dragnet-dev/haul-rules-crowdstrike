// Dragnet [Ransomware]: dragnet-ransomware-2023-0443 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 38a1b5cb-aa45-5266-911e-b7a2c962b07e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
