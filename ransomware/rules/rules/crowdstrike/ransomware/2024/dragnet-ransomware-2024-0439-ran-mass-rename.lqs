// Dragnet [Ransomware]: dragnet-ransomware-2024-0439 — Mass File Rename (redransomware)
// Status: deprecated | Level: high | ID: 7fe70e1c-3258-5188-9d45-ded5f94c626d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
