// Dragnet [Ransomware]: dragnet-ransomware-2026-2329 — Mass File Rename (krybit)
// Status: stable | Level: high | ID: fc811174-c253-5b48-beb4-5bd4870848fd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
