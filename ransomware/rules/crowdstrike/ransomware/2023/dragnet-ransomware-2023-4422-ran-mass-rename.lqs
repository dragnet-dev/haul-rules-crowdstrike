// Dragnet [Ransomware]: dragnet-ransomware-2023-4422 — Mass File Rename (noescape)
// Status: experimental | Level: high | ID: 16cf64ad-bf5c-5126-b570-f4f2eece11f9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
