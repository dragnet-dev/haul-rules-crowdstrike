// Dragnet [Ransomware]: dragnet-ransomware-2022-2853 — Mass File Rename (play)
// Status: deprecated | Level: high | ID: d5174b7a-e13d-5fb4-95c5-9ef333a0a711

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
