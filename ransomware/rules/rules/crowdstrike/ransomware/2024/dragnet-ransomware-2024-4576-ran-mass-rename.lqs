// Dragnet [Ransomware]: dragnet-ransomware-2024-4576 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: c4fb6082-c54e-5e4f-94f8-ac90f8a14daf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
