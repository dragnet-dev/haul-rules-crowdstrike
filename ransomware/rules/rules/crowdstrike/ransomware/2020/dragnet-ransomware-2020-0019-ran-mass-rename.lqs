// Dragnet [Ransomware]: dragnet-ransomware-2020-0019 — Mass File Rename (revil)
// Status: deprecated | Level: high | ID: 778e629f-d07d-5855-868e-b5483d62f40c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
