// Dragnet [Ransomware]: dragnet-ransomware-2023-2334 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 960be267-a96b-5459-9f24-cf889865de1a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
