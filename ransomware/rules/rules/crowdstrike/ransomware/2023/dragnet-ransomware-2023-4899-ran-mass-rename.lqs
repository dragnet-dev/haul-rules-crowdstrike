// Dragnet [Ransomware]: dragnet-ransomware-2023-4899 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 39946cdc-cd98-5190-82ee-d596eb4918e1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
