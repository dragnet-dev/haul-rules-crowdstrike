// Dragnet [Ransomware]: dragnet-ransomware-2022-1759 — Mass File Rename (blackbasta)
// Status: deprecated | Level: high | ID: bb56dd9d-4eaa-59d6-87ad-4d6964dec126

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
