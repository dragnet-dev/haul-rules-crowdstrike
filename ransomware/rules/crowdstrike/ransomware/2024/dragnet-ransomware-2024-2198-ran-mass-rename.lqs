// Dragnet [Ransomware]: dragnet-ransomware-2024-2198 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 88667f97-8387-50e1-949c-97f0f492775b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
