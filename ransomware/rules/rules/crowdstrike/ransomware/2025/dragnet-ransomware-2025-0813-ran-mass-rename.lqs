// Dragnet [Ransomware]: dragnet-ransomware-2025-0813 — Mass File Rename (lockbit5)
// Status: test | Level: high | ID: a92df889-2f60-501d-8569-ef1104df59df

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
