// Dragnet [Ransomware]: dragnet-ransomware-2024-2562 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 5ecdffea-0681-5547-86ed-a4937056a7e1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
