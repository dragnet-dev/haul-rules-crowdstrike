// Dragnet [Ransomware]: dragnet-ransomware-2026-3052 — Mass File Rename (lockbit5)
// Status: test | Level: high | ID: 7885c5ec-a566-5d2d-9bcb-aa22e39400ab

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
