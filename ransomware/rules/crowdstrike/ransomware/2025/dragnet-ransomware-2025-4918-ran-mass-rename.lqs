// Dragnet [Ransomware]: dragnet-ransomware-2025-4918 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 65626b54-45ec-5978-b04c-d9869e8ffcc8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
