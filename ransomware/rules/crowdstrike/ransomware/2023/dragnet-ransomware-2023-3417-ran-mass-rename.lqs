// Dragnet [Ransomware]: dragnet-ransomware-2023-3417 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 88b33614-d2f6-5f09-ade3-143c89c73c96

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
