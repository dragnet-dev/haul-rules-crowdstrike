// Dragnet [Ransomware]: dragnet-ransomware-2021-1548 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: d5d8768f-2946-511a-afef-db510aae73de

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
