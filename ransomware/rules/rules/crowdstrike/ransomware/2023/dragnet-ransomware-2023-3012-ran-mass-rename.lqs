// Dragnet [Ransomware]: dragnet-ransomware-2023-3012 — Mass File Rename (stormous)
// Status: experimental | Level: high | ID: 2b8a4d55-cc07-565a-bddd-f571d486e3ec

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
