// Dragnet [Ransomware]: dragnet-ransomware-2023-5180 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: e8b8c544-5608-57ef-99a3-ebd277e6bf5e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
