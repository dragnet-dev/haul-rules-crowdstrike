// Dragnet [Ransomware]: dragnet-ransomware-2024-2507 — Mass File Rename (donutleaks)
// Status: experimental | Level: high | ID: 43dcaea6-7fb4-5777-95cf-e6456eb5efaf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
