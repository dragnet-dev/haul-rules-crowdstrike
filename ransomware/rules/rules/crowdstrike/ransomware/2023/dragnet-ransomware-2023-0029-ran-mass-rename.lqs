// Dragnet [Ransomware]: dragnet-ransomware-2023-0029 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 973eab88-be3e-53c5-aa00-2a91cd2648f3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
