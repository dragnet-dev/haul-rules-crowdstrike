// Dragnet [Ransomware]: dragnet-ransomware-2022-1607 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 1712d759-e36e-5197-b8f0-5ad839805b33

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
