// Dragnet [Container]: dragnet-container-2024-0351 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 9bf2b63a-f18d-51fa-8435-4c36112c6cb5

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
