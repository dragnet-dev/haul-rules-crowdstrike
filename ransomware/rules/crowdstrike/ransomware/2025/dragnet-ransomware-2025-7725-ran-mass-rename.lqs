// Dragnet [Ransomware]: dragnet-ransomware-2025-7725 — Mass File Rename (handala)
// Status: experimental | Level: high | ID: 0ee57e76-cb85-5db8-891f-ec473f5d31e3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
