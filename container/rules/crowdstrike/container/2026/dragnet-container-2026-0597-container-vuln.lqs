// Dragnet [Container]: dragnet-container-2026-0597 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: d04a80b2-227d-5703-af77-d8df2031d4da

#event_simpleName=*
| (ImageFileName = *chainguard:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
