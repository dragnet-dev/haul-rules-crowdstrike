// Dragnet [Ransomware]: dragnet-ransomware-2025-2409 — Mass File Rename (thegentlemen)
// Status: experimental | Level: high | ID: 0c516c50-7876-529e-a894-9efba25dcfb8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
