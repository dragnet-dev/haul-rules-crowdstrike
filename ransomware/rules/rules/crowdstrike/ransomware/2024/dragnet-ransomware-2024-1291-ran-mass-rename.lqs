// Dragnet [Ransomware]: dragnet-ransomware-2024-1291 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 6408015f-8e6c-54bf-9869-d6d214d8d4b8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
