// Dragnet [Ransomware]: dragnet-ransomware-2024-2466 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: bcabd316-0df0-51a6-8d76-2d70e8399793

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
