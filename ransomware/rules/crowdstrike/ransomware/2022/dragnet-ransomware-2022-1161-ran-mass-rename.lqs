// Dragnet [Ransomware]: dragnet-ransomware-2022-1161 — Mass File Rename (cheers)
// Status: deprecated | Level: high | ID: 9fcd0f14-7069-5b6e-8fd2-d3283cf16d1d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
