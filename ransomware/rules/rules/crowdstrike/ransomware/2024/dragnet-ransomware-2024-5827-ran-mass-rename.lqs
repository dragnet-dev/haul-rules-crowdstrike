// Dragnet [Ransomware]: dragnet-ransomware-2024-5827 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 93053300-707b-596d-b6da-a8407fb1eb35

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
