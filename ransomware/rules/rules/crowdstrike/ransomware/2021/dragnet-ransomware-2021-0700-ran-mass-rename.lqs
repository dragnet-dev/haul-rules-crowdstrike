// Dragnet [Ransomware]: dragnet-ransomware-2021-0700 — Mass File Rename (alphv)
// Status: deprecated | Level: high | ID: 1966afc4-f4e2-5da2-8704-6c59db324fc4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
