// Dragnet [Ransomware]: dragnet-ransomware-2021-0792 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: ec4d4565-eaef-566f-8e4c-9e4778171fdc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
