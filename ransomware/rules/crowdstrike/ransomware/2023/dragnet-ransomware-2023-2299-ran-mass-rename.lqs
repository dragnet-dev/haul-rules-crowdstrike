// Dragnet [Ransomware]: dragnet-ransomware-2023-2299 — Mass File Rename (ransomed)
// Status: deprecated | Level: high | ID: 94b03896-b125-5d74-b75c-88b26f634e43

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
