// Dragnet [Ransomware]: dragnet-ransomware-2024-3275 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 33aae566-ff70-55bd-a8ca-fb7e967ac726

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
