// Dragnet [Ransomware]: dragnet-ransomware-2021-1253 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 12427746-5056-5a64-af76-31a3361741d5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
