// Dragnet [Ransomware]: dragnet-ransomware-2024-1166 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 7e309a95-a9ae-53da-ab8b-703908222ad4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
