// Dragnet [Ransomware]: dragnet-ransomware-2024-0474 — Mass File Rename (arcusmedia)
// Status: experimental | Level: high | ID: ce24979c-ab52-5968-ab06-e780760ebcbe

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
