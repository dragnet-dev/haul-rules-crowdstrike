// Dragnet [Ransomware]: dragnet-ransomware-2025-4683 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: ff59a3b0-dea9-5613-8cee-bbda872f6d7d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
