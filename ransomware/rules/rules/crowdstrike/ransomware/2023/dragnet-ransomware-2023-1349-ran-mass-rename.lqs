// Dragnet [Ransomware]: dragnet-ransomware-2023-1349 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: b5a9fb6b-0fa2-592d-912f-46d7bc157c34

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
