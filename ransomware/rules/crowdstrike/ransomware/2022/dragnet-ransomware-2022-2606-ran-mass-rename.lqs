// Dragnet [Ransomware]: dragnet-ransomware-2022-2606 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 1e38492f-bac5-5eda-b03d-049b489b6061

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
