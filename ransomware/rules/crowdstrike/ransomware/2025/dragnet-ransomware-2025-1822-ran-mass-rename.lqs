// Dragnet [Ransomware]: dragnet-ransomware-2025-1822 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 93c543aa-b782-5aff-900b-1fbe91c9cf18

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
