// Dragnet [Ransomware]: dragnet-ransomware-2024-1587 — Mass File Rename (stormous)
// Status: deprecated | Level: high | ID: d34e1c73-63a5-5242-b089-a35ae5d72361

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
