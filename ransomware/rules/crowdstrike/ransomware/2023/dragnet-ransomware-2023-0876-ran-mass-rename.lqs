// Dragnet [Ransomware]: dragnet-ransomware-2023-0876 — Mass File Rename (play)
// Status: deprecated | Level: high | ID: 73ef0d9f-c1a5-5e60-ba06-43b294080557

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
