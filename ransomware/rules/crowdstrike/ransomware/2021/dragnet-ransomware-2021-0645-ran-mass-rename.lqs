// Dragnet [Ransomware]: dragnet-ransomware-2021-0645 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: cbcadf26-0645-5e6e-ae3d-0d6ac834da69

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
