// Dragnet [Container]: dragnet-container-2026-2158 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: c438a1df-e36e-553c-bf21-24b08c66c709

#event_simpleName=*
| (ImageFileName = *amazonlinux:1* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6*)
| table([timestamp, ComputerName])
| limit(1000)
