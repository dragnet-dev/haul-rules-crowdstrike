// Dragnet [Ransomware]: dragnet-ransomware-2025-5564 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: c75ef45c-adbd-552e-9be5-a6bed17b45d1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
