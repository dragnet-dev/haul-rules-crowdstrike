// Dragnet [Ransomware]: dragnet-ransomware-2022-0789 — Mass File Rename (avoslocker)
// Status: deprecated | Level: high | ID: 715b00fe-5c64-5401-bb34-722258716303

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
