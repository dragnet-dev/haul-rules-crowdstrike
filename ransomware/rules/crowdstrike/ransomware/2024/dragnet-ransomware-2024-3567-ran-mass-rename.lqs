// Dragnet [Ransomware]: dragnet-ransomware-2024-3567 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: ab370fe5-df8d-57bb-aa5f-1c4bee745cd2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
