// Dragnet [Ransomware]: dragnet-ransomware-2022-3045 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 9ee5799f-97af-57e8-a028-04fb75d1365f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
