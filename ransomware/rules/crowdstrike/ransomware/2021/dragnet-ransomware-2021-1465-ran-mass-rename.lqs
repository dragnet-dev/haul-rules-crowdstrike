// Dragnet [Ransomware]: dragnet-ransomware-2021-1465 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: c535dbb8-3661-55de-b221-ce94ae09771d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
