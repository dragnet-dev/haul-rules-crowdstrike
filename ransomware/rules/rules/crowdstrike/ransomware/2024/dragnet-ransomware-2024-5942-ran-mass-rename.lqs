// Dragnet [Ransomware]: dragnet-ransomware-2024-5942 — Mass File Rename (rhysida)
// Status: deprecated | Level: high | ID: 8504902f-da17-54bb-8bf7-d636c482fac9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
