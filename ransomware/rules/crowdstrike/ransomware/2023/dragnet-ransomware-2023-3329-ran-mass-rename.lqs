// Dragnet [Ransomware]: dragnet-ransomware-2023-3329 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 92185fad-1a24-52f3-8f0f-37d44894c5f4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
