// Dragnet [Ransomware]: dragnet-ransomware-2024-5004 — Mass File Rename (meow)
// Status: experimental | Level: high | ID: 0065f53d-867a-505e-9530-17a301264d26

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
