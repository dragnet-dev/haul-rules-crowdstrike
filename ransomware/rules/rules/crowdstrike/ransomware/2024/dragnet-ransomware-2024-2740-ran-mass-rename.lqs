// Dragnet [Ransomware]: dragnet-ransomware-2024-2740 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: b27ed428-801d-5e18-82b3-ebf8a08bc796

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
