// Dragnet [Ransomware]: dragnet-ransomware-2021-0985 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 87a0a4f5-c7de-5bb2-a90b-e988a0b42145

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
