// Dragnet [Ransomware]: dragnet-ransomware-2026-2040 — Mass File Rename (incransom)
// Status: stable | Level: high | ID: c2b396e7-d594-51a1-a16c-48391e06fad1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
