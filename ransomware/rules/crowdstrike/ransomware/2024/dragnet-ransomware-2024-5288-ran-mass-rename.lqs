// Dragnet [Ransomware]: dragnet-ransomware-2024-5288 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 2a293c29-25ff-5da1-bcf5-7aa33d548575

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
