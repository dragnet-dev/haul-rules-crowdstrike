// Dragnet [Ransomware]: dragnet-ransomware-2022-1188 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: fa639ae3-e91e-57a8-9196-2dfcffdbf048

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
