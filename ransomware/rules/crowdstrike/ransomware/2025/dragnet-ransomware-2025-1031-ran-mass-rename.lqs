// Dragnet [Ransomware]: dragnet-ransomware-2025-1031 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: dd6192d3-f60f-52cb-8b65-6cea2870f4c3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
