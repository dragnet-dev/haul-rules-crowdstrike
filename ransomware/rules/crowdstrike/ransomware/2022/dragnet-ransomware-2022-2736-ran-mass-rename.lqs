// Dragnet [Ransomware]: dragnet-ransomware-2022-2736 — Mass File Rename (play)
// Status: deprecated | Level: high | ID: 6d4cbde0-f112-57c1-badd-b0b50110cc6a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
