// Dragnet [Ransomware]: dragnet-ransomware-2025-6548 — Mass File Rename (interlock)
// Status: experimental | Level: high | ID: 116cea8e-d51e-5502-9489-ea241bc45f82

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
