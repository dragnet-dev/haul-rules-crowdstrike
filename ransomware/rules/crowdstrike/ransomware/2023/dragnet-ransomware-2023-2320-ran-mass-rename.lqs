// Dragnet [Ransomware]: dragnet-ransomware-2023-2320 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 63580a94-a8b7-5eed-be38-3439a2cb85bc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
