// Dragnet [Ransomware]: dragnet-ransomware-2023-0461 — Mass File Rename (noescape)
// Status: experimental | Level: high | ID: bb892d3d-7588-5e57-9c2a-29d63371b7bd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
