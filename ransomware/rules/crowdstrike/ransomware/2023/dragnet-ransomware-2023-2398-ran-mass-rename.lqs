// Dragnet [Ransomware]: dragnet-ransomware-2023-2398 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 893bb6e5-7649-5bbd-baa3-0a58b68b8d83

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
