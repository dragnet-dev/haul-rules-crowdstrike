// Dragnet [Container]: dragnet-container-2026-0150 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 669fa0a8-5529-55de-a611-37e7d5c8dbdf

#event_simpleName=*
| (ImageFileName = *chainguard:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
