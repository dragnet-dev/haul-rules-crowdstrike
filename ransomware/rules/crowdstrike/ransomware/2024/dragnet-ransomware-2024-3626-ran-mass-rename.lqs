// Dragnet [Ransomware]: dragnet-ransomware-2024-3626 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 7cef6b61-ee97-5287-a2f6-4f14daf3f05f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
