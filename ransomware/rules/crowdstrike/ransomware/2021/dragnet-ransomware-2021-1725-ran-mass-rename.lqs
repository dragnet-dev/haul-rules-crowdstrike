// Dragnet [Ransomware]: dragnet-ransomware-2021-1725 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 1889bf5e-dea2-56af-a0a8-b0e061d027c8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
