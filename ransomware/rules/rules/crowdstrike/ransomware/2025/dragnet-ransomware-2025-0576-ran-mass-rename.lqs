// Dragnet [Ransomware]: dragnet-ransomware-2025-0576 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: defcdf6a-1cc9-57c2-9f84-b44513fc66ef

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
