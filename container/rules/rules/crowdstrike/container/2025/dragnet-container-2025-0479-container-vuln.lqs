// Dragnet [Container]: dragnet-container-2025-0479 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: dd0a1205-334c-5dd4-8929-3cbf3cb0d04e

#event_simpleName=*
| (ImageFileName = *alpine:3.17* OR ImageFileName = *alpine:3.18* OR ImageFileName = *alpine:3.19* OR ImageFileName = *alpine:3.20* OR ImageFileName = *alpine:3.21* OR ImageFileName = *alpine:3.22* OR ImageFileName = *alpine:3.23* OR ImageFileName = *alpine edge:* OR ImageFileName = *ubuntu:18.04* OR ImageFileName = *ubuntu:20.04* OR ImageFileName = *ubuntu:21.10*)
| table([timestamp, ComputerName])
| limit(1000)
