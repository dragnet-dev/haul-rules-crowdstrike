// Dragnet [Ransomware]: dragnet-ransomware-2025-3936 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: e91c0d8f-6bda-5bb1-820a-37540215dfb9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
