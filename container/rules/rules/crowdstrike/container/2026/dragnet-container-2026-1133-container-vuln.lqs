// Dragnet [Container]: dragnet-container-2026-1133 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 416e690e-c970-5f26-b40e-1b7b902af9e7

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
