// Dragnet [Ransomware]: dragnet-ransomware-2026-2508 — Mass File Rename (incransom)
// Status: test | Level: high | ID: 2e2f5817-4b45-5c89-9ae0-dbb8450e6786

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
