// Dragnet [Ransomware]: dragnet-ransomware-2025-3698 — Mass File Rename (payoutsking)
// Status: test | Level: high | ID: 7590d2c1-f35b-57a4-9b47-226d86adffcd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
