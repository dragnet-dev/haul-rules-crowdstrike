// Dragnet [Container]: dragnet-container-2024-0716 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 861a3e69-5a98-523e-8c43-c11526a37e76

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *ubuntu:18.04-ESM* OR ImageFileName = *ubuntu:20.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
