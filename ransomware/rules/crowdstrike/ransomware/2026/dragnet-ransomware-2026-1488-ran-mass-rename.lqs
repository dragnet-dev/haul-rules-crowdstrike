// Dragnet [Ransomware]: dragnet-ransomware-2026-1488 — Mass File Rename (payoutsking)
// Status: deprecated | Level: high | ID: 25459c25-f450-56f0-8554-e14cc5787887

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
