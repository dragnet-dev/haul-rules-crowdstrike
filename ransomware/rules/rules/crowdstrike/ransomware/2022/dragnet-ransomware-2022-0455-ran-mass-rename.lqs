// Dragnet [Ransomware]: dragnet-ransomware-2022-0455 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 24678023-717a-5573-a030-e734dd14aa59

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
