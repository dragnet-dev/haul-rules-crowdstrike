// Dragnet [Ransomware]: dragnet-ransomware-2025-0468 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: f96c63d1-3c24-59ba-b764-f5141d3ca345

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
