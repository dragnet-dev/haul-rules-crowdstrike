// Dragnet [Ransomware]: dragnet-ransomware-2023-0506 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 39c90729-e662-5986-b195-457ef5112bac

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
