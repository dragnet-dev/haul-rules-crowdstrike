// Dragnet [Ransomware]: dragnet-ransomware-2022-2929 — Mass File Rename (dataleak)
// Status: deprecated | Level: high | ID: b16f4198-37df-5355-bc8a-37e4dbfd9a70

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
