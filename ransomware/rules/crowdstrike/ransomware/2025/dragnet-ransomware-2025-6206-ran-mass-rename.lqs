// Dragnet [Ransomware]: dragnet-ransomware-2025-6206 — Mass File Rename (anubis)
// Status: experimental | Level: high | ID: 3e2c9b4e-c331-50bd-8e9f-d1f74a536c52

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
