// Dragnet [Container]: dragnet-container-2024-0130 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 12538e4d-0596-55f5-b108-0fbf8f75a548

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
