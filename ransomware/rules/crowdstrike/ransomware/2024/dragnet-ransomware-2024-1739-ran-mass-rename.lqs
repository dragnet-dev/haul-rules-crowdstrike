// Dragnet [Ransomware]: dragnet-ransomware-2024-1739 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 5b5e3bdd-f9b5-5003-bbc4-9c76721448c9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
