// Dragnet [Ransomware]: dragnet-ransomware-2026-2671 — Mass File Rename (lockbit5)
// Status: stable | Level: high | ID: 5f975991-b2d4-573d-9cd6-a1aa4a0956f4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
