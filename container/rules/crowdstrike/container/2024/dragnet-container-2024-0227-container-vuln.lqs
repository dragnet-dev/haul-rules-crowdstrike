// Dragnet [Container]: dragnet-container-2024-0227 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 17435284-56c1-53b2-a772-b581ba38bbbb

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:8* OR ImageFileName = *debian:9*)
| table([timestamp, ComputerName])
| limit(1000)
