// Dragnet [Ransomware]: dragnet-ransomware-2024-3925 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: f5854611-cfb6-50aa-9709-0a41c093de53

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
