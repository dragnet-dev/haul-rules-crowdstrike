// Dragnet [Ransomware]: dragnet-ransomware-2024-3858 — Mass File Rename (SilentRansomGroup)
// Status: deprecated | Level: high | ID: bd6afee1-ad33-5b9e-a094-1c98e20576bd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
