// Dragnet [Ransomware]: dragnet-ransomware-2024-4976 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 77438f23-4f05-5174-9bbd-e7f0c1daea5b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
