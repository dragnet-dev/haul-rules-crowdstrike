// Dragnet [Ransomware]: dragnet-ransomware-2020-0130 — Mass File Rename (ragnarlocker)
// Status: deprecated | Level: high | ID: 3e87b460-5d10-55c3-a393-06ec13017378

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
