// Dragnet [Ransomware]: dragnet-ransomware-2021-1644 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: c34bfc06-791c-5f1e-8345-7a54f049fc96

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
