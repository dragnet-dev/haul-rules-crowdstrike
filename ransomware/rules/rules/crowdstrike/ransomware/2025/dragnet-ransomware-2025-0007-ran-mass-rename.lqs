// Dragnet [Ransomware]: dragnet-ransomware-2025-0007 — Mass File Rename (embargo)
// Status: experimental | Level: high | ID: 7812343e-5901-5a56-bdbf-264a7c0620f4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
