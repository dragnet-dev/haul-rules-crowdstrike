// Dragnet [Container]: dragnet-container-2026-0853 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 555ffd27-115b-5849-9583-d323e23b01df

#event_simpleName=*
| (ImageFileName = *chainguard:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
