// Dragnet [Ransomware]: dragnet-ransomware-2025-3309 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 2342d601-5514-5bea-9ff1-6a635cdfa0a0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
