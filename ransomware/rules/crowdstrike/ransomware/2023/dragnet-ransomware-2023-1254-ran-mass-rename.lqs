// Dragnet [Ransomware]: dragnet-ransomware-2023-1254 — Mass File Rename (play)
// Status: deprecated | Level: high | ID: 2d9978b9-a7c9-5a65-ab4b-f3f69be656b3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
