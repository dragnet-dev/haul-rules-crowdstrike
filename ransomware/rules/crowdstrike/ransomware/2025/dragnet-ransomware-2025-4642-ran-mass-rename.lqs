// Dragnet [Ransomware]: dragnet-ransomware-2025-4642 — Mass File Rename (RunSomeWares)
// Status: experimental | Level: high | ID: 5a1711b3-85f2-52af-a79d-55ae9f339f57

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
