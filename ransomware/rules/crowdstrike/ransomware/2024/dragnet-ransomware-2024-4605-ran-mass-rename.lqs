// Dragnet [Ransomware]: dragnet-ransomware-2024-4605 — Mass File Rename (meow)
// Status: experimental | Level: high | ID: 0b642a2d-b5f9-5886-affc-d1b968057f85

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
