// Dragnet [Container]: dragnet-container-2026-2030 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 67ae0c65-0ba1-5bcb-a5bf-6dfa80058482

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6*)
| table([timestamp, ComputerName])
| limit(1000)
