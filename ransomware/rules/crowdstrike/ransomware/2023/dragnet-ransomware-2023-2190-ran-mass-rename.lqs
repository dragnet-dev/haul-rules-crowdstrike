// Dragnet [Ransomware]: dragnet-ransomware-2023-2190 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 1f1a6c31-3ef6-56c7-a5e7-3a7aa2f9c7a0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
