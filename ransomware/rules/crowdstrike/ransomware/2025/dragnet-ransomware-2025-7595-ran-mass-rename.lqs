// Dragnet [Ransomware]: dragnet-ransomware-2025-7595 — Mass File Rename (genesis)
// Status: experimental | Level: high | ID: 2946acdf-896d-5d3c-8d8d-56e9b19f9bdf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
