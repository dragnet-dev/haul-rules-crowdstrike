// Dragnet [Ransomware]: dragnet-ransomware-2023-4725 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 77020f52-a660-5d24-965d-ad801f39d351

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
