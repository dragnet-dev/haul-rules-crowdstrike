// Dragnet [Ransomware]: dragnet-ransomware-2021-1632 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 6b371a6f-55f5-5a15-bdc8-744b41f3a17f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
