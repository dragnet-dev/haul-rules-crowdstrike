// Dragnet [Ransomware]: dragnet-ransomware-2021-1569 — Mass File Rename (grief)
// Status: deprecated | Level: high | ID: 841f04c4-cdac-5447-93bd-7f4c7a776211

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
