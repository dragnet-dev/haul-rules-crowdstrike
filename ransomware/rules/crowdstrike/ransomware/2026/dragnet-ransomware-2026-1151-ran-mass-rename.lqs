// Dragnet [Ransomware]: dragnet-ransomware-2026-1151 — Mass File Rename (thegentlemen)
// Status: stable | Level: high | ID: e5b49183-a863-51e8-864d-cf5bf2734b4c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
