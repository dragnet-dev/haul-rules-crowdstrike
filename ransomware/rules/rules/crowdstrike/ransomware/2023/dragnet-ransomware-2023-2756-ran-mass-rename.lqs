// Dragnet [Ransomware]: dragnet-ransomware-2023-2756 — Mass File Rename (malas)
// Status: experimental | Level: high | ID: 292d396f-6028-5772-9044-f4d816a1a227

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
