// Dragnet [Ransomware]: dragnet-ransomware-2023-5196 — Mass File Rename (play)
// Status: deprecated | Level: high | ID: 98c7d6bd-7e70-5fbe-836c-23c2fa99e334

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
