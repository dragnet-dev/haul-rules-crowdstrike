// Dragnet [Ransomware]: dragnet-ransomware-2022-1861 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: c1276b17-2248-5f5e-8135-3481e4c820a8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
