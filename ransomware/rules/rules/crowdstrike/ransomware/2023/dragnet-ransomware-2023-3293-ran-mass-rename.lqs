// Dragnet [Ransomware]: dragnet-ransomware-2023-3293 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 2c9e54a5-1e66-59a9-b573-042514401968

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
