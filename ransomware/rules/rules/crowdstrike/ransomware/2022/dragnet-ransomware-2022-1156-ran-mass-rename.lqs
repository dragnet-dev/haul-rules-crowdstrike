// Dragnet [Ransomware]: dragnet-ransomware-2022-1156 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: db8dea74-9cbe-5c6d-86fe-85d790b17d46

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
