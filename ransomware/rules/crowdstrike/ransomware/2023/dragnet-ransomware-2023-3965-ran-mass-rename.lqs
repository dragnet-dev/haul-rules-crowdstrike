// Dragnet [Ransomware]: dragnet-ransomware-2023-3965 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 62bd3d02-c902-5629-8ab5-6987fb5ca344

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
