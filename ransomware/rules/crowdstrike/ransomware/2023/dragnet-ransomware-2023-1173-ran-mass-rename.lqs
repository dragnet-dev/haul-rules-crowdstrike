// Dragnet [Ransomware]: dragnet-ransomware-2023-1173 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 2fa36d53-2aab-5250-9d6a-72cf380c058b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
