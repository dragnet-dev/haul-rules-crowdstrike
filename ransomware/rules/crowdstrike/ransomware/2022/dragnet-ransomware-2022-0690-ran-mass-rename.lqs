// Dragnet [Ransomware]: dragnet-ransomware-2022-0690 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 457f4c7e-2461-54ff-99c6-3a56a6338f85

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
