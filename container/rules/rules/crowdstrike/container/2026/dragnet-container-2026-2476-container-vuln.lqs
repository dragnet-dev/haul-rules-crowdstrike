// Dragnet [Container]: dragnet-container-2026-2476 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 8ceb4064-2f46-5223-8300-89a33dbd3e21

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:9* OR ImageFileName = *ubuntu:14.04-ESM* OR ImageFileName = *ubuntu:16.04* OR ImageFileName = *ubuntu:16.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
