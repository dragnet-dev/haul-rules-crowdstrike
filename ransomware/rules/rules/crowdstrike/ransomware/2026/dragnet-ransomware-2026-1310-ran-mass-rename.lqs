// Dragnet [Ransomware]: dragnet-ransomware-2026-1310 — Mass File Rename (incransom)
// Status: stable | Level: high | ID: 48d4bb34-1dd5-551c-95f8-89612ad305d6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
