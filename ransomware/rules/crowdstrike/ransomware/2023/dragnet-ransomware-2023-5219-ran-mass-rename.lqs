// Dragnet [Ransomware]: dragnet-ransomware-2023-5219 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: dd422121-4e26-5a20-b60f-1b9b8f410239

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
