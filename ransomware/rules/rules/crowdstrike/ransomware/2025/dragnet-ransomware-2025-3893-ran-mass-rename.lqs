// Dragnet [Ransomware]: dragnet-ransomware-2025-3893 — Mass File Rename (crazyhunter)
// Status: experimental | Level: high | ID: bcadd781-0454-5614-be03-9dfa9c8f91a0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
