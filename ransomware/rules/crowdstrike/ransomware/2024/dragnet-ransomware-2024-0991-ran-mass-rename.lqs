// Dragnet [Ransomware]: dragnet-ransomware-2024-0991 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: bcdacaa2-fb33-5ca6-a3dd-e4d4c2f0f58b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
