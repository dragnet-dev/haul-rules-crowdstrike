// Dragnet [Ransomware]: dragnet-ransomware-2025-5416 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 7f02942d-ffb7-5aa5-9037-cc8aad6cc489

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
