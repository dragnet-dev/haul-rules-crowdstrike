// Dragnet [Ransomware]: dragnet-ransomware-2024-1236 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: ac0d3f94-30c3-5ed9-b0b2-88cc8895a064

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
