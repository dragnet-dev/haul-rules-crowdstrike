// Dragnet [Ransomware]: dragnet-ransomware-2025-5896 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 870e85f2-a246-5cd0-b29b-df5fccd4cc07

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
