// Dragnet [Ransomware]: dragnet-ransomware-2025-3823 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: c1bbe736-4e77-50e8-a96c-22ff3d18a23e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
