// Dragnet [Ransomware]: dragnet-ransomware-2021-0282 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 5bfc94b9-7bc3-5486-baeb-3e3eb2e0a169

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
