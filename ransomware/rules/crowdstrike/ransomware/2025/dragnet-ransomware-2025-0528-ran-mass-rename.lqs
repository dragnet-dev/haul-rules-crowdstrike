// Dragnet [Ransomware]: dragnet-ransomware-2025-0528 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 3c199692-5d69-5599-a51f-4da2a4e863fb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
