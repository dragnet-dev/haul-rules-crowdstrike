// Dragnet [Ransomware]: dragnet-ransomware-2025-6127 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: ad69f2fc-683b-5a34-a053-a979739cc8ee

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
