// Dragnet [Ransomware]: dragnet-ransomware-2022-0639 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: d34c6874-da03-5b80-8977-15d3cb7305c4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
