// Dragnet [Ransomware]: dragnet-ransomware-2025-6518 — Mass File Rename (interlock)
// Status: experimental | Level: high | ID: 8d635d87-1d12-5705-8e49-4328587383aa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
