// Dragnet [Container]: dragnet-container-2026-1444 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: b6aa4e4d-d976-50bc-b5f5-a92b1922e50c

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
