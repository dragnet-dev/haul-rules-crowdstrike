// Dragnet [Ransomware]: dragnet-ransomware-2024-1366 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 90fbb2e0-86be-5281-abe7-cc55648bcbc5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
