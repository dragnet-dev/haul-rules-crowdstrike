// Dragnet [Ransomware]: dragnet-ransomware-2022-1164 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 6345b244-7597-52a5-953f-9edee5ac87c0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
