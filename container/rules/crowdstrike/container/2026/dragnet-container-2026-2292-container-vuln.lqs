// Dragnet [Container]: dragnet-container-2026-2292 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 73e416e2-cf61-5895-88fb-ad356d63e4e3

#event_simpleName=*
| (ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *ubuntu:12.04*)
| table([timestamp, ComputerName])
| limit(1000)
