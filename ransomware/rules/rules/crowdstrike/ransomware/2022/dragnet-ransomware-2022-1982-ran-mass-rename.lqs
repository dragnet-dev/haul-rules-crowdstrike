// Dragnet [Ransomware]: dragnet-ransomware-2022-1982 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 2da924e0-01f1-5e4f-a23e-24ccabdcbf8e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
