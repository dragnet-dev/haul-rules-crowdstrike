// Dragnet [Ransomware]: dragnet-ransomware-2024-0055 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 9e4fa1b2-a90c-5a34-bc3e-0620a97f71ea

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
