// Dragnet [Ransomware]: dragnet-ransomware-2021-1035 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: a26e5930-8d93-54a7-acee-6e82d36a18f1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
