// Dragnet [Ransomware]: dragnet-ransomware-2026-0219 — Mass File Rename (lockbit5)
// Status: test | Level: high | ID: 8c21883e-b7ba-52aa-adf5-d1da8f06d540

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
