// Dragnet [Ransomware]: dragnet-ransomware-2025-6137 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: 3b17d2ee-1d4f-54a3-99f7-ebdadd8899e5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
