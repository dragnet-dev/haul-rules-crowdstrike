// Dragnet [Ransomware]: dragnet-ransomware-2021-0365 — Mass File Rename (avaddon)
// Status: deprecated | Level: high | ID: 451c2cde-d281-5ef9-a4c0-b7afa9f6cbe0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
