// Dragnet [Ransomware]: dragnet-ransomware-2025-4513 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 3cb93b36-c85f-5301-b1d0-01a4c041a5d0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
