// Dragnet [Ransomware]: dragnet-ransomware-2023-1149 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 7095c774-b04c-553a-8f42-95c78fa82954

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
