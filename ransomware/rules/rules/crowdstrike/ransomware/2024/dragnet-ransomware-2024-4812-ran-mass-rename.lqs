// Dragnet [Ransomware]: dragnet-ransomware-2024-4812 — Mass File Rename (safepay)
// Status: deprecated | Level: high | ID: de8b5849-8031-5e2f-8a59-d59b21884f15

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
