// Dragnet [Ransomware]: dragnet-ransomware-2023-0061 — Mass File Rename (karakurt)
// Status: deprecated | Level: high | ID: a1cf77fc-6163-5af1-bbec-eba9e511d637

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
