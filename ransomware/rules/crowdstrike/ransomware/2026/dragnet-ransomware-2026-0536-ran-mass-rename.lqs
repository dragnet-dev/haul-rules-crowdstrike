// Dragnet [Ransomware]: dragnet-ransomware-2026-0536 — Mass File Rename (nightspire)
// Status: deprecated | Level: high | ID: dd55c565-709a-52be-9621-97f8014d7ab6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
