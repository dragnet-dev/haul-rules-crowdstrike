// Dragnet [Container]: dragnet-container-2026-0024 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 8d19ec77-e09d-5d92-afe9-b562ceeca1d5

#event_simpleName=*
| (ImageFileName = *chainguard:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
