// Dragnet [Ransomware]: dragnet-ransomware-2024-4334 — Mass File Rename (dragonransomware)
// Status: experimental | Level: high | ID: 46a25c42-bc59-5c6d-a293-08e427250a05

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
