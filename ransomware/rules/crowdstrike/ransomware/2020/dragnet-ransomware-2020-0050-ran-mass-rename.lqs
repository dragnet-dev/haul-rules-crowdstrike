// Dragnet [Ransomware]: dragnet-ransomware-2020-0050 — Mass File Rename (doppelpaymer)
// Status: deprecated | Level: high | ID: f16ed0f5-ecab-5205-9331-3f8fcef1d7eb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
