// Dragnet [Container]: dragnet-container-2026-0836 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 3bedf7c5-2b67-573b-9cf4-6559dbb8a50b

#event_simpleName=*
| (ImageFileName = *chainguard:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
