// Dragnet [Ransomware]: dragnet-ransomware-2023-4923 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: a92c3f45-99e3-5fe9-9625-bee660f2c4dc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
