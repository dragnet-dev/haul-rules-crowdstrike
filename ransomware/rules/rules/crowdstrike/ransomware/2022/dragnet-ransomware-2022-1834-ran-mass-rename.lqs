// Dragnet [Ransomware]: dragnet-ransomware-2022-1834 — Mass File Rename (unsafe)
// Status: deprecated | Level: high | ID: 930ea718-a405-5f72-b9e9-77e2e555d1ce

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
