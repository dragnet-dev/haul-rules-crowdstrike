// Dragnet [Ransomware]: dragnet-ransomware-2024-1986 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: caf6491b-d99e-561c-9521-9422c1610275

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
