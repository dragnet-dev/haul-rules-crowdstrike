// Dragnet [Ransomware]: dragnet-ransomware-2025-4235 — Mass File Rename (obscura)
// Status: experimental | Level: high | ID: a6de518b-811f-5166-b292-3c706a07f59a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
