// Dragnet [Ransomware]: dragnet-ransomware-2023-3349 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: b1d70622-ffb7-5477-a155-acb648982393

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
