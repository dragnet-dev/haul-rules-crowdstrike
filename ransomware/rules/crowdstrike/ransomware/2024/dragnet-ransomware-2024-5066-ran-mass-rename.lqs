// Dragnet [Ransomware]: dragnet-ransomware-2024-5066 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 8966b268-6cd6-5237-a7f7-ea13601e9da1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
