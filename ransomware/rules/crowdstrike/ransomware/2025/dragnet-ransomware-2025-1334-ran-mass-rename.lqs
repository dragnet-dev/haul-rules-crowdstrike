// Dragnet [Ransomware]: dragnet-ransomware-2025-1334 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: ff49cb1e-4d89-5485-b94a-e74b8b554530

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
