// Dragnet [Ransomware]: dragnet-ransomware-2022-0754 — Mass File Rename (vicesociety)
// Status: deprecated | Level: high | ID: fc4f2d2f-e4d4-551e-b34f-df1ff5bb174e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
