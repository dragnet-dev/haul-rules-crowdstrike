// Dragnet [Ransomware]: dragnet-ransomware-2023-0328 — Mass File Rename (ransomed)
// Status: deprecated | Level: high | ID: d24db8d6-0eac-50f8-8362-6075ea89828d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
