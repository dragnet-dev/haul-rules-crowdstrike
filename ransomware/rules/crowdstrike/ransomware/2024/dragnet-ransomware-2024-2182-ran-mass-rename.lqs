// Dragnet [Ransomware]: dragnet-ransomware-2024-2182 — Mass File Rename (darkvault)
// Status: experimental | Level: high | ID: 5d1e8b01-79be-5658-b49b-10d84c2fb43b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
