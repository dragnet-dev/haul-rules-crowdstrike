// Dragnet [Ransomware]: dragnet-ransomware-2025-7563 — Mass File Rename (nova)
// Status: experimental | Level: high | ID: 3a8316a3-edb3-5032-8b64-a60940f49189

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
