// Dragnet [Ransomware]: dragnet-ransomware-2023-3907 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: ca3185a2-4bf8-5f82-a25f-d6cfe18d37a2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
