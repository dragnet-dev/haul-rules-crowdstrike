// Dragnet [Ransomware]: dragnet-ransomware-2024-1136 — Mass File Rename (BrainCipher)
// Status: experimental | Level: high | ID: efd6a96b-d8a1-5bfa-b6b3-8bf91e2ad288

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
