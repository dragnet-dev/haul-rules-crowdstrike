// Dragnet [Ransomware]: dragnet-ransomware-2024-4911 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 162c6f38-629b-5250-ba6c-ddbfc980a868

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
