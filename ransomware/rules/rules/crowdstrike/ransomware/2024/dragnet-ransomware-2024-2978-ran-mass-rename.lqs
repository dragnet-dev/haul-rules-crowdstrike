// Dragnet [Ransomware]: dragnet-ransomware-2024-2978 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: f3a94fff-ba84-5c17-8e88-fda5f7281486

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
