// Dragnet [Ransomware]: dragnet-ransomware-2022-1776 — Mass File Rename (avoslocker)
// Status: deprecated | Level: high | ID: 2da1426d-abdc-5449-9e70-2e5336ff5daf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
