// Dragnet [Ransomware]: dragnet-ransomware-2022-2483 — Mass File Rename (blackbasta)
// Status: deprecated | Level: high | ID: 1b489e20-8815-5fa1-bdf1-f65c0b063b28

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
