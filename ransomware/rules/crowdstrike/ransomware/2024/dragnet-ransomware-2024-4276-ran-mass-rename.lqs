// Dragnet [Ransomware]: dragnet-ransomware-2024-4276 — Mass File Rename (qilin)
// Status: deprecated | Level: high | ID: 3c411454-4d52-5026-b240-b61f629ebafd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
