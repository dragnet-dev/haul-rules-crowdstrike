// Dragnet [Ransomware]: dragnet-ransomware-2023-2291 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: ad2b7eb5-8efd-5b4b-9490-86d5802dbff7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
