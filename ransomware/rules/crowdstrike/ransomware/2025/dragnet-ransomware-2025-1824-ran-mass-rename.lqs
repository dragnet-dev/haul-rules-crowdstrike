// Dragnet [Ransomware]: dragnet-ransomware-2025-1824 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: e257a78b-ff22-5665-af59-d8e7a0dab838

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
