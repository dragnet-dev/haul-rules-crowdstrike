// Dragnet [Ransomware]: dragnet-ransomware-2026-2744 — Mass File Rename (bravox)
// Status: stable | Level: high | ID: 21799e1d-cb6b-5d38-9b82-f81f5f1eaa4b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
