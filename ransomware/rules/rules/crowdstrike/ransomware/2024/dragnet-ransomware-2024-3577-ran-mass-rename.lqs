// Dragnet [Ransomware]: dragnet-ransomware-2024-3577 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 7fa4f72c-2bec-5d8f-9d9c-0d95c6acee22

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
