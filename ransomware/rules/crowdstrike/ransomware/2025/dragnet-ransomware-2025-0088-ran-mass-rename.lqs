// Dragnet [Ransomware]: dragnet-ransomware-2025-0088 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: b81ebbe7-395f-5fa9-b3f0-a72f9e98b7d3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
