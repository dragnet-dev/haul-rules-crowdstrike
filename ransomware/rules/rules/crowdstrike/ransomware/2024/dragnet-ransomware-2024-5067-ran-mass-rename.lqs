// Dragnet [Ransomware]: dragnet-ransomware-2024-5067 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: 3f4be895-08e0-56f3-b7e3-1846b12e5d29

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
