// Dragnet [Ransomware]: dragnet-ransomware-2023-2795 — Mass File Rename (malas)
// Status: experimental | Level: high | ID: 67d5410c-d978-5337-96af-94b807b6fd54

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
