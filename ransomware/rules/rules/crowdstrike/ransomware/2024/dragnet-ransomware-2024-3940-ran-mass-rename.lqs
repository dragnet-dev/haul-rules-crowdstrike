// Dragnet [Ransomware]: dragnet-ransomware-2024-3940 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: 307c3907-ba23-5813-b1d7-7bfc86c1fcc9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
