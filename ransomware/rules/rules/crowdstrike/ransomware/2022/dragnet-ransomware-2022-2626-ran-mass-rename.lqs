// Dragnet [Ransomware]: dragnet-ransomware-2022-2626 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 7b8dcf95-a65f-5bb6-9fda-d19d164dfa89

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
