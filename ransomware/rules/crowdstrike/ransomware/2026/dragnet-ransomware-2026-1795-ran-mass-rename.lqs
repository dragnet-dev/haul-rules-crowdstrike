// Dragnet [Ransomware]: dragnet-ransomware-2026-1795 — Mass File Rename (netrunner)
// Status: stable | Level: high | ID: a2e3fc83-9524-5495-802a-4aa2b87686cc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
