// Dragnet [Ransomware]: dragnet-ransomware-2025-3536 — Mass File Rename (beast)
// Status: experimental | Level: high | ID: 96ebc689-9da7-5cb2-afb6-6f3e3714da83

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
