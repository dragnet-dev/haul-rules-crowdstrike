// Dragnet [Ransomware]: dragnet-ransomware-2023-2896 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: b99730f6-27e5-5116-81d3-536a1d1bbdcd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
