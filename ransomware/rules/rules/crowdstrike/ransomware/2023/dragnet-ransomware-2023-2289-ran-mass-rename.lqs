// Dragnet [Ransomware]: dragnet-ransomware-2023-2289 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 883f7674-23fe-5100-89b2-12d1f93fcc30

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
