// Dragnet [Container]: dragnet-container-2025-0688 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 5e09b4b6-64d9-5b60-ab55-5351ef98ef20

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *ubuntu:18.04-ESM* OR ImageFileName = *ubuntu:20.04-ESM* OR ImageFileName = *ubuntu:22.04*)
| table([timestamp, ComputerName])
| limit(1000)
