// Dragnet [Ransomware]: dragnet-ransomware-2021-0996 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 62a4eebe-e0e3-5d90-a7f9-6302d588fe7f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
