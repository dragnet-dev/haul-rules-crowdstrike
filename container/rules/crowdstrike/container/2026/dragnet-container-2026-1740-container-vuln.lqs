// Dragnet [Container]: dragnet-container-2026-1740 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 199cfa92-9989-52d2-baea-31d7a4d320bd

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6*)
| table([timestamp, ComputerName])
| limit(1000)
