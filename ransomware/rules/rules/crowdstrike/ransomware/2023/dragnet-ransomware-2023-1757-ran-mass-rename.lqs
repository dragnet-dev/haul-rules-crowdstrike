// Dragnet [Ransomware]: dragnet-ransomware-2023-1757 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: a9e3ee07-8573-5b6d-9790-6683e07c8ea8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
