// Dragnet [Ransomware]: dragnet-ransomware-2025-6957 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 3c0d65f4-04c2-5a63-b45d-8cb373dd2904

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
