// Dragnet [Ransomware]: dragnet-ransomware-2024-0598 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: f99df0be-7a0f-54f0-8bf4-0233b35629c8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
