// Dragnet [Ransomware]: dragnet-ransomware-2022-2661 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: f00bdf31-3608-5ade-b742-926ab18527d1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
