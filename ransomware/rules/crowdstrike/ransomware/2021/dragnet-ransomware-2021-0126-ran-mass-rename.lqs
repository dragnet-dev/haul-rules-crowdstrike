// Dragnet [Ransomware]: dragnet-ransomware-2021-0126 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 2ba05c2b-98c3-5861-97d9-50ed65c01276

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
