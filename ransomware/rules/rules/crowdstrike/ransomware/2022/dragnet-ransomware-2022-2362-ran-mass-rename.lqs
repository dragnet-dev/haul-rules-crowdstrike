// Dragnet [Ransomware]: dragnet-ransomware-2022-2362 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: beb42878-b3d9-54bd-b9a4-cd0bd3452f67

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
