// Dragnet [Ransomware]: dragnet-ransomware-2022-2867 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 414a3930-8de8-5bcf-b451-9f4159082e26

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
