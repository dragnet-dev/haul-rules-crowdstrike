// Dragnet [Ransomware]: dragnet-ransomware-2023-2467 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 0c90aae5-0a99-5e9d-a2f4-381d18d076d5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
