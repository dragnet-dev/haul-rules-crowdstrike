// Dragnet [Ransomware]: dragnet-ransomware-2023-3642 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 3ed68726-dce5-52a6-b5a2-5e444c874e55

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
