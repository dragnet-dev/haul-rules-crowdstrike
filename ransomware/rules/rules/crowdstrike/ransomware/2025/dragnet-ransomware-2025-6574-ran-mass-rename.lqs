// Dragnet [Ransomware]: dragnet-ransomware-2025-6574 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 2335fc6c-c1d3-52bb-9146-fced332b1d6a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
