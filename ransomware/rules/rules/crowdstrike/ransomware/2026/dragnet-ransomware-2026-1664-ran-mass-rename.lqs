// Dragnet [Ransomware]: dragnet-ransomware-2026-1664 — Mass File Rename (lockbit5)
// Status: stable | Level: high | ID: 282fad81-f2bf-5d74-aa96-ba225aec01a7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
