// Dragnet [Ransomware]: dragnet-ransomware-2023-5308 — Mass File Rename (ransomhouse)
// Status: experimental | Level: high | ID: 872ba888-14c7-5b18-bc7a-a805ef0d3d7f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
