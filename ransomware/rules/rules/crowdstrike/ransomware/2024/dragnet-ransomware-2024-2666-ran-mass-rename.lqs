// Dragnet [Ransomware]: dragnet-ransomware-2024-2666 — Mass File Rename (play)
// Status: experimental | Level: high | ID: c9af2af8-23f5-5a8d-bb73-f79305a83882

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
