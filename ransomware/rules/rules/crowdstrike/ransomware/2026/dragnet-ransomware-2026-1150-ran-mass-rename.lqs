// Dragnet [Ransomware]: dragnet-ransomware-2026-1150 — Mass File Rename (thegentlemen)
// Status: stable | Level: high | ID: fefbbc8a-fc8c-51b6-b68e-6b3d903385c6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
