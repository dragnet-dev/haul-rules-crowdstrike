// Dragnet [Ransomware]: dragnet-ransomware-2024-4016 — Mass File Rename (dragonransomware)
// Status: experimental | Level: high | ID: dab95b63-411f-50f6-8d7b-e5cc4536eacb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
