// Dragnet [Ransomware]: dragnet-ransomware-2022-0653 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 5a34a773-6b9a-5b07-9ffb-375819b4fc75

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
