// Dragnet [Ransomware]: dragnet-ransomware-2024-4176 — Mass File Rename (play)
// Status: experimental | Level: high | ID: e6852d9d-98d5-53b6-9bff-e4f166e6022f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
