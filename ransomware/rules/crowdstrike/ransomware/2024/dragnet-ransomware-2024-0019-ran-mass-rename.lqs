// Dragnet [Ransomware]: dragnet-ransomware-2024-0019 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 1237bca4-5614-59ae-8a38-38d66946f127

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
