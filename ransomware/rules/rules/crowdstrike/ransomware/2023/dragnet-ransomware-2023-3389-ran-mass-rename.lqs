// Dragnet [Ransomware]: dragnet-ransomware-2023-3389 — Mass File Rename (abyss)
// Status: deprecated | Level: high | ID: fd75f1cc-5728-5d82-986f-50e606c5fc24

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
