// Dragnet [Ransomware]: dragnet-ransomware-2026-0022 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 6dd607aa-f4b8-58b3-bab6-f503fa6b5d92

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
