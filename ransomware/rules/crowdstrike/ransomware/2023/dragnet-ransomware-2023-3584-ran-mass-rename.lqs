// Dragnet [Ransomware]: dragnet-ransomware-2023-3584 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: f9295ea6-f070-537f-8e79-83244ddf0b88

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
