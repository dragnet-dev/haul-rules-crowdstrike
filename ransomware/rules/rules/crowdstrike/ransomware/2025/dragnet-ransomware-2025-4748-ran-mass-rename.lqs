// Dragnet [Ransomware]: dragnet-ransomware-2025-4748 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: 3d32665a-d12c-51bb-9a89-f302cd3917a2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
