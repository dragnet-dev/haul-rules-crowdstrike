// Dragnet [Ransomware]: dragnet-ransomware-2022-2872 — Mass File Rename (karakurt)
// Status: deprecated | Level: high | ID: 3fe7ff15-2895-5c10-b202-da9bca2c3b65

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
