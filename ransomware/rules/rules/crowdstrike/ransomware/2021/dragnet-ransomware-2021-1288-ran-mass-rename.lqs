// Dragnet [Ransomware]: dragnet-ransomware-2021-1288 — Mass File Rename (blackshadow)
// Status: deprecated | Level: high | ID: dec1f51b-184c-5540-b121-c7eaf9ef0483

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
