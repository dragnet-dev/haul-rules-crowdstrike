// Dragnet [Ransomware]: dragnet-ransomware-2023-0284 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 32535471-1479-5a90-a1be-70f2473bef02

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
