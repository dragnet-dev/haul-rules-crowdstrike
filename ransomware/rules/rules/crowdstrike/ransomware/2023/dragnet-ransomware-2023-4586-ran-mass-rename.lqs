// Dragnet [Ransomware]: dragnet-ransomware-2023-4586 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: b4f3e94b-30f6-53ce-bdd0-9ca1f00abce1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
