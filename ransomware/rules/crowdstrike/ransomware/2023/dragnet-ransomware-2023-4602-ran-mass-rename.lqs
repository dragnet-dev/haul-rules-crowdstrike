// Dragnet [Ransomware]: dragnet-ransomware-2023-4602 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: d8cba9d1-8404-578f-a7f5-d460cad43421

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
