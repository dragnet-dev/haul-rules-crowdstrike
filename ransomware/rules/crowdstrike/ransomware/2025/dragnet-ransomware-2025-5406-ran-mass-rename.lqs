// Dragnet [Ransomware]: dragnet-ransomware-2025-5406 — Mass File Rename (J)
// Status: experimental | Level: high | ID: 841708ca-db03-5a4c-903a-281ac3a9d605

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
