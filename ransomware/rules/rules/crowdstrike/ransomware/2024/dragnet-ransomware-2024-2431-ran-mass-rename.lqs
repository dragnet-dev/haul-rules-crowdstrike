// Dragnet [Ransomware]: dragnet-ransomware-2024-2431 — Mass File Rename (apt73)
// Status: experimental | Level: high | ID: 956460a8-0bd9-5022-9c1a-32ef75f805cf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
