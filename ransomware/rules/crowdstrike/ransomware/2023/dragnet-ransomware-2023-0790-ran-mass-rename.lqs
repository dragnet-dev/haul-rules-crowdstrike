// Dragnet [Ransomware]: dragnet-ransomware-2023-0790 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: d3f03ba5-56cd-58fc-9aaf-cdd1a7691470

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
