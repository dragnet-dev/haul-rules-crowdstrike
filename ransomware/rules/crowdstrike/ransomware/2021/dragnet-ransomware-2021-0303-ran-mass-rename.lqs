// Dragnet [Ransomware]: dragnet-ransomware-2021-0303 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: ae0f9f9e-0373-59f6-80d2-54182d66f6da

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
