// Dragnet [Ransomware]: dragnet-ransomware-2025-6143 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 9fd3e05d-94a9-54cd-82c9-ae246a2831c6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
