// Dragnet [Ransomware]: dragnet-ransomware-2025-1257 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: a6e459f5-6854-5d20-ab50-1a1622d8f373

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
