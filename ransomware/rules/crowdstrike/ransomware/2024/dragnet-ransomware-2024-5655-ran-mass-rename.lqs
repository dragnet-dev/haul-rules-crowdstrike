// Dragnet [Ransomware]: dragnet-ransomware-2024-5655 — Mass File Rename (dragonransomware)
// Status: experimental | Level: high | ID: c3c76d0f-c887-547d-96e6-00d5b1a4b359

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
