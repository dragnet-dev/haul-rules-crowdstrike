// Dragnet [Ransomware]: dragnet-ransomware-2023-3443 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 841b0db3-2075-580c-97ba-8639634ed2b0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
