// Dragnet [Ransomware]: dragnet-ransomware-2025-6377 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 4cb44f06-19ab-507a-89e7-82d39ad47fa7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
