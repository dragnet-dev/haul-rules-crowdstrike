// Dragnet [Ransomware]: dragnet-ransomware-2024-0967 — Mass File Rename (arcusmedia)
// Status: experimental | Level: high | ID: f2ca584d-32d4-51ff-baf9-f55ca78a17c5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
