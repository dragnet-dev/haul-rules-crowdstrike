// Dragnet [Ransomware]: dragnet-ransomware-2025-2458 — Mass File Rename (thegentlemen)
// Status: experimental | Level: high | ID: d1d38102-06fd-57fd-9f03-a278265343bd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
