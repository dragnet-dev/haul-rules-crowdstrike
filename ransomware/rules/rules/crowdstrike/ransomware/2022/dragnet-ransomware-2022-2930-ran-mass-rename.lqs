// Dragnet [Ransomware]: dragnet-ransomware-2022-2930 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: ded85be8-527f-53d0-a64e-92abf351a687

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
