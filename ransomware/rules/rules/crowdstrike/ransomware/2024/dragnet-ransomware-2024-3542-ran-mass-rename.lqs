// Dragnet [Ransomware]: dragnet-ransomware-2024-3542 — Mass File Rename (meow)
// Status: experimental | Level: high | ID: 0ad35748-1597-520f-aa32-a1059660b99a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
