// Dragnet [Ransomware]: dragnet-ransomware-2022-0987 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: b0023fdc-567e-5756-8ab8-491dcdb01ea0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
