// Dragnet [Ransomware]: dragnet-ransomware-2022-0547 — Mass File Rename (blackbasta)
// Status: deprecated | Level: high | ID: 7aa3d3ce-f326-5fa0-9103-13c506fc2f73

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
