// Dragnet [Ransomware]: dragnet-ransomware-2024-2737 — Mass File Rename (meow)
// Status: experimental | Level: high | ID: 4ba3e9cf-7db8-57d8-bdcf-be934349c005

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
