// Dragnet [Ransomware]: dragnet-ransomware-2023-3908 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: b990bf0d-4426-549a-b31c-8b88d4609f41

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
