// Dragnet [Ransomware]: dragnet-ransomware-2026-0150 — Mass File Rename (lockbit5)
// Status: stable | Level: high | ID: 46ba4e36-ae18-5f9e-9c6f-2f5ff52f95a4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
