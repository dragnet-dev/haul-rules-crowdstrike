// Dragnet [Ransomware]: dragnet-ransomware-2025-0392 — Mass File Rename (datacarry)
// Status: deprecated | Level: high | ID: 14ce5685-4466-5e1b-aca0-4809393446a2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
