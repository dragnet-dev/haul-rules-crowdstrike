// Dragnet [Ransomware]: dragnet-ransomware-2025-5625 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: 0f46394a-a3a9-508c-8a1f-a0272ccdd2ee

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
