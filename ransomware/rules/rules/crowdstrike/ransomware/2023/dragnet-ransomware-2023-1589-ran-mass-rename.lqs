// Dragnet [Ransomware]: dragnet-ransomware-2023-1589 — Mass File Rename (royal)
// Status: experimental | Level: high | ID: a9113501-f7fc-5302-9347-56b05280f879

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
