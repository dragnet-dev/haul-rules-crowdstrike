// Dragnet [Ransomware]: dragnet-ransomware-2022-1425 — Mass File Rename (lv)
// Status: deprecated | Level: high | ID: bf15769e-373b-534d-afeb-e9f5407af5a5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
