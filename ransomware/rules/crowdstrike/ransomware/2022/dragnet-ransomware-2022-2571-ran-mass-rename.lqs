// Dragnet [Ransomware]: dragnet-ransomware-2022-2571 — Mass File Rename (ragnarlocker)
// Status: experimental | Level: high | ID: f820a50d-5cb4-5379-86ec-54652382158c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
