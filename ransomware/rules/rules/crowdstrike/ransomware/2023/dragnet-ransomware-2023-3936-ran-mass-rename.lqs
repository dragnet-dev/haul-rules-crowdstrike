// Dragnet [Ransomware]: dragnet-ransomware-2023-3936 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: ccf9b51c-2854-589c-b2c9-f970c09e40b0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
