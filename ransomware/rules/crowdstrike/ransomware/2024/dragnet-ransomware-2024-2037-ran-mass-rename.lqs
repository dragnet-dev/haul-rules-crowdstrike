// Dragnet [Ransomware]: dragnet-ransomware-2024-2037 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: 9ae4acb7-88fe-50c7-9c56-81536f58e09c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
