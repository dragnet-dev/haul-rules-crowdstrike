// Dragnet [Ransomware]: dragnet-ransomware-2024-1407 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: c0728ec8-2818-5af0-9fce-6ac577aeb15b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
