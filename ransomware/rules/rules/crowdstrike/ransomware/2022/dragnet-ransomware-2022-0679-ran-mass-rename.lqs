// Dragnet [Ransomware]: dragnet-ransomware-2022-0679 — Mass File Rename (worldleaks)
// Status: experimental | Level: high | ID: d4962552-866f-5af1-8929-16ec2c25ca3c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
