// Dragnet [Ransomware]: dragnet-ransomware-2023-4205 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 43244319-b3f2-585d-b282-ca011edc1ea5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
