// Dragnet [Ransomware]: dragnet-ransomware-2023-1844 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 0998744d-be33-58d9-abd1-084d6d114359

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
