// Dragnet [Container]: dragnet-container-2025-0205 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 12279a55-e806-5209-86fc-994633d75620

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:9* OR ImageFileName = *photon os:3.0* OR ImageFileName = *photon os:4.0* OR ImageFileName = *ubuntu:18.04* OR ImageFileName = *ubuntu:18.04-ESM* OR ImageFileName = *ubuntu:20.04* OR ImageFileName = *ubuntu:20.04-ESM* OR ImageFileName = *ubuntu:21.04* OR ImageFileName = *ubuntu:21.10*)
| table([timestamp, ComputerName])
| limit(1000)
