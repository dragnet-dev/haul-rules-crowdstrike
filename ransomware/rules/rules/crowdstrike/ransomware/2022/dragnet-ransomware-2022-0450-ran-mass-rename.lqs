// Dragnet [Ransomware]: dragnet-ransomware-2022-0450 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 77f02f40-fe47-53f0-ab9b-c63be76f0ce2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
