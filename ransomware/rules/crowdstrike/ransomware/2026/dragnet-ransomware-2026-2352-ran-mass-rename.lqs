// Dragnet [Ransomware]: dragnet-ransomware-2026-2352 — Mass File Rename (incransom)
// Status: stable | Level: high | ID: 0d051d09-8a8e-5168-b084-fec1175ad176

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
