// Dragnet [Ransomware]: dragnet-ransomware-2024-3733 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: 2521e91f-7a7e-5f5d-8fd0-8b2c25404961

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
