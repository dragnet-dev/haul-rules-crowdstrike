// Dragnet [Ransomware]: dragnet-ransomware-2022-0040 — Mass File Rename (lorenz)
// Status: deprecated | Level: high | ID: 582f71fc-0386-53aa-b456-272e55add230

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
