// Dragnet [Ransomware]: dragnet-ransomware-2025-4974 — Mass File Rename (pear)
// Status: experimental | Level: high | ID: edd73f23-63ec-5057-af1c-943af2dd8fed

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
