// Dragnet [Ransomware]: dragnet-ransomware-2024-4210 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 66810d99-f080-53d1-9f39-2ff48a22e9f4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
