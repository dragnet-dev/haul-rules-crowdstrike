// Dragnet [Ransomware]: dragnet-ransomware-2021-1461 — Mass File Rename (karma)
// Status: deprecated | Level: high | ID: 1a4f0f2e-7d31-5a58-8b4c-7361ed346403

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
