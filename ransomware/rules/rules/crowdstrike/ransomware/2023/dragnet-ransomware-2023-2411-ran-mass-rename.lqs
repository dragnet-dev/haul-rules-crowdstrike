// Dragnet [Ransomware]: dragnet-ransomware-2023-2411 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 7ab43e4e-df17-5d2a-8889-f3cbaf2eb5ec

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
