// Dragnet [Ransomware]: dragnet-ransomware-2021-0656 — Mass File Rename (avaddon)
// Status: deprecated | Level: high | ID: 4f401cc2-1d50-5d9e-a04d-d22c61fc5086

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
