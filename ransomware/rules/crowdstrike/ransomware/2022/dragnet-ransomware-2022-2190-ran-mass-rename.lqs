// Dragnet [Ransomware]: dragnet-ransomware-2022-2190 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 87412154-0829-53b8-b9cf-72f6b39e0e28

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
