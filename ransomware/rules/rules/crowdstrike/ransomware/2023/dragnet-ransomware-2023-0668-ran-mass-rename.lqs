// Dragnet [Ransomware]: dragnet-ransomware-2023-0668 — Mass File Rename (karakurt)
// Status: experimental | Level: high | ID: b449495a-7d07-5095-a47e-d6508cb277c3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
