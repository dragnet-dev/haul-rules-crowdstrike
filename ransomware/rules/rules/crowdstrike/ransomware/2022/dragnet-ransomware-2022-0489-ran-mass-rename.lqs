// Dragnet [Ransomware]: dragnet-ransomware-2022-0489 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 83469a27-43cc-5198-88dd-ac9718e5d96e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
