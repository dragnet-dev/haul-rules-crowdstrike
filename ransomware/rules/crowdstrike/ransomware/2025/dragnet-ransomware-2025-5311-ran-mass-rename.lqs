// Dragnet [Ransomware]: dragnet-ransomware-2025-5311 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: ec5a05cf-3a19-5953-bb95-a96b11628793

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
