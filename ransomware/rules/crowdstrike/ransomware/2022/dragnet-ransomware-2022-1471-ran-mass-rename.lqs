// Dragnet [Ransomware]: dragnet-ransomware-2022-1471 — Mass File Rename (royal)
// Status: deprecated | Level: high | ID: 8875a45f-b9a1-50f1-b894-582cd656e1d8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
