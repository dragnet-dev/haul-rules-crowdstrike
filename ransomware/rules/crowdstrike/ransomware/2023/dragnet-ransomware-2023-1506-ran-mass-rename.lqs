// Dragnet [Ransomware]: dragnet-ransomware-2023-1506 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 783ba9dc-4b9a-5753-9472-6a75e7c81ef1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
