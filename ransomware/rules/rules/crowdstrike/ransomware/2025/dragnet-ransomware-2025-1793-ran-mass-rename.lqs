// Dragnet [Ransomware]: dragnet-ransomware-2025-1793 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: dcc1d7a1-643a-54bd-a014-ec53e6829576

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
