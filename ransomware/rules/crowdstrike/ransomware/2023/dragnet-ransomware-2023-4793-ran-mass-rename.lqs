// Dragnet [Ransomware]: dragnet-ransomware-2023-4793 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: e79ca734-7af2-5c9c-ab12-c8dfd9219194

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
