// Dragnet [Ransomware]: dragnet-ransomware-2024-4160 — Mass File Rename (embargo)
// Status: experimental | Level: high | ID: 884dfef5-d08a-5a2f-a486-cc1db3c7ec05

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
