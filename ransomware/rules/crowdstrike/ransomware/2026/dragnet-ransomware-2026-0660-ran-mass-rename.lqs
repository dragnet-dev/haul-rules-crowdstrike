// Dragnet [Ransomware]: dragnet-ransomware-2026-0660 — Mass File Rename (vect)
// Status: deprecated | Level: high | ID: 4a4dbb57-92a9-51aa-bee9-a9f452dba5f8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
