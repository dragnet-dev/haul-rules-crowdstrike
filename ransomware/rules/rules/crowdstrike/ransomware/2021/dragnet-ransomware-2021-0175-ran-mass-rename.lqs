// Dragnet [Ransomware]: dragnet-ransomware-2021-0175 — Mass File Rename (deathkitty)
// Status: deprecated | Level: high | ID: 459579f8-cb92-5e81-80d6-5b5bb30484bb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
