// Dragnet [Ransomware]: dragnet-ransomware-2024-2492 — Mass File Rename (apt73)
// Status: experimental | Level: high | ID: ed412122-0c77-526d-b11c-5b3093f06d8a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
