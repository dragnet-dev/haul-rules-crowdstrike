// Dragnet [Ransomware]: dragnet-ransomware-2022-0801 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: ab35acd8-3295-5b57-ac29-35b0700d8a15

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
