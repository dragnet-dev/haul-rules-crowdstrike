// Dragnet [Ransomware]: dragnet-ransomware-2026-0507 — Mass File Rename (payload)
// Status: stable | Level: high | ID: 008368ae-43bf-59ea-b5ef-4681f4edd946

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
