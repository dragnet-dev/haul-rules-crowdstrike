// Dragnet [Container]: dragnet-container-2026-1835 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 85ff0160-5c3d-54a7-8307-7b5688a2fa5f

#event_simpleName=*
| (ImageFileName = *chainguard:* OR ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10*)
| table([timestamp, ComputerName])
| limit(1000)
