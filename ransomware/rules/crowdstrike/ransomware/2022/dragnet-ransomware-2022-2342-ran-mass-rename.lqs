// Dragnet [Ransomware]: dragnet-ransomware-2022-2342 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 9a7f6efa-d617-5816-b6b8-10f8cfcffd0c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
