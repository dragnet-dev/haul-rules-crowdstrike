// Dragnet [Ransomware]: dragnet-ransomware-2022-0467 — Mass File Rename (avoslocker)
// Status: deprecated | Level: high | ID: b7e94cec-e1ba-5038-b2cd-06237a7000ad

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
