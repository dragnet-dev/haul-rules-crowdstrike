// Dragnet [Ransomware]: dragnet-ransomware-2023-3033 — Mass File Rename (medusa)
// Status: deprecated | Level: high | ID: 4e4862a9-a126-503d-a2de-0b4e722dbff6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
