// Dragnet [Ransomware]: dragnet-ransomware-2024-0440 — Mass File Rename (meow)
// Status: experimental | Level: high | ID: b9a6252c-27cd-5a22-b79c-0dc25d0d0762

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
