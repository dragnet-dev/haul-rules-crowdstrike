// Dragnet [Ransomware]: dragnet-ransomware-2024-1933 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 674169ca-c939-5e78-921f-7d776338887b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
