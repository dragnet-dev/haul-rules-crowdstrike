// Dragnet [Ransomware]: dragnet-ransomware-2023-0383 — Mass File Rename (toufan)
// Status: deprecated | Level: high | ID: 990d1e17-2f26-56e1-adee-db0f259913a8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
