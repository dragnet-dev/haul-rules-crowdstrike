// Dragnet [Ransomware]: dragnet-ransomware-2022-2482 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 981ccc14-87f1-5b6d-a296-2b2da6aa3903

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
