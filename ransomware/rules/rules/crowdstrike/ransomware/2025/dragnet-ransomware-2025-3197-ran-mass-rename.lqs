// Dragnet [Ransomware]: dragnet-ransomware-2025-3197 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: b1771a66-1716-5e68-b502-5d6022c6517b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
