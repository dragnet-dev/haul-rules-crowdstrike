// Dragnet [Ransomware]: dragnet-ransomware-2024-4475 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 40e31730-1c6c-59f0-a538-9008fa8e19c5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
