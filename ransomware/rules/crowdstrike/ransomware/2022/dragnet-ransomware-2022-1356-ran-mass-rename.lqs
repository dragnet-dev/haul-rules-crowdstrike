// Dragnet [Ransomware]: dragnet-ransomware-2022-1356 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 178861c6-2f6f-599a-960b-defc97795e84

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
