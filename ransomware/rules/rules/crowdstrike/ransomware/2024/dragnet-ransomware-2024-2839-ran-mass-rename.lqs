// Dragnet [Ransomware]: dragnet-ransomware-2024-2839 — Mass File Rename (blacklock)
// Status: experimental | Level: high | ID: 5bab77d1-2474-569c-b5e9-655dc77d3783

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
