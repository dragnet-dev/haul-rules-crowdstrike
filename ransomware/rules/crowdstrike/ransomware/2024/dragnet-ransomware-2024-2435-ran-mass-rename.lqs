// Dragnet [Ransomware]: dragnet-ransomware-2024-2435 — Mass File Rename (spacebears)
// Status: experimental | Level: high | ID: 9a51d384-46e6-5a1c-b672-f3d46d5b9be4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
