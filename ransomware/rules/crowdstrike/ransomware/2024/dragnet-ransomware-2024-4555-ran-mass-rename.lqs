// Dragnet [Ransomware]: dragnet-ransomware-2024-4555 — Mass File Rename (qiulong)
// Status: experimental | Level: high | ID: c9fd4034-1017-5394-b4f7-cb05bde6fee2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
