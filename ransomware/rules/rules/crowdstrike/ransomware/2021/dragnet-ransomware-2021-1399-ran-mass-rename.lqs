// Dragnet [Ransomware]: dragnet-ransomware-2021-1399 — Mass File Rename (azroteam)
// Status: deprecated | Level: high | ID: 61fe457b-393e-58bf-ac20-b25d9dcdcad8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
