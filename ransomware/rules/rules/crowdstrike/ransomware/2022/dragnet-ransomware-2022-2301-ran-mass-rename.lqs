// Dragnet [Ransomware]: dragnet-ransomware-2022-2301 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: e8d78313-9926-5886-9240-4a84f924fa0d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
