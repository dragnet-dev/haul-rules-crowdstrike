// Dragnet [Ransomware]: dragnet-ransomware-2022-2590 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 09f853e5-ba0a-52f0-8c31-57d845b09adb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
