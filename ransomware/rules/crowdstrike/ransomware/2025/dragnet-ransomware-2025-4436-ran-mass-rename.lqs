// Dragnet [Ransomware]: dragnet-ransomware-2025-4436 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 87d4c0f9-ff9d-5f4c-8736-2c5adbf38f49

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
