// Dragnet [Container]: dragnet-container-2026-1708 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 2b61f291-945a-54ba-9a9f-f6cd6821bd4d

#event_simpleName=*
| (ImageFileName = *amazonlinux:1* OR ImageFileName = *debian:7* OR ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *photon os:4.0* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10* OR ImageFileName = *ubuntu:13.04*)
| table([timestamp, ComputerName])
| limit(1000)
