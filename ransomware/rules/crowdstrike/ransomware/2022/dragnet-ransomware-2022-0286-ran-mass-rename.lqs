// Dragnet [Ransomware]: dragnet-ransomware-2022-0286 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: b9060c3b-6c6f-5e38-8de5-f16429926aef

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
