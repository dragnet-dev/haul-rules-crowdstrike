// Dragnet [Ransomware]: dragnet-ransomware-2023-2037 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 723ed5ed-81fb-54e6-98c0-3850e6e3a5be

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
