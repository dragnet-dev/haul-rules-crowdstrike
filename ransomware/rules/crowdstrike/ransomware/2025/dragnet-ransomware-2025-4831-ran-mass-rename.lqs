// Dragnet [Ransomware]: dragnet-ransomware-2025-4831 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: c07165c9-f216-566b-924f-e2df59ec64f9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
