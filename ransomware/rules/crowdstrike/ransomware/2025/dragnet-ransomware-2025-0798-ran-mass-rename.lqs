// Dragnet [Ransomware]: dragnet-ransomware-2025-0798 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 4ba640ab-b93b-5722-8041-68d5cffe3642

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
