// Dragnet [Ransomware]: dragnet-ransomware-2025-5050 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 86c85492-cefb-5728-ad4e-d3f006920d51

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
