// Dragnet [Ransomware]: dragnet-ransomware-2025-5568 — Mass File Rename (sinobi)
// Status: experimental | Level: high | ID: fad6f688-5d3f-57b1-99ca-d565f731887b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
