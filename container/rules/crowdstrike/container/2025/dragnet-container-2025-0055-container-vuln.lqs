// Dragnet [Container]: dragnet-container-2025-0055 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 3ae0ab8f-4443-5c88-beac-d00163e8a0d5

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
