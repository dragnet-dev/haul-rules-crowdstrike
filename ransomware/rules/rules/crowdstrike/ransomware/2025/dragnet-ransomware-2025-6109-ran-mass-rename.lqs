// Dragnet [Ransomware]: dragnet-ransomware-2025-6109 — Mass File Rename (tridentlocker)
// Status: experimental | Level: high | ID: 7f169faa-cc2b-520c-82f2-d29b708a0d53

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
