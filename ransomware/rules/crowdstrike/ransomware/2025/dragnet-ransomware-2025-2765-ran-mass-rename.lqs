// Dragnet [Ransomware]: dragnet-ransomware-2025-2765 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 71bf8314-f5d8-5f06-9701-50106ecfcde1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
