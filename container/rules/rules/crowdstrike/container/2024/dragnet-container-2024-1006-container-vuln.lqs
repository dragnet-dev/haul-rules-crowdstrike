// Dragnet [Container]: dragnet-container-2024-1006 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: cff74511-8252-514f-9711-14fced7abcf7

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:8* OR ImageFileName = *debian:9* OR ImageFileName = *ubuntu:18.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
