// Dragnet [Ransomware]: dragnet-ransomware-2024-4012 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: 8f92c692-e507-522a-bbc0-d5c731d961a9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
