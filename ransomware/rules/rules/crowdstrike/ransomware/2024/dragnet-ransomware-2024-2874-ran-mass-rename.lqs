// Dragnet [Ransomware]: dragnet-ransomware-2024-2874 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: 71300c68-fb6d-5a0a-a4fc-cbe348ddea39

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
