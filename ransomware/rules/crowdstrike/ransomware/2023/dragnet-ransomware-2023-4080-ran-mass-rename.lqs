// Dragnet [Ransomware]: dragnet-ransomware-2023-4080 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 6fdeb86b-cf2c-54e9-b284-8c8a21f4b9f5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
