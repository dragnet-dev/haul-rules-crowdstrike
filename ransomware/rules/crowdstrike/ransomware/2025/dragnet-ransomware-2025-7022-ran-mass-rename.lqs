// Dragnet [Ransomware]: dragnet-ransomware-2025-7022 — Mass File Rename (incransom)
// Status: test | Level: high | ID: 86b7968b-f7ff-5325-a0db-4f12c09c7153

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
