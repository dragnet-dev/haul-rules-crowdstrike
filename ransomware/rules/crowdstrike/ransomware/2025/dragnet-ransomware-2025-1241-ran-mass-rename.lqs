// Dragnet [Ransomware]: dragnet-ransomware-2025-1241 — Mass File Rename (worldleaks)
// Status: experimental | Level: high | ID: 2167f0d2-c881-51b9-8995-764bed90a673

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
