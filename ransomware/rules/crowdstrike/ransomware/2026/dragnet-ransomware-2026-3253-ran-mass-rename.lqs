// Dragnet [Ransomware]: dragnet-ransomware-2026-3253 — Mass File Rename (dragonforce)
// Status: stable | Level: high | ID: 702d0a3e-fb18-5e2e-88ba-b61507c6d6d4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
