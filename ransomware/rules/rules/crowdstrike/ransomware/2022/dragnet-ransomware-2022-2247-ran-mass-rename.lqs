// Dragnet [Ransomware]: dragnet-ransomware-2022-2247 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 638722c7-c428-5519-8a8a-beb15b3147ee

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
