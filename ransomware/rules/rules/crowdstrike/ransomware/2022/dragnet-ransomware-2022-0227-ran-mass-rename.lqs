// Dragnet [Ransomware]: dragnet-ransomware-2022-0227 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 2379be6d-460d-581c-ad67-402f26b8e471

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
