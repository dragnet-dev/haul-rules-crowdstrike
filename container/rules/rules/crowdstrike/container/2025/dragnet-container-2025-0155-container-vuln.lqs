// Dragnet [Container]: dragnet-container-2025-0155 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 14473de2-7f0e-5f43-80d5-8a02fbe9fecb

#event_simpleName=*
| (ImageFileName = *almalinux:8* OR ImageFileName = *almalinux:9* OR ImageFileName = *amazonlinux:2023* OR ImageFileName = *cbl-mariner:2.0* OR ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:8* OR ImageFileName = *oraclelinux:9* OR ImageFileName = *photon os:3.0* OR ImageFileName = *photon os:4.0* OR ImageFileName = *photon os:5.0* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:16.04-ESM* OR ImageFileName = *ubuntu:18.04-ESM* OR ImageFileName = *ubuntu:20.04* OR ImageFileName = *ubuntu:20.04-ESM* OR ImageFileName = *ubuntu:22.04* OR ImageFileName = *ubuntu:23.10* OR ImageFileName = *ubuntu:24.04* OR ImageFileName = *ubuntu:24.10* OR ImageFileName = *ubuntu:25.04* OR ImageFileName = *ubuntu:25.10* OR ImageFileName = *ubuntu:26.04*)
| table([timestamp, ComputerName])
| limit(1000)
