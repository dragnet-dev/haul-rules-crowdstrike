// Dragnet [Ransomware]: dragnet-ransomware-2025-4849 — Mass File Rename (insomnia)
// Status: experimental | Level: high | ID: 1a4945a7-576a-5595-9c57-e71ecd950a46

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
