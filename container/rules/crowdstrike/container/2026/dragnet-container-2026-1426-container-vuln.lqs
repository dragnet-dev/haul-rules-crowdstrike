// Dragnet [Container]: dragnet-container-2026-1426 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 32aedf5f-173a-514e-9053-697f40f2ea7d

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:7* OR ImageFileName = *debian:8* OR ImageFileName = *debian:9*)
| table([timestamp, ComputerName])
| limit(1000)
