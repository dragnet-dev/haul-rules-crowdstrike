// Dragnet [Ransomware]: dragnet-ransomware-2022-1001 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: d9332c0b-20ae-56e2-bab0-c1f0391614bb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
