// Dragnet [Ransomware]: dragnet-ransomware-2025-6268 — Mass File Rename (teamxxx)
// Status: experimental | Level: high | ID: 1614a13f-3bb7-5c5c-b097-1de83315ed4a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
