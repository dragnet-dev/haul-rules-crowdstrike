// Dragnet [Ransomware]: dragnet-ransomware-2022-1896 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: db653caf-37da-5721-8f6c-24b6989cd900

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
