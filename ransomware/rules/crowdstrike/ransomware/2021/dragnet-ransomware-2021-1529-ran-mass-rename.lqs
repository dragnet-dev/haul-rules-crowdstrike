// Dragnet [Ransomware]: dragnet-ransomware-2021-1529 — Mass File Rename (darkleakmarket)
// Status: deprecated | Level: high | ID: c85b195d-8e4b-5a20-aa3c-6775a8124e2a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
