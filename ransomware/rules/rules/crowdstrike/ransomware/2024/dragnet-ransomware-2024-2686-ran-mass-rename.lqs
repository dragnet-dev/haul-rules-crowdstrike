// Dragnet [Ransomware]: dragnet-ransomware-2024-2686 — Mass File Rename (meow)
// Status: experimental | Level: high | ID: 905737b1-1ea4-5334-91c8-6ac86476f777

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
