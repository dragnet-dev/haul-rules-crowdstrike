// Dragnet [Ransomware]: dragnet-ransomware-2023-3148 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: aae3280b-cb3d-543e-958e-ad164ece8294

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
