// Dragnet [Container]: dragnet-container-2026-2781 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 5035edaa-5d1a-5423-9c48-adf28fa7d49b

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:8* OR ImageFileName = *ubuntu:15.10*)
| table([timestamp, ComputerName])
| limit(1000)
