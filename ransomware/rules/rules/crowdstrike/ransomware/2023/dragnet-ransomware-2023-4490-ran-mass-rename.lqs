// Dragnet [Ransomware]: dragnet-ransomware-2023-4490 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: f310dfb7-da9e-5159-ac5d-be26a5ee008c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
