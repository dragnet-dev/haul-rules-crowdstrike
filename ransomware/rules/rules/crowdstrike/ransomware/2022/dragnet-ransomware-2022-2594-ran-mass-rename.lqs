// Dragnet [Ransomware]: dragnet-ransomware-2022-2594 — Mass File Rename (blackbasta)
// Status: deprecated | Level: high | ID: 3dc4a4c5-e7b3-5893-a941-9b7fc403af1c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
