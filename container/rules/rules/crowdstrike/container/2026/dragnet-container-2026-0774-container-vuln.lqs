// Dragnet [Container]: dragnet-container-2026-0774 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 90a1477f-5f11-5ed5-bb10-486cfec487e6

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:5*)
| table([timestamp, ComputerName])
| limit(1000)
