// Dragnet [Ransomware]: dragnet-ransomware-2025-1739 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: db69e3da-44ab-5873-a160-71598507740f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
