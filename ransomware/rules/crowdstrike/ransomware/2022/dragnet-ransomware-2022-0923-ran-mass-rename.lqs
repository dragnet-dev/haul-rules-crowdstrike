// Dragnet [Ransomware]: dragnet-ransomware-2022-0923 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 6cc477dc-30f5-55f2-852b-3482031ad19f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
