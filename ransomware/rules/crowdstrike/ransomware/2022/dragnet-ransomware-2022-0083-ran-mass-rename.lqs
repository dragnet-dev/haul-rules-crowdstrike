// Dragnet [Ransomware]: dragnet-ransomware-2022-0083 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: fe8e8042-b6d5-5636-b9c6-c80e545d0422

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
