// Dragnet [Ransomware]: dragnet-ransomware-2024-4721 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 57a892bd-70f5-5c8d-af01-fa2a46d54ca2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
