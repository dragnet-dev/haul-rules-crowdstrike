// Dragnet [Ransomware]: dragnet-ransomware-2023-0540 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: c8bc5dff-e077-5e44-a58f-e40cdab864b9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
