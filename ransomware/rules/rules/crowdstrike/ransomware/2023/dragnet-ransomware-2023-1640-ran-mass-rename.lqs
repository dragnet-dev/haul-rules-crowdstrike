// Dragnet [Ransomware]: dragnet-ransomware-2023-1640 — Mass File Rename (qilin)
// Status: deprecated | Level: high | ID: f23e28b3-00fd-5201-b585-e69710936dd4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
