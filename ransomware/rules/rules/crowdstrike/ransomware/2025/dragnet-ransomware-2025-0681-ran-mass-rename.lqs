// Dragnet [Ransomware]: dragnet-ransomware-2025-0681 — Mass File Rename (worldleaks)
// Status: experimental | Level: high | ID: d83e3d3e-ee1d-51aa-8f8e-03e3a227f949

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
