// Dragnet [Ransomware]: dragnet-ransomware-2022-2157 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 2d34d109-6578-5b83-a579-13ab5fdf286b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
