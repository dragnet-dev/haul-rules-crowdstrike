// Dragnet [Ransomware]: dragnet-ransomware-2022-2995 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 502ff6b6-842b-5592-99a2-5defe949ebff

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
