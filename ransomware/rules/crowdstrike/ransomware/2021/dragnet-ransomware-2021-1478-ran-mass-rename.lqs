// Dragnet [Ransomware]: dragnet-ransomware-2021-1478 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: a16abdcb-6439-56a6-b367-ac34d8af4fa3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
