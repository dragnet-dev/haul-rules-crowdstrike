// Dragnet [Ransomware]: dragnet-ransomware-2023-4747 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: cbf657d8-6e07-5153-bd74-7d04b86bd3e6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
