// Dragnet [Ransomware]: dragnet-ransomware-2023-0377 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 50236096-25b3-53e7-afaf-d7f9e06f6656

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
