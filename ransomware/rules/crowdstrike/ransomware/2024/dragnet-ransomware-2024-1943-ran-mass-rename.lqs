// Dragnet [Ransomware]: dragnet-ransomware-2024-1943 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 88494413-10a2-5fa7-94f4-30c4bb67a2a4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
