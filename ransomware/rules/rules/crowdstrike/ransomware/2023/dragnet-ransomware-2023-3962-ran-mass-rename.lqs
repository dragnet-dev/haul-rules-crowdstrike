// Dragnet [Ransomware]: dragnet-ransomware-2023-3962 — Mass File Rename (cloak)
// Status: deprecated | Level: high | ID: da701dd7-dff3-55b0-8637-2333c3ad03ee

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
