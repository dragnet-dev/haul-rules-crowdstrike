// Dragnet [Ransomware]: dragnet-ransomware-2024-5950 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 4d6bd3f6-ee90-569f-becd-1eaeca09cfa6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
