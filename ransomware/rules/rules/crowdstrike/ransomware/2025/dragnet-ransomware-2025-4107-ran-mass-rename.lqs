// Dragnet [Ransomware]: dragnet-ransomware-2025-4107 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 31f5126a-d33d-5162-9393-1bb94993b915

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
