// Dragnet [Ransomware]: dragnet-ransomware-2024-3460 — Mass File Rename (termite)
// Status: experimental | Level: high | ID: 1531a9b5-c448-5e7f-b149-65f89e687768

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
