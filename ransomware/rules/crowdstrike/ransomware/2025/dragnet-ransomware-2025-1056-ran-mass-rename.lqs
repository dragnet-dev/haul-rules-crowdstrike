// Dragnet [Ransomware]: dragnet-ransomware-2025-1056 — Mass File Rename (termite)
// Status: experimental | Level: high | ID: 53348af4-9120-5be8-902b-7c645bf33461

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
