// Dragnet [Ransomware]: dragnet-ransomware-2022-2150 — Mass File Rename (avoslocker)
// Status: deprecated | Level: high | ID: 77f925df-a974-59eb-ac37-36f61e8cae56

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
