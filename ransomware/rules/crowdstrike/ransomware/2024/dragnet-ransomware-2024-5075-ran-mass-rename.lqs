// Dragnet [Ransomware]: dragnet-ransomware-2024-5075 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 86e17b54-3512-5130-b064-d137ba5be99a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
