// Dragnet [Ransomware]: dragnet-ransomware-2022-1420 — Mass File Rename (vicesociety)
// Status: deprecated | Level: high | ID: adc61ad0-112a-5ca5-9380-659e6c4ab4c5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
