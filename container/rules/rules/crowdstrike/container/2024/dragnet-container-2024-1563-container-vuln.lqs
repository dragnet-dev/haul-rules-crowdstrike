// Dragnet [Container]: dragnet-container-2024-1563 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 14d13f61-286f-556a-973e-7e18ce203fdb

#event_simpleName=*
| (ImageFileName = *almalinux:8* OR ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:8* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:20.04* OR ImageFileName = *ubuntu:20.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
