// Dragnet [Ransomware]: dragnet-ransomware-2022-2799 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 8d3978fb-9ed0-5ce8-a698-4f34740b1eb9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
