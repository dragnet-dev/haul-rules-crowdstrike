// Dragnet [Ransomware]: dragnet-ransomware-2025-4537 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: e095a2e3-bcde-58e1-8b77-48b575b22863

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
