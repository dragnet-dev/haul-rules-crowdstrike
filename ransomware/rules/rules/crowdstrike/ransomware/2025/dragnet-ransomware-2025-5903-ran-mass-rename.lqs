// Dragnet [Ransomware]: dragnet-ransomware-2025-5903 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 15deeabf-ef63-5351-aa77-444065e50562

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
