// Dragnet [Ransomware]: dragnet-ransomware-2020-0257 — Mass File Rename (netwalker)
// Status: deprecated | Level: high | ID: 143abc04-a1e8-5775-b975-40c556f73ee6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
