// Dragnet [Ransomware]: dragnet-ransomware-2023-2782 — Mass File Rename (malas)
// Status: experimental | Level: high | ID: 1be61dbd-a8b3-5bb1-ae92-cac4bc448d37

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
