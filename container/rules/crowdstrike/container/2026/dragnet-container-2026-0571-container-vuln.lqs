// Dragnet [Container]: dragnet-container-2026-0571 — Vulnerable Base Image Pull
// Status: deprecated | Level: medium | ID: 0ea44273-1e13-5239-97b1-e53fb13df2eb

#event_simpleName=*
| (ImageFileName = *chainguard:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
