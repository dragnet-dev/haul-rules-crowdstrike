// Dragnet [Ransomware]: dragnet-ransomware-2026-3330 — Mass File Rename (interlock)
// Status: test | Level: high | ID: c4c9f5f8-3613-5b0e-8e15-808677701c32

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
