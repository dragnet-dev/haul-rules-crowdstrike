// Dragnet [Ransomware]: dragnet-ransomware-2025-7360 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 80e6ce20-1fb0-555b-9ac3-33830af076a2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
