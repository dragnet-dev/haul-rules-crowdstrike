// Dragnet [Ransomware]: dragnet-ransomware-2025-7572 — Mass File Rename (nova)
// Status: experimental | Level: high | ID: 61923599-5d95-5e36-afa4-8b76e68c9a6d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
