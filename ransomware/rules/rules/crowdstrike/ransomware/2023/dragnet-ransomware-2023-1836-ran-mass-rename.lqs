// Dragnet [Ransomware]: dragnet-ransomware-2023-1836 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 28404644-d3bb-55e8-938f-ca11e26072b7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
