// Dragnet [Ransomware]: dragnet-ransomware-2023-3618 — Mass File Rename (snatch)
// Status: experimental | Level: high | ID: 7cf250e0-74c8-5772-bfdc-80cd9f8692e1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
