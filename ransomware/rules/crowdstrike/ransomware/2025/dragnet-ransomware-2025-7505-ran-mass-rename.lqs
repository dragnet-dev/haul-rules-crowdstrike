// Dragnet [Ransomware]: dragnet-ransomware-2025-7505 — Mass File Rename (rhysida)
// Status: deprecated | Level: high | ID: 6fffd2e8-50d7-5461-88f3-c6d3016d9c06

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
