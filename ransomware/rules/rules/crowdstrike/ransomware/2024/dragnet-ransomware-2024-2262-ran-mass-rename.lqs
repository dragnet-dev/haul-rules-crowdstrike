// Dragnet [Ransomware]: dragnet-ransomware-2024-2262 — Mass File Rename (dAn0n)
// Status: experimental | Level: high | ID: 1149db6f-7d82-5a8b-a87c-d53988192027

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
