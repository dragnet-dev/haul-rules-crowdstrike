// Dragnet [Ransomware]: dragnet-ransomware-2021-0107 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 99c11aa7-413f-5845-97b8-c05ebc8bd55b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
