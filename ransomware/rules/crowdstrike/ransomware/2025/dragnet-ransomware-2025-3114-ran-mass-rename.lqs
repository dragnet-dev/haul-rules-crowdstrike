// Dragnet [Ransomware]: dragnet-ransomware-2025-3114 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 2fefdf38-2cf3-5f59-8d5e-e846a4e12e65

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
