// Dragnet [Ransomware]: dragnet-ransomware-2024-5241 — Mass File Rename (blacklock)
// Status: experimental | Level: high | ID: 709a7bba-c302-568a-ad3e-e82d44a13ee3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
