// Dragnet [Ransomware]: dragnet-ransomware-2024-0527 — Mass File Rename (meow)
// Status: experimental | Level: high | ID: 8b68e422-591c-57d4-8c80-ba575a07eab8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
