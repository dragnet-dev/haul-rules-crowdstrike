// Dragnet [Ransomware]: dragnet-ransomware-2023-4882 — Mass File Rename (royal)
// Status: experimental | Level: high | ID: da9188db-1691-5abc-b89c-a30b64943d8d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
