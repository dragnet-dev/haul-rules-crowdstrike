// Dragnet [Ransomware]: dragnet-ransomware-2022-0605 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: c2285227-2c52-5e85-bc6e-ceccf91fc2d0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
