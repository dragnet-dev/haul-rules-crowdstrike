// Dragnet [Ransomware]: dragnet-ransomware-2024-4606 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: cadc8ac1-9e48-51c6-8ba4-d457e89568fc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
