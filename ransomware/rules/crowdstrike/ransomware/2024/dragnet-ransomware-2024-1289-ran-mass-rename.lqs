// Dragnet [Ransomware]: dragnet-ransomware-2024-1289 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: 1f71edd9-73b2-52a9-a820-83f43d21d4b3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
