// Dragnet [Ransomware]: dragnet-ransomware-2025-7418 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: 23d386a3-c975-5a55-8ed9-1482e66ed278

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
