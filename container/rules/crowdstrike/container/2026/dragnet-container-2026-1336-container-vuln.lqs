// Dragnet [Container]: dragnet-container-2026-1336 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 2d9d432d-3cd9-5314-abf0-04b1d4eb08fa

#event_simpleName=*
| (ImageFileName = *debian:7* OR ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *oraclelinux:7* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:14.04*)
| table([timestamp, ComputerName])
| limit(1000)
