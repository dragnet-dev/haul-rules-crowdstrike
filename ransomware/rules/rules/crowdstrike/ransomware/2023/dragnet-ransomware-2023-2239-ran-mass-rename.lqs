// Dragnet [Ransomware]: dragnet-ransomware-2023-2239 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 4494031f-3904-5ed0-9c50-c7ae3ea1699c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
