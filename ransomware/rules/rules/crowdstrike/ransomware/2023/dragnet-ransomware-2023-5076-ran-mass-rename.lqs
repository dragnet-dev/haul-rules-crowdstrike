// Dragnet [Ransomware]: dragnet-ransomware-2023-5076 — Mass File Rename (noescape)
// Status: experimental | Level: high | ID: 51b40fe7-4d37-5d76-a816-c7b089a1e8aa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
