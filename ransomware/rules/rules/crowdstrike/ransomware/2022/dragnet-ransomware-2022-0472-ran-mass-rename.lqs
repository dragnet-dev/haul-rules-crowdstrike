// Dragnet [Ransomware]: dragnet-ransomware-2022-0472 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: b3a18175-33cc-5417-b32f-eb773001b9d0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
