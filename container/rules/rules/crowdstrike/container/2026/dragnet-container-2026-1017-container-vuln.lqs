// Dragnet [Container]: dragnet-container-2026-1017 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: b739edd1-b8e9-5171-90e8-38a8ff58c575

#event_simpleName=*
| (ImageFileName = *amazonlinux:1* OR ImageFileName = *debian:8* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:14.04* OR ImageFileName = *ubuntu:14.04-ESM* OR ImageFileName = *ubuntu:16.04* OR ImageFileName = *ubuntu:16.04-ESM* OR ImageFileName = *ubuntu:16.10*)
| table([timestamp, ComputerName])
| limit(1000)
