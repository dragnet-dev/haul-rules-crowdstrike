// Dragnet [Ransomware]: dragnet-ransomware-2024-0170 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: a4ae08ee-5170-5a1b-b534-b35af4810267

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
