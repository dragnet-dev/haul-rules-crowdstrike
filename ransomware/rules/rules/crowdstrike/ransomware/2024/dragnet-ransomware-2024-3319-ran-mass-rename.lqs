// Dragnet [Ransomware]: dragnet-ransomware-2024-3319 — Mass File Rename (safepay)
// Status: deprecated | Level: high | ID: 1a257ed5-0058-55b3-91dc-cd3f44aac3e8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
