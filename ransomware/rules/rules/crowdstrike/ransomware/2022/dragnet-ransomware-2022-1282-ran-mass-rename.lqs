// Dragnet [Ransomware]: dragnet-ransomware-2022-1282 — Mass File Rename (donutleaks)
// Status: deprecated | Level: high | ID: 43cae6f0-80aa-5ee6-90d7-4e561a205b8f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
