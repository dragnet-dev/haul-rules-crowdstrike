// Dragnet [Ransomware]: dragnet-ransomware-2022-1266 — Mass File Rename (alphv)
// Status: deprecated | Level: high | ID: 24f1fd11-7822-595d-a704-6353ae99c2f3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
