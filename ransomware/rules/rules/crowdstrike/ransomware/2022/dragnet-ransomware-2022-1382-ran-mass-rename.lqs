// Dragnet [Ransomware]: dragnet-ransomware-2022-1382 — Mass File Rename (royal)
// Status: deprecated | Level: high | ID: 683d9bc5-6703-5135-b4ef-de1580b039e3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
