// Dragnet [Ransomware]: dragnet-ransomware-2021-0707 — Mass File Rename (spook)
// Status: deprecated | Level: high | ID: e02e4fa9-e8fa-50a4-ae49-f9ffc4945e01

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
