// Dragnet [Ransomware]: dragnet-ransomware-2024-4629 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 69d85246-b1e5-5d7a-a754-9313f39e1b70

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
