// Dragnet [Ransomware]: dragnet-ransomware-2022-2821 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: c147e6e3-f449-5d0d-8951-9c6b824858b5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
