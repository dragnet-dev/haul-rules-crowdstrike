// Dragnet [Ransomware]: dragnet-ransomware-2023-2909 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: b0d39933-f4a0-5a99-83e7-1c7c4c675f98

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
