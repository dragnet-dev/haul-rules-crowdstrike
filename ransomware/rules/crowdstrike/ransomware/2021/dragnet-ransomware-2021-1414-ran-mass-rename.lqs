// Dragnet [Ransomware]: dragnet-ransomware-2021-1414 — Mass File Rename (babuk)
// Status: deprecated | Level: high | ID: 43d07df7-c8d9-5f24-bf2d-a8f9f75f0663

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
