// Dragnet [Container]: dragnet-container-2026-3145 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: afa58923-6cb0-52c2-ac33-7b4f56b8db5a

#event_simpleName=*
| (ImageFileName = *chainguard:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
