// Dragnet [Ransomware]: dragnet-ransomware-2021-0338 — Mass File Rename (revil)
// Status: deprecated | Level: high | ID: 56543cd9-82fb-52ae-9f27-780475df581e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
