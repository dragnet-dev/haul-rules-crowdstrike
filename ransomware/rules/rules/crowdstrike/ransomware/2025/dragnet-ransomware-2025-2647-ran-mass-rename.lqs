// Dragnet [Ransomware]: dragnet-ransomware-2025-2647 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: a888d705-f283-536e-ac33-bac08e2474bc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
