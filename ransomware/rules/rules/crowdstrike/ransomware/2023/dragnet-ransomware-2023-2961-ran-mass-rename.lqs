// Dragnet [Ransomware]: dragnet-ransomware-2023-2961 — Mass File Rename (monti)
// Status: experimental | Level: high | ID: 3373b2bb-8e5f-54a5-8728-c0901f920baf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
