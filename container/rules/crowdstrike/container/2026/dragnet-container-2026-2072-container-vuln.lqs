// Dragnet [Container]: dragnet-container-2026-2072 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 9a7a9545-6470-566c-b9f8-443cb7143338

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:5*)
| table([timestamp, ComputerName])
| limit(1000)
