// Dragnet [Ransomware]: dragnet-ransomware-2025-3667 — Mass File Rename (sinobi)
// Status: experimental | Level: high | ID: 7cac3de5-2098-535b-a517-6f901e532305

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
