// Dragnet [Container]: dragnet-container-2026-2365 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: ca1a3eca-fb8f-50c9-b292-84d4f2495406

#event_simpleName=*
| (ImageFileName = *chainguard:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
