// Dragnet [Ransomware]: dragnet-ransomware-2022-0264 — Mass File Rename (suncrypt)
// Status: deprecated | Level: high | ID: 40cb8a04-38b3-5ca4-ab69-ec70fe32e53f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
