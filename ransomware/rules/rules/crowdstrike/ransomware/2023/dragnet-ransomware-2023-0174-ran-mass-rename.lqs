// Dragnet [Ransomware]: dragnet-ransomware-2023-0174 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 91e4272c-3b27-5665-8b76-0469f6b9bcd1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
