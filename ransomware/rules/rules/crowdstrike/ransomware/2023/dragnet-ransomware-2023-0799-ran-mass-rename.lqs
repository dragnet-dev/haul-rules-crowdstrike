// Dragnet [Ransomware]: dragnet-ransomware-2023-0799 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 104544c7-937e-50d6-962d-c79a41436d1e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
