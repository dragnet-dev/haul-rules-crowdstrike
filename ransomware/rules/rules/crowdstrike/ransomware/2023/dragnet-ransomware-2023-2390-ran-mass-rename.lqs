// Dragnet [Ransomware]: dragnet-ransomware-2023-2390 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 7f985e00-218b-50ae-a770-f710395e24f0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
