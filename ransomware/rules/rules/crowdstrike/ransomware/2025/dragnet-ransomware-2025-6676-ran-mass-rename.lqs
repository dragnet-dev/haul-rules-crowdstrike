// Dragnet [Ransomware]: dragnet-ransomware-2025-6676 — Mass File Rename (spacebears)
// Status: test | Level: high | ID: 8a92e60e-fc3d-5ad5-8ded-6571f34dee2e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
