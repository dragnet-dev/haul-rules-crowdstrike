// Dragnet [Ransomware]: dragnet-ransomware-2024-3509 — Mass File Rename (flocker)
// Status: experimental | Level: high | ID: 06239671-638b-5391-a111-a6ba4c426c77

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
