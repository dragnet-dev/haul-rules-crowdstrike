// Dragnet [Ransomware]: dragnet-ransomware-2022-1357 — Mass File Rename (alphv)
// Status: deprecated | Level: high | ID: 4bb862fa-2886-5830-b744-8119264c5457

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
