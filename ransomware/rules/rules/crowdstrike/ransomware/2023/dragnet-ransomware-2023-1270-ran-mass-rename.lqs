// Dragnet [Ransomware]: dragnet-ransomware-2023-1270 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: c05d26d4-dbc2-503e-b6c7-3009f526f322

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
