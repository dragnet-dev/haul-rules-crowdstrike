// Dragnet [Ransomware]: dragnet-ransomware-2023-4091 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 40662f48-3b7c-5687-9493-6dad2ac4de02

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
