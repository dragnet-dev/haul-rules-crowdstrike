// Dragnet [Ransomware]: dragnet-ransomware-2023-5126 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: f1f3dc3a-0b02-57ab-b2b0-9f9f9cee28fe

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
