// Dragnet [Ransomware]: dragnet-ransomware-2025-3192 — Mass File Rename (SilentRansomGroup)
// Status: deprecated | Level: high | ID: 57cb1dbb-cf17-5bd2-9feb-c13e195ebda8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
