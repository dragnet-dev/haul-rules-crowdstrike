// Dragnet [Ransomware]: dragnet-ransomware-2025-3067 — Mass File Rename (interlock)
// Status: experimental | Level: high | ID: 1683ff64-db5d-5776-8121-31762f0e36f0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
