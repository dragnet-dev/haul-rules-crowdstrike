// Dragnet [Ransomware]: dragnet-ransomware-2026-0445 — Mass File Rename (shinyhunters)
// Status: deprecated | Level: high | ID: 92368549-5cf9-589b-9ea9-70e17a4d6fea

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
