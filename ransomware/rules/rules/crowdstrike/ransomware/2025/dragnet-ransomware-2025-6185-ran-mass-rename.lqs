// Dragnet [Ransomware]: dragnet-ransomware-2025-6185 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: 72be00f4-485f-5900-bd3a-17f9922229bd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
