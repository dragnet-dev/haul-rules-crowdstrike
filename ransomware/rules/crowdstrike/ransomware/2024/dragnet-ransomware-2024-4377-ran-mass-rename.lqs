// Dragnet [Ransomware]: dragnet-ransomware-2024-4377 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: cc2cf73a-18ac-5fd1-a167-79b089043a98

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
