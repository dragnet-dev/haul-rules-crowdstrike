// Dragnet [Ransomware]: dragnet-ransomware-2024-2337 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: d2e56b5e-e70c-5c44-a4c0-88fa68778f2c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
