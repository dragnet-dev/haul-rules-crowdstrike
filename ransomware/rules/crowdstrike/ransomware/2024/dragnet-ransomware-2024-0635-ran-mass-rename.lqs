// Dragnet [Ransomware]: dragnet-ransomware-2024-0635 — Mass File Rename (apt73)
// Status: experimental | Level: high | ID: d1e5586c-2038-55b2-8a06-58d1b6543939

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
