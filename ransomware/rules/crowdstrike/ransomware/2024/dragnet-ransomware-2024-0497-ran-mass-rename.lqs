// Dragnet [Ransomware]: dragnet-ransomware-2024-0497 — Mass File Rename (meow)
// Status: experimental | Level: high | ID: d53d0523-a3c6-507f-835b-cfdb5b6927e0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
