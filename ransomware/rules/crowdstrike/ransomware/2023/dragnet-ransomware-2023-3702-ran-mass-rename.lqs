// Dragnet [Ransomware]: dragnet-ransomware-2023-3702 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: f959e8ea-85a8-50ea-bd69-945650cba838

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
