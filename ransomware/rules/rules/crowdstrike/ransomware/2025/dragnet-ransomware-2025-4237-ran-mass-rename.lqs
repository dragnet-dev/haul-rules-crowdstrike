// Dragnet [Ransomware]: dragnet-ransomware-2025-4237 — Mass File Rename (VanHelsing)
// Status: experimental | Level: high | ID: 0f35949d-ad8b-5de1-a75d-a98864804fbb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
