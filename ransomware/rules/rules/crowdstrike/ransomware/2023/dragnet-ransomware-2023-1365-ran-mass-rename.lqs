// Dragnet [Ransomware]: dragnet-ransomware-2023-1365 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 4c7c425c-7955-5402-9d1d-9b3121294445

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
