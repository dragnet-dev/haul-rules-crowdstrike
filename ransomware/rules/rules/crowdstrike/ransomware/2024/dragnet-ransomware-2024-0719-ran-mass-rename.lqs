// Dragnet [Ransomware]: dragnet-ransomware-2024-0719 — Mass File Rename (blacklock)
// Status: experimental | Level: high | ID: d7d1841f-07d2-5124-9c41-c23012b62a26

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
