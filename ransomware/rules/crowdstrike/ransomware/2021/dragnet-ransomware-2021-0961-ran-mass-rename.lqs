// Dragnet [Ransomware]: dragnet-ransomware-2021-0961 — Mass File Rename (xinglocker)
// Status: deprecated | Level: high | ID: 7f21df29-a2d2-5b45-8ad5-622073ac0ee6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
