// Dragnet [Ransomware]: dragnet-ransomware-2025-7230 — Mass File Rename (dragonforce)
// Status: test | Level: high | ID: 2ec802ff-906e-5d85-935c-844e7070c5ae

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
