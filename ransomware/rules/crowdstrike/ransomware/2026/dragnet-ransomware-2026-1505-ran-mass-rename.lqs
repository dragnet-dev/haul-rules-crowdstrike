// Dragnet [Ransomware]: dragnet-ransomware-2026-1505 — Mass File Rename (genesis)
// Status: stable | Level: high | ID: a55f01d0-c503-507d-afb3-2264f7de2ca3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
