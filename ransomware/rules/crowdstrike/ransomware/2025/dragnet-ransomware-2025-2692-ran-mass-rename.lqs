// Dragnet [Ransomware]: dragnet-ransomware-2025-2692 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 7289fb26-78ba-578c-96e0-85b444e0b562

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
