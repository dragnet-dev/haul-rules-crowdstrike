// Dragnet [Ransomware]: dragnet-ransomware-2024-3409 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 36e7dd43-673e-56fa-b78e-916f9ac78e3b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
