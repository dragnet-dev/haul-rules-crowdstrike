// Dragnet [Ransomware]: dragnet-ransomware-2023-2376 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 9fa9b9e1-aa02-5c3e-b3eb-b27611be3843

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
