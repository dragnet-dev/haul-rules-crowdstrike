// Dragnet [Ransomware]: dragnet-ransomware-2022-2185 — Mass File Rename (snatch)
// Status: deprecated | Level: high | ID: 22bd0f84-d4fd-5bcb-8b25-469f4c027502

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
