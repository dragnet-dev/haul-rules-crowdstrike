// Dragnet [Ransomware]: dragnet-ransomware-2025-0130 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 8b070f46-662f-5ec6-b433-7cb062bcfb20

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
