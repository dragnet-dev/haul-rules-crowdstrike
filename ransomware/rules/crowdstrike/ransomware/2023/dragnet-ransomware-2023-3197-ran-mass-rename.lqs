// Dragnet [Ransomware]: dragnet-ransomware-2023-3197 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 69e5a453-cb1c-583f-9225-f76753c607e3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
