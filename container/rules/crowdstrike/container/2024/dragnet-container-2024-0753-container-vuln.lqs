// Dragnet [Container]: dragnet-container-2024-0753 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: be824415-a3ae-5726-8d8b-2cbe3e31bdbe

#event_simpleName=*
| (ImageFileName = *amazonlinux:2* OR ImageFileName = *debian:7* OR ImageFileName = *debian:8* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *oraclelinux:7* OR ImageFileName = *ubuntu:14.04* OR ImageFileName = *ubuntu:14.04-ESM* OR ImageFileName = *ubuntu:16.04* OR ImageFileName = *ubuntu:16.04-ESM* OR ImageFileName = *ubuntu:17.10*)
| table([timestamp, ComputerName])
| limit(1000)
