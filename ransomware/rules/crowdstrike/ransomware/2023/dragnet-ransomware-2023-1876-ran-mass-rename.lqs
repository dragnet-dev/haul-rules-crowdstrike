// Dragnet [Ransomware]: dragnet-ransomware-2023-1876 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 42a09559-4f4f-58ec-91d3-bc68cb13e492

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
