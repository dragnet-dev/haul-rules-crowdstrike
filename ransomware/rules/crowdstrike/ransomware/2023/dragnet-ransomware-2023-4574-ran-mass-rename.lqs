// Dragnet [Ransomware]: dragnet-ransomware-2023-4574 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 426b918b-1dc2-52ee-a970-7146ed0642cf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
