// Dragnet [Ransomware]: dragnet-ransomware-2023-4359 — Mass File Rename (abyss)
// Status: deprecated | Level: high | ID: b0e623f3-0fe6-5e98-a575-b08dabd6b169

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
