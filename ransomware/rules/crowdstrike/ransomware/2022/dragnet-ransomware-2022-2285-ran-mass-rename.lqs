// Dragnet [Ransomware]: dragnet-ransomware-2022-2285 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: caea8721-46df-597e-8aa7-f2bd9cd0bc9c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
