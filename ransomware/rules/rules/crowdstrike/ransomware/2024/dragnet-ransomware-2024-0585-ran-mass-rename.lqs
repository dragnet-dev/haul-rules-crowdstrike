// Dragnet [Ransomware]: dragnet-ransomware-2024-0585 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 9e96c6cc-c95d-5e1a-aa8f-c78730e2e7e2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
