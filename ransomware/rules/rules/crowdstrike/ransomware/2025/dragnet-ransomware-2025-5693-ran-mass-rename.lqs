// Dragnet [Ransomware]: dragnet-ransomware-2025-5693 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 227eb280-c87c-5e94-b93a-12e9fd52d54d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
