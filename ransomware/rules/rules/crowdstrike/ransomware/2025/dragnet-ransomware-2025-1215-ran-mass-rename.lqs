// Dragnet [Ransomware]: dragnet-ransomware-2025-1215 — Mass File Rename (yurei)
// Status: experimental | Level: high | ID: 94c60dff-5a18-5039-aa1b-ea9a26f8018a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
