// Dragnet [Ransomware]: dragnet-ransomware-2023-0379 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: e5993bea-9eb5-5792-9782-ff6f81f9ee0f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
