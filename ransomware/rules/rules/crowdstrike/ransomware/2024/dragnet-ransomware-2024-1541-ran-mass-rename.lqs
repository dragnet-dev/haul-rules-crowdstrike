// Dragnet [Ransomware]: dragnet-ransomware-2024-1541 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 78dc891a-934d-5403-b3f1-dba09cafbc99

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
