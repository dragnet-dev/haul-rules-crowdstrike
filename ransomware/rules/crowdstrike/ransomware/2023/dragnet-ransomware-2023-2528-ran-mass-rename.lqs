// Dragnet [Ransomware]: dragnet-ransomware-2023-2528 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 4a67f58a-f203-5b58-a417-eaca304c4ef4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
