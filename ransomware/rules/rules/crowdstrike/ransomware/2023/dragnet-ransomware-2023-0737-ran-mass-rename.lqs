// Dragnet [Ransomware]: dragnet-ransomware-2023-0737 — Mass File Rename (play)
// Status: experimental | Level: high | ID: f12cbd65-47d5-590c-9fab-d5cb2777e055

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
