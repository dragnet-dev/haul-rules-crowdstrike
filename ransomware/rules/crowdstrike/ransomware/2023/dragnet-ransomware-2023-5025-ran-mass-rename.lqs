// Dragnet [Ransomware]: dragnet-ransomware-2023-5025 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: ad965528-dc9f-590a-be05-aa6abc80558b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
