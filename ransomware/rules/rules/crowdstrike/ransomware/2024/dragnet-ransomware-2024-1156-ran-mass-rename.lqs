// Dragnet [Ransomware]: dragnet-ransomware-2024-1156 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: eb3bd3fa-f762-5d98-b901-be44d05cc4a4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
