// Dragnet [Ransomware]: dragnet-ransomware-2024-1737 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: a928f095-ff3f-535d-8bb8-de184e81e8b1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
