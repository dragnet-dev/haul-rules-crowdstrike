// Dragnet [Ransomware]: dragnet-ransomware-2024-4948 — Mass File Rename (apt73)
// Status: experimental | Level: high | ID: 97723d09-7b56-5582-aa21-76e7aed005ab

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
