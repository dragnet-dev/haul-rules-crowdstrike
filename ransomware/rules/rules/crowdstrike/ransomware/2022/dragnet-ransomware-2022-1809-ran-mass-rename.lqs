// Dragnet [Ransomware]: dragnet-ransomware-2022-1809 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 17076ac3-363a-526f-b083-4e67487b7e9f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
