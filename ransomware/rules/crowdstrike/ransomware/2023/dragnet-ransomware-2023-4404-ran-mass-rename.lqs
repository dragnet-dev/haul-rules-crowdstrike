// Dragnet [Ransomware]: dragnet-ransomware-2023-4404 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 2888f9b2-8102-5fa9-83f7-353556c543fc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
