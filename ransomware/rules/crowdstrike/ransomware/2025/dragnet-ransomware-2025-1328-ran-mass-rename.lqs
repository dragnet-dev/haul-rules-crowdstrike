// Dragnet [Ransomware]: dragnet-ransomware-2025-1328 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: f7542954-4db8-56d7-9dcd-a7f891ecc310

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
