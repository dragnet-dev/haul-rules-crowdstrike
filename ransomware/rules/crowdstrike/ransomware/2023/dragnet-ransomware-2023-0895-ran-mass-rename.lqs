// Dragnet [Ransomware]: dragnet-ransomware-2023-0895 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: a22d4933-5efe-552d-aa87-04e240cf5bfe

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
