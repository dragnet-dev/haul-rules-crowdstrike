// Dragnet [Ransomware]: dragnet-ransomware-2025-1263 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: ce0f1025-b91a-5ad5-9c9d-d0c5eb8c80bc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
