// Dragnet [Ransomware]: dragnet-ransomware-2022-2863 — Mass File Rename (karakurt)
// Status: deprecated | Level: high | ID: b89534dc-2cb9-55d7-9d1f-82eda76e962a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
