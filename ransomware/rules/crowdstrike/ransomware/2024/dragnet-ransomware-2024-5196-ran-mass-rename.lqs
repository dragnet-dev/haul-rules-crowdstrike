// Dragnet [Ransomware]: dragnet-ransomware-2024-5196 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: a7f20943-23bb-560d-9972-9e2c1a60ec03

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
