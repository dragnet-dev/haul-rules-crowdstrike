// Dragnet [Ransomware]: dragnet-ransomware-2025-5653 — Mass File Rename (SilentRansomGroup)
// Status: deprecated | Level: high | ID: 5cea46f5-92dc-5f89-a6ef-c5e997b268a7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
