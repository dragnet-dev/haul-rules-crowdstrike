// Dragnet [Ransomware]: dragnet-ransomware-2025-6589 — Mass File Rename (spacebears)
// Status: experimental | Level: high | ID: 3bd3dd7b-074a-586c-8737-220d873d550a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
