// Dragnet [Ransomware]: dragnet-ransomware-2025-3043 — Mass File Rename (cloak)
// Status: deprecated | Level: high | ID: 12dbc3b6-3002-5dda-b11b-2c6e53111c76

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
