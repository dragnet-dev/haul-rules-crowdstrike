// Dragnet [Ransomware]: dragnet-ransomware-2024-2512 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: a067d35c-61d6-5913-8155-2f41970ab6b5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
