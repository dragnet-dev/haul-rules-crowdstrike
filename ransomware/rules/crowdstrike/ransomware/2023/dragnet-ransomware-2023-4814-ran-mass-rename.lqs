// Dragnet [Ransomware]: dragnet-ransomware-2023-4814 — Mass File Rename (stormous)
// Status: experimental | Level: high | ID: 68b98142-a8b9-5ac5-9ad6-9522f08a1931

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
