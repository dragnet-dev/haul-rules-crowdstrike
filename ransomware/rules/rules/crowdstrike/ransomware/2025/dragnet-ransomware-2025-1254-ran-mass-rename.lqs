// Dragnet [Ransomware]: dragnet-ransomware-2025-1254 — Mass File Rename (lockbit5)
// Status: experimental | Level: high | ID: 67c07a70-7a46-54e3-b8a8-9dfa825634a8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
