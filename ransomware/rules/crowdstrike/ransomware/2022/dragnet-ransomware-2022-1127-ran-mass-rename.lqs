// Dragnet [Ransomware]: dragnet-ransomware-2022-1127 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 983b55eb-34c5-52de-8073-697c8e9bd201

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
