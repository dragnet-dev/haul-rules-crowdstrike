// Dragnet [Ransomware]: dragnet-ransomware-2022-1661 — Mass File Rename (royal)
// Status: deprecated | Level: high | ID: bcf007bb-a7e5-58c9-bbde-bfa469bd6e97

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
