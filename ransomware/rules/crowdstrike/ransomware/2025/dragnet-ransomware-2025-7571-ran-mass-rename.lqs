// Dragnet [Ransomware]: dragnet-ransomware-2025-7571 — Mass File Rename (nova)
// Status: experimental | Level: high | ID: 859224e3-6a2b-5076-b1a2-1563b4641b81

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
