// Dragnet [Ransomware]: dragnet-ransomware-2022-0666 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: b9cc15f3-901e-529c-af23-89e20be71056

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
