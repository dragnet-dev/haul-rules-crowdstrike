// Dragnet [Ransomware]: dragnet-ransomware-2023-2728 — Mass File Rename (mallox)
// Status: experimental | Level: high | ID: 7e8b512a-7d8e-5946-8cbf-87ca7eed7cdb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
