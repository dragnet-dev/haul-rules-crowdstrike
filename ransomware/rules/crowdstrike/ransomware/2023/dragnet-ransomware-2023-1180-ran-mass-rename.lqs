// Dragnet [Ransomware]: dragnet-ransomware-2023-1180 — Mass File Rename (nokoyawa)
// Status: experimental | Level: high | ID: 3eb4e38c-28d9-58f6-b9b0-f533b86642e8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
