// Dragnet [Ransomware]: dragnet-ransomware-2023-0244 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: a9889d15-87f1-556a-90c9-0d3c0c386c8e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
