// Dragnet [Ransomware]: dragnet-ransomware-2025-0539 — Mass File Rename (obscura)
// Status: experimental | Level: high | ID: 4d457d76-41f5-5959-905c-a1afcbef773e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
