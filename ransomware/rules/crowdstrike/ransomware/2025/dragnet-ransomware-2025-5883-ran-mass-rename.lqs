// Dragnet [Ransomware]: dragnet-ransomware-2025-5883 — Mass File Rename (warlock)
// Status: deprecated | Level: high | ID: acd560f9-3ee4-58e5-bec4-e5e79bbcda9b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
