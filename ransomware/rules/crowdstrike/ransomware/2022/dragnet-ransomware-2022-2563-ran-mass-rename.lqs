// Dragnet [Ransomware]: dragnet-ransomware-2022-2563 — Mass File Rename (lv)
// Status: deprecated | Level: high | ID: fcb79bde-8d63-56dc-afe6-a56d561baddf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
