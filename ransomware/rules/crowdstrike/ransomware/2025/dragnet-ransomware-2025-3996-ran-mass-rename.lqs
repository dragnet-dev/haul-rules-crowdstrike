// Dragnet [Ransomware]: dragnet-ransomware-2025-3996 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 4d128d17-1f6b-54f4-b759-0d2315ef0ba1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
