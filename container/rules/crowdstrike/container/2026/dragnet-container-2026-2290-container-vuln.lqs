// Dragnet [Container]: dragnet-container-2026-2290 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: a9c2636e-8da5-52a8-919d-b06910010dbd

#event_simpleName=*
| (ImageFileName = *amazonlinux:1* OR ImageFileName = *chainguard:* OR ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:12.04*)
| table([timestamp, ComputerName])
| limit(1000)
