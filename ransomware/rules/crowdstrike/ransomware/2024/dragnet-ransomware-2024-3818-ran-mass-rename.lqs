// Dragnet [Ransomware]: dragnet-ransomware-2024-3818 — Mass File Rename (frag)
// Status: deprecated | Level: high | ID: c3a1f910-6b1d-50a1-8104-6a695cc223b0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
