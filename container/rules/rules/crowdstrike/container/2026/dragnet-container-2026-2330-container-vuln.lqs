// Dragnet [Container]: dragnet-container-2026-2330 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 15c45920-29c2-55ce-8f9d-4bf7c9289d03

#event_simpleName=*
| (ImageFileName = *chainguard:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
