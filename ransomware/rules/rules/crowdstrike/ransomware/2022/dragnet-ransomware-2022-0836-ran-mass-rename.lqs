// Dragnet [Ransomware]: dragnet-ransomware-2022-0836 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 876c236b-6cf0-5c13-a6f4-dc0010533c8c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
