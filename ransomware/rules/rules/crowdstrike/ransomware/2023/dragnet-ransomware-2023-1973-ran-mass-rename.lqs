// Dragnet [Ransomware]: dragnet-ransomware-2023-1973 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 79f179c9-146b-59ac-a1d3-6c4dca337df0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
