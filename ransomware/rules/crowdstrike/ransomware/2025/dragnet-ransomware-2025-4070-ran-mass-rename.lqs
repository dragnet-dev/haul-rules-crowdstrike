// Dragnet [Ransomware]: dragnet-ransomware-2025-4070 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: f325509d-ad9c-5cad-ae81-229fd8577482

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
