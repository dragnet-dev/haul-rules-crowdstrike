// Dragnet [Ransomware]: dragnet-ransomware-2023-0412 — Mass File Rename (rhysida)
// Status: experimental | Level: high | ID: ff912f0f-ee64-55e7-a323-a22b6ba947d7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
