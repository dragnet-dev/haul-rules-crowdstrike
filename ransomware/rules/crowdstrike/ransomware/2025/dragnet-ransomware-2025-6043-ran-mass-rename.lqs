// Dragnet [Ransomware]: dragnet-ransomware-2025-6043 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: bc4a844c-6c07-5e20-b048-ea629e59a30f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
