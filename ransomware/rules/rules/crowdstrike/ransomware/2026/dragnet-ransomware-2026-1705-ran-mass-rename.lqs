// Dragnet [Ransomware]: dragnet-ransomware-2026-1705 — Mass File Rename (lockbit5)
// Status: stable | Level: high | ID: d99adecb-2e62-5015-b665-3f0712483d72

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
