// Dragnet [Container]: dragnet-container-2025-0492 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 41005efe-db87-548a-892c-842a52109c05

#event_simpleName=*
| (ImageFileName = *almalinux:9* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:9*)
| table([timestamp, ComputerName])
| limit(1000)
