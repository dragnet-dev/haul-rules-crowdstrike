// Dragnet [Ransomware]: dragnet-ransomware-2023-1298 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 3f9df313-b849-5f33-9348-abb4167fc2d3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
