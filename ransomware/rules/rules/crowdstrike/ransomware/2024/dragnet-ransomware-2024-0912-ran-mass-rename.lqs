// Dragnet [Ransomware]: dragnet-ransomware-2024-0912 — Mass File Rename (termite)
// Status: experimental | Level: high | ID: db79c9f7-7e8c-5031-86fe-0e2062084fc8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
