// Dragnet [Ransomware]: dragnet-ransomware-2026-0712 — Mass File Rename (fulcrumsec)
// Status: stable | Level: high | ID: 8021beba-9149-55c1-bd77-e5778e374944

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
