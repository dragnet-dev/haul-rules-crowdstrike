// Dragnet [Ransomware]: dragnet-ransomware-2021-0176 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 54df1126-4b25-5936-b4e0-4369051d114a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
