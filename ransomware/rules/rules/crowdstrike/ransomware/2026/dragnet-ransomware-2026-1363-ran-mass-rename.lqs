// Dragnet [Ransomware]: dragnet-ransomware-2026-1363 — Mass File Rename (anubis)
// Status: stable | Level: high | ID: 8cbd25c2-42af-50ee-9802-eb38aa3afc74

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
