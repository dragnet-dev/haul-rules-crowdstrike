// Dragnet [Ransomware]: dragnet-ransomware-2022-2300 — Mass File Rename (avoslocker)
// Status: deprecated | Level: high | ID: 914879c3-e15f-5c2b-ba79-5dc486f7941c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
