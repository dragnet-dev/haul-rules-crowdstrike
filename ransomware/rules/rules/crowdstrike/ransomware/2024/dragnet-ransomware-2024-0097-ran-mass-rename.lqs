// Dragnet [Ransomware]: dragnet-ransomware-2024-0097 — Mass File Rename (rhysida)
// Status: deprecated | Level: high | ID: 16fd616d-3889-5c74-886a-4531818327d6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
