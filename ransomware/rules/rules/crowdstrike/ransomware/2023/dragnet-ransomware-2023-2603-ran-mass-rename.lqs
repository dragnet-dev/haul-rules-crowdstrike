// Dragnet [Ransomware]: dragnet-ransomware-2023-2603 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 70920919-9884-516f-8521-ed5100d12b3c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
