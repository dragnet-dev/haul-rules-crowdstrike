// Dragnet [Ransomware]: dragnet-ransomware-2022-2418 — Mass File Rename (blackbasta)
// Status: deprecated | Level: high | ID: 877f4c02-a08b-56d2-acbc-e4cfd36e2fb0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
