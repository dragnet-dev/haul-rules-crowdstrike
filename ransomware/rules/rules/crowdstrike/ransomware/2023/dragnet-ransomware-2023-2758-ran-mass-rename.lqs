// Dragnet [Ransomware]: dragnet-ransomware-2023-2758 — Mass File Rename (malas)
// Status: experimental | Level: high | ID: 9375f527-7bdc-5a79-9e87-de680bc46de9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
