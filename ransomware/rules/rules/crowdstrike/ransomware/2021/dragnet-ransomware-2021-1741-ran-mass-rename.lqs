// Dragnet [Ransomware]: dragnet-ransomware-2021-1741 — Mass File Rename (avaddon)
// Status: deprecated | Level: high | ID: f83b4a21-1d69-5056-a92c-d615d2f6682f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
