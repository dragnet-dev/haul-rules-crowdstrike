// Dragnet [Ransomware]: dragnet-ransomware-2021-1763 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: cb847aa6-df03-557a-bed5-754af10705b4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
