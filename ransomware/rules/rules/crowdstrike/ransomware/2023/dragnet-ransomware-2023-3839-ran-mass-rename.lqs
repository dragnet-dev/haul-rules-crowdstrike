// Dragnet [Ransomware]: dragnet-ransomware-2023-3839 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: ea794c45-0235-5f1d-b4ad-dcff8257dd08

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
