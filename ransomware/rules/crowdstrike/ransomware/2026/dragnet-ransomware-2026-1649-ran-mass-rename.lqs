// Dragnet [Ransomware]: dragnet-ransomware-2026-1649 — Mass File Rename (dragonforce)
// Status: stable | Level: high | ID: c1e04609-f768-5ee5-85d0-4c742ab5678b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
