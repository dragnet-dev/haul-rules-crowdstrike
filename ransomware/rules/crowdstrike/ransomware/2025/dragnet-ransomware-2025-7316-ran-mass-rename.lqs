// Dragnet [Ransomware]: dragnet-ransomware-2025-7316 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 310a1337-065d-5e44-8abc-2a1566945ca9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
