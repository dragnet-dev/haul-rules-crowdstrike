// Dragnet [Ransomware]: dragnet-ransomware-2022-0735 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 8adabc11-b58b-5875-906b-01a86af1665f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
