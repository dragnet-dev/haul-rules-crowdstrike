// Dragnet [Ransomware]: dragnet-ransomware-2025-7169 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 56142126-2010-5786-ac9b-c0a4e12b3e45

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
