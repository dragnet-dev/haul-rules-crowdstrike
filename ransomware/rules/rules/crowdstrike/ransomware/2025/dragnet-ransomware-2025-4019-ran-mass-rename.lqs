// Dragnet [Ransomware]: dragnet-ransomware-2025-4019 — Mass File Rename (SilentRansomGroup)
// Status: deprecated | Level: high | ID: 48c66472-0557-57a2-b7b2-accbcf9799bb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
