// Dragnet [Ransomware]: dragnet-ransomware-2024-2009 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 5c42260d-602a-5473-9400-14a25bf72e7e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
