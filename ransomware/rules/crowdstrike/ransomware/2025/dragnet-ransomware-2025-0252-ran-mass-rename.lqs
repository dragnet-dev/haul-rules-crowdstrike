// Dragnet [Ransomware]: dragnet-ransomware-2025-0252 — Mass File Rename (nightspire)
// Status: deprecated | Level: high | ID: 2e236521-7435-5d91-b3dc-7a9908db36cb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
