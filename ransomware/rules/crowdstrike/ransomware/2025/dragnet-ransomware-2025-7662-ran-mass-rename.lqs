// Dragnet [Ransomware]: dragnet-ransomware-2025-7662 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: a4234f1c-7402-5f67-b4d3-99e7ff2b02a2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
