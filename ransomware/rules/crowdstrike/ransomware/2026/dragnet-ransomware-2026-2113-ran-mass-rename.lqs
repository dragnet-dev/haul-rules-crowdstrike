// Dragnet [Ransomware]: dragnet-ransomware-2026-2113 — Mass File Rename (SilentRansomGroup)
// Status: deprecated | Level: high | ID: 1860afd5-fdba-5184-9934-2c909de91b6f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
