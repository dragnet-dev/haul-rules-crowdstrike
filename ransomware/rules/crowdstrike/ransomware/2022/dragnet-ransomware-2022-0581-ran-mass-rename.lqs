// Dragnet [Ransomware]: dragnet-ransomware-2022-0581 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: a8e75ac1-a42c-55f0-8a50-ef07be0d52f8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
