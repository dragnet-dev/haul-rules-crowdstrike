// Dragnet [Ransomware]: dragnet-ransomware-2023-0336 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 5bd0ce3c-c169-5469-842e-b72007e3e701

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
