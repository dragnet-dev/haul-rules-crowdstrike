// Dragnet [Ransomware]: dragnet-ransomware-2026-2242 — Mass File Rename (BrainCipher)
// Status: stable | Level: high | ID: e071ed5f-546b-5516-9aa9-fbc8543f6286

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
