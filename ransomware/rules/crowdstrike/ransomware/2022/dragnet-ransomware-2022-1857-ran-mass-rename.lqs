// Dragnet [Ransomware]: dragnet-ransomware-2022-1857 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 34a6a294-eb30-5b37-a238-3c17d78ad5fe

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
