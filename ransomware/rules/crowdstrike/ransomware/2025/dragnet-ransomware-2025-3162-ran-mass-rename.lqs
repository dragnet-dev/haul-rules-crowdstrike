// Dragnet [Ransomware]: dragnet-ransomware-2025-3162 — Mass File Rename (spacebears)
// Status: experimental | Level: high | ID: a3b22a4a-c26d-55c3-baa2-52103790bace

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
