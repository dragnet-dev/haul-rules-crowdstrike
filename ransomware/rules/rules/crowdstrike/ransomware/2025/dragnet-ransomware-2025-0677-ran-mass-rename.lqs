// Dragnet [Ransomware]: dragnet-ransomware-2025-0677 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: e156711c-4cf5-5570-b6a1-6c763555221f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
