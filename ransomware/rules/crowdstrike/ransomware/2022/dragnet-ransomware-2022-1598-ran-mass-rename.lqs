// Dragnet [Ransomware]: dragnet-ransomware-2022-1598 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: fefbf7a1-9f2b-5007-8a16-9d96c8510681

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
