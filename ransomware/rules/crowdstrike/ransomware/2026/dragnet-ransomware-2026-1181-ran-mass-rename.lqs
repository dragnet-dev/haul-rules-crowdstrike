// Dragnet [Ransomware]: dragnet-ransomware-2026-1181 — Mass File Rename (safepay)
// Status: stable | Level: high | ID: 6e55b8ce-55b8-5c3a-86e8-f09dbef7814b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
