// Dragnet [Ransomware]: dragnet-ransomware-2025-1238 — Mass File Rename (payoutsking)
// Status: experimental | Level: high | ID: e4ed0ce4-efa0-5a5e-96ed-12f41458fda1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
