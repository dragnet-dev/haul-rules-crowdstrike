// Dragnet [Ransomware]: dragnet-ransomware-2025-2461 — Mass File Rename (thegentlemen)
// Status: experimental | Level: high | ID: e4c20574-8fc5-51b1-a4c0-95fa803ed21c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
