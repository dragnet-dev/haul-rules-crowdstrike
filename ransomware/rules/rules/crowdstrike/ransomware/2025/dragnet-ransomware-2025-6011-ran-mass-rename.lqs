// Dragnet [Ransomware]: dragnet-ransomware-2025-6011 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 7d90ff01-5fb9-56e7-9bbf-2e7224f7982a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
