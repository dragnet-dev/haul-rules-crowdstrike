// Dragnet [Ransomware]: dragnet-ransomware-2025-1026 — Mass File Rename (ransomhouse)
// Status: experimental | Level: high | ID: c97ec605-e697-5d36-9b0b-7e4d2b272319

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
