// Dragnet [Ransomware]: dragnet-ransomware-2026-1140 — Mass File Rename (thegentlemen)
// Status: stable | Level: high | ID: 56587ca6-45f3-5b46-a355-cffcdf389cf7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
