// Dragnet [Ransomware]: dragnet-ransomware-2025-7282 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 1dcaf971-c9bd-5452-a675-70c8ebca2536

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
