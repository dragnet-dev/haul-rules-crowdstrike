// Dragnet [Ransomware]: dragnet-ransomware-2025-1969 — Mass File Rename (direwolf)
// Status: experimental | Level: high | ID: 12b725fa-8465-5f42-bdd8-8fc626a80f74

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
