// Dragnet [Container]: dragnet-container-2026-2212 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: f026217e-5e21-5aa0-b256-44aa5e0592a1

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
