// Dragnet [Ransomware]: dragnet-ransomware-2021-1597 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 8dcbce38-2d0a-533c-8789-38aed06df0eb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
