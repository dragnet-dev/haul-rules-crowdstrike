// Dragnet [Ransomware]: dragnet-ransomware-2023-3842 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 1a562052-7d5b-5939-aceb-048dee6b2c7a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
