// Dragnet [Ransomware]: dragnet-ransomware-2024-0704 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 808fde23-4657-5c21-bd6b-a31f4caa3e5d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
