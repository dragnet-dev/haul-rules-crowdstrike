// Dragnet [Container]: dragnet-container-2026-0315 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: e583cf69-5f61-52e5-8188-cdb8edf375e2

#event_simpleName=*
| (ImageFileName = *amazonlinux:1* OR ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10*)
| table([timestamp, ComputerName])
| limit(1000)
