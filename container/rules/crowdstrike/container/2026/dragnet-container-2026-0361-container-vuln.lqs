// Dragnet [Container]: dragnet-container-2026-0361 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 0938e86c-bfe1-579b-89db-e2dbc04aa270

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:7*)
| table([timestamp, ComputerName])
| limit(1000)
