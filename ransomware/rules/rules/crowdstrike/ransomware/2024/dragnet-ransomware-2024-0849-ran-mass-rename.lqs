// Dragnet [Ransomware]: dragnet-ransomware-2024-0849 — Mass File Rename (play)
// Status: experimental | Level: high | ID: aa09ace4-3806-5cf5-bb80-bef7962b8b61

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
