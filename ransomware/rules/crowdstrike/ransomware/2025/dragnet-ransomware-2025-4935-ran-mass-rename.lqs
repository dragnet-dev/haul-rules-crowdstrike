// Dragnet [Ransomware]: dragnet-ransomware-2025-4935 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 31439287-dfb1-5556-a4e1-97b912fa6882

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
