// Dragnet [Ransomware]: dragnet-ransomware-2022-1344 — Mass File Rename (ransomhouse)
// Status: deprecated | Level: high | ID: d03d0bb3-50eb-505c-9a65-50f1e3c27bcc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
