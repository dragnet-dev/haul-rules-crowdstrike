// Dragnet [Container]: dragnet-container-2024-1201 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 5bff6859-80c5-5fbe-b9e2-173e22ab2512

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *photon os:2.0* OR ImageFileName = *photon os:3.0* OR ImageFileName = *photon os:5.0*)
| table([timestamp, ComputerName])
| limit(1000)
