// Dragnet [Ransomware]: dragnet-ransomware-2021-1734 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 75de1f0a-5049-506d-83a2-551f3c05b944

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
