// Dragnet [Ransomware]: dragnet-ransomware-2021-0173 — Mass File Rename (karma)
// Status: deprecated | Level: high | ID: 640afd68-3d64-52b3-b1b6-1a022047b03f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
