// Dragnet [Ransomware]: dragnet-ransomware-2024-5286 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 3ad36499-7896-5875-8609-ea6d18815c13

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
