// Dragnet [Ransomware]: dragnet-ransomware-2024-0705 — Mass File Rename (meow)
// Status: experimental | Level: high | ID: f0a48b22-d299-5ccb-9d5b-6467bc557a54

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
