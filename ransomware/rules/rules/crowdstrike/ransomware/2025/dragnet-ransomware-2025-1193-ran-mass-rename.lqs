// Dragnet [Ransomware]: dragnet-ransomware-2025-1193 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 6513b967-9f79-5128-952d-e472bebb76cd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
