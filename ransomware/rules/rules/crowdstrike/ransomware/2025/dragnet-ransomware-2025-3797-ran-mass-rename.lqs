// Dragnet [Ransomware]: dragnet-ransomware-2025-3797 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 3ebf1ec0-8ed5-5f08-aeba-eb2d03367d7c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
