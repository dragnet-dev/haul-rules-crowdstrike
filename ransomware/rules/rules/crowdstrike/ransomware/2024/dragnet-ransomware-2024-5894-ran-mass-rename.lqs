// Dragnet [Ransomware]: dragnet-ransomware-2024-5894 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 937e8e93-42e0-5265-a07f-572216a11dd5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
