// Dragnet [Container]: dragnet-container-2026-1006 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 75e7b435-beef-5b97-ba78-da8a4eb00fc2

#event_simpleName=*
| (ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10*)
| table([timestamp, ComputerName])
| limit(1000)
