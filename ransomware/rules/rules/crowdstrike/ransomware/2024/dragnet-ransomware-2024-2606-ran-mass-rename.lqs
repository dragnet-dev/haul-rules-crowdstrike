// Dragnet [Ransomware]: dragnet-ransomware-2024-2606 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: d688f8f3-b6fc-54c3-a843-c0dea5e7263d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
