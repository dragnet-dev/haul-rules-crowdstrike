// Dragnet [Ransomware]: dragnet-ransomware-2024-4983 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 918ed20b-e0ad-5c8b-b7b2-47582df2df04

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
