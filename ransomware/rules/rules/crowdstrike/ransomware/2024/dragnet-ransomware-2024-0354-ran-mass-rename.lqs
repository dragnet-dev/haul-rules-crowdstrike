// Dragnet [Ransomware]: dragnet-ransomware-2024-0354 — Mass File Rename (spacebears)
// Status: experimental | Level: high | ID: 754dd7a8-d2fa-562b-8a75-6c7a2ba48416

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
