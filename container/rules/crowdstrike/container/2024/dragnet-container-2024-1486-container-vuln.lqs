// Dragnet [Container]: dragnet-container-2024-1486 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 5938da76-d7fa-5ea4-81c6-7d6aa2f18598

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:7* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:14.04* OR ImageFileName = *ubuntu:14.04-ESM* OR ImageFileName = *ubuntu:14.10*)
| table([timestamp, ComputerName])
| limit(1000)
