// Dragnet [Ransomware]: dragnet-ransomware-2024-1682 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: f7e35c80-9b19-50f0-8eb5-a3fff7a9283b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
