// Dragnet [Ransomware]: dragnet-ransomware-2024-3167 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: d749821c-787d-5e70-b43e-579da1ef3d68

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
