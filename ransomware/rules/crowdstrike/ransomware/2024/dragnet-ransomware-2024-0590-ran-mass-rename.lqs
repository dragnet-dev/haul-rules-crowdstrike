// Dragnet [Ransomware]: dragnet-ransomware-2024-0590 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 7a7111f1-7a7f-5f0e-b317-3ef7f00e4cd9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
