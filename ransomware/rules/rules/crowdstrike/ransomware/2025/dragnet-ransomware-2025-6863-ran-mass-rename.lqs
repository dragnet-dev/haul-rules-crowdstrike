// Dragnet [Ransomware]: dragnet-ransomware-2025-6863 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 598c27d0-1b4c-57d7-83fb-811d6a4206d8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
