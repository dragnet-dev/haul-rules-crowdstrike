// Dragnet [Ransomware]: dragnet-ransomware-2023-0727 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 60f0a6e8-f1f5-5a5f-bf08-09b186e89834

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
