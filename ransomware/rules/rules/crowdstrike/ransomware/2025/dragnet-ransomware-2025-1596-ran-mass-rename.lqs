// Dragnet [Ransomware]: dragnet-ransomware-2025-1596 — Mass File Rename (payoutsking)
// Status: experimental | Level: high | ID: 076b45b5-f26b-5a18-8989-0763a418bfe3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
