// Dragnet [Ransomware]: dragnet-ransomware-2023-2051 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: e4fa97b7-4e4f-5b36-9899-de47c155fcd2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
