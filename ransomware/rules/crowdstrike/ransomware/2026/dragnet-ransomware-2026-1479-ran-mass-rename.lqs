// Dragnet [Ransomware]: dragnet-ransomware-2026-1479 — Mass File Rename (coinbasecartel)
// Status: stable | Level: high | ID: f488fa84-5c70-5bb2-82e1-1db97cf3b6d0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
