// Dragnet [Ransomware]: dragnet-ransomware-2021-0396 — Mass File Rename (avaddon)
// Status: deprecated | Level: high | ID: 98e48c9f-dec0-52ca-a8ad-d4e82d6e69e5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
