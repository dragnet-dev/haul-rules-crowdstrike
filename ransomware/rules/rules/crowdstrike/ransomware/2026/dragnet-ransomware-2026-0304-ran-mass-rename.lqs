// Dragnet [Ransomware]: dragnet-ransomware-2026-0304 — Mass File Rename (incransom)
// Status: stable | Level: high | ID: 9300749b-5d8a-58c3-85cb-ff1a905a3b0c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
