// Dragnet [Ransomware]: dragnet-ransomware-2023-2984 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: ff939b85-6034-572e-b5f7-11342eb362ac

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
