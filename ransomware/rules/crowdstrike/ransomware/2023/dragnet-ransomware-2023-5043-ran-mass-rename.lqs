// Dragnet [Ransomware]: dragnet-ransomware-2023-5043 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: f7098a49-7c18-538b-843f-121e627b73ff

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
