// Dragnet [Ransomware]: dragnet-ransomware-2022-0284 — Mass File Rename (ransomhouse)
// Status: deprecated | Level: high | ID: dff0e20d-6b58-5848-b5a7-7bda82ab3ba0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
