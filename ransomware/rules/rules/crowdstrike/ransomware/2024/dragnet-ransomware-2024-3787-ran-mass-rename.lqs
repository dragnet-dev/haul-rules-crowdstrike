// Dragnet [Ransomware]: dragnet-ransomware-2024-3787 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 7a9c1402-abf9-5def-98fd-b864fed0ee67

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
