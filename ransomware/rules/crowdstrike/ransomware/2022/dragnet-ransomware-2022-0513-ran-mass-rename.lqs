// Dragnet [Ransomware]: dragnet-ransomware-2022-0513 — Mass File Rename (cheers)
// Status: deprecated | Level: high | ID: a5675300-f30b-563d-8995-46d138ed1a37

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
