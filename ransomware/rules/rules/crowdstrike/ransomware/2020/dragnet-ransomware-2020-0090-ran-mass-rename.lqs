// Dragnet [Ransomware]: dragnet-ransomware-2020-0090 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 1cb6f1c9-b938-54d6-ad86-59fe0a694e1d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
