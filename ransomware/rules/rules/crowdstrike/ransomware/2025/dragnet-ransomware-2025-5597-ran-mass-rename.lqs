// Dragnet [Ransomware]: dragnet-ransomware-2025-5597 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 4f4d88b0-f885-5579-97c3-dcead9a92d39

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
