// Dragnet [Ransomware]: dragnet-ransomware-2025-1477 — Mass File Rename (chaos)
// Status: experimental | Level: high | ID: 8dce3306-1020-57ea-9424-e0f0d774e1c7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
