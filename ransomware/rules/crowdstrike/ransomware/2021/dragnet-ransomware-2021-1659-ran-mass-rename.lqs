// Dragnet [Ransomware]: dragnet-ransomware-2021-1659 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: a1a38f52-8b82-535a-80b0-e6f0dc184433

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
