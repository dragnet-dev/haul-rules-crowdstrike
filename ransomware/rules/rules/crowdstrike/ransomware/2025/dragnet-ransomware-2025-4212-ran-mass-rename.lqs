// Dragnet [Ransomware]: dragnet-ransomware-2025-4212 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 0f617b0b-2db5-5a24-9870-648a8c39fbaa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
