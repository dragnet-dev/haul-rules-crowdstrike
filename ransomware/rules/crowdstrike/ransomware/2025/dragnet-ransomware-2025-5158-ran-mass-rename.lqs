// Dragnet [Ransomware]: dragnet-ransomware-2025-5158 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 0edb88c3-8db4-5b40-9a2d-f403d87f7085

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
