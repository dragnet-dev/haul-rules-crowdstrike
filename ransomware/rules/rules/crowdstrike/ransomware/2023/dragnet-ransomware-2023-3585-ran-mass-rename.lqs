// Dragnet [Ransomware]: dragnet-ransomware-2023-3585 — Mass File Rename (play)
// Status: experimental | Level: high | ID: c58b6ca4-931a-5126-ad4e-503fa84f74bd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
