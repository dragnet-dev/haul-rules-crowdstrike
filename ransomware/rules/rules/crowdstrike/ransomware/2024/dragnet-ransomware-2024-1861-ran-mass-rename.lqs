// Dragnet [Ransomware]: dragnet-ransomware-2024-1861 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 3da41fd9-9f30-51b2-b37e-ce00a896a58d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
