// Dragnet [Ransomware]: dragnet-ransomware-2024-6023 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: fa645576-a6fc-5395-b8e0-f8f7affc81cd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
