// Dragnet [Ransomware]: dragnet-ransomware-2021-0185 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 213dd2ff-49b2-5e2d-8c81-013f6759f03e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
