// Dragnet [Ransomware]: dragnet-ransomware-2024-5300 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: 01640523-8ddc-594a-9019-4abad92fcf77

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
