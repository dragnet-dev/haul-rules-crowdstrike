// Dragnet [Ransomware]: dragnet-ransomware-2025-2973 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: ad971658-a8ce-52bd-af84-8f27b4ef3812

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
