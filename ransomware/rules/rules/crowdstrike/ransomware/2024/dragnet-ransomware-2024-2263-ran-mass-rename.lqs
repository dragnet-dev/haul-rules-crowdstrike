// Dragnet [Ransomware]: dragnet-ransomware-2024-2263 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 0a1301e5-1e92-5545-8bc9-0d5dc3d4ceff

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
