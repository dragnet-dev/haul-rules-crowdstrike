// Dragnet [Ransomware]: dragnet-ransomware-2025-5937 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 2be9ad35-7efd-5dab-8c6f-30a9e8caddf1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
