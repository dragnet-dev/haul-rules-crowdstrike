// Dragnet [Ransomware]: dragnet-ransomware-2025-4416 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: 88482593-3fb4-5981-8af5-65be06ebae66

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
