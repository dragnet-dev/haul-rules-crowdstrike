// Dragnet [Ransomware]: dragnet-ransomware-2024-4955 — Mass File Rename (hellogookie)
// Status: experimental | Level: high | ID: e1a8c808-a7e7-5498-929f-2170bc683e11

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
