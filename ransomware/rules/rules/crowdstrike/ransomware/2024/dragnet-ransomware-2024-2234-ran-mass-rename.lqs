// Dragnet [Ransomware]: dragnet-ransomware-2024-2234 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: cb11129a-cf7d-53d5-826a-bf3e9ad0c10a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
