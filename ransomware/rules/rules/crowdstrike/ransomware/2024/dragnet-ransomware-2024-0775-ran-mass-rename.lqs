// Dragnet [Ransomware]: dragnet-ransomware-2024-0775 — Mass File Rename (donutleaks)
// Status: experimental | Level: high | ID: db68af6d-b497-5675-a973-3be821acd103

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
