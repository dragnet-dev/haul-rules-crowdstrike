// Dragnet [Ransomware]: dragnet-ransomware-2023-1758 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 92cbd38e-8b32-5490-8652-73c1a1ad5472

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
