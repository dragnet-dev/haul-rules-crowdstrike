// Dragnet [Ransomware]: dragnet-ransomware-2025-7583 — Mass File Rename (cephalus)
// Status: deprecated | Level: high | ID: 0eb19538-0f4a-5de1-9f3d-a6fd74a69054

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
