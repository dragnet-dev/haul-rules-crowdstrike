// Dragnet [Ransomware]: dragnet-ransomware-2024-3411 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: 7256c2d1-e9e0-5e2f-90e5-8002eb75017d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
