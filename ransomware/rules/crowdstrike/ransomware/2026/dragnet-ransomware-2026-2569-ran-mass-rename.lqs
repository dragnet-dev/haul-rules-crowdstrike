// Dragnet [Ransomware]: dragnet-ransomware-2026-2569 — Mass File Rename (lockbit5)
// Status: stable | Level: high | ID: f801377b-008e-59b7-be68-b220783b9495

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
