// Dragnet [Ransomware]: dragnet-ransomware-2025-4339 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: 2099bddc-bcec-56b4-bfef-529368064883

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
