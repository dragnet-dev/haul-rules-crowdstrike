// Dragnet [Ransomware]: dragnet-ransomware-2024-4509 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: f1a2616a-b51c-5cde-9a13-4efc49aaec8d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
