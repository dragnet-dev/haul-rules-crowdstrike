// Dragnet [Ransomware]: dragnet-ransomware-2021-0374 — Mass File Rename (avaddon)
// Status: deprecated | Level: high | ID: 76b24737-9190-5445-8577-3c45b86fd909

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
