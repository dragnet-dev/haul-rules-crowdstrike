// Dragnet [Ransomware]: dragnet-ransomware-2024-0564 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 5e19e5a6-76ca-57d3-ac64-2639d8d57117

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
