// Dragnet [Ransomware]: dragnet-ransomware-2024-1794 — Mass File Rename (darkvault)
// Status: experimental | Level: high | ID: c5c5baa4-d1a6-56f9-b29b-ef6f214ce381

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
