// Dragnet [Ransomware]: dragnet-ransomware-2025-4961 — Mass File Rename (devman)
// Status: deprecated | Level: high | ID: 75d20a3c-c2dc-551e-b6dd-2058a58750b1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
