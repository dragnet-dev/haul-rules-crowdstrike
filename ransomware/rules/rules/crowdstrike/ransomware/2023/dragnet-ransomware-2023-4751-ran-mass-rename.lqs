// Dragnet [Ransomware]: dragnet-ransomware-2023-4751 — Mass File Rename (malekteam)
// Status: experimental | Level: high | ID: 1f7a25e8-43fb-55b3-81d1-5c4898ae318f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
