// Dragnet [Container]: dragnet-container-2026-1673 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 451b290b-712c-5777-95ee-5507b3fb38eb

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:5*)
| table([timestamp, ComputerName])
| limit(1000)
