// Dragnet [Ransomware]: dragnet-ransomware-2026-0223 — Mass File Rename (thegentlemen)
// Status: deprecated | Level: high | ID: ca031129-37bd-5255-8686-d0cf7484f9bc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
