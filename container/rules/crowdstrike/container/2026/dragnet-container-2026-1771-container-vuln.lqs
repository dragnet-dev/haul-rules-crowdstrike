// Dragnet [Container]: dragnet-container-2026-1771 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: c60d85a1-f695-5280-a555-058f1c2da0a0

#event_simpleName=*
| (ImageFileName = *chainguard:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
