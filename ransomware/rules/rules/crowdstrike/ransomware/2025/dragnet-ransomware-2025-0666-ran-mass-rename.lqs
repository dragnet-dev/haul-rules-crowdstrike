// Dragnet [Ransomware]: dragnet-ransomware-2025-0666 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 9eeff108-6029-5121-a16a-e17063e91969

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
