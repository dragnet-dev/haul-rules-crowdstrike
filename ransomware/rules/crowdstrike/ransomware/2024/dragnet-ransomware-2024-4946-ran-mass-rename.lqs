// Dragnet [Ransomware]: dragnet-ransomware-2024-4946 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 1d33032c-ee7d-5b37-b064-22e2f2fa5983

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
