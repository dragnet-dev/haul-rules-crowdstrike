// Dragnet [Ransomware]: dragnet-ransomware-2024-3691 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: b27dc32c-5f87-599d-9be5-57b6a0e04db5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
