// Dragnet [Ransomware]: dragnet-ransomware-2025-7525 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: f6a1c3f3-987d-51d3-8112-187ff6e57919

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
