// Dragnet [Ransomware]: dragnet-ransomware-2022-1483 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 823c901d-32a5-5f96-a0a4-929216a5a763

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
