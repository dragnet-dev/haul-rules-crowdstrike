// Dragnet [Ransomware]: dragnet-ransomware-2025-1415 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 43105d75-1243-5853-bc82-1c902e712b24

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
