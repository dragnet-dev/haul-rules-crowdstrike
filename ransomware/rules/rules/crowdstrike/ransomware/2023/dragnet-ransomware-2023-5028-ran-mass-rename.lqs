// Dragnet [Ransomware]: dragnet-ransomware-2023-5028 — Mass File Rename (noescape)
// Status: experimental | Level: high | ID: 807ccee9-886b-5f82-8467-61e393d926aa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
