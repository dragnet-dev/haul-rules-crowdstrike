// Dragnet [Ransomware]: dragnet-ransomware-2023-1983 — Mass File Rename (avoslocker)
// Status: deprecated | Level: high | ID: 14f4640e-0d11-55e9-be7e-6c595820a1db

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
