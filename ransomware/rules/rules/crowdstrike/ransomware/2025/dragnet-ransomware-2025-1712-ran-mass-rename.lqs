// Dragnet [Ransomware]: dragnet-ransomware-2025-1712 — Mass File Rename (VanHelsing)
// Status: experimental | Level: high | ID: 588caf3d-7310-5a6c-8cc0-935eb61ad087

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
