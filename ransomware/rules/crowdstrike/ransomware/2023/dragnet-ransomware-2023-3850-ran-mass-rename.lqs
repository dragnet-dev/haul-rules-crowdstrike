// Dragnet [Ransomware]: dragnet-ransomware-2023-3850 — Mass File Rename (play)
// Status: experimental | Level: high | ID: d33fc2b2-4574-5d01-9ed5-638de97f71a0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
