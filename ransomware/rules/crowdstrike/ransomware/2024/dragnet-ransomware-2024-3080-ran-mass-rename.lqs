// Dragnet [Ransomware]: dragnet-ransomware-2024-3080 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 4e36657c-26fd-559f-b830-a2547fda7b11

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
