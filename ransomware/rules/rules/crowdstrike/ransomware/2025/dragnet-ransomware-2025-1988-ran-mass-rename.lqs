// Dragnet [Ransomware]: dragnet-ransomware-2025-1988 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: c8ab1cc4-d55a-5751-ad3c-99901372da29

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
