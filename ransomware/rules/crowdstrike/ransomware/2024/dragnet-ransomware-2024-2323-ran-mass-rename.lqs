// Dragnet [Ransomware]: dragnet-ransomware-2024-2323 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: a02a991f-6c05-5934-805c-4dca2b86ad4c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
