// Dragnet [Ransomware]: dragnet-ransomware-2025-1686 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 2b130306-dea8-501d-8260-34f175b6934d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
