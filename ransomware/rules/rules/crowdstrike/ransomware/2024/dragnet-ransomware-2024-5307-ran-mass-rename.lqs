// Dragnet [Ransomware]: dragnet-ransomware-2024-5307 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 1fe8a43a-3db2-5d76-b670-78e2bd25d5c3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
