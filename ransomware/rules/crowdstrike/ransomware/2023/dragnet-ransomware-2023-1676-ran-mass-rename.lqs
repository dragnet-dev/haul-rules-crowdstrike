// Dragnet [Ransomware]: dragnet-ransomware-2023-1676 — Mass File Rename (cactus)
// Status: deprecated | Level: high | ID: 0abc9a4e-29cc-593d-86a9-2030d4b9566f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
