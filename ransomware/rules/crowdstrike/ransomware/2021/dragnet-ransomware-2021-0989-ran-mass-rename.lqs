// Dragnet [Ransomware]: dragnet-ransomware-2021-0989 — Mass File Rename (avoslocker)
// Status: deprecated | Level: high | ID: 205d8b7a-525e-5dd3-99a1-1df6cf33f586

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
