// Dragnet [Ransomware]: dragnet-ransomware-2025-7335 — Mass File Rename (play)
// Status: experimental | Level: high | ID: f9f79024-1177-52ad-92b9-f63a479e426f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
