// Dragnet [Ransomware]: dragnet-ransomware-2025-3721 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 5ff8a267-bad7-5e81-b4d2-357886e9e000

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
