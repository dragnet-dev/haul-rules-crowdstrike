// Dragnet [Ransomware]: dragnet-ransomware-2026-0261 — Mass File Rename (fulcrumsec)
// Status: stable | Level: high | ID: 55049b6f-b595-5b23-b7db-8cc2be74e8b4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
