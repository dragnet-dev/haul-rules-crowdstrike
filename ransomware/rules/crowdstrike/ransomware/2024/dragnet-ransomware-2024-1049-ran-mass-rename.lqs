// Dragnet [Ransomware]: dragnet-ransomware-2024-1049 — Mass File Rename (ransomhouse)
// Status: experimental | Level: high | ID: 59118c0b-29f2-5d88-afe5-184579366256

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
