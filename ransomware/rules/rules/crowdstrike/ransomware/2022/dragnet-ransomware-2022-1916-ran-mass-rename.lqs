// Dragnet [Ransomware]: dragnet-ransomware-2022-1916 — Mass File Rename (royal)
// Status: deprecated | Level: high | ID: c839bce1-ee25-511c-b8c5-2c97a1353bbd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
