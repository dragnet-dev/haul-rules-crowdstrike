// Dragnet [Ransomware]: dragnet-ransomware-2022-2213 — Mass File Rename (karakurt)
// Status: deprecated | Level: high | ID: 4664736a-3f5f-5c90-b7fb-09cfd31c1d8a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
