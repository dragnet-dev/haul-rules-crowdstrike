// Dragnet [Ransomware]: dragnet-ransomware-2023-2596 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 8b6531e2-ec1c-5fdd-ba09-b1772f17b74f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
