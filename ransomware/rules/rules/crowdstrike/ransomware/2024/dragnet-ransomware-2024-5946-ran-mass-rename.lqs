// Dragnet [Ransomware]: dragnet-ransomware-2024-5946 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 77cb88ab-5c90-598d-8bc7-b3c57e3a085e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
