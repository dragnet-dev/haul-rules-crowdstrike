// Dragnet [Ransomware]: dragnet-ransomware-2024-4964 — Mass File Rename (interlock)
// Status: experimental | Level: high | ID: e160ad98-ff79-51b7-ac97-3b520db68333

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
