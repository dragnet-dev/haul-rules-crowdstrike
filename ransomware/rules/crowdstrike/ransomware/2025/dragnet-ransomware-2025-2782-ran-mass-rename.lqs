// Dragnet [Ransomware]: dragnet-ransomware-2025-2782 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 63477013-0f5c-565c-9c82-a273055271f8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
