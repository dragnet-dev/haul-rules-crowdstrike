// Dragnet [Ransomware]: dragnet-ransomware-2022-2376 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: dba355a0-9450-5f72-a744-c227ec4e9a8c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
