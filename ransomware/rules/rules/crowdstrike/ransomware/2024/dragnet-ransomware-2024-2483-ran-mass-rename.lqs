// Dragnet [Ransomware]: dragnet-ransomware-2024-2483 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 5a8a3fce-3b61-595d-8c83-b0488a647768

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
