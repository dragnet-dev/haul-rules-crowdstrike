// Dragnet [Ransomware]: dragnet-ransomware-2024-3009 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 3f5eda35-8c08-5b49-b7ee-de4f96dc07b6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
