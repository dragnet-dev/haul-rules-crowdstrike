// Dragnet [Ransomware]: dragnet-ransomware-2022-1510 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 467f784f-d4db-5fcf-ac7f-5d53f879d158

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
