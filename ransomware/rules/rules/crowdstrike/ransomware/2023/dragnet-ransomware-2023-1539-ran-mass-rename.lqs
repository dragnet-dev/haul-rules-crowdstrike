// Dragnet [Ransomware]: dragnet-ransomware-2023-1539 — Mass File Rename (raworld)
// Status: experimental | Level: high | ID: 28c87eb8-9b05-5ca4-98f1-fbe06fab7488

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
