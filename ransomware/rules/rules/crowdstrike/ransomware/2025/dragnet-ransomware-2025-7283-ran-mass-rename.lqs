// Dragnet [Ransomware]: dragnet-ransomware-2025-7283 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: b6a89135-7e7f-5e42-96f0-4283e76d966d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
