// Dragnet [Ransomware]: dragnet-ransomware-2025-5379 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 5ae5d662-7e87-5111-b9b5-23e874181744

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
