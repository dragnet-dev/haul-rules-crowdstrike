// Dragnet [Container]: dragnet-container-2026-0816 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 24b031e1-fa94-5b5d-a1c4-49d43dcbaca4

#event_simpleName=*
| (ImageFileName = *debian:7* OR ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10* OR ImageFileName = *ubuntu:13.04*)
| table([timestamp, ComputerName])
| limit(1000)
