// Dragnet [Ransomware]: dragnet-ransomware-2023-3466 — Mass File Rename (cactus)
// Status: deprecated | Level: high | ID: e500f2e2-97f0-5c81-a111-5656fffa3d3a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
