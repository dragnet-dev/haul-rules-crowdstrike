// Dragnet [Ransomware]: dragnet-ransomware-2025-0594 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: 5e2f494c-f699-541c-aa08-518f68969927

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
