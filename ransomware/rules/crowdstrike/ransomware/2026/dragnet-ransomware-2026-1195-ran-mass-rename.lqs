// Dragnet [Ransomware]: dragnet-ransomware-2026-1195 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 3c1940f3-8061-598f-ba88-10e193562b12

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
