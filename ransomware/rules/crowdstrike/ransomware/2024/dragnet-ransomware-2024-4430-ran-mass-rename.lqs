// Dragnet [Ransomware]: dragnet-ransomware-2024-4430 — Mass File Rename (raworld)
// Status: experimental | Level: high | ID: 9f2292e4-5c37-554e-85cd-a3d06f38acc1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
