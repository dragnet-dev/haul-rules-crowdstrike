// Dragnet [Ransomware]: dragnet-ransomware-2025-3184 — Mass File Rename (anubis)
// Status: experimental | Level: high | ID: cad6b51c-6ab2-51c7-96d7-f5adf53512fd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
