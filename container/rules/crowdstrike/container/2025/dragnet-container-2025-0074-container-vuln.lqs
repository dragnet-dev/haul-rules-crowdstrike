// Dragnet [Container]: dragnet-container-2025-0074 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 141ae36f-4dc1-5209-858e-12fa55efae7b

#event_simpleName=*
| (ImageFileName = *amazonlinux:2023* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:7* OR ImageFileName = *oraclelinux:9* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:20.04* OR ImageFileName = *ubuntu:20.04-ESM* OR ImageFileName = *ubuntu:22.04*)
| table([timestamp, ComputerName])
| limit(1000)
