// Dragnet [Ransomware]: dragnet-ransomware-2023-1515 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: fb4c9a07-a179-570f-a039-227fcdebc65d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
