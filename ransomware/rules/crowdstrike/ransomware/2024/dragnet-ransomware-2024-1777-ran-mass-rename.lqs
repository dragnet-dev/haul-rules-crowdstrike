// Dragnet [Ransomware]: dragnet-ransomware-2024-1777 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 93cab521-5990-59a3-80f1-846dfe8a706c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
