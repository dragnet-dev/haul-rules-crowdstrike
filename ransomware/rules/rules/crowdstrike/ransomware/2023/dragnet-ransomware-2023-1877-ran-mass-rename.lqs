// Dragnet [Ransomware]: dragnet-ransomware-2023-1877 — Mass File Rename (donutleaks)
// Status: experimental | Level: high | ID: 635ee162-252b-564f-83a1-5a597dda527a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
