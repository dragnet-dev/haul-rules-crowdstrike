// Dragnet [Ransomware]: dragnet-ransomware-2023-1490 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 548d2712-6cd5-57fa-b7f5-cd8f5404fd7f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
