// Dragnet [Ransomware]: dragnet-ransomware-2020-0242 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 736e1062-f7d3-507f-bb5d-b69728182eb2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
