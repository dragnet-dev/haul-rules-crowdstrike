// Dragnet [Ransomware]: dragnet-ransomware-2025-0473 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: 9a7a174b-b2ee-55fb-a28f-03d5e5ace207

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
