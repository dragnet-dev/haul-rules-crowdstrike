// Dragnet [Ransomware]: dragnet-ransomware-2024-2687 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 89a81699-af33-5887-9508-865570bc8760

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
