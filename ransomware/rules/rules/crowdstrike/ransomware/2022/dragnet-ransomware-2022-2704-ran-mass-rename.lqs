// Dragnet [Ransomware]: dragnet-ransomware-2022-2704 — Mass File Rename (bitlocker)
// Status: deprecated | Level: high | ID: 5a1bd695-bdda-5ae4-8d52-2e9774fa1169

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
