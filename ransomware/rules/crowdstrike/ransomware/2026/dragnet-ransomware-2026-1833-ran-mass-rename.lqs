// Dragnet [Ransomware]: dragnet-ransomware-2026-1833 — Mass File Rename (incransom)
// Status: stable | Level: high | ID: 86fcd36e-81ad-5517-b95d-2b893c2620b9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
