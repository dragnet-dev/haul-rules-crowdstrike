// Dragnet [Ransomware]: dragnet-ransomware-2025-5865 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 85b24cb7-7da1-5852-aa2b-9123f67056ad

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
