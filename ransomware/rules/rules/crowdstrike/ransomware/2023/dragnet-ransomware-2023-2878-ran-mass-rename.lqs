// Dragnet [Ransomware]: dragnet-ransomware-2023-2878 — Mass File Rename (malas)
// Status: experimental | Level: high | ID: d982739f-ba6b-55b2-b16c-32d548649c06

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
