// Dragnet [Container]: dragnet-container-2026-0030 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 84e1ed40-27e2-5671-89ae-bc8f6eb10880

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10*)
| table([timestamp, ComputerName])
| limit(1000)
