// Dragnet [Ransomware]: dragnet-ransomware-2023-4440 — Mass File Rename (noescape)
// Status: experimental | Level: high | ID: 60955620-e103-5f61-9016-ef654106ab29

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
