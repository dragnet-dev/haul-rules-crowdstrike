// Dragnet [Ransomware]: dragnet-ransomware-2025-4128 — Mass File Rename (tengu)
// Status: experimental | Level: high | ID: 3d424952-9407-5053-879a-47a457f523c4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
