// Dragnet [Ransomware]: dragnet-ransomware-2022-2230 — Mass File Rename (lv)
// Status: deprecated | Level: high | ID: c7a9ee6f-31eb-5e18-bea3-c4f2f8966960

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
