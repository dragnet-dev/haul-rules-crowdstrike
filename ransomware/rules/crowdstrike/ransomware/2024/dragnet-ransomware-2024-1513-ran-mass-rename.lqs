// Dragnet [Ransomware]: dragnet-ransomware-2024-1513 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: 8106ff08-758c-5505-b741-17fbfc2bbb6e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
