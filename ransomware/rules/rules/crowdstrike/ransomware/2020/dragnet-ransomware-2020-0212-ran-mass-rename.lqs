// Dragnet [Ransomware]: dragnet-ransomware-2020-0212 — Mass File Rename (ragnarlocker)
// Status: deprecated | Level: high | ID: 2fe92de6-aba3-5621-9417-e7aa7cbe782d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
