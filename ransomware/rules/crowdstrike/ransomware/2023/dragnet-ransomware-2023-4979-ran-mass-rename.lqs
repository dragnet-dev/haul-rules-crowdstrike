// Dragnet [Ransomware]: dragnet-ransomware-2023-4979 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 6d6fba9d-c606-514e-ac8c-77700f3984b4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
