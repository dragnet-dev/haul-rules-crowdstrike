// Dragnet [Ransomware]: dragnet-ransomware-2026-2840 — Mass File Rename (stormous)
// Status: deprecated | Level: high | ID: 40849026-0ee3-5bce-97eb-1024f53eaebf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
