// Dragnet [Ransomware]: dragnet-ransomware-2023-1123 — Mass File Rename (noescape)
// Status: experimental | Level: high | ID: fad523cb-8fe3-5d74-8e7b-fdbabfd18062

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
