// Dragnet [Ransomware]: dragnet-ransomware-2024-4546 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 17c7c008-142b-5fa3-8b1a-8e570e418d3e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
