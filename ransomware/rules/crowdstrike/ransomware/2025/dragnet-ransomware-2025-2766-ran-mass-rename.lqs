// Dragnet [Ransomware]: dragnet-ransomware-2025-2766 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: f7147ec3-78f8-5646-bbc2-7a0a2e500f35

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
