// Dragnet [Ransomware]: dragnet-ransomware-2025-4417 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: d474a461-0fa9-5f6f-9430-0a251f8df54c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
