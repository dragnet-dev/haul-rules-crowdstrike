// Dragnet [Ransomware]: dragnet-ransomware-2022-1489 — Mass File Rename (midas)
// Status: deprecated | Level: high | ID: b0028fa5-c9f6-5e96-b8f8-aca3e6b83dcd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
