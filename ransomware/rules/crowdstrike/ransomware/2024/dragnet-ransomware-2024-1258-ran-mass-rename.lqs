// Dragnet [Ransomware]: dragnet-ransomware-2024-1258 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: c4f075b9-f4a1-51ef-9f58-d19d3d20ca49

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
