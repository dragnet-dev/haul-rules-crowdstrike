// Dragnet [Ransomware]: dragnet-ransomware-2026-0076 — Mass File Rename (lockbit5)
// Status: stable | Level: high | ID: 2817bbdb-b03e-5924-885a-31d9f4172f86

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
