// Dragnet [Ransomware]: dragnet-ransomware-2022-0041 — Mass File Rename (alphv)
// Status: deprecated | Level: high | ID: d6780979-b043-573b-8221-652b097b43df

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
