// Dragnet [Ransomware]: dragnet-ransomware-2023-0685 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 64094b19-d240-5514-8b92-9ec4ede36d46

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
