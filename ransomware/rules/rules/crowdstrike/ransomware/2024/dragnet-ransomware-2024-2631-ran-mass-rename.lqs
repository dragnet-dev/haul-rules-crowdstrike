// Dragnet [Ransomware]: dragnet-ransomware-2024-2631 — Mass File Rename (donex)
// Status: experimental | Level: high | ID: c8c7227d-57f7-570d-902c-ee9af39c478c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
