// Dragnet [Container]: dragnet-container-2026-2958 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 0a821bbe-2c47-5803-9c77-009eff3dd385

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:7* OR ImageFileName = *debian:8*)
| table([timestamp, ComputerName])
| limit(1000)
