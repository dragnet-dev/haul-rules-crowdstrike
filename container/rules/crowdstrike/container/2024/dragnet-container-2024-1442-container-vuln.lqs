// Dragnet [Container]: dragnet-container-2024-1442 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 0b4cce4b-b285-5bb6-9faa-d126ef272ce1

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
