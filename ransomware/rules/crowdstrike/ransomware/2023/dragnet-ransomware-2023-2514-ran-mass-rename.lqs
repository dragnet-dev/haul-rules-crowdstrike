// Dragnet [Ransomware]: dragnet-ransomware-2023-2514 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 75fe89bc-a0d0-5de9-82ad-97c6cd37cef1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
