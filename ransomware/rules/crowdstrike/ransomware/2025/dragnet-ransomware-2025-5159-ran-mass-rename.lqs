// Dragnet [Ransomware]: dragnet-ransomware-2025-5159 — Mass File Rename (rhysida)
// Status: experimental | Level: high | ID: dff49ff6-eb26-5391-a340-d39d496677c1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
