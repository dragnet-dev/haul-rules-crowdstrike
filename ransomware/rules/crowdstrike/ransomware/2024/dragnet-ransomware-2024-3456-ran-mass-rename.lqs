// Dragnet [Ransomware]: dragnet-ransomware-2024-3456 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: 9212b168-0b16-5f80-8f3b-d7dbc6ca4896

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
