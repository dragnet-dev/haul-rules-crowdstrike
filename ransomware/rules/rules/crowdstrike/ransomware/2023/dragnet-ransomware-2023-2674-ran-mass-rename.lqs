// Dragnet [Ransomware]: dragnet-ransomware-2023-2674 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 9497d776-6e9d-5401-9cb0-52534795b8ef

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
