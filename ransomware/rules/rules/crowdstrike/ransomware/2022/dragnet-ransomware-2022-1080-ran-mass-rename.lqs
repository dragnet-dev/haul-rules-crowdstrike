// Dragnet [Ransomware]: dragnet-ransomware-2022-1080 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: c75ca3c8-d17a-568c-83f0-1ca0d5ae83b5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
