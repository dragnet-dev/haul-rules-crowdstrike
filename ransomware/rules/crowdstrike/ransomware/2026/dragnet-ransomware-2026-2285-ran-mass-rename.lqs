// Dragnet [Ransomware]: dragnet-ransomware-2026-2285 — Mass File Rename (lockbit5)
// Status: stable | Level: high | ID: 0adb1f9d-e78a-5f6f-97f4-b1732c9a1c8c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
