// Dragnet [Ransomware]: dragnet-ransomware-2026-0041 — Mass File Rename (everest)
// Status: stable | Level: high | ID: f1d98bbc-c855-542c-92ae-4445d3d6fe8f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
