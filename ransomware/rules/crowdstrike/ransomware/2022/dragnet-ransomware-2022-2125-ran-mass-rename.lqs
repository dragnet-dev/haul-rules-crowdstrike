// Dragnet [Ransomware]: dragnet-ransomware-2022-2125 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 0228604c-a630-5a5a-aebc-89da3ed865a5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
