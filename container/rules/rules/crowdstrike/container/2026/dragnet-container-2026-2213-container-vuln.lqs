// Dragnet [Container]: dragnet-container-2026-2213 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 3941a0a9-dca0-5d55-8f61-76a1b340be2d

#event_simpleName=*
| (ImageFileName = *debian:7* OR ImageFileName = *debian:8* OR ImageFileName = *ubuntu:14.04* OR ImageFileName = *ubuntu:15.04* OR ImageFileName = *ubuntu:15.10*)
| table([timestamp, ComputerName])
| limit(1000)
