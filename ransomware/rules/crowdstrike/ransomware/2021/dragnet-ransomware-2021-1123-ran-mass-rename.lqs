// Dragnet [Ransomware]: dragnet-ransomware-2021-1123 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: f178bb8b-d918-5905-9675-4ffcb48aaad7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
