// Dragnet [Ransomware]: dragnet-ransomware-2024-4446 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: c413df7a-cd00-54e8-92e8-c1357afa1096

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
