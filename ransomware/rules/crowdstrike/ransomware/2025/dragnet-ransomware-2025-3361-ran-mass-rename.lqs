// Dragnet [Ransomware]: dragnet-ransomware-2025-3361 — Mass File Rename (sinobi)
// Status: experimental | Level: high | ID: c980c045-ca3f-5666-80b1-4cdd38061c32

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
