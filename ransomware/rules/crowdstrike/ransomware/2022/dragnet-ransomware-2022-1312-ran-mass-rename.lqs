// Dragnet [Ransomware]: dragnet-ransomware-2022-1312 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 3cb81499-7154-5f93-8db6-1fa35dd8a35a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
