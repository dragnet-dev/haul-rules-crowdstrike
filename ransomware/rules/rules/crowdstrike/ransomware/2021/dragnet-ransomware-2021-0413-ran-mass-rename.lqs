// Dragnet [Ransomware]: dragnet-ransomware-2021-0413 — Mass File Rename (lv)
// Status: deprecated | Level: high | ID: e248f07d-a4c2-5b6b-b935-e2e0a8ed672b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
