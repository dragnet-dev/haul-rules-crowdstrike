// Dragnet [Ransomware]: dragnet-ransomware-2024-1934 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: f2f15096-2aac-5a95-871d-86d86f9386ae

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
