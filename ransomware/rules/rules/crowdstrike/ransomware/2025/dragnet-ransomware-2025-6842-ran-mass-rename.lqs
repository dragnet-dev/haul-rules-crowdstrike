// Dragnet [Ransomware]: dragnet-ransomware-2025-6842 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: d6d8326e-6d37-5c69-8788-5b8d01a6992b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
