// Dragnet [Ransomware]: dragnet-ransomware-2023-2549 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 497c4463-7c45-5842-8240-97c3720abfa1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
