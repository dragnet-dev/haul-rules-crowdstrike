// Dragnet [Ransomware]: dragnet-ransomware-2023-3673 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 72980119-f212-50ee-af75-56f5621c516a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
