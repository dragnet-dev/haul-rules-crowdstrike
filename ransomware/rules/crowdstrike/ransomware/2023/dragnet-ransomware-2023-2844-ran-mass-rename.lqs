// Dragnet [Ransomware]: dragnet-ransomware-2023-2844 — Mass File Rename (malas)
// Status: experimental | Level: high | ID: 7ad0d904-b23a-556c-909a-f4e58a345676

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
