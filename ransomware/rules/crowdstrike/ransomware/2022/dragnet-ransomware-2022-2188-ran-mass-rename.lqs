// Dragnet [Ransomware]: dragnet-ransomware-2022-2188 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 5eba798f-cbac-5c92-b9cc-5ebbd459439f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
