// Dragnet [Ransomware]: dragnet-ransomware-2023-4508 — Mass File Rename (pear)
// Status: experimental | Level: high | ID: 7cdc8278-af65-5ce3-959d-b2f934605cd8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
