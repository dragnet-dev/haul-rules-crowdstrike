// Dragnet [Ransomware]: dragnet-ransomware-2023-3954 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: 820ffb95-73ce-5334-bf17-3fad2c7d5a6c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
