// Dragnet [Ransomware]: dragnet-ransomware-2022-1979 — Mass File Rename (alphv)
// Status: deprecated | Level: high | ID: 8480540d-6027-5e0f-8222-f2d7ec2d9ec2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
