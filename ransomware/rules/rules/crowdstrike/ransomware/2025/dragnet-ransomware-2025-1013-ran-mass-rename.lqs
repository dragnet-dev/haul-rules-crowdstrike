// Dragnet [Ransomware]: dragnet-ransomware-2025-1013 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 6e4311d4-aa32-56f5-aa7c-a72188d9e8f7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
