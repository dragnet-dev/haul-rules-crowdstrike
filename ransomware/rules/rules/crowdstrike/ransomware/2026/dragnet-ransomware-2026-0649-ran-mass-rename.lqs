// Dragnet [Ransomware]: dragnet-ransomware-2026-0649 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 41027526-b473-53fe-980f-ca40dd92a301

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
