// Dragnet [Container]: dragnet-container-2026-2377 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 7d34d89d-6104-5fc0-a763-b52773d4dde6

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
