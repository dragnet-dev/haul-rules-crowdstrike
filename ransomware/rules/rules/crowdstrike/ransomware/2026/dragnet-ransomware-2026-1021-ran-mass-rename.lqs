// Dragnet [Ransomware]: dragnet-ransomware-2026-1021 — Mass File Rename (thegentlemen)
// Status: test | Level: high | ID: bee77e2c-2f30-5dfc-9e49-4324a99965de

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
