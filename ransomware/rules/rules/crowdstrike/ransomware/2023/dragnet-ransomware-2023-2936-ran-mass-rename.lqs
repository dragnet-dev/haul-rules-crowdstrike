// Dragnet [Ransomware]: dragnet-ransomware-2023-2936 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: e174c17e-2a8d-5394-a5d1-8cd17991168a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
