// Dragnet [Ransomware]: dragnet-ransomware-2026-0336 — Mass File Rename (spacebears)
// Status: test | Level: high | ID: a72091b6-51c8-5400-99cf-18c630cd61bb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
