// Dragnet [Ransomware]: dragnet-ransomware-2023-2459 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 98336d10-e5b3-5ec7-bc39-b71c4e354a2b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
