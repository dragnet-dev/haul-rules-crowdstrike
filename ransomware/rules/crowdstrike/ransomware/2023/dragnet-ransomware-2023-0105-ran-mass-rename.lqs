// Dragnet [Ransomware]: dragnet-ransomware-2023-0105 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 445ba2e4-c3d0-524f-bebb-daf88537d170

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
