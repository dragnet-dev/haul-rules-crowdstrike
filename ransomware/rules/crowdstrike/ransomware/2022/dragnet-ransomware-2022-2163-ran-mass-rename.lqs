// Dragnet [Ransomware]: dragnet-ransomware-2022-2163 — Mass File Rename (royal)
// Status: deprecated | Level: high | ID: 514b2a80-cb5f-50ab-9761-62d45bcbaa12

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
