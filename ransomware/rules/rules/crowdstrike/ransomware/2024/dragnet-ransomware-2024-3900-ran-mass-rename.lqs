// Dragnet [Ransomware]: dragnet-ransomware-2024-3900 — Mass File Rename (dragonransomware)
// Status: experimental | Level: high | ID: 4e9c9fa6-be75-5c3b-b32c-cabf84d0fe60

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
