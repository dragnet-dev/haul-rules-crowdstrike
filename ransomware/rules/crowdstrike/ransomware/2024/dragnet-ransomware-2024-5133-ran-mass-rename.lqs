// Dragnet [Ransomware]: dragnet-ransomware-2024-5133 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 0413427f-cdb6-581d-83c9-f7eeeed58dd2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
