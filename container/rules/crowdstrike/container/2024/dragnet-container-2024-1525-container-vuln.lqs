// Dragnet [Container]: dragnet-container-2024-1525 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: bd9e2965-30fa-5d2e-ac63-e0ff2863d5e3

#event_simpleName=*
| (ImageFileName = *almalinux:8* OR ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:9* OR ImageFileName = *oraclelinux:8* OR ImageFileName = *redhat/ubi9:*)
| table([timestamp, ComputerName])
| limit(1000)
