// Dragnet [Ransomware]: dragnet-ransomware-2025-5351 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 0daf4adb-1075-523e-9480-e7eb62f3b0f1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
