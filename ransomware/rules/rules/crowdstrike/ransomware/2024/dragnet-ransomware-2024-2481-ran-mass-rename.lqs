// Dragnet [Ransomware]: dragnet-ransomware-2024-2481 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 5d742ace-e178-5ff6-98de-6270ad996d80

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
