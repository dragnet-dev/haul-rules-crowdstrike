// Dragnet [Ransomware]: dragnet-ransomware-2025-4062 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 6ad4620a-27f3-5cab-880e-a39257a5b74a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
