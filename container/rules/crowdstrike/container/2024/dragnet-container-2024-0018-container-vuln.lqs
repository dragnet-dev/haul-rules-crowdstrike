// Dragnet [Container]: dragnet-container-2024-0018 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 1554c40e-2306-5e1d-8342-376479edfbf9

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:8* OR ImageFileName = *debian:9*)
| table([timestamp, ComputerName])
| limit(1000)
