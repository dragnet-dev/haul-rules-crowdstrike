// Dragnet [Ransomware]: dragnet-ransomware-2024-5084 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: be23260b-ca29-5c2c-b500-690ecd6cbdc7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
