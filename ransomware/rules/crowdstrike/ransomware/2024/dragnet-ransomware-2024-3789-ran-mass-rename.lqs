// Dragnet [Ransomware]: dragnet-ransomware-2024-3789 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: feb838f2-fb21-5513-a84d-7d09d12eb6e5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
