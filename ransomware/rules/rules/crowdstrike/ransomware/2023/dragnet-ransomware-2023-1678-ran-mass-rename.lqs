// Dragnet [Ransomware]: dragnet-ransomware-2023-1678 — Mass File Rename (ElDorado)
// Status: deprecated | Level: high | ID: f36eecac-419a-5fb6-89e3-dca717a316ce

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
