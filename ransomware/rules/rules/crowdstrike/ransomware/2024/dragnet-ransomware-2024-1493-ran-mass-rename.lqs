// Dragnet [Ransomware]: dragnet-ransomware-2024-1493 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: 8ae965d5-a7ef-56ed-9c75-d2a71f0bb76b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
