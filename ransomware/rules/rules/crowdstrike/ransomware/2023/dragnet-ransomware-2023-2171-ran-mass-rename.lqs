// Dragnet [Ransomware]: dragnet-ransomware-2023-2171 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: dff2870b-249d-51fb-a8a3-d958dcd0c885

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
