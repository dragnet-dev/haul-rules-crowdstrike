// Dragnet [Ransomware]: dragnet-ransomware-2022-1863 — Mass File Rename (play)
// Status: deprecated | Level: high | ID: e4aaff1a-15bc-5c56-a704-3604a4726084

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
