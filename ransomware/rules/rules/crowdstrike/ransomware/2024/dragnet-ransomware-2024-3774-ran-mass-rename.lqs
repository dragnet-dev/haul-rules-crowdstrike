// Dragnet [Ransomware]: dragnet-ransomware-2024-3774 — Mass File Rename (dragonforce)
// Status: deprecated | Level: high | ID: 3c0cba4e-353f-5b84-b9ec-84347d14284e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
