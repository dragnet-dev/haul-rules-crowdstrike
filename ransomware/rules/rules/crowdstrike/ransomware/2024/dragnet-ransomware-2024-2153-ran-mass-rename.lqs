// Dragnet [Ransomware]: dragnet-ransomware-2024-2153 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 613e7cf6-3268-5cdf-8f2a-b0b3746bffaf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
