// Dragnet [Ransomware]: dragnet-ransomware-2021-0182 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 1ff4446e-2c7e-519c-8209-ba4e3e772523

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
