// Dragnet [Ransomware]: dragnet-ransomware-2020-0067 — Mass File Rename (netwalker)
// Status: deprecated | Level: high | ID: 1af48e75-bd03-5c59-a48b-cf05d019fddb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
