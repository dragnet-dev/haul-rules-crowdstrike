// Dragnet [Ransomware]: dragnet-ransomware-2023-2019 — Mass File Rename (losttrust)
// Status: deprecated | Level: high | ID: 9976fe3f-2b4b-592c-b2ed-01dce0f830ff

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
