// Dragnet [Ransomware]: dragnet-ransomware-2024-5256 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 230bd285-57ff-5d45-9d10-cb759d5a9a50

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
