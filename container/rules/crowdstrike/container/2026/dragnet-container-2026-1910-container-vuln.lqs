// Dragnet [Container]: dragnet-container-2026-1910 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 2891e0c8-44cb-5edc-8f0e-1a7cfffddc33

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:5*)
| table([timestamp, ComputerName])
| limit(1000)
