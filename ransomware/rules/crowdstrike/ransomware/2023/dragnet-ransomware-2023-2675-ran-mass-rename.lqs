// Dragnet [Ransomware]: dragnet-ransomware-2023-2675 — Mass File Rename (royal)
// Status: experimental | Level: high | ID: cb72c16e-0381-510c-b16d-7774da706be7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
