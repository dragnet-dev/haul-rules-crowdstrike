// Dragnet [Ransomware]: dragnet-ransomware-2023-4024 — Mass File Rename (ransomhouse)
// Status: experimental | Level: high | ID: d72d64d4-aff5-509d-9125-89351eb965d1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
