// Dragnet [Ransomware]: dragnet-ransomware-2023-0435 — Mass File Rename (ransomhouse)
// Status: deprecated | Level: high | ID: 9c0d4dac-c600-5296-b253-67a3d187410a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
