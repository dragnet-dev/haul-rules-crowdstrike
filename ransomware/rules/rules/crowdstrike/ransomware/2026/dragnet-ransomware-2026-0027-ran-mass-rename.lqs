// Dragnet [Ransomware]: dragnet-ransomware-2026-0027 — Mass File Rename (payoutsking)
// Status: stable | Level: high | ID: 8c9d1cff-4f7b-546e-a2bc-ad0da5ad2ead

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
