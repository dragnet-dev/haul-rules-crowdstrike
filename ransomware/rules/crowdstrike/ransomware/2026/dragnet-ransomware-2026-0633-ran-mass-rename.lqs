// Dragnet [Ransomware]: dragnet-ransomware-2026-0633 — Mass File Rename (dragonforce)
// Status: test | Level: high | ID: 9945b844-0958-5dc4-82c2-2df7a1b97f5c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
