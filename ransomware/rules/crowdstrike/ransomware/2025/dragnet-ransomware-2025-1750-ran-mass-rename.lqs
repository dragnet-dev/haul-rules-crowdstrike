// Dragnet [Ransomware]: dragnet-ransomware-2025-1750 — Mass File Rename (direwolf)
// Status: experimental | Level: high | ID: e8d11784-783e-51c1-b78e-461750e7314f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
