// Dragnet [Ransomware]: dragnet-ransomware-2025-6701 — Mass File Rename (rhysida)
// Status: experimental | Level: high | ID: 5d938b19-2739-53fe-9744-b30118a5557e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
