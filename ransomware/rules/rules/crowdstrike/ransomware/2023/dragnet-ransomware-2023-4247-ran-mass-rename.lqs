// Dragnet [Ransomware]: dragnet-ransomware-2023-4247 — Mass File Rename (royal)
// Status: experimental | Level: high | ID: 1f71352d-294d-556a-a456-0eb163c4f749

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
