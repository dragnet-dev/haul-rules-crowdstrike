// Dragnet [Ransomware]: dragnet-ransomware-2025-0658 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 38ed3f59-f7e2-5b53-b3fb-b1786ca7a959

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
