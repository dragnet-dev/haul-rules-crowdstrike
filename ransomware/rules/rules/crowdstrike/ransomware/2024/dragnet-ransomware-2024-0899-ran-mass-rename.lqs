// Dragnet [Ransomware]: dragnet-ransomware-2024-0899 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 5688438d-1181-5ad2-a653-a89aa19c39cc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
