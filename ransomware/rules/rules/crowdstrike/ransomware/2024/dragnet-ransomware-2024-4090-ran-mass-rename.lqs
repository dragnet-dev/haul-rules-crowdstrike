// Dragnet [Ransomware]: dragnet-ransomware-2024-4090 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: eba10193-f332-54ac-a478-9dd4a3af1b2e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
