// Dragnet [Ransomware]: dragnet-ransomware-2024-1887 — Mass File Rename (trinity)
// Status: experimental | Level: high | ID: badba2e8-f537-5cca-aadf-59d64e1ccdd4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
