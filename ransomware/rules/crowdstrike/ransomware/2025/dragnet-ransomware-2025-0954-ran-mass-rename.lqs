// Dragnet [Ransomware]: dragnet-ransomware-2025-0954 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 54ad4e24-6021-50a4-ac98-fb056c8151ba

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
