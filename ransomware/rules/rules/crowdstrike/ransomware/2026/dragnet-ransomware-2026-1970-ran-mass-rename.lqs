// Dragnet [Ransomware]: dragnet-ransomware-2026-1970 — Mass File Rename (payload)
// Status: stable | Level: high | ID: 325c66e5-c7f9-560d-8d42-d78e954a614a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
