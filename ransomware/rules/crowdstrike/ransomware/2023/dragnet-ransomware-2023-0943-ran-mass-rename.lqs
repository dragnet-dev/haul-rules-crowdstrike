// Dragnet [Ransomware]: dragnet-ransomware-2023-0943 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 220fb247-4c66-5c60-bfd2-d28b7b41b407

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
