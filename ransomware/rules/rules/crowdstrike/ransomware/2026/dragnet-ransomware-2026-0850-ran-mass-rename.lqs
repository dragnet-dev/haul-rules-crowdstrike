// Dragnet [Ransomware]: dragnet-ransomware-2026-0850 — Mass File Rename (LeakBazaar)
// Status: stable | Level: high | ID: 2f7a3dbc-3e8e-582d-b22e-0e658f0b565b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
