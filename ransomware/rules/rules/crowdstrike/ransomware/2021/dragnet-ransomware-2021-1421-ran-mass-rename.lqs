// Dragnet [Ransomware]: dragnet-ransomware-2021-1421 — Mass File Rename (karma)
// Status: deprecated | Level: high | ID: 70022020-6ac5-5520-837f-acd79adae652

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
