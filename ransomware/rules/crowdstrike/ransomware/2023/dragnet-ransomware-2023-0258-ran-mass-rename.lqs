// Dragnet [Ransomware]: dragnet-ransomware-2023-0258 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: bf772370-fd9a-5fa5-9a7b-8f0e63b3e6f8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
