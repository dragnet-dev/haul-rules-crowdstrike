// Dragnet [Ransomware]: dragnet-ransomware-2024-4313 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 749721d6-0e1f-59a4-aab0-a0db6da58252

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
