// Dragnet [Ransomware]: dragnet-ransomware-2021-0017 — Mass File Rename (lv)
// Status: deprecated | Level: high | ID: 223c6b50-1aee-5dad-8011-c4e873b97c19

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
