// Dragnet [Ransomware]: dragnet-ransomware-2024-1037 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: c201e15b-9d18-50d2-b79c-ded246fa7881

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
