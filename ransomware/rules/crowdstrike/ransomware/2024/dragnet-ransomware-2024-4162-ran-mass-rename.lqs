// Dragnet [Ransomware]: dragnet-ransomware-2024-4162 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 618df5b6-7c01-570a-8456-07d857083c9a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
