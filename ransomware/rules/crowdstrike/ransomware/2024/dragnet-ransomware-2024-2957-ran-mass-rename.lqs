// Dragnet [Ransomware]: dragnet-ransomware-2024-2957 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 41439b2e-d023-5e3e-aac2-23ffd41b4ab5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
