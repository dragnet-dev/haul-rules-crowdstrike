// Dragnet [Ransomware]: dragnet-ransomware-2025-3181 — Mass File Rename (bert)
// Status: experimental | Level: high | ID: 826ef6dd-9dd4-5c13-b872-7234d1d294ac

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
