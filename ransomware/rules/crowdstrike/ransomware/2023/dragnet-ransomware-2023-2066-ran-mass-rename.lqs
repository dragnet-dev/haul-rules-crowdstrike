// Dragnet [Ransomware]: dragnet-ransomware-2023-2066 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: fcf8214a-13ce-57d5-960e-0b68b999a919

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
