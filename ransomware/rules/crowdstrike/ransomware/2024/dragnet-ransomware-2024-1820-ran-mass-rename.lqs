// Dragnet [Ransomware]: dragnet-ransomware-2024-1820 — Mass File Rename (stormous)
// Status: deprecated | Level: high | ID: d2e08eb7-c445-5610-a7dd-cbd6a81a3d66

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
