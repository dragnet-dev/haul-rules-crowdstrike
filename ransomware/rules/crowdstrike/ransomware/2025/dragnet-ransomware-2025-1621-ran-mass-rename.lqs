// Dragnet [Ransomware]: dragnet-ransomware-2025-1621 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 5b4fd787-efbd-5fd8-9a3b-1610978d3cd8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
