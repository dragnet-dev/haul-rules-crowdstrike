// Dragnet [Ransomware]: dragnet-ransomware-2023-0787 — Mass File Rename (play)
// Status: experimental | Level: high | ID: c95a2940-c984-535e-a9b0-27381c009782

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
