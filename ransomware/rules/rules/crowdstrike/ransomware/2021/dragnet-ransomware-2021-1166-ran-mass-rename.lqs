// Dragnet [Ransomware]: dragnet-ransomware-2021-1166 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 70bf8b22-e49b-5ee4-914b-17b1de29d2b2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
