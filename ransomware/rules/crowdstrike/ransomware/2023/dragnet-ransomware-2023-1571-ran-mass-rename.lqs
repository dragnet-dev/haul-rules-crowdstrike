// Dragnet [Ransomware]: dragnet-ransomware-2023-1571 — Mass File Rename (knight)
// Status: experimental | Level: high | ID: 32f66ff9-77f3-5a89-b6d6-838cc8f531c8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
