// Dragnet [Ransomware]: dragnet-ransomware-2021-0753 — Mass File Rename (darkside)
// Status: deprecated | Level: high | ID: 098d8f77-476f-5e01-a3dc-3ce5fab18be2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
