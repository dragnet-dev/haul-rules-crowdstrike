// Dragnet [Ransomware]: dragnet-ransomware-2022-1293 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: cb6b000d-6001-5aa7-97aa-480f447ede01

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
