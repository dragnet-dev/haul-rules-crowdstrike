// Dragnet [Ransomware]: dragnet-ransomware-2021-1265 — Mass File Rename (medusalocker)
// Status: experimental | Level: high | ID: 69f468d1-4d35-5b7b-b507-9e447ab95f45

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
