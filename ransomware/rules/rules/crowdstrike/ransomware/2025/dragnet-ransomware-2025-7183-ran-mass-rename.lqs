// Dragnet [Ransomware]: dragnet-ransomware-2025-7183 — Mass File Rename (sarcoma)
// Status: deprecated | Level: high | ID: 37c71399-0b8d-5115-bbbb-3f8dcedeed26

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
