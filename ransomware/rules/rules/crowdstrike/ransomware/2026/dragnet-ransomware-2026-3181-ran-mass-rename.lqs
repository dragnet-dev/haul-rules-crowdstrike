// Dragnet [Ransomware]: dragnet-ransomware-2026-3181 — Mass File Rename (handala)
// Status: stable | Level: high | ID: c6e95f07-c0e6-5fce-9521-0b8ca4729575

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
