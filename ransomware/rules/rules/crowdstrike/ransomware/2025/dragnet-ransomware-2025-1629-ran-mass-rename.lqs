// Dragnet [Ransomware]: dragnet-ransomware-2025-1629 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 2011d62f-545e-5292-a81d-6ea3f1947571

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
