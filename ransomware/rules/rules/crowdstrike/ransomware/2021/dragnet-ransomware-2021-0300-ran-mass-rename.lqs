// Dragnet [Ransomware]: dragnet-ransomware-2021-0300 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: c7e1222c-be18-54f2-a86f-d4fc920b5c63

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
