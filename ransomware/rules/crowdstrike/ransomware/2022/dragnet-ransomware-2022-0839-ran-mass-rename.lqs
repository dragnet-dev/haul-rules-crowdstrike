// Dragnet [Ransomware]: dragnet-ransomware-2022-0839 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: c0fd8524-ae3a-5adb-a91d-10b667043a0d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
