// Dragnet [Ransomware]: dragnet-ransomware-2025-4393 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: c3ddc8ce-91dc-56dc-b0b3-6115123a3f41

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
