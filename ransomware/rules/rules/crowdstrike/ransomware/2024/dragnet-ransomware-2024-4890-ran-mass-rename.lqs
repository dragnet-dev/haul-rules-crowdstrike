// Dragnet [Ransomware]: dragnet-ransomware-2024-4890 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: 0f581ec8-6b88-5b92-9a30-d3844c71a971

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
