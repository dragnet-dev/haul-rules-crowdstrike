// Dragnet [Ransomware]: dragnet-ransomware-2025-2206 — Mass File Rename (devman)
// Status: deprecated | Level: high | ID: c2e7887b-d999-5262-a3ed-776b2e0474ef

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
