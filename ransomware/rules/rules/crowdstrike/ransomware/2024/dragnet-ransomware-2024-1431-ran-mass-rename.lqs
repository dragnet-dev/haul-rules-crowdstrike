// Dragnet [Ransomware]: dragnet-ransomware-2024-1431 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: c0862f04-c53d-5178-a6a0-d662ae5f9e11

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
