// Dragnet [Ransomware]: dragnet-ransomware-2023-0964 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 1c3e3dc6-8c5a-5016-80d5-cefd93081283

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
