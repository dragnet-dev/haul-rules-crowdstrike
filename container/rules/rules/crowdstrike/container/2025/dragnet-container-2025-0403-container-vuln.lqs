// Dragnet [Container]: dragnet-container-2025-0403 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: cfbec67f-66ac-5979-bc87-ade9e6f12aea

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *ubuntu:18.04-ESM* OR ImageFileName = *ubuntu:22.04*)
| table([timestamp, ComputerName])
| limit(1000)
