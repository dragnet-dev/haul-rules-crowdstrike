// Dragnet [Ransomware]: dragnet-ransomware-2021-0259 — Mass File Rename (blackmatter)
// Status: deprecated | Level: high | ID: 5c45d0b8-783f-5add-a945-f18cb26e69e7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
