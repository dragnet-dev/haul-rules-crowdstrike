// Dragnet [Ransomware]: dragnet-ransomware-2023-0814 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 62d8bc91-44f7-5e95-aa78-6fa5649413f5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
