// Dragnet [Ransomware]: dragnet-ransomware-2025-7349 — Mass File Rename (devman)
// Status: experimental | Level: high | ID: 451c541c-b644-55f3-9001-779801bc4bae

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
