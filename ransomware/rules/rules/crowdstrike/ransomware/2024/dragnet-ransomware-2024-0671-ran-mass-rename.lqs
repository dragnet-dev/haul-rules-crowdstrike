// Dragnet [Ransomware]: dragnet-ransomware-2024-0671 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 607c5c17-a167-5e7d-81b6-df471a0f3bd2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
