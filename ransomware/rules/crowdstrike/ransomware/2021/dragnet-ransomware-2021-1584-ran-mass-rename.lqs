// Dragnet [Ransomware]: dragnet-ransomware-2021-1584 — Mass File Rename (lockdata)
// Status: deprecated | Level: high | ID: 99d0e835-fa51-5e02-aa78-9bc1e06652a4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
