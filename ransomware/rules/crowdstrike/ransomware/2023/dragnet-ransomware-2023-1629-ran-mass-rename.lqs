// Dragnet [Ransomware]: dragnet-ransomware-2023-1629 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 254ca63a-d39b-55e3-87f7-2a30cbec4256

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
