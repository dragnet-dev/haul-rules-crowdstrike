// Dragnet [Ransomware]: dragnet-ransomware-2024-0229 — Mass File Rename (play)
// Status: experimental | Level: high | ID: a6639ac7-2ac5-5807-bc75-e2d73401e8b9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
