// Dragnet [Ransomware]: dragnet-ransomware-2021-1078 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 15d4d0fe-9c1c-5432-a1e5-76c9d25e987a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
