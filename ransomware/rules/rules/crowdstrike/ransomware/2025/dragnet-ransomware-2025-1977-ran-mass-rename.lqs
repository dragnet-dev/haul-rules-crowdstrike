// Dragnet [Ransomware]: dragnet-ransomware-2025-1977 — Mass File Rename (arcusmedia)
// Status: experimental | Level: high | ID: ca361035-0830-5298-be13-30090f6c04bd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
