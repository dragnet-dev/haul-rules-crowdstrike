// Dragnet [Ransomware]: dragnet-ransomware-2023-4560 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 752af019-4f3c-56ca-9b70-19c24e4e43fc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
