// Dragnet [Ransomware]: dragnet-ransomware-2022-2947 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: 76b3f24e-42d4-5b8f-9283-4487b49b6a6b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
