// Dragnet [Ransomware]: dragnet-ransomware-2022-1949 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: f94a16c1-de41-55fe-96b1-4f6c9a27ca04

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
