// Dragnet [Ransomware]: dragnet-ransomware-2026-0432 — Mass File Rename (dragonforce)
// Status: stable | Level: high | ID: 0d65382f-a221-5e5f-8471-0605c6839e90

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
