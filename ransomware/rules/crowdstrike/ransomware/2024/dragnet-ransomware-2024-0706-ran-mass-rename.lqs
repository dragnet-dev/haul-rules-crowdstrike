// Dragnet [Ransomware]: dragnet-ransomware-2024-0706 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: cea542cb-3efd-53ef-bb2b-bea539eff254

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
