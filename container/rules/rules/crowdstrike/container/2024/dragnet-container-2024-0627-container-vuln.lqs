// Dragnet [Container]: dragnet-container-2024-0627 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 556ff0df-6cfb-5cc8-af24-75adafb71842

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
