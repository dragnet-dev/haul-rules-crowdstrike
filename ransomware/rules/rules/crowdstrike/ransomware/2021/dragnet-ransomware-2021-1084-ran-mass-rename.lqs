// Dragnet [Ransomware]: dragnet-ransomware-2021-1084 — Mass File Rename (ragnarlocker)
// Status: deprecated | Level: high | ID: b196d780-c5d0-56ab-851b-982a1ca3e581

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
