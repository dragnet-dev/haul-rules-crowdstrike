// Dragnet [Ransomware]: dragnet-ransomware-2025-6832 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 510b858f-3dbe-5b6f-a012-dd29f05748be

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
