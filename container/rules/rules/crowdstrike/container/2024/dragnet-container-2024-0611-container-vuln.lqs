// Dragnet [Container]: dragnet-container-2024-0611 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: f8d5056e-d54b-56bd-9f0a-898881a55545

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:9* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:18.04* OR ImageFileName = *ubuntu:18.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
