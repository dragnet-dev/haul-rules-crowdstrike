// Dragnet [Ransomware]: dragnet-ransomware-2026-0439 — Mass File Rename (lockbit5)
// Status: stable | Level: high | ID: 952c7325-60ea-565c-95c1-f4e497f23c61

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
