// Dragnet [Ransomware]: dragnet-ransomware-2022-1039 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: a7f83561-f72a-55f7-a592-460238e9e003

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
