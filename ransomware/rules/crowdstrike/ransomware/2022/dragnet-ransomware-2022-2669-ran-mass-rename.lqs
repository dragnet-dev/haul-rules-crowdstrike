// Dragnet [Ransomware]: dragnet-ransomware-2022-2669 — Mass File Rename (karakurt)
// Status: experimental | Level: high | ID: fd12e121-d39a-5699-9dea-c7fdd48cb091

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
