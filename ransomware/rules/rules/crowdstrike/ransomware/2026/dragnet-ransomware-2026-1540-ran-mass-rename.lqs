// Dragnet [Ransomware]: dragnet-ransomware-2026-1540 — Mass File Rename (incransom)
// Status: stable | Level: high | ID: 6e13bc8f-a269-5d8a-acd0-13be1f93f245

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
