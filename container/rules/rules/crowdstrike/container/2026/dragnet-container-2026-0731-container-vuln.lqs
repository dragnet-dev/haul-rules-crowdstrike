// Dragnet [Container]: dragnet-container-2026-0731 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: ab210c73-2cfb-5b81-992b-6eb14b9639db

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
