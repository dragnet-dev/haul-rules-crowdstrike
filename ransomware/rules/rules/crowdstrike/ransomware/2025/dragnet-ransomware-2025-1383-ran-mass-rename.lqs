// Dragnet [Ransomware]: dragnet-ransomware-2025-1383 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 477df23b-b3fe-5491-b521-c188c84bf94a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
