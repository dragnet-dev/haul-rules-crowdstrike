// Dragnet [Ransomware]: dragnet-ransomware-2022-3074 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: ae179e57-9331-58d9-a329-180cf9143dd6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
