// Dragnet [Ransomware]: dragnet-ransomware-2022-0093 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: bf3b597a-1301-5cf2-9b5c-a37faa26f0a4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
