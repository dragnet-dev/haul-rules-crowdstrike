// Dragnet [Ransomware]: dragnet-ransomware-2025-1844 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: da450ff4-572b-5499-84ac-67df1faec4b7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
