// Dragnet [Ransomware]: dragnet-ransomware-2024-2098 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 4b29a8d4-7d99-5a3f-a4bf-a091204c2dbb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
