// Dragnet [Ransomware]: dragnet-ransomware-2025-6371 — Mass File Rename (lockbit5)
// Status: test | Level: high | ID: a3e8c5db-3efb-5664-998e-59f6f0a528ab

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
