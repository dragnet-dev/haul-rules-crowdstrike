// Dragnet [Ransomware]: dragnet-ransomware-2023-1557 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 52c5c05a-110a-5a9d-b7c4-f6e94323da95

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
