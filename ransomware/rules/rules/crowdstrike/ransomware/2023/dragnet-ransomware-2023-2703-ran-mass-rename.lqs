// Dragnet [Ransomware]: dragnet-ransomware-2023-2703 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: d06e0ba5-4a97-55db-9b7f-551faf792be7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
