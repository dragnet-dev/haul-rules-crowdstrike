// Dragnet [Ransomware]: dragnet-ransomware-2022-2291 — Mass File Rename (karakurt)
// Status: experimental | Level: high | ID: 20293c67-8c71-5329-a0f7-8a03bc9c4947

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
