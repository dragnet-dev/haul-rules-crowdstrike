// Dragnet [Ransomware]: dragnet-ransomware-2022-1411 — Mass File Rename (karakurt)
// Status: deprecated | Level: high | ID: ab195e55-aa8e-51ed-bda8-4955073a9cde

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
