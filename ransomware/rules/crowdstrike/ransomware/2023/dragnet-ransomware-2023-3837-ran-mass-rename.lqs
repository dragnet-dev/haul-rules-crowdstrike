// Dragnet [Ransomware]: dragnet-ransomware-2023-3837 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 1ade6658-5b5c-5a71-98ea-93c4b7a25f25

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
