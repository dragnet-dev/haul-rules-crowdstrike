// Dragnet [Ransomware]: dragnet-ransomware-2026-3161 — Mass File Rename (incransom)
// Status: test | Level: high | ID: aac8656e-88da-5b65-990d-c56a8a79cba0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
