// Dragnet [Ransomware]: dragnet-ransomware-2022-0974 — Mass File Rename (royal)
// Status: deprecated | Level: high | ID: d0f69abc-6292-5b21-aa9e-5255412717ce

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
