// Dragnet [Ransomware]: dragnet-ransomware-2024-4887 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 860560a1-d77a-5106-a727-33e748444e39

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
