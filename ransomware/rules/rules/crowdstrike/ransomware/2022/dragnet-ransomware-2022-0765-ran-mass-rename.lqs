// Dragnet [Ransomware]: dragnet-ransomware-2022-0765 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 2742509b-bed1-557d-9fd2-6e3dfd73efc5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
