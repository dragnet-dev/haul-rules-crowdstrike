// Dragnet [Ransomware]: dragnet-ransomware-2026-0164 — Mass File Rename (insomnia)
// Status: stable | Level: high | ID: 11c4c677-7961-54c3-bea5-815ecbb719a8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
