// Dragnet [Ransomware]: dragnet-ransomware-2025-1268 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: feef645c-7390-5c44-9feb-576cd0705383

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
