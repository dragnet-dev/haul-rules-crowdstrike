// Dragnet [Ransomware]: dragnet-ransomware-2023-1292 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 4ce9fd0e-92d4-5e92-b110-8ba71a9c04dd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
