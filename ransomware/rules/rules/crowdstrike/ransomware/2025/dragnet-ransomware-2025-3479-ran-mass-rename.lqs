// Dragnet [Ransomware]: dragnet-ransomware-2025-3479 — Mass File Rename (warlock)
// Status: experimental | Level: high | ID: 8803aeba-2d89-5c1f-9a1e-5b4cd8b80e48

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
