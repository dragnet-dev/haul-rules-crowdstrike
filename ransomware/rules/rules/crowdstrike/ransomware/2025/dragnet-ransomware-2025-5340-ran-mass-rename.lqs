// Dragnet [Ransomware]: dragnet-ransomware-2025-5340 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 73b17cab-8c6d-515a-8fc0-31a6d09336df

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
