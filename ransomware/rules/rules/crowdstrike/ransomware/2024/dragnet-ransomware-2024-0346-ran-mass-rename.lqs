// Dragnet [Ransomware]: dragnet-ransomware-2024-0346 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 07f8993b-e811-5f2f-afe4-faf466e91bce

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
