// Dragnet [Ransomware]: dragnet-ransomware-2021-0406 — Mass File Rename (xinglocker)
// Status: deprecated | Level: high | ID: 998e61ec-1890-5baf-80e8-c78e5cf7e5e3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
