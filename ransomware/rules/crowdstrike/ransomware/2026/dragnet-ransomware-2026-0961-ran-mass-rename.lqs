// Dragnet [Ransomware]: dragnet-ransomware-2026-0961 — Mass File Rename (bravox)
// Status: stable | Level: high | ID: f6f854b2-77aa-564d-abf0-66a56da8aa50

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
