// Dragnet [Ransomware]: dragnet-ransomware-2025-0734 — Mass File Rename (spacebears)
// Status: experimental | Level: high | ID: 656da195-4eab-5e13-bc46-b38090679cc3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
