// Dragnet [Ransomware]: dragnet-ransomware-2025-6162 — Mass File Rename (devman)
// Status: experimental | Level: high | ID: 6eabbdd0-80eb-5b8a-b8b8-5040860266ac

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
