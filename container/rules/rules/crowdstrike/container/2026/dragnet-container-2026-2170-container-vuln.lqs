// Dragnet [Container]: dragnet-container-2026-2170 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 58229f20-27b3-54da-9d56-b5b18bd37964

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:7*)
| table([timestamp, ComputerName])
| limit(1000)
