// Dragnet [Ransomware]: dragnet-ransomware-2024-3904 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: dfa80e13-58d3-5f88-bb66-fdb27dbe3694

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
