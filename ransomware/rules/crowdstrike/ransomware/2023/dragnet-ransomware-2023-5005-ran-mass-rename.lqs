// Dragnet [Ransomware]: dragnet-ransomware-2023-5005 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: c223ec95-427e-5050-a685-96021570c1c0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
