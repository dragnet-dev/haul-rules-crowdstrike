// Dragnet [Ransomware]: dragnet-ransomware-2022-0676 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 7b9dd495-5a8a-567c-81ef-37a821189ed8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
