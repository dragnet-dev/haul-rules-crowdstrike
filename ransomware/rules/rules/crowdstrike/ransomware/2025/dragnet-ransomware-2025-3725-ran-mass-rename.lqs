// Dragnet [Ransomware]: dragnet-ransomware-2025-3725 — Mass File Rename (sinobi)
// Status: experimental | Level: high | ID: ade17e4c-2cfd-542f-b359-c528d1618004

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
