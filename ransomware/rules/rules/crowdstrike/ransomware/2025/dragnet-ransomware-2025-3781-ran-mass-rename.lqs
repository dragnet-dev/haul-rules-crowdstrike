// Dragnet [Ransomware]: dragnet-ransomware-2025-3781 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 84fe7430-4d1f-5947-be58-95ce30e3770f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
