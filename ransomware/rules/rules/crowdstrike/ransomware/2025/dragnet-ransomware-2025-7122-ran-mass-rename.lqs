// Dragnet [Ransomware]: dragnet-ransomware-2025-7122 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 9229e3f5-984a-58a6-8698-06e1b0022ecf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
