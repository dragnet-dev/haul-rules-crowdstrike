// Dragnet [Ransomware]: dragnet-ransomware-2025-5997 — Mass File Rename (arcusmedia)
// Status: experimental | Level: high | ID: 88e314ba-fda9-5737-9fec-600978487b41

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
