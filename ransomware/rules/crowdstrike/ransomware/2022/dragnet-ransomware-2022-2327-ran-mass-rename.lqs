// Dragnet [Ransomware]: dragnet-ransomware-2022-2327 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 5ffc85ff-9ce2-55e2-9c82-513dc7248d7b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
