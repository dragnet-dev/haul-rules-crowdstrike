// Dragnet [Ransomware]: dragnet-ransomware-2022-2767 — Mass File Rename (blackbasta)
// Status: deprecated | Level: high | ID: 74d5b660-4e72-5acc-a061-d924d0b4fdba

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
