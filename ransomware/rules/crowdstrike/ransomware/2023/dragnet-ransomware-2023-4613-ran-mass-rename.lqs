// Dragnet [Ransomware]: dragnet-ransomware-2023-4613 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: d9e9c721-644e-50e2-9250-0f879544f0a8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
