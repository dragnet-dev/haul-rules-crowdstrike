// Dragnet [Ransomware]: dragnet-ransomware-2024-2229 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 6c705e2b-2a26-5954-9e94-3a1a8dbe4064

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
