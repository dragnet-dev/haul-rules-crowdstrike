// Dragnet [Ransomware]: dragnet-ransomware-2025-3569 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 1f4da989-bba0-565b-a8bb-3fc7647dcd28

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
