// Dragnet [Ransomware]: dragnet-ransomware-2025-5043 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 750e6da0-c0cf-5cf3-96e7-ebd027b20878

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
