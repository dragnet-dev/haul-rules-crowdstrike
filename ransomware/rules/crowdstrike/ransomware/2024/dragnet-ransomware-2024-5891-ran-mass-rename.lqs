// Dragnet [Ransomware]: dragnet-ransomware-2024-5891 — Mass File Rename (helldown)
// Status: experimental | Level: high | ID: 09b626f6-e603-57ab-8380-4c3366bff804

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
