// Dragnet [Ransomware]: dragnet-ransomware-2023-5251 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: c7c139dc-211f-500b-ba9b-e6325c1ce012

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
