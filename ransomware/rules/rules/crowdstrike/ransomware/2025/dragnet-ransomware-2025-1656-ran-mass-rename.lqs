// Dragnet [Ransomware]: dragnet-ransomware-2025-1656 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 059dfe3f-abcc-569d-894a-611ec29a04a8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
