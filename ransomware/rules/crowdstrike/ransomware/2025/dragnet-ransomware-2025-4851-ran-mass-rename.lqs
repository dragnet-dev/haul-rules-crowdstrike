// Dragnet [Ransomware]: dragnet-ransomware-2025-4851 — Mass File Rename (devman)
// Status: deprecated | Level: high | ID: 7b93d645-318a-5299-b31f-2c081ee2a1ab

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
