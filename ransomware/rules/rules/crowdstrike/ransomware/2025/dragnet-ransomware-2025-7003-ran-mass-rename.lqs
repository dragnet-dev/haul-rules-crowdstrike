// Dragnet [Ransomware]: dragnet-ransomware-2025-7003 — Mass File Rename (payoutsking)
// Status: experimental | Level: high | ID: 046311fd-fef1-537b-a22b-24aada3a61bf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
