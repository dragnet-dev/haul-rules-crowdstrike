// Dragnet [Container]: dragnet-container-2026-0729 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 2b07727b-8559-5c6d-b74b-3146e6b524a0

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:8* OR ImageFileName = *debian:9*)
| table([timestamp, ComputerName])
| limit(1000)
