// Dragnet [Ransomware]: dragnet-ransomware-2023-1635 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: d4f74384-5edf-5a23-8c1e-79cfd7bee332

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
