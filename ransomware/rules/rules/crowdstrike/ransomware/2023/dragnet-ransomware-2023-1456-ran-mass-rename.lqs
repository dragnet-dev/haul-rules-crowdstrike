// Dragnet [Ransomware]: dragnet-ransomware-2023-1456 — Mass File Rename (siegedsec)
// Status: experimental | Level: high | ID: 9afd4227-3896-574d-a04e-de9d15f9ff07

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
