// Dragnet [Ransomware]: dragnet-ransomware-2025-5988 — Mass File Rename (nova)
// Status: experimental | Level: high | ID: 76b6cb99-83a5-56e5-844d-8818b6b65c7e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
