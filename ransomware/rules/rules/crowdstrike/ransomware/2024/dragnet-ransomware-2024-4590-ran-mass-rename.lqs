// Dragnet [Ransomware]: dragnet-ransomware-2024-4590 — Mass File Rename (spacebears)
// Status: experimental | Level: high | ID: 1527fefc-ff11-569e-80fc-92012a79d736

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
