// Dragnet [Container]: dragnet-container-2026-1066 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 9e59e4c4-4e28-5225-b42f-07842fb10b7e

#event_simpleName=*
| (ImageFileName = *chainguard:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
