// Dragnet [Ransomware]: dragnet-ransomware-2025-5443 — Mass File Rename (handala)
// Status: experimental | Level: high | ID: 30c5234f-e829-5b77-a98a-71e11f393cd3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
