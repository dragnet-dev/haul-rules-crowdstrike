// Dragnet [Ransomware]: dragnet-ransomware-2024-5764 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 28d26362-ed07-5231-b4e1-940271a4644b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
