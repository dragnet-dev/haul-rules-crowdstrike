// Dragnet [Ransomware]: dragnet-ransomware-2025-6192 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: f6271a18-fc0f-506a-b871-37b394db388c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
