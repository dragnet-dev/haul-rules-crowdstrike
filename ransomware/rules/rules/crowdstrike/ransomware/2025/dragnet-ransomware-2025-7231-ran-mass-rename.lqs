// Dragnet [Ransomware]: dragnet-ransomware-2025-7231 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: cc1cde5a-5e69-5eda-9555-194d5d5d85cd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
