// Dragnet [Ransomware]: dragnet-ransomware-2023-2645 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 614c6587-79fa-5d7a-ad56-bb9b6baa1def

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
