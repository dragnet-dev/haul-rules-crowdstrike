// Dragnet [Container]: dragnet-container-2026-0159 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 1995a8ff-d1a3-5f1d-bfc0-ed2fce5b1163

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6*)
| table([timestamp, ComputerName])
| limit(1000)
