// Dragnet [Ransomware]: dragnet-ransomware-2025-4055 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: 52e842eb-88fb-5dfb-9dfc-81787210ad00

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
