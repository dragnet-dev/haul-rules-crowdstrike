// Dragnet [Ransomware]: dragnet-ransomware-2024-3234 — Mass File Rename (abyss)
// Status: deprecated | Level: high | ID: ff6d31ef-1531-5a70-937a-8d373370d2aa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
