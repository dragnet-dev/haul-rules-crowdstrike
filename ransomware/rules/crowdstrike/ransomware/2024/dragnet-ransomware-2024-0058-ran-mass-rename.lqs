// Dragnet [Ransomware]: dragnet-ransomware-2024-0058 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: 5f5b1ec6-c87c-5fd3-a8fb-57d5ab6ae82a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
