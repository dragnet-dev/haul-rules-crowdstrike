// Dragnet [Ransomware]: dragnet-ransomware-2024-4326 — Mass File Rename (apt73)
// Status: experimental | Level: high | ID: 304c648c-8bb6-5d47-9b3d-7cde0e1708aa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
