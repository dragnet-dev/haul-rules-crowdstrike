// Dragnet [Ransomware]: dragnet-ransomware-2024-0035 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: c867417a-b26b-586c-8f65-1fa434a7ba63

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
