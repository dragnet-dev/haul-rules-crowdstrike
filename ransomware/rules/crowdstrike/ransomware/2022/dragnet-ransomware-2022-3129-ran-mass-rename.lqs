// Dragnet [Ransomware]: dragnet-ransomware-2022-3129 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 9be1a3f0-caed-5e18-9f00-cab1655145ef

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
