// Dragnet [Container]: dragnet-container-2024-0826 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 243c060d-de0f-5e92-b5f8-be8c976f7697

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:8* OR ImageFileName = *debian:9* OR ImageFileName = *ubuntu:18.04-ESM* OR ImageFileName = *ubuntu:20.04-ESM* OR ImageFileName = *ubuntu:22.04*)
| table([timestamp, ComputerName])
| limit(1000)
