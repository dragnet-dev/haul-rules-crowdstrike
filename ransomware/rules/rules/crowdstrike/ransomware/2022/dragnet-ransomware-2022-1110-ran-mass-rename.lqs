// Dragnet [Ransomware]: dragnet-ransomware-2022-1110 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: d9329209-4b00-50f9-89f5-2fabad5ea7bb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
