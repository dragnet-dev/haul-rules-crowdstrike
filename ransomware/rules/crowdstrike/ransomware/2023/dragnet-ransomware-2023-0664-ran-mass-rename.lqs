// Dragnet [Ransomware]: dragnet-ransomware-2023-0664 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 22819ab9-124b-5079-a7f5-3f3c2d977dec

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
