// Dragnet [Ransomware]: dragnet-ransomware-2024-4585 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: e13c6991-b54a-5978-8ad2-6fa106b021ca

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
