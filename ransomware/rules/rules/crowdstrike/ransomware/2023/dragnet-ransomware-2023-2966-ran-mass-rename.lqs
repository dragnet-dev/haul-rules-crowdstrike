// Dragnet [Ransomware]: dragnet-ransomware-2023-2966 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 3e3b0c07-07b6-5f29-9b6f-1e56fd3f666c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
