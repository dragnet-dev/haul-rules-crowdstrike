// Dragnet [Ransomware]: dragnet-ransomware-2023-3402 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: ed2684e7-42d8-5781-ae4a-1741288b81ac

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
