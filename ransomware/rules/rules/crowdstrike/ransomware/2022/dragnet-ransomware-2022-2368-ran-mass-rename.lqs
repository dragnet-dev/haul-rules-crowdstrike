// Dragnet [Ransomware]: dragnet-ransomware-2022-2368 — Mass File Rename (everest)
// Status: deprecated | Level: high | ID: f328baf0-731b-52a0-a2e2-f0121d5898f1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
