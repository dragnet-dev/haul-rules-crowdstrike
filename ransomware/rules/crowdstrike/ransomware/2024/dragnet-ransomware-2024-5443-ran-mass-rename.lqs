// Dragnet [Ransomware]: dragnet-ransomware-2024-5443 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: b18ebe0a-2457-58d6-bf60-d73c816863b7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
