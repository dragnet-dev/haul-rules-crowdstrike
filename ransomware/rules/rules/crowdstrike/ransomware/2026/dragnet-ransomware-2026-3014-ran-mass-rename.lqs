// Dragnet [Ransomware]: dragnet-ransomware-2026-3014 — Mass File Rename (nightspire)
// Status: deprecated | Level: high | ID: 8b909f6b-c0f6-51e6-ba00-efc1622cc925

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
