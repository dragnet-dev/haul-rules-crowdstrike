// Dragnet [Ransomware]: dragnet-ransomware-2025-7209 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 9ce6fbc8-8a9a-5fab-ae3b-bcb608c19e08

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
