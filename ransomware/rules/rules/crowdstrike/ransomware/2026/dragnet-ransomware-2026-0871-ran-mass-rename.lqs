// Dragnet [Ransomware]: dragnet-ransomware-2026-0871 — Mass File Rename (thegentlemen)
// Status: deprecated | Level: high | ID: 63fcdcbb-e32e-5f75-a92a-4f0a9b17acb1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
