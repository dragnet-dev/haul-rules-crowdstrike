// Dragnet [Ransomware]: dragnet-ransomware-2024-4202 — Mass File Rename (donutleaks)
// Status: experimental | Level: high | ID: efe635e9-9929-58d9-bda0-e60b5aeb77fd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
