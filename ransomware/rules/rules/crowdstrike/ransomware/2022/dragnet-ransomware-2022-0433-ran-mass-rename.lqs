// Dragnet [Ransomware]: dragnet-ransomware-2022-0433 — Mass File Rename (blackbasta)
// Status: deprecated | Level: high | ID: 1b108c9f-6e11-558f-a1d5-889c990df36e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
