// Dragnet [Ransomware]: dragnet-ransomware-2025-2947 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: a64b8224-0ae7-5455-905a-0780c8309068

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
