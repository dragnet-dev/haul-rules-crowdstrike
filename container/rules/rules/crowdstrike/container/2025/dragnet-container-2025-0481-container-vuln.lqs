// Dragnet [Container]: dragnet-container-2025-0481 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 81e207ad-07f8-5ebd-8d88-ac54a5fa108d

#event_simpleName=*
| (ImageFileName = *amazonlinux:2* OR ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:9* OR ImageFileName = *oraclelinux:7* OR ImageFileName = *ubuntu:14.04-ESM* OR ImageFileName = *ubuntu:16.04-ESM* OR ImageFileName = *ubuntu:18.04* OR ImageFileName = *ubuntu:18.04-ESM* OR ImageFileName = *ubuntu:20.04* OR ImageFileName = *ubuntu:20.04-ESM* OR ImageFileName = *ubuntu:20.10*)
| table([timestamp, ComputerName])
| limit(1000)
