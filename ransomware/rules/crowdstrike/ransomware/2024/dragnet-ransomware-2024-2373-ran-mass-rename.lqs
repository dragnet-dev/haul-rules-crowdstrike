// Dragnet [Ransomware]: dragnet-ransomware-2024-2373 — Mass File Rename (rhysida)
// Status: deprecated | Level: high | ID: 2861295e-2954-5916-aecc-41efdf1baeb7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
