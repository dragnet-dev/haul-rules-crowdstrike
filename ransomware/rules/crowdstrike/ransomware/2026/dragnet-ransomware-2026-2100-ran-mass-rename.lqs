// Dragnet [Ransomware]: dragnet-ransomware-2026-2100 — Mass File Rename (anubis)
// Status: stable | Level: high | ID: 6420221d-113c-53f3-87d0-0538b43d8a22

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
