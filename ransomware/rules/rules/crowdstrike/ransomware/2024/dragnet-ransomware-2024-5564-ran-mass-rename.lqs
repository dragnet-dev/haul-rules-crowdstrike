// Dragnet [Ransomware]: dragnet-ransomware-2024-5564 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 449a7ca2-40dc-5f14-b9e5-119f9b973747

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
