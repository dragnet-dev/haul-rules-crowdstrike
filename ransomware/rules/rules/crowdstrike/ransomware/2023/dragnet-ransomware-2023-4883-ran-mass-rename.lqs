// Dragnet [Ransomware]: dragnet-ransomware-2023-4883 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: a528a7f5-d4d5-5df7-9053-0dd31b0bede7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
