// Dragnet [Ransomware]: dragnet-ransomware-2024-4381 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: f43bcd79-5635-5fa4-81cf-acb1c90c2f68

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
