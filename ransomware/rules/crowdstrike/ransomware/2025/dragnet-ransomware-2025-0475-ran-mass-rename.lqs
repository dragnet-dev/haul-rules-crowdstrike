// Dragnet [Ransomware]: dragnet-ransomware-2025-0475 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: d71d537a-3bc8-5f97-ad99-a4fe7ac01a6b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
