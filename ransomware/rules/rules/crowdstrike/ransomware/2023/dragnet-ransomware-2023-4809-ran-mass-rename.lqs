// Dragnet [Ransomware]: dragnet-ransomware-2023-4809 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 550da928-a05f-5cf7-a42c-5b5e8a84f62b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
