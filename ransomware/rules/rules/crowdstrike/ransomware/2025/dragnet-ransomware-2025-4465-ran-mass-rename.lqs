// Dragnet [Ransomware]: dragnet-ransomware-2025-4465 — Mass File Rename (nightspire)
// Status: deprecated | Level: high | ID: 3051f042-10ac-5496-92d7-2cf7c5902775

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
