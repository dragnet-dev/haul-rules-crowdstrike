// Dragnet [Ransomware]: dragnet-ransomware-2024-1033 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 5b729fe7-91ab-5a77-8230-32af8e17217f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
