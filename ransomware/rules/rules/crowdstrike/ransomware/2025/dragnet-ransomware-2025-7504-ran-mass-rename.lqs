// Dragnet [Ransomware]: dragnet-ransomware-2025-7504 — Mass File Rename (obscura)
// Status: experimental | Level: high | ID: e8841a95-678c-5f9b-b708-5d91ed81c624

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
