// Dragnet [Ransomware]: dragnet-ransomware-2024-3602 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 41eb2284-5b4b-5968-a25e-1800728fa0ef

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
