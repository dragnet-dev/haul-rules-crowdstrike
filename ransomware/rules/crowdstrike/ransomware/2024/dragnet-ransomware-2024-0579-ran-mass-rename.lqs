// Dragnet [Ransomware]: dragnet-ransomware-2024-0579 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: c9232d26-4871-5295-a61e-f516aed8d883

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
