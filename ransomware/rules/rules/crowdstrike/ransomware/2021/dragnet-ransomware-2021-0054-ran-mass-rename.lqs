// Dragnet [Ransomware]: dragnet-ransomware-2021-0054 — Mass File Rename (avaddon)
// Status: deprecated | Level: high | ID: c90ef657-a2aa-5fa9-9acc-5e7095c2786d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
