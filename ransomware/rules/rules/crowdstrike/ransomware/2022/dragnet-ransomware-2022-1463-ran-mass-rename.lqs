// Dragnet [Ransomware]: dragnet-ransomware-2022-1463 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 0ffe058c-b3b2-512e-adf8-b5dc1db07493

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
