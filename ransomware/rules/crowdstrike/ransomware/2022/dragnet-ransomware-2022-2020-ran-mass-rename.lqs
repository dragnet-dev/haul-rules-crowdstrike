// Dragnet [Ransomware]: dragnet-ransomware-2022-2020 — Mass File Rename (lv)
// Status: deprecated | Level: high | ID: 92f518f8-d4fb-53f5-9465-b384e78106f1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
