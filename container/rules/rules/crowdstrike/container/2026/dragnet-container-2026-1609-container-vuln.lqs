// Dragnet [Container]: dragnet-container-2026-1609 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 38acdfe2-f25e-5a3e-b9b4-03746990f831

#event_simpleName=*
| (ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *redhat/ubi9:*)
| table([timestamp, ComputerName])
| limit(1000)
