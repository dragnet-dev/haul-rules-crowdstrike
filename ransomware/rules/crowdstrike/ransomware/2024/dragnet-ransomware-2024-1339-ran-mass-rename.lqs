// Dragnet [Ransomware]: dragnet-ransomware-2024-1339 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: 30a422c9-d28d-5421-b02f-f3c9b9c5c239

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
