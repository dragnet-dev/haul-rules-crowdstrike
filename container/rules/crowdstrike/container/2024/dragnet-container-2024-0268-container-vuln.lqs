// Dragnet [Container]: dragnet-container-2024-0268 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: ac995702-9d98-5f51-a468-f87ad00383b7

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *ubuntu:18.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
