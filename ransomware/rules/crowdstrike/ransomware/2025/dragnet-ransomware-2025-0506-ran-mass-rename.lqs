// Dragnet [Ransomware]: dragnet-ransomware-2025-0506 — Mass File Rename (nova)
// Status: experimental | Level: high | ID: bfdd325e-9d9c-56c7-8fee-b1a10a90f0b8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
