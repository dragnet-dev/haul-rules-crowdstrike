// Dragnet [Ransomware]: dragnet-ransomware-2025-7410 — Mass File Rename (kairos)
// Status: experimental | Level: high | ID: fec6d49a-47c3-51ba-b870-d641c0ca0edb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
