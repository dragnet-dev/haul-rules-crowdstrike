// Dragnet [Ransomware]: dragnet-ransomware-2021-1494 — Mass File Rename (ransomexx)
// Status: deprecated | Level: high | ID: 5822104b-8e3f-5abf-9fbd-166206112a7e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
