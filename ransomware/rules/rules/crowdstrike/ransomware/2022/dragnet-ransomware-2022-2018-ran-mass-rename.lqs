// Dragnet [Ransomware]: dragnet-ransomware-2022-2018 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 49bb3e8a-c28e-574d-9167-80f7fec51fcb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
