// Dragnet [Ransomware]: dragnet-ransomware-2023-1799 — Mass File Rename (termite)
// Status: experimental | Level: high | ID: d597574b-5410-5d5d-b74e-f2e59fc58860

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
