// Dragnet [Ransomware]: dragnet-ransomware-2020-0177 — Mass File Rename (maze)
// Status: deprecated | Level: high | ID: aebc0610-fb6f-5291-ae11-7f11a497eb05

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
