// Dragnet [Container]: dragnet-container-2024-1500 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: c8d14554-2ff5-527e-b94a-0564032deda6

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:9* OR ImageFileName = *ubuntu:18.04-ESM* OR ImageFileName = *ubuntu:20.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
