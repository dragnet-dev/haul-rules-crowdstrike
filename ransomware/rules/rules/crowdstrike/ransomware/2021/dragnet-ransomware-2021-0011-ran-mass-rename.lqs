// Dragnet [Ransomware]: dragnet-ransomware-2021-0011 — Mass File Rename (avaddon)
// Status: deprecated | Level: high | ID: 3e65acce-9f4c-589b-af01-b01c4bf6abd6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
