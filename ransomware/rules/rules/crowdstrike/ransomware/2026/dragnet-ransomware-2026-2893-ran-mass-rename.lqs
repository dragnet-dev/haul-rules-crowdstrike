// Dragnet [Ransomware]: dragnet-ransomware-2026-2893 — Mass File Rename (stormous)
// Status: deprecated | Level: high | ID: 72c5f273-3f28-56c7-a97b-ce2c9d468bc2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
