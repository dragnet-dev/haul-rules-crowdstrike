// Dragnet [Ransomware]: dragnet-ransomware-2025-6597 — Mass File Rename (J)
// Status: experimental | Level: high | ID: 47647041-7483-5ca4-a599-1af554103a12

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
