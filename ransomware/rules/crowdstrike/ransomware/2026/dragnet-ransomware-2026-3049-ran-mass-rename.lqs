// Dragnet [Ransomware]: dragnet-ransomware-2026-3049 — Mass File Rename (dragonforce)
// Status: stable | Level: high | ID: 4ea0ab84-1f56-5e4f-ba90-786724c94689

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
