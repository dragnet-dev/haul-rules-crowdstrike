// Dragnet [Ransomware]: dragnet-ransomware-2022-2928 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 9aa83aa5-6a45-58fd-87d7-f148e785756a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
