// Dragnet [Ransomware]: dragnet-ransomware-2025-5071 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 821f15d9-5483-52ce-bd05-b8dfce8d38d0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
