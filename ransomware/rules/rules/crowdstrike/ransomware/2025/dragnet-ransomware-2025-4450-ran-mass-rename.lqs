// Dragnet [Ransomware]: dragnet-ransomware-2025-4450 — Mass File Rename (devman)
// Status: experimental | Level: high | ID: 5e458e73-b347-5714-bb8f-f95af0b0025c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
