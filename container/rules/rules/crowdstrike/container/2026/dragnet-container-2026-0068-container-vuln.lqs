// Dragnet [Container]: dragnet-container-2026-0068 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 41f43e0e-5f56-5e94-8738-fa0dc21c820b

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:7* OR ImageFileName = *debian:8* OR ImageFileName = *debian:9* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:18.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
