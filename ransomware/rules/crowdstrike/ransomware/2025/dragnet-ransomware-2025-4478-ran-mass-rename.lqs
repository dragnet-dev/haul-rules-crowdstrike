// Dragnet [Ransomware]: dragnet-ransomware-2025-4478 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 61c1c789-36cc-5f41-8bd9-9ffa583cdab2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
