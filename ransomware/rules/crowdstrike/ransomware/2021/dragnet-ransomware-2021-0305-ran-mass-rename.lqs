// Dragnet [Ransomware]: dragnet-ransomware-2021-0305 — Mass File Rename (blacktor)
// Status: deprecated | Level: high | ID: 776b9165-35c4-5bfc-b733-2bbdbe113b1f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
