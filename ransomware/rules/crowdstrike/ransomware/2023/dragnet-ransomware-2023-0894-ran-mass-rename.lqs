// Dragnet [Ransomware]: dragnet-ransomware-2023-0894 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 302ff413-d2b0-5ffc-94c2-cdea8510b6d3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
