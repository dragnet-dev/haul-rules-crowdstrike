// Dragnet [Ransomware]: dragnet-ransomware-2023-1733 — Mass File Rename (ransomed)
// Status: experimental | Level: high | ID: b485f133-f31e-5f80-b153-b3064d9f6dba

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
