// Dragnet [Ransomware]: dragnet-ransomware-2023-3506 — Mass File Rename (abyss)
// Status: deprecated | Level: high | ID: 0f5a560a-d017-5461-b2f9-77a7dcd5ee41

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
