// Dragnet [Ransomware]: dragnet-ransomware-2025-2470 — Mass File Rename (thegentlemen)
// Status: test | Level: high | ID: 28dd9191-c5ac-5106-8208-2135343bd91f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
