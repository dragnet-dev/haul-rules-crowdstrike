// Dragnet [Ransomware]: dragnet-ransomware-2026-1837 — Mass File Rename (moneymessage)
// Status: stable | Level: high | ID: 45790e49-c96e-5afd-a6a4-8ac8a9d93194

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
