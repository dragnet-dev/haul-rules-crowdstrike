// Dragnet [Ransomware]: dragnet-ransomware-2025-2966 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 4618aaeb-7b8f-5669-b5a1-e956792de2e4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
