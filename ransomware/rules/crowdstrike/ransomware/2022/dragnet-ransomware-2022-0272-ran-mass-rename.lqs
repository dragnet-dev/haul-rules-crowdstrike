// Dragnet [Ransomware]: dragnet-ransomware-2022-0272 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 7f7c5103-961a-5be7-ab6a-dcaf9abcc011

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
