// Dragnet [Ransomware]: dragnet-ransomware-2024-2185 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 7547e07e-a0b1-5cb3-9c01-082abdead0a3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
