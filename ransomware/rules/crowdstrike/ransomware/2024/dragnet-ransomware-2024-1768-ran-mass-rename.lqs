// Dragnet [Ransomware]: dragnet-ransomware-2024-1768 — Mass File Rename (darkvault)
// Status: experimental | Level: high | ID: 72a4f894-52f8-5bfc-807a-fa5277b39bb3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
