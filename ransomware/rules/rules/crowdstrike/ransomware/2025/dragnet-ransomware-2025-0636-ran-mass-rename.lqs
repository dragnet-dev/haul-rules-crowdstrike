// Dragnet [Ransomware]: dragnet-ransomware-2025-0636 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 24ca96ac-c01c-5fb6-862d-f46a883c5043

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
