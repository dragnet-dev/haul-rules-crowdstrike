// Dragnet [Ransomware]: dragnet-ransomware-2023-3604 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: fe1efbf1-3280-586a-aede-e4966b7a203a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
