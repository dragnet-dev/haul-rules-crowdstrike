// Dragnet [Ransomware]: dragnet-ransomware-2022-0317 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 3e08422b-db64-51a8-8d3c-d63f4ce20776

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
