// Dragnet [Ransomware]: dragnet-ransomware-2024-4370 — Mass File Rename (rhysida)
// Status: deprecated | Level: high | ID: ef459c1c-72ed-526f-9798-17c1138a8283

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
