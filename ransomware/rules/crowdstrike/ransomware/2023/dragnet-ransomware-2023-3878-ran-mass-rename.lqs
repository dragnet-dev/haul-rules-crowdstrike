// Dragnet [Ransomware]: dragnet-ransomware-2023-3878 — Mass File Rename (play)
// Status: experimental | Level: high | ID: cd025fad-aba5-5ed1-a634-9f44fb89e722

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
