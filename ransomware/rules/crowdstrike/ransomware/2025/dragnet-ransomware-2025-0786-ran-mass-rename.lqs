// Dragnet [Ransomware]: dragnet-ransomware-2025-0786 — Mass File Rename (spacebears)
// Status: experimental | Level: high | ID: 69c6bd83-9097-5837-8f4e-0811fce16695

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
