// Dragnet [Ransomware]: dragnet-ransomware-2023-2735 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 22c18f24-8f23-5068-8ff0-9b1a67653369

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
