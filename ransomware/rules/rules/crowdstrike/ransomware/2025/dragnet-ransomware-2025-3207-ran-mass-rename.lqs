// Dragnet [Ransomware]: dragnet-ransomware-2025-3207 — Mass File Rename (VanHelsing)
// Status: experimental | Level: high | ID: c3134111-20f3-5757-bfc6-e76ea64829f3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
