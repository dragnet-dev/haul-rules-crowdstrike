// Dragnet [Ransomware]: dragnet-ransomware-2021-1246 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 14ea82ba-e113-5184-bca2-2c5f339fa0bf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
