// Dragnet [Ransomware]: dragnet-ransomware-2025-4404 — Mass File Rename (interlock)
// Status: test | Level: high | ID: e881f84b-58ca-5d7f-bb16-70adf11401ff

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
