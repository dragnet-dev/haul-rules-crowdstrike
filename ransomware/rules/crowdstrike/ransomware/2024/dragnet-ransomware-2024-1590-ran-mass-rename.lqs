// Dragnet [Ransomware]: dragnet-ransomware-2024-1590 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 367e68d9-9dca-51a6-a13c-ec36437a94be

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
