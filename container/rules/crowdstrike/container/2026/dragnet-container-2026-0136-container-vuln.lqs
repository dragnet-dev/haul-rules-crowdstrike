// Dragnet [Container]: dragnet-container-2026-0136 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: cbbc1c15-2a55-5bc5-89ed-5690e5ff02aa

#event_simpleName=*
| (ImageFileName = *amazonlinux:1* OR ImageFileName = *debian:7* OR ImageFileName = *debian:8* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:14.04* OR ImageFileName = *ubuntu:14.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
