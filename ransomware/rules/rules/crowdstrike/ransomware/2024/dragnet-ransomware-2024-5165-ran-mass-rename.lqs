// Dragnet [Ransomware]: dragnet-ransomware-2024-5165 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 9f674593-832c-5e3f-92b1-35919631e287

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
