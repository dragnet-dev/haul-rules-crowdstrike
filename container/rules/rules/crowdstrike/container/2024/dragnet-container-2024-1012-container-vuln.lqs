// Dragnet [Container]: dragnet-container-2024-1012 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 9017ce8c-1cc5-5a47-b12b-0286531afb4b

#event_simpleName=*
| (ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:18.04-ESM* OR ImageFileName = *ubuntu:20.04-ESM* OR ImageFileName = *ubuntu:22.04* OR ImageFileName = *ubuntu:24.04*)
| table([timestamp, ComputerName])
| limit(1000)
