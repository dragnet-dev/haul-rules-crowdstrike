// Dragnet [Ransomware]: dragnet-ransomware-2025-2615 — Mass File Rename (devman)
// Status: experimental | Level: high | ID: f3a000b2-789c-55e2-a574-25c936a3ae57

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
