// Dragnet [Container]: dragnet-container-2025-0520 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: a42471c3-84dc-5324-ad89-b7d390bce033

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *redhat/ubi9:*)
| table([timestamp, ComputerName])
| limit(1000)
