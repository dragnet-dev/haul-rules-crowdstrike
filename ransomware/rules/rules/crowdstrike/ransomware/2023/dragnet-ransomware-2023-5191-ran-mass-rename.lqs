// Dragnet [Ransomware]: dragnet-ransomware-2023-5191 — Mass File Rename (royal)
// Status: experimental | Level: high | ID: 71af5e30-fabb-5dfa-8353-764d6cbdf04f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
