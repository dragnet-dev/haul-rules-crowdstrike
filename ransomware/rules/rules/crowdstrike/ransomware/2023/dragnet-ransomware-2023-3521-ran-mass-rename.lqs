// Dragnet [Ransomware]: dragnet-ransomware-2023-3521 — Mass File Rename (nokoyawa)
// Status: experimental | Level: high | ID: fa2813db-53c8-50f3-98dc-89a49081fb4e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
