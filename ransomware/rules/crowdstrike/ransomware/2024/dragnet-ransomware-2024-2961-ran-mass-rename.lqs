// Dragnet [Ransomware]: dragnet-ransomware-2024-2961 — Mass File Rename (mallox)
// Status: experimental | Level: high | ID: 3eea92d3-cd14-5104-ba1a-e716e7ef4bff

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
