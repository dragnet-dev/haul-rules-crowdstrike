// Dragnet [Ransomware]: dragnet-ransomware-2026-0099 — Mass File Rename (lockbit5)
// Status: stable | Level: high | ID: 284c0741-9c6d-557f-a8b4-049895fbdba5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
