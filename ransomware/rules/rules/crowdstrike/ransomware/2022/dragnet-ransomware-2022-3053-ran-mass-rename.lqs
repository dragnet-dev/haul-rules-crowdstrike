// Dragnet [Ransomware]: dragnet-ransomware-2022-3053 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: a61d5061-7c1b-5fcf-97a4-7d7f9c6744d6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
