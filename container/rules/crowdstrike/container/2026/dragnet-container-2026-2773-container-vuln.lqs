// Dragnet [Container]: dragnet-container-2026-2773 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 35ce9a8a-b9b5-5549-8ed2-b801058e2bef

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
