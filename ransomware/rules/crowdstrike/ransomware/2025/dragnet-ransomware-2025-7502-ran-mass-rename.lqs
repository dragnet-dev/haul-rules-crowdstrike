// Dragnet [Ransomware]: dragnet-ransomware-2025-7502 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 390b2204-4715-5dc3-bfe2-c0e066397549

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
