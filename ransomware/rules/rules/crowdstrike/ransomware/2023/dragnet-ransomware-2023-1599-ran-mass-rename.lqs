// Dragnet [Ransomware]: dragnet-ransomware-2023-1599 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: f09a9e02-5dca-5f44-8455-7f3aecb98d76

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
