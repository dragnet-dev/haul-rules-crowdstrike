// Dragnet [Ransomware]: dragnet-ransomware-2022-1048 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: efcab133-7cce-52a0-b6a4-9b3f0bc9e349

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
