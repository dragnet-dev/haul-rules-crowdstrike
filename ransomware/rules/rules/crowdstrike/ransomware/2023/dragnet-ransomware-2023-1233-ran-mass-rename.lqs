// Dragnet [Ransomware]: dragnet-ransomware-2023-1233 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 23a357f7-5528-5081-92c5-65c7d142f2f9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
