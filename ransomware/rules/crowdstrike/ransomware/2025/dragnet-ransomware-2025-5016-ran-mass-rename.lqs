// Dragnet [Ransomware]: dragnet-ransomware-2025-5016 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: f31ec5f6-e3af-5a8c-8f9f-711c4aecfcc0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
