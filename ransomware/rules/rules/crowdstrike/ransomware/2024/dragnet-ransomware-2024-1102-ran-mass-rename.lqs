// Dragnet [Ransomware]: dragnet-ransomware-2024-1102 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 70948455-c38e-5ad8-bed2-74efaddfc846

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
