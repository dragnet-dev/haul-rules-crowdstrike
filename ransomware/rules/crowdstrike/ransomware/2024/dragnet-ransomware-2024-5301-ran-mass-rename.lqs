// Dragnet [Ransomware]: dragnet-ransomware-2024-5301 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 40e8008f-79e9-5118-b472-954fd0f3a07d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
