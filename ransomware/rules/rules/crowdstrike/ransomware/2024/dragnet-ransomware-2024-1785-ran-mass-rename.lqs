// Dragnet [Ransomware]: dragnet-ransomware-2024-1785 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: 8dda425c-74ee-59ba-b2db-8bfab8ff8ce0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
