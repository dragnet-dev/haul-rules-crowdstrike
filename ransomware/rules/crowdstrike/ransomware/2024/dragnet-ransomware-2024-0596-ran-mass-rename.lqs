// Dragnet [Ransomware]: dragnet-ransomware-2024-0596 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: b347e0dc-b1ad-586a-a08f-114c13d9708b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
