// Dragnet [Ransomware]: dragnet-ransomware-2025-1914 — Mass File Rename (blacknevas)
// Status: test | Level: high | ID: a36f667c-18ca-5447-a8d0-d84ac1d07e24

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
