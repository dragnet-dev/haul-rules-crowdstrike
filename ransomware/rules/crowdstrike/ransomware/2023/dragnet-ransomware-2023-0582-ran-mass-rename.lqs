// Dragnet [Ransomware]: dragnet-ransomware-2023-0582 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 303dc368-29f8-5ed8-bc5e-4471e5715ed1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
