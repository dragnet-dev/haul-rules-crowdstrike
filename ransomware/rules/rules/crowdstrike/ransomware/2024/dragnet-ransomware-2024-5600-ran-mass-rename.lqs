// Dragnet [Ransomware]: dragnet-ransomware-2024-5600 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 8b7e89a3-b1cf-56d6-8778-e9e279556b42

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
