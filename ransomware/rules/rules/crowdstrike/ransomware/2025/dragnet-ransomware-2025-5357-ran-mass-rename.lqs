// Dragnet [Ransomware]: dragnet-ransomware-2025-5357 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 4719a073-7c37-5a0e-8001-9fe5b2cc24da

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
