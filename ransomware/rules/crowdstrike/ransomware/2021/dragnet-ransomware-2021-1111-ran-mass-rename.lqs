// Dragnet [Ransomware]: dragnet-ransomware-2021-1111 — Mass File Rename (spook)
// Status: deprecated | Level: high | ID: 4ecf60f2-58f8-5ce3-9ce2-3a82f2fb009d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
