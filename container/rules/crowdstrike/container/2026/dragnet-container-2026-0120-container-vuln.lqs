// Dragnet [Container]: dragnet-container-2026-0120 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: aac08bdf-44ef-553f-b31e-5f1bda11525a

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:7* OR ImageFileName = *debian:8* OR ImageFileName = *ubuntu:14.04*)
| table([timestamp, ComputerName])
| limit(1000)
