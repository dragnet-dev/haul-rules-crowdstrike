// Dragnet [Ransomware]: dragnet-ransomware-2025-0320 — Mass File Rename (direwolf)
// Status: experimental | Level: high | ID: c8fb8dbc-22e5-5f48-829c-03124d293bb0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
