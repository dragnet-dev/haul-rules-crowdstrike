// Dragnet [Ransomware]: dragnet-ransomware-2024-4859 — Mass File Rename (monti)
// Status: experimental | Level: high | ID: 6ffdfe54-c614-5afd-b4d2-821af9b03153

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
