// Dragnet [Ransomware]: dragnet-ransomware-2025-2636 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: ccf4557f-7d4b-5972-b6ea-8db0b661acbb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
