// Dragnet [Ransomware]: dragnet-ransomware-2026-1305 — Mass File Rename (incransom)
// Status: test | Level: high | ID: 391823db-df46-5c59-8b4e-8e5bfab7a79e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
