// Dragnet [Ransomware]: dragnet-ransomware-2025-5241 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 8e6290af-ede2-53ad-bd79-1e592cf368af

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
