// Dragnet [Ransomware]: dragnet-ransomware-2024-1563 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: c524c5e6-2e6a-5615-b5b7-af7dc214f664

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
