// Dragnet [Ransomware]: dragnet-ransomware-2025-1353 — Mass File Rename (obscura)
// Status: experimental | Level: high | ID: cd6b13bf-5ac9-5edd-aad0-5d37eec6417d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
