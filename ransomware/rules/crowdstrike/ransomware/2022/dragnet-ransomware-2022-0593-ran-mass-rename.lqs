// Dragnet [Ransomware]: dragnet-ransomware-2022-0593 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: bd3d85fe-a84c-5fd2-81ae-6f380dfdd449

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
