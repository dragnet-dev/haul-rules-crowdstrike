// Dragnet [Ransomware]: dragnet-ransomware-2024-0989 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 98addbea-16df-51cf-be7b-54e6d16ed02d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
