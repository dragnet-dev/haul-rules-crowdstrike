// Dragnet [Ransomware]: dragnet-ransomware-2022-1906 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: c3289360-b52f-5116-a592-e04cc4914428

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
