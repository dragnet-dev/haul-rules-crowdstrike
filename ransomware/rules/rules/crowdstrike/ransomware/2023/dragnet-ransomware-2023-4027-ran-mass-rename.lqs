// Dragnet [Ransomware]: dragnet-ransomware-2023-4027 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: a3f6e56c-855e-53e6-99b1-26da61f1ba91

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
