// Dragnet [Container]: dragnet-container-2024-0664 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 2b83b443-f002-5d1d-9d05-287f367642cc

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:8* OR ImageFileName = *debian:9*)
| table([timestamp, ComputerName])
| limit(1000)
