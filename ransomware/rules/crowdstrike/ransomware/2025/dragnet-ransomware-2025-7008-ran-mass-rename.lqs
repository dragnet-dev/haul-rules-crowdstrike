// Dragnet [Ransomware]: dragnet-ransomware-2025-7008 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: b40d487e-802c-5b1a-b4cf-5b8c9f10e0a0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
