// Dragnet [Ransomware]: dragnet-ransomware-2024-2068 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: d87ed7fc-8fe1-56db-ac51-aa348bcd33f8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
