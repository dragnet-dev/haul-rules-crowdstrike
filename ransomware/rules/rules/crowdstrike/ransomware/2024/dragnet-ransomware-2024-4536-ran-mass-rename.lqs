// Dragnet [Ransomware]: dragnet-ransomware-2024-4536 — Mass File Rename (donutleaks)
// Status: experimental | Level: high | ID: 55013bdd-2efb-57d0-acd2-74e46ccfe634

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
