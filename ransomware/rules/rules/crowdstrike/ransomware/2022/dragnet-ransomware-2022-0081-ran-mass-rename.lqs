// Dragnet [Ransomware]: dragnet-ransomware-2022-0081 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: c57a2fd8-5bfa-5f3b-b6db-eede3df742f0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
