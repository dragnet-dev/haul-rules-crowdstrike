// Dragnet [Container]: dragnet-container-2026-2193 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: c5d58f7d-ae56-5445-bc56-30240ea42458

#event_simpleName=*
| (ImageFileName = *alpine edge:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
