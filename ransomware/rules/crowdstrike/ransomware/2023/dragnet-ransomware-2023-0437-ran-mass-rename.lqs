// Dragnet [Ransomware]: dragnet-ransomware-2023-0437 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 19d90b69-f48f-5447-b4b5-17a0bcb3fa35

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
