// Dragnet [Ransomware]: dragnet-ransomware-2020-0202 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 43387426-ea4f-5e70-9930-5c39c288aafd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
