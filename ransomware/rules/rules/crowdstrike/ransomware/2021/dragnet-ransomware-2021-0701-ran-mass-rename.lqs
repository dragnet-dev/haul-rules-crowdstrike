// Dragnet [Ransomware]: dragnet-ransomware-2021-0701 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: c85390c7-3209-5724-bf10-9caaaef6118e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
