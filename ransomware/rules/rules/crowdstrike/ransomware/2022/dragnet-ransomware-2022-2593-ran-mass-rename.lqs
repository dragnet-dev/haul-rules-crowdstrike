// Dragnet [Ransomware]: dragnet-ransomware-2022-2593 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 2bfb8db0-355f-5dbc-9d8e-46e98cc68634

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
