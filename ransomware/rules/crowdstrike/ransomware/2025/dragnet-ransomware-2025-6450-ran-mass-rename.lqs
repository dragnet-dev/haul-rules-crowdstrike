// Dragnet [Ransomware]: dragnet-ransomware-2025-6450 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 7605e761-1364-5634-a0cf-6c8985b03500

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
