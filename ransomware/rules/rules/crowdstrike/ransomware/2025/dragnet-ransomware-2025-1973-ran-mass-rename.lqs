// Dragnet [Ransomware]: dragnet-ransomware-2025-1973 — Mass File Rename (nitrogen)
// Status: experimental | Level: high | ID: 1ec8103c-d581-5d13-af97-fc5512526f2b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
