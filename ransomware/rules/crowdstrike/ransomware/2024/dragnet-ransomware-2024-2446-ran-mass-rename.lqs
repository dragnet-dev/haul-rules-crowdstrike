// Dragnet [Ransomware]: dragnet-ransomware-2024-2446 — Mass File Rename (rhysida)
// Status: deprecated | Level: high | ID: 8162cc19-0299-5431-b30e-646c377ae2d1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
