// Dragnet [Ransomware]: dragnet-ransomware-2024-1798 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: c2946711-ce02-56c4-bb91-78d08e835d8e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
