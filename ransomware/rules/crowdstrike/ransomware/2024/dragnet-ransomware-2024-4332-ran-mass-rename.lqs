// Dragnet [Ransomware]: dragnet-ransomware-2024-4332 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 832fd97f-055b-599f-a546-7fd3c6ef02cd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
