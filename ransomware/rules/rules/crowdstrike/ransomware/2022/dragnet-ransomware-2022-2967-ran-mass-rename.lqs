// Dragnet [Ransomware]: dragnet-ransomware-2022-2967 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 1374210a-e85d-5ba6-8e70-6464ac55b114

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
