// Dragnet [Ransomware]: dragnet-ransomware-2021-1298 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: fecae080-3d68-588b-8ad5-e02d0336f0b4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
