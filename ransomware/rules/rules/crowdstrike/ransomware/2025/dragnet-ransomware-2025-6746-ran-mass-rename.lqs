// Dragnet [Ransomware]: dragnet-ransomware-2025-6746 — Mass File Rename (SilentRansomGroup)
// Status: deprecated | Level: high | ID: 9f051b91-656f-5f2d-ad51-25b52b6de99c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
