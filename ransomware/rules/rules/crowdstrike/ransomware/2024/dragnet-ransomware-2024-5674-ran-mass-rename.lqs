// Dragnet [Ransomware]: dragnet-ransomware-2024-5674 — Mass File Rename (abyss)
// Status: deprecated | Level: high | ID: 7d8942b3-9a3e-5f7b-897e-c0734fcd41cd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
