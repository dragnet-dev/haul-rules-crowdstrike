// Dragnet [Ransomware]: dragnet-ransomware-2022-1680 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 79a09780-f203-5eb4-9b99-1d78e7c4b2ef

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
