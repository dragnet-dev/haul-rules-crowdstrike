// Dragnet [Ransomware]: dragnet-ransomware-2023-2944 — Mass File Rename (royal)
// Status: experimental | Level: high | ID: 027ca19b-2c60-57f9-b06d-d12bdd64118f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
