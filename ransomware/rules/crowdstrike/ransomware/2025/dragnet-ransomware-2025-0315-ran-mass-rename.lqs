// Dragnet [Ransomware]: dragnet-ransomware-2025-0315 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: b84fbab3-06b4-538e-b259-ccdd66cad146

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
