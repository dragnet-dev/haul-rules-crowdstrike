// Dragnet [Container]: dragnet-container-2024-1574 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 94f3ab94-f964-5d15-b24e-14436d08dd72

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:8* OR ImageFileName = *debian:9* OR ImageFileName = *ubuntu:16.04-ESM* OR ImageFileName = *ubuntu:18.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
