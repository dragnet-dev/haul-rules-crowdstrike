// Dragnet [Container]: dragnet-container-2024-0328 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: d0440d6a-8980-5aa2-9c82-167c8a465bf1

#event_simpleName=*
| (ImageFileName = *debian:8* OR ImageFileName = *debian:9* OR ImageFileName = *ubuntu:16.04-ESM* OR ImageFileName = *ubuntu:18.04-ESM* OR ImageFileName = *ubuntu:19.04* OR ImageFileName = *ubuntu:19.10* OR ImageFileName = *ubuntu:20.04* OR ImageFileName = *ubuntu:20.04-ESM* OR ImageFileName = *ubuntu:20.10*)
| table([timestamp, ComputerName])
| limit(1000)
