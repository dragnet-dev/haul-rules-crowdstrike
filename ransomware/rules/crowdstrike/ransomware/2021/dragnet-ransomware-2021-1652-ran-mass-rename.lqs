// Dragnet [Ransomware]: dragnet-ransomware-2021-1652 — Mass File Rename (avaddon)
// Status: deprecated | Level: high | ID: 2e52696e-fc57-5dfe-be87-d11ed9ac1f75

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
