// Dragnet [Ransomware]: dragnet-ransomware-2023-4933 — Mass File Rename (ransomhouse)
// Status: experimental | Level: high | ID: b1e6d776-62ff-5e25-b360-bc2b98533480

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
