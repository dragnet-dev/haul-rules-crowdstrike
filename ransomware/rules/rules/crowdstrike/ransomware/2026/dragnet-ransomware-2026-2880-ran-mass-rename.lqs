// Dragnet [Ransomware]: dragnet-ransomware-2026-2880 — Mass File Rename (lockbit5)
// Status: test | Level: high | ID: 9c165e6b-a061-55b3-a1b9-d9b660097844

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
