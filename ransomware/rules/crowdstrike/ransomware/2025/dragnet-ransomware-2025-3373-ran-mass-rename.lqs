// Dragnet [Ransomware]: dragnet-ransomware-2025-3373 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 823d5feb-6cb3-58a8-a0d6-01de1e4a401d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
