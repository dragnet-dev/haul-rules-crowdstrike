// Dragnet [Container]: dragnet-container-2024-1320 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: ce508dc0-e4ea-5343-b9e7-24d65baba253

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:9*)
| table([timestamp, ComputerName])
| limit(1000)
