// Dragnet [Ransomware]: dragnet-ransomware-2023-0257 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: a3d00e6a-17e0-595b-b7c7-9db9c88f6263

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
