// Dragnet [Ransomware]: dragnet-ransomware-2024-3948 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: e3488b1a-1874-54e4-9249-e685331a85b7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
