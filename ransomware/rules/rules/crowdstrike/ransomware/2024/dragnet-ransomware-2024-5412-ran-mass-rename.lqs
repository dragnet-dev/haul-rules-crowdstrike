// Dragnet [Ransomware]: dragnet-ransomware-2024-5412 — Mass File Rename (ElDorado)
// Status: deprecated | Level: high | ID: 414343d7-5d7d-504f-b39e-7f25b5771aa1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
