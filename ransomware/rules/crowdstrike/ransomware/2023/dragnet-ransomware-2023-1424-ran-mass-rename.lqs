// Dragnet [Ransomware]: dragnet-ransomware-2023-1424 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: c2401e41-356e-5de6-84db-f95b55044c50

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
