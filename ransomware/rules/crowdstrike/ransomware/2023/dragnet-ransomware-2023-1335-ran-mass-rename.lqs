// Dragnet [Ransomware]: dragnet-ransomware-2023-1335 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 35550ea1-b6dc-5eac-bd34-c347eeae8f14

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
