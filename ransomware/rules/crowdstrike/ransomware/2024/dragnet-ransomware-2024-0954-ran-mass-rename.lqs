// Dragnet [Ransomware]: dragnet-ransomware-2024-0954 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 034666ba-d5ce-5a97-b108-429c66814c47

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
