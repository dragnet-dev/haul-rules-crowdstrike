// Dragnet [Ransomware]: dragnet-ransomware-2025-6414 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: 2dd997a6-a266-5660-9eab-b30519aa7e5a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
