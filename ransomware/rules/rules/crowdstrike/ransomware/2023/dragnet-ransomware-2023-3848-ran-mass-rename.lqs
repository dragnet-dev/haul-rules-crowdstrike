// Dragnet [Ransomware]: dragnet-ransomware-2023-3848 — Mass File Rename (royal)
// Status: experimental | Level: high | ID: 3c2dbbb5-5cc0-5064-86eb-493be124fdeb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
