// Dragnet [Ransomware]: dragnet-ransomware-2022-2278 — Mass File Rename (snatch)
// Status: experimental | Level: high | ID: 36e251de-8a73-532e-a387-2bd9d794740c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
