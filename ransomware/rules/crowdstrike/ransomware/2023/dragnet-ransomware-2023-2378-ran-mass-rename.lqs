// Dragnet [Ransomware]: dragnet-ransomware-2023-2378 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 95466169-4d6c-570e-b909-6f0d10ffed64

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
