// Dragnet [Ransomware]: dragnet-ransomware-2025-3371 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: 83ff5346-efd7-518c-8d07-ff9c57170381

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
