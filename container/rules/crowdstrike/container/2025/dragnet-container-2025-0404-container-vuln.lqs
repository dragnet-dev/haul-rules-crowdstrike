// Dragnet [Container]: dragnet-container-2025-0404 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 86d074a6-1368-582f-894a-9aab657b6e15

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
