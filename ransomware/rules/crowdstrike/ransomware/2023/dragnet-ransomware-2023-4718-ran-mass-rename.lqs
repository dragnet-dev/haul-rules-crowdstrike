// Dragnet [Ransomware]: dragnet-ransomware-2023-4718 — Mass File Rename (ransomed)
// Status: experimental | Level: high | ID: f7e80072-2a7f-5b79-a3cd-989b229a406e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
