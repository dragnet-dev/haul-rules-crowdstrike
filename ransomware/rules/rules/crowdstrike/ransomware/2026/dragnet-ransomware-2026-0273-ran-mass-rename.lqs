// Dragnet [Ransomware]: dragnet-ransomware-2026-0273 — Mass File Rename (morpheus)
// Status: deprecated | Level: high | ID: 875ef7f7-a510-5928-9e02-f9bb49a07bbd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
