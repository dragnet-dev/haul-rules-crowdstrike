// Dragnet [Ransomware]: dragnet-ransomware-2025-0346 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 732a8bd2-7a12-56df-baf6-ce728fe74d1e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
