// Dragnet [Ransomware]: dragnet-ransomware-2023-2362 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 17ab46a9-84f7-5cd6-a660-0d41688a9df5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
