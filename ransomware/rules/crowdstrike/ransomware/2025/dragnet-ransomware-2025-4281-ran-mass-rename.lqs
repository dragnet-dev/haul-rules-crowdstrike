// Dragnet [Ransomware]: dragnet-ransomware-2025-4281 — Mass File Rename (rhysida)
// Status: experimental | Level: high | ID: fb16cfee-ddb8-5d8a-85ad-6bf7f42ed1bf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
