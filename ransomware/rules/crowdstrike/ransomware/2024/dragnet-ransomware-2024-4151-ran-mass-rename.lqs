// Dragnet [Ransomware]: dragnet-ransomware-2024-4151 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 912936d3-1047-5ee8-9826-a4a3e9a0271d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
