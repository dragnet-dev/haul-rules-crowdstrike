// Dragnet [Ransomware]: dragnet-ransomware-2024-3070 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 84b14625-7fd0-567c-9c24-c02f011d1cf7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
