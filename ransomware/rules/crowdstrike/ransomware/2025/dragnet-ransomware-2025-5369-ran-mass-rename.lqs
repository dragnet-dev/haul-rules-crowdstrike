// Dragnet [Ransomware]: dragnet-ransomware-2025-5369 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 67f216d6-e86b-5e5e-bdde-28d97babc72f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
