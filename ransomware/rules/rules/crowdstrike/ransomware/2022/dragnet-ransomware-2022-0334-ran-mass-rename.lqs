// Dragnet [Ransomware]: dragnet-ransomware-2022-0334 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 757979bd-6103-5702-b170-469c0e105ec8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
