// Dragnet [Ransomware]: dragnet-ransomware-2026-0171 — Mass File Rename (incransom)
// Status: test | Level: high | ID: a4a43a09-13bc-5710-8a4d-01acc7e2f6c9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
