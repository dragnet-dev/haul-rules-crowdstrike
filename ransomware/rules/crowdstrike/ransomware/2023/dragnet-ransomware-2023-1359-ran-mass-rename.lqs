// Dragnet [Ransomware]: dragnet-ransomware-2023-1359 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: f7de0809-cbc9-54d8-bc3e-2dbad2b88e85

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
