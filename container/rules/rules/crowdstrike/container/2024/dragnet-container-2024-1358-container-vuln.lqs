// Dragnet [Container]: dragnet-container-2024-1358 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: f6a0871e-d2e6-5917-9d16-b6b95e4adf28

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:9*)
| table([timestamp, ComputerName])
| limit(1000)
