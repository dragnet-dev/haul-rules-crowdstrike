// Dragnet [Ransomware]: dragnet-ransomware-2022-2797 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 1b3f443a-5d14-54e0-9ef7-e4a5fd35bece

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
