// Dragnet [Ransomware]: dragnet-ransomware-2025-6328 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 5c6b217a-8229-58b8-bbbf-afc8f684e752

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
