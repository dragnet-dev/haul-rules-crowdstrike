// Dragnet [Ransomware]: dragnet-ransomware-2024-1569 — Mass File Rename (dragonforce)
// Status: deprecated | Level: high | ID: b2e718fd-4004-5c61-80c2-56f5d5ba082a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
