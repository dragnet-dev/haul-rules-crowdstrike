// Dragnet [Ransomware]: dragnet-ransomware-2025-0925 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 04bd9b31-7152-5786-a499-71d57ea43ff3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
