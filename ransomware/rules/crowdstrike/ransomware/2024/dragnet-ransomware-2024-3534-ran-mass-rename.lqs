// Dragnet [Ransomware]: dragnet-ransomware-2024-3534 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 88a2a514-a4ac-5532-89cc-62cca56f480b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
