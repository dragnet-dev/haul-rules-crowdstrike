// Dragnet [Ransomware]: dragnet-ransomware-2022-0958 — Mass File Rename (avoslocker)
// Status: deprecated | Level: high | ID: 8e5dd2a5-5eea-57f4-a4bf-d55dc027bf69

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
