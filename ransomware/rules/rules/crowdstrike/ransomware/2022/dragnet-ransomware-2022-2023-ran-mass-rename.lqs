// Dragnet [Ransomware]: dragnet-ransomware-2022-2023 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 9a2bcf7f-6b3d-5ac0-98db-1c16f2049b0f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
