// Dragnet [Ransomware]: dragnet-ransomware-2025-1242 — Mass File Rename (worldleaks)
// Status: experimental | Level: high | ID: 54c68a00-843a-55f2-b5bb-ca90fc347ceb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
