// Dragnet [Ransomware]: dragnet-ransomware-2025-4479 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 2f53b4ea-6573-52d0-b885-c47e02dde423

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
