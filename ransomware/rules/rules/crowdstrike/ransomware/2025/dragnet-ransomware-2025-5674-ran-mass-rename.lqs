// Dragnet [Ransomware]: dragnet-ransomware-2025-5674 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 25dc4d4c-7eda-552f-bec9-6cde5bc080fa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
