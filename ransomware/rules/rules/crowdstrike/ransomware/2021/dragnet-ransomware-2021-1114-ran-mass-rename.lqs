// Dragnet [Ransomware]: dragnet-ransomware-2021-1114 — Mass File Rename (snatch)
// Status: experimental | Level: high | ID: d977e6f1-1fbd-5995-8d51-f4dd51f7c221

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
