// Dragnet [Ransomware]: dragnet-ransomware-2025-0132 — Mass File Rename (killsec)
// Status: deprecated | Level: high | ID: dcffc5e8-893d-532c-b3fb-595f72cd54cb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
