// Dragnet [Ransomware]: dragnet-ransomware-2025-3788 — Mass File Rename (play)
// Status: experimental | Level: high | ID: cfa09e2b-6a12-506b-85d1-43bb5bfd7b68

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
