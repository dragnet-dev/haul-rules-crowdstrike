// Dragnet [Ransomware]: dragnet-ransomware-2021-0297 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 41330cb0-ac47-5ed8-84e2-7404e06323bb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
