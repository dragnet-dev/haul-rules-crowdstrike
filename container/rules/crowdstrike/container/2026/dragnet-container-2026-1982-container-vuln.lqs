// Dragnet [Container]: dragnet-container-2026-1982 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 024e68bc-aa5c-5c6d-ab13-7b4045c975c6

#event_simpleName=*
| (ImageFileName = *chainguard:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
