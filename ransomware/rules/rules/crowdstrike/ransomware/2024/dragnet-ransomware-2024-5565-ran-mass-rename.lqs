// Dragnet [Ransomware]: dragnet-ransomware-2024-5565 — Mass File Rename (apt73)
// Status: experimental | Level: high | ID: 59918295-e804-5c23-9487-259bd606d796

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
