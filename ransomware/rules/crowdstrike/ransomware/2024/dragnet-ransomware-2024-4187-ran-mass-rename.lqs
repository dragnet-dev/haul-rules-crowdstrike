// Dragnet [Ransomware]: dragnet-ransomware-2024-4187 — Mass File Rename (rhysida)
// Status: experimental | Level: high | ID: 40756c3b-1a58-5c77-aab8-665688263bd6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
