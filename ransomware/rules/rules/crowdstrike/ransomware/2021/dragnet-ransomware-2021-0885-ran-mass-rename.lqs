// Dragnet [Ransomware]: dragnet-ransomware-2021-0885 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: f4321f57-a0d2-5bef-b4e8-8619b02f49ce

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
