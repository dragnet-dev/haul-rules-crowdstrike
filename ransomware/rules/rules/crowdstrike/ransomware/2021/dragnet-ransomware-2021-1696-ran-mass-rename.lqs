// Dragnet [Ransomware]: dragnet-ransomware-2021-1696 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: dcb4fddb-ab56-5d0e-9906-3b42bbfaa88c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
