// Dragnet [Ransomware]: dragnet-ransomware-2025-7879 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: feb14a98-4925-5a62-9b59-03cfab4d3f5b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
