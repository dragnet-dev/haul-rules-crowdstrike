// Dragnet [Ransomware]: dragnet-ransomware-2024-0760 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: bf42ec65-2c14-5c83-af65-a4442078b4e7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
