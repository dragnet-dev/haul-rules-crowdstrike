// Dragnet [Ransomware]: dragnet-ransomware-2025-5192 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: ecd6b32f-b0c0-58c4-930d-350f474b9b31

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
