// Dragnet [Ransomware]: dragnet-ransomware-2020-0153 — Mass File Rename (doppelpaymer)
// Status: deprecated | Level: high | ID: 29168c19-2413-5ae3-ad52-ce973cc52110

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
