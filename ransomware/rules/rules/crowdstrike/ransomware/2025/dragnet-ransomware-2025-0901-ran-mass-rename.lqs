// Dragnet [Ransomware]: dragnet-ransomware-2025-0901 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: c9c72820-4840-53f7-a352-79459712ee8f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
