// Dragnet [Ransomware]: dragnet-ransomware-2024-2785 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 68ea883d-69ef-518b-b075-6b5d5632dfad

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
