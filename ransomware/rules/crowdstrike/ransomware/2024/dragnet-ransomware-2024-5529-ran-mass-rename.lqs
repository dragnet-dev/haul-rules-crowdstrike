// Dragnet [Ransomware]: dragnet-ransomware-2024-5529 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: 7caa83b8-4d24-5bbd-bd21-1f46d4bd6e9b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
