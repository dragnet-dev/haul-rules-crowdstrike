// Dragnet [Ransomware]: dragnet-ransomware-2023-4520 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 057b7ea7-b4d4-5eec-bfde-1977ac027124

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
