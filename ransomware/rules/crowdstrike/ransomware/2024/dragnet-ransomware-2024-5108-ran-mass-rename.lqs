// Dragnet [Ransomware]: dragnet-ransomware-2024-5108 — Mass File Rename (meow)
// Status: experimental | Level: high | ID: caf0144e-75bc-561e-906b-1f39875eab74

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
