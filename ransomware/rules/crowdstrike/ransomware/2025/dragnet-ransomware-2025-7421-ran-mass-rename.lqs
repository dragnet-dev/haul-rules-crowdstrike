// Dragnet [Ransomware]: dragnet-ransomware-2025-7421 — Mass File Rename (beast)
// Status: experimental | Level: high | ID: 6223e1ab-70b7-50fc-b642-18422669c2a6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
