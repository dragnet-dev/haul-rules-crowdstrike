// Dragnet [Ransomware]: dragnet-ransomware-2022-1220 — Mass File Rename (play)
// Status: deprecated | Level: high | ID: f90069c2-a359-56d4-8785-8e01f52fe4c3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
