// Dragnet [Ransomware]: dragnet-ransomware-2025-7624 — Mass File Rename (weyhro)
// Status: experimental | Level: high | ID: 58e58169-8acd-5fa8-8726-54f5e2cf4c3c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
