// Dragnet [Ransomware]: dragnet-ransomware-2025-6116 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 4604edc5-9a70-592e-b42e-cc0aa12524d5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
