// Dragnet [Ransomware]: dragnet-ransomware-2025-6035 — Mass File Rename (global)
// Status: deprecated | Level: high | ID: cf5b1f8f-ca55-5ee2-854a-a8217454283b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
