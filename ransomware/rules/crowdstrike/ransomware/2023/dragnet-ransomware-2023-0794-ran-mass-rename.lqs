// Dragnet [Ransomware]: dragnet-ransomware-2023-0794 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 248ac48a-8904-52b9-9a68-9dcc7a264447

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
