// Dragnet [Ransomware]: dragnet-ransomware-2024-2596 — Mass File Rename (ransomhouse)
// Status: experimental | Level: high | ID: 7a170a33-de99-5cee-9ddf-6ad5b0fd3864

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
