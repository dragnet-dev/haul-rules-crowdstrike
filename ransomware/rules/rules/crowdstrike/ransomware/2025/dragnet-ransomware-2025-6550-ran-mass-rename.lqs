// Dragnet [Ransomware]: dragnet-ransomware-2025-6550 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 1a22e760-e9c5-59ec-b205-cae0309267f9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
