// Dragnet [Ransomware]: dragnet-ransomware-2026-2321 — Mass File Rename (vect)
// Status: deprecated | Level: high | ID: a086c94d-258e-5011-8350-95af072eb1b0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
