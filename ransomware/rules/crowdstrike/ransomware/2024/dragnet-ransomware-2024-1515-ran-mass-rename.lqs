// Dragnet [Ransomware]: dragnet-ransomware-2024-1515 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: a0d4f5ec-316d-5aa9-89af-7638eb08bba7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
