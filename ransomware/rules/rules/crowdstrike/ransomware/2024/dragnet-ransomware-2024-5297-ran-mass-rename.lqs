// Dragnet [Ransomware]: dragnet-ransomware-2024-5297 — Mass File Rename (dragonforce)
// Status: deprecated | Level: high | ID: cf3882f2-c1ec-50d4-a6fb-b6012d4fd8b9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
