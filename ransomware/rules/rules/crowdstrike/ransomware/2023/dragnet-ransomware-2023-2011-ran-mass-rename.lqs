// Dragnet [Ransomware]: dragnet-ransomware-2023-2011 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 0e9e886a-8c51-5ce5-b1b1-74cae29a2dc6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
