// Dragnet [Ransomware]: dragnet-ransomware-2025-7896 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 043f7b89-adf7-535e-b223-f856e11a0e9f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
