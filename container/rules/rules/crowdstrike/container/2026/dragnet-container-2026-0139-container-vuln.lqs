// Dragnet [Container]: dragnet-container-2026-0139 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 7e920575-6346-52e9-a3f8-d20d44be39a9

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:7* OR ImageFileName = *debian:8* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:14.04* OR ImageFileName = *ubuntu:14.10* OR ImageFileName = *ubuntu:15.04*)
| table([timestamp, ComputerName])
| limit(1000)
