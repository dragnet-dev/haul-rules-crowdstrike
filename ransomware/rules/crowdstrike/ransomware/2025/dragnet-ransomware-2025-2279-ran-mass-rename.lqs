// Dragnet [Ransomware]: dragnet-ransomware-2025-2279 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: bba7e510-b2ed-5ff2-90ec-dc3d09e73da8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
