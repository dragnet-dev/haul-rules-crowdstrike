// Dragnet [Container]: dragnet-container-2026-1838 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 7acb52e0-4f37-5fe2-a6eb-7edfdb5dcf9e

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:7* OR ImageFileName = *debian:8*)
| table([timestamp, ComputerName])
| limit(1000)
