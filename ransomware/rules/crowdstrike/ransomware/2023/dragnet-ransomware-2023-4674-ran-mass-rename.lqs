// Dragnet [Ransomware]: dragnet-ransomware-2023-4674 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: b5472036-6da7-5b6f-907f-140a3a98dd22

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
