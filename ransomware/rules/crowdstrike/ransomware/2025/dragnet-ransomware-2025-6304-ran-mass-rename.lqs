// Dragnet [Ransomware]: dragnet-ransomware-2025-6304 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 7d621ded-3fcc-5a59-a8db-a218c98ce360

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
