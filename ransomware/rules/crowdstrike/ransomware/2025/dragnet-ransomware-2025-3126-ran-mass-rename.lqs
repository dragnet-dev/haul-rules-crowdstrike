// Dragnet [Ransomware]: dragnet-ransomware-2025-3126 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 138f41bc-509a-537e-b427-4fa4784a834e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
