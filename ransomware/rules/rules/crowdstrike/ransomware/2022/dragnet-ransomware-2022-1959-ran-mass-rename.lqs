// Dragnet [Ransomware]: dragnet-ransomware-2022-1959 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 490fed87-305b-5cb9-b7be-4ef88a08d0a0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
