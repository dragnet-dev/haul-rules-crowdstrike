// Dragnet [Container]: dragnet-container-2024-1458 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 924a63ca-f572-5aa1-803b-bb82b450413a

#event_simpleName=*
| (ImageFileName = *almalinux:9* OR ImageFileName = *cbl-mariner:2.0* OR ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:9* OR ImageFileName = *redhat/ubi9:*)
| table([timestamp, ComputerName])
| limit(1000)
