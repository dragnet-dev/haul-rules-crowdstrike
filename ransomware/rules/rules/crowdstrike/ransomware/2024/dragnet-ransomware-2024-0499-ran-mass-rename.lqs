// Dragnet [Ransomware]: dragnet-ransomware-2024-0499 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: cf0c1522-23fd-5507-a048-9c1ea6f0b261

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
