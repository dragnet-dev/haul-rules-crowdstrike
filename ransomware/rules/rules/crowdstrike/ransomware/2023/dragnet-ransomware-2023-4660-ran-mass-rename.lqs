// Dragnet [Ransomware]: dragnet-ransomware-2023-4660 — Mass File Rename (cuba)
// Status: experimental | Level: high | ID: 50e6bdaa-742a-5fb9-b0fb-6ecd298e4e89

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
