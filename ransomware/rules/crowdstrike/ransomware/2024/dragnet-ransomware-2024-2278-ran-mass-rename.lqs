// Dragnet [Ransomware]: dragnet-ransomware-2024-2278 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 569c5da7-b0bf-5a4c-ad4c-1562cde7bd89

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
