// Dragnet [Ransomware]: dragnet-ransomware-2021-0954 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 75068683-6b12-5a13-8778-0e2bd8a2a592

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
