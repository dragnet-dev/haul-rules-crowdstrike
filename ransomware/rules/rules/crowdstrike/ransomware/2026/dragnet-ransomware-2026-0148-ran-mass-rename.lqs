// Dragnet [Ransomware]: dragnet-ransomware-2026-0148 — Mass File Rename (ransomhouse)
// Status: stable | Level: high | ID: 8f40165a-b44d-5d1e-8eff-8aa3ecd278ff

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
