// Dragnet [Ransomware]: dragnet-ransomware-2025-2005 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 6a946b9f-f012-53fe-9591-5c4e1b4b00d7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
