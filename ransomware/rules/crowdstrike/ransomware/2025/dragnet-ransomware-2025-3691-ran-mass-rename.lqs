// Dragnet [Ransomware]: dragnet-ransomware-2025-3691 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: fb6f16a3-cfd0-5a96-90fe-2fbdc15c8fbf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
