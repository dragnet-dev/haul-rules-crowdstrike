// Dragnet [Ransomware]: dragnet-ransomware-2025-7492 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 2a3e27f7-0f4c-5b17-9802-34dd048ad936

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
