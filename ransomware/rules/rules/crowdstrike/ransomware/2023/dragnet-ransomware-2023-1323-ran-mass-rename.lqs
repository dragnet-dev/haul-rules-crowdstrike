// Dragnet [Ransomware]: dragnet-ransomware-2023-1323 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: f94260ea-a5e7-5ce5-af09-cd19302493e5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
