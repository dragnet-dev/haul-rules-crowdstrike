// Dragnet [Ransomware]: dragnet-ransomware-2025-4408 — Mass File Rename (coinbasecartel)
// Status: test | Level: high | ID: 37455371-b330-59ef-a73e-d44641caa16e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
