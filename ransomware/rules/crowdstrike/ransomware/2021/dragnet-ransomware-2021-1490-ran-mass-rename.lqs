// Dragnet [Ransomware]: dragnet-ransomware-2021-1490 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 9d726a0c-d007-567f-b9ae-a9557a91b6fd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
