// Dragnet [Ransomware]: dragnet-ransomware-2025-3118 — Mass File Rename (threeam)
// Status: experimental | Level: high | ID: 592afdc6-193e-5324-bff7-76aca96643ba

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
