// Dragnet [Ransomware]: dragnet-ransomware-2025-1303 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 95cb5d05-33fa-50f9-84e6-3bc64f5bb6fe

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
