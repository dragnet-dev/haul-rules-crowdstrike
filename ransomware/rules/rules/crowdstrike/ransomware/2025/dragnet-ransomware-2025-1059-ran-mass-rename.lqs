// Dragnet [Ransomware]: dragnet-ransomware-2025-1059 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: ffe770f4-107e-53e5-bd2c-2df014d48b5d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
