// Dragnet [Ransomware]: dragnet-ransomware-2025-1498 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: 1ea48f0c-c7e9-58fa-bbb8-b029c37eb36f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
