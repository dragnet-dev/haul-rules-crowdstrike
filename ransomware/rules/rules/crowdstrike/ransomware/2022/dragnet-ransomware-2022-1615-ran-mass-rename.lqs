// Dragnet [Ransomware]: dragnet-ransomware-2022-1615 — Mass File Rename (blackbasta)
// Status: deprecated | Level: high | ID: fa8e063f-e5e2-5708-a498-23e6f60b319d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
