// Dragnet [Ransomware]: dragnet-ransomware-2025-0785 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: a2413283-6660-5873-af87-e08d2801452d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
