// Dragnet [Ransomware]: dragnet-ransomware-2025-2057 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 710a5244-2201-550e-9efe-0abb90d95f7f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
