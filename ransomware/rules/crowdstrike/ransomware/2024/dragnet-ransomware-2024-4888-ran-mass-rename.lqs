// Dragnet [Ransomware]: dragnet-ransomware-2024-4888 — Mass File Rename (cicada3301)
// Status: experimental | Level: high | ID: 203a1c90-038f-5b0f-b7fe-557f992a2b4a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
