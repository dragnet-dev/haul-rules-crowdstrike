// Dragnet [Ransomware]: dragnet-ransomware-2024-3681 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 72d358b4-0e2a-553e-8bf8-05598dcfdc1d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
