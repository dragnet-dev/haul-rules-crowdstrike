// Dragnet [Ransomware]: dragnet-ransomware-2021-0018 — Mass File Rename (darkside)
// Status: deprecated | Level: high | ID: 479cb13c-4d7d-554c-b941-019ac0ca0b98

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
