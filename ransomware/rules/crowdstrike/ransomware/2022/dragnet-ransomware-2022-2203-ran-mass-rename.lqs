// Dragnet [Ransomware]: dragnet-ransomware-2022-2203 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 41d9876b-ba3f-5e91-959f-0da3e992e638

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
