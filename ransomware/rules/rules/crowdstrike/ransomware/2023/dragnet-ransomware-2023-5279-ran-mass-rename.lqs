// Dragnet [Ransomware]: dragnet-ransomware-2023-5279 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 592019c9-199c-5959-b706-0c0cbd0ecdb1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
