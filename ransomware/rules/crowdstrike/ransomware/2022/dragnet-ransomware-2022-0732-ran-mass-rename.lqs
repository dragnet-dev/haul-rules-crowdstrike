// Dragnet [Ransomware]: dragnet-ransomware-2022-0732 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: e28b0c83-ed56-5b58-ae06-0f9c135e7d98

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
