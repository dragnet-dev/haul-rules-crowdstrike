// Dragnet [Ransomware]: dragnet-ransomware-2024-0169 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 01c88e31-9260-5655-b1f5-7743f904d2b4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
