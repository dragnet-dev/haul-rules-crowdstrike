// Dragnet [Ransomware]: dragnet-ransomware-2025-7618 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: fa6ba871-a811-59f6-9098-0194c9a98e94

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
