// Dragnet [Ransomware]: dragnet-ransomware-2023-5198 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 605a7ab9-7d4a-5fc3-b6d0-240d336bc443

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
