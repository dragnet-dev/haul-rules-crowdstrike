// Dragnet [Container]: dragnet-container-2026-2277 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: e3c40f60-c874-5032-9cba-8b68e7d29c47

#event_simpleName=*
| (ImageFileName = *chainguard:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
