// Dragnet [Ransomware]: dragnet-ransomware-2024-3083 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 9202c573-5daf-5f04-a37f-6dd949d8e299

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
