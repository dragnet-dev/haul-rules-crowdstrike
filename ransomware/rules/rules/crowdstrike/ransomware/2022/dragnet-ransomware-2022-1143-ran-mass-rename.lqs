// Dragnet [Ransomware]: dragnet-ransomware-2022-1143 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: e519dbc6-664d-5b86-b3cb-f9cc9ef658f7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
