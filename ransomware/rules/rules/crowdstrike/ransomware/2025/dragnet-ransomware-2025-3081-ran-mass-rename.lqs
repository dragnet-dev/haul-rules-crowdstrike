// Dragnet [Ransomware]: dragnet-ransomware-2025-3081 — Mass File Rename (play)
// Status: experimental | Level: high | ID: ac4fc050-750f-5708-be84-acf624b9ca75

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
