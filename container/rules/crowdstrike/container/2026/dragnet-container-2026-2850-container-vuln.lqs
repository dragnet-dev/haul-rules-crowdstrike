// Dragnet [Container]: dragnet-container-2026-2850 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 25d563cf-9423-5c35-91cc-df036a890609

#event_simpleName=*
| (ImageFileName = *chainguard:* OR ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10*)
| table([timestamp, ComputerName])
| limit(1000)
