// Dragnet [Ransomware]: dragnet-ransomware-2026-0784 — Mass File Rename (everest)
// Status: stable | Level: high | ID: 43607eed-2d93-5449-870b-8908dc793c31

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
