// Dragnet [Ransomware]: dragnet-ransomware-2024-5169 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: 0fa00eb3-ff6e-583e-850b-73ac07b14d1f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
