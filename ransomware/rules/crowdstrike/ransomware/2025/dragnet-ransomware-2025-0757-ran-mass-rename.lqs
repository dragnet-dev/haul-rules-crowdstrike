// Dragnet [Ransomware]: dragnet-ransomware-2025-0757 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 48666402-07af-57ec-be25-78255ad45d9e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
