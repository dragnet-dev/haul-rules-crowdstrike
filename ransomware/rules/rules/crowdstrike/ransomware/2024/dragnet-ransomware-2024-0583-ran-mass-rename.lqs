// Dragnet [Ransomware]: dragnet-ransomware-2024-0583 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: 95d8bf8a-bb92-519c-848a-21aa9bfb07d6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
