// Dragnet [Ransomware]: dragnet-ransomware-2025-4862 — Mass File Rename (handala)
// Status: experimental | Level: high | ID: 143e6a38-a235-5e47-ba8e-c6caf00ab616

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
