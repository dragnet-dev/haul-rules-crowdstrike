// Dragnet [Ransomware]: dragnet-ransomware-2026-1155 — Mass File Rename (thegentlemen)
// Status: stable | Level: high | ID: 3b0dfe62-99bc-5007-934b-7dcd6a1cf713

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
