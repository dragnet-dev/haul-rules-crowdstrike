// Dragnet [Ransomware]: dragnet-ransomware-2024-4463 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 1b63ac74-1168-598e-9592-569dda1688a2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
