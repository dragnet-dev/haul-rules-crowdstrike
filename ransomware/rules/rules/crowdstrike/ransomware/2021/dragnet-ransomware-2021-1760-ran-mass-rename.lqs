// Dragnet [Ransomware]: dragnet-ransomware-2021-1760 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 2574830b-3e5c-51ca-a969-e71b9b255858

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
