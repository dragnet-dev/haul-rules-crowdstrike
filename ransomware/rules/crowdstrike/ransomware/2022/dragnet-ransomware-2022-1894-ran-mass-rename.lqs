// Dragnet [Ransomware]: dragnet-ransomware-2022-1894 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 47e5d7c3-aa32-55da-9096-617a8617d90e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
