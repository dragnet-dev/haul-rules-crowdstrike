// Dragnet [Ransomware]: dragnet-ransomware-2023-1059 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: bdf63b0a-2caa-5cd2-8d3d-e28eec0f7035

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
