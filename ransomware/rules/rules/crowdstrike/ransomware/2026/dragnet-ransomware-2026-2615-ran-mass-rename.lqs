// Dragnet [Ransomware]: dragnet-ransomware-2026-2615 — Mass File Rename (handala)
// Status: stable | Level: high | ID: 7b589b68-9c7a-52f4-ae2e-ce0c06665057

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
