// Dragnet [Ransomware]: dragnet-ransomware-2025-2902 — Mass File Rename (arcusmedia)
// Status: experimental | Level: high | ID: cf8146fc-a822-5cbe-a59c-5ba717985458

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
