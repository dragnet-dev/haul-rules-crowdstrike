// Dragnet [Ransomware]: dragnet-ransomware-2025-1561 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 93110185-bfa8-5a09-abc6-3565c962cb91

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
