// Dragnet [Ransomware]: dragnet-ransomware-2022-1507 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 0678f6ac-be7a-59bb-b8f9-86bf0026b0ca

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
