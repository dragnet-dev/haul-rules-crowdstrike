// Dragnet [Ransomware]: dragnet-ransomware-2025-5189 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 8b86b213-cea3-52c0-8a6b-87355cdd193e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
