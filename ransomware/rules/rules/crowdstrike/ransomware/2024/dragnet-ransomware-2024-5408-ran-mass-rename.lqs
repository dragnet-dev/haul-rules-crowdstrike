// Dragnet [Ransomware]: dragnet-ransomware-2024-5408 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 706bbec3-4398-5623-b009-a9df6153a50c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
