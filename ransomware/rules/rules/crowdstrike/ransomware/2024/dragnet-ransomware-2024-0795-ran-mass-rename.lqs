// Dragnet [Ransomware]: dragnet-ransomware-2024-0795 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 1a29d376-98cd-5138-b15d-04a3b18a1d43

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
