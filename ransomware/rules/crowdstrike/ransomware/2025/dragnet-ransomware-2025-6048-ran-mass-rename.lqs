// Dragnet [Ransomware]: dragnet-ransomware-2025-6048 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: ea0291f9-6443-5dac-bfea-658bf50b1bb2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
