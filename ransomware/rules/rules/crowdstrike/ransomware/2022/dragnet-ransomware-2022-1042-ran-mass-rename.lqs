// Dragnet [Ransomware]: dragnet-ransomware-2022-1042 — Mass File Rename (ransomexx)
// Status: experimental | Level: high | ID: f35a8dcd-0e89-5462-973a-63d25e7052bb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
