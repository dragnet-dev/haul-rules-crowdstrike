// Dragnet [Ransomware]: dragnet-ransomware-2025-0363 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 6a715719-6ce6-5f2f-9788-207781f6ace7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
