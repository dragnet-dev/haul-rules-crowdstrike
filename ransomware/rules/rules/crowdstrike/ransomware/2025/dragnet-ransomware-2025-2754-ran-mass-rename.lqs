// Dragnet [Ransomware]: dragnet-ransomware-2025-2754 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 8df0caee-6e33-57e5-ae46-8ec437217936

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
