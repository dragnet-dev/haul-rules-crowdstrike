// Dragnet [Ransomware]: dragnet-ransomware-2023-1017 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 7648569d-68c8-548e-aef5-ef7ce4463ba3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
