// Dragnet [Ransomware]: dragnet-ransomware-2022-1904 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 9d700632-247c-50af-83d6-44ca60228b7d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
