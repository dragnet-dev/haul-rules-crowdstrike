// Dragnet [Container]: dragnet-container-2025-0621 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 67492272-3052-576f-b654-d861d9bada14

#event_simpleName=*
| (ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
