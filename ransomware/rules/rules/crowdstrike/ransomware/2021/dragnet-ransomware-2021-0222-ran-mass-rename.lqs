// Dragnet [Ransomware]: dragnet-ransomware-2021-0222 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: fd115275-61fc-521e-ada7-9a8dca78badd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
