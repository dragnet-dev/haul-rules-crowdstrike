// Dragnet [Ransomware]: dragnet-ransomware-2026-2993 — Mass File Rename (lapsus$)
// Status: deprecated | Level: high | ID: b3aaccf3-5189-51bd-a1b1-4669fb166b89

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
