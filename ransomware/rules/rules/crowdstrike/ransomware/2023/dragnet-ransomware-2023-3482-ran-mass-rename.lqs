// Dragnet [Ransomware]: dragnet-ransomware-2023-3482 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 66799825-13b3-576e-a6ec-409eca42fd7d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
