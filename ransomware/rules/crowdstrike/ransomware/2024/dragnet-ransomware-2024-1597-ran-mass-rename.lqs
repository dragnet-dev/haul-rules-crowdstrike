// Dragnet [Ransomware]: dragnet-ransomware-2024-1597 — Mass File Rename (argonauts)
// Status: experimental | Level: high | ID: a7a013da-cb47-5045-afed-b6a2c51343a8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
