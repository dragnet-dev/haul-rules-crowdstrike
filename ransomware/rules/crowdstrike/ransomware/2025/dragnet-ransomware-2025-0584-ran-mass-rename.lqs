// Dragnet [Ransomware]: dragnet-ransomware-2025-0584 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 18fa5605-e674-5d94-a165-a3edec9408b5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
