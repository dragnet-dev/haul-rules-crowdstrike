// Dragnet [Ransomware]: dragnet-ransomware-2025-1015 — Mass File Rename (nightspire)
// Status: deprecated | Level: high | ID: 875ca6b8-2ad5-5a2a-b4c7-eed844bc54a9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
