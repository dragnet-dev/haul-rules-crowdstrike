// Dragnet [Ransomware]: dragnet-ransomware-2024-5147 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 23d66e44-07da-5a72-b643-c54a9ef1dbe8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
