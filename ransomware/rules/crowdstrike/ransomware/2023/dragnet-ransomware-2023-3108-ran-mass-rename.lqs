// Dragnet [Ransomware]: dragnet-ransomware-2023-3108 — Mass File Rename (donutleaks)
// Status: experimental | Level: high | ID: e10d8c8d-bdeb-51df-bf4a-9355c47ccb51

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
