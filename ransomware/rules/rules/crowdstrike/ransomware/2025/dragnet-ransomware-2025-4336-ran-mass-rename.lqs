// Dragnet [Ransomware]: dragnet-ransomware-2025-4336 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 6495bea8-51cd-5f9f-b66c-0c2358297e69

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
