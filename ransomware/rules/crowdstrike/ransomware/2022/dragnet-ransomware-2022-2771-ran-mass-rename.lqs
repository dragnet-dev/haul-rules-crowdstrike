// Dragnet [Ransomware]: dragnet-ransomware-2022-2771 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 5098fe0a-9698-57c8-aae6-afb4e292277d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
