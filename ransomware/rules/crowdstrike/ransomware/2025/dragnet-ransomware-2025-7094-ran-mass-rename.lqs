// Dragnet [Ransomware]: dragnet-ransomware-2025-7094 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: d85d7194-9168-543b-8cca-f99bf2d87f64

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
