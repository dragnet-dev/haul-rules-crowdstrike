// Dragnet [Ransomware]: dragnet-ransomware-2023-0182 — Mass File Rename (play)
// Status: experimental | Level: high | ID: f6b0d6bf-10cb-559b-97e8-a554f9fa9dc9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
