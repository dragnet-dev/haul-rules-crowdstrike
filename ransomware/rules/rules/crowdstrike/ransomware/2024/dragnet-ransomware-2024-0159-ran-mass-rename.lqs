// Dragnet [Ransomware]: dragnet-ransomware-2024-0159 — Mass File Rename (dragonransomware)
// Status: experimental | Level: high | ID: 74a10913-64e7-549a-a779-d60b451ab262

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
