// Dragnet [Ransomware]: dragnet-ransomware-2024-0553 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 5ae80636-e4bb-53fb-92c9-0fecec4e4592

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
