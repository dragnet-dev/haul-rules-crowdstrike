// Dragnet [Ransomware]: dragnet-ransomware-2024-1261 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 4f238516-7318-50e5-bea3-2f387196142a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
