// Dragnet [Ransomware]: dragnet-ransomware-2025-2327 — Mass File Rename (pear)
// Status: experimental | Level: high | ID: 51f540d8-601f-5043-a911-8479b05f34ac

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
