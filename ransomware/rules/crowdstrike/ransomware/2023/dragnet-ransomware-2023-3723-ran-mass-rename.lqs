// Dragnet [Ransomware]: dragnet-ransomware-2023-3723 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 66e4d55a-eeef-5e96-b74b-46105243335b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
