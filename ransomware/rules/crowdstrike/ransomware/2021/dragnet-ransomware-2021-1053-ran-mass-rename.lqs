// Dragnet [Ransomware]: dragnet-ransomware-2021-1053 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 790ceac4-0393-5226-a828-356e49b80f35

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
