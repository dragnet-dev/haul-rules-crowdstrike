// Dragnet [Ransomware]: dragnet-ransomware-2023-0176 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 098301e0-14d4-5758-82fa-6a2e407781ae

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
