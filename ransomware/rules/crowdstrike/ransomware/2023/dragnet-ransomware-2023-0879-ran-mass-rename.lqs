// Dragnet [Ransomware]: dragnet-ransomware-2023-0879 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 79732b66-b8cb-5598-a55c-8a922ea781fc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
