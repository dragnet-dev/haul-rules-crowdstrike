// Dragnet [Ransomware]: dragnet-ransomware-2024-1741 — Mass File Rename (meow)
// Status: experimental | Level: high | ID: 39f51e32-c9f1-5cd9-9708-3201c774b5dd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
