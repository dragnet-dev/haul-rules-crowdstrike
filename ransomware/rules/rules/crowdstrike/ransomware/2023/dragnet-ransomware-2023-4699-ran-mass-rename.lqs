// Dragnet [Ransomware]: dragnet-ransomware-2023-4699 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 5a31c24d-ca0e-55c7-896c-c085e6e777be

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
