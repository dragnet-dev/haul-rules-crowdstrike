// Dragnet [Ransomware]: dragnet-ransomware-2020-0148 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 8349a5cf-6f0b-5c2c-a408-f00290667130

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
