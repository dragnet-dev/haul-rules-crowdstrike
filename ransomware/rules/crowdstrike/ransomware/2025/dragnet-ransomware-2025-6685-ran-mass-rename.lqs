// Dragnet [Ransomware]: dragnet-ransomware-2025-6685 — Mass File Rename (datacarry)
// Status: deprecated | Level: high | ID: ee21f30b-4b8b-58be-a453-7b340176ae43

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
