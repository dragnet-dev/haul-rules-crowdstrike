// Dragnet [Ransomware]: dragnet-ransomware-2024-1427 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: b2daf4d1-0d2c-5388-82e1-692d5d25a6c5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
