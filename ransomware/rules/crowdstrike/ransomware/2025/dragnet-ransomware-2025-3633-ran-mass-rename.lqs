// Dragnet [Ransomware]: dragnet-ransomware-2025-3633 — Mass File Rename (nova)
// Status: experimental | Level: high | ID: c0196f77-3ffd-5724-9b68-fac3d5f25017

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
