// Dragnet [Ransomware]: dragnet-ransomware-2025-2484 — Mass File Rename (thegentlemen)
// Status: experimental | Level: high | ID: 367abbd1-9379-5341-a00b-2762eece6965

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
