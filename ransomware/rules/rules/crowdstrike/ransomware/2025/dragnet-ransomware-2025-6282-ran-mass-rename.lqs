// Dragnet [Ransomware]: dragnet-ransomware-2025-6282 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 12793f1e-5e50-54a8-a1b9-469ea33b32b4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
