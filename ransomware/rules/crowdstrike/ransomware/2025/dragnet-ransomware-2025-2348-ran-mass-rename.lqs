// Dragnet [Ransomware]: dragnet-ransomware-2025-2348 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: a1ab08d5-5d9e-5582-9798-16337cc0358d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
