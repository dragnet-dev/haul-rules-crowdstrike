// Dragnet [Ransomware]: dragnet-ransomware-2024-5712 — Mass File Rename (cicada3301)
// Status: experimental | Level: high | ID: 1f6b0145-77c7-54b8-9027-c1cc1789af49

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
