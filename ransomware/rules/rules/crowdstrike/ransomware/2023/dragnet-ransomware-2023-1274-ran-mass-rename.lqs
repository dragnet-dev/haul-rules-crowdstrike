// Dragnet [Ransomware]: dragnet-ransomware-2023-1274 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: bbc20d30-ef50-5d5a-a183-6bad4f9c9b75

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
