// Dragnet [Ransomware]: dragnet-ransomware-2023-0145 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 4e7ef5d5-b4c0-560a-b352-20628a5f2d3b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
