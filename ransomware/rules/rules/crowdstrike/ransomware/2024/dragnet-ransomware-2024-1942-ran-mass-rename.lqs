// Dragnet [Ransomware]: dragnet-ransomware-2024-1942 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 58e9c08a-5cce-5c6d-a01c-c82139cd8157

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
