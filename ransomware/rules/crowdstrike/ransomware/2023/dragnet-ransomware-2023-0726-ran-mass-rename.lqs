// Dragnet [Ransomware]: dragnet-ransomware-2023-0726 — Mass File Rename (noescape)
// Status: experimental | Level: high | ID: 54730db4-0842-5000-872d-ca648a7fbffb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
