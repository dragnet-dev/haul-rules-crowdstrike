// Dragnet [Ransomware]: dragnet-ransomware-2023-1827 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 5b2a7d3b-bb99-5006-9b3b-71e288fa12af

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
