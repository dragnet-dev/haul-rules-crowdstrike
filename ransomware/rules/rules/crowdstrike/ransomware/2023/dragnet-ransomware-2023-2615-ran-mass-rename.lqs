// Dragnet [Ransomware]: dragnet-ransomware-2023-2615 — Mass File Rename (cloak)
// Status: experimental | Level: high | ID: 0a9a4e76-7a2b-5bf9-a713-7a1037a29291

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
