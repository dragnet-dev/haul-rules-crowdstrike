// Dragnet [Ransomware]: dragnet-ransomware-2025-5851 — Mass File Rename (gunra)
// Status: experimental | Level: high | ID: 74239ec5-24af-5f4f-bb98-8e6d38ea2a40

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
