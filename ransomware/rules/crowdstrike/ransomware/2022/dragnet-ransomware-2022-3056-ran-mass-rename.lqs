// Dragnet [Ransomware]: dragnet-ransomware-2022-3056 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: d690b3d4-07aa-5eb9-986e-aa5a1ffa8181

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
