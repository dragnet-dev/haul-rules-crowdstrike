// Dragnet [Container]: dragnet-container-2024-0568 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 76d707d0-3451-5c8f-b005-38925f96a9e3

#event_simpleName=*
| (ImageFileName = *almalinux:8* OR ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
