// Dragnet [Ransomware]: dragnet-ransomware-2022-0330 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 9f5b83f7-3c31-59a4-930d-a3949809689d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
