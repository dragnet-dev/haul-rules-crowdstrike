// Dragnet [Ransomware]: dragnet-ransomware-2023-1120 — Mass File Rename (cactus)
// Status: deprecated | Level: high | ID: 943bb2fe-d8f7-5280-ba85-bf17b8b84354

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
