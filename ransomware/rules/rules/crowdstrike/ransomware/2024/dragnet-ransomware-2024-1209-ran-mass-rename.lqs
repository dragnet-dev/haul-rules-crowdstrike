// Dragnet [Ransomware]: dragnet-ransomware-2024-1209 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: bc0a638e-2bff-5a4f-9159-4110c52136e1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
