// Dragnet [Ransomware]: dragnet-ransomware-2024-3312 — Mass File Rename (ValenciaLeaks)
// Status: experimental | Level: high | ID: 46160d96-2c9a-5dd7-bd73-f093283fc305

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
