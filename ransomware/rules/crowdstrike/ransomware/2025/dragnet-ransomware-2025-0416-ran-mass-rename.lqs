// Dragnet [Ransomware]: dragnet-ransomware-2025-0416 — Mass File Rename (lockbit5)
// Status: test | Level: high | ID: ae8fea1c-8cdc-593d-8312-477b77009a81

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
