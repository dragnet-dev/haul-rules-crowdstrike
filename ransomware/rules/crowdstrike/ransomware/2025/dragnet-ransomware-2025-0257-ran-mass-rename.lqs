// Dragnet [Ransomware]: dragnet-ransomware-2025-0257 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 81605991-b4d1-5ccd-a067-4ad02029bf37

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
