// Dragnet [Ransomware]: dragnet-ransomware-2023-5039 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: a9acc6a0-787d-59f4-9efa-dbc56e282f7b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
