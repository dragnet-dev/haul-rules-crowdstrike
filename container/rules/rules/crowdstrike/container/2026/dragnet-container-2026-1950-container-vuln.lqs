// Dragnet [Container]: dragnet-container-2026-1950 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 50b8896a-4b4d-5667-a924-ff7fa226941f

#event_simpleName=*
| (ImageFileName = *debian:7* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10* OR ImageFileName = *ubuntu:13.04* OR ImageFileName = *ubuntu:13.10*)
| table([timestamp, ComputerName])
| limit(1000)
