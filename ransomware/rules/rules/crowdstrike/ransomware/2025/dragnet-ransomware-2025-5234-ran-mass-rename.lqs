// Dragnet [Ransomware]: dragnet-ransomware-2025-5234 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 2a099a97-cc17-5c55-98d1-559e1719e59d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
