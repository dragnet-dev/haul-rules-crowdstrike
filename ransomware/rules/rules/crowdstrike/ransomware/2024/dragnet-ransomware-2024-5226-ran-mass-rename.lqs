// Dragnet [Ransomware]: dragnet-ransomware-2024-5226 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 5eaa8344-886a-5a12-b4dd-b477f63c30c7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
