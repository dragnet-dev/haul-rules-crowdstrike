// Dragnet [Ransomware]: dragnet-ransomware-2025-5670 — Mass File Rename (payoutsking)
// Status: test | Level: high | ID: 4f655f5f-9402-5952-8e3a-4be55b81656c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
