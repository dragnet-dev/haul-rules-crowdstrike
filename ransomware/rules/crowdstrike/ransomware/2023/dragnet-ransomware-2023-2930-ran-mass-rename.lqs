// Dragnet [Ransomware]: dragnet-ransomware-2023-2930 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 5fc1d58d-1877-5763-af73-993ccd0ab441

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
