// Dragnet [Ransomware]: dragnet-ransomware-2025-1601 — Mass File Rename (warlock)
// Status: deprecated | Level: high | ID: 93151c55-40e6-5cb7-b54d-82db788d9d28

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
