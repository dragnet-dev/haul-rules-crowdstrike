// Dragnet [Ransomware]: dragnet-ransomware-2026-2665 — Mass File Rename (lockbit5)
// Status: stable | Level: high | ID: ae84eed0-75fc-5988-8265-67cb52c789a7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
