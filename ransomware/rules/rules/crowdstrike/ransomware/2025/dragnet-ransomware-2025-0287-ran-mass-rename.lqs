// Dragnet [Ransomware]: dragnet-ransomware-2025-0287 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 07544acc-d181-5ab3-8937-053029703877

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
