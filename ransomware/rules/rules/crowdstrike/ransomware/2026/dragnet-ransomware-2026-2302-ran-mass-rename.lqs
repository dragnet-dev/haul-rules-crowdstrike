// Dragnet [Ransomware]: dragnet-ransomware-2026-2302 — Mass File Rename (incransom)
// Status: test | Level: high | ID: 24bf4fd6-6306-5f1f-8e75-07db2bea72ee

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
