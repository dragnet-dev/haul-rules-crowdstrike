// Dragnet [Ransomware]: dragnet-ransomware-2023-2476 — Mass File Rename (royal)
// Status: experimental | Level: high | ID: 31317a14-fcaa-512a-b7dd-9657f6096677

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
