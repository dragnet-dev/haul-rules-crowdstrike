// Dragnet [Ransomware]: dragnet-ransomware-2022-1181 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 5e6c5126-e05e-566e-a6d6-5204e6d9e4bf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
