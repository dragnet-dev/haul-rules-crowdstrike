// Dragnet [Ransomware]: dragnet-ransomware-2024-3398 — Mass File Rename (cloak)
// Status: deprecated | Level: high | ID: 0488b8de-fc1e-516b-a118-138a0bcb7061

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
