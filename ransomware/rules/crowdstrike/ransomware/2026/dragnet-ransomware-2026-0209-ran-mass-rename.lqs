// Dragnet [Ransomware]: dragnet-ransomware-2026-0209 — Mass File Rename (incransom)
// Status: stable | Level: high | ID: 987792e4-62d1-5331-a4a2-1e215f9b8da6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
