// Dragnet [Ransomware]: dragnet-ransomware-2023-0591 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 56d355d5-99f6-5b62-8b9f-a7dcd6658df9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
