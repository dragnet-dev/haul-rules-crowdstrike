// Dragnet [Ransomware]: dragnet-ransomware-2026-1121 — Mass File Rename (thegentlemen)
// Status: test | Level: high | ID: b1b6bd15-aa2a-5a93-a8c4-8d15ba9f2e0e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
