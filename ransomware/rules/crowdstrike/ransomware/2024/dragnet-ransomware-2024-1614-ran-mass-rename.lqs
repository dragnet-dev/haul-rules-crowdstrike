// Dragnet [Ransomware]: dragnet-ransomware-2024-1614 — Mass File Rename (qiulong)
// Status: experimental | Level: high | ID: aa1c7864-3e2e-5bab-ac98-5a7a64303192

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
