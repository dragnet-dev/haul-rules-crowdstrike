// Dragnet [Ransomware]: dragnet-ransomware-2024-4477 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 286bbcad-ae70-5b55-b1c9-a575467d2272

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
