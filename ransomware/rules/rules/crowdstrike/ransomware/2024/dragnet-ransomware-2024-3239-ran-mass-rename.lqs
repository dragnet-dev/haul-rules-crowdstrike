// Dragnet [Ransomware]: dragnet-ransomware-2024-3239 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 076520e0-16be-56f1-80ea-6bb7865f0b26

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
