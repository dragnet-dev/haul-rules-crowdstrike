// Dragnet [Ransomware]: dragnet-ransomware-2023-1870 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: d6b5e7da-7594-5c9a-9ac7-bcb905322d50

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
