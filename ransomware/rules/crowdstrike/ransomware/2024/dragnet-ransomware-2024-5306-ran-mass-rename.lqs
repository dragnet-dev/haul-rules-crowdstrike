// Dragnet [Ransomware]: dragnet-ransomware-2024-5306 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: 2871efc1-63c1-5028-a4a5-f2cc30df7525

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
