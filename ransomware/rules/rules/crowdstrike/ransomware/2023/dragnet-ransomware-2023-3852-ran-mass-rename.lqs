// Dragnet [Ransomware]: dragnet-ransomware-2023-3852 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 96677339-daa3-58e5-8b15-cb4d63b0aea3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
