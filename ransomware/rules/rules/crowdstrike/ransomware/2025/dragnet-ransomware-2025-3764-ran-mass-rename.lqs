// Dragnet [Ransomware]: dragnet-ransomware-2025-3764 — Mass File Rename (stormous)
// Status: deprecated | Level: high | ID: 6734b08a-a622-5b43-9a12-8202c8b80c02

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
