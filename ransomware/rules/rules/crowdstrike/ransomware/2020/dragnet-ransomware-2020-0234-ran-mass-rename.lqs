// Dragnet [Ransomware]: dragnet-ransomware-2020-0234 — Mass File Rename (ryuk)
// Status: deprecated | Level: high | ID: 14b44153-71db-58dc-bddc-d6153d53612c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
