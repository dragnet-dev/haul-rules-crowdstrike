// Dragnet [Ransomware]: dragnet-ransomware-2025-5824 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: 60eccd7b-6f43-59c3-9720-0cc492f98c3b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
