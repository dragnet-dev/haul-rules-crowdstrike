// Dragnet [Container]: dragnet-container-2024-1080 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 7a54aae1-6432-5c51-bdfc-32158c072a6d

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:8* OR ImageFileName = *debian:9* OR ImageFileName = *ubuntu:18.04* OR ImageFileName = *ubuntu:18.04-ESM* OR ImageFileName = *ubuntu:19.04*)
| table([timestamp, ComputerName])
| limit(1000)
