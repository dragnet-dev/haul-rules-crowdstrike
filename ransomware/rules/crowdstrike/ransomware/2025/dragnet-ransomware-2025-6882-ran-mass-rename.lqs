// Dragnet [Ransomware]: dragnet-ransomware-2025-6882 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: ebf2d5d7-c189-5d02-b6ca-c3d5fc73e7fc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
