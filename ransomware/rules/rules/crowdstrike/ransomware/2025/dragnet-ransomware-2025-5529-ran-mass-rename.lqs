// Dragnet [Ransomware]: dragnet-ransomware-2025-5529 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: 6867693e-6346-5b33-b305-99dbc70a0332

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
