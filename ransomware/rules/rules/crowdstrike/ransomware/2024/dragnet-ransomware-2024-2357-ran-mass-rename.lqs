// Dragnet [Ransomware]: dragnet-ransomware-2024-2357 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 47d10458-a9e5-5dd4-818b-98f5f4ab2010

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
