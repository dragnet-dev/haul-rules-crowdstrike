// Dragnet [Container]: dragnet-container-2024-1414 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: e484c3c8-0874-5b15-963b-b91ca2029622

#event_simpleName=*
| (ImageFileName = *almalinux:8* OR ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:8* OR ImageFileName = *debian:9* OR ImageFileName = *oraclelinux:8* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:16.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
