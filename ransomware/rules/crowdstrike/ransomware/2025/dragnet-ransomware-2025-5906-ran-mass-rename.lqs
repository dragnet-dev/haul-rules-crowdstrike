// Dragnet [Ransomware]: dragnet-ransomware-2025-5906 — Mass File Rename (play)
// Status: experimental | Level: high | ID: eee03f92-6294-5267-a60f-64d12bead050

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
