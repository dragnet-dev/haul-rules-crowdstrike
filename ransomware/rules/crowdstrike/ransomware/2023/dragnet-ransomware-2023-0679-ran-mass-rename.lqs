// Dragnet [Ransomware]: dragnet-ransomware-2023-0679 — Mass File Rename (nokoyawa)
// Status: experimental | Level: high | ID: 69691380-017a-51f6-96e2-af695496b5e0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
