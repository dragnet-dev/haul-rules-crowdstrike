// Dragnet [Ransomware]: dragnet-ransomware-2022-2673 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: f85d5f30-4969-53e4-9163-ef09d17b2969

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
