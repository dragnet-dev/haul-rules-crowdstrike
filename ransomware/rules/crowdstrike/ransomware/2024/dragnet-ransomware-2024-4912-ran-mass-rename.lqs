// Dragnet [Ransomware]: dragnet-ransomware-2024-4912 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 8b16789d-ab78-5d76-b96b-38673a0520cd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
