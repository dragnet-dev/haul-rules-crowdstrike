// Dragnet [Ransomware]: dragnet-ransomware-2021-0362 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 6eeedd5b-7427-53bb-8690-5d02bf345ee4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
