// Dragnet [Ransomware]: dragnet-ransomware-2025-4378 — Mass File Rename (sinobi)
// Status: experimental | Level: high | ID: d6ef2d11-2163-53cc-9a4e-a690c0b8695d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
