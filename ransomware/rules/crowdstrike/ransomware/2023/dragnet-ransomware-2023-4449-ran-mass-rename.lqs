// Dragnet [Ransomware]: dragnet-ransomware-2023-4449 — Mass File Rename (darkrace)
// Status: experimental | Level: high | ID: 41e19cec-01b4-5f78-9623-88a5b8d6bc95

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
