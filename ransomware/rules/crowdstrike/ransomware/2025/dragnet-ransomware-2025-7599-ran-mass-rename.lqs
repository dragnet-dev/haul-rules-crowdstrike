// Dragnet [Ransomware]: dragnet-ransomware-2025-7599 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: c8dd6b61-d2df-5936-9187-fed86d7fe352

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
