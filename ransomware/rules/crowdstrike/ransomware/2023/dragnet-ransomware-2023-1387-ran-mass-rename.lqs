// Dragnet [Ransomware]: dragnet-ransomware-2023-1387 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 52d2a156-c1eb-51c4-913e-23d4c1627c3d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
