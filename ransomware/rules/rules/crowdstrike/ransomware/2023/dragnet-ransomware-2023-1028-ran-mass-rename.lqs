// Dragnet [Ransomware]: dragnet-ransomware-2023-1028 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: b3d19824-9594-52e2-9751-fe4193bb1778

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
