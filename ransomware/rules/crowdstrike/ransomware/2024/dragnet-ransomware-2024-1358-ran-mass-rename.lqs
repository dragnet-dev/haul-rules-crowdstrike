// Dragnet [Ransomware]: dragnet-ransomware-2024-1358 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 3d7a0338-d59a-5580-ac22-f296af9898a4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
