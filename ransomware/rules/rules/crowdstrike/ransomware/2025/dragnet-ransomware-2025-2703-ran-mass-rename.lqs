// Dragnet [Ransomware]: dragnet-ransomware-2025-2703 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: c3bc1da3-a342-5070-934f-e7b077a3dda3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
