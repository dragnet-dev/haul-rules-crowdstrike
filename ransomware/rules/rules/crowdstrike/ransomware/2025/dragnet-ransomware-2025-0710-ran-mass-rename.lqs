// Dragnet [Ransomware]: dragnet-ransomware-2025-0710 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: a260e8e0-3112-518a-9acd-233d1f214057

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
