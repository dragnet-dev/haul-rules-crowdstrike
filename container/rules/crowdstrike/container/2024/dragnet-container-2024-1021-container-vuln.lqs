// Dragnet [Container]: dragnet-container-2024-1021 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: b3b5441a-9c4a-58c3-abd9-7fae3a43e86c

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:9*)
| table([timestamp, ComputerName])
| limit(1000)
