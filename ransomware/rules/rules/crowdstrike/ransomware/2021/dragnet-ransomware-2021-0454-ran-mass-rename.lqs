// Dragnet [Ransomware]: dragnet-ransomware-2021-0454 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: b302e249-cdb2-584d-b7b3-b49dd26f2bc9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
