// Dragnet [Ransomware]: dragnet-ransomware-2023-2279 — Mass File Rename (noescape)
// Status: experimental | Level: high | ID: a5d1a95d-c933-5652-a96c-7a572c842188

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
