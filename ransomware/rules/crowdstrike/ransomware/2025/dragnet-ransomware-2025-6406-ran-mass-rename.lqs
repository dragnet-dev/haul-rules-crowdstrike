// Dragnet [Ransomware]: dragnet-ransomware-2025-6406 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: a972fc29-dac9-599e-819f-f3001e8a3e20

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
