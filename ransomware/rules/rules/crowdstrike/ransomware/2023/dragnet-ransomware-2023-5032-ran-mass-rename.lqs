// Dragnet [Ransomware]: dragnet-ransomware-2023-5032 — Mass File Rename (cloak)
// Status: deprecated | Level: high | ID: d4093a22-f8c1-5dcb-b31d-3c6348f22721

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
