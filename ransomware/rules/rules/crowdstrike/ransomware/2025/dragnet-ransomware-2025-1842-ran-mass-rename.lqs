// Dragnet [Ransomware]: dragnet-ransomware-2025-1842 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: c667de3c-df24-5b05-985d-c43b52ecdf6f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
