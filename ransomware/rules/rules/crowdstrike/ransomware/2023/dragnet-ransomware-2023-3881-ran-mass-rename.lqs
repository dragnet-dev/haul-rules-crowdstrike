// Dragnet [Ransomware]: dragnet-ransomware-2023-3881 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 1d8a1dc2-9b99-59be-8362-8fa5fe5148c4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
