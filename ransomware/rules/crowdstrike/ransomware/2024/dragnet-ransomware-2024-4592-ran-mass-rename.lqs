// Dragnet [Ransomware]: dragnet-ransomware-2024-4592 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 705f156b-5c6d-5396-83ee-8604428073c0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
