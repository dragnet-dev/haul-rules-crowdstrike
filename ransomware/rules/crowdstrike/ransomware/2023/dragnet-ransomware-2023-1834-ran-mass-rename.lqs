// Dragnet [Ransomware]: dragnet-ransomware-2023-1834 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 5cf7388f-4bd2-5fa4-a83f-9e9374a44d3c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
