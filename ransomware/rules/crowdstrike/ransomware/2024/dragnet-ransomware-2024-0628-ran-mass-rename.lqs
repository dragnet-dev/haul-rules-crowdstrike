// Dragnet [Ransomware]: dragnet-ransomware-2024-0628 — Mass File Rename (spacebears)
// Status: experimental | Level: high | ID: 57bc6c70-4158-5fa2-ba07-763aacac8031

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
