// Dragnet [Ransomware]: dragnet-ransomware-2022-0257 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 0ff513f7-bd6b-562b-9d07-8a41c45fe405

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
