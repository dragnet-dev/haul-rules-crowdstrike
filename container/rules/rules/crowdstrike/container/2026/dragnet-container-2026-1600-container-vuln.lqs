// Dragnet [Container]: dragnet-container-2026-1600 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 68aeeeec-363d-5239-ab8e-52a6a52bd9e8

#event_simpleName=*
| (ImageFileName = *chainguard:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
