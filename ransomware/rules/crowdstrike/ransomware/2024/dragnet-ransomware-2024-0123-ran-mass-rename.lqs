// Dragnet [Ransomware]: dragnet-ransomware-2024-0123 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 40f03637-46c9-5335-8bea-7886f09ff92a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
