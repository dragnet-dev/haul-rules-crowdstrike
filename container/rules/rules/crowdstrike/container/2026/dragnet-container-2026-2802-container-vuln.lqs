// Dragnet [Container]: dragnet-container-2026-2802 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 3238a928-005c-55bf-b99b-52dc3177ce67

#event_simpleName=*
| (ImageFileName = *amazonlinux:1* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:6*)
| table([timestamp, ComputerName])
| limit(1000)
