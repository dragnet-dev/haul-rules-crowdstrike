// Dragnet [Ransomware]: dragnet-ransomware-2025-1278 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: aa7be734-c30c-553a-861f-c0f01114ce45

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
