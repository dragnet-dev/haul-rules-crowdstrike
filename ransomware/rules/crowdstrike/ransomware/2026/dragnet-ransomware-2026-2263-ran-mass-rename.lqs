// Dragnet [Ransomware]: dragnet-ransomware-2026-2263 — Mass File Rename (dragonforce)
// Status: stable | Level: high | ID: 01cf252d-23aa-54d1-9ec6-30c6a7f2b90b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
