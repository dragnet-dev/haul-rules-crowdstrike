// Dragnet [Ransomware]: dragnet-ransomware-2024-4958 — Mass File Rename (safepay)
// Status: deprecated | Level: high | ID: fc238724-aeaa-510f-b520-704d47498933

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
