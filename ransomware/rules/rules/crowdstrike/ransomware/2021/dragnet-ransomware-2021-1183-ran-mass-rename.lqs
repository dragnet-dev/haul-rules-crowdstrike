// Dragnet [Ransomware]: dragnet-ransomware-2021-1183 — Mass File Rename (marketo)
// Status: deprecated | Level: high | ID: 0eee3580-76d3-52f2-b93d-4e2f7565d3ea

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
