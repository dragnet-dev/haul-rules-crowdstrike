// Dragnet [Container]: dragnet-container-2026-2821 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 3130c48f-ed24-57cb-8459-31601ead307b

#event_simpleName=*
| (ImageFileName = *alpine:3.23* OR ImageFileName = *alpine edge:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
