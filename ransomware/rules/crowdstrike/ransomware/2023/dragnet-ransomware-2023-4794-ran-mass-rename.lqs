// Dragnet [Ransomware]: dragnet-ransomware-2023-4794 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 4407d03d-399e-56d1-96ae-71edc8b282a1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
