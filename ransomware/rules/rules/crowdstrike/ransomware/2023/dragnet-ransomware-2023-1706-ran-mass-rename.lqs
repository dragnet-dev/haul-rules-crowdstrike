// Dragnet [Ransomware]: dragnet-ransomware-2023-1706 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 4e0ff7de-c0a4-5af9-9c57-37d4c0ed05df

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
