// Dragnet [Ransomware]: dragnet-ransomware-2022-2466 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 2a5fcd47-0ae8-53d9-9953-036fdb7365df

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
