// Dragnet [Ransomware]: dragnet-ransomware-2024-0887 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: 55d03d83-3c72-5747-b7a6-fbeca0bae86b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
