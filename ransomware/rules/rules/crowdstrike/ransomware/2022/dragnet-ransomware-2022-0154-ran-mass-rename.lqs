// Dragnet [Ransomware]: dragnet-ransomware-2022-0154 — Mass File Rename (snatch)
// Status: deprecated | Level: high | ID: 43301ea9-4b60-563a-b071-078cc8552131

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
