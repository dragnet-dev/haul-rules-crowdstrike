// Dragnet [Ransomware]: dragnet-ransomware-2024-4265 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: ab01cc1d-f99b-5277-bf71-7a438a5d1bee

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
