// Dragnet [Ransomware]: dragnet-ransomware-2023-3500 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 16258785-39a7-53ce-9df0-e2b9a3b885f9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
