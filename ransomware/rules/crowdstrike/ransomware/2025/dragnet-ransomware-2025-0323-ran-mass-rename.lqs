// Dragnet [Ransomware]: dragnet-ransomware-2025-0323 — Mass File Rename (embargo)
// Status: experimental | Level: high | ID: 80f675cf-69fe-5930-8d19-2d0bbd2eeeae

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
