// Dragnet [Ransomware]: dragnet-ransomware-2024-0471 — Mass File Rename (ransomexx)
// Status: experimental | Level: high | ID: a08a9e89-3709-5921-91fa-27a32b0fcf82

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
