// Dragnet [Ransomware]: dragnet-ransomware-2023-4380 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 122d67be-9112-5cd1-b416-1795115eb7ad

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
