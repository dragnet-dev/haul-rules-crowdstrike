// Dragnet [Ransomware]: dragnet-ransomware-2024-5831 — Mass File Rename (ransomhouse)
// Status: experimental | Level: high | ID: d2fdd2b1-3573-5ce4-9bfc-d9f189a36af9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
