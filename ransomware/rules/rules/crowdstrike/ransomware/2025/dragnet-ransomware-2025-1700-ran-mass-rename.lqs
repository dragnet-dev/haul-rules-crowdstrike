// Dragnet [Ransomware]: dragnet-ransomware-2025-1700 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 6b6fb019-a9e2-55b1-a93f-b6200398c558

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
