// Dragnet [Ransomware]: dragnet-ransomware-2025-2704 — Mass File Rename (flocker)
// Status: experimental | Level: high | ID: dbb4590e-4c55-56f4-83f2-9b0e8023a9ac

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
