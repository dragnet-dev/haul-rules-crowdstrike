// Dragnet [Ransomware]: dragnet-ransomware-2024-4189 — Mass File Rename (ValenciaLeaks)
// Status: experimental | Level: high | ID: 8b649b13-d0ae-5885-968c-357984fa62b2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
