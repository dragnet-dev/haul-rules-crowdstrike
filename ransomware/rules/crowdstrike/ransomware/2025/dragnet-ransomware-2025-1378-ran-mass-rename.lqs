// Dragnet [Ransomware]: dragnet-ransomware-2025-1378 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 5708088a-875c-5e76-ad73-5906bf72ee77

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
