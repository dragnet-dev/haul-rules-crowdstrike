// Dragnet [Ransomware]: dragnet-ransomware-2022-1600 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: be444100-c318-5dbe-a19f-2951a46b489b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
