// Dragnet [Ransomware]: dragnet-ransomware-2025-0962 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: b8bc1a41-e9f0-5cc9-9201-a6da69dab7ac

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
