// Dragnet [Ransomware]: dragnet-ransomware-2022-0106 — Mass File Rename (everest)
// Status: deprecated | Level: high | ID: fbeed2a7-e3ed-5782-bdd6-6321ec1f9e0e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
