// Dragnet [Ransomware]: dragnet-ransomware-2024-2350 — Mass File Rename (raworld)
// Status: experimental | Level: high | ID: edcd727b-0eb6-5ba6-96df-e4a17795f614

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
