// Dragnet [Ransomware]: dragnet-ransomware-2025-1323 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: c0c47a69-c76a-5c1f-98d1-9d8c4242aa2d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
