// Dragnet [Ransomware]: dragnet-ransomware-2023-3192 — Mass File Rename (cactus)
// Status: deprecated | Level: high | ID: 2f2743b2-5ff1-5c77-a1d9-f7b37a8dac24

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
