// Dragnet [Ransomware]: dragnet-ransomware-2025-2300 — Mass File Rename (anubis)
// Status: experimental | Level: high | ID: 57387fc9-89bc-51a6-9211-fdc1a0bb9327

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
