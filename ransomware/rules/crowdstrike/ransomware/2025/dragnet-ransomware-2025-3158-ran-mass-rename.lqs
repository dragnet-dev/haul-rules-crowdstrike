// Dragnet [Ransomware]: dragnet-ransomware-2025-3158 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 4ffdae31-58d0-56a9-88a4-7101efb904e9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
