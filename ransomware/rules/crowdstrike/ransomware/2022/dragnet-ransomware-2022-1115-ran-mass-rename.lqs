// Dragnet [Ransomware]: dragnet-ransomware-2022-1115 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 3a453007-2863-5fac-9cae-07762130bf0b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
