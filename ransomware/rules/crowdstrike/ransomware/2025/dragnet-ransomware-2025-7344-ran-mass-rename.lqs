// Dragnet [Ransomware]: dragnet-ransomware-2025-7344 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 5b67a9e3-3112-58e7-83d8-48e5fa65147c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
