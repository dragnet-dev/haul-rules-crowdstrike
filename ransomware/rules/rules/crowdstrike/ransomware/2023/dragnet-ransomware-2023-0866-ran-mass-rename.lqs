// Dragnet [Ransomware]: dragnet-ransomware-2023-0866 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: daf2b334-6eb4-5041-ad49-2461cfdbaab9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
