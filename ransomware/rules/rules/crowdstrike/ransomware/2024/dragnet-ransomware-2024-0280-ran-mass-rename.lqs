// Dragnet [Ransomware]: dragnet-ransomware-2024-0280 — Mass File Rename (BrainCipher)
// Status: experimental | Level: high | ID: 4acfb4d7-adfa-5465-958a-b02c9e9fe6a8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
