// Dragnet [Ransomware]: dragnet-ransomware-2023-4317 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 71d88fa1-0128-5c56-9582-dffd70401276

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
