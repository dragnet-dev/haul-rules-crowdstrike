// Dragnet [Ransomware]: dragnet-ransomware-2024-2883 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 694cf3cc-b279-5f79-8d2c-0885f2fa48b2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
