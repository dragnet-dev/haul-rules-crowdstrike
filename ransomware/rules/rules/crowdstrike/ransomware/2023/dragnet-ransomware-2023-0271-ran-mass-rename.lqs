// Dragnet [Ransomware]: dragnet-ransomware-2023-0271 — Mass File Rename (stormous)
// Status: deprecated | Level: high | ID: 42fb677d-8826-5546-8672-80eafca28b91

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
