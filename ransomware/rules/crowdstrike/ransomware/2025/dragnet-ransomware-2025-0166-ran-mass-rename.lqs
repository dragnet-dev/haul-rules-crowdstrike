// Dragnet [Ransomware]: dragnet-ransomware-2025-0166 — Mass File Rename (rhysida)
// Status: experimental | Level: high | ID: 8fb829dd-bcb2-579a-be24-a31771279b37

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
