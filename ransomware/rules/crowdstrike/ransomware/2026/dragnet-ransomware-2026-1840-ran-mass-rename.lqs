// Dragnet [Ransomware]: dragnet-ransomware-2026-1840 — Mass File Rename (safepay)
// Status: stable | Level: high | ID: e42236fd-833b-5488-9041-74c294572b07

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
