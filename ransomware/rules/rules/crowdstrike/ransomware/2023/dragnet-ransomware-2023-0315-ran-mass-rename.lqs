// Dragnet [Ransomware]: dragnet-ransomware-2023-0315 — Mass File Rename (play)
// Status: experimental | Level: high | ID: bfc5ed6c-c492-5a51-8451-ed5f24e9fc2c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
