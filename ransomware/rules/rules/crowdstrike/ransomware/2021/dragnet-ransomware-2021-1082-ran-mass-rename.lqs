// Dragnet [Ransomware]: dragnet-ransomware-2021-1082 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 479bd0d2-0593-5473-a478-3fa082dc98a1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
