// Dragnet [Ransomware]: dragnet-ransomware-2023-2296 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 6469db07-61d7-5e0d-9786-ac2c16f2d2e2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
