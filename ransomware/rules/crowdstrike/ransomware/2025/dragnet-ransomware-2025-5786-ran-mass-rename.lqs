// Dragnet [Ransomware]: dragnet-ransomware-2025-5786 — Mass File Rename (play)
// Status: experimental | Level: high | ID: b614637d-3a26-514e-b8cb-1b345f7ac30f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
