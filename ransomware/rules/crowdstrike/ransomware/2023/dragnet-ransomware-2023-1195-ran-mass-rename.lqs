// Dragnet [Ransomware]: dragnet-ransomware-2023-1195 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: a3fc8792-408b-56dc-a1a9-b8a22d11d735

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
