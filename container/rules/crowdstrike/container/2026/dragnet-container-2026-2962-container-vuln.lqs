// Dragnet [Container]: dragnet-container-2026-2962 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 04e4f9d1-852f-5aa4-bfbb-80da25930562

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:8* OR ImageFileName = *redhat/ubi9:*)
| table([timestamp, ComputerName])
| limit(1000)
