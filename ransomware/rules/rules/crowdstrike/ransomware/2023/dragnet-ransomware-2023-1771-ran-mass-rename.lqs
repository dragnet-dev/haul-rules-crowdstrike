// Dragnet [Ransomware]: dragnet-ransomware-2023-1771 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: e6f14f9d-fef7-5ea6-814b-fb5872381680

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
