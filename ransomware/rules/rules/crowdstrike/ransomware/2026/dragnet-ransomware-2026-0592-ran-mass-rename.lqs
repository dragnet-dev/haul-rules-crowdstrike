// Dragnet [Ransomware]: dragnet-ransomware-2026-0592 — Mass File Rename (AiLock)
// Status: deprecated | Level: high | ID: b3145df5-f503-59e3-9712-936a42a78036

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
