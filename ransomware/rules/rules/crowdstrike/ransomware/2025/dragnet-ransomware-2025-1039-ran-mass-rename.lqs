// Dragnet [Ransomware]: dragnet-ransomware-2025-1039 — Mass File Rename (spacebears)
// Status: experimental | Level: high | ID: 51823ae8-3df2-543a-8cde-b038d1e91f20

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
