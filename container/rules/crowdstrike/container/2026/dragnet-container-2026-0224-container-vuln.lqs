// Dragnet [Container]: dragnet-container-2026-0224 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: ec35dadd-3234-5a48-8b2c-8c1682397258

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:6*)
| table([timestamp, ComputerName])
| limit(1000)
