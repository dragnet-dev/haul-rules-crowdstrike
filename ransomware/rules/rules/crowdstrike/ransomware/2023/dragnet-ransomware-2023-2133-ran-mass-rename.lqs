// Dragnet [Ransomware]: dragnet-ransomware-2023-2133 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: b11b96d3-72ba-5ad6-9c41-5e9667d5d384

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
