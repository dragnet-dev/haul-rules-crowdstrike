// Dragnet [Ransomware]: dragnet-ransomware-2024-2898 — Mass File Rename (ransomhouse)
// Status: experimental | Level: high | ID: 7637bcbf-d461-5729-b6dd-21200728f782

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
