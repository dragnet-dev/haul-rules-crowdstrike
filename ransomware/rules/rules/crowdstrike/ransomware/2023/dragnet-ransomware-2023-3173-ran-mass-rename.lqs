// Dragnet [Ransomware]: dragnet-ransomware-2023-3173 — Mass File Rename (vicesociety)
// Status: experimental | Level: high | ID: 01eb4f6a-34f0-5bca-a6fb-fdfd45a230b1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
