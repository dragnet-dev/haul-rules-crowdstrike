// Dragnet [Ransomware]: dragnet-ransomware-2022-2864 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 1684debe-5a96-5513-b187-bfd346ba52e6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
