// Dragnet [Ransomware]: dragnet-ransomware-2024-1746 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: 4cb32133-ad68-5533-bd61-79e814b98d0f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
