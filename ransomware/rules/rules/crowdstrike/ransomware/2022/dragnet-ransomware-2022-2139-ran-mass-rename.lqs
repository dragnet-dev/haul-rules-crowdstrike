// Dragnet [Ransomware]: dragnet-ransomware-2022-2139 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 40612d99-db82-5394-9331-1950bfb16168

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
