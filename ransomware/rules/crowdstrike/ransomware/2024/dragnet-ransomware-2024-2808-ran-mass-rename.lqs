// Dragnet [Ransomware]: dragnet-ransomware-2024-2808 — Mass File Rename (play)
// Status: experimental | Level: high | ID: fee544c8-501b-58fb-8256-7865a4234f08

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
