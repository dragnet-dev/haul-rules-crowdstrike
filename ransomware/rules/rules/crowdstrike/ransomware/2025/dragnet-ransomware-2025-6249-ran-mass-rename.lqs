// Dragnet [Ransomware]: dragnet-ransomware-2025-6249 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 1fe32d1a-747f-5e88-bb50-7ab69ece766e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
