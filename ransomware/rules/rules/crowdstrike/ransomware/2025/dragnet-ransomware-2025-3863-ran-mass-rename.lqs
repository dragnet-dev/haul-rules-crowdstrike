// Dragnet [Ransomware]: dragnet-ransomware-2025-3863 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 017899fc-fa15-572a-98e7-90662f9d0de3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
