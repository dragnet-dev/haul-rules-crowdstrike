// Dragnet [Ransomware]: dragnet-ransomware-2026-3283 — Mass File Rename (dragonforce)
// Status: stable | Level: high | ID: 32a58c7e-b38d-5ca2-aa1b-8301fa9803b9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
