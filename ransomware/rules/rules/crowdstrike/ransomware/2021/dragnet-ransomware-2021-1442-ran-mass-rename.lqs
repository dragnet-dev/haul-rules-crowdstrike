// Dragnet [Ransomware]: dragnet-ransomware-2021-1442 — Mass File Rename (payloadbin)
// Status: deprecated | Level: high | ID: d71ef663-9706-53bf-a909-b92e80439fb7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
