// Dragnet [Ransomware]: dragnet-ransomware-2024-5810 — Mass File Rename (apt73)
// Status: experimental | Level: high | ID: bab8a918-2475-56d4-81ed-f42401f579cc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
