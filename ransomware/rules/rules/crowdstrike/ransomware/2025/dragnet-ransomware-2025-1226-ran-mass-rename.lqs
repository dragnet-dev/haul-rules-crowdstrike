// Dragnet [Ransomware]: dragnet-ransomware-2025-1226 — Mass File Rename (sinobi)
// Status: experimental | Level: high | ID: cf43cb59-f384-5e9e-86b2-903a8b44cd9e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
