// Dragnet [Ransomware]: dragnet-ransomware-2023-2195 — Mass File Rename (rhysida)
// Status: deprecated | Level: high | ID: 0f7917e3-7fae-5cb2-9d14-b137009cf2c4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
