// Dragnet [Ransomware]: dragnet-ransomware-2026-1347 — Mass File Rename (direwolf)
// Status: test | Level: high | ID: 7397ec3c-c476-5c12-b206-eb100c223e73

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
