// Dragnet [Ransomware]: dragnet-ransomware-2026-0829 — Mass File Rename (interlock)
// Status: test | Level: high | ID: da8f427e-6b3c-5804-a10c-a711efa5885f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
