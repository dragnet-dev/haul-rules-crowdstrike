// Dragnet [Ransomware]: dragnet-ransomware-2025-5680 — Mass File Rename (obscura)
// Status: deprecated | Level: high | ID: 9b040e0d-ed81-5ea9-93c1-50d62fd63399

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
