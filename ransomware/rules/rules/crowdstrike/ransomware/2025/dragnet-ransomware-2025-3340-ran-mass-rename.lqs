// Dragnet [Ransomware]: dragnet-ransomware-2025-3340 — Mass File Rename (termite)
// Status: experimental | Level: high | ID: 7797dee9-9fbd-5f21-a5f4-0c818fbc6268

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
