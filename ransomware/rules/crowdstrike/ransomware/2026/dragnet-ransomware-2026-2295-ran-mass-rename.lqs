// Dragnet [Ransomware]: dragnet-ransomware-2026-2295 — Mass File Rename (worldleaks)
// Status: stable | Level: high | ID: 886a2125-bb91-5351-8330-c3cbc0c10046

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
