// Dragnet [Ransomware]: dragnet-ransomware-2025-0364 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: dafde847-65fb-5ff2-be7c-424924aff07f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
