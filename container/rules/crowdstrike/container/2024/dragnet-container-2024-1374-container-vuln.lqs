// Dragnet [Container]: dragnet-container-2024-1374 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: d5ead563-5765-5c57-a4c6-33c20729c996

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
