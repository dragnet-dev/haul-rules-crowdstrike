// Dragnet [Ransomware]: dragnet-ransomware-2024-2553 — Mass File Rename (cicada3301)
// Status: experimental | Level: high | ID: aa8eb0f4-71b2-522b-816c-cbf2f49854c7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
