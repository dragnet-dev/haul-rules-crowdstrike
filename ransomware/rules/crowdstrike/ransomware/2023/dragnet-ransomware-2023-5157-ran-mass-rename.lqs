// Dragnet [Ransomware]: dragnet-ransomware-2023-5157 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 0d855d24-304c-5744-b00a-ab6304ecc877

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
