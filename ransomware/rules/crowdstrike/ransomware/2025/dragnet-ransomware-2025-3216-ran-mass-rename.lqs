// Dragnet [Ransomware]: dragnet-ransomware-2025-3216 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: f1e26294-e2d6-5f2b-b37c-0f8e7dacc234

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
