// Dragnet [Ransomware]: dragnet-ransomware-2024-3859 — Mass File Rename (hellcat)
// Status: deprecated | Level: high | ID: 15654e09-0e2a-5faa-9a56-72047b64221d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
