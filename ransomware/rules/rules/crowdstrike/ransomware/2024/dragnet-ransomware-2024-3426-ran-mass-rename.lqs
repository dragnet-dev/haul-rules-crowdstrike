// Dragnet [Ransomware]: dragnet-ransomware-2024-3426 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: 2a1e7aac-1deb-5414-b9aa-4b3045aa68ee

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
