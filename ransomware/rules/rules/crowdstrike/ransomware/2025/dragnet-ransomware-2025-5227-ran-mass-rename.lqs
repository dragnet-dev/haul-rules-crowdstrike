// Dragnet [Ransomware]: dragnet-ransomware-2025-5227 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 85746ff4-afa9-5deb-9463-e0b12b7ed88c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
