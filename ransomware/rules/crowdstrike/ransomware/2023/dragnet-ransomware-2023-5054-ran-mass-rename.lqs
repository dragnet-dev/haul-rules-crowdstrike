// Dragnet [Ransomware]: dragnet-ransomware-2023-5054 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 7ffb66d1-d8af-542e-9054-5ba5c2a7da89

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
