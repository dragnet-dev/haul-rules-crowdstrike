// Dragnet [Ransomware]: dragnet-ransomware-2025-3433 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 8ca7f9d2-c8f6-561e-8d2a-44b3861f9b2a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
