// Dragnet [Ransomware]: dragnet-ransomware-2024-4543 — Mass File Rename (dragonransomware)
// Status: experimental | Level: high | ID: e457ff2f-12ae-5e4d-8ce8-8e29cf1699f5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
