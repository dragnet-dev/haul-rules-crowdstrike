// Dragnet [Ransomware]: dragnet-ransomware-2025-7121 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: af9744c9-1e1a-5f32-bfb4-107b382b243d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
