// Dragnet [Ransomware]: dragnet-ransomware-2023-4601 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 34435bc9-cbfe-5509-a04c-3d4aed30842d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
