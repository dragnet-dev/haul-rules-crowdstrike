// Dragnet [Ransomware]: dragnet-ransomware-2021-1662 — Mass File Rename (revil)
// Status: deprecated | Level: high | ID: 605356f5-9048-5b9c-9bb2-4b5f47c53334

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
