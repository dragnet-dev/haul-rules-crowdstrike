// Dragnet [Ransomware]: dragnet-ransomware-2023-0329 — Mass File Rename (play)
// Status: deprecated | Level: high | ID: 457f7bd2-ef9d-587c-a82c-a3fc3e0e7bfb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
