// Dragnet [Ransomware]: dragnet-ransomware-2024-3819 — Mass File Rename (cicada3301)
// Status: experimental | Level: high | ID: ea7822d1-866d-5b66-bd55-d66a55dcd5c8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
