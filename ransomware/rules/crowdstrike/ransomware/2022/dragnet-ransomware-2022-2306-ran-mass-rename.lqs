// Dragnet [Ransomware]: dragnet-ransomware-2022-2306 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: d3ccacf1-9e34-5e2b-bad5-c2b09a726ab1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
