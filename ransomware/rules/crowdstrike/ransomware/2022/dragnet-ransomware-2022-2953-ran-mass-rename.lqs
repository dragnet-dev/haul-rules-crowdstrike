// Dragnet [Ransomware]: dragnet-ransomware-2022-2953 — Mass File Rename (suncrypt)
// Status: deprecated | Level: high | ID: 4580a297-3d68-5fcf-9682-46d65046767e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
