// Dragnet [Ransomware]: dragnet-ransomware-2025-1145 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: c0dd8d27-028f-5d93-9a28-258589747a63

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
