// Dragnet [Ransomware]: dragnet-ransomware-2025-0789 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 790f4c0a-d2e8-50b0-905a-6e046d3137be

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
