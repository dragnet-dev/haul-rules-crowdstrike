// Dragnet [Ransomware]: dragnet-ransomware-2023-2451 — Mass File Rename (royal)
// Status: deprecated | Level: high | ID: 4cb7eaaf-5579-53e7-817c-62faa9bb69d1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
