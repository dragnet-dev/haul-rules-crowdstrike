// Dragnet [Ransomware]: dragnet-ransomware-2021-1544 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 1d60cef6-d4bd-51bb-98eb-781019216f5e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
