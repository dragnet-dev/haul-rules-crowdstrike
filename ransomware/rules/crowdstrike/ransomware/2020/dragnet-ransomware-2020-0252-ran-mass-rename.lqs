// Dragnet [Ransomware]: dragnet-ransomware-2020-0252 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: abf9389b-79cd-5f15-bf9b-0864b474c98f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
