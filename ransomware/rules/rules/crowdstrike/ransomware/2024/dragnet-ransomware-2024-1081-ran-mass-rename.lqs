// Dragnet [Ransomware]: dragnet-ransomware-2024-1081 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: c3678586-9ba4-54a9-a493-d1b17cf6e88e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
