// Dragnet [Ransomware]: dragnet-ransomware-2020-0240 — Mass File Rename (ragnarlocker)
// Status: deprecated | Level: high | ID: 70673bb7-c16f-5248-be36-44ebb480b483

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
