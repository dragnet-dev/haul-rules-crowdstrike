// Dragnet [Ransomware]: dragnet-ransomware-2025-5617 — Mass File Rename (devman)
// Status: experimental | Level: high | ID: 87cd8aae-ee8f-54ba-abcf-21e7bc9201e5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
