// Dragnet [Ransomware]: dragnet-ransomware-2026-2672 — Mass File Rename (worldleaks)
// Status: test | Level: high | ID: e8d45cf4-74be-5a6e-bdf2-bed58409a33d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
