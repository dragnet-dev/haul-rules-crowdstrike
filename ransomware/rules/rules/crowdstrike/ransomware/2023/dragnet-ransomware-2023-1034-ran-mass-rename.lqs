// Dragnet [Ransomware]: dragnet-ransomware-2023-1034 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: b7690e66-00ce-5291-8971-f34bd61133d7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
