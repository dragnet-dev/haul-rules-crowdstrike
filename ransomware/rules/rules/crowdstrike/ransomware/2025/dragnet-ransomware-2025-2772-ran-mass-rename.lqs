// Dragnet [Ransomware]: dragnet-ransomware-2025-2772 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: ac729483-fdee-5460-82c9-0d146bf8554d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
