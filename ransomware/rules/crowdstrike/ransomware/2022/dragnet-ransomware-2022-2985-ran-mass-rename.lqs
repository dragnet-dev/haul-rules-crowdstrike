// Dragnet [Ransomware]: dragnet-ransomware-2022-2985 — Mass File Rename (snatch)
// Status: deprecated | Level: high | ID: 75456731-0031-5087-9be4-d2f4ef403027

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
