// Dragnet [Ransomware]: dragnet-ransomware-2023-1157 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 3cc8e826-81c1-5e3b-bee3-668c38423de5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
