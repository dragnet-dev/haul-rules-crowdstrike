// Dragnet [Ransomware]: dragnet-ransomware-2023-1513 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: d8839218-d9cf-53bd-b5dc-4bf646dfc83f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
