// Dragnet [Ransomware]: dragnet-ransomware-2023-4670 — Mass File Rename (medusa)
// Status: deprecated | Level: high | ID: c7ff033b-1ecd-560f-9b73-d4f81e9a05c4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
