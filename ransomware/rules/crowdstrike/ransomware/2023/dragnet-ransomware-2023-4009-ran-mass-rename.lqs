// Dragnet [Ransomware]: dragnet-ransomware-2023-4009 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 4041292b-7973-5d2b-bfe8-944359ad497d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
