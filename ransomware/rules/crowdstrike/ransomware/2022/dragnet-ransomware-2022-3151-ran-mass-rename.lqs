// Dragnet [Ransomware]: dragnet-ransomware-2022-3151 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 4cf9e133-c098-5649-b16a-8ffc523d00d2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
