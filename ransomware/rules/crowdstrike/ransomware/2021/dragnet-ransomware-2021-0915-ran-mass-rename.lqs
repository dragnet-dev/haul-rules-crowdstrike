// Dragnet [Ransomware]: dragnet-ransomware-2021-0915 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: 00169eb3-7293-5801-a56c-57e0b4bb8b01

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
