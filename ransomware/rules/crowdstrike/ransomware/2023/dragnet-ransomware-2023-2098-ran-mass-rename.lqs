// Dragnet [Ransomware]: dragnet-ransomware-2023-2098 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 88127706-9728-5551-87f9-51c11817d11d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
