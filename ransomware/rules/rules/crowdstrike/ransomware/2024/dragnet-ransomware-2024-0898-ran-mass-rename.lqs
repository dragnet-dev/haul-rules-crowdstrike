// Dragnet [Ransomware]: dragnet-ransomware-2024-0898 — Mass File Rename (flocker)
// Status: experimental | Level: high | ID: 97f79515-5711-5d46-98ae-979cb23b90ef

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
