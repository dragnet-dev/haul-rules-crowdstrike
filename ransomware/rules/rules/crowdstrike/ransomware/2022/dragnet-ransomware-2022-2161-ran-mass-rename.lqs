// Dragnet [Ransomware]: dragnet-ransomware-2022-2161 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 6033246e-598e-5fe4-b1aa-a1057f329679

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
