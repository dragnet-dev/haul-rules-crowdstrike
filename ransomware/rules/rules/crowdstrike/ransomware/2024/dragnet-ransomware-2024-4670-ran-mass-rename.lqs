// Dragnet [Ransomware]: dragnet-ransomware-2024-4670 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 619eb8fb-d6b6-5e04-8b22-10b23768bf6c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
