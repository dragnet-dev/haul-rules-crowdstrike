// Dragnet [Ransomware]: dragnet-ransomware-2025-2293 — Mass File Rename (SilentRansomGroup)
// Status: deprecated | Level: high | ID: ab105b6f-e401-53ef-9076-73a9e52626a3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
