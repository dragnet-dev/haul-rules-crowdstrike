// Dragnet [Ransomware]: dragnet-ransomware-2024-5311 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 1a2f0a3a-7023-5fb3-8c6e-ff849563c8e6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
