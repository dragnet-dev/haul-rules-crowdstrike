// Dragnet [Ransomware]: dragnet-ransomware-2023-0291 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 17035afc-7e30-53a8-8dcc-48992d6c629f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
