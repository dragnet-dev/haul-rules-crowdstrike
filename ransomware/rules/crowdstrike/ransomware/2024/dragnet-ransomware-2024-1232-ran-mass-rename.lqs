// Dragnet [Ransomware]: dragnet-ransomware-2024-1232 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: ac6286b1-a2c8-5a00-ae3b-296a42e5aea6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
