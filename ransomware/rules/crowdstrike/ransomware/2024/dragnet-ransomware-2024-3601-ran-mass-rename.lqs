// Dragnet [Ransomware]: dragnet-ransomware-2024-3601 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 4dda43de-0576-50f4-aaf5-2ea101b5a080

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
