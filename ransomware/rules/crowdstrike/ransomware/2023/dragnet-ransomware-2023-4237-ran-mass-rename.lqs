// Dragnet [Ransomware]: dragnet-ransomware-2023-4237 — Mass File Rename (losttrust)
// Status: deprecated | Level: high | ID: 64721ca8-b9cd-5bfb-ba11-8b5a1c297559

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
