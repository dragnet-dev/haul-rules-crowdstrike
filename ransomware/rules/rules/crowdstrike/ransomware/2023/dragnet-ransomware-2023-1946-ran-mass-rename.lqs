// Dragnet [Ransomware]: dragnet-ransomware-2023-1946 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: fe847b4a-9f33-5395-b423-3ea2d268f3f9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
