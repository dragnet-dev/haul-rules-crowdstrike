// Dragnet [Ransomware]: dragnet-ransomware-2024-2829 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 48b89db7-ca0a-521a-ab93-b5986cd621aa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
