// Dragnet [Ransomware]: dragnet-ransomware-2022-3003 — Mass File Rename (stormous)
// Status: deprecated | Level: high | ID: 389dfe5e-cabf-503d-90c9-b4ced41e18e0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
