// Dragnet [Ransomware]: dragnet-ransomware-2024-2334 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 5e4beae9-b056-5e3c-9568-a3b4360a5c06

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
