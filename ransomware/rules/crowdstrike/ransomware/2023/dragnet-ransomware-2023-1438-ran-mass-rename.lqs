// Dragnet [Ransomware]: dragnet-ransomware-2023-1438 — Mass File Rename (play)
// Status: experimental | Level: high | ID: e18bb1a0-89a1-51d0-ba51-0f6fbe5a46d7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
