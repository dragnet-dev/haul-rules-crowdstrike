// Dragnet [Ransomware]: dragnet-ransomware-2021-0252 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 968ac276-732b-5778-96b9-e512c0b0300b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
