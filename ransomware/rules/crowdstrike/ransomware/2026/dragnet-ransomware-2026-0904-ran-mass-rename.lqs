// Dragnet [Ransomware]: dragnet-ransomware-2026-0904 — Mass File Rename (SilentRansomGroup)
// Status: deprecated | Level: high | ID: ee4cbd3a-19ef-549f-ba85-1a48ea30c3bd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
