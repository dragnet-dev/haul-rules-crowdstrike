// Dragnet [Ransomware]: dragnet-ransomware-2023-3683 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: ec1aa033-bccb-511d-8dc8-9855de2803be

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
