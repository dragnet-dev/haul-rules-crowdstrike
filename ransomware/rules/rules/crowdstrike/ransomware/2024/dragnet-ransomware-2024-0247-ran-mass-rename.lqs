// Dragnet [Ransomware]: dragnet-ransomware-2024-0247 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: b24e07a6-f99a-5acc-aff6-5fa3d41ae114

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
