// Dragnet [Ransomware]: dragnet-ransomware-2022-2044 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 723a3ebd-d0e1-5982-8ef7-0c80a7cc2c09

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
