// Dragnet [Ransomware]: dragnet-ransomware-2025-5965 — Mass File Rename (sinobi)
// Status: experimental | Level: high | ID: 0591d15e-bcbd-5aea-a784-c3cf3f5b3afe

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
