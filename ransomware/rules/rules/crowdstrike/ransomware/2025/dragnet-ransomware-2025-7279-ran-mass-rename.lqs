// Dragnet [Ransomware]: dragnet-ransomware-2025-7279 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 7da15258-3ee4-5353-b76d-200d56beec2c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
