// Dragnet [Ransomware]: dragnet-ransomware-2026-0698 — Mass File Rename (dragonforce)
// Status: stable | Level: high | ID: 6a6ba951-7c01-5ce0-810f-98c13f3247e0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
