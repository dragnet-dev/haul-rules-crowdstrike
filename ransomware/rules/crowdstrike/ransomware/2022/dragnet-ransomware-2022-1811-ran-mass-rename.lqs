// Dragnet [Ransomware]: dragnet-ransomware-2022-1811 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 558da959-21aa-53f1-8461-abbcd0f17503

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
