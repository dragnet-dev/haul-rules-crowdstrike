// Dragnet [Ransomware]: dragnet-ransomware-2023-3935 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 3e92046b-eb42-522b-a57e-178cdc6490f0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
