// Dragnet [Ransomware]: dragnet-ransomware-2025-7732 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 5e25daac-3596-52f0-82d2-25fddf6283bb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
