// Dragnet [Ransomware]: dragnet-ransomware-2021-1037 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: f9a8eec3-1061-5b60-9f4e-5584ff0d93da

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
