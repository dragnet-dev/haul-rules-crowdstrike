// Dragnet [Ransomware]: dragnet-ransomware-2023-0382 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: a18b7121-6ef7-5833-b5ef-d2874cf1f4dd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
