// Dragnet [Ransomware]: dragnet-ransomware-2020-0105 — Mass File Rename (maze)
// Status: deprecated | Level: high | ID: 1c2e51b9-5427-5242-bb2e-645841ffdbba

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
