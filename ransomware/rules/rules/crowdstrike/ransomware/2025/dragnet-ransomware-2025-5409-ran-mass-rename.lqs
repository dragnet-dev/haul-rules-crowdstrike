// Dragnet [Ransomware]: dragnet-ransomware-2025-5409 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 6eff0892-8795-5798-b2b6-6bf27110a7df

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
