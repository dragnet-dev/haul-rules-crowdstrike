// Dragnet [Ransomware]: dragnet-ransomware-2025-3828 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 9d103c9f-159f-5c62-8852-945094aed6d7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
