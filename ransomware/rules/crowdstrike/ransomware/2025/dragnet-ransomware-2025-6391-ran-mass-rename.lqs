// Dragnet [Ransomware]: dragnet-ransomware-2025-6391 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: 27d9dd64-90b9-532f-b51f-8f8f391ba2b2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
