// Dragnet [Ransomware]: dragnet-ransomware-2025-5319 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: ffdc19fd-2945-5726-a566-519cd5d4b53c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
