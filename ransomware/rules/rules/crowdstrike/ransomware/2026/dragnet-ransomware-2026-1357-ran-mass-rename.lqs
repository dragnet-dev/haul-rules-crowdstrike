// Dragnet [Ransomware]: dragnet-ransomware-2026-1357 — Mass File Rename (worldleaks)
// Status: stable | Level: high | ID: 3017ffcd-f181-5362-b50d-11cae0c2949d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
