// Dragnet [Ransomware]: dragnet-ransomware-2023-3894 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 95dc99f4-d78b-5161-9f73-732e97224e83

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
