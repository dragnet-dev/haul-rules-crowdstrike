// Dragnet [Ransomware]: dragnet-ransomware-2023-2872 — Mass File Rename (malas)
// Status: experimental | Level: high | ID: fb2d635b-2211-59fc-b138-b88cbbd86ac4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
