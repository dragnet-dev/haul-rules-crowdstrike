// Dragnet [Ransomware]: dragnet-ransomware-2026-0715 — Mass File Rename (incransom)
// Status: stable | Level: high | ID: 6428a08a-796f-5caf-8c87-7bf4ba50c099

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
