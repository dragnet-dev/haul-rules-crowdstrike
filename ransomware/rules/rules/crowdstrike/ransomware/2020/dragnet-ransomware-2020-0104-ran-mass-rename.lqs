// Dragnet [Ransomware]: dragnet-ransomware-2020-0104 — Mass File Rename (netwalker)
// Status: deprecated | Level: high | ID: ed028f60-ad80-5250-8f2d-1cce8eaf0e44

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
