// Dragnet [Ransomware]: dragnet-ransomware-2025-1275 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: 8f4bb59e-7f8c-5e09-8127-c959111e964c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
