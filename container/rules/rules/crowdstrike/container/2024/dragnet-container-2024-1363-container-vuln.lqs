// Dragnet [Container]: dragnet-container-2024-1363 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: f32415a6-7832-5df0-977a-0a55244c12b7

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:8* OR ImageFileName = *debian:9* OR ImageFileName = *ubuntu:16.04* OR ImageFileName = *ubuntu:16.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
