// Dragnet [Ransomware]: dragnet-ransomware-2023-1405 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 320c44d2-675e-5f0e-898f-c046df764fb4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
