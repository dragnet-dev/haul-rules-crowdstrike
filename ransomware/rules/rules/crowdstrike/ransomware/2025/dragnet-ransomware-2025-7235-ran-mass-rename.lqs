// Dragnet [Ransomware]: dragnet-ransomware-2025-7235 — Mass File Rename (ransomhouse)
// Status: experimental | Level: high | ID: 2d245d5f-2483-585e-99ed-1b55691acdd1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
