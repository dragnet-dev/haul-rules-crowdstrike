// Dragnet [Ransomware]: dragnet-ransomware-2024-3752 — Mass File Rename (monti)
// Status: experimental | Level: high | ID: ec161610-9118-5286-8a6c-0c68c831ae1c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
