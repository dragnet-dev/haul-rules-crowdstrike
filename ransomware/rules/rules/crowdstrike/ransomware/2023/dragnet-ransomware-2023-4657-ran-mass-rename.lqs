// Dragnet [Ransomware]: dragnet-ransomware-2023-4657 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 98366ee5-6817-53f1-9ada-c0ad57ec0ab0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
