// Dragnet [Ransomware]: dragnet-ransomware-2021-1733 — Mass File Rename (marketo)
// Status: deprecated | Level: high | ID: 0d5bcef1-f861-5e81-ade3-4ed0038c8691

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
