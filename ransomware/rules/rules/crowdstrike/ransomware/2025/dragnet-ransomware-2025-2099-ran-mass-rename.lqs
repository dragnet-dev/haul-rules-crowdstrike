// Dragnet [Ransomware]: dragnet-ransomware-2025-2099 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 5680ce86-532c-5fcc-a1ed-7091c9f0d87f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
