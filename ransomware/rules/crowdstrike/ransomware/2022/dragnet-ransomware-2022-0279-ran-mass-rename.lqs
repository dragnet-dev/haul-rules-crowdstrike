// Dragnet [Ransomware]: dragnet-ransomware-2022-0279 — Mass File Rename (blackbasta)
// Status: deprecated | Level: high | ID: 0226c6c0-82ac-5a6d-99f2-9658f0bac814

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
