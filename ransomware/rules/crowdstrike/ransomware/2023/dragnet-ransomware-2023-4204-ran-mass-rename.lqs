// Dragnet [Ransomware]: dragnet-ransomware-2023-4204 — Mass File Rename (dragonforce)
// Status: deprecated | Level: high | ID: cd6e9788-c01d-57e9-86cb-29d4e8bd6e0f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
