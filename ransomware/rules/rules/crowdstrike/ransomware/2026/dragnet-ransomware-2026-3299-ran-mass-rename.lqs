// Dragnet [Ransomware]: dragnet-ransomware-2026-3299 — Mass File Rename (incransom)
// Status: stable | Level: high | ID: 034cd0cf-f57e-5342-b2b1-583c3db759c1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
