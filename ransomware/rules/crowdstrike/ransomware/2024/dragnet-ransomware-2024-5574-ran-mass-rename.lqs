// Dragnet [Ransomware]: dragnet-ransomware-2024-5574 — Mass File Rename (hellcat)
// Status: deprecated | Level: high | ID: 36a3ba6f-8bac-529c-a80e-dab7d3ce4c51

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
