// Dragnet [Ransomware]: dragnet-ransomware-2022-0219 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 67f4f56b-eb1f-5bf6-8ccb-f5130c8c7873

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
