// Dragnet [Ransomware]: dragnet-ransomware-2023-0302 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 5fc4f7e9-34b1-5bd1-804f-55b3f3aece1a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
