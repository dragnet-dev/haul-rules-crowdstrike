// Dragnet [Ransomware]: dragnet-ransomware-2026-3498 — Mass File Rename (genesis)
// Status: stable | Level: high | ID: 1a5f45f4-90d8-5d74-9dab-9c6108bbb177

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
