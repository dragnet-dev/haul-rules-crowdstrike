// Dragnet [Ransomware]: dragnet-ransomware-2025-0179 — Mass File Rename (embargo)
// Status: experimental | Level: high | ID: 65c1674b-134f-5d2a-bb62-1b52133367a3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
