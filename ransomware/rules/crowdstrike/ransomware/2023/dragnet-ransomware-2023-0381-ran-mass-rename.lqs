// Dragnet [Ransomware]: dragnet-ransomware-2023-0381 — Mass File Rename (losttrust)
// Status: deprecated | Level: high | ID: 8a3b07b7-340d-5b5c-baa6-f5279745b172

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
