// Dragnet [Ransomware]: dragnet-ransomware-2025-2732 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 59ebc176-4ebd-52be-86b8-41f5eff7aa9c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
