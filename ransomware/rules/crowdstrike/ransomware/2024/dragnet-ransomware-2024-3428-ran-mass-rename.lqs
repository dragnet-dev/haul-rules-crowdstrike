// Dragnet [Ransomware]: dragnet-ransomware-2024-3428 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 865a0108-7663-5d6c-9074-ea3837950c4b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
