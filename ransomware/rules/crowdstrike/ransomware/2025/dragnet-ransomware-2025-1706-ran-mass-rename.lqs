// Dragnet [Ransomware]: dragnet-ransomware-2025-1706 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 7e7313b9-d34f-5b2d-b46e-d9c78350c8a2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
