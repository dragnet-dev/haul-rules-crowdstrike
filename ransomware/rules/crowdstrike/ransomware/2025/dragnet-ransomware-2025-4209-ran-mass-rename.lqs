// Dragnet [Ransomware]: dragnet-ransomware-2025-4209 — Mass File Rename (stormous)
// Status: experimental | Level: high | ID: e2e7e57c-9ab1-59b1-b46a-42e9b99dcc8a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
