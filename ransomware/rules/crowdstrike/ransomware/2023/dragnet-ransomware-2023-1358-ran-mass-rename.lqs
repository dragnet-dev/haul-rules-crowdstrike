// Dragnet [Ransomware]: dragnet-ransomware-2023-1358 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 80e62850-25b0-58c2-8d8f-ff9247d697b0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
