// Dragnet [Ransomware]: dragnet-ransomware-2025-2264 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: d0683fb2-6b16-5827-9885-c585f3ba4e35

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
