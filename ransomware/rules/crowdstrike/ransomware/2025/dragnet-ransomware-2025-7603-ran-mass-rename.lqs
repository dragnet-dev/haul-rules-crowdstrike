// Dragnet [Ransomware]: dragnet-ransomware-2025-7603 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: 1fcd286b-35f4-55ec-be3f-c5c70368c220

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
