// Dragnet [Ransomware]: dragnet-ransomware-2025-3342 — Mass File Rename (termite)
// Status: experimental | Level: high | ID: 9d93467e-2704-53d9-9a7c-c2a5cee7bfbd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
