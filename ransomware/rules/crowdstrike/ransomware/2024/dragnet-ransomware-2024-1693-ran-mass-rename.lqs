// Dragnet [Ransomware]: dragnet-ransomware-2024-1693 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 02a62bc6-0ab1-5053-b73f-071dc1717894

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
