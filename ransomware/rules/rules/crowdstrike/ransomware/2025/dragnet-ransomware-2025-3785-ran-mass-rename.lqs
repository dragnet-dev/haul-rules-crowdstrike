// Dragnet [Ransomware]: dragnet-ransomware-2025-3785 — Mass File Rename (sinobi)
// Status: experimental | Level: high | ID: a9aa8ecd-9f0b-5be8-8f36-5154a2023823

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
