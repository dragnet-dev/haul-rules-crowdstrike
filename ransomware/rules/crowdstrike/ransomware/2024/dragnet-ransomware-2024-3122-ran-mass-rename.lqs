// Dragnet [Ransomware]: dragnet-ransomware-2024-3122 — Mass File Rename (underground)
// Status: experimental | Level: high | ID: ac663809-58c7-5022-abc8-404b835988e8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
