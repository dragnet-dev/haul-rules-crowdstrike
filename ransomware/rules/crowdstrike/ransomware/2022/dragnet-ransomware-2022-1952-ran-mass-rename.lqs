// Dragnet [Ransomware]: dragnet-ransomware-2022-1952 — Mass File Rename (vicesociety)
// Status: deprecated | Level: high | ID: 459d256b-0af6-5df1-bb5f-5c717cfc04b5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
