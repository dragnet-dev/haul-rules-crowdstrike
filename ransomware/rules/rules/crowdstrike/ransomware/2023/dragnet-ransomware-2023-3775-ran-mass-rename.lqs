// Dragnet [Ransomware]: dragnet-ransomware-2023-3775 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 860d8a44-9ed2-53be-b78f-006b653c4a01

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
