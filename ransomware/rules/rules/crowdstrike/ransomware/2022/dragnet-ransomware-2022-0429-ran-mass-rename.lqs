// Dragnet [Ransomware]: dragnet-ransomware-2022-0429 — Mass File Rename (blackbasta)
// Status: deprecated | Level: high | ID: c0a52adf-e84b-5a0a-a960-024f3d925311

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
