// Dragnet [Ransomware]: dragnet-ransomware-2023-0730 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: eb01d736-d172-54d9-a5d7-3c09498279de

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
