// Dragnet [Ransomware]: dragnet-ransomware-2023-0230 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 48038aec-fafd-5a0f-8e9a-677384afcf48

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
