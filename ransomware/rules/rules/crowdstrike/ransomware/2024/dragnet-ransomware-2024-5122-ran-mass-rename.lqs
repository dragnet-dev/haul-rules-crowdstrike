// Dragnet [Ransomware]: dragnet-ransomware-2024-5122 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: f588f18c-6e66-51b0-add8-eb43b1b2a549

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
