// Dragnet [Ransomware]: dragnet-ransomware-2026-3341 — Mass File Rename (safepay)
// Status: stable | Level: high | ID: 50df8e1c-b7f2-5cd7-a26c-bb836051da34

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
