// Dragnet [Ransomware]: dragnet-ransomware-2025-1079 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: a1b8605d-9871-572c-aa80-0b88849e4273

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
