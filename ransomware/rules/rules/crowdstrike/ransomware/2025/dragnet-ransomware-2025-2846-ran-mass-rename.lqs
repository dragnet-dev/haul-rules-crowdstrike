// Dragnet [Ransomware]: dragnet-ransomware-2025-2846 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: f3419558-3d42-5f8c-9a26-fc6b9be40e52

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
