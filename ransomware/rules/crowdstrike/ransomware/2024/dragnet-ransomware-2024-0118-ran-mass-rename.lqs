// Dragnet [Ransomware]: dragnet-ransomware-2024-0118 — Mass File Rename (darkvault)
// Status: experimental | Level: high | ID: b3554429-2f4e-546e-b3aa-b6d60a9f645b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
