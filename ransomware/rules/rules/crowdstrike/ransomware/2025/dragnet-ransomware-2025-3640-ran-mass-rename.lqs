// Dragnet [Ransomware]: dragnet-ransomware-2025-3640 — Mass File Rename (devman)
// Status: deprecated | Level: high | ID: d9145668-216d-51e3-8faa-afc9ae2c5a9a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
