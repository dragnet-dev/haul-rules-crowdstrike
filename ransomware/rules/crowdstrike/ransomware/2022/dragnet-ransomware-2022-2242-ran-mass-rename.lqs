// Dragnet [Ransomware]: dragnet-ransomware-2022-2242 — Mass File Rename (everest)
// Status: deprecated | Level: high | ID: 04d8527f-4193-54b4-8b56-adaa6a501d93

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
