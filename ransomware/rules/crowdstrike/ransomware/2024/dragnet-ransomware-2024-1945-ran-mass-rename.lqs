// Dragnet [Ransomware]: dragnet-ransomware-2024-1945 — Mass File Rename (arcusmedia)
// Status: experimental | Level: high | ID: adee9a41-5191-549d-b142-6171ebf68789

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
