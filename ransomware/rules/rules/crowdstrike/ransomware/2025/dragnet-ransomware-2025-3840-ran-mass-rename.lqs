// Dragnet [Ransomware]: dragnet-ransomware-2025-3840 — Mass File Rename (worldleaks)
// Status: experimental | Level: high | ID: 9c925bb8-0e8f-5dc3-a4d8-0131320d7bf3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
