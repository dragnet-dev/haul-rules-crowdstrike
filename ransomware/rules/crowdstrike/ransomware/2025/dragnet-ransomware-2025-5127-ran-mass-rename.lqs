// Dragnet [Ransomware]: dragnet-ransomware-2025-5127 — Mass File Rename (warlock)
// Status: deprecated | Level: high | ID: 03df3842-c6d3-557a-8e6b-b56cdf78c2be

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
