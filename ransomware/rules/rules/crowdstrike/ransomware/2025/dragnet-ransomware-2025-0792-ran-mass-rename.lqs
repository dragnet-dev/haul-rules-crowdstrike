// Dragnet [Ransomware]: dragnet-ransomware-2025-0792 — Mass File Rename (embargo)
// Status: experimental | Level: high | ID: 8cc8037a-5e1f-5093-92ba-8a5b1247c9a6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
