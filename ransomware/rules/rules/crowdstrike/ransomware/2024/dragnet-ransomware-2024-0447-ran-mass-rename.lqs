// Dragnet [Ransomware]: dragnet-ransomware-2024-0447 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 5d30800a-9191-5a8a-a5d2-a76872140232

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
