// Dragnet [Ransomware]: dragnet-ransomware-2021-1407 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: b512cad1-be47-5654-ba3e-c56596eb7fbf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
