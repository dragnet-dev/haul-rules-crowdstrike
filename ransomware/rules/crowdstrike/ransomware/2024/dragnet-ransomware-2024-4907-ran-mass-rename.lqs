// Dragnet [Ransomware]: dragnet-ransomware-2024-4907 — Mass File Rename (spacebears)
// Status: experimental | Level: high | ID: a2ed9370-2404-57a6-88a2-881501790300

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
