// Dragnet [Ransomware]: dragnet-ransomware-2023-4142 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 360bf16c-4a45-510d-879f-75a740b83f01

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
