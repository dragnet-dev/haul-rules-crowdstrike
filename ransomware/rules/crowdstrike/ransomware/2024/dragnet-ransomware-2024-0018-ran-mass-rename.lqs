// Dragnet [Ransomware]: dragnet-ransomware-2024-0018 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 386c0e75-f2f1-51b4-9476-c9deaa9536b9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
