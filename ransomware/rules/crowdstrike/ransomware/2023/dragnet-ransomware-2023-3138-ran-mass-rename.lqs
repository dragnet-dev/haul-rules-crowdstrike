// Dragnet [Ransomware]: dragnet-ransomware-2023-3138 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 21ea3cd9-623c-5376-91fb-aec3a2ea9872

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
