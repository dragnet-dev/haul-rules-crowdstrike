// Dragnet [Ransomware]: dragnet-ransomware-2025-7102 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: e450b1aa-137d-582b-a496-0c925fdbd068

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
