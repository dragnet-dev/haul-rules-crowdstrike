// Dragnet [Ransomware]: dragnet-ransomware-2023-5095 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 4fe5fdfa-84b4-584d-a046-b7b237d467f9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
