// Dragnet [Container]: dragnet-container-2024-0585 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: ebcd2626-1b87-5220-8302-d2d27ebb0f28

#event_simpleName=*
| (ImageFileName = *amazonlinux:2* OR ImageFileName = *debian:8* OR ImageFileName = *redhat/ubi9:*)
| table([timestamp, ComputerName])
| limit(1000)
