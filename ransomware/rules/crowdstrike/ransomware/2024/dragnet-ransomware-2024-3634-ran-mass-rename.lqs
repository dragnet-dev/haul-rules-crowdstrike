// Dragnet [Ransomware]: dragnet-ransomware-2024-3634 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 368953bb-8dad-52c1-a36a-d0753cdfdb10

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
