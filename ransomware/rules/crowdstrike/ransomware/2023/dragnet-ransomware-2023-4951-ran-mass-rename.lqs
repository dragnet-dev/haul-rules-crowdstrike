// Dragnet [Ransomware]: dragnet-ransomware-2023-4951 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: d1a02610-894f-59e8-826e-88e8c04efca5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
