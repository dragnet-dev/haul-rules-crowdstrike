// Dragnet [Ransomware]: dragnet-ransomware-2023-4013 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 165bf089-b480-52c2-869c-525fc34c5d27

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
