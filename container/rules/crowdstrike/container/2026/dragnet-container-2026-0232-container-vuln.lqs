// Dragnet [Container]: dragnet-container-2026-0232 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 9e51c52d-255a-532f-9153-a91aac3b7b94

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
