// Dragnet [Ransomware]: dragnet-ransomware-2025-4684 — Mass File Rename (global)
// Status: deprecated | Level: high | ID: 5f750113-da44-5a03-a3da-2e5bed2024c7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
