// Dragnet [Ransomware]: dragnet-ransomware-2025-1783 — Mass File Rename (bqtlock)
// Status: experimental | Level: high | ID: f13d64aa-bfed-5f04-afd0-2f9afeb7eb5a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
