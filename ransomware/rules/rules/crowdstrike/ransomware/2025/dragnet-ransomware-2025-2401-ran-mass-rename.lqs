// Dragnet [Ransomware]: dragnet-ransomware-2025-2401 — Mass File Rename (thegentlemen)
// Status: experimental | Level: high | ID: 05a94087-1a5d-5a34-ae0d-ca7fe862c3ee

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
