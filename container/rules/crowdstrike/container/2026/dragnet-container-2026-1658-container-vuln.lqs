// Dragnet [Container]: dragnet-container-2026-1658 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 1b09ec9c-8571-59fa-9900-515071861eec

#event_simpleName=*
| (ImageFileName = *debian:7* OR ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10* OR ImageFileName = *ubuntu:13.04* OR ImageFileName = *ubuntu:13.10*)
| table([timestamp, ComputerName])
| limit(1000)
