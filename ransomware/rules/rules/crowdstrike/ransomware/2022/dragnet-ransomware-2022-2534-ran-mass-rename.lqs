// Dragnet [Ransomware]: dragnet-ransomware-2022-2534 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 264c9943-8fa4-5396-a608-4ae20777a258

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
