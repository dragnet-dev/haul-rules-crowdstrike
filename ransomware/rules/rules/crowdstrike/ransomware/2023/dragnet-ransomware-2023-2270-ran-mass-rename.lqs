// Dragnet [Ransomware]: dragnet-ransomware-2023-2270 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 1e91b28b-7fe5-556e-aec0-25075a000b99

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
