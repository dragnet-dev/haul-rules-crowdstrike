// Dragnet [Ransomware]: dragnet-ransomware-2022-1859 — Mass File Rename (royal)
// Status: deprecated | Level: high | ID: e7963a79-aeef-5c71-9589-a950fe34ba34

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
