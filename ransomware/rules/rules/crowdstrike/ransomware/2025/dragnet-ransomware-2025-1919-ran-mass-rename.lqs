// Dragnet [Ransomware]: dragnet-ransomware-2025-1919 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: c0b03c24-9508-5c09-a61b-5ba1ae34c1e3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
