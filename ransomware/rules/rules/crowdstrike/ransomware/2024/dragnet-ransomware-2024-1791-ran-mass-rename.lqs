// Dragnet [Ransomware]: dragnet-ransomware-2024-1791 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 510ffb09-f747-5018-bb68-e74a1967b736

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
