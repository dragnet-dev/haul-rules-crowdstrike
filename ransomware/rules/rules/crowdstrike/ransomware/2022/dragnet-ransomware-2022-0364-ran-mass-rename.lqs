// Dragnet [Ransomware]: dragnet-ransomware-2022-0364 — Mass File Rename (karakurt)
// Status: deprecated | Level: high | ID: aff36e65-7f0f-5e5f-8366-998883568476

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
