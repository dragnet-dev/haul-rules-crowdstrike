// Dragnet [Ransomware]: dragnet-ransomware-2023-1470 — Mass File Rename (play)
// Status: deprecated | Level: high | ID: 1f6372b8-0e54-5299-be2a-db46192c5cb5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
