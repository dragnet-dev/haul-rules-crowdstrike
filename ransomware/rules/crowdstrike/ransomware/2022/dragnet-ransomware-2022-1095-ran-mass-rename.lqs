// Dragnet [Ransomware]: dragnet-ransomware-2022-1095 — Mass File Rename (nightsky)
// Status: deprecated | Level: high | ID: e2e31e5b-892e-561b-8f9a-6dc5173652e0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
