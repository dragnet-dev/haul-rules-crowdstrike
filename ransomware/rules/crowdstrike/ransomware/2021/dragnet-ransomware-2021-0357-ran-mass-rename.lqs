// Dragnet [Ransomware]: dragnet-ransomware-2021-0357 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: c75d9ff3-636b-5368-ab3e-20634bcce03f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
