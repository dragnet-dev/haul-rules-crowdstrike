// Dragnet [Ransomware]: dragnet-ransomware-2024-0085 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 42486552-bc62-5a81-a0b1-c34fd69e6f4b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
