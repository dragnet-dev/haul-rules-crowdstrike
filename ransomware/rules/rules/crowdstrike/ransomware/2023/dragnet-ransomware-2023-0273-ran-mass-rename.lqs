// Dragnet [Ransomware]: dragnet-ransomware-2023-0273 — Mass File Rename (mallox)
// Status: deprecated | Level: high | ID: 5308596d-49b7-5111-a79e-ed117cce8955

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
