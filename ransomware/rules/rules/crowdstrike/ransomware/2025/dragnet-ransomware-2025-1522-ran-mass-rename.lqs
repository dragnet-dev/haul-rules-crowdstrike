// Dragnet [Ransomware]: dragnet-ransomware-2025-1522 — Mass File Rename (nova)
// Status: experimental | Level: high | ID: b3d4bf81-4c59-5272-89c7-83fcc4373390

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
