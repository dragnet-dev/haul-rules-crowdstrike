// Dragnet [Ransomware]: dragnet-ransomware-2026-1953 — Mass File Rename (dragonforce)
// Status: test | Level: high | ID: 753766e3-3cf5-5cf3-a412-df0df9d3fab5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
