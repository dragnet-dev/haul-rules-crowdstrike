// Dragnet [Ransomware]: dragnet-ransomware-2024-3704 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 673646ba-eb1d-5ce5-bd3b-f48c53fa6c50

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
