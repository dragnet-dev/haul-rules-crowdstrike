// Dragnet [Ransomware]: dragnet-ransomware-2023-4590 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 1dfce20e-bf91-50a2-b90b-f6161b3f3fb3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
