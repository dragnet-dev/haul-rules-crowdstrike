// Dragnet [Ransomware]: dragnet-ransomware-2025-6042 — Mass File Rename (stormous)
// Status: experimental | Level: high | ID: f1b314a0-dff7-535d-b524-c09bb3c84ea8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
