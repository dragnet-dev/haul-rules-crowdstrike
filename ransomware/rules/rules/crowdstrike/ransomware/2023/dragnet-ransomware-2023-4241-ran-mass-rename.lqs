// Dragnet [Ransomware]: dragnet-ransomware-2023-4241 — Mass File Rename (royal)
// Status: experimental | Level: high | ID: 41c4d5bb-e71b-5ed7-9cdf-e2ebd6aaef84

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
