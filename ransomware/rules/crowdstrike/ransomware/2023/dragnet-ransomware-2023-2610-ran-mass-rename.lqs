// Dragnet [Ransomware]: dragnet-ransomware-2023-2610 — Mass File Rename (malekteam)
// Status: experimental | Level: high | ID: ba3632f5-3010-5b9e-9019-820117c5c80c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
