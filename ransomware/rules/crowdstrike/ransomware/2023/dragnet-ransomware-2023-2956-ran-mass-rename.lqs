// Dragnet [Ransomware]: dragnet-ransomware-2023-2956 — Mass File Rename (vicesociety)
// Status: experimental | Level: high | ID: dbb86a04-5893-5e0f-be1e-9f7c529ae77a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
