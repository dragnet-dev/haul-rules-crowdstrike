// Dragnet [Ransomware]: dragnet-ransomware-2025-0421 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: adbdfb16-3d78-51bd-98c9-8a6b9da4ca7d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
