// Dragnet [Ransomware]: dragnet-ransomware-2024-2976 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: 0df5806c-6d63-58cd-a362-520a3169861c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
