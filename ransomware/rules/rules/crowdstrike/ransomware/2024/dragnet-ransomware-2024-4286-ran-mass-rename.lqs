// Dragnet [Ransomware]: dragnet-ransomware-2024-4286 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: ebbee3c6-79e2-510c-843c-f98072fc5a66

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
