// Dragnet [Ransomware]: dragnet-ransomware-2023-4867 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: c0bffa3f-1808-5117-ac3f-ea94d2564daf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
