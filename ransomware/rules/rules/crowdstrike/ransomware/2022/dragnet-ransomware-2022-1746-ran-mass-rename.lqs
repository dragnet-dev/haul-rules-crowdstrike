// Dragnet [Ransomware]: dragnet-ransomware-2022-1746 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 2a671e6e-d243-5397-81ef-042fddbe01a0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
