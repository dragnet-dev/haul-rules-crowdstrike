// Dragnet [Ransomware]: dragnet-ransomware-2025-3354 — Mass File Rename (kairos)
// Status: experimental | Level: high | ID: a182368f-b464-5cd9-9a1c-193ee7528e83

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
