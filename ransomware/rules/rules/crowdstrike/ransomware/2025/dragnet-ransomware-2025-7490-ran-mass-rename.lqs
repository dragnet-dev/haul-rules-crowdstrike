// Dragnet [Ransomware]: dragnet-ransomware-2025-7490 — Mass File Rename (lockbit3)
// Status: test | Level: high | ID: 5abd1cbd-9aee-5de1-868d-e3ab4cc2aab7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
