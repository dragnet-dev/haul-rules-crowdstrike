// Dragnet [Ransomware]: dragnet-ransomware-2023-3533 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: a99823ff-e071-5e6d-b3db-5c4adf24e16f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
