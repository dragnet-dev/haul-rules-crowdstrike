// Dragnet [Ransomware]: dragnet-ransomware-2022-0214 — Mass File Rename (everest)
// Status: deprecated | Level: high | ID: ca763483-8093-5ff9-a513-70435b63902d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
