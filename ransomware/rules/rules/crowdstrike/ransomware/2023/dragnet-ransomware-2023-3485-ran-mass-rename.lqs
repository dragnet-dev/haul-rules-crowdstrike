// Dragnet [Ransomware]: dragnet-ransomware-2023-3485 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: e64ee89b-96bc-5713-8c99-0f608db12313

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
