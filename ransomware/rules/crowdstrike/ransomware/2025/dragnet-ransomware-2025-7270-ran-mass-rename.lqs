// Dragnet [Ransomware]: dragnet-ransomware-2025-7270 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 2dd5dbf9-723c-59e0-9adf-54079ff269a4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
