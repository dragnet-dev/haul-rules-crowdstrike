// Dragnet [Ransomware]: dragnet-ransomware-2025-5722 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 60e02063-bf7f-5594-afce-0d059b3f779a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
