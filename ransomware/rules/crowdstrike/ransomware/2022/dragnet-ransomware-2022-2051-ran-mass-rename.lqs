// Dragnet [Ransomware]: dragnet-ransomware-2022-2051 — Mass File Rename (avoslocker)
// Status: deprecated | Level: high | ID: 891b2982-a12c-5197-a987-f3c0b5208138

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
