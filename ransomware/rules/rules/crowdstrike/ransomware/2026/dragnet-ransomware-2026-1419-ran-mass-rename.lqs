// Dragnet [Ransomware]: dragnet-ransomware-2026-1419 — Mass File Rename (LeakBazaar)
// Status: stable | Level: high | ID: 373450cb-f22f-590a-b55e-feeaa19a4f7e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
