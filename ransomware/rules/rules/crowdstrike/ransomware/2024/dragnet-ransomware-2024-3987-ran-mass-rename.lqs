// Dragnet [Ransomware]: dragnet-ransomware-2024-3987 — Mass File Rename (cicada3301)
// Status: experimental | Level: high | ID: bbbb4b81-1ae0-5d8d-b172-22a273c3eb21

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
