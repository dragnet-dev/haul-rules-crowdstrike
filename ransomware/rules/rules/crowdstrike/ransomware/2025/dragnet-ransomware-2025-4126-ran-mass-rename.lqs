// Dragnet [Ransomware]: dragnet-ransomware-2025-4126 — Mass File Rename (datacarry)
// Status: deprecated | Level: high | ID: 7977f827-528e-5e3a-9575-a1cacfe47de8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
