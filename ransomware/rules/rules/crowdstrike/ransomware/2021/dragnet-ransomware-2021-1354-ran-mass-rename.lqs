// Dragnet [Ransomware]: dragnet-ransomware-2021-1354 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: e0a8de84-b960-5e37-aa9c-764c57dd71ba

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
