// Dragnet [Ransomware]: dragnet-ransomware-2024-4399 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: e79424cf-96e3-5e2b-bc6f-6a8bcf6909bd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
