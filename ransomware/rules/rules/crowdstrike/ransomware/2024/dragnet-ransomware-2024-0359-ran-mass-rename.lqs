// Dragnet [Ransomware]: dragnet-ransomware-2024-0359 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: d115b799-10fb-5974-8f59-cec30ef97747

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
