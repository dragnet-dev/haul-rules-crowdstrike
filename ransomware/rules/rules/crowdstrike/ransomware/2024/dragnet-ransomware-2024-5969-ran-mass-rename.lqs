// Dragnet [Ransomware]: dragnet-ransomware-2024-5969 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 17b1817f-4cf6-5d2e-9af6-6118592fc039

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
