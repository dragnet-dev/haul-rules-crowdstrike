// Dragnet [Ransomware]: dragnet-ransomware-2022-0384 — Mass File Rename (karakurt)
// Status: deprecated | Level: high | ID: 04fde691-93f9-56c6-87f6-ca6c1bce2d34

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
