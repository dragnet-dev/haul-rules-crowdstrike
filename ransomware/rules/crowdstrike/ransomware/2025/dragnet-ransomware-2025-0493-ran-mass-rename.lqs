// Dragnet [Ransomware]: dragnet-ransomware-2025-0493 — Mass File Rename (handala)
// Status: experimental | Level: high | ID: 9bc9b39b-d044-5a52-a66f-7950f7a36ac7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
