// Dragnet [Ransomware]: dragnet-ransomware-2025-2831 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: de8e1693-96b2-52d9-9d2e-babb690e273b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
