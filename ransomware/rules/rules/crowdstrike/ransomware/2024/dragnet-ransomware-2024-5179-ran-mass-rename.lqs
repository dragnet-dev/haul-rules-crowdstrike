// Dragnet [Ransomware]: dragnet-ransomware-2024-5179 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: e1f0a48f-7bb5-57f7-9167-6a06fc7877a5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
