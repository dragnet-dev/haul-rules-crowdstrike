// Dragnet [Ransomware]: dragnet-ransomware-2025-5729 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 5fc47d00-b2ce-5906-b23f-b2ce670baf04

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
