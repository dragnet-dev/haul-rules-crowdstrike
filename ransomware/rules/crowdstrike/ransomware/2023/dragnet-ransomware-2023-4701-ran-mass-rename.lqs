// Dragnet [Ransomware]: dragnet-ransomware-2023-4701 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 384f13b9-cc3a-5532-b3cd-e46923189483

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
