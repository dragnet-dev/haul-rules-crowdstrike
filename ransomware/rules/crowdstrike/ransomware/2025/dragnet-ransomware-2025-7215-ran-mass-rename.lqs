// Dragnet [Ransomware]: dragnet-ransomware-2025-7215 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: 19d12dfe-54f6-5fea-9a14-4a51cea8d07b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
