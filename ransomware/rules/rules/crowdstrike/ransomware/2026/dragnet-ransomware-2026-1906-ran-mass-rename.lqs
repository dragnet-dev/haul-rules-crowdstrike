// Dragnet [Ransomware]: dragnet-ransomware-2026-1906 — Mass File Rename (AuditTeam)
// Status: stable | Level: high | ID: 3c6b87b7-e2ed-5050-9a03-5c33a75b5ebd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
