// Dragnet [Ransomware]: dragnet-ransomware-2025-5994 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: 12335cd8-ac6a-5502-b9e6-2d8acd7d20ce

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
