// Dragnet [Ransomware]: dragnet-ransomware-2024-1008 — Mass File Rename (ciphbit)
// Status: deprecated | Level: high | ID: b9d6c1bc-af9b-5b3a-a7f0-0cab497fbd0a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
