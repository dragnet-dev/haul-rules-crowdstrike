// Dragnet [Ransomware]: dragnet-ransomware-2025-5522 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 45c6f946-2189-5ffb-9394-c2e76898ea54

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
