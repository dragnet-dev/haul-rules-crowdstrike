// Dragnet [Ransomware]: dragnet-ransomware-2024-0842 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 91a30eee-0470-54a8-b02c-2b22b6d1bc03

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
