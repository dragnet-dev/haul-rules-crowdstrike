// Dragnet [Ransomware]: dragnet-ransomware-2026-3168 — Mass File Rename (payoutsking)
// Status: test | Level: high | ID: ede1e7d1-5ce1-53ed-aa62-05ef007bf46a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
