// Dragnet [Ransomware]: dragnet-ransomware-2025-2746 — Mass File Rename (payoutsking)
// Status: experimental | Level: high | ID: e6bc300a-4382-5671-92c1-92fd08190860

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
