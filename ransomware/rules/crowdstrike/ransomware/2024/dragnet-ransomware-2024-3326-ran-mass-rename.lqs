// Dragnet [Ransomware]: dragnet-ransomware-2024-3326 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 6b40e4ca-c12e-544f-99ea-12f157127cbd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
