// Dragnet [Ransomware]: dragnet-ransomware-2023-4444 — Mass File Rename (noescape)
// Status: experimental | Level: high | ID: 2025e865-a114-5ba2-86db-3d975f167df6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
