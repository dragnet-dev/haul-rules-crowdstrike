// Dragnet [Ransomware]: dragnet-ransomware-2022-1815 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: d6f712e4-bee5-5726-8578-212f90e437a0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
