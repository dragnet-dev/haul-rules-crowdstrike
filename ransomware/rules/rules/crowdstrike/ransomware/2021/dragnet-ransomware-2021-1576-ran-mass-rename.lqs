// Dragnet [Ransomware]: dragnet-ransomware-2021-1576 — Mass File Rename (xinglocker)
// Status: deprecated | Level: high | ID: 6ee298ef-fba9-5b21-a517-e7e3b680d166

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
