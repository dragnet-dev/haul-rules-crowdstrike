// Dragnet [Ransomware]: dragnet-ransomware-2022-3096 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: fc60ec21-504e-5413-9110-4d57364f3120

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
