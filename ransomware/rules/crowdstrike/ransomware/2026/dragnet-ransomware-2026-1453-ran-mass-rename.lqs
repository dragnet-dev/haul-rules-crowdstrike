// Dragnet [Ransomware]: dragnet-ransomware-2026-1453 — Mass File Rename (safepay)
// Status: stable | Level: high | ID: feb53c17-bca9-5739-a922-d83cc7c522ab

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
