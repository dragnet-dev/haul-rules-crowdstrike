// Dragnet [Ransomware]: dragnet-ransomware-2024-1653 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: b4ba2b54-bd35-5d90-a2a9-3fed0d06f7d0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
