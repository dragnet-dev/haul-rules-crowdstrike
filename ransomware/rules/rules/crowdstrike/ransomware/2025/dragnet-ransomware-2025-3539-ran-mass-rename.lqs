// Dragnet [Ransomware]: dragnet-ransomware-2025-3539 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: be7e9035-643f-562e-b451-de29e78e4e03

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
