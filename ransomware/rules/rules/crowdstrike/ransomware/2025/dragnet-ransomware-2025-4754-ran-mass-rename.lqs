// Dragnet [Ransomware]: dragnet-ransomware-2025-4754 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: a03fe246-1cca-535b-8e64-12250dc1359c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
