// Dragnet [Ransomware]: dragnet-ransomware-2025-6440 — Mass File Rename (devman)
// Status: deprecated | Level: high | ID: fdca12ef-87e0-50de-8488-3027768160b6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
