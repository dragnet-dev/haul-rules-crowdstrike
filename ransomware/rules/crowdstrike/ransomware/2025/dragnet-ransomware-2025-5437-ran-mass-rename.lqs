// Dragnet [Ransomware]: dragnet-ransomware-2025-5437 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 38e9d89d-5e18-503f-8626-4686c1814094

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
