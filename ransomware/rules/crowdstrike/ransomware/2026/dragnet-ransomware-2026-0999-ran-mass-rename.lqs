// Dragnet [Ransomware]: dragnet-ransomware-2026-0999 — Mass File Rename (shinyhunters)
// Status: deprecated | Level: high | ID: 13f7785d-05a3-5bd7-ac4e-4f9f1e4042b8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
