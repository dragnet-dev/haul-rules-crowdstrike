// Dragnet [Ransomware]: dragnet-ransomware-2025-3557 — Mass File Rename (abyss)
// Status: deprecated | Level: high | ID: a8075de2-d932-5199-a183-e56ddb02fa5e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
