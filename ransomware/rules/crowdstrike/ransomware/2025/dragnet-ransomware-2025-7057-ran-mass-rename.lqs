// Dragnet [Ransomware]: dragnet-ransomware-2025-7057 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: d780df07-4b37-5b13-a9f4-9907b3506140

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
