// Dragnet [Ransomware]: dragnet-ransomware-2025-2481 — Mass File Rename (thegentlemen)
// Status: experimental | Level: high | ID: b33eca28-68e3-547b-b601-4e1b214152cc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
