// Dragnet [Ransomware]: dragnet-ransomware-2025-0470 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: 01a68b0a-46c6-5ead-9431-bc2f2d26dd71

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
