// Dragnet [Ransomware]: dragnet-ransomware-2023-4998 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: eb0c5cfb-2f0a-55ed-b6ba-c54912552b77

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
