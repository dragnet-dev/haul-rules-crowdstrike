// Dragnet [Ransomware]: dragnet-ransomware-2024-2630 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: ba568f9b-e8f1-5593-927c-1c6422c4c28d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
