// Dragnet [Ransomware]: dragnet-ransomware-2021-0149 — Mass File Rename (revil)
// Status: deprecated | Level: high | ID: a54e0b58-85c6-5713-aade-c2be45ed6616

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
