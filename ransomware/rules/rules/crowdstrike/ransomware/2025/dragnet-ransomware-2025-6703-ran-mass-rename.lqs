// Dragnet [Ransomware]: dragnet-ransomware-2025-6703 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 902a40be-0ec1-5568-afd7-baed8d9337ad

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
