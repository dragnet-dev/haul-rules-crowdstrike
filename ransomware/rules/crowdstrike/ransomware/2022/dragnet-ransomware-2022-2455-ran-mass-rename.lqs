// Dragnet [Ransomware]: dragnet-ransomware-2022-2455 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 01b92eca-bbf6-5db4-87b0-c99fd8bd3fb9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
