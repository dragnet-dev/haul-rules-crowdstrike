// Dragnet [Ransomware]: dragnet-ransomware-2021-1449 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: f4cf9982-1efc-5851-861a-93f51ba1d1ef

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
