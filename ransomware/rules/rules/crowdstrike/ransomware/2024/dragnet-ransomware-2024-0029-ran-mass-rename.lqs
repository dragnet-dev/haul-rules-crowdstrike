// Dragnet [Ransomware]: dragnet-ransomware-2024-0029 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 41f89353-a5f7-564d-a78d-3283f631c17f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
