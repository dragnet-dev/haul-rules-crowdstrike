// Dragnet [Ransomware]: dragnet-ransomware-2025-2219 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 159205af-0f56-5787-af6f-fb10f62e9e5d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
