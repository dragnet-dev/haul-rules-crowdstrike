// Dragnet [Ransomware]: dragnet-ransomware-2025-2223 — Mass File Rename (lockbit5)
// Status: experimental | Level: high | ID: fef47f0d-a101-5f37-82e8-cefcea8981bb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
