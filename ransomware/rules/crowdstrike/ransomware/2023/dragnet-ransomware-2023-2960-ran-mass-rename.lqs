// Dragnet [Ransomware]: dragnet-ransomware-2023-2960 — Mass File Rename (monti)
// Status: experimental | Level: high | ID: 3ab7d857-11f1-5423-b849-7c1ca036ad11

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
