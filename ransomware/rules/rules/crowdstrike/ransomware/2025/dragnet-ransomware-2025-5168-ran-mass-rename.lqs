// Dragnet [Ransomware]: dragnet-ransomware-2025-5168 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 13c7b65a-3dd2-59d4-b497-910c1813eb2f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
