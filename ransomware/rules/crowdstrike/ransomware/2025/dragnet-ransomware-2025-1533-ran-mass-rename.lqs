// Dragnet [Ransomware]: dragnet-ransomware-2025-1533 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 3172e90f-b2d3-5949-ad67-ef33ccbc0010

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
