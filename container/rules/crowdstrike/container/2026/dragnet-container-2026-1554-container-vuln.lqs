// Dragnet [Container]: dragnet-container-2026-1554 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 3b94bf9f-8549-53e5-8894-f693a7f9f6d6

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:7* OR ImageFileName = *debian:8*)
| table([timestamp, ComputerName])
| limit(1000)
