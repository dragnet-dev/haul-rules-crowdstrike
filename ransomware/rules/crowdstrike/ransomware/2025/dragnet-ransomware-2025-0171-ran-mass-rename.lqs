// Dragnet [Ransomware]: dragnet-ransomware-2025-0171 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 6a445bf0-6477-5ef3-aaa2-2dd06c3308c8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
