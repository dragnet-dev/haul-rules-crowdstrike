// Dragnet [Ransomware]: dragnet-ransomware-2023-4569 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: f25e20c6-7337-52e4-9328-3715b6797b25

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
