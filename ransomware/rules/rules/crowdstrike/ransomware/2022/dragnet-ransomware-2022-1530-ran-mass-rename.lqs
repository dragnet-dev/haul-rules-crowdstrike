// Dragnet [Ransomware]: dragnet-ransomware-2022-1530 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 8324c2b6-9dc6-5bb6-a61c-f1dc174e753a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
