// Dragnet [Ransomware]: dragnet-ransomware-2022-1455 — Mass File Rename (blackbasta)
// Status: deprecated | Level: high | ID: a3edba1a-167f-5271-9389-ee7d4cbca452

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
