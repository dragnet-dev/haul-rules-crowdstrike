// Dragnet [Ransomware]: dragnet-ransomware-2022-3123 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 592b71b7-a27a-571d-9c2c-7114c91c8037

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
