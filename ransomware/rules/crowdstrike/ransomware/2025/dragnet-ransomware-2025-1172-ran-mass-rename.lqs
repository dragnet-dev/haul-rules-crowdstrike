// Dragnet [Ransomware]: dragnet-ransomware-2025-1172 — Mass File Rename (alphalocker)
// Status: experimental | Level: high | ID: e330e35d-3fac-5fec-99b0-2d2689b5d3b1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
