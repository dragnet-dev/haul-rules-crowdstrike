// Dragnet [Ransomware]: dragnet-ransomware-2023-1294 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 63980fcd-a106-5efd-be49-5bb5a16d6138

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
