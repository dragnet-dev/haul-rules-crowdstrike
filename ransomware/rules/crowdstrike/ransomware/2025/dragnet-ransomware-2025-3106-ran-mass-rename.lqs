// Dragnet [Ransomware]: dragnet-ransomware-2025-3106 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: f76db99d-923f-50ef-8e7a-ef29e043bcbc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
