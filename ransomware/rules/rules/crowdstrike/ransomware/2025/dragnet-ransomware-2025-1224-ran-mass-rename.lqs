// Dragnet [Ransomware]: dragnet-ransomware-2025-1224 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 49e73961-7dd6-5afe-9a61-d8174acf9d94

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
