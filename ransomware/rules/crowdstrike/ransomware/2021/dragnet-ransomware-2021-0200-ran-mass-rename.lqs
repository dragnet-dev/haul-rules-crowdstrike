// Dragnet [Ransomware]: dragnet-ransomware-2021-0200 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 57a8302d-00af-5f62-a9b7-aa018fe390db

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
