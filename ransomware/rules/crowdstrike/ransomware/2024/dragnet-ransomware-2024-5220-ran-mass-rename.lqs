// Dragnet [Ransomware]: dragnet-ransomware-2024-5220 — Mass File Rename (trigona)
// Status: experimental | Level: high | ID: 3a7c85db-728f-5b5a-8e6f-916977d5b37f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
