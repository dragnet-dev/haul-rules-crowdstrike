// Dragnet [Ransomware]: dragnet-ransomware-2026-0559 — Mass File Rename (payoutsking)
// Status: stable | Level: high | ID: eab15c4e-5847-541c-bd06-b075ea663e96

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
