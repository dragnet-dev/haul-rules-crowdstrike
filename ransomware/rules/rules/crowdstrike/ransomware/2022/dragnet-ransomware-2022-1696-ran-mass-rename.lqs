// Dragnet [Ransomware]: dragnet-ransomware-2022-1696 — Mass File Rename (karakurt)
// Status: deprecated | Level: high | ID: dd2528b7-98a7-56d7-96b3-09379e333382

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
