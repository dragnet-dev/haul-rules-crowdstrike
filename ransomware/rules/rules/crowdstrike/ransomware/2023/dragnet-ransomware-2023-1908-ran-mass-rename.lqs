// Dragnet [Ransomware]: dragnet-ransomware-2023-1908 — Mass File Rename (noescape)
// Status: experimental | Level: high | ID: ee2c9952-9226-5000-af97-405024ac5f4e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
