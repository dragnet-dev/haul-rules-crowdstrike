// Dragnet [Ransomware]: dragnet-ransomware-2025-5989 — Mass File Rename (direwolf)
// Status: experimental | Level: high | ID: 3d092bb6-2b05-595d-b865-830889348539

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
