// Dragnet [Ransomware]: dragnet-ransomware-2024-2905 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 9e6b4bf7-9ebe-569d-a41f-5ac0233e47a6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
