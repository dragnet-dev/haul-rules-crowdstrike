// Dragnet [Ransomware]: dragnet-ransomware-2023-2313 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: cbc1efa0-4c44-5e9d-a7e4-837f9e11a774

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
