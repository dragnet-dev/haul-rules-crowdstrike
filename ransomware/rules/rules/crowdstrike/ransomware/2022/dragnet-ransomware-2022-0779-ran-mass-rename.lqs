// Dragnet [Ransomware]: dragnet-ransomware-2022-0779 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: b51942af-6367-5f64-853a-fd60947229ad

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
