// Dragnet [Ransomware]: dragnet-ransomware-2023-4628 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 255edf6f-38f6-5335-8832-2d0d38439a9c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
