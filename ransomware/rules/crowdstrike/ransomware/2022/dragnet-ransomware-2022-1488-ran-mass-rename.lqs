// Dragnet [Ransomware]: dragnet-ransomware-2022-1488 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: dcb50985-a30f-5b4a-874c-c8233ab94bb1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
