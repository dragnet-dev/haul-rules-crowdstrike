// Dragnet [Ransomware]: dragnet-ransomware-2023-4676 — Mass File Rename (ransomhouse)
// Status: experimental | Level: high | ID: 1a8a7b7e-3ccc-5201-a73b-8e31e65a3550

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
