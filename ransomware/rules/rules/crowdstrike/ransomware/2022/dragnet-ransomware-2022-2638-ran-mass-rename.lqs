// Dragnet [Ransomware]: dragnet-ransomware-2022-2638 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: cef3e023-bea7-5863-8238-3f45e3785c4c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
