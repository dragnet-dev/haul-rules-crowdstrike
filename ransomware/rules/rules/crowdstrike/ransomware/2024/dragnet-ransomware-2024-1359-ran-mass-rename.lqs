// Dragnet [Ransomware]: dragnet-ransomware-2024-1359 — Mass File Rename (dragonforce)
// Status: deprecated | Level: high | ID: ce56fb83-ffe5-5ac1-a12a-f35358c75176

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
