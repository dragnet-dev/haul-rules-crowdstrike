// Dragnet [Ransomware]: dragnet-ransomware-2023-3382 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 0900d714-db8e-5e3b-9fbd-d844b410ceef

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
