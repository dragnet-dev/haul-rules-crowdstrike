// Dragnet [Ransomware]: dragnet-ransomware-2025-6473 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: a054109e-a082-5b64-97bb-6d1e595a4a15

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
