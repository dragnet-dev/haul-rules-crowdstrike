// Dragnet [Ransomware]: dragnet-ransomware-2024-0984 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 6725a6fa-c032-5caf-99a3-d88c2f52dfe4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
