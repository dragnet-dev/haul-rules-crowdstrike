// Dragnet [Ransomware]: dragnet-ransomware-2023-0014 — Mass File Rename (royal)
// Status: experimental | Level: high | ID: 5d0071c7-9995-5e8e-9e04-0f7d388dd013

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
