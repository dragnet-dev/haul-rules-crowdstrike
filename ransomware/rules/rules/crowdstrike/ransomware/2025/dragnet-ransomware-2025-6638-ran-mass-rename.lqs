// Dragnet [Ransomware]: dragnet-ransomware-2025-6638 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 0564ca78-0d0d-5694-a2ab-4977f76c08dc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
