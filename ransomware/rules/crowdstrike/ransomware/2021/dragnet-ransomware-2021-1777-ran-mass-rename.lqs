// Dragnet [Ransomware]: dragnet-ransomware-2021-1777 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 82e7a420-e7d8-571b-8389-a11f8c5c8457

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
