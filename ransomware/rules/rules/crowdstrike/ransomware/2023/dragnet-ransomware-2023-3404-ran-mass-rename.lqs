// Dragnet [Ransomware]: dragnet-ransomware-2023-3404 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 5a5ffa0a-1077-5d20-b535-c9eb105b6e31

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
