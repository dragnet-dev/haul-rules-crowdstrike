// Dragnet [Container]: dragnet-container-2024-0115 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 1f48c081-3621-562a-b996-e35dfcd8b862

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12*)
| table([timestamp, ComputerName])
| limit(1000)
