// Dragnet [Ransomware]: dragnet-ransomware-2023-1816 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: f9fb148b-1ee0-53c3-80cd-40a4b75d7ef3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
