// Dragnet [Ransomware]: dragnet-ransomware-2025-4010 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: f5cdcc77-b272-520a-b3e0-c1d846a10048

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
