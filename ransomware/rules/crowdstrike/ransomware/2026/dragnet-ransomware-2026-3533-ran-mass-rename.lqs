// Dragnet [Ransomware]: dragnet-ransomware-2026-3533 — Mass File Rename (SilentRansomGroup)
// Status: deprecated | Level: high | ID: 90528174-2750-503d-8178-7f51f2bb8e13

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
