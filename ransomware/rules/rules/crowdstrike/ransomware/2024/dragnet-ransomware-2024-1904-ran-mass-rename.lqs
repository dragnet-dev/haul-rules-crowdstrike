// Dragnet [Ransomware]: dragnet-ransomware-2024-1904 — Mass File Rename (handala)
// Status: experimental | Level: high | ID: 243abda7-f001-5fc2-a450-79a3c179b9b3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
