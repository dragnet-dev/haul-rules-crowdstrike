// Dragnet [Ransomware]: dragnet-ransomware-2025-5817 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: b8b0d2ea-dab5-5d93-9911-55c1816a43e3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
