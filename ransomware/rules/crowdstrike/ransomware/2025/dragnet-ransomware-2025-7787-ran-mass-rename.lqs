// Dragnet [Ransomware]: dragnet-ransomware-2025-7787 — Mass File Rename (lockbit5)
// Status: test | Level: high | ID: b70a9dd9-8588-5cf4-9cdc-9e45706306d7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
