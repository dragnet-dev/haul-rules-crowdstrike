// Dragnet [Ransomware]: dragnet-ransomware-2024-1363 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: 10a97f10-5c60-587c-a7bb-8ad61a86e4c2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
