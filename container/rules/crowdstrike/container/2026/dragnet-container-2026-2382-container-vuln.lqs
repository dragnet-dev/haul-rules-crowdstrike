// Dragnet [Container]: dragnet-container-2026-2382 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 82cfd9d6-816a-5f34-80bf-7234201f7303

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:8*)
| table([timestamp, ComputerName])
| limit(1000)
