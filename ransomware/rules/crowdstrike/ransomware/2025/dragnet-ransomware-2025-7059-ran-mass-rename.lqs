// Dragnet [Ransomware]: dragnet-ransomware-2025-7059 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 62af6fbf-ccc4-5960-b80b-3bf087c0161b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
