// Dragnet [Container]: dragnet-container-2026-0084 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: a67db6b2-e1eb-541a-8afb-3703ea02c197

#event_simpleName=*
| (ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10*)
| table([timestamp, ComputerName])
| limit(1000)
