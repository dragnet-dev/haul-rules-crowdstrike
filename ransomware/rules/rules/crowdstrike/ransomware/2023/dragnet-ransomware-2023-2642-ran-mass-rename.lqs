// Dragnet [Ransomware]: dragnet-ransomware-2023-2642 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: a6bd4a68-f2b7-57ee-a141-181fb2b2787f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
