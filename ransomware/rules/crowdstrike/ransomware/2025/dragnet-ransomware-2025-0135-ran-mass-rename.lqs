// Dragnet [Ransomware]: dragnet-ransomware-2025-0135 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: c92e1bd3-d0bf-5cbd-9d50-4ebb81a6e242

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
