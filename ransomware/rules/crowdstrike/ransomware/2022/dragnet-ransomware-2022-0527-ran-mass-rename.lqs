// Dragnet [Ransomware]: dragnet-ransomware-2022-0527 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 4584877d-d1b5-58fd-85e0-632944c0d51c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
