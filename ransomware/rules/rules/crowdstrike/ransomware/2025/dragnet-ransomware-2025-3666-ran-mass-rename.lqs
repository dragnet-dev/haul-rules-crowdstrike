// Dragnet [Ransomware]: dragnet-ransomware-2025-3666 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: b8115cb5-f8d2-535d-b430-b9b3171faedc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
