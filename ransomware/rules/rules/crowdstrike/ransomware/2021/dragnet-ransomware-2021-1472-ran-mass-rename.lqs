// Dragnet [Ransomware]: dragnet-ransomware-2021-1472 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 562e0d23-bde3-5716-95a9-3fa27e5cd3e2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
