// Dragnet [Ransomware]: dragnet-ransomware-2025-5074 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: 93a79996-a6f2-510b-bed3-cf513f756927

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
