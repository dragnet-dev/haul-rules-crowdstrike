// Dragnet [Ransomware]: dragnet-ransomware-2022-1763 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: eadb0f93-688c-532d-ae7b-d5ca901c9a90

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
