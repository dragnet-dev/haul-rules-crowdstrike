// Dragnet [Ransomware]: dragnet-ransomware-2025-7290 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: a94900b6-7c69-530c-b052-90a291cfe7ca

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
