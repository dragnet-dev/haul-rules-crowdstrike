// Dragnet [Ransomware]: dragnet-ransomware-2022-1400 — Mass File Rename (cuba)
// Status: deprecated | Level: high | ID: 66c20bf2-fcd7-54f6-af71-b327b686d811

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
