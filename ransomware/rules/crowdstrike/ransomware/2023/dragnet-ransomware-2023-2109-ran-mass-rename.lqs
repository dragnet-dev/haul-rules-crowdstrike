// Dragnet [Ransomware]: dragnet-ransomware-2023-2109 — Mass File Rename (rhysida)
// Status: experimental | Level: high | ID: 4a031c58-9a02-56d4-a0ed-60d2e2b8da13

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
