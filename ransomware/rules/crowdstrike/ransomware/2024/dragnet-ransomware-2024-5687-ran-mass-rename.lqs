// Dragnet [Ransomware]: dragnet-ransomware-2024-5687 — Mass File Rename (apt73)
// Status: experimental | Level: high | ID: f8cf3970-fccd-57ad-b392-ffb708732267

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
