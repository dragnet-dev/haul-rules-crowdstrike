// Dragnet [Container]: dragnet-container-2026-2303 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 8f9995d7-d5ef-51be-aef4-3152e985a8ae

#event_simpleName=*
| (ImageFileName = *alpine:3.2* OR ImageFileName = *alpine:3.3* OR ImageFileName = *alpine:3.4* OR ImageFileName = *alpine:3.5* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:7* OR ImageFileName = *debian:8* OR ImageFileName = *ubuntu:16.04* OR ImageFileName = *ubuntu:16.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
