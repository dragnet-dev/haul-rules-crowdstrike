// Dragnet [Container]: dragnet-container-2024-0795 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 2d42bf0d-d5f9-516d-9b54-59d592467bbe

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:9*)
| table([timestamp, ComputerName])
| limit(1000)
