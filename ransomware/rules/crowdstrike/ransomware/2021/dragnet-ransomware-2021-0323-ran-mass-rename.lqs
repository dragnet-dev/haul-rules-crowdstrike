// Dragnet [Ransomware]: dragnet-ransomware-2021-0323 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: ca6b0ad2-264d-5801-b0e8-a62e0e418c68

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
