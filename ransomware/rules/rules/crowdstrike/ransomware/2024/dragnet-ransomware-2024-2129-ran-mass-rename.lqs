// Dragnet [Ransomware]: dragnet-ransomware-2024-2129 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 97f3e0c9-d5cc-50a8-aacf-94bcc52797cb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
