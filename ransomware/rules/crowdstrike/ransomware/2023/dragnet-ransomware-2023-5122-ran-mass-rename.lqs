// Dragnet [Ransomware]: dragnet-ransomware-2023-5122 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: 1e6836d6-53b9-51bb-8e79-b476da8418ee

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
