// Dragnet [Ransomware]: dragnet-ransomware-2024-5662 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: d93d1ec5-ac90-56f4-91ef-ee8b14e30f15

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
