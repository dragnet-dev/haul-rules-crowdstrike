// Dragnet [Ransomware]: dragnet-ransomware-2023-0690 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: cd99e604-0e01-5836-8567-dd83561eee13

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
