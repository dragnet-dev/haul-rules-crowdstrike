// Dragnet [Container]: dragnet-container-2025-0661 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 8ee39e69-cd3b-5b29-a28f-dd1526772ecf

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *ubuntu:20.04-ESM* OR ImageFileName = *ubuntu:22.04*)
| table([timestamp, ComputerName])
| limit(1000)
