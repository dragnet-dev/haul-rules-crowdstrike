// Dragnet [Ransomware]: dragnet-ransomware-2025-1714 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: 46744bca-5dd6-5d85-b39a-042d4460ffc4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
