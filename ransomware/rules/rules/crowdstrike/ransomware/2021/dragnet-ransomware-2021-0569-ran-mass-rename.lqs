// Dragnet [Ransomware]: dragnet-ransomware-2021-0569 — Mass File Rename (avaddon)
// Status: deprecated | Level: high | ID: 556ce5d9-fabb-5229-8732-2c90d578b09a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
