// Dragnet [Ransomware]: dragnet-ransomware-2025-7532 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: fb7a6849-e4e0-5f7a-a6a7-346f7493d6a0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
