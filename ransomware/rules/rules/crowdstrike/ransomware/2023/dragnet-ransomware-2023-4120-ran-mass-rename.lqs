// Dragnet [Ransomware]: dragnet-ransomware-2023-4120 — Mass File Rename (losttrust)
// Status: deprecated | Level: high | ID: c7d1651d-9844-5182-b825-7c5a76b1e36f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
