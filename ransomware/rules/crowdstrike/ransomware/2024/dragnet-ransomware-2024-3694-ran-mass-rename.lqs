// Dragnet [Ransomware]: dragnet-ransomware-2024-3694 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 492fada4-606c-50d9-af70-774e68b429a4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
