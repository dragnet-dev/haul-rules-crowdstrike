// Dragnet [Ransomware]: dragnet-ransomware-2021-0450 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 934ccfc3-a0e6-5cde-84c6-18b64a643d1a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
