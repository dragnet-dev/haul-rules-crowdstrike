// Dragnet [Ransomware]: dragnet-ransomware-2022-2108 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: a4838e33-65b5-5d7c-a798-e021d11b186b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
