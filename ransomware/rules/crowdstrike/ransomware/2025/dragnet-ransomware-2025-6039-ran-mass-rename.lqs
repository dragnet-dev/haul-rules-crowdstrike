// Dragnet [Ransomware]: dragnet-ransomware-2025-6039 — Mass File Rename (metaencryptor)
// Status: experimental | Level: high | ID: af540225-1bae-50e3-b007-bfa43ee5385d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
