// Dragnet [Ransomware]: dragnet-ransomware-2024-2817 — Mass File Rename (argonauts)
// Status: experimental | Level: high | ID: 8f064698-6089-5be2-b1a9-3d9954956ed3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
