// Dragnet [Ransomware]: dragnet-ransomware-2025-1069 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: ccdd8d75-3dca-565d-9fbd-7a426b15a66e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
