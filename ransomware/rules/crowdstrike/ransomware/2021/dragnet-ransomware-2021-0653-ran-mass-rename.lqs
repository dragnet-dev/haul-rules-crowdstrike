// Dragnet [Ransomware]: dragnet-ransomware-2021-0653 — Mass File Rename (atomsilo)
// Status: experimental | Level: high | ID: bc78ac39-4217-5dba-a53b-188336c3fb2a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
