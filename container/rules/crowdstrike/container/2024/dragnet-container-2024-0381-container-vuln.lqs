// Dragnet [Container]: dragnet-container-2024-0381 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 073093f1-a2e2-5816-ae87-5a319e4995a1

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
