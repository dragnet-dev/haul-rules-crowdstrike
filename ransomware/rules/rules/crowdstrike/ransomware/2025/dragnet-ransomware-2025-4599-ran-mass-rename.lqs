// Dragnet [Ransomware]: dragnet-ransomware-2025-4599 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 4c904d77-93bf-5e1d-adee-e0648a417198

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
