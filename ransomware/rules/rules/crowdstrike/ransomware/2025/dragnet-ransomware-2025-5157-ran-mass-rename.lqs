// Dragnet [Ransomware]: dragnet-ransomware-2025-5157 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: ec6d6edc-86c7-56b1-a6fc-32c022a66b8c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
