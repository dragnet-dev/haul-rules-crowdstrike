// Dragnet [Ransomware]: dragnet-ransomware-2025-7626 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: e537886f-129e-5a50-a052-b2dc16667ca9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
