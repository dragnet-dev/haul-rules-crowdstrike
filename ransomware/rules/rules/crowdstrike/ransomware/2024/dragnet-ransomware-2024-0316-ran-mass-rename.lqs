// Dragnet [Ransomware]: dragnet-ransomware-2024-0316 — Mass File Rename (blacklock)
// Status: experimental | Level: high | ID: 6cba3933-f940-5d39-a06e-8722e59491e0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
