// Dragnet [Ransomware]: dragnet-ransomware-2023-3566 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: c3a27278-6ea5-5009-a000-3e4eac2ccabe

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
