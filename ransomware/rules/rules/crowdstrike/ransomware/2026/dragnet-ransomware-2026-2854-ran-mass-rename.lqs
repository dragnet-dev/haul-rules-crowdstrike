// Dragnet [Ransomware]: dragnet-ransomware-2026-2854 — Mass File Rename (nightspire)
// Status: deprecated | Level: high | ID: d6b107d5-d458-57f1-a697-c022ac891707

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
