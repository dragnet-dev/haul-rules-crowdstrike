// Dragnet [Ransomware]: dragnet-ransomware-2022-2743 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 970ec554-ab7e-514e-ad79-d7deb78ae30f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
