// Dragnet [Ransomware]: dragnet-ransomware-2025-5892 — Mass File Rename (SilentRansomGroup)
// Status: deprecated | Level: high | ID: 148b8167-42c6-5151-8c45-80b31820b108

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
