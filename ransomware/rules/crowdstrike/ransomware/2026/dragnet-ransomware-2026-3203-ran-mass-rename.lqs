// Dragnet [Ransomware]: dragnet-ransomware-2026-3203 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 0650466c-1167-5252-bcff-df3ee07d8b2d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
