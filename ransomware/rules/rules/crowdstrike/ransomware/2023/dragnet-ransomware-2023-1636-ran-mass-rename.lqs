// Dragnet [Ransomware]: dragnet-ransomware-2023-1636 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 2344f7f3-70f9-5d54-8ce5-79f02a129998

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
