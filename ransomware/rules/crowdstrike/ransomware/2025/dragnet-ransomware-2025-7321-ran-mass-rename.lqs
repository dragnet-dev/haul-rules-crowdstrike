// Dragnet [Ransomware]: dragnet-ransomware-2025-7321 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: b504f761-e9b6-5e7e-9948-4e1ca6555048

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
