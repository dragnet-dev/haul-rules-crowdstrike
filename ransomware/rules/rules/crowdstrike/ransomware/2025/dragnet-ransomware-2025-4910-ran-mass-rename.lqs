// Dragnet [Ransomware]: dragnet-ransomware-2025-4910 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 860f26af-519c-57d4-8757-1471eb325d27

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
