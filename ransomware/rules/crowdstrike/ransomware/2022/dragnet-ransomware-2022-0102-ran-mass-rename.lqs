// Dragnet [Ransomware]: dragnet-ransomware-2022-0102 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 1ad7c73c-7479-560a-b77f-544237876607

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
