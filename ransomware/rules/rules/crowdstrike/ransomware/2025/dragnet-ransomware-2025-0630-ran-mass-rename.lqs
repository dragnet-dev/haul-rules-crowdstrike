// Dragnet [Ransomware]: dragnet-ransomware-2025-0630 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: 28458e35-1805-54ff-9d11-e1f8cb0f183e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
