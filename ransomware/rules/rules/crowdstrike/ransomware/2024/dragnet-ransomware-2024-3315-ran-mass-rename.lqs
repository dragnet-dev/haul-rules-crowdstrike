// Dragnet [Ransomware]: dragnet-ransomware-2024-3315 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 6393a66d-1145-571d-ac4b-745809197af4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
