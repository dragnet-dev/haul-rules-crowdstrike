// Dragnet [Ransomware]: dragnet-ransomware-2022-0791 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 34a25442-36d8-5199-981d-d693b1dfce45

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
