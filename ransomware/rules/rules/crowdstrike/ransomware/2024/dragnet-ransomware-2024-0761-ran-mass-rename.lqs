// Dragnet [Ransomware]: dragnet-ransomware-2024-0761 — Mass File Rename (play)
// Status: experimental | Level: high | ID: d2c5f44f-7880-5803-986c-0912ec1ac228

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
