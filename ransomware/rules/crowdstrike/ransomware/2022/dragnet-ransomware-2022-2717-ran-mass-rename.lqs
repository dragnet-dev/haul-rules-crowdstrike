// Dragnet [Ransomware]: dragnet-ransomware-2022-2717 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: e717bc6b-d300-529a-8b9d-9316524016c5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
