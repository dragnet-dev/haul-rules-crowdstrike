// Dragnet [Ransomware]: dragnet-ransomware-2022-0357 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 1c4ea696-da86-5ac5-9fae-607139bbe4fb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
