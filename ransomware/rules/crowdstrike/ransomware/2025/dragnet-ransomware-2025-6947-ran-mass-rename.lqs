// Dragnet [Ransomware]: dragnet-ransomware-2025-6947 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: d6fc7799-c3b6-519c-b64c-2d3d21c8c057

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
