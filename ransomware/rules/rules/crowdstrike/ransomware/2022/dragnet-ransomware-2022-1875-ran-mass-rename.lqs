// Dragnet [Ransomware]: dragnet-ransomware-2022-1875 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: eb6f5e6c-3b61-5529-bb4f-25552d6aaacc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
