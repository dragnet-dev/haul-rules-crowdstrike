// Dragnet [Ransomware]: dragnet-ransomware-2025-2639 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 9e3e4122-7417-543e-b16d-0f87cf44d61e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
