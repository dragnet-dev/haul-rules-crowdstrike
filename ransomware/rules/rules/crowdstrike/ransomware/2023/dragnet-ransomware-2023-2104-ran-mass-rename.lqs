// Dragnet [Ransomware]: dragnet-ransomware-2023-2104 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 022faa87-9bcc-52e8-80cc-50be3c1062ab

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
