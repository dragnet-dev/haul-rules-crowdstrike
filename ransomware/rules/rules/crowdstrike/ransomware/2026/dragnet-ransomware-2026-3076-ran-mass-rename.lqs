// Dragnet [Ransomware]: dragnet-ransomware-2026-3076 — Mass File Rename (lapsus$)
// Status: deprecated | Level: high | ID: 8a38b6bd-0c96-5807-b2f6-79c31a57f86d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
