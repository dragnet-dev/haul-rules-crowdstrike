// Dragnet [Ransomware]: dragnet-ransomware-2025-3896 — Mass File Rename (kairos)
// Status: experimental | Level: high | ID: e73451a8-fab4-512e-9e53-42bb83c5a504

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
