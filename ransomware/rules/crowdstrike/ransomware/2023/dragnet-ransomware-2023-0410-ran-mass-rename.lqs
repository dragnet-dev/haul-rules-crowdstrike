// Dragnet [Ransomware]: dragnet-ransomware-2023-0410 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 9f829489-17f8-58be-9e4b-035edd994a04

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
