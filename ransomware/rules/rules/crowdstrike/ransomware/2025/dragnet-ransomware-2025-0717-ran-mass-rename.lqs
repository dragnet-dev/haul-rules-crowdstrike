// Dragnet [Ransomware]: dragnet-ransomware-2025-0717 — Mass File Rename (nightspire)
// Status: deprecated | Level: high | ID: b2cac2b3-dc22-5443-baf6-baccfc53d7ae

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
