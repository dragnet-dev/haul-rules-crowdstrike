// Dragnet [Ransomware]: dragnet-ransomware-2026-3308 — Mass File Rename (anubis)
// Status: stable | Level: high | ID: 9271d04a-3b91-5359-86cd-69f5b6db4528

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
