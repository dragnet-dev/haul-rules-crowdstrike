// Dragnet [Ransomware]: dragnet-ransomware-2024-0004 — Mass File Rename (play)
// Status: experimental | Level: high | ID: f896f4ab-6519-510a-944e-58ada2f26cfc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
