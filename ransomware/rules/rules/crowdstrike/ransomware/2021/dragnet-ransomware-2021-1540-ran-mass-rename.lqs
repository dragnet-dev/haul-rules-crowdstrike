// Dragnet [Ransomware]: dragnet-ransomware-2021-1540 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 1e0f1845-986f-5b66-99fe-76d123c4273f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
