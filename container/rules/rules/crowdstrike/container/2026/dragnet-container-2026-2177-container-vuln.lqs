// Dragnet [Container]: dragnet-container-2026-2177 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 8e3bfd96-a6b8-5046-a4dd-8d3af6f52c33

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:8* OR ImageFileName = *debian:9*)
| table([timestamp, ComputerName])
| limit(1000)
