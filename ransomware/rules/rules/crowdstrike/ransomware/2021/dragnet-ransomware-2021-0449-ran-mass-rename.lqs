// Dragnet [Ransomware]: dragnet-ransomware-2021-0449 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 9a0ab977-0d29-5f66-8f70-454c3e9349a8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
