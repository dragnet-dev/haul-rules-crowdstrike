// Dragnet [Ransomware]: dragnet-ransomware-2021-1321 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 8a986858-edd8-5c07-a5c4-5a65346db131

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
