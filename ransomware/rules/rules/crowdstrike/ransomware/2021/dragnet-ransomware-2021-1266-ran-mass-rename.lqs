// Dragnet [Ransomware]: dragnet-ransomware-2021-1266 — Mass File Rename (revil)
// Status: deprecated | Level: high | ID: 01cbd28a-c119-5ac1-9073-e5d3707cd04a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
