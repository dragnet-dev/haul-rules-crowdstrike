// Dragnet [Ransomware]: dragnet-ransomware-2025-1754 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 11b236bc-16dd-5409-a397-d83ebdddc88e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
