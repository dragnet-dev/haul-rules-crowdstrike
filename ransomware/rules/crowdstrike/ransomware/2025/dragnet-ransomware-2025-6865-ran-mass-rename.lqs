// Dragnet [Ransomware]: dragnet-ransomware-2025-6865 — Mass File Rename (bravox)
// Status: experimental | Level: high | ID: f0e7c016-062d-589b-9a19-078392762125

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
