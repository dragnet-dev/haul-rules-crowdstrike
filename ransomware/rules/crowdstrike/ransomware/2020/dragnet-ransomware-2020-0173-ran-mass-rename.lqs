// Dragnet [Ransomware]: dragnet-ransomware-2020-0173 — Mass File Rename (maze)
// Status: deprecated | Level: high | ID: d3ba52da-6c54-56b0-9f67-4ddb4fd93c5c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
