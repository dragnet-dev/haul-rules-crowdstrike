// Dragnet [Ransomware]: dragnet-ransomware-2023-4906 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 8ea56d14-f630-5cd3-90ad-52594ef61461

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
