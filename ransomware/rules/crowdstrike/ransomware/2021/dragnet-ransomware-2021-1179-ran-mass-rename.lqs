// Dragnet [Ransomware]: dragnet-ransomware-2021-1179 — Mass File Rename (avaddon)
// Status: deprecated | Level: high | ID: 9729475b-1d49-5870-aa39-d7297c35a949

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
