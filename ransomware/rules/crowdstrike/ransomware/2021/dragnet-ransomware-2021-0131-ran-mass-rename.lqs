// Dragnet [Ransomware]: dragnet-ransomware-2021-0131 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 61e22eb3-7d17-5d11-a7ec-4d874fcaaa92

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
