// Dragnet [Ransomware]: dragnet-ransomware-2024-4011 — Mass File Rename (qilin)
// Status: deprecated | Level: high | ID: 07232939-d27d-53b6-9b4e-609d9cf9ee42

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
