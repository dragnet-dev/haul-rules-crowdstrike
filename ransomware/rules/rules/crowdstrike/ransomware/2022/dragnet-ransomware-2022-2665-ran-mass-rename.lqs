// Dragnet [Ransomware]: dragnet-ransomware-2022-2665 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: c73e4894-2d7f-5c4a-a281-d053baa489ac

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
