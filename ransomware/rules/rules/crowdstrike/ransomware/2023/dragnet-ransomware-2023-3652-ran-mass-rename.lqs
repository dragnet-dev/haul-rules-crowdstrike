// Dragnet [Ransomware]: dragnet-ransomware-2023-3652 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 73875468-057d-59c5-950a-f58ae5d36463

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
