// Dragnet [Ransomware]: dragnet-ransomware-2026-0144 — Mass File Rename (incransom)
// Status: test | Level: high | ID: 3d6aedbc-8674-5660-9fdb-b2929b26aa35

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
