// Dragnet [Ransomware]: dragnet-ransomware-2025-2184 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 80b1349e-9155-54e8-9de2-4b1f36fa5f6a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
