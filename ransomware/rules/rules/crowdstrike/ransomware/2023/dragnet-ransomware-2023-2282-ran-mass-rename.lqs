// Dragnet [Ransomware]: dragnet-ransomware-2023-2282 — Mass File Rename (stormous)
// Status: experimental | Level: high | ID: 8ab71948-fd78-5476-999c-cf970b6bfd11

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
