// Dragnet [Ransomware]: dragnet-ransomware-2023-0941 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 65fbb639-ad11-5ad9-8395-0fcc50f0f88f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
