// Dragnet [Ransomware]: dragnet-ransomware-2025-6560 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: 89420338-b7cf-59b7-b8ee-34e478c770a1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
