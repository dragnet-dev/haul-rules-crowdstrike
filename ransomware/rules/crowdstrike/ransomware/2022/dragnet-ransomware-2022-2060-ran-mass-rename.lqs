// Dragnet [Ransomware]: dragnet-ransomware-2022-2060 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 29da3ded-1a6c-5785-9efd-3281fcd68e9c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
