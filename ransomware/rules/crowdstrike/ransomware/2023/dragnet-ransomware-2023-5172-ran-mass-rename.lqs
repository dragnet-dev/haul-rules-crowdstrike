// Dragnet [Ransomware]: dragnet-ransomware-2023-5172 — Mass File Rename (medusalocker)
// Status: experimental | Level: high | ID: 7a2502bf-caf9-516f-8662-0ad3d5da7b48

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
