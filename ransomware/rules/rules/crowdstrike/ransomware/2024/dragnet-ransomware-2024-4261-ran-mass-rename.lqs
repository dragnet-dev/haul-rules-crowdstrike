// Dragnet [Ransomware]: dragnet-ransomware-2024-4261 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 6db7a0d3-a2e4-5811-8ded-cb3b72cb99ca

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
