// Dragnet [Ransomware]: dragnet-ransomware-2022-2461 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: aa4f13be-1e92-5d5e-8ca0-131cf4cb144f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
