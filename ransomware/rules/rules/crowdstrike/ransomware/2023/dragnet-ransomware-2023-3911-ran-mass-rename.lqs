// Dragnet [Ransomware]: dragnet-ransomware-2023-3911 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: f7083c6b-2bc1-55dc-9873-2a80b4f41fe7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
