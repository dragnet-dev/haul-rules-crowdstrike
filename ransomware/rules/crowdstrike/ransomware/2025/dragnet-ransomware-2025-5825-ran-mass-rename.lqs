// Dragnet [Ransomware]: dragnet-ransomware-2025-5825 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: 2900b74c-7928-5f0e-a913-56953cdf09aa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
