// Dragnet [Ransomware]: dragnet-ransomware-2025-1971 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: fce678a8-466e-5024-a397-7793618f2739

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
