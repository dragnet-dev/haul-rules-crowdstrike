// Dragnet [Ransomware]: dragnet-ransomware-2026-3106 — Mass File Rename (dragonforce)
// Status: test | Level: high | ID: 7b15fac4-7149-5fcb-83e4-96a7405dcde0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
