// Dragnet [Ransomware]: dragnet-ransomware-2023-4418 — Mass File Rename (threeam)
// Status: experimental | Level: high | ID: 48e1c983-f0e7-5ff1-9cd7-a4dee3912d48

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
