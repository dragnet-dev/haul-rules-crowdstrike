// Dragnet [Ransomware]: dragnet-ransomware-2022-1584 — Mass File Rename (medusalocker)
// Status: deprecated | Level: high | ID: b2e5ace2-feae-582f-ba98-38e09e53553d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
