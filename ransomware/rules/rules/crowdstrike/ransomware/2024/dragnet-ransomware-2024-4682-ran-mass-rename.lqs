// Dragnet [Ransomware]: dragnet-ransomware-2024-4682 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: f54d1f34-87f7-580a-b792-edf51daa77fe

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
