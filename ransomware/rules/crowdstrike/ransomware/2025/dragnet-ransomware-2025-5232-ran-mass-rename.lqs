// Dragnet [Ransomware]: dragnet-ransomware-2025-5232 — Mass File Rename (lockbit5)
// Status: test | Level: high | ID: d503600c-8611-504d-a96b-d95d3be416aa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
