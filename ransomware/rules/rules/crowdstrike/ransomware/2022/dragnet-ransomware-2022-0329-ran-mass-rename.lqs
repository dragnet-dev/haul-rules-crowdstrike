// Dragnet [Ransomware]: dragnet-ransomware-2022-0329 — Mass File Rename (sparta)
// Status: deprecated | Level: high | ID: 269ad9c6-0d2c-5867-a71a-926ce4c1c7ac

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
