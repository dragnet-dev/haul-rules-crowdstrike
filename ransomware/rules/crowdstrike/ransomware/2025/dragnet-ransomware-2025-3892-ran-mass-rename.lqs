// Dragnet [Ransomware]: dragnet-ransomware-2025-3892 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: 7e6191eb-a4db-534c-ba2a-186673425e97

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
