// Dragnet [Ransomware]: dragnet-ransomware-2023-1868 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: b615a380-96f8-5815-824a-e8e8bc64710f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
