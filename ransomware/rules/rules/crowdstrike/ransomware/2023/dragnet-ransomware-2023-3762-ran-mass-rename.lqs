// Dragnet [Ransomware]: dragnet-ransomware-2023-3762 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 8099d25a-a9a4-5f13-aee7-edf11081012e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
