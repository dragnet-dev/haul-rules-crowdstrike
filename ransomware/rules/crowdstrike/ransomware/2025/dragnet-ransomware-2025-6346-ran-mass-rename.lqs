// Dragnet [Ransomware]: dragnet-ransomware-2025-6346 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 4d08bcc3-8ddb-5cf0-bd5c-83ace543c9fc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
