// Dragnet [Ransomware]: dragnet-ransomware-2025-0450 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: ac450329-c936-5a3c-9092-2fabd4746b23

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
