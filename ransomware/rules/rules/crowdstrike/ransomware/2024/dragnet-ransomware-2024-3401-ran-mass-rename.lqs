// Dragnet [Ransomware]: dragnet-ransomware-2024-3401 — Mass File Rename (raworld)
// Status: experimental | Level: high | ID: dfe1a060-6030-5610-8cb5-f40703c20a91

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
