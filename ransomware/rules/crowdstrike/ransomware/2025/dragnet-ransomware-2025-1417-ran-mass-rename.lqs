// Dragnet [Ransomware]: dragnet-ransomware-2025-1417 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 6bc61136-ca86-5a23-908a-41a9893b88f1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
