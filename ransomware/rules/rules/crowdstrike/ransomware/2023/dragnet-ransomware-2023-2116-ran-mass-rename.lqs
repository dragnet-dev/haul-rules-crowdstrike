// Dragnet [Ransomware]: dragnet-ransomware-2023-2116 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 65410077-ca8a-51cb-a7c0-529efb3c57b2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
