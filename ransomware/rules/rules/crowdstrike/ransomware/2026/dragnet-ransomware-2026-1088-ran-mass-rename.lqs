// Dragnet [Ransomware]: dragnet-ransomware-2026-1088 — Mass File Rename (thegentlemen)
// Status: test | Level: high | ID: 1a00c796-d471-50cf-9232-7c059eb86e8d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
