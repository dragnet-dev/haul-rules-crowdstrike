// Dragnet [Ransomware]: dragnet-ransomware-2025-1704 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 56d5bad8-24ba-55cb-8ad8-6dd9a1da595b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
