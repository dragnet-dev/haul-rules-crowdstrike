// Dragnet [Ransomware]: dragnet-ransomware-2022-1969 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 351f8e19-1a80-5cea-9e52-da3dc8a8d863

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
