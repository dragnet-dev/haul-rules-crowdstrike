// Dragnet [Ransomware]: dragnet-ransomware-2025-4496 — Mass File Rename (anubis)
// Status: experimental | Level: high | ID: a24dd004-4e35-5d0e-a5bd-99bb059ac7fc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
