// Dragnet [Ransomware]: dragnet-ransomware-2022-1371 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 7415c55e-4a69-545a-bbec-81715776728f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
