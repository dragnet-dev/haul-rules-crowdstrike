// Dragnet [Ransomware]: dragnet-ransomware-2024-2648 — Mass File Rename (trigona)
// Status: experimental | Level: high | ID: a8bce613-3493-5169-b2b2-0ccfaf54214b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
