// Dragnet [Ransomware]: dragnet-ransomware-2023-5127 — Mass File Rename (play)
// Status: experimental | Level: high | ID: a880b76c-6622-5a13-8db4-534a546cc5ef

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
