// Dragnet [Ransomware]: dragnet-ransomware-2025-4798 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 4b427f2d-5013-56ee-b6e3-c6f139d9fbe2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
