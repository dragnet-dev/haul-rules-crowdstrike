// Dragnet [Ransomware]: dragnet-ransomware-2022-1257 — Mass File Rename (karakurt)
// Status: deprecated | Level: high | ID: 36b64a94-d8d3-5bdb-810e-33acfe51b0e9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
