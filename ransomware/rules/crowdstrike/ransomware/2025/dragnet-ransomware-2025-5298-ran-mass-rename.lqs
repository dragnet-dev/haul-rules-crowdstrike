// Dragnet [Ransomware]: dragnet-ransomware-2025-5298 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 46887f5c-ad4c-5c3f-b466-cfb38c020529

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
