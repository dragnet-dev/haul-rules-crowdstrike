// Dragnet [Ransomware]: dragnet-ransomware-2025-5610 — Mass File Rename (rhysida)
// Status: experimental | Level: high | ID: 9bd2a461-e652-572b-a000-e61dd05d1c91

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
