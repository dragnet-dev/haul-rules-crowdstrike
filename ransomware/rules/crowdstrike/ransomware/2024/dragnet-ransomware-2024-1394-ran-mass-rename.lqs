// Dragnet [Ransomware]: dragnet-ransomware-2024-1394 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: e3112027-d9e7-516a-a3ae-3dffdb1755fe

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
