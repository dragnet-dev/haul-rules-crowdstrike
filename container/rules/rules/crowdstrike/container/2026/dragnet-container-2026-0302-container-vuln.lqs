// Dragnet [Container]: dragnet-container-2026-0302 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: f9e9824d-c2ba-55cb-a5f4-dc37c45eaec4

#event_simpleName=*
| (ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10* OR ImageFileName = *ubuntu:13.04* OR ImageFileName = *ubuntu:13.10*)
| table([timestamp, ComputerName])
| limit(1000)
