// Dragnet [Ransomware]: dragnet-ransomware-2025-1112 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: fd1e6a15-b865-59b3-bf8a-dab841e88b47

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
