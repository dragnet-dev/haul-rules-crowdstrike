// Dragnet [Ransomware]: dragnet-ransomware-2024-0976 — Mass File Rename (frag)
// Status: deprecated | Level: high | ID: 250ca54f-4888-55ac-a229-645cc6a57d2f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
