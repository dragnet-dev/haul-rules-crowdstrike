// Dragnet [Container]: dragnet-container-2026-3060 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 3ff746df-d2db-5a90-9c9b-7994e4d51173

#event_simpleName=*
| (ImageFileName = *alpine edge:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
