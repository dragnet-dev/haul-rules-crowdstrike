// Dragnet [Ransomware]: dragnet-ransomware-2025-6224 — Mass File Rename (lockbit5)
// Status: experimental | Level: high | ID: 88492f67-d01b-5135-a52d-6816a5a4b7e0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
