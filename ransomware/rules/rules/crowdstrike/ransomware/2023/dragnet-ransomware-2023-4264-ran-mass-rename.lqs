// Dragnet [Ransomware]: dragnet-ransomware-2023-4264 — Mass File Rename (losttrust)
// Status: deprecated | Level: high | ID: 45356232-1be3-5080-8115-32aa00c34482

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
