// Dragnet [Ransomware]: dragnet-ransomware-2025-7845 — Mass File Rename (devman)
// Status: experimental | Level: high | ID: f1856d6f-3a6f-5f52-b648-0e47e1e21c84

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
