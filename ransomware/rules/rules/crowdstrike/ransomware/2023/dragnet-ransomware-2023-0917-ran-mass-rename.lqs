// Dragnet [Ransomware]: dragnet-ransomware-2023-0917 — Mass File Rename (play)
// Status: experimental | Level: high | ID: d4c08cba-ff4a-5062-a972-823ae2a4337f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
