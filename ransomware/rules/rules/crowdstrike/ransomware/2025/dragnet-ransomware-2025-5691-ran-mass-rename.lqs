// Dragnet [Ransomware]: dragnet-ransomware-2025-5691 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: 203344e5-1c46-527d-b354-6fa708ec18ca

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
