// Dragnet [Ransomware]: dragnet-ransomware-2025-0103 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: c63ff9d6-fae4-5a5d-b939-d91addaa9259

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
