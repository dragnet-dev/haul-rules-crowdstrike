// Dragnet [Ransomware]: dragnet-ransomware-2024-0381 — Mass File Rename (darkvault)
// Status: experimental | Level: high | ID: a5956aa8-710e-5b14-ab1c-e22bc6dbeae7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
