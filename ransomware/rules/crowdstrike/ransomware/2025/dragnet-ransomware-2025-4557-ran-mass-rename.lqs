// Dragnet [Ransomware]: dragnet-ransomware-2025-4557 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 90b0b847-1487-5c5b-adaa-7f7c781d9659

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
