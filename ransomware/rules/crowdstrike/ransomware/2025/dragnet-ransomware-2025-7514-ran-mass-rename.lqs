// Dragnet [Ransomware]: dragnet-ransomware-2025-7514 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: 3566c62f-ad55-5030-92bd-47b7b79f44ff

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
