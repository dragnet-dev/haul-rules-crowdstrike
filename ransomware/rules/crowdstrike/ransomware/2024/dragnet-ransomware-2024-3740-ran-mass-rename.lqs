// Dragnet [Ransomware]: dragnet-ransomware-2024-3740 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 2015e32c-7a9b-5c5c-9ef1-264f9475d82a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
