// Dragnet [Ransomware]: dragnet-ransomware-2025-4764 — Mass File Rename (nova)
// Status: experimental | Level: high | ID: a0adfc7b-c6ea-50c1-802f-de8075f19cbf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
