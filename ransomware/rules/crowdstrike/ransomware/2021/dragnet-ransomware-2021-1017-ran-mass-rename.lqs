// Dragnet [Ransomware]: dragnet-ransomware-2021-1017 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 92732369-29f7-5f13-9d0d-f372a2841cff

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
