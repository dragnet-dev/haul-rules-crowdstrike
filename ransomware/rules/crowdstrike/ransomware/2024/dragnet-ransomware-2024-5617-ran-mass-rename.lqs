// Dragnet [Ransomware]: dragnet-ransomware-2024-5617 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: 79e7fd85-5374-54e5-8dfb-bad97a1e03de

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
