// Dragnet [Container]: dragnet-container-2026-1131 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 1d33b232-8f64-5584-891b-560b9edee6f1

#event_simpleName=*
| (ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10* OR ImageFileName = *ubuntu:13.04* OR ImageFileName = *ubuntu:13.10*)
| table([timestamp, ComputerName])
| limit(1000)
