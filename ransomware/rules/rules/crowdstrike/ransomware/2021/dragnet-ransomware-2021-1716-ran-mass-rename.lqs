// Dragnet [Ransomware]: dragnet-ransomware-2021-1716 — Mass File Rename (spook)
// Status: deprecated | Level: high | ID: 1b9ca0a4-b4e7-50c5-a6e8-9b736328c3ef

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
