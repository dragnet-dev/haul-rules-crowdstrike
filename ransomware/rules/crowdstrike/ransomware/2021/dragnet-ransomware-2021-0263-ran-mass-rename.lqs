// Dragnet [Ransomware]: dragnet-ransomware-2021-0263 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 996543f8-9f2c-569d-ab25-87f26b0536a7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
