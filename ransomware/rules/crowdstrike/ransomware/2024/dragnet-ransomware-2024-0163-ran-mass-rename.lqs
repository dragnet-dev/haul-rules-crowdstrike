// Dragnet [Ransomware]: dragnet-ransomware-2024-0163 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 704ee216-a2d9-5657-95ae-8ae78824bd0c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
