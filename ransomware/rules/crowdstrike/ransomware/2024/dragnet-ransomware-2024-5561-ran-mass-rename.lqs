// Dragnet [Ransomware]: dragnet-ransomware-2024-5561 — Mass File Rename (dragonransomware)
// Status: experimental | Level: high | ID: b78140a5-1d05-5614-8b18-718a632483e5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
