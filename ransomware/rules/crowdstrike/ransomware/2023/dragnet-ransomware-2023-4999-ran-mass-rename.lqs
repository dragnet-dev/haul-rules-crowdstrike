// Dragnet [Ransomware]: dragnet-ransomware-2023-4999 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: 84d03cf2-787b-5d22-8784-48c4adddd500

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
