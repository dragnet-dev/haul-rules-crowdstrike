// Dragnet [Container]: dragnet-container-2024-0434 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 611aa197-1e35-59f0-8241-ebe776de24ab

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *redhat/ubi9:*)
| table([timestamp, ComputerName])
| limit(1000)
