// Dragnet [Ransomware]: dragnet-ransomware-2024-5392 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: c4701ba9-23f2-5a26-a4f1-98525bd2fa7f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
