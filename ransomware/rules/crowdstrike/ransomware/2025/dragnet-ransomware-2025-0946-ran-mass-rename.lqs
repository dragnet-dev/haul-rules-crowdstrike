// Dragnet [Ransomware]: dragnet-ransomware-2025-0946 — Mass File Rename (pear)
// Status: experimental | Level: high | ID: 1e555143-cbcc-5f85-bb71-b293319353d8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
