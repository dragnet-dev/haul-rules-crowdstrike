// Dragnet [Ransomware]: dragnet-ransomware-2023-0682 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 2e9d9748-bd75-57f6-be53-08388aec8e83

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
