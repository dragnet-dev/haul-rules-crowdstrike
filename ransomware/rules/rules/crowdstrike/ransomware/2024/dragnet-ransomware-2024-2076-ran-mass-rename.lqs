// Dragnet [Ransomware]: dragnet-ransomware-2024-2076 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 00e8b698-0297-53ea-8d52-866aa7dd6a9c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
