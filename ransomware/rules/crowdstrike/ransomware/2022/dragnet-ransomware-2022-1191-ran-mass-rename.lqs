// Dragnet [Ransomware]: dragnet-ransomware-2022-1191 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: a751e636-aea7-554f-9827-f3fa6ad87f04

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
