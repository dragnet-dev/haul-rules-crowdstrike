// Dragnet [Ransomware]: dragnet-ransomware-2025-1733 — Mass File Rename (arcusmedia)
// Status: experimental | Level: high | ID: 0386d881-f177-5267-95aa-3ad5b99e8e07

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
