// Dragnet [Ransomware]: dragnet-ransomware-2025-1590 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: 1cb3bc07-23e3-5282-a012-e6363dfd7386

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
