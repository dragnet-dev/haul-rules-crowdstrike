// Dragnet [Ransomware]: dragnet-ransomware-2022-2927 — Mass File Rename (play)
// Status: deprecated | Level: high | ID: 73d596bf-5dcc-5947-94de-cdbaa85e23c3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
