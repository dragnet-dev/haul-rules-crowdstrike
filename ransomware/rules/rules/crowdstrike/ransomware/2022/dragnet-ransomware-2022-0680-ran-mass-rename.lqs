// Dragnet [Ransomware]: dragnet-ransomware-2022-0680 — Mass File Rename (ragnarlocker)
// Status: deprecated | Level: high | ID: 81d178d4-bfd5-555a-b41a-bad50bf3cbf8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
