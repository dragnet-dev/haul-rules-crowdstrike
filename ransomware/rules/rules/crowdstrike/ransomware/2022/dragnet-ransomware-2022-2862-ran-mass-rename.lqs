// Dragnet [Ransomware]: dragnet-ransomware-2022-2862 — Mass File Rename (medusalocker)
// Status: deprecated | Level: high | ID: baf1a72a-af8b-5a42-bb37-996704d73d24

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
