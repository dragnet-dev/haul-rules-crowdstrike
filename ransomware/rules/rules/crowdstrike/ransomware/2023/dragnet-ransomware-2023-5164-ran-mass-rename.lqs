// Dragnet [Ransomware]: dragnet-ransomware-2023-5164 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: aa7cf010-7d47-5113-b122-571e41bbdb8b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
