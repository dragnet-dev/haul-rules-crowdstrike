// Dragnet [Ransomware]: dragnet-ransomware-2025-0673 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 86dbfb30-0962-5770-8c60-a11b97d54499

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
