// Dragnet [Ransomware]: dragnet-ransomware-2024-2164 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: ff9851ca-fede-55bd-9e7e-cac9df8ac00b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
