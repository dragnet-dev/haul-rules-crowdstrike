// Dragnet [Ransomware]: dragnet-ransomware-2025-0622 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: 13e76581-98d3-5095-bafd-d7a587a433b0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
