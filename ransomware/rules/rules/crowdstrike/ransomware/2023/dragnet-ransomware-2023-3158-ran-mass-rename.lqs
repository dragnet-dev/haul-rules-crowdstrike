// Dragnet [Ransomware]: dragnet-ransomware-2023-3158 — Mass File Rename (coinbasecartel)
// Status: experimental | Level: high | ID: 72113a5d-7930-5624-bbef-7d7cabcb2273

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
