// Dragnet [Ransomware]: dragnet-ransomware-2026-3285 — Mass File Rename (BrainCipher)
// Status: stable | Level: high | ID: c457b486-ad26-5cb1-a600-0ab9bfe4c1a4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
