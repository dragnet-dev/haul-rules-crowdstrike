// Dragnet [Ransomware]: dragnet-ransomware-2024-1866 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: be02015d-b42e-5a1a-b276-a19c0e695ca6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
