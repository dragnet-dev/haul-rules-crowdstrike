// Dragnet [Ransomware]: dragnet-ransomware-2024-1357 — Mass File Rename (dragonforce)
// Status: deprecated | Level: high | ID: 8e17c551-1b28-5a75-a970-1b9719e23c26

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
