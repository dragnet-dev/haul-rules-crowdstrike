// Dragnet [Ransomware]: dragnet-ransomware-2025-2802 — Mass File Rename (warlock)
// Status: deprecated | Level: high | ID: 9e106040-933e-59f0-9dd3-ec97f9e9b540

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
