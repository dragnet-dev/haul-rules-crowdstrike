// Dragnet [Ransomware]: dragnet-ransomware-2023-4048 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 4e844053-3c7f-5867-8fc4-80b3076b8200

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
