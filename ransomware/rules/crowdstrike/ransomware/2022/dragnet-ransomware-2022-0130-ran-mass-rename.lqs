// Dragnet [Ransomware]: dragnet-ransomware-2022-0130 — Mass File Rename (pandora)
// Status: deprecated | Level: high | ID: 73175a02-c6ee-555a-ad98-25477ee86633

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
