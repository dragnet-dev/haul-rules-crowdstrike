// Dragnet [Ransomware]: dragnet-ransomware-2024-0404 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 9a9a0b5b-a726-58f9-8fcf-79739e06263d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
