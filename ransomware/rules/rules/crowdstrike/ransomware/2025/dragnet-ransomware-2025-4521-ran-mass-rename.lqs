// Dragnet [Ransomware]: dragnet-ransomware-2025-4521 — Mass File Rename (play)
// Status: experimental | Level: high | ID: f60ae4da-a0ec-5c21-af03-6744eb170bf6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
