// Dragnet [Ransomware]: dragnet-ransomware-2022-0267 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: a6371ded-e697-5705-9ae1-2b2e97ecb311

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
