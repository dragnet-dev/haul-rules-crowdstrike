// Dragnet [Ransomware]: dragnet-ransomware-2023-4719 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 97a57d5a-87d7-56a8-a718-421b1ff0fce1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
