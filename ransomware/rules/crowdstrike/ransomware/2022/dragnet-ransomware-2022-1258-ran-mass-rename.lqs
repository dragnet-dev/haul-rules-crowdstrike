// Dragnet [Ransomware]: dragnet-ransomware-2022-1258 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 3ae6f3e0-9a4f-555d-9f26-6fc607b85e1c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
