// Dragnet [Ransomware]: dragnet-ransomware-2022-2924 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 846a4965-ac74-5479-9229-8647e924db12

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
