// Dragnet [Ransomware]: dragnet-ransomware-2026-2769 — Mass File Rename (lockbit5)
// Status: stable | Level: high | ID: 3f7bbec8-ab70-5c36-af10-f81a35502a50

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
