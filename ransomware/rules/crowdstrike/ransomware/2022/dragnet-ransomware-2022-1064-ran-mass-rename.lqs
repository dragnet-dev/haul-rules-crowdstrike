// Dragnet [Ransomware]: dragnet-ransomware-2022-1064 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 7c9cb30e-2ca1-555d-94f8-6f3737d6147e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
