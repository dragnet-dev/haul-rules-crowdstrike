// Dragnet [Ransomware]: dragnet-ransomware-2023-1520 — Mass File Rename (darkrace)
// Status: experimental | Level: high | ID: f03fb457-8193-5077-bcea-2641e4887014

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
