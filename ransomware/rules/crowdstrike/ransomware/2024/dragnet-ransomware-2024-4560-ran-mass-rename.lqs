// Dragnet [Ransomware]: dragnet-ransomware-2024-4560 — Mass File Rename (meow)
// Status: experimental | Level: high | ID: 8f03c5a6-a1a9-5c77-b243-71771b73e691

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
