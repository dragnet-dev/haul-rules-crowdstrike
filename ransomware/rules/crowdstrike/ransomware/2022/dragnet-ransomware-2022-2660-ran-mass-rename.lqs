// Dragnet [Ransomware]: dragnet-ransomware-2022-2660 — Mass File Rename (alphv)
// Status: deprecated | Level: high | ID: e22c600d-81aa-58b6-80a4-3b6b2e693723

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
