// Dragnet [Ransomware]: dragnet-ransomware-2024-4765 — Mass File Rename (threeam)
// Status: experimental | Level: high | ID: f03b936d-356d-5daa-a811-970ce5cf72aa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
