// Dragnet [Ransomware]: dragnet-ransomware-2022-1853 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 04e639bf-cc07-515d-837e-c58cb4d1db04

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
