// Dragnet [Ransomware]: dragnet-ransomware-2026-3414 — Mass File Rename (incransom)
// Status: test | Level: high | ID: 4fbd5b16-c755-5277-9409-746d9be71532

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
