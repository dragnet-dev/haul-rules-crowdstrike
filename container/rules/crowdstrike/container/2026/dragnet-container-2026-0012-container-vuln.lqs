// Dragnet [Container]: dragnet-container-2026-0012 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 07d5b847-af3b-5638-b9ed-26c07579dc7a

#event_simpleName=*
| (ImageFileName = *chainguard:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
