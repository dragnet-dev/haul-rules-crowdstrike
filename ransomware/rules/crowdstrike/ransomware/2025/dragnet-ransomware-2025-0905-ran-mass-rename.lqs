// Dragnet [Ransomware]: dragnet-ransomware-2025-0905 — Mass File Rename (spacebears)
// Status: test | Level: high | ID: 0c4ae65c-245c-524f-ae19-b65bbde85ec2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
