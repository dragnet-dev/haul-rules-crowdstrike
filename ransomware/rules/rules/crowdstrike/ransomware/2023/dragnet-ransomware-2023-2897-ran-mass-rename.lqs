// Dragnet [Ransomware]: dragnet-ransomware-2023-2897 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: f1e6bd58-6f31-59a8-86fc-c2c5786117c6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
