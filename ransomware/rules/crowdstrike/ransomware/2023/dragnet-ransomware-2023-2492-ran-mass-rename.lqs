// Dragnet [Ransomware]: dragnet-ransomware-2023-2492 — Mass File Rename (mallox)
// Status: deprecated | Level: high | ID: c8c5bfa6-32d9-536d-bd34-348749e08655

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
