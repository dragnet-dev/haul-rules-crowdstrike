// Dragnet [Ransomware]: dragnet-ransomware-2021-0086 — Mass File Rename (midas)
// Status: deprecated | Level: high | ID: 33488349-5c83-581d-98ed-afb69f580672

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
