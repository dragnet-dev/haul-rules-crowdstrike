// Dragnet [Ransomware]: dragnet-ransomware-2024-5716 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: a8a93c66-d9de-5017-8b72-52988be57489

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
