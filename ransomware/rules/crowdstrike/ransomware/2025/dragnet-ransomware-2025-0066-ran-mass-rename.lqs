// Dragnet [Ransomware]: dragnet-ransomware-2025-0066 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: ddad0b6b-38c7-5a30-ae95-90bca50d0e53

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
