// Dragnet [Ransomware]: dragnet-ransomware-2022-0597 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: c8d93b41-43cc-58fc-b964-062a70c78f7b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
