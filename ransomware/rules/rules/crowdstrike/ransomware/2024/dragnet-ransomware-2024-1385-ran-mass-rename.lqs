// Dragnet [Ransomware]: dragnet-ransomware-2024-1385 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 8de687f1-a3b0-5560-9a66-6f241a97e635

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
