// Dragnet [Ransomware]: dragnet-ransomware-2025-4691 — Mass File Rename (qilin)
// Status: deprecated | Level: high | ID: 7f0734e4-9e2b-5ec3-ab7f-f08338bbdbc5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
