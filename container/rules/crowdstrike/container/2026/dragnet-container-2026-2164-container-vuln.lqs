// Dragnet [Container]: dragnet-container-2026-2164 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 65a1fbb0-a645-5a2b-b335-c32d96a6a749

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:5*)
| table([timestamp, ComputerName])
| limit(1000)
