// Dragnet [Ransomware]: dragnet-ransomware-2025-5516 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 7f58c5e7-675f-5b28-9021-344c0f795d84

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
