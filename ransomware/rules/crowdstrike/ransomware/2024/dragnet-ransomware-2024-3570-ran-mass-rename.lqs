// Dragnet [Ransomware]: dragnet-ransomware-2024-3570 — Mass File Rename (darkvault)
// Status: experimental | Level: high | ID: 223c0db1-ea98-5aec-b5ed-981271fba66c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
