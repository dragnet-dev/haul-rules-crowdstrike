// Dragnet [Ransomware]: dragnet-ransomware-2025-3509 — Mass File Rename (warlock)
// Status: deprecated | Level: high | ID: fc323eee-92ce-5d67-9b12-ef5b5bcc2757

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
