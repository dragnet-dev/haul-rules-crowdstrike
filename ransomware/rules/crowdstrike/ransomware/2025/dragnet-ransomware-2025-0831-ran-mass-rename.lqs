// Dragnet [Ransomware]: dragnet-ransomware-2025-0831 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 730577b6-4962-5db3-801e-0ccfdb70ae12

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
