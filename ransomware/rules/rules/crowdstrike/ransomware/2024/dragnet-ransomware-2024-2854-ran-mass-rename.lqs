// Dragnet [Ransomware]: dragnet-ransomware-2024-2854 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 83271ad6-40f6-5588-9a3d-349fd3026e2f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
