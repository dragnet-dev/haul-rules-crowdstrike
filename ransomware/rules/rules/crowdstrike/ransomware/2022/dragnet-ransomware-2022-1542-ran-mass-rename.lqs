// Dragnet [Ransomware]: dragnet-ransomware-2022-1542 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 3e59226a-1f6a-54b8-8b52-a77f7e120e58

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
