// Dragnet [Ransomware]: dragnet-ransomware-2024-5645 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 56dc9645-db38-5603-a4a2-6e2280b0cdf4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
