// Dragnet [Ransomware]: dragnet-ransomware-2020-0133 — Mass File Rename (netwalker)
// Status: deprecated | Level: high | ID: f8b890a4-eb8a-55ed-b935-b9bce64d3138

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
