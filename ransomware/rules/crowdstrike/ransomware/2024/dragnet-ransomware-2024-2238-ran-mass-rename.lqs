// Dragnet [Ransomware]: dragnet-ransomware-2024-2238 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 4958e192-39dc-59c5-9a7f-f4a15d4df423

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
