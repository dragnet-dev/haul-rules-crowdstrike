// Dragnet [Ransomware]: dragnet-ransomware-2024-2133 — Mass File Rename (raworld)
// Status: experimental | Level: high | ID: 39b84a11-8558-587a-b67f-1bdb0e34bcf1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
