// Dragnet [Ransomware]: dragnet-ransomware-2023-1159 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: b42464b8-b641-556e-996b-83a26a972d69

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
