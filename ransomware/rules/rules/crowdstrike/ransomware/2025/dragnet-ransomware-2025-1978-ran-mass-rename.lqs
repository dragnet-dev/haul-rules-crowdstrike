// Dragnet [Ransomware]: dragnet-ransomware-2025-1978 — Mass File Rename (blacklock)
// Status: experimental | Level: high | ID: 51d6ddde-a4f0-59f7-9aaf-91849c016059

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
