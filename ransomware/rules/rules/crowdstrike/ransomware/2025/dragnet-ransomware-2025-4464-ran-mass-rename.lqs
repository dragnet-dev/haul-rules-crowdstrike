// Dragnet [Ransomware]: dragnet-ransomware-2025-4464 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: af9a9d54-198c-5220-8f4f-9513a4b19204

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
