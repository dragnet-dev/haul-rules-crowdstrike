// Dragnet [Ransomware]: dragnet-ransomware-2021-0649 — Mass File Rename (ragnarok)
// Status: deprecated | Level: high | ID: dac8228c-4943-5465-b78d-35fd4306343a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
