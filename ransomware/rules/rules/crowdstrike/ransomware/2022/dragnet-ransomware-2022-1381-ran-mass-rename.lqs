// Dragnet [Ransomware]: dragnet-ransomware-2022-1381 — Mass File Rename (avoslocker)
// Status: deprecated | Level: high | ID: eb749596-9402-55cb-ad26-77f7a576c8e2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
