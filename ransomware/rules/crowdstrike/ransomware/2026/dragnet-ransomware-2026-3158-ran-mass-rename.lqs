// Dragnet [Ransomware]: dragnet-ransomware-2026-3158 — Mass File Rename (sinobi)
// Status: stable | Level: high | ID: 5f683b5c-e942-5183-8c7b-1e4b5404a137

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
