// Dragnet [Ransomware]: dragnet-ransomware-2024-4282 — Mass File Rename (trigona)
// Status: experimental | Level: high | ID: 9c8b4754-96fb-57be-b609-f8efe54f535f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
