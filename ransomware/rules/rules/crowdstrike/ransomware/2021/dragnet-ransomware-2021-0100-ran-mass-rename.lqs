// Dragnet [Ransomware]: dragnet-ransomware-2021-0100 — Mass File Rename (everest)
// Status: deprecated | Level: high | ID: aa60e443-7526-5e83-a250-69e0d2628dc4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
