// Dragnet [Ransomware]: dragnet-ransomware-2024-3640 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 57467667-b501-5808-8d48-48889cd03e27

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
