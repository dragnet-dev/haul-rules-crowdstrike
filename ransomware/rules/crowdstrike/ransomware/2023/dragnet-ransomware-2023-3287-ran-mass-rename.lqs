// Dragnet [Ransomware]: dragnet-ransomware-2023-3287 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 5359ff38-4f6f-51cf-93de-85181dd68a6d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
