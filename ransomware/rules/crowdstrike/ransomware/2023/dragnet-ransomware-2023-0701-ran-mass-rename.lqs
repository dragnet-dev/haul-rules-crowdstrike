// Dragnet [Ransomware]: dragnet-ransomware-2023-0701 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: f41c393f-a260-5bd6-b9d2-d3d5c877b582

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
