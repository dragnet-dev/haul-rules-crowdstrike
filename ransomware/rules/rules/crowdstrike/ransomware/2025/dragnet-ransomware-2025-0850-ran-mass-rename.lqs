// Dragnet [Ransomware]: dragnet-ransomware-2025-0850 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 7c16e16d-3b12-5451-8dd3-659bb19d5caa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
