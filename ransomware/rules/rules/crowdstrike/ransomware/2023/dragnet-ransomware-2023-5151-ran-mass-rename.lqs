// Dragnet [Ransomware]: dragnet-ransomware-2023-5151 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 22768fae-f8b5-5e7f-bcbb-f66568abc5c2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
