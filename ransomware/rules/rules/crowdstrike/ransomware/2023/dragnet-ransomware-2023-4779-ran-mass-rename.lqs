// Dragnet [Ransomware]: dragnet-ransomware-2023-4779 — Mass File Rename (raworld)
// Status: experimental | Level: high | ID: 33f5d9a0-efe2-565e-963f-9fd8a98ed5b4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
