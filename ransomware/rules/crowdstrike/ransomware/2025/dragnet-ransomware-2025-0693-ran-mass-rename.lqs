// Dragnet [Ransomware]: dragnet-ransomware-2025-0693 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 1e496924-bb6e-5015-ae5a-11087811c84a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
