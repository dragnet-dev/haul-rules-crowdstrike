// Dragnet [Ransomware]: dragnet-ransomware-2023-3205 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: e1615450-f854-55e0-b1a7-56b0ee1a49e7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
