// Dragnet [Ransomware]: dragnet-ransomware-2023-3358 — Mass File Rename (noescape)
// Status: experimental | Level: high | ID: 717b453a-cd09-5647-8ebf-95b2e0757f62

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
