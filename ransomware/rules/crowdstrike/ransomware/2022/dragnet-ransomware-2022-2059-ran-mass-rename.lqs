// Dragnet [Ransomware]: dragnet-ransomware-2022-2059 — Mass File Rename (ransomhouse)
// Status: deprecated | Level: high | ID: d6742cf2-0161-5d06-81c7-89907427b435

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
