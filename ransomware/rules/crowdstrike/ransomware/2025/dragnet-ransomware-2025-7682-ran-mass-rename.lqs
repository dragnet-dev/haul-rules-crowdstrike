// Dragnet [Ransomware]: dragnet-ransomware-2025-7682 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 3695f430-d040-5683-9485-dafec10de83a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
