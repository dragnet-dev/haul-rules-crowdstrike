// Dragnet [Ransomware]: dragnet-ransomware-2025-7134 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 4dcf7c45-4626-53ea-811c-17d7a397dbc4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
