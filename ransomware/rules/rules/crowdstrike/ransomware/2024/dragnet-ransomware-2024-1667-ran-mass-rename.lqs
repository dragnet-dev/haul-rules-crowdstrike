// Dragnet [Ransomware]: dragnet-ransomware-2024-1667 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 776379e2-2cf1-5143-af4e-734629fd095a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
