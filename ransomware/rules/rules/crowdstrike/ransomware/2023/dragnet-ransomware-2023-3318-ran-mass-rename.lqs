// Dragnet [Ransomware]: dragnet-ransomware-2023-3318 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 4ea56408-c521-58bd-8c7b-2e4279a05447

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
