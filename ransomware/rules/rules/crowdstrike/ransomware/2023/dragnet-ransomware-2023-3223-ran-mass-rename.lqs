// Dragnet [Ransomware]: dragnet-ransomware-2023-3223 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 81b6e4d8-d805-5632-a62a-7a9417935ecc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
