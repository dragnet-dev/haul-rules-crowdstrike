// Dragnet [Ransomware]: dragnet-ransomware-2025-0945 — Mass File Rename (SilentRansomGroup)
// Status: deprecated | Level: high | ID: 72a5e92d-e5c7-5745-926e-029d61a1a346

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
