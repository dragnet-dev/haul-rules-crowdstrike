// Dragnet [Ransomware]: dragnet-ransomware-2025-4543 — Mass File Rename (rhysida)
// Status: deprecated | Level: high | ID: 6f00afc5-7c22-55df-93da-690dfd95cf57

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
