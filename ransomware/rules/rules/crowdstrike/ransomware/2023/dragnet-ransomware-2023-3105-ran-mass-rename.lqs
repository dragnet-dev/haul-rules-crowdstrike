// Dragnet [Ransomware]: dragnet-ransomware-2023-3105 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 2ccb222c-0f70-557b-8047-72b8ceeebe37

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
