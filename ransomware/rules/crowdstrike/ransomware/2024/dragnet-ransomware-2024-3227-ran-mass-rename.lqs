// Dragnet [Ransomware]: dragnet-ransomware-2024-3227 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: e406cf92-c526-5a88-849e-cd0196c78ec7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
