// Dragnet [Ransomware]: dragnet-ransomware-2023-0541 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 95b831ae-2e6c-58da-b87b-11079e6e4c52

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
