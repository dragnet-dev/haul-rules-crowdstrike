// Dragnet [Ransomware]: dragnet-ransomware-2023-4679 — Mass File Rename (karakurt)
// Status: experimental | Level: high | ID: 4f34dc8f-d8be-5260-962b-634e5afc751c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
