// Dragnet [Ransomware]: dragnet-ransomware-2024-3212 — Mass File Rename (knight)
// Status: experimental | Level: high | ID: bc9771f1-0c6c-542b-8018-d6326c644d13

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
