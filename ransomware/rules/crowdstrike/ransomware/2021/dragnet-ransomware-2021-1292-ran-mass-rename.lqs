// Dragnet [Ransomware]: dragnet-ransomware-2021-1292 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: c089f131-909e-5d22-86cd-4820bcaabec1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
