// Dragnet [Ransomware]: dragnet-ransomware-2024-5450 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 5b53a9be-ec23-54ef-9cc1-1f125afea9ff

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
