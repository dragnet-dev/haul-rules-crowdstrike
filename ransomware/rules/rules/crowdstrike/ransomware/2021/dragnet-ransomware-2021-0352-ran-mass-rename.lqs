// Dragnet [Ransomware]: dragnet-ransomware-2021-0352 — Mass File Rename (revil)
// Status: deprecated | Level: high | ID: 1d6bff68-192e-5a30-963a-86ddc13d947a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
