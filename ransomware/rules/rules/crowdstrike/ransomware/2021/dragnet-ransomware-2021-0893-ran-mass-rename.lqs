// Dragnet [Ransomware]: dragnet-ransomware-2021-0893 — Mass File Rename (rook)
// Status: deprecated | Level: high | ID: ed84dbd8-4d50-5e81-b946-665b8994d864

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
