// Dragnet [Ransomware]: dragnet-ransomware-2023-3514 — Mass File Rename (apt73)
// Status: experimental | Level: high | ID: d781d428-6a32-54bb-b1e9-d5cf61685788

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
