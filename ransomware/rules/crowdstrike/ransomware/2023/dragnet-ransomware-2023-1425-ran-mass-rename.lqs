// Dragnet [Ransomware]: dragnet-ransomware-2023-1425 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: a8bc1574-03a6-5cb6-8d63-f5085e392995

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
