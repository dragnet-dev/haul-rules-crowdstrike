// Dragnet [Ransomware]: dragnet-ransomware-2024-5451 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 65296a66-b936-5290-9650-110c9b6b2eb7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
