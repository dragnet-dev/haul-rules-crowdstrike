// Dragnet [Ransomware]: dragnet-ransomware-2023-4424 — Mass File Rename (vendetta)
// Status: deprecated | Level: high | ID: cc239c83-77f9-5cf4-bb66-0fe2dcd1ae1a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
