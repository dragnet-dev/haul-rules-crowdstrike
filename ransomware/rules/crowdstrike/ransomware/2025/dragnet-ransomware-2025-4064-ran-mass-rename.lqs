// Dragnet [Ransomware]: dragnet-ransomware-2025-4064 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 835e3d5e-ff0c-5cd7-a618-ae54aa27e74d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
