// Dragnet [Ransomware]: dragnet-ransomware-2023-3023 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: aaafd84e-65ae-5f14-8594-3418ade1578b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
