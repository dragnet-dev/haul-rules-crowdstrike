// Dragnet [Ransomware]: dragnet-ransomware-2023-2667 — Mass File Rename (abyss)
// Status: deprecated | Level: high | ID: 82f63678-350e-56ab-95ab-9989e57a0724

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
