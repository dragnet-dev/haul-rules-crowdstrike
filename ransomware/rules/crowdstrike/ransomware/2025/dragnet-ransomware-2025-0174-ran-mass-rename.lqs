// Dragnet [Ransomware]: dragnet-ransomware-2025-0174 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 8c18d266-57c9-5ab9-8ffb-8a5d46602315

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
