// Dragnet [Ransomware]: dragnet-ransomware-2024-2192 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: ec60b350-aa2a-5d50-9cb7-5b9a5427ec77

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
