// Dragnet [Ransomware]: dragnet-ransomware-2023-0655 — Mass File Rename (raworld)
// Status: experimental | Level: high | ID: 476b5a08-c00a-542b-a5ab-503f11bdaeee

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
