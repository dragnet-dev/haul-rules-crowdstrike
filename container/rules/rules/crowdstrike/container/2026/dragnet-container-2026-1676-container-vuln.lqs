// Dragnet [Container]: dragnet-container-2026-1676 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 52ac3977-3fe4-5f67-b1fa-67b882ca8018

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:8* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:14.04* OR ImageFileName = *ubuntu:14.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
