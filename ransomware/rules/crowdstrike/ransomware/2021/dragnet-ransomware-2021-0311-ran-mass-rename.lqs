// Dragnet [Ransomware]: dragnet-ransomware-2021-0311 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 41c66073-6e33-5487-8ed9-9c157326dc7c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
