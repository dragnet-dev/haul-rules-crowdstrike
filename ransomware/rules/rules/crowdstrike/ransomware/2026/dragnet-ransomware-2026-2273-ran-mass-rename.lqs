// Dragnet [Ransomware]: dragnet-ransomware-2026-2273 — Mass File Rename (lockbit5)
// Status: stable | Level: high | ID: f2799293-81fe-5d63-b1d9-5542235c46ae

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
