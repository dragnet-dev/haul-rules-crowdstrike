// Dragnet [Ransomware]: dragnet-ransomware-2023-1360 — Mass File Rename (ciphbit)
// Status: deprecated | Level: high | ID: 702eaa2b-f3ff-5c0f-be76-1895365c1567

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
