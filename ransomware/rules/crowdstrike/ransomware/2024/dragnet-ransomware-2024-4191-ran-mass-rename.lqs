// Dragnet [Ransomware]: dragnet-ransomware-2024-4191 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: b91f5838-1dd4-5e7e-b4db-6ed1c7dab81e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
