// Dragnet [Ransomware]: dragnet-ransomware-2023-0359 — Mass File Rename (nokoyawa)
// Status: experimental | Level: high | ID: 62a400b0-4143-51cc-82d2-e515fea156da

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
