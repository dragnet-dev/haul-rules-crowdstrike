// Dragnet [Ransomware]: dragnet-ransomware-2025-1356 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 71180ee7-22ff-5c27-9f66-72a1f1d2ebf0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
