// Dragnet [Ransomware]: dragnet-ransomware-2021-1573 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 6edb05f6-9f41-51a1-b02b-e1d73db9950a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
