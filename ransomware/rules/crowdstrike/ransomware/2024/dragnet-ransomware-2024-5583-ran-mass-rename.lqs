// Dragnet [Ransomware]: dragnet-ransomware-2024-5583 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 80c69f39-4804-5906-a9f4-32e6e9142eea

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
