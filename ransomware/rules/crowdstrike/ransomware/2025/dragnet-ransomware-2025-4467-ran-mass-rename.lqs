// Dragnet [Ransomware]: dragnet-ransomware-2025-4467 — Mass File Rename (crazyhunter)
// Status: experimental | Level: high | ID: 1e572e4f-f580-53c8-a6b1-994b6a3e11cd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
