// Dragnet [Ransomware]: dragnet-ransomware-2025-0814 — Mass File Rename (J)
// Status: experimental | Level: high | ID: eb7bb38f-20d0-53ed-9634-5ecfb5b3898c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
