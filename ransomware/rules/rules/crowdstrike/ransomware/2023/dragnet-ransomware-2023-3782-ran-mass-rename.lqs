// Dragnet [Ransomware]: dragnet-ransomware-2023-3782 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 5722b901-67d8-5751-8ab6-d95e5702f698

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
