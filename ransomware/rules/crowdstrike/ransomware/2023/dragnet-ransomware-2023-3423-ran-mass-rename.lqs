// Dragnet [Ransomware]: dragnet-ransomware-2023-3423 — Mass File Rename (ragnarlocker)
// Status: experimental | Level: high | ID: aa524057-df70-5af5-baa9-ca09c05c1c4d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
