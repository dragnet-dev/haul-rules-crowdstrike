// Dragnet [Ransomware]: dragnet-ransomware-2024-5530 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 067f1d59-fa7b-5b2e-ab91-ba982ce03c9f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
