// Dragnet [Ransomware]: dragnet-ransomware-2025-7351 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 6cdd0b15-6a0c-5772-8983-ccb5c2fe6e9a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
