// Dragnet [Ransomware]: dragnet-ransomware-2025-6505 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 704a28f6-169d-50eb-8626-5b5ccf0cd8eb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
