// Dragnet [Ransomware]: dragnet-ransomware-2025-4211 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 1256f1a0-0564-5602-8903-23bc664378e6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
