// Dragnet [Container]: dragnet-container-2026-0741 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: e1bedf98-b43a-5a9b-99e1-6cafc0cb90ae

#event_simpleName=*
| (ImageFileName = *amazonlinux:1* OR ImageFileName = *debian:7* OR ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *oraclelinux:7* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:14.04* OR ImageFileName = *ubuntu:14.10*)
| table([timestamp, ComputerName])
| limit(1000)
