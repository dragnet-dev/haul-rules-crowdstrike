// Dragnet [Ransomware]: dragnet-ransomware-2025-6441 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 5cc4e6ca-2864-5893-8814-81a47a6e49e5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
