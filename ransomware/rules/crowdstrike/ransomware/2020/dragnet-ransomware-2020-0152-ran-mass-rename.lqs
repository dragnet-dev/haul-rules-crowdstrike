// Dragnet [Ransomware]: dragnet-ransomware-2020-0152 — Mass File Rename (ragnarlocker)
// Status: deprecated | Level: high | ID: 8fa1813d-e5b8-539f-9ee4-452457dd066c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
