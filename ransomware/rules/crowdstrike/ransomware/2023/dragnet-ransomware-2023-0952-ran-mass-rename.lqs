// Dragnet [Ransomware]: dragnet-ransomware-2023-0952 — Mass File Rename (medusalocker)
// Status: experimental | Level: high | ID: 05632e7e-9729-5c0f-82b2-2ad00b0a242b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
