// Dragnet [Ransomware]: dragnet-ransomware-2024-0642 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 80da38a7-2259-51c3-8067-4d8062b3c64c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
