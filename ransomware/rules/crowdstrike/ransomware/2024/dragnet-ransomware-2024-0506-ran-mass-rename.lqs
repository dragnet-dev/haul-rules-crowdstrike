// Dragnet [Ransomware]: dragnet-ransomware-2024-0506 — Mass File Rename (snatch)
// Status: experimental | Level: high | ID: fdbf555b-4fda-5f6e-925c-39fbcd2c6df1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
