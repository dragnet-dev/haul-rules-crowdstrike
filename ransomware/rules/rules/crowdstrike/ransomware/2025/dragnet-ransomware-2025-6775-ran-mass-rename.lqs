// Dragnet [Ransomware]: dragnet-ransomware-2025-6775 — Mass File Rename (kraken)
// Status: experimental | Level: high | ID: 0f7d1fc6-e0bf-5631-bb93-0463b0978700

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
