// Dragnet [Ransomware]: dragnet-ransomware-2024-5498 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 0ad55fee-9128-56dd-a2f8-11080bb222e1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
