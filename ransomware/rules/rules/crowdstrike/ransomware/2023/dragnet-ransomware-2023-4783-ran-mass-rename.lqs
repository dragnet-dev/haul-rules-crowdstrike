// Dragnet [Ransomware]: dragnet-ransomware-2023-4783 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: f238d008-6a2d-5dfb-b553-dd621ad27a2c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
