// Dragnet [Ransomware]: dragnet-ransomware-2023-0710 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: 6d1fbca5-15ff-5d4e-8bc3-ebf3349bd156

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
