// Dragnet [Ransomware]: dragnet-ransomware-2024-5400 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 100ba0ce-4e3f-5100-9367-ee7f399a4204

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
