// Dragnet [Ransomware]: dragnet-ransomware-2022-0888 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: a474f08a-1013-592f-93be-35e029e2e06f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
