// Dragnet [Ransomware]: dragnet-ransomware-2025-0079 — Mass File Rename (nightspire)
// Status: deprecated | Level: high | ID: 861acd3d-84f4-52f9-88e1-facde83b8222

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
