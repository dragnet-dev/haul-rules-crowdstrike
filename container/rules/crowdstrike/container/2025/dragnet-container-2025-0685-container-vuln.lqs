// Dragnet [Container]: dragnet-container-2025-0685 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 9c97b1a3-9240-5869-9bff-60f1a92fe917

#event_simpleName=*
| (ImageFileName = *chainguard:* OR ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *ubuntu:20.04* OR ImageFileName = *ubuntu:20.04-ESM* OR ImageFileName = *ubuntu:21.10* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
