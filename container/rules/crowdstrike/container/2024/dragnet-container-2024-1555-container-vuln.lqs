// Dragnet [Container]: dragnet-container-2024-1555 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: c0e1a430-0fcf-5648-ad3b-5920005553da

#event_simpleName=*
| (ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *ubuntu:22.04*)
| table([timestamp, ComputerName])
| limit(1000)
