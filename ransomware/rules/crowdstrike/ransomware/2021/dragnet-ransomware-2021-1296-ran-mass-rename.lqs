// Dragnet [Ransomware]: dragnet-ransomware-2021-1296 — Mass File Rename (mountlocker)
// Status: deprecated | Level: high | ID: 18d79353-0e4c-5c43-83b0-4c3e2d4ec88d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
