// Dragnet [Ransomware]: dragnet-ransomware-2024-2370 — Mass File Rename (handala)
// Status: experimental | Level: high | ID: 4564e4d5-ed07-5f19-ac38-b83b2eeeb9f0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
