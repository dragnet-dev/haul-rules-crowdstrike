// Dragnet [Container]: dragnet-container-2026-1008 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 0793e07b-d666-569b-8621-3198aad05447

#event_simpleName=*
| (ImageFileName = *alpine:3.6* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:7* OR ImageFileName = *debian:8* OR ImageFileName = *ubuntu:14.04* OR ImageFileName = *ubuntu:16.04* OR ImageFileName = *ubuntu:16.04-ESM* OR ImageFileName = *ubuntu:16.10* OR ImageFileName = *ubuntu:17.04*)
| table([timestamp, ComputerName])
| limit(1000)
