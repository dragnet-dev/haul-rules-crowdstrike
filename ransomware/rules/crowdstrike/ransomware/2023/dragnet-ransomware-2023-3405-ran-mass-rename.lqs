// Dragnet [Ransomware]: dragnet-ransomware-2023-3405 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 43ba2a53-4cc2-522a-9d93-d76aee84e9ca

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
