// Dragnet [Ransomware]: dragnet-ransomware-2023-1794 — Mass File Rename (cactus)
// Status: deprecated | Level: high | ID: e3ab137f-2e5d-5821-9699-b6f038b47bdd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
