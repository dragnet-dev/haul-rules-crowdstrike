// Dragnet [Ransomware]: dragnet-ransomware-2025-0561 — Mass File Rename (coinbasecartel)
// Status: test | Level: high | ID: 1daded5d-4694-5ac7-9f4d-c8e51696ac2f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
