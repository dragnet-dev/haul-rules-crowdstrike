// Dragnet [Ransomware]: dragnet-ransomware-2024-4440 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 3fdb3ce0-d552-5c03-af0f-ada1590141e5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
