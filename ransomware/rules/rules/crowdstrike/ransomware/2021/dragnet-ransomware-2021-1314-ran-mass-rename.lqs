// Dragnet [Ransomware]: dragnet-ransomware-2021-1314 — Mass File Rename (avaddon)
// Status: deprecated | Level: high | ID: 266a130a-c144-5062-b45a-e5a8bbd2a0d0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
