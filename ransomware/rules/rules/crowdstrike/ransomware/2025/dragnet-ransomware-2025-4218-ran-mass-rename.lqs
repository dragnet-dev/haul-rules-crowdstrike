// Dragnet [Ransomware]: dragnet-ransomware-2025-4218 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 498d3e76-4a6a-5dc4-85e3-8550e9e89f66

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
