// Dragnet [Ransomware]: dragnet-ransomware-2024-3317 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: ef35cf9e-3402-5e6f-93d4-165daea0e9a0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
