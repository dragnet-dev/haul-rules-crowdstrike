// Dragnet [Ransomware]: dragnet-ransomware-2025-2311 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 30bb72bc-724a-545f-89c4-20038cc4a3c9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
