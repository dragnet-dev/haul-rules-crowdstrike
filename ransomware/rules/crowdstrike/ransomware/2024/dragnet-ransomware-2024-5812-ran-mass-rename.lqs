// Dragnet [Ransomware]: dragnet-ransomware-2024-5812 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: abb3047f-7c92-5676-b91c-cd5c1767385c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
