// Dragnet [Ransomware]: dragnet-ransomware-2022-0575 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 033939ce-e071-5094-8eb9-36b6e27a3766

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
