// Dragnet [Container]: dragnet-container-2024-0288 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 9d626e6e-2f81-5e89-b336-b6878c40286a

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:8* OR ImageFileName = *debian:9* OR ImageFileName = *ubuntu:18.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
