// Dragnet [Ransomware]: dragnet-ransomware-2025-1414 — Mass File Rename (handala)
// Status: experimental | Level: high | ID: b46b2bbc-85f2-561e-bc40-3b9711c5dc63

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
