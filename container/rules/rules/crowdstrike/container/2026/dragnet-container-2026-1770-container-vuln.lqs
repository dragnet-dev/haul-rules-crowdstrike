// Dragnet [Container]: dragnet-container-2026-1770 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 180d108e-66d2-5566-a2c0-817a7632a9f3

#event_simpleName=*
| (ImageFileName = *alpine:3.23* OR ImageFileName = *alpine edge:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
