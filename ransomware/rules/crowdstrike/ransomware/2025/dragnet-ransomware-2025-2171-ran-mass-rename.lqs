// Dragnet [Ransomware]: dragnet-ransomware-2025-2171 — Mass File Rename (cloak)
// Status: deprecated | Level: high | ID: 923e1bc5-cd5e-5ce8-a946-69b7d649f6f0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
