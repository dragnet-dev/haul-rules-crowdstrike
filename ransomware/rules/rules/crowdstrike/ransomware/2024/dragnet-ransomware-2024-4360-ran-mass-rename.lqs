// Dragnet [Ransomware]: dragnet-ransomware-2024-4360 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: f28bbf69-3323-5ecc-8735-7a00be240cbb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
