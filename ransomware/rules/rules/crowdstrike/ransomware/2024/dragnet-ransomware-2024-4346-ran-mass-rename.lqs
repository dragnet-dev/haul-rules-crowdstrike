// Dragnet [Ransomware]: dragnet-ransomware-2024-4346 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 568ae1d0-f689-5058-b972-7f64975f9a60

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
