// Dragnet [Ransomware]: dragnet-ransomware-2025-3548 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 624e20a8-5dbf-5aec-9dcb-47a33d423cee

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
