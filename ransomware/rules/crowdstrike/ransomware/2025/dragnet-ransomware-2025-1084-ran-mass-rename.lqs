// Dragnet [Ransomware]: dragnet-ransomware-2025-1084 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: bc7bcf2b-f221-5f96-9102-410a79d10520

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
