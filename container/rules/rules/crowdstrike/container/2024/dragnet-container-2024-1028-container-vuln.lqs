// Dragnet [Container]: dragnet-container-2024-1028 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: cdd02d6c-aa77-5058-94b1-c358d43daf22

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
