// Dragnet [Ransomware]: dragnet-ransomware-2025-0306 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: d43fc5fd-1198-5091-909c-b6a55d5f3241

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
