// Dragnet [Ransomware]: dragnet-ransomware-2025-1399 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 6fcd9af0-3093-53f3-bcd2-fe33163edcf8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
