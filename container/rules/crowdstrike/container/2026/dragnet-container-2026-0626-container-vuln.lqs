// Dragnet [Container]: dragnet-container-2026-0626 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 248e7b1c-8ba8-5002-9e85-3679f2870785

#event_simpleName=*
| (ImageFileName = *amazonlinux:1* OR ImageFileName = *chainguard:* OR ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *photon os:4.0* OR ImageFileName = *ubuntu:12.04*)
| table([timestamp, ComputerName])
| limit(1000)
