| (ImageFileName = *alpine:3.2* OR ImageFileName = *alpine:3.3* OR ImageFileName = *alpine:3.4* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:8* OR ImageFileName = *ubuntu:14.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
