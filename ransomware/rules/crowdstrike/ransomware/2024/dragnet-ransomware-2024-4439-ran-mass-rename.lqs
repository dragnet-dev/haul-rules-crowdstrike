// Dragnet [Ransomware]: dragnet-ransomware-2024-4439 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: 7aa94c15-4440-54db-92f6-12c313d19bef

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
