// Dragnet [Container]: dragnet-container-2024-1517 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 911288ee-b2a3-5d16-bbea-eadfcfade622

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
