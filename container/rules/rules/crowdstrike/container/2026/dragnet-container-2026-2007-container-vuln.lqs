// Dragnet [Container]: dragnet-container-2026-2007 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 55b5508f-a1f9-56eb-8364-85331eb42c5b

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
