// Dragnet [Container]: dragnet-container-2026-2691 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 9461e292-5b0f-550d-aec3-ef2c87759916

#event_simpleName=*
| (ImageFileName = *azure linux:3.0* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *photon os:4.0* OR ImageFileName = *photon os:5.0* OR ImageFileName = *redhat/ubi9:*)
| table([timestamp, ComputerName])
| limit(1000)
