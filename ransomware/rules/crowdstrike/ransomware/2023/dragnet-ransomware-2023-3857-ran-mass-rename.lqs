// Dragnet [Ransomware]: dragnet-ransomware-2023-3857 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: e46fbf25-e8da-50f4-a239-42d196e6c88f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
