// Dragnet [Ransomware]: dragnet-ransomware-2024-3729 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 57d1226f-b708-541e-a688-c6eb17a52c53

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
