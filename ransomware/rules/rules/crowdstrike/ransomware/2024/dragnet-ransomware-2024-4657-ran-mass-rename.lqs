// Dragnet [Ransomware]: dragnet-ransomware-2024-4657 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 239d7eaf-92fa-5adf-9975-0c86c3d3f9e4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
