// Dragnet [Ransomware]: dragnet-ransomware-2026-0896 — Mass File Rename (safepay)
// Status: stable | Level: high | ID: 8bb5ba0c-acc6-50bf-91ea-008d38e9e90d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
