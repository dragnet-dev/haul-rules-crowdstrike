// Dragnet [Container]: dragnet-container-2026-0948 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 71576cb3-0bb6-54dc-af5c-c377df03d423

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:5*)
| table([timestamp, ComputerName])
| limit(1000)
