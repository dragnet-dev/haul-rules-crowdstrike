// Dragnet [Ransomware]: dragnet-ransomware-2023-4972 — Mass File Rename (dunghill)
// Status: experimental | Level: high | ID: 189f10fb-6bb2-5302-9e8e-23e610b1ea21

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
