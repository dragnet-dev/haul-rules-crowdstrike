// Dragnet [Ransomware]: dragnet-ransomware-2024-4922 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 807bdeeb-12ba-550b-8d0f-c43de183de08

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
