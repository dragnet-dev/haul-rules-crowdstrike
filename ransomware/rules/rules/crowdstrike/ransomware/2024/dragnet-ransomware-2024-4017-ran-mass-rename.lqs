// Dragnet [Ransomware]: dragnet-ransomware-2024-4017 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: 66466e00-a413-5caa-99b5-d8c5c72963e7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
