// Dragnet [Ransomware]: dragnet-ransomware-2024-4693 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 64fc30a4-8224-5f52-b9ef-342faf99dcb6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
