// Dragnet [Ransomware]: dragnet-ransomware-2024-1484 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: 7dc1c40d-f536-53b5-b31a-30843ff064b4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
