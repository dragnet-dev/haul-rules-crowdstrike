// Dragnet [Ransomware]: dragnet-ransomware-2023-0458 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: d2d86f71-9931-5f99-bc55-f311b6bf8f86

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
