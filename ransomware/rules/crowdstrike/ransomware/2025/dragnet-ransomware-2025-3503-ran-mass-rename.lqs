// Dragnet [Ransomware]: dragnet-ransomware-2025-3503 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: f70509b5-c107-5f83-8f13-17e1078660cc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
