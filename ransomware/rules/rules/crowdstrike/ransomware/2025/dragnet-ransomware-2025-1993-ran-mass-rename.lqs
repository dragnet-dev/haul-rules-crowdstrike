// Dragnet [Ransomware]: dragnet-ransomware-2025-1993 — Mass File Rename (crypto24)
// Status: deprecated | Level: high | ID: 090aca12-a764-58e1-9822-984437eb6904

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
