// Dragnet [Ransomware]: dragnet-ransomware-2021-1371 — Mass File Rename (revil)
// Status: deprecated | Level: high | ID: 379e1980-c045-5fab-9cbe-1109fe086c87

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
