// Dragnet [Ransomware]: dragnet-ransomware-2024-4906 — Mass File Rename (meow)
// Status: experimental | Level: high | ID: c28b5f5a-278b-5dde-b3f9-9b4eb07a2cad

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
