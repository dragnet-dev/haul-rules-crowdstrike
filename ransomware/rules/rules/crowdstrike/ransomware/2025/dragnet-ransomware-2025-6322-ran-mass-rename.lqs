// Dragnet [Ransomware]: dragnet-ransomware-2025-6322 — Mass File Rename (kawa4096)
// Status: deprecated | Level: high | ID: 5a5aa037-5f63-5ce6-b0a8-f52c1b30cbc8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
