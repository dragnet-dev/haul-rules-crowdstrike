// Dragnet [Ransomware]: dragnet-ransomware-2023-4330 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 1a8951b4-2701-525b-8171-de8ea1fb6dff

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
