// Dragnet [Ransomware]: dragnet-ransomware-2024-4644 — Mass File Rename (blacklock)
// Status: experimental | Level: high | ID: e664a8c2-3e17-5a50-938e-def99d60ef21

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
