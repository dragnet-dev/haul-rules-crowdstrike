// Dragnet [Ransomware]: dragnet-ransomware-2023-3494 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 1ab8b371-0ddc-5fa5-87f9-5906b65f19bb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
