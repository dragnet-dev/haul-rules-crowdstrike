// Dragnet [Ransomware]: dragnet-ransomware-2025-4348 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: a4509e18-17d1-5e8a-9f88-14a4a5b806b5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
