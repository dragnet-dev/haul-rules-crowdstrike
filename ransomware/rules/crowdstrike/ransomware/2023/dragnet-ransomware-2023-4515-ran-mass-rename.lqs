// Dragnet [Ransomware]: dragnet-ransomware-2023-4515 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: e782887f-6070-5a16-a806-a6adc8c37a78

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
