// Dragnet [Ransomware]: dragnet-ransomware-2022-0523 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: bbf6aa3e-7cf9-5171-8dba-1a4a8f65061c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
