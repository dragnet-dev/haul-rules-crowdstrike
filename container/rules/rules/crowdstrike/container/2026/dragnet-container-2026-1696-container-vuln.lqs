// Dragnet [Container]: dragnet-container-2026-1696 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: dd7b7643-57e2-5a0d-9475-1153e56d6043

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:7* OR ImageFileName = *debian:8* OR ImageFileName = *ubuntu:14.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
