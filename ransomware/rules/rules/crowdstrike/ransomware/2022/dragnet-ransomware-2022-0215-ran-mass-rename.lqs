// Dragnet [Ransomware]: dragnet-ransomware-2022-0215 — Mass File Rename (royal)
// Status: deprecated | Level: high | ID: 19221f2b-2c10-5bb6-97ea-9a9093e544cf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
