// Dragnet [Ransomware]: dragnet-ransomware-2025-3471 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 7f6965a2-4ec2-5544-a182-7f18018007ac

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
