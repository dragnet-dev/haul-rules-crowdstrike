// Dragnet [Container]: dragnet-container-2024-1052 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: b565b9dd-59b7-5551-9cbd-a5edf5846620

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:8* OR ImageFileName = *debian:9*)
| table([timestamp, ComputerName])
| limit(1000)
