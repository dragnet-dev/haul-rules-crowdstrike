// Dragnet [Ransomware]: dragnet-ransomware-2025-3033 — Mass File Rename (dragonforce)
// Status: test | Level: high | ID: 3af364ad-beb2-5fef-8875-1570ee33c6fb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
