// Dragnet [Ransomware]: dragnet-ransomware-2024-5955 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 24541e03-dc92-5f1a-8cac-4e80b8ec42a3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
