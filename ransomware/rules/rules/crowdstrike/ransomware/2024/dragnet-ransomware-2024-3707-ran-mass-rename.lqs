// Dragnet [Ransomware]: dragnet-ransomware-2024-3707 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: f1733e5f-384f-5a53-855f-017e6ea7ac2b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
