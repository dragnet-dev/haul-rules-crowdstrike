// Dragnet [Ransomware]: dragnet-ransomware-2024-1960 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: bc41982e-9a25-5bd8-9eba-b35235910a39

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
