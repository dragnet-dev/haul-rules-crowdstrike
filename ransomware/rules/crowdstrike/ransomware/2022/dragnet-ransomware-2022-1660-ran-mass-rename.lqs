// Dragnet [Ransomware]: dragnet-ransomware-2022-1660 — Mass File Rename (cuba)
// Status: deprecated | Level: high | ID: ae412c3f-5711-5309-94f1-fd8b935e5cbb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
