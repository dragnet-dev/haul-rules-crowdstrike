// Dragnet [Container]: dragnet-container-2024-0053 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 3e032815-ad84-5c13-8549-79a78e879ddb

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
