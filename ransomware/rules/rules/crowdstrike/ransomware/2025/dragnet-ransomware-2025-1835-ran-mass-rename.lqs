// Dragnet [Ransomware]: dragnet-ransomware-2025-1835 — Mass File Rename (sinobi)
// Status: experimental | Level: high | ID: 5aaaf012-c0fa-5aff-8bec-45245fed6333

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
