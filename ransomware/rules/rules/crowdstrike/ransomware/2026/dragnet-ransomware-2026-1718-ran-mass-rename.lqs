// Dragnet [Ransomware]: dragnet-ransomware-2026-1718 — Mass File Rename (incransom)
// Status: stable | Level: high | ID: 168ad9c0-3511-57cc-b3ae-ef71a5d92e26

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
