// Dragnet [Ransomware]: dragnet-ransomware-2021-0589 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 8daa50bd-66a2-5ebb-a61e-cc34db549aa0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
