// Dragnet [Ransomware]: dragnet-ransomware-2025-7205 — Mass File Rename (lockbit5)
// Status: test | Level: high | ID: d751f39e-5754-5cc2-9eb0-758f57e985c0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
