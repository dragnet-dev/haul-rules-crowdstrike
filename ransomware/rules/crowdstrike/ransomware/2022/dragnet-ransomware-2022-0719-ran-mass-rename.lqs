// Dragnet [Ransomware]: dragnet-ransomware-2022-0719 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 36ac69dd-c763-57bd-8c4e-2dbb2d1c503b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
