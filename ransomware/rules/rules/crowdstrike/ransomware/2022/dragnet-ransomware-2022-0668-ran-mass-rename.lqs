// Dragnet [Ransomware]: dragnet-ransomware-2022-0668 — Mass File Rename (play)
// Status: deprecated | Level: high | ID: 0f864777-671b-5a94-8a15-a998fa6809be

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
