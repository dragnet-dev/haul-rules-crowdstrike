// Dragnet [Ransomware]: dragnet-ransomware-2022-2235 — Mass File Rename (blackbasta)
// Status: deprecated | Level: high | ID: 0be53393-2cc1-5b3c-a589-4c072a742e1d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
