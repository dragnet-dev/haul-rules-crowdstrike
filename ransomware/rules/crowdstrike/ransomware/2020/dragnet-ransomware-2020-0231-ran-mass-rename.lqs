// Dragnet [Ransomware]: dragnet-ransomware-2020-0231 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 73c7ca42-a828-5c9c-90ea-45b55c31c932

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
