// Dragnet [Ransomware]: dragnet-ransomware-2026-1754 — Mass File Rename (AuditTeam)
// Status: stable | Level: high | ID: 3266fe36-4677-5afb-beec-e792b3b3d6d2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
