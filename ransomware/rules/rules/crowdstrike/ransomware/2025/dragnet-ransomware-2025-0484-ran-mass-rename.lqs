// Dragnet [Ransomware]: dragnet-ransomware-2025-0484 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 6a81c959-10d9-5b9b-a1e0-f44ea6540dc0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
