// Dragnet [Ransomware]: dragnet-ransomware-2025-2964 — Mass File Rename (direwolf)
// Status: experimental | Level: high | ID: e522d604-66dd-558b-bb4b-82e84c03c97a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
