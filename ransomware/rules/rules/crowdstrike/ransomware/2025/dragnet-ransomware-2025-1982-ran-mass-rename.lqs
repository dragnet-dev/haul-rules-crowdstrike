// Dragnet [Ransomware]: dragnet-ransomware-2025-1982 — Mass File Rename (dragonforce)
// Status: test | Level: high | ID: 049dcb41-0afd-5dbb-a123-baa40a8a0c15

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
