// Dragnet [Ransomware]: dragnet-ransomware-2025-6989 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 75c41ca9-9ac1-5a19-97d8-674eaf249dff

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
