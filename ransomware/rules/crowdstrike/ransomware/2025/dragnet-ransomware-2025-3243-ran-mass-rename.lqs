// Dragnet [Ransomware]: dragnet-ransomware-2025-3243 — Mass File Rename (sarcoma)
// Status: deprecated | Level: high | ID: 08fae057-d6a8-5a50-8ad6-9bf7d491efaf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
