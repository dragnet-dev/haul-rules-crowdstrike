// Dragnet [Ransomware]: dragnet-ransomware-2025-0343 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: bb78cfe2-dfdf-5479-952d-8a92ed3aa9ae

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
