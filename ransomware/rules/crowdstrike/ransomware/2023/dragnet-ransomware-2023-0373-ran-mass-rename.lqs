// Dragnet [Ransomware]: dragnet-ransomware-2023-0373 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: d8b485e5-ee0e-5e55-a500-68685f7a5976

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
