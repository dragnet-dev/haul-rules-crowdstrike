// Dragnet [Ransomware]: dragnet-ransomware-2026-2754 — Mass File Rename (embargo)
// Status: stable | Level: high | ID: dc618cc4-75a6-51e4-b102-62dc691ffd39

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
