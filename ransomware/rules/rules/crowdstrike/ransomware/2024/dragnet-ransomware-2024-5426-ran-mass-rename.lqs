// Dragnet [Ransomware]: dragnet-ransomware-2024-5426 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 61350766-72d9-5f6a-a93d-5f97a7da108b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
