// Dragnet [Ransomware]: dragnet-ransomware-2024-0387 — Mass File Rename (spacebears)
// Status: experimental | Level: high | ID: c596a4a6-6b35-578e-8f45-0c34d7f961fc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
