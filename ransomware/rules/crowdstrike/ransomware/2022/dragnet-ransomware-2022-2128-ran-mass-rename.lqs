// Dragnet [Ransomware]: dragnet-ransomware-2022-2128 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 60935d6c-3fa6-5977-9d4c-ef312edf106b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
