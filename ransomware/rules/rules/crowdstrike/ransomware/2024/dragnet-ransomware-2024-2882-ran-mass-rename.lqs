// Dragnet [Ransomware]: dragnet-ransomware-2024-2882 — Mass File Rename (SilentRansomGroup)
// Status: deprecated | Level: high | ID: abd3fc82-6846-5e25-baa8-394c7d75defc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
