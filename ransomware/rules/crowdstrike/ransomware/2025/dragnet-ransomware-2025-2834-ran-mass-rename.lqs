// Dragnet [Ransomware]: dragnet-ransomware-2025-2834 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: 1df3483c-71bd-553c-a01e-8cfd6a787e6a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
