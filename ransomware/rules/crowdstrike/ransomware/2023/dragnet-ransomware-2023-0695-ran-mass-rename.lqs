// Dragnet [Ransomware]: dragnet-ransomware-2023-0695 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: e5cf480b-7637-5612-85bb-c8dcdbbb43be

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
