// Dragnet [Ransomware]: dragnet-ransomware-2024-0064 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: f28012c7-b969-53ce-ba3e-8a6ad1482cb4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
