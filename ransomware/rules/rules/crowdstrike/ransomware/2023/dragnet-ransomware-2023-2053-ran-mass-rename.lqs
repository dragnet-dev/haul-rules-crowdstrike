// Dragnet [Ransomware]: dragnet-ransomware-2023-2053 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: be287b9a-e1b6-54a2-a250-2c3d1fc1be04

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
