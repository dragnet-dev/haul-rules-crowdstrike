// Dragnet [Ransomware]: dragnet-ransomware-2022-1321 — Mass File Rename (snatch)
// Status: experimental | Level: high | ID: f1aaa792-9541-5b0f-a7b2-5914f923f03e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
