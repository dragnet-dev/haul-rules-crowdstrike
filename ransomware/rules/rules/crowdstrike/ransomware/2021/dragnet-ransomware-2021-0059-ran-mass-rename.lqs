// Dragnet [Ransomware]: dragnet-ransomware-2021-0059 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 487362db-65ed-53ff-90cf-a550391d0913

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
