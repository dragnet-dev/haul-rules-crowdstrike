// Dragnet [Ransomware]: dragnet-ransomware-2025-5404 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 1c855ef3-c760-5fcd-9473-850ea4257269

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
