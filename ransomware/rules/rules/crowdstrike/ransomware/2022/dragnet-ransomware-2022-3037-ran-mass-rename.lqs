// Dragnet [Ransomware]: dragnet-ransomware-2022-3037 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 7beaeb3f-d13e-5e0a-b777-aa8db7dc210e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
