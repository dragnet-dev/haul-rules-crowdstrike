// Dragnet [Ransomware]: dragnet-ransomware-2021-0069 — Mass File Rename (suncrypt)
// Status: deprecated | Level: high | ID: 222f4725-1221-5b94-bf39-499a6e8e54e4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
