// Dragnet [Ransomware]: dragnet-ransomware-2025-7659 — Mass File Rename (spacebears)
// Status: experimental | Level: high | ID: d28a0b41-1b40-5256-9893-ccaefae0822e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
