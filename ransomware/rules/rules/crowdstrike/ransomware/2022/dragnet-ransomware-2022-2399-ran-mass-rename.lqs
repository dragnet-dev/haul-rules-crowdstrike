// Dragnet [Ransomware]: dragnet-ransomware-2022-2399 — Mass File Rename (ragnarlocker)
// Status: deprecated | Level: high | ID: 02700c9e-cbbe-5b10-9623-2bc8e0cc2478

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
