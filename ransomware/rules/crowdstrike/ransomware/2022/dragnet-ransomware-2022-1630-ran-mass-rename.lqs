// Dragnet [Ransomware]: dragnet-ransomware-2022-1630 — Mass File Rename (snatch)
// Status: deprecated | Level: high | ID: a9441cce-ac8b-553a-95ae-3bf150c31079

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
