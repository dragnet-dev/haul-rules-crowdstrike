// Dragnet [Ransomware]: dragnet-ransomware-2025-5119 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: 68c257d0-e0be-5450-8baa-e2a68de0f417

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
