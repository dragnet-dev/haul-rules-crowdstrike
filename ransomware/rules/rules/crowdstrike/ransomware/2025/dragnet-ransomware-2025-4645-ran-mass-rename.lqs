// Dragnet [Ransomware]: dragnet-ransomware-2025-4645 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: c0088b19-765c-5042-a5d1-79bfdd59124c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
