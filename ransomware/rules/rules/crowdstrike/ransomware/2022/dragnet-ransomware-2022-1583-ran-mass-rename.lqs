// Dragnet [Ransomware]: dragnet-ransomware-2022-1583 — Mass File Rename (blackbasta)
// Status: deprecated | Level: high | ID: 382c8937-fc5b-53c0-bb0e-1a4566fd6173

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
