// Dragnet [Ransomware]: dragnet-ransomware-2024-0137 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 81038372-2ec9-5fbc-a45b-bb9481229c9e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
