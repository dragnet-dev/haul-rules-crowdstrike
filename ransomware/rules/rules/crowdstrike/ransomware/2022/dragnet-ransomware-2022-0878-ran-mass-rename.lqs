// Dragnet [Ransomware]: dragnet-ransomware-2022-0878 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 5349ba1a-71b2-5de2-879b-6e6117e31518

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
