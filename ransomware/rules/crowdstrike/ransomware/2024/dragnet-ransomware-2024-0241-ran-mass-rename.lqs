// Dragnet [Ransomware]: dragnet-ransomware-2024-0241 — Mass File Rename (mallox)
// Status: deprecated | Level: high | ID: 55704d7e-e792-5b17-b5ca-0ac86e3bbd64

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
