// Dragnet [Ransomware]: dragnet-ransomware-2024-2706 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 4965236c-09a6-50d1-9094-e9ca2d5df2d2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
