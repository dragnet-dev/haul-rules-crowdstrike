// Dragnet [Ransomware]: dragnet-ransomware-2023-2640 — Mass File Rename (avoslocker)
// Status: deprecated | Level: high | ID: 066b64bc-8c06-5043-bc85-337cc691d238

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
