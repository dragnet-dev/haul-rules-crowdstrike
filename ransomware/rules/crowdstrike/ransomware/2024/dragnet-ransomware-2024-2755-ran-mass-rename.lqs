// Dragnet [Ransomware]: dragnet-ransomware-2024-2755 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 9a70a058-60ce-5bdf-bfc0-5b23a19f3a4c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
