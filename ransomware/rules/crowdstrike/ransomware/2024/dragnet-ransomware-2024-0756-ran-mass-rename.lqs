// Dragnet [Ransomware]: dragnet-ransomware-2024-0756 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 63911d0e-39a9-56c8-bf75-fda691471729

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
