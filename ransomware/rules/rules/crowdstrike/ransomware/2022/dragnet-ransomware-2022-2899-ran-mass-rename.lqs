// Dragnet [Ransomware]: dragnet-ransomware-2022-2899 — Mass File Rename (royal)
// Status: deprecated | Level: high | ID: 687749ea-0f01-511f-8a2e-313d913f65da

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
