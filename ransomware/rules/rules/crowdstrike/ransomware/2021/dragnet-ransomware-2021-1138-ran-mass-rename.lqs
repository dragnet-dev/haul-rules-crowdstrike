// Dragnet [Ransomware]: dragnet-ransomware-2021-1138 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 74fb22c7-6956-5d6d-bb8a-6bdf57250152

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
