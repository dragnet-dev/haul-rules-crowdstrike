// Dragnet [Ransomware]: dragnet-ransomware-2025-6244 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: b0eb4f2c-03ef-5a1b-9507-f8b03bc8dae7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
