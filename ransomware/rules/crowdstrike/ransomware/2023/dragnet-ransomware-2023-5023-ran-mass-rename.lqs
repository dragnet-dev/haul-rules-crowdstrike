// Dragnet [Ransomware]: dragnet-ransomware-2023-5023 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: 1333f290-ef02-5ea7-9ca7-f8e46991f5e4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
