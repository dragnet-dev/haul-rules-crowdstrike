// Dragnet [Ransomware]: dragnet-ransomware-2024-3593 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 463f6610-edca-5110-868b-43e2670523f8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
