// Dragnet [Ransomware]: dragnet-ransomware-2024-5445 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: 3f38cb3b-2788-52cd-8806-87eb69ee9ae3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
