// Dragnet [Ransomware]: dragnet-ransomware-2022-0180 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: c80d3680-6aa0-5453-890b-ac84a3986df4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
