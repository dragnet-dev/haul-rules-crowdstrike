// Dragnet [Ransomware]: dragnet-ransomware-2022-2164 — Mass File Rename (royal)
// Status: deprecated | Level: high | ID: 285ff256-b4d6-50e2-9b48-1b5a365017f9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
