// Dragnet [Ransomware]: dragnet-ransomware-2022-2836 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 7c9a33cf-303c-5f59-ab23-f41cc8dac468

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
