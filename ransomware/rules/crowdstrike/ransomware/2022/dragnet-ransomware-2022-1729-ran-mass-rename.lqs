// Dragnet [Ransomware]: dragnet-ransomware-2022-1729 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: a2928782-d875-572b-add8-97f7627771a3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
