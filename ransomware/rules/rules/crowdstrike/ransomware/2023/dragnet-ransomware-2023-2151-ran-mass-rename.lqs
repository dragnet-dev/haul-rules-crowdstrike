// Dragnet [Ransomware]: dragnet-ransomware-2023-2151 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: 52518d59-853e-504c-8317-ba6692431431

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
