// Dragnet [Ransomware]: dragnet-ransomware-2020-0254 — Mass File Rename (revil)
// Status: deprecated | Level: high | ID: e07a9677-a53b-580a-b219-1ed7b09deebb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
