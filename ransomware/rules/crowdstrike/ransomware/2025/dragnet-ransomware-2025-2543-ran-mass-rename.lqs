// Dragnet [Ransomware]: dragnet-ransomware-2025-2543 — Mass File Rename (spacebears)
// Status: test | Level: high | ID: 51fe9d92-f74c-5e00-b9f0-81f50d396619

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
