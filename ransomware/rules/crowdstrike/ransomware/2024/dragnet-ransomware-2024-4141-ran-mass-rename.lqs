// Dragnet [Ransomware]: dragnet-ransomware-2024-4141 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 1dbb0e9f-bb66-5278-862f-148450629449

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
