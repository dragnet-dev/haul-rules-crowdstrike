// Dragnet [Ransomware]: dragnet-ransomware-2023-4434 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 7e120049-0b07-53cd-a912-f729ebc714a3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
