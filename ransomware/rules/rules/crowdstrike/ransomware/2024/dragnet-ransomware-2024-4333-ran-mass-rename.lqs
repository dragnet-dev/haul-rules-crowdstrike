// Dragnet [Ransomware]: dragnet-ransomware-2024-4333 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 611ad5c6-4705-5c46-a22c-bc0261b1bfe6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
