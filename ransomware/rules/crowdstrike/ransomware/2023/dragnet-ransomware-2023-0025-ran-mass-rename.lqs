// Dragnet [Ransomware]: dragnet-ransomware-2023-0025 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 4d2b1d34-8b29-5bbb-aafe-afe1380fee09

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
