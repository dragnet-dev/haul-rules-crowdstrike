// Dragnet [Ransomware]: dragnet-ransomware-2025-5523 — Mass File Rename (worldleaks)
// Status: experimental | Level: high | ID: 3a6f2df5-dbb6-57dd-a189-b260f74e4fbd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
