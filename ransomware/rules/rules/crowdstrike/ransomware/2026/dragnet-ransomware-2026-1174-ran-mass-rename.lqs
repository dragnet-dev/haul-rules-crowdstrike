// Dragnet [Ransomware]: dragnet-ransomware-2026-1174 — Mass File Rename (thegentlemen)
// Status: stable | Level: high | ID: 5fc14a3f-2a2b-56af-b21f-11b54d411370

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
