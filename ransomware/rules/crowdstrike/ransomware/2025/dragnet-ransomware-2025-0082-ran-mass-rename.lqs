// Dragnet [Ransomware]: dragnet-ransomware-2025-0082 — Mass File Rename (coinbasecartel)
// Status: experimental | Level: high | ID: 55ae3572-a159-5b10-a970-3b660b6c94cd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
