// Dragnet [Ransomware]: dragnet-ransomware-2021-1661 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: b3551008-861b-55a5-8a53-30f670e3fa94

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
