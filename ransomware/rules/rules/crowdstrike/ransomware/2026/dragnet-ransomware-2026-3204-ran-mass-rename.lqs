// Dragnet [Ransomware]: dragnet-ransomware-2026-3204 — Mass File Rename (insomnia)
// Status: test | Level: high | ID: f65668b2-6460-504d-af04-bdeca6b51caa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
