// Dragnet [Ransomware]: dragnet-ransomware-2023-2866 — Mass File Rename (malas)
// Status: experimental | Level: high | ID: f195d782-e24c-5031-a31d-4a56108f6968

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
