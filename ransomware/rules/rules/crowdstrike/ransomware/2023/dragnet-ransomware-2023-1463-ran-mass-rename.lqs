// Dragnet [Ransomware]: dragnet-ransomware-2023-1463 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 6154c142-ea28-5386-a416-f795c40e52d7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
