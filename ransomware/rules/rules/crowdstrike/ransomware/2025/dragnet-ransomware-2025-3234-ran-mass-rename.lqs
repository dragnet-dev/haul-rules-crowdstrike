// Dragnet [Ransomware]: dragnet-ransomware-2025-3234 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 831e140a-bf49-5c0d-ad0b-3fd20f87737b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
