// Dragnet [Ransomware]: dragnet-ransomware-2025-6931 — Mass File Rename (blacknevas)
// Status: experimental | Level: high | ID: c4ca7619-f456-5f08-ba78-68c928bd5c88

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
