// Dragnet [Ransomware]: dragnet-ransomware-2024-5863 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: abe4ed3e-01bd-575c-a502-e1a3fdacc923

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
