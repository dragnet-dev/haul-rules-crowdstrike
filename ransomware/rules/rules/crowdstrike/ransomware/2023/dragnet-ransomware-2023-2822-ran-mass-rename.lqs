// Dragnet [Ransomware]: dragnet-ransomware-2023-2822 — Mass File Rename (malas)
// Status: experimental | Level: high | ID: 9fdc41a5-14b3-5336-af6e-255f4f6d792f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
