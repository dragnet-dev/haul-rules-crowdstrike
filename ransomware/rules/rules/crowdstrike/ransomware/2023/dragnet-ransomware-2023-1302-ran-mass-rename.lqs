// Dragnet [Ransomware]: dragnet-ransomware-2023-1302 — Mass File Rename (everest)
// Status: deprecated | Level: high | ID: ae818541-f8f5-5f54-8b7a-1fd62b3d058e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
