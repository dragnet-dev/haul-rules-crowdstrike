// Dragnet [Ransomware]: dragnet-ransomware-2025-2242 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: fc4ba37f-3a1e-5d8a-860a-b925552aaed5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
