// Dragnet [Ransomware]: dragnet-ransomware-2022-1111 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 434de795-1a14-5865-8c2b-b98f1d1c3179

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
