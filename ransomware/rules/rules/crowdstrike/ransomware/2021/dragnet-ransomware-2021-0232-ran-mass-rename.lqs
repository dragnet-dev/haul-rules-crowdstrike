// Dragnet [Ransomware]: dragnet-ransomware-2021-0232 — Mass File Rename (xinglocker)
// Status: deprecated | Level: high | ID: 459e469b-5974-566a-88f0-94b70272f11f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
