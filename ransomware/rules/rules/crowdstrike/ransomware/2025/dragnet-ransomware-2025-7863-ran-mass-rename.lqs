// Dragnet [Ransomware]: dragnet-ransomware-2025-7863 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 9f3fc980-4862-521c-85e6-3b914e7bc75e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
