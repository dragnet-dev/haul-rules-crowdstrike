// Dragnet [Container]: dragnet-container-2024-1347 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: ae80b27c-297b-5426-9464-4202c427b0a5

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
