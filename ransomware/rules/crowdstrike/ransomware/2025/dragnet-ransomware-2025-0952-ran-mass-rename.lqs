// Dragnet [Ransomware]: dragnet-ransomware-2025-0952 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 85f0dc62-39a1-5497-92f0-7d4bf5220839

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
