// Dragnet [Ransomware]: dragnet-ransomware-2021-1025 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: e8594705-4abc-54c5-b8fc-fa616acea643

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
