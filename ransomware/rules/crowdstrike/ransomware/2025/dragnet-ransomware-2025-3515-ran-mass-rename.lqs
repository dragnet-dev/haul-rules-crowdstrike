// Dragnet [Ransomware]: dragnet-ransomware-2025-3515 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 2652cdd0-22e0-56f9-b564-e8280be88f23

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
