// Dragnet [Ransomware]: dragnet-ransomware-2025-1646 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: a7b6cafb-8d03-5dfc-ba89-b8e0469c91cb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
