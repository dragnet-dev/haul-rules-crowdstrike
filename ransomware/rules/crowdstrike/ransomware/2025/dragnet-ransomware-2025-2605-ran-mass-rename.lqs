// Dragnet [Ransomware]: dragnet-ransomware-2025-2605 — Mass File Rename (coinbasecartel)
// Status: experimental | Level: high | ID: d4dd137c-d551-5bb4-a9a8-0c0d92952969

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
