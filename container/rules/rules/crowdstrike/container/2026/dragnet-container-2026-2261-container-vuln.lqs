// Dragnet [Container]: dragnet-container-2026-2261 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: ad75d9e5-532c-5506-a68e-deecb0587314

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
