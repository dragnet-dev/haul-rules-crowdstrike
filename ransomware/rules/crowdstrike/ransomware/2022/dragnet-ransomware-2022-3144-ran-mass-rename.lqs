// Dragnet [Ransomware]: dragnet-ransomware-2022-3144 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: bd82dd78-632e-5294-b061-11fc810808a8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
