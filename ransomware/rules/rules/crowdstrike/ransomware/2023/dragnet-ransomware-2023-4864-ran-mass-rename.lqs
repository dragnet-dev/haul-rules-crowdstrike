// Dragnet [Ransomware]: dragnet-ransomware-2023-4864 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: 1681a43f-fb0a-540f-9e5a-5a8a408ca38b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
