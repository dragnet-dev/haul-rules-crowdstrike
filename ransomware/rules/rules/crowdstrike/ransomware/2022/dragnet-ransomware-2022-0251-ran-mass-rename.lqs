// Dragnet [Ransomware]: dragnet-ransomware-2022-0251 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: 93ddcd37-c1ac-570f-b0ca-881f16fa4835

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
