// Dragnet [Ransomware]: dragnet-ransomware-2026-0888 — Mass File Rename (lockbit5)
// Status: stable | Level: high | ID: 4969c137-61c3-51fb-b129-481c1d050767

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
