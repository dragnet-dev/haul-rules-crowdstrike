// Dragnet [Ransomware]: dragnet-ransomware-2024-3671 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 29a02e4f-3456-506c-8908-15fe77e4d654

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
