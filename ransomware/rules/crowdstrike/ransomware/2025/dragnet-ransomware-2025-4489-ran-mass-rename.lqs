// Dragnet [Ransomware]: dragnet-ransomware-2025-4489 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: f6f53d7b-4b9a-5d1b-9a31-fba78bf995a2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
