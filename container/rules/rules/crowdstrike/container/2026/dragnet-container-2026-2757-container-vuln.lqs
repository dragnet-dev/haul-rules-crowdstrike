// Dragnet [Container]: dragnet-container-2026-2757 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 1fc17975-103d-5a43-b012-e0487b7c06d3

#event_simpleName=*
| (ImageFileName = *alpine:3.2* OR ImageFileName = *alpine:3.3* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:8* OR ImageFileName = *ubuntu:14.04* OR ImageFileName = *ubuntu:14.04-ESM* OR ImageFileName = *ubuntu:15.10* OR ImageFileName = *ubuntu:16.04* OR ImageFileName = *ubuntu:16.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
