// Dragnet [Ransomware]: dragnet-ransomware-2025-2379 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: a678ff36-3831-5077-8426-3fddf71e4c41

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
