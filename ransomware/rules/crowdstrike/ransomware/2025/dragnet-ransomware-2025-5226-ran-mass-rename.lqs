// Dragnet [Ransomware]: dragnet-ransomware-2025-5226 — Mass File Rename (sinobi)
// Status: experimental | Level: high | ID: 3739e90d-e781-5c26-b096-c048d98769a0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
