// Dragnet [Ransomware]: dragnet-ransomware-2024-1830 — Mass File Rename (dragonransomware)
// Status: experimental | Level: high | ID: 152155ce-8755-5fcb-8148-9fea5d4d723d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
