// Dragnet [Ransomware]: dragnet-ransomware-2025-1070 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: c7a7edfe-8f36-59e1-bfec-37c5a035d232

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
