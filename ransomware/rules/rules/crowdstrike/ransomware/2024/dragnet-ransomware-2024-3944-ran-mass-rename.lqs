// Dragnet [Ransomware]: dragnet-ransomware-2024-3944 — Mass File Rename (raworld)
// Status: experimental | Level: high | ID: 305f06d7-a6ad-532f-9a64-31200d7b3577

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
