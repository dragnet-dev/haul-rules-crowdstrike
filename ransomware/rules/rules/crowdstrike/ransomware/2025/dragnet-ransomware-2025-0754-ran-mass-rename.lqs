// Dragnet [Ransomware]: dragnet-ransomware-2025-0754 — Mass File Rename (killsec)
// Status: deprecated | Level: high | ID: d9cf51c7-6933-50d1-9338-5853c76cb2d0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
