// Dragnet [Ransomware]: dragnet-ransomware-2023-4360 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 309fd4b7-e536-5460-b84f-e8e6a7a71c37

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
