// Dragnet [Ransomware]: dragnet-ransomware-2023-1228 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 65903755-fbb7-5cd6-b8e0-a5ee982805d6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
