// Dragnet [Ransomware]: dragnet-ransomware-2022-2428 — Mass File Rename (royal)
// Status: deprecated | Level: high | ID: b9ce45c7-f0c8-56a7-b771-c154c40a4362

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
