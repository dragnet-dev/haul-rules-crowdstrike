// Dragnet [Ransomware]: dragnet-ransomware-2024-5034 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: da7646d3-98e6-505c-9276-a231537a321b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
