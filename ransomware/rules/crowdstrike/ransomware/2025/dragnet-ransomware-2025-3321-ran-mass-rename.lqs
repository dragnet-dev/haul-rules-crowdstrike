// Dragnet [Ransomware]: dragnet-ransomware-2025-3321 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 81bde918-a4ef-5742-9dc4-87f81fe61fee

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
