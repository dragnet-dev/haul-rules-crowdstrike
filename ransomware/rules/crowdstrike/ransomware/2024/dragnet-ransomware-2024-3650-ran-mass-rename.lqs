// Dragnet [Ransomware]: dragnet-ransomware-2024-3650 — Mass File Rename (qilin)
// Status: deprecated | Level: high | ID: 927f38c3-36ac-5ec8-9d67-d772130ef01c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
