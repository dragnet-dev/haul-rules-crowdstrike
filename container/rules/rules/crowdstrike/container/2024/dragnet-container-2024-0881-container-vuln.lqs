// Dragnet [Container]: dragnet-container-2024-0881 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 140b8fb7-debd-5738-8708-818150edf13c

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
