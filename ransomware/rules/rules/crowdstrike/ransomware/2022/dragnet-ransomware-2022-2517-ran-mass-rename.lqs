// Dragnet [Ransomware]: dragnet-ransomware-2022-2517 — Mass File Rename (mallox)
// Status: deprecated | Level: high | ID: 26320545-8277-5946-8a82-73f0cd8997de

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
