// Dragnet [Ransomware]: dragnet-ransomware-2024-1134 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: f188b58c-82fe-519d-aa76-fd1fcfdb257c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
