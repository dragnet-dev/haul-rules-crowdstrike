// Dragnet [Ransomware]: dragnet-ransomware-2026-3451 — Mass File Rename (anubis)
// Status: stable | Level: high | ID: 92a97014-56e9-5ff1-b92c-ce8f1543b5f0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
