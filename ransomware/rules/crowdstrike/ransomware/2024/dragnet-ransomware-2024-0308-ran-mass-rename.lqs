// Dragnet [Ransomware]: dragnet-ransomware-2024-0308 — Mass File Rename (raworld)
// Status: experimental | Level: high | ID: a7b10021-5696-52c5-b1f1-031d8fdea7ac

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
