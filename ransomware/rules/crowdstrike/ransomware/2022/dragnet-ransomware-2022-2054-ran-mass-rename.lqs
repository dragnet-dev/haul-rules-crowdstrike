// Dragnet [Ransomware]: dragnet-ransomware-2022-2054 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 3b857b75-b1f0-532b-a7a2-d3f9baec22b4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
