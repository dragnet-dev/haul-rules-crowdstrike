// Dragnet [Ransomware]: dragnet-ransomware-2025-2908 — Mass File Rename (worldleaks)
// Status: experimental | Level: high | ID: 8f2f2323-081a-5a0b-ba54-b764aaf4dad5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
