// Dragnet [Ransomware]: dragnet-ransomware-2025-7445 — Mass File Rename (sarcoma)
// Status: deprecated | Level: high | ID: 1c93310e-6d7f-5d35-874f-c317c209156d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
