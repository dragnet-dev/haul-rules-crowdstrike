// Dragnet [Ransomware]: dragnet-ransomware-2024-5437 — Mass File Rename (rhysida)
// Status: deprecated | Level: high | ID: 26914069-9a14-508a-87db-3c2c5f04e13f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
