// Dragnet [Ransomware]: dragnet-ransomware-2022-0704 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 4fe51b71-31cb-5bf5-bff5-7b2c974c5e4e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
