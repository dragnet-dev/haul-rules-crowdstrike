// Dragnet [Ransomware]: dragnet-ransomware-2022-2143 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 4a157ef0-b339-53ae-a0b7-9ad3dfa09294

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
