// Dragnet [Ransomware]: dragnet-ransomware-2024-0699 — Mass File Rename (ciphbit)
// Status: deprecated | Level: high | ID: e1023d41-0ee4-530d-80e0-9c3fa2b7fd8d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
