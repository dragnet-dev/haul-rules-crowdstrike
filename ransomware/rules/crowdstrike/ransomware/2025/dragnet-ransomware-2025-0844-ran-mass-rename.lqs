// Dragnet [Ransomware]: dragnet-ransomware-2025-0844 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 7516c446-9bf6-58e0-846b-1ccb03efa558

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
