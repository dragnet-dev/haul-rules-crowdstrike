// Dragnet [Ransomware]: dragnet-ransomware-2025-1424 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: 8a80bdd5-a053-5c13-9320-a62c0e60da0b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
