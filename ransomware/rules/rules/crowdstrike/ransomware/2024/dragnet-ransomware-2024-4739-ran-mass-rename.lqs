// Dragnet [Ransomware]: dragnet-ransomware-2024-4739 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 01bf24f6-d404-55a0-9ec1-9c0d37eeb95b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
