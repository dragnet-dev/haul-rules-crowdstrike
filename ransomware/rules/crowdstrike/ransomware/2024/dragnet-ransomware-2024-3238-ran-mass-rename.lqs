// Dragnet [Ransomware]: dragnet-ransomware-2024-3238 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: f6779769-9682-50d8-b32c-58864aaa3323

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
