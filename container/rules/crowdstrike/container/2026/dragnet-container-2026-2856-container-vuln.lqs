// Dragnet [Container]: dragnet-container-2026-2856 — Vulnerable Base Image Pull
// Status: deprecated | Level: medium | ID: f509e82a-142b-5b33-88e1-4ee52d980a1d

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
