// Dragnet [Ransomware]: dragnet-ransomware-2022-2360 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 90921a7b-5b78-58a6-b6de-7499d8085ff4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
