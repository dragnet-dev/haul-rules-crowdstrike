// Dragnet [Ransomware]: dragnet-ransomware-2024-4889 — Mass File Rename (ElDorado)
// Status: deprecated | Level: high | ID: ac11cdcc-cb26-5e9f-b809-b89683fdd19f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
