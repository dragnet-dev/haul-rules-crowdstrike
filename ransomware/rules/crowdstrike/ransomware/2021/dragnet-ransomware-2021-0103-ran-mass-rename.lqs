// Dragnet [Ransomware]: dragnet-ransomware-2021-0103 — Mass File Rename (avaddon)
// Status: deprecated | Level: high | ID: 377b5a14-dd8b-5ce7-bb56-a992ca9fd031

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
