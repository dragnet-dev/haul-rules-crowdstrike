// Dragnet [Ransomware]: dragnet-ransomware-2023-1126 — Mass File Rename (royal)
// Status: experimental | Level: high | ID: 6c30c388-b9e3-5b9e-a532-3e36e3051505

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
