// Dragnet [Ransomware]: dragnet-ransomware-2023-5089 — Mass File Rename (ransomhouse)
// Status: experimental | Level: high | ID: 32df5115-3e93-570c-b2d4-5888b44d07fb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
