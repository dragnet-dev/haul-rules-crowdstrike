// Dragnet [Ransomware]: dragnet-ransomware-2025-4365 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 66955970-672d-5203-8f0e-b387a531beaf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
