// Dragnet [Ransomware]: dragnet-ransomware-2022-0268 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: c48dc47b-3789-5475-bf6a-cf04f31f4207

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
