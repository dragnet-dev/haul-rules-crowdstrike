// Dragnet [Container]: dragnet-container-2026-2707 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 89fb2465-5aaa-5072-bb43-81e493587e30

#event_simpleName=*
| (ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10* OR ImageFileName = *ubuntu:13.04* OR ImageFileName = *ubuntu:13.10*)
| table([timestamp, ComputerName])
| limit(1000)
