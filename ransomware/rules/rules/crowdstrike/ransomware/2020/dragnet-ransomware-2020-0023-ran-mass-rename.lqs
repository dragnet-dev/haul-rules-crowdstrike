// Dragnet [Ransomware]: dragnet-ransomware-2020-0023 — Mass File Rename (ransomexx)
// Status: deprecated | Level: high | ID: e06982eb-bf96-5fc0-9d34-aa439095cf60

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
