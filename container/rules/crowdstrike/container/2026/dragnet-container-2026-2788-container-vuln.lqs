// Dragnet [Container]: dragnet-container-2026-2788 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: b1529773-8483-5f47-9e3b-6f222503d6a2

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
