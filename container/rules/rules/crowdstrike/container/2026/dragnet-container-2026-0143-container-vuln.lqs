// Dragnet [Container]: dragnet-container-2026-0143 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 99e7f2ec-9b87-589f-a0d8-58ba0b9d3e36

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:5*)
| table([timestamp, ComputerName])
| limit(1000)
