// Dragnet [Ransomware]: dragnet-ransomware-2025-4976 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 48bcb528-2b14-5cc8-acbf-748521cc0a80

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
