// Dragnet [Ransomware]: dragnet-ransomware-2023-3066 — Mass File Rename (rancoz)
// Status: experimental | Level: high | ID: 57cc4847-1d8d-51e8-804d-7d1bf8488631

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
