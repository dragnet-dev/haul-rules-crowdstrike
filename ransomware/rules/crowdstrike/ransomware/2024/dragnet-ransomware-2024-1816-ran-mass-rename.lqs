// Dragnet [Ransomware]: dragnet-ransomware-2024-1816 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 11b264b2-56d3-59a9-a017-facec0717d2b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
