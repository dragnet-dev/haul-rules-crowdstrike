// Dragnet [Ransomware]: dragnet-ransomware-2023-5183 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 3e06a29d-c6fc-5e2b-b841-cd53ff5c3062

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
