// Dragnet [Ransomware]: dragnet-ransomware-2022-2709 — Mass File Rename (karakurt)
// Status: experimental | Level: high | ID: a984a654-f406-5aaa-bb02-56ddfd81d7fb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
