// Dragnet [Ransomware]: dragnet-ransomware-2023-2713 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 1bab88c0-e25f-5e1f-8fb2-1652bcfc5906

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
