// Dragnet [Ransomware]: dragnet-ransomware-2020-0095 — Mass File Rename (ragnarlocker)
// Status: deprecated | Level: high | ID: b694c99d-1c17-5073-a4ff-1cb898fca8a4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
