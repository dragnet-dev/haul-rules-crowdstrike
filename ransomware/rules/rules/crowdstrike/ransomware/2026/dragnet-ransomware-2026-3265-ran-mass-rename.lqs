// Dragnet [Ransomware]: dragnet-ransomware-2026-3265 — Mass File Rename (killsec)
// Status: deprecated | Level: high | ID: 4237a846-7c74-5703-8e6c-6064a6c75dd2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
