// Dragnet [Ransomware]: dragnet-ransomware-2021-1264 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: ee8f2a79-ca25-5013-9172-25e76e784849

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
