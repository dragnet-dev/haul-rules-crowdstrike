// Dragnet [Ransomware]: dragnet-ransomware-2026-0229 — Mass File Rename (payload)
// Status: stable | Level: high | ID: b3d3a04c-6805-52f0-aea6-14eb0032e300

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
