// Dragnet [Ransomware]: dragnet-ransomware-2023-4114 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 35fcc69d-f652-58ae-b123-93df092effa6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
