// Dragnet [Ransomware]: dragnet-ransomware-2025-0068 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 365df30e-a551-531c-be88-cb960e04bd5f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
