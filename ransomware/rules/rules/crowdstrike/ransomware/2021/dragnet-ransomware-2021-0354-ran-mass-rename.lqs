// Dragnet [Ransomware]: dragnet-ransomware-2021-0354 — Mass File Rename (xinglocker)
// Status: deprecated | Level: high | ID: 9694bab9-55dc-5811-a8b1-e1c9c00da865

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
