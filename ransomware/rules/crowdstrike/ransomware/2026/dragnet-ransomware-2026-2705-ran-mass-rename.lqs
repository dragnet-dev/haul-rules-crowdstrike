// Dragnet [Ransomware]: dragnet-ransomware-2026-2705 — Mass File Rename (dragonforce)
// Status: stable | Level: high | ID: 67d7a28f-e3fa-5d2c-a29f-43dff22aae9f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
