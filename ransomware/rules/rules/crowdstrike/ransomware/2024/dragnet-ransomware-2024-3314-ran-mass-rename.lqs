// Dragnet [Ransomware]: dragnet-ransomware-2024-3314 — Mass File Rename (safepay)
// Status: deprecated | Level: high | ID: 2b9ac089-2c31-5b7c-851b-10e15c29aada

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
