// Dragnet [Ransomware]: dragnet-ransomware-2024-2387 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: bfda9cc0-58d2-50b6-acd3-287897e0c555

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
