// Dragnet [Ransomware]: dragnet-ransomware-2024-4856 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: b2065bda-9fcf-55eb-8495-37eb4caaf6d0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
