// Dragnet [Ransomware]: dragnet-ransomware-2023-0411 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 5950fca7-0227-575d-ad31-44654f24dce4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
