// Dragnet [Ransomware]: dragnet-ransomware-2024-2000 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 5b2b8fce-f36f-5433-b512-b91cf2a2e900

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
