// Dragnet [Ransomware]: dragnet-ransomware-2024-2176 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 1bf2414b-dad0-58f9-bff7-8e423ab2facc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
