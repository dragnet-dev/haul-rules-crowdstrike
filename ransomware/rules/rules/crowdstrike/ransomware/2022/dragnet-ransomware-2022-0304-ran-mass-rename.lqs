// Dragnet [Ransomware]: dragnet-ransomware-2022-0304 — Mass File Rename (everest)
// Status: deprecated | Level: high | ID: d6d28af7-1112-5af5-a4cb-02d60775bfc4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
