// Dragnet [Ransomware]: dragnet-ransomware-2023-4061 — Mass File Rename (losttrust)
// Status: deprecated | Level: high | ID: d4df112a-d411-5292-a528-60c6844c49e2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
