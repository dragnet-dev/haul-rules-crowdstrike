// Dragnet [Ransomware]: dragnet-ransomware-2025-2486 — Mass File Rename (thegentlemen)
// Status: experimental | Level: high | ID: 307f2bb5-7e10-56e8-9e03-6ca4bf62eaa3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
