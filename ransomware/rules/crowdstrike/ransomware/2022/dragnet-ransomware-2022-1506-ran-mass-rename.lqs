// Dragnet [Ransomware]: dragnet-ransomware-2022-1506 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 4f641f2e-3ec0-56ac-8f2a-a891a1782c99

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
