// Dragnet [Ransomware]: dragnet-ransomware-2023-4630 — Mass File Rename (werewolves)
// Status: experimental | Level: high | ID: de1ab17d-3fb1-58ea-ba6b-51257103ab9a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
