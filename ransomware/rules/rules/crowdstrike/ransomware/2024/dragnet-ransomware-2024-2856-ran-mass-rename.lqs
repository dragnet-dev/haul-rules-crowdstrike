// Dragnet [Ransomware]: dragnet-ransomware-2024-2856 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 4118d889-9773-54b5-8202-9c07a0061a1a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
