// Dragnet [Ransomware]: dragnet-ransomware-2025-4255 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 2a57bd94-14bf-5e59-b697-605ee72bc4f1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
