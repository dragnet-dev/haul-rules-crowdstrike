// Dragnet [Ransomware]: dragnet-ransomware-2024-3170 — Mass File Rename (ciphbit)
// Status: deprecated | Level: high | ID: a53c1d21-6165-55f3-8556-8724ec8e3b81

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
