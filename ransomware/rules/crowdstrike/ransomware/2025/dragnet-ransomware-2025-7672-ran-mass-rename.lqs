// Dragnet [Ransomware]: dragnet-ransomware-2025-7672 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: 8fa95e71-d79b-5cfd-9773-0678cdad65bf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
