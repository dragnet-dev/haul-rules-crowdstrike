// Dragnet [Ransomware]: dragnet-ransomware-2024-0941 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: cff7e2f1-135b-5051-b1d0-e9917edd14e4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
