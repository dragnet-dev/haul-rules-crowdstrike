// Dragnet [Ransomware]: dragnet-ransomware-2024-5654 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 48c45820-9b21-52b8-adf0-83b0c3876ae4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
