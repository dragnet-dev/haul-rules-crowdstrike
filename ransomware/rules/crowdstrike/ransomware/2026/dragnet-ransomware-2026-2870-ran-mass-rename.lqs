// Dragnet [Ransomware]: dragnet-ransomware-2026-2870 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 434bcaa3-336d-5166-be93-3d4361053ff7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
