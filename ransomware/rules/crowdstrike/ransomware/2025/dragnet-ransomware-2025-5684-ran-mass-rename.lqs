// Dragnet [Ransomware]: dragnet-ransomware-2025-5684 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 400b31c6-6464-5417-9673-536f897b81da

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
