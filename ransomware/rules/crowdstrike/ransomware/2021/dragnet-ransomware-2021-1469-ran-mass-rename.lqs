// Dragnet [Ransomware]: dragnet-ransomware-2021-1469 — Mass File Rename (midas)
// Status: deprecated | Level: high | ID: bbd0d227-d280-5a5c-b6fd-c27b8e85f5cc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
