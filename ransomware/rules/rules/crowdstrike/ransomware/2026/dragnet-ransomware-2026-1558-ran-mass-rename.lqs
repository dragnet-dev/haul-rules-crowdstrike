// Dragnet [Ransomware]: dragnet-ransomware-2026-1558 — Mass File Rename (dragonforce)
// Status: stable | Level: high | ID: c9eb2232-731c-5f0f-b848-d659b7071b7f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
