// Dragnet [Ransomware]: dragnet-ransomware-2024-0223 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 4d7b19b1-96a0-54c7-8045-d8336e08f216

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
