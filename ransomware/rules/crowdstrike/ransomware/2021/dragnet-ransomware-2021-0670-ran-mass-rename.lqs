// Dragnet [Ransomware]: dragnet-ransomware-2021-0670 — Mass File Rename (avaddon)
// Status: deprecated | Level: high | ID: fadc9bd7-0d3a-5438-8917-acbe6fc2de62

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
