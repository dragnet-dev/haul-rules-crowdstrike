// Dragnet [Ransomware]: dragnet-ransomware-2025-6802 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: bbf475a3-f073-51c7-9d70-bac61077ed80

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
