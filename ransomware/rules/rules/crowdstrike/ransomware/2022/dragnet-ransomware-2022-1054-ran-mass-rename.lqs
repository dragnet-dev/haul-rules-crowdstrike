// Dragnet [Ransomware]: dragnet-ransomware-2022-1054 — Mass File Rename (ragnarlocker)
// Status: deprecated | Level: high | ID: ea6df3a5-9368-594b-9fb0-ef880f60526f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
