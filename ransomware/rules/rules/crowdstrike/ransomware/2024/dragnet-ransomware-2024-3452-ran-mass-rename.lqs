// Dragnet [Ransomware]: dragnet-ransomware-2024-3452 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 28cc6a5e-43d0-52f2-954b-9bcc48a12246

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
