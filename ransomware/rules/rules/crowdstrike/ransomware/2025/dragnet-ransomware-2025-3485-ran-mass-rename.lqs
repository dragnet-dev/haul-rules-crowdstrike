// Dragnet [Ransomware]: dragnet-ransomware-2025-3485 — Mass File Rename (sinobi)
// Status: experimental | Level: high | ID: 15c057e1-4986-57a8-9f08-00f088afaddc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
