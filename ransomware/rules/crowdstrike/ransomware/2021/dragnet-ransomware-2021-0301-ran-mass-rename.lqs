// Dragnet [Ransomware]: dragnet-ransomware-2021-0301 — Mass File Rename (pay2key)
// Status: deprecated | Level: high | ID: c869dd19-4bdd-59e5-9001-f8e0b5665e68

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
