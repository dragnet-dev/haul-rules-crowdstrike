// Dragnet [Ransomware]: dragnet-ransomware-2025-3734 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 07d502bf-0a7f-5802-82c1-80e6f017a653

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
