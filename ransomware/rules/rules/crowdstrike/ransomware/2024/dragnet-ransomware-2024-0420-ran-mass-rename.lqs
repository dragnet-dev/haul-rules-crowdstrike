// Dragnet [Ransomware]: dragnet-ransomware-2024-0420 — Mass File Rename (dragonforce)
// Status: deprecated | Level: high | ID: 2b219508-b313-5849-841c-903e1976b40b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
