// Dragnet [Ransomware]: dragnet-ransomware-2024-4136 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: 2791925a-db7f-532c-b650-ab8de1f9e59d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
