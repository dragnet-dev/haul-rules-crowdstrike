// Dragnet [Ransomware]: dragnet-ransomware-2023-4965 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 9bb534f7-fa93-58f6-accc-fcf9021c209c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
