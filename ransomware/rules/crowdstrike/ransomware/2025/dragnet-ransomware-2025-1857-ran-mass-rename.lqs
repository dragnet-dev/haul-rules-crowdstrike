// Dragnet [Ransomware]: dragnet-ransomware-2025-1857 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 55fb38df-7d7b-50d1-98d0-92400ea73abd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
