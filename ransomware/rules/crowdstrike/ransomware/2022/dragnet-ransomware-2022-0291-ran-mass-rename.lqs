// Dragnet [Ransomware]: dragnet-ransomware-2022-0291 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 40becd79-21ae-542b-9019-aa1261ced779

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
