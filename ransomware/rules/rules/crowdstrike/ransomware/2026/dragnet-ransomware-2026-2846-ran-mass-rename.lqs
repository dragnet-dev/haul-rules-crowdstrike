// Dragnet [Ransomware]: dragnet-ransomware-2026-2846 — Mass File Rename (shinyhunters)
// Status: deprecated | Level: high | ID: ddbe57f2-8804-5559-9cb5-c1af232346e4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
