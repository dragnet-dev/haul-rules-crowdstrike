// Dragnet [Ransomware]: dragnet-ransomware-2024-3931 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: be8715b9-92b4-5b29-a1fa-76eba7b15a85

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
