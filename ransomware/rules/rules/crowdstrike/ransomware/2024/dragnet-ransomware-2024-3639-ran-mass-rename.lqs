// Dragnet [Ransomware]: dragnet-ransomware-2024-3639 — Mass File Rename (sarcoma)
// Status: deprecated | Level: high | ID: b4147f85-bf55-525c-83dc-791f76f84bb3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
