// Dragnet [Ransomware]: dragnet-ransomware-2024-3421 — Mass File Rename (dragonforce)
// Status: deprecated | Level: high | ID: 76be8200-9f50-5485-8594-dac091eaa78d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
