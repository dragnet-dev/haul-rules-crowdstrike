// Dragnet [Ransomware]: dragnet-ransomware-2025-2438 — Mass File Rename (thegentlemen)
// Status: experimental | Level: high | ID: 18a9eb6d-9e17-51f4-9de0-5c04d4ca4a4b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
