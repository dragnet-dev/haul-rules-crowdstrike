// Dragnet [Ransomware]: dragnet-ransomware-2023-5007 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: db31be7b-e6e3-5eeb-8e8e-15b4dee1cdf6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
