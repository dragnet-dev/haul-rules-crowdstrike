// Dragnet [Ransomware]: dragnet-ransomware-2025-2904 — Mass File Rename (sinobi)
// Status: experimental | Level: high | ID: a17e438e-7afe-5e38-a20f-ccdb1a433349

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
