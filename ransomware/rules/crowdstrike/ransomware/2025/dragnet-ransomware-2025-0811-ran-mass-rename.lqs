// Dragnet [Ransomware]: dragnet-ransomware-2025-0811 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: fc6f273c-bdcd-5182-b500-2e7b2b1510b4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
