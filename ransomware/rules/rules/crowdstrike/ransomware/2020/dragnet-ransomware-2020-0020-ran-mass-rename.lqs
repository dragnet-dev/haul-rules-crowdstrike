// Dragnet [Ransomware]: dragnet-ransomware-2020-0020 — Mass File Rename (doppelpaymer)
// Status: deprecated | Level: high | ID: d562b856-6f49-5da4-916c-4b2f19c2d567

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
