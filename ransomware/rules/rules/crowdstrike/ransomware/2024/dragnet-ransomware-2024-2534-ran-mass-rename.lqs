// Dragnet [Ransomware]: dragnet-ransomware-2024-2534 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 99da1232-4185-5178-ac38-81cf7c46b3bb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
