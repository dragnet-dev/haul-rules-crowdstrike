// Dragnet [Ransomware]: dragnet-ransomware-2026-0892 — Mass File Rename (termite)
// Status: stable | Level: high | ID: ae1fcd24-7cc6-5ca7-9a59-554027574fe2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
