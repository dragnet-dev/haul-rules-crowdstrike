// Dragnet [Container]: dragnet-container-2026-0561 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 4394f479-0b0b-59fc-a847-3f9cc2852d7d

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:5*)
| table([timestamp, ComputerName])
| limit(1000)
