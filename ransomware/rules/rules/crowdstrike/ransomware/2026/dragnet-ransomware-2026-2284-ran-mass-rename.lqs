// Dragnet [Ransomware]: dragnet-ransomware-2026-2284 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: a1823d9b-93d0-5a2b-8eab-9667560dbb1c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
