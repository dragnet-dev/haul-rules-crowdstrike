// Dragnet [Ransomware]: dragnet-ransomware-2023-0032 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: ea6646d2-914c-5605-b0b1-b9b7a202ce57

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
