// Dragnet [Ransomware]: dragnet-ransomware-2021-0035 — Mass File Rename (bonacigroup)
// Status: deprecated | Level: high | ID: 51aa131f-9439-58a8-8bed-c75e78183169

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
