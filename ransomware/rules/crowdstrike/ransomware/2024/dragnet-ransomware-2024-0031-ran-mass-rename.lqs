// Dragnet [Ransomware]: dragnet-ransomware-2024-0031 — Mass File Rename (dragonransomware)
// Status: experimental | Level: high | ID: 76152fe9-2ac0-531b-af5d-035ae60fdb84

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
