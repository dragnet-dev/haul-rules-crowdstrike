// Dragnet [Ransomware]: dragnet-ransomware-2024-1107 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 5af51b1f-4221-55dd-a496-b2a34c45647b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
