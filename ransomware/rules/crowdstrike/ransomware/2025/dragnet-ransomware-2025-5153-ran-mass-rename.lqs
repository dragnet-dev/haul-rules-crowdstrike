// Dragnet [Ransomware]: dragnet-ransomware-2025-5153 — Mass File Rename (blacknevas)
// Status: experimental | Level: high | ID: 03897871-72a2-59f6-8585-1d202c5eaec5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
