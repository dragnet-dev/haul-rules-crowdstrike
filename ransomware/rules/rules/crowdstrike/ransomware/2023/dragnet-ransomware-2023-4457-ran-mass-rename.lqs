// Dragnet [Ransomware]: dragnet-ransomware-2023-4457 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 1796cbea-adcb-5643-9971-08773c07e8ea

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
