// Dragnet [Ransomware]: dragnet-ransomware-2023-3855 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 8be3fdd2-2cb4-5ba2-8846-3166c780629a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
