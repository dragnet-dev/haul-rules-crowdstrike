// Dragnet [Ransomware]: dragnet-ransomware-2023-1690 — Mass File Rename (noescape)
// Status: experimental | Level: high | ID: 24a1af9b-7855-52f0-a117-a848641b1723

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
