// Dragnet [Ransomware]: dragnet-ransomware-2024-4783 — Mass File Rename (dragonransomware)
// Status: experimental | Level: high | ID: 109f0676-649c-55e7-b3f4-8229a94c81ad

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
