// Dragnet [Ransomware]: dragnet-ransomware-2021-1655 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 681db11a-9870-5457-ae59-a0a348b2f406

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
