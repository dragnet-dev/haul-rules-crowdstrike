// Dragnet [Ransomware]: dragnet-ransomware-2025-7278 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 656ab64f-95b5-5838-85b2-f136e65e7be1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
