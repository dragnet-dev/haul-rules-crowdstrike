// Dragnet [Ransomware]: dragnet-ransomware-2025-1911 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 356edbfa-4027-532b-9f2b-f83cc5edb25a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
