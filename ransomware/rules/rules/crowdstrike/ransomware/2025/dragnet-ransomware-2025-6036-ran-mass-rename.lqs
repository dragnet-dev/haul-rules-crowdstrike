// Dragnet [Ransomware]: dragnet-ransomware-2025-6036 — Mass File Rename (interlock)
// Status: test | Level: high | ID: ee57e218-36a6-5612-9031-97b82a1d2dde

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
