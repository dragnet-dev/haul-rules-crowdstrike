// Dragnet [Ransomware]: dragnet-ransomware-2024-0194 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 6edb2aa9-ae7d-5f3f-b3af-2715f9d86489

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
