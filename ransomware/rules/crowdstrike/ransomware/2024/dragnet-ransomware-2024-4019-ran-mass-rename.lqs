// Dragnet [Ransomware]: dragnet-ransomware-2024-4019 — Mass File Rename (SilentRansomGroup)
// Status: deprecated | Level: high | ID: 65e01ecf-2210-5c50-bd3f-015229c6247c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
