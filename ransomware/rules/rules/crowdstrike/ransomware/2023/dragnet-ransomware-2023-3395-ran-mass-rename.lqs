// Dragnet [Ransomware]: dragnet-ransomware-2023-3395 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: c9609685-ed4d-5afc-b0e6-0412e7eb1012

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
