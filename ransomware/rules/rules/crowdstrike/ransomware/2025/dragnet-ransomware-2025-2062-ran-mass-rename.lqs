// Dragnet [Ransomware]: dragnet-ransomware-2025-2062 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 8c5f3c77-b73c-5e39-a435-c9e08946e9b1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
