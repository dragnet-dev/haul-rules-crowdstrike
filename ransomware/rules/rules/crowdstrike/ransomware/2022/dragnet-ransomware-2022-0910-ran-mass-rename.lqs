// Dragnet [Ransomware]: dragnet-ransomware-2022-0910 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 7178b4cd-7991-552a-acc0-598483f928f9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
