// Dragnet [Ransomware]: dragnet-ransomware-2025-3355 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: f448bd37-1ef6-5717-b821-a877a461a44f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
