// Dragnet [Ransomware]: dragnet-ransomware-2023-4173 — Mass File Rename (noescape)
// Status: experimental | Level: high | ID: a2412947-42ec-5bb8-9f2c-a2b848d3caf0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
