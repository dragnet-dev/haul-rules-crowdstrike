// Dragnet [Container]: dragnet-container-2026-1819 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 1d4911b3-7bd5-5cb1-b87f-c3506a454543

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *ubuntu:12.04*)
| table([timestamp, ComputerName])
| limit(1000)
