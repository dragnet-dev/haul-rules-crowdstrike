// Dragnet [Ransomware]: dragnet-ransomware-2023-4472 — Mass File Rename (stormous)
// Status: deprecated | Level: high | ID: 4ae60b8e-b356-5a83-8cdb-c29aa11ae5b5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
