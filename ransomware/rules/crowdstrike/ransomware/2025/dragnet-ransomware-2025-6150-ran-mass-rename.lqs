// Dragnet [Ransomware]: dragnet-ransomware-2025-6150 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 2f1c09e4-15cf-5353-b395-8f368edfd37b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
