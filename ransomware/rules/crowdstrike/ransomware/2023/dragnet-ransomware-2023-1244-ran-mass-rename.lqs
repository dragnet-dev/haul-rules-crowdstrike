// Dragnet [Ransomware]: dragnet-ransomware-2023-1244 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 274df78e-59ac-5b1b-9da2-b910410e1701

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
