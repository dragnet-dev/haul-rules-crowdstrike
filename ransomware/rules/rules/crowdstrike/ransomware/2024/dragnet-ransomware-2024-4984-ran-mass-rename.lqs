// Dragnet [Ransomware]: dragnet-ransomware-2024-4984 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 85e5b567-887f-5e59-9e84-d064f628b962

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
