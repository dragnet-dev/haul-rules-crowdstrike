// Dragnet [Ransomware]: dragnet-ransomware-2023-4454 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: b7039f59-d538-5b2d-b072-de64512a23f9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
