// Dragnet [Ransomware]: dragnet-ransomware-2025-3495 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 5933aab4-e0dd-55ed-9661-4390c9179603

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
