// Dragnet [Ransomware]: dragnet-ransomware-2024-0969 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 0d5f0929-ecdf-55ab-8a48-791b4f214e95

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
