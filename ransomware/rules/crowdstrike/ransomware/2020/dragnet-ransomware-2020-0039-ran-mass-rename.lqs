// Dragnet [Ransomware]: dragnet-ransomware-2020-0039 — Mass File Rename (maze)
// Status: deprecated | Level: high | ID: 9bace5ca-d579-52bc-a412-31013b23ae57

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
