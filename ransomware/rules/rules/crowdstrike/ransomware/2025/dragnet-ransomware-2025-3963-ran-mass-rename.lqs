// Dragnet [Ransomware]: dragnet-ransomware-2025-3963 — Mass File Rename (sinobi)
// Status: experimental | Level: high | ID: 139b9bea-5076-532a-9889-18967d520830

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
