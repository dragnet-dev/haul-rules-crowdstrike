// Dragnet [Ransomware]: dragnet-ransomware-2024-0153 — Mass File Rename (spacebears)
// Status: experimental | Level: high | ID: d5a2e8dc-0e7d-5953-ac59-03d986736dd2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
