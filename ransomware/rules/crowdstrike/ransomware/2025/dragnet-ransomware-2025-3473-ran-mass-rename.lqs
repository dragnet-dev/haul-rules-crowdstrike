// Dragnet [Ransomware]: dragnet-ransomware-2025-3473 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: e8241ac7-adb2-566e-8c45-35fc50dbf02d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
