// Dragnet [Ransomware]: dragnet-ransomware-2024-0389 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: e5bfe398-2450-5edd-84be-0494fdb0c274

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
