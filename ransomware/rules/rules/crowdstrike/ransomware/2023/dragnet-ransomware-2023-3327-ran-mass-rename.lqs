// Dragnet [Ransomware]: dragnet-ransomware-2023-3327 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 35241b19-b2f6-5196-a870-48322c540602

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
