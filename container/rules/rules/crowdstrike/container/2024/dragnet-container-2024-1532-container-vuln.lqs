// Dragnet [Container]: dragnet-container-2024-1532 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 92b08c1e-eef4-526a-bef2-21de83accc2e

#event_simpleName=*
| (ImageFileName = *alpine:3.10* OR ImageFileName = *alpine:3.11* OR ImageFileName = *alpine:3.12* OR ImageFileName = *alpine:3.13* OR ImageFileName = *alpine:3.14* OR ImageFileName = *alpine:3.15* OR ImageFileName = *alpine:3.8* OR ImageFileName = *alpine:3.9* OR ImageFileName = *amazonlinux:1* OR ImageFileName = *ubuntu:18.04* OR ImageFileName = *ubuntu:18.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
