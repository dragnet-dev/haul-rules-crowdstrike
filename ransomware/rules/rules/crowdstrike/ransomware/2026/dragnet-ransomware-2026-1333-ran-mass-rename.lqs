// Dragnet [Ransomware]: dragnet-ransomware-2026-1333 — Mass File Rename (nightspire)
// Status: deprecated | Level: high | ID: 8328299a-8340-5322-8192-5b5d9eab8a23

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
