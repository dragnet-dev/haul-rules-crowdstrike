// Dragnet [Ransomware]: dragnet-ransomware-2025-5282 — Mass File Rename (lockbit5)
// Status: test | Level: high | ID: 3db4a65b-d4fb-51af-aabb-442dda891062

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
