// Dragnet [Ransomware]: dragnet-ransomware-2023-4921 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 8d98832b-24bc-5b4b-9774-b613a2309dfc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
