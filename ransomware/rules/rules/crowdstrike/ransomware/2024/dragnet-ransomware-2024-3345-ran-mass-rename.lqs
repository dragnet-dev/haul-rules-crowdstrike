// Dragnet [Ransomware]: dragnet-ransomware-2024-3345 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: 33444457-d94d-5351-a57c-39188d3a965e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
