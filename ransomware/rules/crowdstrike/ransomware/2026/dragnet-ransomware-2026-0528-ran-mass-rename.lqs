// Dragnet [Ransomware]: dragnet-ransomware-2026-0528 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 94a3d63f-d384-54ac-8b36-0e3e00bcf9f1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
