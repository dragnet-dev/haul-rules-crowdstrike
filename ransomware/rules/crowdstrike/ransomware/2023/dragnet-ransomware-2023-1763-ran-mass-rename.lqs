// Dragnet [Ransomware]: dragnet-ransomware-2023-1763 — Mass File Rename (darkrace)
// Status: experimental | Level: high | ID: 145954b0-599e-5601-940d-eac5c51889b1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
