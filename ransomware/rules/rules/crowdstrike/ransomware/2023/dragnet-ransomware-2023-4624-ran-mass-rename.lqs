// Dragnet [Ransomware]: dragnet-ransomware-2023-4624 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 6f2cdbc7-5d17-5ada-a9d0-0053b1741482

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
