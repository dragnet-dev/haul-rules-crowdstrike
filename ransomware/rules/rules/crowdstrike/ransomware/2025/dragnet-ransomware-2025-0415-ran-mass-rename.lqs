// Dragnet [Ransomware]: dragnet-ransomware-2025-0415 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 1be3ac98-ec19-58f8-9ed3-cea991fe60f6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
