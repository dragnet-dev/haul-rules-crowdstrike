// Dragnet [Ransomware]: dragnet-ransomware-2023-0063 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 2cfecc05-8b49-59da-a081-1289108b1351

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
