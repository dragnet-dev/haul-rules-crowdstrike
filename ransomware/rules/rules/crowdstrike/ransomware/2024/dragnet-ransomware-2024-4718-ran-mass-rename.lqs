// Dragnet [Ransomware]: dragnet-ransomware-2024-4718 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 856db94d-f307-5638-9372-dc5835235262

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
