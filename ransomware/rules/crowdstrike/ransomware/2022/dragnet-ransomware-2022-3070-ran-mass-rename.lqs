// Dragnet [Ransomware]: dragnet-ransomware-2022-3070 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: a585330e-7d27-59e9-a9ea-47932877da7d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
