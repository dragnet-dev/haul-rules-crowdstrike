// Dragnet [Ransomware]: dragnet-ransomware-2022-1567 — Mass File Rename (leaktheanalyst)
// Status: deprecated | Level: high | ID: bba18253-9539-5a12-943e-5a89b05f6649

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
