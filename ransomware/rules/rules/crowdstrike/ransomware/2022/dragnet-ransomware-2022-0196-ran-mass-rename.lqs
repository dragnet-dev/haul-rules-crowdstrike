// Dragnet [Ransomware]: dragnet-ransomware-2022-0196 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 3dc4b67f-5775-53f7-a183-ffc3084ea092

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
