// Dragnet [Ransomware]: dragnet-ransomware-2022-3055 — Mass File Rename (midas)
// Status: deprecated | Level: high | ID: aaf014b7-ca38-5170-bc9c-4c7288deca3a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
