// Dragnet [Ransomware]: dragnet-ransomware-2023-4896 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: a54e4750-2caa-5749-8806-f7925c8dd283

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
