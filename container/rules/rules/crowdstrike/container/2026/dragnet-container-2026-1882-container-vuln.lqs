// Dragnet [Container]: dragnet-container-2026-1882 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 0bc0bb67-799f-56b3-82ee-398b18bca8fe

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:5*)
| table([timestamp, ComputerName])
| limit(1000)
