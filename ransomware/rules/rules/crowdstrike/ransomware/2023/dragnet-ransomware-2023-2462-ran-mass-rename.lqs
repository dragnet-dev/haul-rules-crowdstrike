// Dragnet [Ransomware]: dragnet-ransomware-2023-2462 — Mass File Rename (noescape)
// Status: experimental | Level: high | ID: b557e482-0b9a-56b6-b1b2-c8668851f15d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
