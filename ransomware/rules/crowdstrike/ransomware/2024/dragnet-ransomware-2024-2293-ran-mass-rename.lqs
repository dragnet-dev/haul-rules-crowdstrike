// Dragnet [Ransomware]: dragnet-ransomware-2024-2293 — Mass File Rename (safepay)
// Status: deprecated | Level: high | ID: a16bd8ed-2cd8-50a7-a061-0a55c70956a0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
