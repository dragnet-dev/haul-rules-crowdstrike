// Dragnet [Ransomware]: dragnet-ransomware-2022-3027 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: d7563507-a01a-5984-b69f-7796a05734e1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
