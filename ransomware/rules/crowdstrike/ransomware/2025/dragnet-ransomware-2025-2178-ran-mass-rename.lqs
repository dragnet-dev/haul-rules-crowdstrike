// Dragnet [Ransomware]: dragnet-ransomware-2025-2178 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: 9dd1a31c-1997-56a6-ac81-e18ec20927fe

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
