// Dragnet [Ransomware]: dragnet-ransomware-2023-1544 — Mass File Rename (cloak)
// Status: deprecated | Level: high | ID: 5c6aaa1f-3558-5ea0-b215-81d3974b2c57

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
