// Dragnet [Ransomware]: dragnet-ransomware-2021-1630 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 8893214f-63bd-5b27-9541-7002923a23a2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
