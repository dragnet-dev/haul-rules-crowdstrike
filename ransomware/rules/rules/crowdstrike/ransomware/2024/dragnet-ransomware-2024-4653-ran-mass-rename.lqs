// Dragnet [Ransomware]: dragnet-ransomware-2024-4653 — Mass File Rename (snatch)
// Status: experimental | Level: high | ID: 22591145-32f8-5bd2-9d8c-dc85feda1489

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
