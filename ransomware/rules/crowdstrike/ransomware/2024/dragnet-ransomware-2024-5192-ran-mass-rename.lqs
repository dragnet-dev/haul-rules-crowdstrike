// Dragnet [Ransomware]: dragnet-ransomware-2024-5192 — Mass File Rename (SilentRansomGroup)
// Status: deprecated | Level: high | ID: d1f4d667-829e-516b-8d08-2d4b34db9906

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
