// Dragnet [Ransomware]: dragnet-ransomware-2024-3030 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 4f66ddd9-f954-5736-80c0-40816850d391

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
