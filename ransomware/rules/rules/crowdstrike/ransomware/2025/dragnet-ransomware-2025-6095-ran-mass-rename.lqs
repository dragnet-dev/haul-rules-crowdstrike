// Dragnet [Ransomware]: dragnet-ransomware-2025-6095 — Mass File Rename (warlock)
// Status: deprecated | Level: high | ID: 0faecdc7-e362-5ec7-9356-b89c75eb6ca4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
