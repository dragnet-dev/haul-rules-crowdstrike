// Dragnet [Ransomware]: dragnet-ransomware-2023-0831 — Mass File Rename (ransomed)
// Status: experimental | Level: high | ID: 8fcdd2d8-793b-5e70-8a97-549c4fc8335e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
