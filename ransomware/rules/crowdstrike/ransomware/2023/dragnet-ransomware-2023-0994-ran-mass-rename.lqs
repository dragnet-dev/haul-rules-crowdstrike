// Dragnet [Ransomware]: dragnet-ransomware-2023-0994 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: d689748b-480e-5c07-8563-f1f9d0ea4428

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
