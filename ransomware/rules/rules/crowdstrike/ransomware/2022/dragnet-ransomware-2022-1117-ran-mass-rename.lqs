// Dragnet [Ransomware]: dragnet-ransomware-2022-1117 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 789f46f1-5966-5760-bf05-dc1d48e858f1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
