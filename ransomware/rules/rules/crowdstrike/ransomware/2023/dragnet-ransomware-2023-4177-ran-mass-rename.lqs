// Dragnet [Ransomware]: dragnet-ransomware-2023-4177 — Mass File Rename (mallox)
// Status: experimental | Level: high | ID: 81b6e012-7bbc-5e11-a3b6-1ae95505d8e4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
