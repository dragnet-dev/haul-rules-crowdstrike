// Dragnet [Ransomware]: dragnet-ransomware-2025-2541 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 5fc1ad6f-ca45-5579-b4d3-208b85ddc7f3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
