// Dragnet [Ransomware]: dragnet-ransomware-2022-0739 — Mass File Rename (ragnarlocker)
// Status: deprecated | Level: high | ID: 6398350d-7b6e-565f-adcd-4bcfe8e4d6c4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
