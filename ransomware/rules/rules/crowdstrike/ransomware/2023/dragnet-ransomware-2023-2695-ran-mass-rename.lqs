// Dragnet [Ransomware]: dragnet-ransomware-2023-2695 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 59c17172-dd17-557d-8c3c-64feea39d709

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
