// Dragnet [Ransomware]: dragnet-ransomware-2024-1573 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 3f41bcf4-be90-560a-b883-d4aa5ba15fd9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
