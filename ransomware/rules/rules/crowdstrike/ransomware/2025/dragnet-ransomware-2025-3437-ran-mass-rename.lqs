// Dragnet [Ransomware]: dragnet-ransomware-2025-3437 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 35e9bed3-5a75-55de-888a-b0faabaa37e4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
