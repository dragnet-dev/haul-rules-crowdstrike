// Dragnet [Ransomware]: dragnet-ransomware-2025-3877 — Mass File Rename (payoutsking)
// Status: experimental | Level: high | ID: b2201fa5-a021-5e94-9cff-aa2a68f10a68

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
