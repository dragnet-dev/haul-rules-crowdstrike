// Dragnet [Ransomware]: dragnet-ransomware-2023-2616 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 57f275ef-b40b-5ed9-92b7-4dd14e8f25b4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
