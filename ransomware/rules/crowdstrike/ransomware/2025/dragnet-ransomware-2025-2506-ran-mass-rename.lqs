// Dragnet [Ransomware]: dragnet-ransomware-2025-2506 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: c29fd4c9-f13d-57dc-95ee-182abbd1b201

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
