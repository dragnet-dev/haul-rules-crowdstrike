// Dragnet [Ransomware]: dragnet-ransomware-2025-4570 — Mass File Rename (ransomhouse)
// Status: test | Level: high | ID: aa04355c-6a52-568a-9678-6ce726d45c7f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
