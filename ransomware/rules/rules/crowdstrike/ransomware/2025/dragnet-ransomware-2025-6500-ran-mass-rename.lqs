// Dragnet [Ransomware]: dragnet-ransomware-2025-6500 — Mass File Rename (securotrop)
// Status: experimental | Level: high | ID: 88f32f0b-d89d-508c-8d4d-52e8e9c7c6e7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
