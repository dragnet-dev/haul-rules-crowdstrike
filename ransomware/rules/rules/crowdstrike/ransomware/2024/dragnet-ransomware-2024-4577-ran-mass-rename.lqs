// Dragnet [Ransomware]: dragnet-ransomware-2024-4577 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 31fd7630-2006-539a-a593-5f3a156fc7dd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
