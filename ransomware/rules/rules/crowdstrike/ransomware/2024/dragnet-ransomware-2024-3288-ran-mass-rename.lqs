// Dragnet [Ransomware]: dragnet-ransomware-2024-3288 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: bf6dadaa-7f30-540b-89d0-4b2f63aac756

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
