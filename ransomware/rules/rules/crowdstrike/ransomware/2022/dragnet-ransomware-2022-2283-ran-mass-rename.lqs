// Dragnet [Ransomware]: dragnet-ransomware-2022-2283 — Mass File Rename (onyx)
// Status: deprecated | Level: high | ID: 6133c247-517a-57ca-a134-ab76c8cabab2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
