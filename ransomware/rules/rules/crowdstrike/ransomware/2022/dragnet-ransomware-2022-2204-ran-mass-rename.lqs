// Dragnet [Ransomware]: dragnet-ransomware-2022-2204 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: a869460a-09cf-50be-8e42-ae567d537fee

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
