// Dragnet [Ransomware]: dragnet-ransomware-2025-5376 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 7e144f77-730f-5590-8141-51cff52af319

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
