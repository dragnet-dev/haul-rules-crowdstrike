// Dragnet [Container]: dragnet-container-2024-0719 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 77dc62f1-514b-54ec-ae43-e7af04fe186c

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
