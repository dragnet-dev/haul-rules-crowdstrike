// Dragnet [Ransomware]: dragnet-ransomware-2024-4119 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 7385c5d0-5c85-561b-ab02-03d5c899e867

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
