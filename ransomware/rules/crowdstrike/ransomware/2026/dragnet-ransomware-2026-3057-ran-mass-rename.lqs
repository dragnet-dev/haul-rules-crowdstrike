// Dragnet [Ransomware]: dragnet-ransomware-2026-3057 — Mass File Rename (dragonforce)
// Status: test | Level: high | ID: 37b291a7-eeb5-5725-bd13-95fa5d62c146

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
