// Dragnet [Ransomware]: dragnet-ransomware-2022-0373 — Mass File Rename (everest)
// Status: deprecated | Level: high | ID: 1a1cf2a6-8c6d-513b-9c5c-d666e1f9276c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
