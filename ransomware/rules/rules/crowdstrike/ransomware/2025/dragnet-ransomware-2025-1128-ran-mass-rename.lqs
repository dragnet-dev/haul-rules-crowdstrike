// Dragnet [Ransomware]: dragnet-ransomware-2025-1128 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: 1bd5b248-7e01-5676-87e7-391236132a7f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
