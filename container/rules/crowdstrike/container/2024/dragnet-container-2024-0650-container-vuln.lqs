// Dragnet [Container]: dragnet-container-2024-0650 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 566a62c8-79f0-5954-9ff7-ccc6d659e77c

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:9* OR ImageFileName = *ubuntu:14.04-ESM* OR ImageFileName = *ubuntu:16.04-ESM* OR ImageFileName = *ubuntu:18.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
