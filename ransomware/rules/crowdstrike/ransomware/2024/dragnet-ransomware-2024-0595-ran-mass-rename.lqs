// Dragnet [Ransomware]: dragnet-ransomware-2024-0595 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 30473e43-b24a-584c-a275-832648b0c9a2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
