// Dragnet [Ransomware]: dragnet-ransomware-2024-2779 — Mass File Rename (meow)
// Status: experimental | Level: high | ID: 7bc6a69b-9894-57a3-b94b-e7adb52f6038

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
