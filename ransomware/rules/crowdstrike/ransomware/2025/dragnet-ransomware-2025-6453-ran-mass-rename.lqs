// Dragnet [Ransomware]: dragnet-ransomware-2025-6453 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 850f5313-bb5b-5bae-8c80-2011685d7855

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
