// Dragnet [Ransomware]: dragnet-ransomware-2023-0495 — Mass File Rename (raworld)
// Status: experimental | Level: high | ID: e27af37f-6505-5223-9895-48b07888b39e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
