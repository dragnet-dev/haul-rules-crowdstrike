// Dragnet [Ransomware]: dragnet-ransomware-2021-0369 — Mass File Rename (marketo)
// Status: deprecated | Level: high | ID: cd2c0ac6-6ae7-5e9a-8fd0-4c2668c4cc9e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
