// Dragnet [Ransomware]: dragnet-ransomware-2025-6654 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 1bbe51b5-c785-5bd5-aeca-196e75d5bce8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
