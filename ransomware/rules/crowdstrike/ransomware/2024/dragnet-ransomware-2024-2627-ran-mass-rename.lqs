// Dragnet [Ransomware]: dragnet-ransomware-2024-2627 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: 4377a665-581a-5a55-8215-caefb958a812

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
