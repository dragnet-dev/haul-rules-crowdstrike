// Dragnet [Ransomware]: dragnet-ransomware-2025-4690 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 79256c5f-d539-54db-8279-0598a743c5aa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
