// Dragnet [Ransomware]: dragnet-ransomware-2025-2463 — Mass File Rename (thegentlemen)
// Status: test | Level: high | ID: a4353e27-02ef-579d-b145-fcba3de0002f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
