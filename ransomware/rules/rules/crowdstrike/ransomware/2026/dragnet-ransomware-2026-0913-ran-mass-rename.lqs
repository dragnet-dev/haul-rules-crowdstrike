// Dragnet [Ransomware]: dragnet-ransomware-2026-0913 — Mass File Rename (krybit)
// Status: stable | Level: high | ID: 0c4818d5-2ee3-5207-af5f-cb23e2a0796f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
