// Dragnet [Ransomware]: dragnet-ransomware-2024-5572 — Mass File Rename (ValenciaLeaks)
// Status: experimental | Level: high | ID: 5667deeb-7dee-5ab1-bec9-db93c4216053

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
