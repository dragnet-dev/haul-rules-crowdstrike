// Dragnet [Ransomware]: dragnet-ransomware-2025-3169 — Mass File Rename (rhysida)
// Status: deprecated | Level: high | ID: ef8a141a-d1aa-5d73-8937-e281d2fafadc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
