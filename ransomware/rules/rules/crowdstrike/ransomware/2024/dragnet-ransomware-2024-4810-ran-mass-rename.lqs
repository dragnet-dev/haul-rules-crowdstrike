// Dragnet [Ransomware]: dragnet-ransomware-2024-4810 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 1fa5ab9d-8d43-51c8-91cb-2037e99f8ac6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
