// Dragnet [Ransomware]: dragnet-ransomware-2023-2791 — Mass File Rename (malas)
// Status: experimental | Level: high | ID: 4495f15c-acab-5cd3-889a-9eb4e4310e49

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
