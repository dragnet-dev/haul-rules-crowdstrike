// Dragnet [Ransomware]: dragnet-ransomware-2022-0270 — Mass File Rename (cuba)
// Status: deprecated | Level: high | ID: 43ef7552-00b2-566f-b7c0-9271c2bbd418

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
