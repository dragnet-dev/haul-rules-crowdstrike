// Dragnet [Container]: dragnet-container-2024-1133 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 0e32cf62-f415-54ae-9717-601e5b17d5b1

#event_simpleName=*
| (ImageFileName = *almalinux:8* OR ImageFileName = *amazonlinux:2022* OR ImageFileName = *cbl-mariner:1.0* OR ImageFileName = *cbl-mariner:2.0* OR ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:9* OR ImageFileName = *oraclelinux:8* OR ImageFileName = *photon os:2.0* OR ImageFileName = *photon os:3.0* OR ImageFileName = *photon os:4.0* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:18.04-ESM* OR ImageFileName = *ubuntu:20.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
