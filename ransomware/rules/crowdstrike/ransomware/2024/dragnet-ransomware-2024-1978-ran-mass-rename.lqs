// Dragnet [Ransomware]: dragnet-ransomware-2024-1978 — Mass File Rename (helldown)
// Status: experimental | Level: high | ID: 03c611fc-48dc-5ebb-adcd-117fb2c27582

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
