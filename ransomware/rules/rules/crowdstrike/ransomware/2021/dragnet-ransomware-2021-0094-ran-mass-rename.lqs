// Dragnet [Ransomware]: dragnet-ransomware-2021-0094 — Mass File Rename (avaddon)
// Status: deprecated | Level: high | ID: f5ad0003-950b-5711-8863-b27d76af5d7c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
