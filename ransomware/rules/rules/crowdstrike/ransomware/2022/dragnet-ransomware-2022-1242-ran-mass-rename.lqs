// Dragnet [Ransomware]: dragnet-ransomware-2022-1242 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: 7045072e-991a-51bc-a884-9591f3aace9c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
