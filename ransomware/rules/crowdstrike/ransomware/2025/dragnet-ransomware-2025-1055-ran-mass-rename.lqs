// Dragnet [Ransomware]: dragnet-ransomware-2025-1055 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: d91601e5-4676-5447-b6bb-5dbc4832629b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
