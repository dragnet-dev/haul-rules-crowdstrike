// Dragnet [Ransomware]: dragnet-ransomware-2025-4252 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 5c824099-f285-579c-b67b-f96580bc3e7b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
