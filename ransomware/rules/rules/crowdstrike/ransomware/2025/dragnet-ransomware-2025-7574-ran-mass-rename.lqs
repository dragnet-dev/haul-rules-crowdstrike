// Dragnet [Ransomware]: dragnet-ransomware-2025-7574 — Mass File Rename (nova)
// Status: experimental | Level: high | ID: 1ab1ba41-b627-5875-aa88-274630c53de4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
