// Dragnet [Ransomware]: dragnet-ransomware-2024-5903 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: b6e64cb5-cec8-5a07-929b-01ab5a8c6e85

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
