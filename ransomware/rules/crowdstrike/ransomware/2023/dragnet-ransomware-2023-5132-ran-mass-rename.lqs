// Dragnet [Ransomware]: dragnet-ransomware-2023-5132 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 35096eba-9752-5bd5-9a9d-39e4b48cad8f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
