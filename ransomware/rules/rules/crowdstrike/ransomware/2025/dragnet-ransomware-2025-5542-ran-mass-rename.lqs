// Dragnet [Ransomware]: dragnet-ransomware-2025-5542 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: d355b909-f0c4-59f1-b8cb-6079ed487afa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
