// Dragnet [Ransomware]: dragnet-ransomware-2025-5560 — Mass File Rename (dunghill)
// Status: experimental | Level: high | ID: 21562465-f45a-56e8-b950-0a9ddf3747f1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
