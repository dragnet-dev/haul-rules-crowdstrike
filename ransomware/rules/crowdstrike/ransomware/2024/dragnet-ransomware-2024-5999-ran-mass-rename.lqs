// Dragnet [Ransomware]: dragnet-ransomware-2024-5999 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: c649b28b-9fe4-594f-b918-d8eefb774c56

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
