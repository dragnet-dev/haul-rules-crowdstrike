// Dragnet [Ransomware]: dragnet-ransomware-2025-0291 — Mass File Rename (worldleaks)
// Status: experimental | Level: high | ID: ba246eba-7b5b-5135-b693-0f881ba413f1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
