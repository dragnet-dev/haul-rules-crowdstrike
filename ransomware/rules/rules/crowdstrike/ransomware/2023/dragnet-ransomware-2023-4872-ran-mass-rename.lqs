// Dragnet [Ransomware]: dragnet-ransomware-2023-4872 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: bef01d78-ac4e-50b0-90ad-fedfab023c8d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
