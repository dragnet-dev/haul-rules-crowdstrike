// Dragnet [Ransomware]: dragnet-ransomware-2021-1301 — Mass File Rename (mountlocker)
// Status: deprecated | Level: high | ID: d6d01e2e-30f5-5ba5-aa80-bab45d7966f6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
