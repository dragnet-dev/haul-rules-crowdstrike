// Dragnet [Ransomware]: dragnet-ransomware-2025-1050 — Mass File Rename (nitrogen)
// Status: experimental | Level: high | ID: 67f22f53-563e-5150-9965-dcf4c66f2dc8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
