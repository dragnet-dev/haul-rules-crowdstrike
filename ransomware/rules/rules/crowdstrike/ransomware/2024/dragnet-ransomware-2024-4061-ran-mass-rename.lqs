// Dragnet [Ransomware]: dragnet-ransomware-2024-4061 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 9b35e10a-8614-5e39-a70e-d8739ed4c85f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
