// Dragnet [Ransomware]: dragnet-ransomware-2022-2467 — Mass File Rename (bianlian)
// Status: deprecated | Level: high | ID: 9492fc5c-c7c1-54f4-a38e-bce7806a3340

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
