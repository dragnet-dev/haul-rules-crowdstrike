// Dragnet [Ransomware]: dragnet-ransomware-2025-3643 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: c227d58a-0776-55e3-bfd4-a661ef066a5a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
