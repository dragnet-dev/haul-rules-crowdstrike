// Dragnet [Ransomware]: dragnet-ransomware-2024-2089 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 9d596547-d6f7-5e79-809f-4f7f4e97e275

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
