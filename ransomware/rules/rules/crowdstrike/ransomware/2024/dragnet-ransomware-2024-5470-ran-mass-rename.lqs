// Dragnet [Ransomware]: dragnet-ransomware-2024-5470 — Mass File Rename (dAn0n)
// Status: experimental | Level: high | ID: 5504e773-f2f7-508b-b6ef-973977f0721f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
