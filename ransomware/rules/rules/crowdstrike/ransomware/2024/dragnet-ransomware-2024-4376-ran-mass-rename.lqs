// Dragnet [Ransomware]: dragnet-ransomware-2024-4376 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 9dabc2d2-e333-5a48-85ff-0cb8ef5d356b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
