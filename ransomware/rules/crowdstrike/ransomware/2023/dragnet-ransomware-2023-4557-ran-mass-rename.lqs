// Dragnet [Ransomware]: dragnet-ransomware-2023-4557 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: e21ef634-3b4a-58f3-bb97-4308d4779ac0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
