// Dragnet [Ransomware]: dragnet-ransomware-2024-1589 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 4ef03c20-fe4e-52d6-a402-1e91677bb1ed

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
