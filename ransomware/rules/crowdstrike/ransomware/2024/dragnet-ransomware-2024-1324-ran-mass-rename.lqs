// Dragnet [Ransomware]: dragnet-ransomware-2024-1324 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 989b9f5f-f056-5763-90bb-d7842e4b29a2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
