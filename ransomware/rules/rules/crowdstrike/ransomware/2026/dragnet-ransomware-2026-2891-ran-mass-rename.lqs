// Dragnet [Ransomware]: dragnet-ransomware-2026-2891 — Mass File Rename (dragonforce)
// Status: stable | Level: high | ID: c8308eff-3b4e-5bad-b83e-6be7e58bb1e9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
