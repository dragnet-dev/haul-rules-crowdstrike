// Dragnet [Ransomware]: dragnet-ransomware-2023-4018 — Mass File Rename (play)
// Status: deprecated | Level: high | ID: 04f0b194-c9a0-5a0e-8d2b-bfae21f50135

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
