// Dragnet [Ransomware]: dragnet-ransomware-2020-0147 — Mass File Rename (coldlock)
// Status: deprecated | Level: high | ID: d9568718-96a5-51c1-a3ed-ec4c0ba59a90

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
