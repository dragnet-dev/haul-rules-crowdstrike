// Dragnet [Ransomware]: dragnet-ransomware-2022-0757 — Mass File Rename (projectrelic)
// Status: deprecated | Level: high | ID: d0730e2b-a0f6-5e01-847e-05a0375cdd89

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
