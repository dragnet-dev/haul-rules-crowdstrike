// Dragnet [Container]: dragnet-container-2024-0574 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: fab1286a-070b-59fb-a61b-6d931ed1a222

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *ubuntu:16.04* OR ImageFileName = *ubuntu:16.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
