// Dragnet [Ransomware]: dragnet-ransomware-2023-2114 — Mass File Rename (royal)
// Status: experimental | Level: high | ID: 41631e50-0166-5b96-9aa1-f4c29c834ed7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
