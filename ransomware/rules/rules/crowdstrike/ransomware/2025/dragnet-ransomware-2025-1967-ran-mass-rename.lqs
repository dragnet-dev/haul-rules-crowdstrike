// Dragnet [Ransomware]: dragnet-ransomware-2025-1967 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 9e98f66f-e7cd-518b-b20d-2030e663080c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
