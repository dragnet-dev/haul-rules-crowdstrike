// Dragnet [Ransomware]: dragnet-ransomware-2023-4952 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: bc28288e-d56f-58f9-bf6f-fb7e555f8dc8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
