// Dragnet [Ransomware]: dragnet-ransomware-2025-4461 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 655f3d88-1a9c-5007-aa51-ceeaf45680cf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
