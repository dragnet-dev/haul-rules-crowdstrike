// Dragnet [Ransomware]: dragnet-ransomware-2025-7496 — Mass File Rename (ransomhouse)
// Status: experimental | Level: high | ID: 98c989fb-08af-58d1-8393-35592d0034f4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
