// Dragnet [Ransomware]: dragnet-ransomware-2026-2161 — Mass File Rename (nightspire)
// Status: deprecated | Level: high | ID: 75663f93-5540-58b9-a5f6-bbd59bd9ba09

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
