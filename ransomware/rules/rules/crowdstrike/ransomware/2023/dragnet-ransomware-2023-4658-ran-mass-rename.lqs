// Dragnet [Ransomware]: dragnet-ransomware-2023-4658 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 39f43e88-ee82-52cb-a31f-0af225932de7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
