// Dragnet [Ransomware]: dragnet-ransomware-2022-1351 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 4f94da53-d30b-569a-838c-81520de150b8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
