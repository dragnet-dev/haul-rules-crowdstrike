// Dragnet [Ransomware]: dragnet-ransomware-2025-5400 — Mass File Rename (lunalock)
// Status: experimental | Level: high | ID: 774a74db-5347-5c95-9e30-4517834764ba

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
