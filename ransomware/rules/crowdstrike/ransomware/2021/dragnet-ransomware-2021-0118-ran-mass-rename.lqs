// Dragnet [Ransomware]: dragnet-ransomware-2021-0118 — Mass File Rename (blackmatter)
// Status: deprecated | Level: high | ID: 453e653a-cc31-5804-8989-483b0bc49338

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
