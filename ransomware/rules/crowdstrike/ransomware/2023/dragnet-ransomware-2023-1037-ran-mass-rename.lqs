// Dragnet [Ransomware]: dragnet-ransomware-2023-1037 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: b537d5c6-84e3-5378-86b5-8c4afb1a711c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
