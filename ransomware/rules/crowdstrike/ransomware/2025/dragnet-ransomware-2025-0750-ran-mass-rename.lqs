// Dragnet [Ransomware]: dragnet-ransomware-2025-0750 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: 9dc1589e-ada3-5ac8-8745-29ea529286a7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
