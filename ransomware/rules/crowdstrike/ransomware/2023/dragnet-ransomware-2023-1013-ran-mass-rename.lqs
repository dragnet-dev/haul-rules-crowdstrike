// Dragnet [Ransomware]: dragnet-ransomware-2023-1013 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 97058b06-58bf-59c1-a6bc-61504ad8b7b6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
