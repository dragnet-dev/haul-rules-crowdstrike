// Dragnet [Ransomware]: dragnet-ransomware-2024-3517 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: 51dad524-2b81-5205-8d78-c3132354b099

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
