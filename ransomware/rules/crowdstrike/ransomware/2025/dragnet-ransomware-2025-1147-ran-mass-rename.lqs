// Dragnet [Ransomware]: dragnet-ransomware-2025-1147 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 21a06623-ffb1-5ada-b574-4820af016d4b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
