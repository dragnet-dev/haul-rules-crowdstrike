// Dragnet [Ransomware]: dragnet-ransomware-2025-4672 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: c961d701-03f2-54ba-9a6b-ebaf5e46e5d3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
