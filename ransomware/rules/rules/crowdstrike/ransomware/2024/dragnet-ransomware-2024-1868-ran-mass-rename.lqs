// Dragnet [Ransomware]: dragnet-ransomware-2024-1868 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 28d56d13-8ef3-595d-8bbd-3d5a957c25df

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
