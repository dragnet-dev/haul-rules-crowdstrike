// Dragnet [Ransomware]: dragnet-ransomware-2023-2885 — Mass File Rename (malas)
// Status: experimental | Level: high | ID: 6c9ec700-5e0b-5294-abb7-2bf0926166c0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
