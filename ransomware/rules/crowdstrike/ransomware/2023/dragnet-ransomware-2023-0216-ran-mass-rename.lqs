// Dragnet [Ransomware]: dragnet-ransomware-2023-0216 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 1317a461-987c-54e0-aab2-85b9d274001a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
