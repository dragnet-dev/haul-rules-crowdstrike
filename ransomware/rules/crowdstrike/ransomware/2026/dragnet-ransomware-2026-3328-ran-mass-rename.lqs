// Dragnet [Ransomware]: dragnet-ransomware-2026-3328 — Mass File Rename (shinyhunters)
// Status: deprecated | Level: high | ID: 6aba5e2b-264c-5836-bd2c-2fdec475bfec

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
