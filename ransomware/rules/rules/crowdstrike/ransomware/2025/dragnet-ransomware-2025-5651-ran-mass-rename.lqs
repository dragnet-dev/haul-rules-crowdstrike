// Dragnet [Ransomware]: dragnet-ransomware-2025-5651 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 8578300e-d8de-5bb0-9139-8c95f22a4e07

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
