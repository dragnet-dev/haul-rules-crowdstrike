// Dragnet [Ransomware]: dragnet-ransomware-2024-5354 — Mass File Rename (ElDorado)
// Status: deprecated | Level: high | ID: 4049e656-df3e-58d9-92d1-e4d5bd0be978

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
