// Dragnet [Ransomware]: dragnet-ransomware-2021-1018 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 2fc45892-4c92-534a-8cab-e0d8bd9840f0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
