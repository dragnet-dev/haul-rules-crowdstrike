// Dragnet [Ransomware]: dragnet-ransomware-2025-4358 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: f422f0c7-d010-5d42-bf5c-bb0b95d871bd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
