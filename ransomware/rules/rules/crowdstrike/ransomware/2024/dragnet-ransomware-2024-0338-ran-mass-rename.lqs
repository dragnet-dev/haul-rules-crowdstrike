// Dragnet [Ransomware]: dragnet-ransomware-2024-0338 — Mass File Rename (cloak)
// Status: deprecated | Level: high | ID: fcca404c-34b7-565e-821b-83ba55640fb3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
