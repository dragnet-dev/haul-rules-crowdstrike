// Dragnet [Ransomware]: dragnet-ransomware-2021-1126 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 36252fae-a7d0-555e-bf3b-230a4c538388

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
