// Dragnet [Ransomware]: dragnet-ransomware-2023-2759 — Mass File Rename (malas)
// Status: experimental | Level: high | ID: 9cec196c-8a3b-535c-85ab-144751815636

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
