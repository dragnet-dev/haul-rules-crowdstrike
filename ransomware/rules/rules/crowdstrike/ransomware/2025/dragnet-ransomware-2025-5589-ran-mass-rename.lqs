// Dragnet [Ransomware]: dragnet-ransomware-2025-5589 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 507342b8-edda-537e-b06c-09d63c04a01f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
