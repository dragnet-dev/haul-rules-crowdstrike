// Dragnet [Ransomware]: dragnet-ransomware-2025-7160 — Mass File Rename (blackshrantac)
// Status: test | Level: high | ID: 1b937277-95ac-540e-afa2-cb68a91ead54

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
