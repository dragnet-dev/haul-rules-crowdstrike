// Dragnet [Ransomware]: dragnet-ransomware-2023-3792 — Mass File Rename (royal)
// Status: deprecated | Level: high | ID: 261341d9-a056-53b8-a957-3632345dbdb8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
