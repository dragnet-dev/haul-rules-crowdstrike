// Dragnet [Ransomware]: dragnet-ransomware-2024-4935 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: 594d892c-2929-5472-8ad7-47fce9119db4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
