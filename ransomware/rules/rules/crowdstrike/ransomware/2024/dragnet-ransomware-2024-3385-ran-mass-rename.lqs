// Dragnet [Ransomware]: dragnet-ransomware-2024-3385 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 90c1cf25-c570-5f7c-a8d9-0b5ba078747c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
