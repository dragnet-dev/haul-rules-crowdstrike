// Dragnet [Ransomware]: dragnet-ransomware-2022-0770 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: ebd9136c-c8ed-57ce-9a9b-b59747b3adce

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
