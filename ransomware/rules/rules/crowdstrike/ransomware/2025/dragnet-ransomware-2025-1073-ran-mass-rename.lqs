// Dragnet [Ransomware]: dragnet-ransomware-2025-1073 — Mass File Rename (warlock)
// Status: deprecated | Level: high | ID: 0d2add57-a2ee-5367-bc3d-75b68be242af

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
