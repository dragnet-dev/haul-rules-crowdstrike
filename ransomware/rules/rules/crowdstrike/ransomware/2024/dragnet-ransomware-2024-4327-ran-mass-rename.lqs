// Dragnet [Ransomware]: dragnet-ransomware-2024-4327 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: a8d99f33-053c-55f3-b0ba-b60587ddfc5b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
