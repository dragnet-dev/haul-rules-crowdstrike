// Dragnet [Ransomware]: dragnet-ransomware-2025-0050 — Mass File Rename (BrainCipher)
// Status: experimental | Level: high | ID: 79b459da-3960-5347-b999-69f3447610e0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
