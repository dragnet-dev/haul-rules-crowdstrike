// Dragnet [Ransomware]: dragnet-ransomware-2024-4678 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 5581d90e-d1e1-5187-92fc-e2dce3e0c0a7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
