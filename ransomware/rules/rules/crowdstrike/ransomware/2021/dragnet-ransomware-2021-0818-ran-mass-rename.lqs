// Dragnet [Ransomware]: dragnet-ransomware-2021-0818 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 02a210aa-ecb2-52f1-bdc3-a08ff7a3ff8c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
