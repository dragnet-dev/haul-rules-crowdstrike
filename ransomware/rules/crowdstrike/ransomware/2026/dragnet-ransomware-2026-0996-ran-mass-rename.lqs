// Dragnet [Ransomware]: dragnet-ransomware-2026-0996 — Mass File Rename (spacebears)
// Status: test | Level: high | ID: e2e3eb5b-4fd0-5a4e-9f6c-68478638b595

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
