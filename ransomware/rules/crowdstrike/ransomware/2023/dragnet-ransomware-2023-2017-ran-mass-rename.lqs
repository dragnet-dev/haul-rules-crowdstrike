// Dragnet [Ransomware]: dragnet-ransomware-2023-2017 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 2a34c230-dd11-5e3d-a509-89b12b5d0923

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
