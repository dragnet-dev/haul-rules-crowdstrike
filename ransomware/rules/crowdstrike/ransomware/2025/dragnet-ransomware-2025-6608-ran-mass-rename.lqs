// Dragnet [Ransomware]: dragnet-ransomware-2025-6608 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 099df532-ca04-5df1-aadf-54feaf1493d7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
