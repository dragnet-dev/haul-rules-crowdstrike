// Dragnet [Ransomware]: dragnet-ransomware-2020-0149 — Mass File Rename (maze)
// Status: deprecated | Level: high | ID: 6cd05dc6-0dc7-563c-ba9a-41c73c62c3d0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
