// Dragnet [Ransomware]: dragnet-ransomware-2022-2639 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 42928ea7-5a23-5018-87f4-fe5fc20582af

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
