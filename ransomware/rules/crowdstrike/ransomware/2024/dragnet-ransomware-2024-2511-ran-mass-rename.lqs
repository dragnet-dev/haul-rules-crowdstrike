// Dragnet [Ransomware]: dragnet-ransomware-2024-2511 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 19b23d70-eb02-55fb-b87b-20555fc070af

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
