// Dragnet [Ransomware]: dragnet-ransomware-2022-0295 — Mass File Rename (onyx)
// Status: deprecated | Level: high | ID: 395f8608-e5f3-54b6-9396-d80ce2aa1398

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
