// Dragnet [Ransomware]: dragnet-ransomware-2023-1366 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 89393598-7061-5633-825a-4b6a8e8a812c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
