// Dragnet [Ransomware]: dragnet-ransomware-2025-6490 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: e1160df1-ffa3-55ed-b7de-e94740dd8d8a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
