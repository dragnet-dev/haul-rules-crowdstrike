// Dragnet [Ransomware]: dragnet-ransomware-2022-3036 — Mass File Rename (revil)
// Status: deprecated | Level: high | ID: ad7c5630-117b-576e-a581-1ee21030d5db

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
