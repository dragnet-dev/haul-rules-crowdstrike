// Dragnet [Ransomware]: dragnet-ransomware-2024-2987 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 29d7bdac-0198-5e4f-a33e-c5a4c23e9df6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
