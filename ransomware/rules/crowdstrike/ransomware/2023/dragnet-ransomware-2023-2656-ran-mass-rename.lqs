// Dragnet [Ransomware]: dragnet-ransomware-2023-2656 — Mass File Rename (dragonforce)
// Status: deprecated | Level: high | ID: e07bc6bc-8960-5253-a723-bcc7b61a16e2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
