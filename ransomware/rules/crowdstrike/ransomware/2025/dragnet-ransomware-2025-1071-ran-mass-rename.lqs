// Dragnet [Ransomware]: dragnet-ransomware-2025-1071 — Mass File Rename (obscura)
// Status: experimental | Level: high | ID: 0b16b82d-4387-52fe-a7a7-c351354394c8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
