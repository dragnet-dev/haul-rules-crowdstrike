// Dragnet [Ransomware]: dragnet-ransomware-2025-4421 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 60b4cbcc-7540-54b6-9c64-8e839ff298d8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
