// Dragnet [Container]: dragnet-container-2026-1030 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 9457694e-dfeb-5384-b841-966810a9f1eb

#event_simpleName=*
| (ImageFileName = *alpine edge:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
