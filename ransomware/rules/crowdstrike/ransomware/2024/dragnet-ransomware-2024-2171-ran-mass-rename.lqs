// Dragnet [Ransomware]: dragnet-ransomware-2024-2171 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: e98d9a26-3ba5-5c7a-a02c-d489d4e27925

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
