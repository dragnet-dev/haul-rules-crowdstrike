// Dragnet [Ransomware]: dragnet-ransomware-2025-3862 — Mass File Rename (nova)
// Status: experimental | Level: high | ID: fa821392-6c7a-54f8-902b-ce625ac32cbb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
