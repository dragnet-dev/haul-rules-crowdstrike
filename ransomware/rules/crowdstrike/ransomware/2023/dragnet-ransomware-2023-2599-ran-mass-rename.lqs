// Dragnet [Ransomware]: dragnet-ransomware-2023-2599 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 865a5da9-ad84-59c5-8a6e-e39922929d1a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
