// Dragnet [Ransomware]: dragnet-ransomware-2026-1018 — Mass File Rename (thegentlemen)
// Status: test | Level: high | ID: b97f755d-0e79-56d0-a87b-1f2854b16a4b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
