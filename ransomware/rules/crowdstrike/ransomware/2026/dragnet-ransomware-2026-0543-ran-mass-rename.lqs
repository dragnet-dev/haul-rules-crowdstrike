// Dragnet [Ransomware]: dragnet-ransomware-2026-0543 — Mass File Rename (LeakBazaar)
// Status: stable | Level: high | ID: 87914fdc-dfb8-5a93-8c8f-2f284fd95db7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
