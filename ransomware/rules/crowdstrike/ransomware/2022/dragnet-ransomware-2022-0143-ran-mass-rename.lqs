// Dragnet [Ransomware]: dragnet-ransomware-2022-0143 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 1f574ba3-bbe4-5834-804b-480c629367f1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
