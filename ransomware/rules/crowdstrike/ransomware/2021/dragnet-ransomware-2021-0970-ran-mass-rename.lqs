// Dragnet [Ransomware]: dragnet-ransomware-2021-0970 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 7933b1ae-2cbf-5455-b085-be4a6bec52f3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
