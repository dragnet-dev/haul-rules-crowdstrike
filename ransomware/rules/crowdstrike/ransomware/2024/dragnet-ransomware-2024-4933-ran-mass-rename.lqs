// Dragnet [Ransomware]: dragnet-ransomware-2024-4933 — Mass File Rename (cloak)
// Status: deprecated | Level: high | ID: cf8db6c3-fc74-5a60-badb-be12b5d91b7c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
