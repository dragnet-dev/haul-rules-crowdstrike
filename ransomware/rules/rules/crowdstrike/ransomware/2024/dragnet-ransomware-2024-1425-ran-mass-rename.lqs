// Dragnet [Ransomware]: dragnet-ransomware-2024-1425 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 4bed8a28-5596-5f66-93a3-d4f6e72c7ba0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
