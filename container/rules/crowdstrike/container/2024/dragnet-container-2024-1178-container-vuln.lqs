// Dragnet [Container]: dragnet-container-2024-1178 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 66097bdb-d2b6-5362-80e1-6e375e7d13d5

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
