// Dragnet [Ransomware]: dragnet-ransomware-2021-1320 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 11170759-7ce6-5113-880a-12533bc48530

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
