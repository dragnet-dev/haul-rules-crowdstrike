// Dragnet [Ransomware]: dragnet-ransomware-2025-4185 — Mass File Rename (securotrop)
// Status: experimental | Level: high | ID: 824b08a4-8626-507d-a07d-4e135e7bbc34

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
