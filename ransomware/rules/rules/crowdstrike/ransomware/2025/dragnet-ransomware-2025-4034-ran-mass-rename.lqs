// Dragnet [Ransomware]: dragnet-ransomware-2025-4034 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 751e9646-5dbc-5c91-aea8-1a15a189bcd9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
