// Dragnet [Ransomware]: dragnet-ransomware-2023-4298 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 882970ab-6cd7-5e52-8fba-0f26f82d2889

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
