// Dragnet [Ransomware]: dragnet-ransomware-2023-3501 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 5c9ac5f2-25b7-59df-a11b-7a6db2735bb0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
