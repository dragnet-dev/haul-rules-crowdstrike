// Dragnet [Ransomware]: dragnet-ransomware-2024-5755 — Mass File Rename (chort)
// Status: experimental | Level: high | ID: 61c4f83e-4e43-5668-a0d7-8b4c8d82ca52

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
