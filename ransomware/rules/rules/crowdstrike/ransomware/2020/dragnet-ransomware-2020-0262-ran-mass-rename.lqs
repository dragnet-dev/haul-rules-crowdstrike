// Dragnet [Ransomware]: dragnet-ransomware-2020-0262 — Mass File Rename (revil)
// Status: deprecated | Level: high | ID: 11bbfe9d-f17d-5e2f-8c4f-74ecd2869798

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
