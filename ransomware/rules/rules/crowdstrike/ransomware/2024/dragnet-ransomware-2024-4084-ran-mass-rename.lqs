// Dragnet [Ransomware]: dragnet-ransomware-2024-4084 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: 6bfc9a5a-f9a7-5b59-b7b3-24fa3832cbca

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
