// Dragnet [Ransomware]: dragnet-ransomware-2025-6392 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: 68baedba-1082-5d9e-84d9-acdf46942dac

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
