// Dragnet [Ransomware]: dragnet-ransomware-2025-5698 — Mass File Rename (handala)
// Status: experimental | Level: high | ID: 96a884e5-bfda-589a-bc0e-4d1b06b8e99f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
