// Dragnet [Ransomware]: dragnet-ransomware-2024-0948 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 16600b79-6872-51e8-91fe-2ae81b6748c1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
