// Dragnet [Ransomware]: dragnet-ransomware-2022-0139 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 1cb13db5-bc02-5589-938b-3504dd15c36f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
