// Dragnet [Ransomware]: dragnet-ransomware-2022-0160 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 0e3be6b1-75ef-5842-8ad3-99866e431188

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
