// Dragnet [Ransomware]: dragnet-ransomware-2022-1830 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: f6deb840-f679-5291-b2b1-c349a8dd9f11

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
