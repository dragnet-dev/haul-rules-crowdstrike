// Dragnet [Container]: dragnet-container-2026-1268 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: a0710ca0-6ca5-59c0-ad4b-faf0088b6a2e

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6*)
| table([timestamp, ComputerName])
| limit(1000)
