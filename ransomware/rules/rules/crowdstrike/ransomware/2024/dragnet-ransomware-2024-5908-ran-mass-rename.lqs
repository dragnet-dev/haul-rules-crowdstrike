// Dragnet [Ransomware]: dragnet-ransomware-2024-5908 — Mass File Rename (redransomware)
// Status: deprecated | Level: high | ID: 8ac17eb2-b533-5097-85b6-022442229a87

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
