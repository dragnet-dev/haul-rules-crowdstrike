// Dragnet [Ransomware]: dragnet-ransomware-2020-0174 — Mass File Rename (sekhmet)
// Status: deprecated | Level: high | ID: 04e1ce02-4565-566d-9551-ba234a7d5a27

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
