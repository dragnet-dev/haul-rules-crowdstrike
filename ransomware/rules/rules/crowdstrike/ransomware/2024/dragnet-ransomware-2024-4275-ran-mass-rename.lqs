// Dragnet [Ransomware]: dragnet-ransomware-2024-4275 — Mass File Rename (coinbasecartel)
// Status: experimental | Level: high | ID: 7df711ab-833d-5045-a99c-d983c97fea90

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
