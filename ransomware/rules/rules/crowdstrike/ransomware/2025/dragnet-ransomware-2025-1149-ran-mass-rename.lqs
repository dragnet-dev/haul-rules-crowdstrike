// Dragnet [Ransomware]: dragnet-ransomware-2025-1149 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: b107dffd-46e2-5b9a-acc9-51018dd105a0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
