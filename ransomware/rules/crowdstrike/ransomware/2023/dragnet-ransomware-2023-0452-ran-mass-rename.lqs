// Dragnet [Ransomware]: dragnet-ransomware-2023-0452 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: e7169274-ee6b-5f45-b364-7dbb73649291

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
