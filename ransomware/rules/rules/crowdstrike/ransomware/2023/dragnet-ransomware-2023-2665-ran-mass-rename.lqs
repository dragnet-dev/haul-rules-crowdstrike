// Dragnet [Ransomware]: dragnet-ransomware-2023-2665 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 34613513-52a2-5594-a92a-caccaf753558

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
