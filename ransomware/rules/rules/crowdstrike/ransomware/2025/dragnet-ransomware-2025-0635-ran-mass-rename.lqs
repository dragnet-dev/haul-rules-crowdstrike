// Dragnet [Ransomware]: dragnet-ransomware-2025-0635 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 3c21840b-0d42-532c-a0e8-4fc0cf460eaa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
