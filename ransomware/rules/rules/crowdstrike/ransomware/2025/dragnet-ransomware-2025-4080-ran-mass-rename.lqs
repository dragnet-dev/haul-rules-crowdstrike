// Dragnet [Ransomware]: dragnet-ransomware-2025-4080 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: 10eb251a-6487-5285-9800-1ad9b4f443f2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
