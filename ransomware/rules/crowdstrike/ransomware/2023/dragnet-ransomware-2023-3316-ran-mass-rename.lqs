// Dragnet [Ransomware]: dragnet-ransomware-2023-3316 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 8cac014f-8a84-5cb5-91a1-05dce4972c1e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
