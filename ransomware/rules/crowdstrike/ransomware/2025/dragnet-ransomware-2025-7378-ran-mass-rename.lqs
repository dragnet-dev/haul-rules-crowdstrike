// Dragnet [Ransomware]: dragnet-ransomware-2025-7378 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: 11958d4c-f2c0-52fc-b88c-cb9ccfc752b7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
