// Dragnet [Container]: dragnet-container-2025-0178 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 7996261d-54f3-53a0-abf3-23c415278e1b

#event_simpleName=*
| (ImageFileName = *chainguard:* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:9* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:24.04* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
