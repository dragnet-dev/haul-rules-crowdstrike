// Dragnet [Container]: dragnet-container-2024-1154 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: c546aeb7-3c98-55cf-a901-6166af89a125

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:9*)
| table([timestamp, ComputerName])
| limit(1000)
