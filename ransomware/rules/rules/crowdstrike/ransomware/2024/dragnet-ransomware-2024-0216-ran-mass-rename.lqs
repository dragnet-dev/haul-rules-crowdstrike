// Dragnet [Ransomware]: dragnet-ransomware-2024-0216 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 0e490586-7212-5c20-b129-44bfbbb57c9f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
