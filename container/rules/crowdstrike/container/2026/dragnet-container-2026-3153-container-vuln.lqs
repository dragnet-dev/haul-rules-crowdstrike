// Dragnet [Container]: dragnet-container-2026-3153 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 1cdc45ab-248c-5eb5-a3bc-0bb875c8b622

#event_simpleName=*
| (ImageFileName = *amazonlinux:1* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *ubuntu:12.04*)
| table([timestamp, ComputerName])
| limit(1000)
