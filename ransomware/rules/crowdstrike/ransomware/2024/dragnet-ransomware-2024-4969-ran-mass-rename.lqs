// Dragnet [Ransomware]: dragnet-ransomware-2024-4969 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 9bb3e757-96ac-5787-8210-be64dd204638

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
