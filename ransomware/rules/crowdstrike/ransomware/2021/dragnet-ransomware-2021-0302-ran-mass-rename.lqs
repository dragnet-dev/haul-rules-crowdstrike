// Dragnet [Ransomware]: dragnet-ransomware-2021-0302 — Mass File Rename (azroteam)
// Status: deprecated | Level: high | ID: 060a444c-3c7b-52c1-83f6-f3c7edb249ad

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
