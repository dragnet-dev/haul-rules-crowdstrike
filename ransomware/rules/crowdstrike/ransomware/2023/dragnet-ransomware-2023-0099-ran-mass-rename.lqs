// Dragnet [Ransomware]: dragnet-ransomware-2023-0099 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 9d705302-341d-5403-a292-a37df3793b34

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
