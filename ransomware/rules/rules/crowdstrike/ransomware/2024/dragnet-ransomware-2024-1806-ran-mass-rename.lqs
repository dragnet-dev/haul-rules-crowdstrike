// Dragnet [Ransomware]: dragnet-ransomware-2024-1806 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 702fc4c5-4b2a-5cda-abb5-4c7d9aeda7d2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
