// Dragnet [Ransomware]: dragnet-ransomware-2025-3865 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 55ce68bd-d701-5510-970b-0125c1d7ccca

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
