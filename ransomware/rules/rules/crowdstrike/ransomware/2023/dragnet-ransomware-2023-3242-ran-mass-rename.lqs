// Dragnet [Ransomware]: dragnet-ransomware-2023-3242 — Mass File Rename (ragnarlocker)
// Status: experimental | Level: high | ID: d3439151-c372-59dd-a118-84172ceea86c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
