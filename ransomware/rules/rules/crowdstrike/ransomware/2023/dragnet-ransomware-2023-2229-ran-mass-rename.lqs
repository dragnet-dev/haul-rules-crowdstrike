// Dragnet [Ransomware]: dragnet-ransomware-2023-2229 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 0e84e63a-870c-56b8-9876-a0c66cbe7f3c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
