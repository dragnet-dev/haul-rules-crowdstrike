// Dragnet [Ransomware]: dragnet-ransomware-2023-5204 — Mass File Rename (ragnarlocker)
// Status: experimental | Level: high | ID: b81882e7-bdff-527f-a059-8fffe694cda2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
