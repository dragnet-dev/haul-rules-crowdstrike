// Dragnet [Ransomware]: dragnet-ransomware-2024-0933 — Mass File Rename (handala)
// Status: experimental | Level: high | ID: e5858992-61db-57ce-a451-61dd0e8828ba

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
