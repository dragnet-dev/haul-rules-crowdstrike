// Dragnet [Ransomware]: dragnet-ransomware-2021-1267 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: f373cc99-a4a0-505c-a767-e89f07ab1d8d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
