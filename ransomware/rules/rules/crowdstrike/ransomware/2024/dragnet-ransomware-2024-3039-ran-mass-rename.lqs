// Dragnet [Ransomware]: dragnet-ransomware-2024-3039 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: 389b8aad-c5a7-5fd8-a25d-8ec18c776ccb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
