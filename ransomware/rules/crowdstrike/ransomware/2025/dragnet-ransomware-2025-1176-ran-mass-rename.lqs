// Dragnet [Ransomware]: dragnet-ransomware-2025-1176 — Mass File Rename (direwolf)
// Status: experimental | Level: high | ID: d54e3e09-9131-5833-85c5-c584cc29a416

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
