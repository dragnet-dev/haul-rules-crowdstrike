// Dragnet [Ransomware]: dragnet-ransomware-2022-1339 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 81abd757-f2ac-52e5-9eda-0ffff4ceb4f0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
