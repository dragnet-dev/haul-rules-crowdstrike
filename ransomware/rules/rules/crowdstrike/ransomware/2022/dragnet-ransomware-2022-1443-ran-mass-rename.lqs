// Dragnet [Ransomware]: dragnet-ransomware-2022-1443 — Mass File Rename (avoslocker)
// Status: deprecated | Level: high | ID: 7f1902ae-c415-566c-ba15-086cbfeb3e4f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
