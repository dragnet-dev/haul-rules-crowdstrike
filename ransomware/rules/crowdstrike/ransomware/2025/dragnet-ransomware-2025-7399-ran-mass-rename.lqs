// Dragnet [Ransomware]: dragnet-ransomware-2025-7399 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: 235c6c28-ff95-583f-9015-e358a26167bf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
