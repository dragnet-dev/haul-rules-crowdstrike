// Dragnet [Container]: dragnet-container-2026-2474 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: ede44fc0-e7a7-53ed-b2fa-ae89e038c144

#event_simpleName=*
| (ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10* OR ImageFileName = *ubuntu:13.04* OR ImageFileName = *ubuntu:13.10*)
| table([timestamp, ComputerName])
| limit(1000)
