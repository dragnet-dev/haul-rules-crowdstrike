// Dragnet [Ransomware]: dragnet-ransomware-2022-1924 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: 7a66c7ce-cc2e-5222-b9d5-24eea1c4767b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
