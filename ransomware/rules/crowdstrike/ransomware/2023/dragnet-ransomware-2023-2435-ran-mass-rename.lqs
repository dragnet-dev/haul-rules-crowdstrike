// Dragnet [Ransomware]: dragnet-ransomware-2023-2435 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 4e298f7f-7091-5c3a-b024-2033d5a4f6f9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
