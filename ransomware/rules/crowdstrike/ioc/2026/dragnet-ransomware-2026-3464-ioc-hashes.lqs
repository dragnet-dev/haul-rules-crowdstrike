// Dragnet [IOC]: dragnet-ransomware-2026-3464 — Malicious File Hash
// Status: test | Level: medium | ID: e599e6a8-ff5d-5342-86d7-8d3528f7e6b3

#event_simpleName=PeFileWritten OR #event_simpleName=NewExecutableWritten
| (MD5HashData = "7886f04af218392a1688528ff599a4eb" OR MD5HashData = "35702b428046bc2eca42ec97adf4f598")
| table([timestamp, ComputerName, FilePath, ImageFileName])
| limit(1000)
