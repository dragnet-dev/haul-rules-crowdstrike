// Dragnet [Ransomware]: dragnet-ransomware-2025-2405 — Mass File Rename (thegentlemen)
// Status: experimental | Level: high | ID: e77e3ecd-d56f-52cd-b282-a4753adb44fc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
