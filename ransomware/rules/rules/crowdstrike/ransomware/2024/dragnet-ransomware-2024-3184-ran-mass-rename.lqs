// Dragnet [Ransomware]: dragnet-ransomware-2024-3184 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: ad667fbc-20c9-5097-991e-46026302ebd5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
