// Dragnet [Container]: dragnet-container-2026-1867 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: c6f371e9-1237-5a1c-ad32-e13e274c3190

#event_simpleName=*
| (ImageFileName = *chainguard:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:7* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:14.04* OR ImageFileName = *ubuntu:14.04-ESM* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
