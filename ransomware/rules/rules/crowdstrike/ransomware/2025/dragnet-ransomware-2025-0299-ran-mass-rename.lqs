// Dragnet [Ransomware]: dragnet-ransomware-2025-0299 — Mass File Rename (worldleaks)
// Status: experimental | Level: high | ID: cbc48fa3-91b2-51d2-835e-e44820a8d64a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
