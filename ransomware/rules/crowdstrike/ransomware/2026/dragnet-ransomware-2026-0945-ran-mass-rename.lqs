// Dragnet [Ransomware]: dragnet-ransomware-2026-0945 — Mass File Rename (payload)
// Status: stable | Level: high | ID: f3c0778e-70eb-5e0b-9087-238719bff24d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
