// Dragnet [Ransomware]: dragnet-ransomware-2025-1420 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: a99b457f-6086-5bdb-930d-123ae965e3c3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
