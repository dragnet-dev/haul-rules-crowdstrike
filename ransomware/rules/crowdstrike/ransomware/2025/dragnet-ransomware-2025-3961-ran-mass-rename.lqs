// Dragnet [Ransomware]: dragnet-ransomware-2025-3961 — Mass File Rename (nightspire)
// Status: deprecated | Level: high | ID: 8160ed42-8c66-5a93-8f04-f8ff34565234

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
