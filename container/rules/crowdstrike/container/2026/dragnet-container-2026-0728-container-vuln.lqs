// Dragnet [Container]: dragnet-container-2026-0728 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: beaab2c1-2017-58cd-9cb4-dd02a62a71c2

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:7* OR ImageFileName = *debian:8*)
| table([timestamp, ComputerName])
| limit(1000)
