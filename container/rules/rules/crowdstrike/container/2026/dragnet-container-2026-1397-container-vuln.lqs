// Dragnet [Container]: dragnet-container-2026-1397 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: fa4e8c8f-06b6-5427-85bb-cd6c50a115e0

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:7* OR ImageFileName = *debian:8* OR ImageFileName = *redhat/ubi9:*)
| table([timestamp, ComputerName])
| limit(1000)
