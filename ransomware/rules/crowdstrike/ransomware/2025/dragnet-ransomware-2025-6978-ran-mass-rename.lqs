// Dragnet [Ransomware]: dragnet-ransomware-2025-6978 — Mass File Rename (securotrop)
// Status: experimental | Level: high | ID: 3415c9c9-9923-59bc-9dff-d538edac6f24

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
