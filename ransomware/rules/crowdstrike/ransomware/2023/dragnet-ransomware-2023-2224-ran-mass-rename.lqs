// Dragnet [Ransomware]: dragnet-ransomware-2023-2224 — Mass File Rename (knight)
// Status: experimental | Level: high | ID: 1500f5de-0804-5dbc-a9d3-b936d4e96eeb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
