// Dragnet [Ransomware]: dragnet-ransomware-2022-2009 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: bcbde450-b22a-5315-8f91-3a525978d87c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
