// Dragnet [Ransomware]: dragnet-ransomware-2025-5115 — Mass File Rename (sinobi)
// Status: experimental | Level: high | ID: 6db55a18-2940-50e8-b1cc-79e93fe979ce

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
