// Dragnet [Ransomware]: dragnet-ransomware-2025-7529 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: 5ea21bf3-19f5-57a1-bc25-08744723512e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
