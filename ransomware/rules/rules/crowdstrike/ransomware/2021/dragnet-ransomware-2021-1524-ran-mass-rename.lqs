// Dragnet [Ransomware]: dragnet-ransomware-2021-1524 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 8e1d1e00-f6d8-5e19-b34a-772261ef9f6f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
