// Dragnet [Ransomware]: dragnet-ransomware-2024-1346 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: 9c188871-bd68-5bfe-a874-6d59afd7850b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
