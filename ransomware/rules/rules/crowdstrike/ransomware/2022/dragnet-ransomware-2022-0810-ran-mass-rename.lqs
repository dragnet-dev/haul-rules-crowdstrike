// Dragnet [Ransomware]: dragnet-ransomware-2022-0810 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 21976a9f-20c6-5993-9e2b-d8fcb307fe57

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
