// Dragnet [Ransomware]: dragnet-ransomware-2023-2824 — Mass File Rename (malas)
// Status: experimental | Level: high | ID: 620550f6-ab55-5058-991c-7146b2fb65a9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
