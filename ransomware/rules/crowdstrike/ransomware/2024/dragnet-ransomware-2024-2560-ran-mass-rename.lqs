// Dragnet [Ransomware]: dragnet-ransomware-2024-2560 — Mass File Rename (frag)
// Status: deprecated | Level: high | ID: 213128f7-a96c-53fe-b568-1fd747f46a9e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
