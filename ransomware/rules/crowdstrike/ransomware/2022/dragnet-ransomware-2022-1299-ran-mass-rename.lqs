// Dragnet [Ransomware]: dragnet-ransomware-2022-1299 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 4baac439-4d80-5b6d-a97f-7f88f0bc4b87

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
