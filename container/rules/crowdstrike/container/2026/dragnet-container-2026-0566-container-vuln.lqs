// Dragnet [Container]: dragnet-container-2026-0566 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 6fe7b3fd-e089-58d3-a038-5a1e7d7d3966

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:8* OR ImageFileName = *debian:9*)
| table([timestamp, ComputerName])
| limit(1000)
