// Dragnet [Ransomware]: dragnet-ransomware-2021-0381 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 6b2a84f6-c80d-5350-8a26-bab37d2b9443

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
