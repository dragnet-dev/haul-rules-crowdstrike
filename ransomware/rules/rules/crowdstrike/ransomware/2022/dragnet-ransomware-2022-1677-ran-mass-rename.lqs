// Dragnet [Ransomware]: dragnet-ransomware-2022-1677 — Mass File Rename (play)
// Status: deprecated | Level: high | ID: 57f0307e-9264-5401-90c3-dcee0af77015

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
