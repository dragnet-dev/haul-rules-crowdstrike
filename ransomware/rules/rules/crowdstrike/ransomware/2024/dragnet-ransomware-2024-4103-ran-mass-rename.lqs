// Dragnet [Ransomware]: dragnet-ransomware-2024-4103 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: ea2c0a28-90a0-55d7-affa-f622785d3c3c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
