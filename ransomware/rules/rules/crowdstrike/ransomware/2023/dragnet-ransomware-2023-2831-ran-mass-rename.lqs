// Dragnet [Ransomware]: dragnet-ransomware-2023-2831 — Mass File Rename (malas)
// Status: experimental | Level: high | ID: 1a1c1884-2a13-5eeb-889f-b50f93e6bbe4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
