// Dragnet [Ransomware]: dragnet-ransomware-2025-1941 — Mass File Rename (flocker)
// Status: experimental | Level: high | ID: 139ab050-1d5f-57be-82e2-a06771ff8199

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
