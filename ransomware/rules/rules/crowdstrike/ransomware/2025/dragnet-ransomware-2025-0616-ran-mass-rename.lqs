// Dragnet [Ransomware]: dragnet-ransomware-2025-0616 — Mass File Rename (beast)
// Status: experimental | Level: high | ID: 4e327eae-d248-52f6-9636-28f26155068f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
