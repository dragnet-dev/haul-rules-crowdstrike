// Dragnet [Ransomware]: dragnet-ransomware-2021-1480 — Mass File Rename (spook)
// Status: deprecated | Level: high | ID: 1d673891-b607-5571-8c15-94672e5ff835

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
