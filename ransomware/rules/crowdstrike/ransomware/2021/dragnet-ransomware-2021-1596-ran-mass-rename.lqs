// Dragnet [Ransomware]: dragnet-ransomware-2021-1596 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: aa868e69-8a76-5fcc-9fdc-43f763aeab0b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
