// Dragnet [Ransomware]: dragnet-ransomware-2022-0148 — Mass File Rename (royal)
// Status: deprecated | Level: high | ID: 75481779-4f4c-547f-b56f-cd09f98985d3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
