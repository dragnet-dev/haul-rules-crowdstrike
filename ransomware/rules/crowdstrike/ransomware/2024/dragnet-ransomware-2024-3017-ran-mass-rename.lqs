// Dragnet [Ransomware]: dragnet-ransomware-2024-3017 — Mass File Rename (stormous)
// Status: experimental | Level: high | ID: 94509e20-4350-551c-85b3-163b4d6feee5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
