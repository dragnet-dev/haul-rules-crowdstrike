// Dragnet [Ransomware]: dragnet-ransomware-2026-2488 — Mass File Rename (safepay)
// Status: stable | Level: high | ID: 12b79af3-1bd4-5795-b94f-e6d302b5f837

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
