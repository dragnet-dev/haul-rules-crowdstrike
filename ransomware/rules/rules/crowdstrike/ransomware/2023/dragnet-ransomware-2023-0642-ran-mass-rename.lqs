// Dragnet [Ransomware]: dragnet-ransomware-2023-0642 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 618c33d5-a613-5d88-9353-9c60fca91744

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
