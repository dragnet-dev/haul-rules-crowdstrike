// Dragnet [Container]: dragnet-container-2026-2944 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: ba906c92-700a-5a74-b47f-c9e62c2db035

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:5*)
| table([timestamp, ComputerName])
| limit(1000)
