// Dragnet [Ransomware]: dragnet-ransomware-2025-3529 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 6cd6b9bb-9496-5b5f-a2d2-82a699c1473b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
