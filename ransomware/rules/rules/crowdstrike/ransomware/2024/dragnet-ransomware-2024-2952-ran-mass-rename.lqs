// Dragnet [Ransomware]: dragnet-ransomware-2024-2952 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: e2174fb3-7709-5957-9551-ab9db739ec6f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
