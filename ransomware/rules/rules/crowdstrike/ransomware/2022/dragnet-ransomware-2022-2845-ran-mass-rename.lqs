// Dragnet [Ransomware]: dragnet-ransomware-2022-2845 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: a3d81719-7276-5920-91b9-3268ace03cdd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
