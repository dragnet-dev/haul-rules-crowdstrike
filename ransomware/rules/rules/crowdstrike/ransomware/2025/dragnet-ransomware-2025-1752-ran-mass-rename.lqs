// Dragnet [Ransomware]: dragnet-ransomware-2025-1752 — Mass File Rename (spacebears)
// Status: experimental | Level: high | ID: 36701d7a-2e02-5112-88f3-a1df22f12d8b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
