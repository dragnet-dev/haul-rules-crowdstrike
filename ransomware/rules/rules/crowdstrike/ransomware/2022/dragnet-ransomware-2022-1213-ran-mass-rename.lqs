// Dragnet [Ransomware]: dragnet-ransomware-2022-1213 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 7dffa15c-94fe-502b-b0af-d1c6d13c4359

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
