// Dragnet [Ransomware]: dragnet-ransomware-2022-2718 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 7ce61eeb-ce70-5419-a836-05e4f217bf6f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
