// Dragnet [Ransomware]: dragnet-ransomware-2025-0112 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 8bb52680-bc9d-5067-9850-eeb49109eb1f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
