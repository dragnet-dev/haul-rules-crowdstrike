// Dragnet [Ransomware]: dragnet-ransomware-2025-4942 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: f176b8fe-b13b-560b-b07b-0980ed56b7f8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
