// Dragnet [Ransomware]: dragnet-ransomware-2024-2445 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 62580b4e-098f-53fc-bc54-d2848c272770

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
