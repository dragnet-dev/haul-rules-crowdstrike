// Dragnet [Ransomware]: dragnet-ransomware-2022-3033 — Mass File Rename (vicesociety)
// Status: deprecated | Level: high | ID: 8d2742de-6ef2-5bcc-933b-fd8cc6af8ba5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
