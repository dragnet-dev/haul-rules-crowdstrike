// Dragnet [Ransomware]: dragnet-ransomware-2023-0792 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 3e69fb9c-ef4d-5cd1-9548-cc2d905aa7a8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
