// Dragnet [Ransomware]: dragnet-ransomware-2023-0975 — Mass File Rename (threeam)
// Status: experimental | Level: high | ID: c9b37641-8a8c-54b3-9140-4226a38313b3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
