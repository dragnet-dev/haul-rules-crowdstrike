// Dragnet [Ransomware]: dragnet-ransomware-2024-0498 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: a653a3db-c2f1-57c7-a177-a55ed5fe5bc3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
