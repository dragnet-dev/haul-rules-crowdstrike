// Dragnet [Ransomware]: dragnet-ransomware-2024-0547 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 3630c986-9598-58e7-8b1a-867dead61cb4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
