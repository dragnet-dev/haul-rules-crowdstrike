// Dragnet [Ransomware]: dragnet-ransomware-2026-1642 — Mass File Rename (worldleaks)
// Status: test | Level: high | ID: f84e2d96-eaaa-5ebd-8a70-854c7990798c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
