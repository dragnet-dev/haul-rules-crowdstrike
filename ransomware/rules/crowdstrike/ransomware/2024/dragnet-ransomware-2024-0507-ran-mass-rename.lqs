// Dragnet [Ransomware]: dragnet-ransomware-2024-0507 — Mass File Rename (dragonforce)
// Status: deprecated | Level: high | ID: bd4da5f9-835c-5e22-adcf-29e4e5e21702

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
