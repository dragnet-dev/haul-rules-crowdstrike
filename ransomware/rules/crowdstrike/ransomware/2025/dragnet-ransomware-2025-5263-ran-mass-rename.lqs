// Dragnet [Ransomware]: dragnet-ransomware-2025-5263 — Mass File Rename (flocker)
// Status: experimental | Level: high | ID: 83f1f759-d872-579c-977a-4ea3c11bf6ab

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
