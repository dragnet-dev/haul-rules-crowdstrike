// Dragnet [Ransomware]: dragnet-ransomware-2025-4473 — Mass File Rename (monti)
// Status: experimental | Level: high | ID: 477b1b7e-4c7c-5bfe-b492-a896ff4472d9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
