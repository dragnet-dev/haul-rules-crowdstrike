// Dragnet [Ransomware]: dragnet-ransomware-2024-5938 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 8f752df4-5727-57d8-873d-836c7b1cdd11

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
