// Dragnet [Ransomware]: dragnet-ransomware-2024-4171 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: 69963cdb-c456-57dc-b2da-d52a17fbf1d8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
