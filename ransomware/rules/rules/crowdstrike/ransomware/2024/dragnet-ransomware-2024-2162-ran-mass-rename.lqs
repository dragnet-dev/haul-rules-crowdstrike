// Dragnet [Ransomware]: dragnet-ransomware-2024-2162 — Mass File Rename (dragonforce)
// Status: deprecated | Level: high | ID: 19e7bcd7-ff0b-58e7-9b54-95e8fdfccc4c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
