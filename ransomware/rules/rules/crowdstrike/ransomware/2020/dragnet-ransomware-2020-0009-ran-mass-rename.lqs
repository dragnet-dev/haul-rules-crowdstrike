// Dragnet [Ransomware]: dragnet-ransomware-2020-0009 — Mass File Rename (ryuk)
// Status: deprecated | Level: high | ID: 0dcf47b5-986f-5b19-a721-8f0e964ee529

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
