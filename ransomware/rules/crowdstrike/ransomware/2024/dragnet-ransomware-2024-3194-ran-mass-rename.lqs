// Dragnet [Ransomware]: dragnet-ransomware-2024-3194 — Mass File Rename (dragonransomware)
// Status: experimental | Level: high | ID: 1f0c43ad-ca6f-5c11-8d6f-ef9370e5259f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
