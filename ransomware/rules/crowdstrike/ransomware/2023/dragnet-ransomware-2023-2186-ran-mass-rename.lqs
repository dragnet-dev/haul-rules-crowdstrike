// Dragnet [Ransomware]: dragnet-ransomware-2023-2186 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 48f2ee0b-8555-5087-a1fa-74cb0bb8b7f7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
