// Dragnet [Ransomware]: dragnet-ransomware-2025-4125 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 8e948810-4089-515d-aeca-d42e8667e4cf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
