// Dragnet [Ransomware]: dragnet-ransomware-2025-6944 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 378b4aef-c228-5c76-9d89-c04ae4e2fb6a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
