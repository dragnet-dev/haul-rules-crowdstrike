// Dragnet [Ransomware]: dragnet-ransomware-2024-4320 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 94fa5b0e-b13a-565a-800b-b1cd00c7f7d0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
