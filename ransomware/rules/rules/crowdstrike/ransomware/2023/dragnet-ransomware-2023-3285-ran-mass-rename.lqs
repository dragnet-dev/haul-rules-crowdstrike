// Dragnet [Ransomware]: dragnet-ransomware-2023-3285 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 5727c27e-b44b-52e7-bf51-fe1d28a552a6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
