// Dragnet [Ransomware]: dragnet-ransomware-2024-4614 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: 5d126489-4839-59ab-918e-9a34ef89d605

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
