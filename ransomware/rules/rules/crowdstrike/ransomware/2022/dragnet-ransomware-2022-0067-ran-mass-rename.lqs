// Dragnet [Ransomware]: dragnet-ransomware-2022-0067 — Mass File Rename (royal)
// Status: deprecated | Level: high | ID: 25d5cc73-405f-531e-a6b1-38e731df52ec

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
