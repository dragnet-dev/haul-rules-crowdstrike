// Dragnet [Ransomware]: dragnet-ransomware-2025-0446 — Mass File Rename (nova)
// Status: experimental | Level: high | ID: 18b54133-3151-50a0-a8ca-6f8f66572be8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
