// Dragnet [Ransomware]: dragnet-ransomware-2025-4777 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 6fe7a58d-fe99-5822-9c03-c99229e8c8ab

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
