// Dragnet [Ransomware]: dragnet-ransomware-2023-4868 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: ab2c331e-3cdb-5a82-a19b-ec133eb002c8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
