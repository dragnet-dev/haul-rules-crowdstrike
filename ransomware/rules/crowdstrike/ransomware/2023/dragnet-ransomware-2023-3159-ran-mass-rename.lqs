// Dragnet [Ransomware]: dragnet-ransomware-2023-3159 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 922bc712-737a-52d7-b204-a0cc9cf1398a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
