// Dragnet [Ransomware]: dragnet-ransomware-2022-3143 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 6ec48c9b-493e-5c9f-a689-4ef7696e37cb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
