// Dragnet [Ransomware]: dragnet-ransomware-2023-1416 — Mass File Rename (noescape)
// Status: experimental | Level: high | ID: 4a247f9b-ab97-52c4-9aac-13d41f18f6c6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
