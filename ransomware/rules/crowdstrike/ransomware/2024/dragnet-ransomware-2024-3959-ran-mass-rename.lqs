// Dragnet [Ransomware]: dragnet-ransomware-2024-3959 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: ffd85ca2-cbbe-5fa2-9b87-16f8de960828

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
