// Dragnet [Ransomware]: dragnet-ransomware-2025-5300 — Mass File Rename (coinbasecartel)
// Status: test | Level: high | ID: 62adb6e2-49ff-56ac-b35e-cee8c4b4ed3d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
