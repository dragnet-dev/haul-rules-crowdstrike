// Dragnet [Ransomware]: dragnet-ransomware-2023-4318 — Mass File Rename (dragonforce)
// Status: deprecated | Level: high | ID: 75253dc7-6ce1-5191-b3e3-4ab3ab58a4ef

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
