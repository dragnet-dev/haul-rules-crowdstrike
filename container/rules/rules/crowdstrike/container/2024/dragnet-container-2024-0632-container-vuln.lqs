// Dragnet [Container]: dragnet-container-2024-0632 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 12b11cf3-a1da-519b-adc2-506db0373038

#event_simpleName=*
| (ImageFileName = *amazonlinux:2023* OR ImageFileName = *oraclelinux:7* OR ImageFileName = *oraclelinux:8* OR ImageFileName = *redhat/ubi9:*)
| table([timestamp, ComputerName])
| limit(1000)
