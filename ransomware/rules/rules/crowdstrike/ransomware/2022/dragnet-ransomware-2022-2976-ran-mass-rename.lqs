// Dragnet [Ransomware]: dragnet-ransomware-2022-2976 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: fb96f72c-1433-5755-94f6-a05157beef50

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
