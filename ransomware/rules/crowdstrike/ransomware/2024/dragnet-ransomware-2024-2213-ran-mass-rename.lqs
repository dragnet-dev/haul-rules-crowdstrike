// Dragnet [Ransomware]: dragnet-ransomware-2024-2213 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 5f35ab4f-8d93-557b-8c77-a3485d694914

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
