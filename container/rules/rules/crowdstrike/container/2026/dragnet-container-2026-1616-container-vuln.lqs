// Dragnet [Container]: dragnet-container-2026-1616 — Vulnerable Base Image Pull
// Status: deprecated | Level: medium | ID: e40ade18-d05c-5d7c-8034-440d8e2d6d57

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:7*)
| table([timestamp, ComputerName])
| limit(1000)
