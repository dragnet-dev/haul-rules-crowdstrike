// Dragnet [Ransomware]: dragnet-ransomware-2025-0578 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: a5d3b7c8-24ee-579b-9621-eb9fba39e225

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
