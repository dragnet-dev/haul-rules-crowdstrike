// Dragnet [Ransomware]: dragnet-ransomware-2024-3968 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: d95cee31-2a08-5f68-bfbe-8d66eb76df86

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
