// Dragnet [Ransomware]: dragnet-ransomware-2025-1931 — Mass File Rename (chaos)
// Status: experimental | Level: high | ID: 4b6f3da3-7b2f-545e-8034-960669870f18

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
