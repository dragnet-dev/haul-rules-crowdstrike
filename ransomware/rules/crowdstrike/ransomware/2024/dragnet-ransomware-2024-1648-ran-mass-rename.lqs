// Dragnet [Ransomware]: dragnet-ransomware-2024-1648 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 0a4893fb-eb7a-5289-a7e8-23be48d7137a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
