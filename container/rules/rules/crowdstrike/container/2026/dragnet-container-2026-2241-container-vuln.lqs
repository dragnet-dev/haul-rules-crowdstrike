// Dragnet [Container]: dragnet-container-2026-2241 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: d461e547-d50e-54d5-a68d-e172b99abda5

#event_simpleName=*
| (ImageFileName = *debian:7* OR ImageFileName = *debian:8* OR ImageFileName = *ubuntu:14.04* OR ImageFileName = *ubuntu:15.04* OR ImageFileName = *ubuntu:15.10*)
| table([timestamp, ComputerName])
| limit(1000)
