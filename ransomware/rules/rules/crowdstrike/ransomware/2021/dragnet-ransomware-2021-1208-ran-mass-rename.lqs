// Dragnet [Ransomware]: dragnet-ransomware-2021-1208 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: f7b405c9-b435-5863-acdf-f9a149b1ccdb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
