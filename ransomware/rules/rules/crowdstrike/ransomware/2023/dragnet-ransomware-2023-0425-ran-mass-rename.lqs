// Dragnet [Ransomware]: dragnet-ransomware-2023-0425 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 82edd631-f7c3-5a90-b1d1-cc719e735d4a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
