// Dragnet [Ransomware]: dragnet-ransomware-2021-0164 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: 09598535-26ad-55be-834d-5f5abd2e1d84

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
