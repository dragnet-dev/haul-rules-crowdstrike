// Dragnet [Ransomware]: dragnet-ransomware-2025-7635 — Mass File Rename (lockbit5)
// Status: test | Level: high | ID: 63b87a04-ab2f-5d94-83d0-f625fc9b42b3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
