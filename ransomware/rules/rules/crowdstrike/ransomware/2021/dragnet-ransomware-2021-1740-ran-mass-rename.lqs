// Dragnet [Ransomware]: dragnet-ransomware-2021-1740 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: e794123e-62d5-51fb-9b15-3aed0a128302

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
