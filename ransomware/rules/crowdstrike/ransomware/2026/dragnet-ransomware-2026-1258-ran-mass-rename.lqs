// Dragnet [Ransomware]: dragnet-ransomware-2026-1258 — Mass File Rename (incransom)
// Status: stable | Level: high | ID: 8b5ae5e5-aad2-5539-ba98-1416e9fe2130

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
