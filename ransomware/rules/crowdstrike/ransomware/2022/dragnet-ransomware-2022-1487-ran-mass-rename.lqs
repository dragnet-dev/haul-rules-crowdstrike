// Dragnet [Ransomware]: dragnet-ransomware-2022-1487 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 05afe83f-51ce-550d-aed5-9dbcc3881a31

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
