// Dragnet [Ransomware]: dragnet-ransomware-2025-6909 — Mass File Rename (ransomhouse)
// Status: experimental | Level: high | ID: 8b94a440-82a5-5fff-882f-63e25db84bd8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
