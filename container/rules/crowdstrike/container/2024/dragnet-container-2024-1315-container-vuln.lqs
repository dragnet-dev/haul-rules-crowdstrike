// Dragnet [Container]: dragnet-container-2024-1315 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 47173d55-7bcf-57c3-bbfd-cbde9d22e032

#event_simpleName=*
| (ImageFileName = *almalinux:9* OR ImageFileName = *amazonlinux:1* OR ImageFileName = *amazonlinux:2* OR ImageFileName = *amazonlinux:2022* OR ImageFileName = *amazonlinux:2023* OR ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:7* OR ImageFileName = *oraclelinux:9* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:16.04-ESM* OR ImageFileName = *ubuntu:18.04-ESM* OR ImageFileName = *ubuntu:20.04-ESM* OR ImageFileName = *ubuntu:22.04*)
| table([timestamp, ComputerName])
| limit(1000)
