// Dragnet [Ransomware]: dragnet-ransomware-2024-3992 — Mass File Rename (threeam)
// Status: experimental | Level: high | ID: 90b7bf23-c1ef-5df5-8dbc-d001ccfc075e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
