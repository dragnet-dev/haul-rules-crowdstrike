// Dragnet [Ransomware]: dragnet-ransomware-2024-4945 — Mass File Rename (play)
// Status: experimental | Level: high | ID: f4fbf9f0-9706-51b4-93ec-385d2bd10ec2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
