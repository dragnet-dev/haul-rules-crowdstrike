// Dragnet [Ransomware]: dragnet-ransomware-2024-0750 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: 72b997a2-a1c3-5177-a40b-2a0de741ff28

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
