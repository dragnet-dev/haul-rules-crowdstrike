// Dragnet [Ransomware]: dragnet-ransomware-2022-0235 — Mass File Rename (blackbasta)
// Status: deprecated | Level: high | ID: 13cb41e9-43d7-5a16-9e29-e56d8d22b7ac

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
