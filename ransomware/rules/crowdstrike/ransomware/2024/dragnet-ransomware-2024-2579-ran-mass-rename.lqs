// Dragnet [Ransomware]: dragnet-ransomware-2024-2579 — Mass File Rename (frag)
// Status: deprecated | Level: high | ID: 406e3f47-36bb-5b26-8065-75e0881a6e02

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
