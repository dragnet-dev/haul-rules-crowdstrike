// Dragnet [Ransomware]: dragnet-ransomware-2022-2889 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: a4d8498f-8442-51ca-aa14-20fd0d3e0378

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
