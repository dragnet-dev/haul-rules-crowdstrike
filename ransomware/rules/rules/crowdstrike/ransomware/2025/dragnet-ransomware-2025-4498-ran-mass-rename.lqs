// Dragnet [Ransomware]: dragnet-ransomware-2025-4498 — Mass File Rename (kairos)
// Status: experimental | Level: high | ID: f1886e2b-4dd9-5140-98de-99bc5e85e7d7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
