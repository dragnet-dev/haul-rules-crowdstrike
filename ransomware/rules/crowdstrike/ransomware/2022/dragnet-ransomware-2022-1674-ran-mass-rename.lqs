// Dragnet [Ransomware]: dragnet-ransomware-2022-1674 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: d32fa2c7-e36a-5d50-afd2-f920d76dad36

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
