// Dragnet [Ransomware]: dragnet-ransomware-2025-6205 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 293de656-b106-5898-ba0c-8dd916f8cf96

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
