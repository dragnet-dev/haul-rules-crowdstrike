// Dragnet [Ransomware]: dragnet-ransomware-2022-2795 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: adb32a59-035a-58dc-8141-f1ed7adf3bc5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
