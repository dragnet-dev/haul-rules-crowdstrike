// Dragnet [Ransomware]: dragnet-ransomware-2021-0683 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 1076d04e-1d54-55a2-a74f-c82348d624a8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
