// Dragnet [Ransomware]: dragnet-ransomware-2025-4215 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 587e1ab3-f4e3-5cfe-97b0-25478339b724

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
