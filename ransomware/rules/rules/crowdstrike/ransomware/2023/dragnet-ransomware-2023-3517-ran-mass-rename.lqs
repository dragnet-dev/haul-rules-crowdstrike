// Dragnet [Ransomware]: dragnet-ransomware-2023-3517 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: d28c7e81-e734-579e-adb2-d92f95e70295

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
