// Dragnet [Ransomware]: dragnet-ransomware-2023-1854 — Mass File Rename (nokoyawa)
// Status: experimental | Level: high | ID: a34c1921-453c-5201-a6de-eefac729d968

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
