// Dragnet [Ransomware]: dragnet-ransomware-2025-4229 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 0466defb-4b17-51e0-9fdb-cfeaebe3cf29

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
