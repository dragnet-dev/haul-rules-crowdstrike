// Dragnet [Ransomware]: dragnet-ransomware-2023-1595 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 899b2aec-1d80-575f-9ba6-c329d3a10de2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
