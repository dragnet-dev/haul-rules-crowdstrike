// Dragnet [Ransomware]: dragnet-ransomware-2023-4895 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 48f9151e-8641-5b15-82f7-ceb1094d9a80

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
