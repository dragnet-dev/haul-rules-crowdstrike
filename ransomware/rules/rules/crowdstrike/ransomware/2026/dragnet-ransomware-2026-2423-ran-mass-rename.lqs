// Dragnet [Ransomware]: dragnet-ransomware-2026-2423 — Mass File Rename (SilentRansomGroup)
// Status: deprecated | Level: high | ID: 07546420-cc9a-50c8-ab69-c07715330385

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
