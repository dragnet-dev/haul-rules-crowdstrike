// Dragnet [Ransomware]: dragnet-ransomware-2025-3244 — Mass File Rename (nightspire)
// Status: deprecated | Level: high | ID: bd4b6179-6ac8-554d-924b-867465b062c2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
