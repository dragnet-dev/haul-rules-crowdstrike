// Dragnet [Ransomware]: dragnet-ransomware-2024-1699 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 83cf4b8f-7ac5-58f8-aa87-67346e198458

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
