// Dragnet [Ransomware]: dragnet-ransomware-2026-2058 — Mass File Rename (vect)
// Status: deprecated | Level: high | ID: 31817732-54f1-59bf-9533-475e8f463997

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
