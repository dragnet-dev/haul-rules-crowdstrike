// Dragnet [Ransomware]: dragnet-ransomware-2024-2046 — Mass File Rename (kairos)
// Status: experimental | Level: high | ID: 0956d168-f0e4-5b11-b84a-d716dbb4cd5a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
