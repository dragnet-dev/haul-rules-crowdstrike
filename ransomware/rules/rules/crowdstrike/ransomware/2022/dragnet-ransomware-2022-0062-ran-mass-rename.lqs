// Dragnet [Ransomware]: dragnet-ransomware-2022-0062 — Mass File Rename (alphv)
// Status: deprecated | Level: high | ID: 33481f7d-3c06-5b19-9f72-69e7851c7a2f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
