// Dragnet [Ransomware]: dragnet-ransomware-2024-2111 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: a516dcb0-bd1f-54b3-840f-ee7b01e77871

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
