// Dragnet [Ransomware]: dragnet-ransomware-2021-0466 — Mass File Rename (spook)
// Status: deprecated | Level: high | ID: 3144b52d-4e4b-58d5-8296-b84c744c3318

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
