// Dragnet [Ransomware]: dragnet-ransomware-2026-3002 — Mass File Rename (handala)
// Status: stable | Level: high | ID: 3c740aea-c76f-568b-a847-257697d5f06f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
