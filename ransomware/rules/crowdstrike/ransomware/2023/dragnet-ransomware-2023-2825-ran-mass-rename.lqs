// Dragnet [Ransomware]: dragnet-ransomware-2023-2825 — Mass File Rename (malas)
// Status: experimental | Level: high | ID: 06229c56-6352-5b32-9ccf-06071f052029

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
