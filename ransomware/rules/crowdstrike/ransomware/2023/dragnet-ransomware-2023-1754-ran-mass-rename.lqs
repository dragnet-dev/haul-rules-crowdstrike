// Dragnet [Ransomware]: dragnet-ransomware-2023-1754 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: f22d025a-16a3-57ac-9b8c-5dee15c3ec9d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
