// Dragnet [Ransomware]: dragnet-ransomware-2025-7461 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: a7978a97-9151-57b7-9c13-f6041442d275

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
