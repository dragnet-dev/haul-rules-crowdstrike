// Dragnet [Ransomware]: dragnet-ransomware-2023-2900 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 7f7473a8-90f2-5610-bce6-51edf4104c03

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
