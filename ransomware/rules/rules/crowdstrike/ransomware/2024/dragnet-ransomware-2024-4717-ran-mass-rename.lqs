// Dragnet [Ransomware]: dragnet-ransomware-2024-4717 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 2bf62cbe-9693-5c74-a170-b45eada6467a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
