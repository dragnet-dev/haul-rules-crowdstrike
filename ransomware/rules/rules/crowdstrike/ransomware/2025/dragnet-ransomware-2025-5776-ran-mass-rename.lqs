// Dragnet [Ransomware]: dragnet-ransomware-2025-5776 — Mass File Rename (obscura)
// Status: experimental | Level: high | ID: a98620f9-f23f-571f-8520-00f68f7d1fe4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
