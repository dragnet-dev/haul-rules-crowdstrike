// Dragnet [Ransomware]: dragnet-ransomware-2023-0870 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: c03e01fc-da01-5895-84de-a00ab9fbcf05

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
