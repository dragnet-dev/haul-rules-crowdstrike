// Dragnet [Ransomware]: dragnet-ransomware-2025-2749 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: ac4f433d-7000-5e90-8a23-28a3b4b8b3c1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
