// Dragnet [Ransomware]: dragnet-ransomware-2025-1506 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 6ac64d69-112f-534a-af30-45a564cd3314

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
