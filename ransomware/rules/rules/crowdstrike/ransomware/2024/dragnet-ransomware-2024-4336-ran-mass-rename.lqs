// Dragnet [Ransomware]: dragnet-ransomware-2024-4336 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 27427703-e178-51c5-8961-931b93f01839

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
