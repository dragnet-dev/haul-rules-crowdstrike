// Dragnet [Ransomware]: dragnet-ransomware-2024-1213 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 5a832a52-638f-59e0-ace0-0c8581c2612f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
