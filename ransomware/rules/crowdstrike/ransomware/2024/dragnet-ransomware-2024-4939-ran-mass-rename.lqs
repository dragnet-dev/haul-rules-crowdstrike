// Dragnet [Ransomware]: dragnet-ransomware-2024-4939 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: b8247864-7b4a-5f75-902a-5e026427c567

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
