// Dragnet [Ransomware]: dragnet-ransomware-2025-0618 — Mass File Rename (handala)
// Status: experimental | Level: high | ID: 475d3349-766d-5f46-886b-21405457c61d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
