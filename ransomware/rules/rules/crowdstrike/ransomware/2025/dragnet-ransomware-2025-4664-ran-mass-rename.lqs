// Dragnet [Ransomware]: dragnet-ransomware-2025-4664 — Mass File Rename (blacklock)
// Status: experimental | Level: high | ID: b4d51b9d-ed66-56cf-aa46-d7cef280b274

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
