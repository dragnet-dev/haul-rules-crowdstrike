// Dragnet [Ransomware]: dragnet-ransomware-2022-0169 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 91d7a6f5-6c34-5223-8a54-2de62e007b03

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
