// Dragnet [Ransomware]: dragnet-ransomware-2024-3903 — Mass File Rename (play)
// Status: experimental | Level: high | ID: fca5d3e3-590a-5e22-95b6-a4a16491bf08

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
