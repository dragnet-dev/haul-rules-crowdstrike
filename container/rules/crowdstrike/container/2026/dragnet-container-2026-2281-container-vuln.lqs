// Dragnet [Container]: dragnet-container-2026-2281 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 8141b149-8edf-5773-a3fc-678b1d26a661

#event_simpleName=*
| (ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10* OR ImageFileName = *ubuntu:13.04* OR ImageFileName = *ubuntu:13.10*)
| table([timestamp, ComputerName])
| limit(1000)
