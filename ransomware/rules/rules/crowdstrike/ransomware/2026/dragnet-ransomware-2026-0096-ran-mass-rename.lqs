// Dragnet [Ransomware]: dragnet-ransomware-2026-0096 — Mass File Rename (dragonforce)
// Status: stable | Level: high | ID: 2a640a79-f827-5641-a78a-f9a201d7a5af

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
