// Dragnet [Ransomware]: dragnet-ransomware-2023-1501 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: 89487c71-d089-56b2-bdd5-4bbfa6cd3c9b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
