// Dragnet [Ransomware]: dragnet-ransomware-2023-1685 — Mass File Rename (darkpower)
// Status: experimental | Level: high | ID: c1fdf059-c72c-5fce-bd5c-2adf179c31e3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
