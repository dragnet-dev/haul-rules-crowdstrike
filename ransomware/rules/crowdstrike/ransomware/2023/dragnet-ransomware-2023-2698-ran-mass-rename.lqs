// Dragnet [Ransomware]: dragnet-ransomware-2023-2698 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 5514ee78-6422-5b29-bd31-6e969f594588

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
