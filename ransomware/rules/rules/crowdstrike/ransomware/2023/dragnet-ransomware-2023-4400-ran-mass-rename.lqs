// Dragnet [Ransomware]: dragnet-ransomware-2023-4400 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 56a1fd62-e9aa-588a-8702-1823b7204412

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
