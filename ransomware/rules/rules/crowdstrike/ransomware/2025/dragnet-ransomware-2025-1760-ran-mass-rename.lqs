// Dragnet [Ransomware]: dragnet-ransomware-2025-1760 — Mass File Rename (ransomhouse)
// Status: experimental | Level: high | ID: 0fe6d4f7-caf2-5e33-b565-bb0a0892e512

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
