// Dragnet [Ransomware]: dragnet-ransomware-2022-0054 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: eee54d25-ccf8-5e74-adb4-ea8cd0ec5a62

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
