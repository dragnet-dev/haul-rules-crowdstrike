// Dragnet [Ransomware]: dragnet-ransomware-2024-5218 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 3444d55e-254a-5419-bbb7-8ca72e7f8de2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
