// Dragnet [Ransomware]: dragnet-ransomware-2026-1398 — Mass File Rename (lockbit5)
// Status: stable | Level: high | ID: e980c89f-e32e-58a3-9371-79cb804f910c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
