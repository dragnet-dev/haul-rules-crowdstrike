// Dragnet [Ransomware]: dragnet-ransomware-2021-0257 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 0e73e08d-f066-59bc-b021-019f621aaeb3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
