// Dragnet [Ransomware]: dragnet-ransomware-2023-1018 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 8b70f83e-c11b-5af0-aa9a-e471224f92ca

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
