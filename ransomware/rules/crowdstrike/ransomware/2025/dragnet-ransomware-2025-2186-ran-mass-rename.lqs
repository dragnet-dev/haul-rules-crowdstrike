// Dragnet [Ransomware]: dragnet-ransomware-2025-2186 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: bceab328-80ef-5063-ba77-d87581dc8036

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
