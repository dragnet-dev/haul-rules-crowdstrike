// Dragnet [Ransomware]: dragnet-ransomware-2024-5087 — Mass File Rename (meow)
// Status: experimental | Level: high | ID: 4838d625-0c80-5b7c-a72d-51cefad69efe

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
