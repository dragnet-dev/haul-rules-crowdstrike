// Dragnet [Ransomware]: dragnet-ransomware-2026-1223 — Mass File Rename (dragonforce)
// Status: stable | Level: high | ID: c3b8c33c-a720-5d04-adfd-f7bdcd69087f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
