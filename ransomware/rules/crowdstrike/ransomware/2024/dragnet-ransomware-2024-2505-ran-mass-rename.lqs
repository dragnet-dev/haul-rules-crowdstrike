// Dragnet [Ransomware]: dragnet-ransomware-2024-2505 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 3d3d3e2d-d025-5f7e-aa89-ba392be5b8a5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
