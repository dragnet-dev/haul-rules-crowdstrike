// Dragnet [Ransomware]: dragnet-ransomware-2020-0176 — Mass File Rename (maze)
// Status: deprecated | Level: high | ID: d1560505-54fd-5775-b583-af9371d09727

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
