// Dragnet [Ransomware]: dragnet-ransomware-2024-0771 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: c3351b34-8678-55e8-8b8b-e0b57fa11101

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
