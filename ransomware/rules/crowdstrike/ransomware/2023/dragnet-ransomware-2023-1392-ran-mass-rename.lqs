// Dragnet [Ransomware]: dragnet-ransomware-2023-1392 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 4b5c77f3-4c2c-5f20-b17c-2a7809e8b856

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
