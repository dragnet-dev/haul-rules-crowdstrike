// Dragnet [Ransomware]: dragnet-ransomware-2023-3002 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: b4edcc87-3911-597c-84eb-2d95cff34259

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
