// Dragnet [Ransomware]: dragnet-ransomware-2022-0610 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: f070591a-8782-5da9-860c-8f7fc04f58b7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
