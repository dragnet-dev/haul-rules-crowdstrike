// Dragnet [Ransomware]: dragnet-ransomware-2025-0977 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: dd4d56c2-900b-5790-8fcd-0be78a9ddb15

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
