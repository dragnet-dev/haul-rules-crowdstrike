// Dragnet [Container]: dragnet-container-2025-0096 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 0d7232f9-b852-5b4e-8451-6c3df6b64209

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
