// Dragnet [Ransomware]: dragnet-ransomware-2023-3411 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: d53d7aa3-7d7c-59ad-83c6-2ae19f415c1f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
