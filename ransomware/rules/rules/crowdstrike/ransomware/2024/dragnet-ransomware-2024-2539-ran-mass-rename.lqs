// Dragnet [Ransomware]: dragnet-ransomware-2024-2539 — Mass File Rename (meow)
// Status: experimental | Level: high | ID: ec3692f9-0089-55f5-b204-9a79d1ef23c6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
