// Dragnet [Ransomware]: dragnet-ransomware-2024-4131 — Mass File Rename (ciphbit)
// Status: deprecated | Level: high | ID: 3eba4179-9dc1-52eb-92af-05a612318438

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
