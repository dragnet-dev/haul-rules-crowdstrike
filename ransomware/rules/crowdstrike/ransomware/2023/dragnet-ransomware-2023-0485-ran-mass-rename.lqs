// Dragnet [Ransomware]: dragnet-ransomware-2023-0485 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 97d5f645-d818-5dd9-afb2-e4b7cbe0d4fa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
