// Dragnet [Ransomware]: dragnet-ransomware-2025-5060 — Mass File Rename (shinyhunters)
// Status: experimental | Level: high | ID: 0b55a8a9-50a8-5ac1-93b3-9ff94aea2d26

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
