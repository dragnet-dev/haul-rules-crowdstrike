// Dragnet [Ransomware]: dragnet-ransomware-2025-4989 — Mass File Rename (shinyhunters)
// Status: experimental | Level: high | ID: fd870d18-eb80-5a11-9ab9-2d3ae516d43e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
