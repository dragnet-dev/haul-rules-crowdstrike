// Dragnet [Ransomware]: dragnet-ransomware-2023-3621 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 2d6c908f-1253-5880-b2c3-004b67d0c98f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
