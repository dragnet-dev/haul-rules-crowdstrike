// Dragnet [Ransomware]: dragnet-ransomware-2023-4720 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 44935d57-6354-5739-9790-ccb2dff97ea2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
