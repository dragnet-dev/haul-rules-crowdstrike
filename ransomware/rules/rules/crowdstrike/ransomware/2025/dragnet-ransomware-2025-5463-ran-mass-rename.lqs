// Dragnet [Ransomware]: dragnet-ransomware-2025-5463 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: fe0189be-f372-51db-be1f-47ed5a4eccc9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
