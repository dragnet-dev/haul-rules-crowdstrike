// Dragnet [Container]: dragnet-container-2026-1512 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 0c5af6c2-9b69-5240-8cab-71753c718919

#event_simpleName=*
| (ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10* OR ImageFileName = *ubuntu:13.04* OR ImageFileName = *ubuntu:13.10*)
| table([timestamp, ComputerName])
| limit(1000)
