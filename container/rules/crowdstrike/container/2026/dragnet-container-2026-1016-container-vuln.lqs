// Dragnet [Container]: dragnet-container-2026-1016 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 4882e806-370d-53ab-8d68-7983ac308244

#event_simpleName=*
| (ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10* OR ImageFileName = *ubuntu:13.04* OR ImageFileName = *ubuntu:13.10*)
| table([timestamp, ComputerName])
| limit(1000)
