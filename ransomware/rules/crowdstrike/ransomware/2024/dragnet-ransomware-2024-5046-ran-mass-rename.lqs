// Dragnet [Ransomware]: dragnet-ransomware-2024-5046 — Mass File Rename (monti)
// Status: experimental | Level: high | ID: 97fb32d4-f2ff-52b0-bf49-a7ac691a13ed

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
