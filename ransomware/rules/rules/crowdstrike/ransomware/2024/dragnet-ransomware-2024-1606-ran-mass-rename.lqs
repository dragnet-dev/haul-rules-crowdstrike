// Dragnet [Ransomware]: dragnet-ransomware-2024-1606 — Mass File Rename (dragonransomware)
// Status: experimental | Level: high | ID: b42095e7-cfb0-51c9-bdae-5aa91d7d7cb2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
