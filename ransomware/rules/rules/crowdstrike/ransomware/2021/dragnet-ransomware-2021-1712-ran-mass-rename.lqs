// Dragnet [Ransomware]: dragnet-ransomware-2021-1712 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 6f0f7c73-27a6-5bca-9b71-820e247f133d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
