// Dragnet [Ransomware]: dragnet-ransomware-2025-1183 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: bdf3cde1-7396-5cab-a254-1786373d368c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
