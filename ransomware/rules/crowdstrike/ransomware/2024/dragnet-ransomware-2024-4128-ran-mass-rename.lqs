// Dragnet [Ransomware]: dragnet-ransomware-2024-4128 — Mass File Rename (alphalocker)
// Status: experimental | Level: high | ID: 317b55e9-c528-5d2f-9805-c4fad8401767

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
