// Dragnet [Ransomware]: dragnet-ransomware-2022-1641 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 67762626-041e-5e15-941b-5efa7c9682ae

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
