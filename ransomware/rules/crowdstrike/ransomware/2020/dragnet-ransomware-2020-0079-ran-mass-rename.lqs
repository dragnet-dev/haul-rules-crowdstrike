// Dragnet [Ransomware]: dragnet-ransomware-2020-0079 — Mass File Rename (maze)
// Status: deprecated | Level: high | ID: d9c26dfe-5bc9-5649-939b-ca05bac55e1d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
