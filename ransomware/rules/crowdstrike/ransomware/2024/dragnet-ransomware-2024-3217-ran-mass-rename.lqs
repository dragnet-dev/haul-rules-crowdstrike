// Dragnet [Ransomware]: dragnet-ransomware-2024-3217 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 2328f33a-e789-5eb5-bd18-4844aaef892d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
