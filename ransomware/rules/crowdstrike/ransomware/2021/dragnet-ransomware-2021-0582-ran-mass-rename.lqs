// Dragnet [Ransomware]: dragnet-ransomware-2021-0582 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: b963da0e-a006-57ec-9c2a-780ae66865be

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
