// Dragnet [Ransomware]: dragnet-ransomware-2024-3947 — Mass File Rename (monti)
// Status: experimental | Level: high | ID: 5a260e40-39fa-5bf2-8917-26e0853c6f9c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
