// Dragnet [Container]: dragnet-container-2026-0070 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: a4a8e21d-ac31-5895-b29d-88da13d4031b

#event_simpleName=*
| (ImageFileName = *chainguard:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
