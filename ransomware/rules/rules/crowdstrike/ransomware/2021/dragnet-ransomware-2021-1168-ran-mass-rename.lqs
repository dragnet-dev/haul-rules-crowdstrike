// Dragnet [Ransomware]: dragnet-ransomware-2021-1168 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: d5199cf9-d524-590e-830e-878f6854df4c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
