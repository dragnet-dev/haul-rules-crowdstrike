// Dragnet [Ransomware]: dragnet-ransomware-2024-3316 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 22de827b-c816-551d-bcb3-8e117813310b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
