// Dragnet [Ransomware]: dragnet-ransomware-2022-2533 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: b43463d6-9c52-5e9c-8900-3c8ad196d7c9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
