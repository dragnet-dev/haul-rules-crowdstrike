// Dragnet [Ransomware]: dragnet-ransomware-2024-0999 — Mass File Rename (lockbit5)
// Status: experimental | Level: high | ID: a3fc8a31-3605-5fee-9341-04503e83edde

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
