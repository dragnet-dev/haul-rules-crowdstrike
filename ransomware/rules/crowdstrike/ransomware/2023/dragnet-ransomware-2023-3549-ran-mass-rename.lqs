// Dragnet [Ransomware]: dragnet-ransomware-2023-3549 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 9bac8717-5e23-5a63-9358-8a102f2c2e92

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
