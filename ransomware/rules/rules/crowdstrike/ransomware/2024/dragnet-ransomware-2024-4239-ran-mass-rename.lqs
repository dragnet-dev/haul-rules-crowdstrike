// Dragnet [Ransomware]: dragnet-ransomware-2024-4239 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: 8b72ce3c-d7ea-5e5b-bf45-81de99d6f4d1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
