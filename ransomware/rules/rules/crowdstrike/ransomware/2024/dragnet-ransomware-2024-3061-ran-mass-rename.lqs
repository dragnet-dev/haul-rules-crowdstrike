// Dragnet [Ransomware]: dragnet-ransomware-2024-3061 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 59192b7a-67a1-53fd-8b12-e9e203137c91

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
