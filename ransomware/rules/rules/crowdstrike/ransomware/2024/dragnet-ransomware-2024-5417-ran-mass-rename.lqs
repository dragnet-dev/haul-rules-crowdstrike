// Dragnet [Ransomware]: dragnet-ransomware-2024-5417 — Mass File Rename (play)
// Status: experimental | Level: high | ID: e89dc6c0-29fb-5ae9-85f1-26a7f625761b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
