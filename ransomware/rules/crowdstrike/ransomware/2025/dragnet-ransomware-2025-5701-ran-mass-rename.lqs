// Dragnet [Ransomware]: dragnet-ransomware-2025-5701 — Mass File Rename (morpheus)
// Status: deprecated | Level: high | ID: ddd0e33b-3e75-5d6a-9a1a-7f8b365b03d4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
