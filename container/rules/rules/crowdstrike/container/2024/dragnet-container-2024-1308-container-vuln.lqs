// Dragnet [Container]: dragnet-container-2024-1308 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 404346bb-1ff4-5bf1-8dd6-6a378498b7ca

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *redhat/ubi9:*)
| table([timestamp, ComputerName])
| limit(1000)
