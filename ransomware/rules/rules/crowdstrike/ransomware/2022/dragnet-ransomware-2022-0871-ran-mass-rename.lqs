// Dragnet [Ransomware]: dragnet-ransomware-2022-0871 — Mass File Rename (quantum)
// Status: deprecated | Level: high | ID: ad3e990d-ae26-5a12-8a18-3db39c3c3a7c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
