// Dragnet [Ransomware]: dragnet-ransomware-2024-1730 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: c269bce5-ea27-53fb-80e8-3a940a97a3e5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
