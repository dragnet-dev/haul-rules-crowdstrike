// Dragnet [Ransomware]: dragnet-ransomware-2024-0858 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: dc3e3791-db73-532c-a8d6-47d40e1e52f5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
