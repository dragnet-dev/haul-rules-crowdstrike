// Dragnet [Ransomware]: dragnet-ransomware-2023-2126 — Mass File Rename (siegedsec)
// Status: deprecated | Level: high | ID: 8fa9b2aa-018e-5d1b-a60b-f5b0a8c91336

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
