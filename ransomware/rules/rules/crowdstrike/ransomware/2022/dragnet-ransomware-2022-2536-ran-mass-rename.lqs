// Dragnet [Ransomware]: dragnet-ransomware-2022-2536 — Mass File Rename (redalert)
// Status: deprecated | Level: high | ID: 45f767d7-badd-5746-89ba-d8445a127286

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
