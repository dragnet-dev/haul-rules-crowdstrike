// Dragnet [Ransomware]: dragnet-ransomware-2023-4940 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 8cd5cf57-1209-5e9d-8fe3-761808da7fd5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
