// Dragnet [Ransomware]: dragnet-ransomware-2026-2527 — Mass File Rename (thegentlemen)
// Status: deprecated | Level: high | ID: 3b7d1dd4-35fa-5cd7-8711-d3d3517b31c2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
