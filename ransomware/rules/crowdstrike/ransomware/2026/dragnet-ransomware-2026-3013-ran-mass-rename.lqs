// Dragnet [Ransomware]: dragnet-ransomware-2026-3013 — Mass File Rename (SilentRansomGroup)
// Status: deprecated | Level: high | ID: 9cfc872f-e4dc-5bf0-b22a-352bb7338037

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
