// Dragnet [Ransomware]: dragnet-ransomware-2021-0405 — Mass File Rename (groove)
// Status: deprecated | Level: high | ID: 9b80a3f1-d205-5ba0-9610-47e436e187f0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
