// Dragnet [Ransomware]: dragnet-ransomware-2025-2318 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 785072b2-6e5f-50d2-8be6-a46f968711db

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
