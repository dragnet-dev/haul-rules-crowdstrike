// Dragnet [Ransomware]: dragnet-ransomware-2024-5370 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: df635a4c-e074-57e3-9027-6ecd1e68b325

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
