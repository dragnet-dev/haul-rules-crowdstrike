// Dragnet [Ransomware]: dragnet-ransomware-2024-2222 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 41121035-db4e-58e2-b836-e218c7d2bc71

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
