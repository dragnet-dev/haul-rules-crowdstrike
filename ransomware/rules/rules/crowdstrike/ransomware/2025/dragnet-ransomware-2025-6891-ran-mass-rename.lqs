// Dragnet [Ransomware]: dragnet-ransomware-2025-6891 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 42f3c474-0f63-5a05-a300-29edeb5a4492

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
