// Dragnet [Ransomware]: dragnet-ransomware-2024-1462 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 31e0ff38-1ae9-5025-a1c1-aa1b94401371

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
