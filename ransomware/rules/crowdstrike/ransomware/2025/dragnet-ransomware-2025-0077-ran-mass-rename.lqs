// Dragnet [Ransomware]: dragnet-ransomware-2025-0077 — Mass File Rename (pear)
// Status: experimental | Level: high | ID: fd43e2a2-7d5c-51a0-9e35-66fd3fa1f034

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
