// Dragnet [Ransomware]: dragnet-ransomware-2024-1901 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 06250573-136c-518b-ba75-bfd4acadcda1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
