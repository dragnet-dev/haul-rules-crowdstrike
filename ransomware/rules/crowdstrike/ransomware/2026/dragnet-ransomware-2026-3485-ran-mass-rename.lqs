// Dragnet [Ransomware]: dragnet-ransomware-2026-3485 — Mass File Rename (handala)
// Status: stable | Level: high | ID: ae57f561-7805-532b-96e3-5de44da087b5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
