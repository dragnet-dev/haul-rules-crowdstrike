// Dragnet [Container]: dragnet-container-2024-1269 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: f03b2f17-3fc9-516d-9bec-f61b460b4ebe

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:9* OR ImageFileName = *oraclelinux:8* OR ImageFileName = *ubuntu:18.04-ESM* OR ImageFileName = *ubuntu:20.04* OR ImageFileName = *ubuntu:20.04-ESM* OR ImageFileName = *ubuntu:20.10* OR ImageFileName = *ubuntu:21.04* OR ImageFileName = *ubuntu:21.10* OR ImageFileName = *ubuntu:22.04* OR ImageFileName = *ubuntu:22.10* OR ImageFileName = *ubuntu:23.04* OR ImageFileName = *ubuntu:23.10* OR ImageFileName = *ubuntu:24.04* OR ImageFileName = *ubuntu:24.10*)
| table([timestamp, ComputerName])
| limit(1000)
