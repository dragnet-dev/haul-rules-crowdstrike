// Dragnet [Ransomware]: dragnet-ransomware-2021-0055 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: d5415684-82fb-5124-bde8-8e0cbc6bd026

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
