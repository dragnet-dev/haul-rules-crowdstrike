// Dragnet [Ransomware]: dragnet-ransomware-2024-4262 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: cf66eb53-dcdf-512b-b3fb-14673b279ab3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
