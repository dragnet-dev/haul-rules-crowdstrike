// Dragnet [Ransomware]: dragnet-ransomware-2024-3962 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: c456d1b7-305c-5670-a5b2-d7ba5396ca15

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
