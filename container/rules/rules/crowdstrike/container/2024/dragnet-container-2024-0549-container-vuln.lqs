// Dragnet [Container]: dragnet-container-2024-0549 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 3a03eca5-fac2-5428-b712-136c48f92e7c

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:9* OR ImageFileName = *ubuntu:20.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
