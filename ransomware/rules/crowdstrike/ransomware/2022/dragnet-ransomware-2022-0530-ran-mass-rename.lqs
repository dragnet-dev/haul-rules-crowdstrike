// Dragnet [Ransomware]: dragnet-ransomware-2022-0530 — Mass File Rename (royal)
// Status: deprecated | Level: high | ID: 28953112-42c5-5110-a181-9788f0aa8f4d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
