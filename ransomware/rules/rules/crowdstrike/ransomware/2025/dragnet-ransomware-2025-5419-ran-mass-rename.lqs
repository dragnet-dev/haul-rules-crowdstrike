// Dragnet [Ransomware]: dragnet-ransomware-2025-5419 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: a518ec07-6603-5294-b88c-52bc96d28ac0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
