// Dragnet [Ransomware]: dragnet-ransomware-2024-4172 — Mass File Rename (apt73)
// Status: experimental | Level: high | ID: 99eb3946-7176-52da-8b3e-68f37a253434

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
