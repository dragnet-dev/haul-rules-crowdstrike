// Dragnet [Ransomware]: dragnet-ransomware-2023-2420 — Mass File Rename (stormous)
// Status: experimental | Level: high | ID: 867db90a-275b-5687-a17b-e7773d1da0d9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
