// Dragnet [Ransomware]: dragnet-ransomware-2026-2943 — Mass File Rename (SilentRansomGroup)
// Status: deprecated | Level: high | ID: da54af68-357d-5e8a-8510-66e0071afa34

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
