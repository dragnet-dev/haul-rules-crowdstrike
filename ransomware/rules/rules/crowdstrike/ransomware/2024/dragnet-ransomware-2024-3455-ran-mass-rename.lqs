// Dragnet [Ransomware]: dragnet-ransomware-2024-3455 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 9dfced34-c684-5782-b551-cefa5924ca54

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
