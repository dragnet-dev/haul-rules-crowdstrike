// Dragnet [Ransomware]: dragnet-ransomware-2021-0858 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 27d5763f-911a-5dcf-920a-12ce92c5d16b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
