// Dragnet [Ransomware]: dragnet-ransomware-2024-0135 — Mass File Rename (stormous)
// Status: deprecated | Level: high | ID: b1b870d1-55c7-52a8-89ed-1d27d940dd97

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
