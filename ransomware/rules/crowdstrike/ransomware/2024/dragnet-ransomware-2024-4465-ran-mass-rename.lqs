// Dragnet [Ransomware]: dragnet-ransomware-2024-4465 — Mass File Rename (cicada3301)
// Status: experimental | Level: high | ID: a450573e-6803-5af2-9916-cd141129884d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
