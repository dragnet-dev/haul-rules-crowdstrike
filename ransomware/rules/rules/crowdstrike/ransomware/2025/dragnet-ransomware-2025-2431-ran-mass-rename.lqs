// Dragnet [Ransomware]: dragnet-ransomware-2025-2431 — Mass File Rename (thegentlemen)
// Status: experimental | Level: high | ID: de050203-7a52-5ff5-820f-eff21fea7744

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
