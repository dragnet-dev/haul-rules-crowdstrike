// Dragnet [Ransomware]: dragnet-ransomware-2023-2306 — Mass File Rename (losttrust)
// Status: deprecated | Level: high | ID: 304451c2-6ff8-5150-87d2-cee29397d71a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
