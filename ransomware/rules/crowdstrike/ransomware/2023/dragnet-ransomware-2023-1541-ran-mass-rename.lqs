// Dragnet [Ransomware]: dragnet-ransomware-2023-1541 — Mass File Rename (karakurt)
// Status: experimental | Level: high | ID: 5818d96b-bfc4-5486-bb1b-4222f1069d24

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
