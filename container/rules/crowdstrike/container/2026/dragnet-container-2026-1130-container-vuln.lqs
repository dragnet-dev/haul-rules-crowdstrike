// Dragnet [Container]: dragnet-container-2026-1130 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: a43a7735-7662-526d-b91f-a0799c58cc8c

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:12.04*)
| table([timestamp, ComputerName])
| limit(1000)
