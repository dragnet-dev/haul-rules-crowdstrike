// Dragnet [Ransomware]: dragnet-ransomware-2025-6924 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 91beff91-fa58-55d7-97c2-49773739605c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
