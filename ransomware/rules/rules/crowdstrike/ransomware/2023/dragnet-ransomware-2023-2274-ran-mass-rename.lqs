// Dragnet [Ransomware]: dragnet-ransomware-2023-2274 — Mass File Rename (ragnarlocker)
// Status: experimental | Level: high | ID: 7adc95eb-97aa-53bd-9a54-5a3ffb68e3bf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
