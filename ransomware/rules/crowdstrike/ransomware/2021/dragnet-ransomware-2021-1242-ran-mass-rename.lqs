// Dragnet [Ransomware]: dragnet-ransomware-2021-1242 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 5cc210d6-e7f7-5dc8-9cee-e0a2641f2e79

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
