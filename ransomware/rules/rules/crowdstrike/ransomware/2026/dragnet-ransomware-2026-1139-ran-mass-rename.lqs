// Dragnet [Ransomware]: dragnet-ransomware-2026-1139 — Mass File Rename (thegentlemen)
// Status: stable | Level: high | ID: 54b19d8b-41dc-5624-8672-d518b9b3ff3e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
