// Dragnet [Ransomware]: dragnet-ransomware-2024-0641 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 3257881a-2e76-578e-9a40-44b520ced8fa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
