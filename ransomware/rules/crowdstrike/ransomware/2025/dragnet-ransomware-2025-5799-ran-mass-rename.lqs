// Dragnet [Ransomware]: dragnet-ransomware-2025-5799 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 42cf3566-765b-5b34-b134-5c215fc2e620

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
