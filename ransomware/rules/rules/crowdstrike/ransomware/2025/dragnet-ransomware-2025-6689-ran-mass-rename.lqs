// Dragnet [Ransomware]: dragnet-ransomware-2025-6689 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: afd29b30-77ba-5310-883a-26eaa32202cb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
