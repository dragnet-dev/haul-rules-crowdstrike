// Dragnet [Container]: dragnet-container-2024-0816 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: c3b71aa6-47f2-56a7-a544-0fd9e65be6bd

#event_simpleName=*
| (ImageFileName = *amazonlinux:1* OR ImageFileName = *debian:7* OR ImageFileName = *debian:8* OR ImageFileName = *redhat/ubi9:*)
| table([timestamp, ComputerName])
| limit(1000)
