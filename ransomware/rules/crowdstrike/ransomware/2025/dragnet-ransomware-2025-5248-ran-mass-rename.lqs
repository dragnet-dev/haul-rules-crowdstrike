// Dragnet [Ransomware]: dragnet-ransomware-2025-5248 — Mass File Rename (ralord)
// Status: experimental | Level: high | ID: 3729d036-6afe-5f03-b250-17ece4483770

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
