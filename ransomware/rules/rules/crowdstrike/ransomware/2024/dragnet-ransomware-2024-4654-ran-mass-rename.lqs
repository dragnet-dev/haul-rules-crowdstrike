// Dragnet [Ransomware]: dragnet-ransomware-2024-4654 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: a7ebedd5-bca3-55a4-85fb-fbc18536969d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
