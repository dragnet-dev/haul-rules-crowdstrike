// Dragnet [Ransomware]: dragnet-ransomware-2023-1389 — Mass File Rename (play)
// Status: deprecated | Level: high | ID: e378590e-139d-537a-8d84-28f5b3f189ce

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
