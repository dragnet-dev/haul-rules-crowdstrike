// Dragnet [Ransomware]: dragnet-ransomware-2025-6235 — Mass File Rename (lockbit5)
// Status: test | Level: high | ID: dca5367c-2085-5af5-8f40-ea6889e42858

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
