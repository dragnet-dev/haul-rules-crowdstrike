// Dragnet [Ransomware]: dragnet-ransomware-2023-5159 — Mass File Rename (losttrust)
// Status: deprecated | Level: high | ID: b7e8eaad-a20b-5dfb-82ca-c8f64556e4fd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
