// Dragnet [Container]: dragnet-container-2024-0445 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: be4a5164-0904-58d8-8132-c9e6b265a0ff

#event_simpleName=*
| (ImageFileName = *amazonlinux:2* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *photon os:2.0* OR ImageFileName = *ubuntu:17.10*)
| table([timestamp, ComputerName])
| limit(1000)
