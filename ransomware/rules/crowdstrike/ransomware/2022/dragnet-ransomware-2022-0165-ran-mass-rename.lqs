// Dragnet [Ransomware]: dragnet-ransomware-2022-0165 — Mass File Rename (royal)
// Status: deprecated | Level: high | ID: 1d799b12-ef34-5091-a648-a32a9f1a717a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
