// Dragnet [Ransomware]: dragnet-ransomware-2024-3242 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 15d633f5-9fbb-5b90-be25-e4d418ffd0d1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
