// Dragnet [Ransomware]: dragnet-ransomware-2020-0048 — Mass File Rename (revil)
// Status: deprecated | Level: high | ID: 758a5c10-1e17-5895-85ee-ecd588c0e0a6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
