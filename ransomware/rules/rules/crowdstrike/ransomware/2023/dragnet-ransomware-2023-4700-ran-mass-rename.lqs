// Dragnet [Ransomware]: dragnet-ransomware-2023-4700 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 624e50eb-131e-5032-9427-b69051b8fb2e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
