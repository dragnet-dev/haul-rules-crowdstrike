// Dragnet [Ransomware]: dragnet-ransomware-2022-2345 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 9b301f44-a07f-5d20-b3dd-f5d994522fbe

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
