// Dragnet [Container]: dragnet-container-2025-0711 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: f93fc370-8426-538b-8e35-bbcdc011123f

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
