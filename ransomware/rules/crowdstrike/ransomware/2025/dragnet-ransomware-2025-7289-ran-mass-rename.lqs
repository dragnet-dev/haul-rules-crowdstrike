// Dragnet [Ransomware]: dragnet-ransomware-2025-7289 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: ead6d20a-2bcc-5b03-8f58-ba65d0b27898

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
