// Dragnet [Ransomware]: dragnet-ransomware-2023-0191 — Mass File Rename (ciphbit)
// Status: deprecated | Level: high | ID: 25562090-0509-57c3-86fa-262ad8680cb8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
