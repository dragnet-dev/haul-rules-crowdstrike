// Dragnet [Ransomware]: dragnet-ransomware-2024-2157 — Mass File Rename (raworld)
// Status: experimental | Level: high | ID: fa22a882-2e33-548e-bfec-42ef157054a6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
