// Dragnet [Ransomware]: dragnet-ransomware-2025-4509 — Mass File Rename (worldleaks)
// Status: experimental | Level: high | ID: 2adba823-3507-5b43-aed7-59326285b44f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
