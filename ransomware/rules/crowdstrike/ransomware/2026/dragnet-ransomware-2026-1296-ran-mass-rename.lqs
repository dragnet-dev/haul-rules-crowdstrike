// Dragnet [Ransomware]: dragnet-ransomware-2026-1296 — Mass File Rename (anubis)
// Status: stable | Level: high | ID: 5be3cc4f-5255-5b2d-9cb3-3fab7eb62b2c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
