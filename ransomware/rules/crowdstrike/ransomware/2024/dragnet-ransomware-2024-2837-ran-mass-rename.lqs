// Dragnet [Ransomware]: dragnet-ransomware-2024-2837 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: bf3f00fc-3531-5220-b16f-162f9a7d6b94

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
