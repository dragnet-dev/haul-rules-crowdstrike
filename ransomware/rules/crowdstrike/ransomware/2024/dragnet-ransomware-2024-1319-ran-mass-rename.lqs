// Dragnet [Ransomware]: dragnet-ransomware-2024-1319 — Mass File Rename (cicada3301)
// Status: experimental | Level: high | ID: 61eba67c-7686-52a5-a3b3-5cd65b2e6855

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
