// Dragnet [Ransomware]: dragnet-ransomware-2025-3176 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: e0905807-d4e0-5be4-be1f-f512958f41c5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
