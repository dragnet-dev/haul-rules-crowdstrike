// Dragnet [Container]: dragnet-container-2026-1208 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 3f35b5d0-03d3-53b4-9f96-cd5a534fcf06

#event_simpleName=*
| (ImageFileName = *chainguard:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
