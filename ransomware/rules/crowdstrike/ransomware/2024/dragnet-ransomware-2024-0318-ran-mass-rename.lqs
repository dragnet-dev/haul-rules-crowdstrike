// Dragnet [Ransomware]: dragnet-ransomware-2024-0318 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 4f383657-83fa-5e7a-8318-8291ae7d3f86

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
