// Dragnet [Ransomware]: dragnet-ransomware-2023-3664 — Mass File Rename (ransomexx)
// Status: experimental | Level: high | ID: 09dc64ec-8206-56fc-9f74-904ac69536a7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
