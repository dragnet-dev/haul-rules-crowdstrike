// Dragnet [Ransomware]: dragnet-ransomware-2024-0181 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: b944db5a-a736-5ba5-9ba1-21a05197a8af

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
