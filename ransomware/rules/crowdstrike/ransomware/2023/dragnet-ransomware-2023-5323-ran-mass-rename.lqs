// Dragnet [Ransomware]: dragnet-ransomware-2023-5323 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: b885f948-ec4a-580e-80e4-1a0d021971ee

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
