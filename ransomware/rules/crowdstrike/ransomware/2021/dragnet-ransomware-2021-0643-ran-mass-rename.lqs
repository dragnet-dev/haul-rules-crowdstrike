// Dragnet [Ransomware]: dragnet-ransomware-2021-0643 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: fc29aae4-a170-51fc-b476-d6ebd83dbdf7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
