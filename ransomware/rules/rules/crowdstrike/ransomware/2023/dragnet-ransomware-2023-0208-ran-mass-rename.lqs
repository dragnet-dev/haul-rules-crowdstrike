// Dragnet [Ransomware]: dragnet-ransomware-2023-0208 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 5d4fdd61-0a28-5d8f-97c7-561704a9e248

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
