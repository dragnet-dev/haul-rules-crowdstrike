// Dragnet [Ransomware]: dragnet-ransomware-2025-7577 — Mass File Rename (payoutsking)
// Status: deprecated | Level: high | ID: 0c55841c-8141-53b4-abbe-b327e587c57e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
