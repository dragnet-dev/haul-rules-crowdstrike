// Dragnet [Ransomware]: dragnet-ransomware-2024-4758 — Mass File Rename (cloak)
// Status: deprecated | Level: high | ID: 86784971-d4c6-50cb-a101-17500e858a2f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
