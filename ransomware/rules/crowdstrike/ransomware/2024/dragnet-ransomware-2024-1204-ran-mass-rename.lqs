// Dragnet [Ransomware]: dragnet-ransomware-2024-1204 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 15420103-b4c8-50fa-8157-c984c9e8bd38

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
