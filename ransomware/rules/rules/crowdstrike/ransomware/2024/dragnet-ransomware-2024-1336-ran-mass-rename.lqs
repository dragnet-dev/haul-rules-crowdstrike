// Dragnet [Ransomware]: dragnet-ransomware-2024-1336 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: a4602b91-1e15-5a79-a07f-88aefc873d0e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
