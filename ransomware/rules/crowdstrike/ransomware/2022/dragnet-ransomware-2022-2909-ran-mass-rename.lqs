// Dragnet [Ransomware]: dragnet-ransomware-2022-2909 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: 724c923d-75e0-59ef-acd9-b6dd4480e819

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
