// Dragnet [Ransomware]: dragnet-ransomware-2024-1131 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 493d4158-292d-58be-b742-c53854fde8fd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
