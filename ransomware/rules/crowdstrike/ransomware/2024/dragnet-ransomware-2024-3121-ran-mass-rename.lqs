// Dragnet [Ransomware]: dragnet-ransomware-2024-3121 — Mass File Rename (apt73)
// Status: experimental | Level: high | ID: 1f159a70-72e5-5cda-b902-139d0dd7cb6f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
