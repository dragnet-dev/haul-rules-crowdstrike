// Dragnet [Ransomware]: dragnet-ransomware-2024-2623 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 1c98870b-4cf5-52a0-936b-ae3a70c327aa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
