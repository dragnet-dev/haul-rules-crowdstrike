// Dragnet [Ransomware]: dragnet-ransomware-2020-0015 — Mass File Rename (maze)
// Status: deprecated | Level: high | ID: c0eb9928-f63b-5045-8ff3-d60ab2c3616d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
