// Dragnet [Ransomware]: dragnet-ransomware-2023-4368 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: fee18297-2a1f-5aa2-9c5f-d510332b50d4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
