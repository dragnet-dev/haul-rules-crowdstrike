// Dragnet [Ransomware]: dragnet-ransomware-2024-2257 — Mass File Rename (stormous)
// Status: deprecated | Level: high | ID: 9ade0566-dc09-56ed-be99-362e3433d8ba

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
