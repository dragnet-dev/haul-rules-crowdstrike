// Dragnet [Container]: dragnet-container-2025-0075 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 091edd92-6b9e-5837-964e-21e31771ee07

#event_simpleName=*
| (ImageFileName = *cbl-mariner:2.0* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *redhat/ubi9:*)
| table([timestamp, ComputerName])
| limit(1000)
