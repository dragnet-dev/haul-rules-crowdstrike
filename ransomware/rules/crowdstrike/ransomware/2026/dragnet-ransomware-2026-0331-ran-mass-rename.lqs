// Dragnet [Ransomware]: dragnet-ransomware-2026-0331 — Mass File Rename (payoutsking)
// Status: stable | Level: high | ID: be011777-600b-5382-a5de-d9c3fa062d9a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
