// Dragnet [Ransomware]: dragnet-ransomware-2024-1610 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 1f1dfb7e-dc99-51a2-b02b-ab1af8690db6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
