// Dragnet [Ransomware]: dragnet-ransomware-2023-1432 — Mass File Rename (nokoyawa)
// Status: experimental | Level: high | ID: 968b8af9-0cd3-5a7c-b1e6-b3c3d7cc7e2d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
