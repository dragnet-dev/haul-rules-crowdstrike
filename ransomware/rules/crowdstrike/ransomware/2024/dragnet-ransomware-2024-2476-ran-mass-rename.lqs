// Dragnet [Ransomware]: dragnet-ransomware-2024-2476 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: c801932f-2375-59c0-9de1-d32aeceb3121

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
