// Dragnet [Ransomware]: dragnet-ransomware-2022-3035 — Mass File Rename (cuba)
// Status: deprecated | Level: high | ID: 6e197517-e699-55fe-9f9c-c52f52b5d37c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
