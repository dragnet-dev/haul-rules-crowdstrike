// Dragnet [Ransomware]: dragnet-ransomware-2025-5773 — Mass File Rename (handala)
// Status: experimental | Level: high | ID: f0c3d174-41f6-52ef-a1aa-db5769525e4f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
