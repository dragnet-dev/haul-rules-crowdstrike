// Dragnet [Container]: dragnet-container-2026-0203 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 9e4fb36c-ca1e-5a54-9049-1ace4db7b5b0

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:5*)
| table([timestamp, ComputerName])
| limit(1000)
