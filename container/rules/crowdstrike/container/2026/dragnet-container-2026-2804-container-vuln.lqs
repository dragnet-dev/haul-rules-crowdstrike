// Dragnet [Container]: dragnet-container-2026-2804 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: c7bd5209-2dde-507c-9bc8-7d573fd48da5

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:6*)
| table([timestamp, ComputerName])
| limit(1000)
