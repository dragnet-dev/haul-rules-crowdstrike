// Dragnet [Ransomware]: dragnet-ransomware-2025-1006 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 40c8037c-7dcb-53ab-ab5f-e7e1719be6cf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
