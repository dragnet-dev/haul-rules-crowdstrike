// Dragnet [Ransomware]: dragnet-ransomware-2025-2450 — Mass File Rename (thegentlemen)
// Status: experimental | Level: high | ID: 314df2e6-bc58-5944-be12-26904a5bbc32

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
