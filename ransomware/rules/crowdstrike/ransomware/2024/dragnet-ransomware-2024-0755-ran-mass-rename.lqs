// Dragnet [Ransomware]: dragnet-ransomware-2024-0755 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 33f07d62-69f0-5a0c-97d5-511795238b90

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
