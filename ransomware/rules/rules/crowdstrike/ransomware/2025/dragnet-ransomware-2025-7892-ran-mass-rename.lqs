// Dragnet [Ransomware]: dragnet-ransomware-2025-7892 — Mass File Rename (radar)
// Status: deprecated | Level: high | ID: 8d8a0a10-1563-56d2-a75a-4fa9cd3aad11

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
