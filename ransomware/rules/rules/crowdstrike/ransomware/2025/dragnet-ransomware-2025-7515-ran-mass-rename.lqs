// Dragnet [Ransomware]: dragnet-ransomware-2025-7515 — Mass File Rename (warlock)
// Status: deprecated | Level: high | ID: 17cf0423-f9aa-5836-81cd-540a35369358

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
