// Dragnet [Ransomware]: dragnet-ransomware-2022-2166 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 38e61759-f733-579d-8a81-07645cf176df

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
