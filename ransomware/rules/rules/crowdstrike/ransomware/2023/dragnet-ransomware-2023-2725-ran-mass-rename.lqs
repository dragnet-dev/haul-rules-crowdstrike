// Dragnet [Ransomware]: dragnet-ransomware-2023-2725 — Mass File Rename (werewolves)
// Status: experimental | Level: high | ID: 06ed6b52-f1ac-52a2-b4c6-0846169e1152

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
