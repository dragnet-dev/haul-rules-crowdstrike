// Dragnet [Ransomware]: dragnet-ransomware-2023-2783 — Mass File Rename (malas)
// Status: experimental | Level: high | ID: 4ecf45eb-4818-5319-a2c9-0408c50af0cd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
