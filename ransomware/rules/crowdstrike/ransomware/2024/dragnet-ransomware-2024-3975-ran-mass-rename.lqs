// Dragnet [Ransomware]: dragnet-ransomware-2024-3975 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 7ac50bbb-f3bf-584c-8e8a-fd45d6a754ee

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
