// Dragnet [Ransomware]: dragnet-ransomware-2022-1816 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 24e78f76-3908-5721-a267-10ba210f96ff

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
