// Dragnet [Ransomware]: dragnet-ransomware-2020-0189 — Mass File Rename (maze)
// Status: deprecated | Level: high | ID: 87062e7c-200f-5b5a-b33c-761fa837b958

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
