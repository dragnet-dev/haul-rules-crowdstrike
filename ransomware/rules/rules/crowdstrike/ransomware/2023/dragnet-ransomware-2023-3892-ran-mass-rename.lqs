// Dragnet [Ransomware]: dragnet-ransomware-2023-3892 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 167340b1-af04-55f0-ab62-7ef3cc66ed91

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
