// Dragnet [Ransomware]: dragnet-ransomware-2024-0979 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 03665c3c-b743-5eb5-85ad-5635003b10cb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
