// Dragnet [Ransomware]: dragnet-ransomware-2025-2126 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 787962d4-e09f-5bb7-a707-e9d4941e69e8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
