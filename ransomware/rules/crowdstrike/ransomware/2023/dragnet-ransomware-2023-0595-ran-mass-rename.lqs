// Dragnet [Ransomware]: dragnet-ransomware-2023-0595 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: 373ed3e6-afa7-54a1-b2fa-1e30b051a981

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
