// Dragnet [Ransomware]: dragnet-ransomware-2026-2808 — Mass File Rename (SilentRansomGroup)
// Status: deprecated | Level: high | ID: a44fcc66-81e6-5dab-9db7-d265c06029cb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
