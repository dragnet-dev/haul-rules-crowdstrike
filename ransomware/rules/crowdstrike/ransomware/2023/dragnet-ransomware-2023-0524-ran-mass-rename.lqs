// Dragnet [Ransomware]: dragnet-ransomware-2023-0524 — Mass File Rename (stormous)
// Status: experimental | Level: high | ID: c6122216-bb8a-54b1-bf47-860d299fe0f4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
