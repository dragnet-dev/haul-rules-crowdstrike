// Dragnet [Ransomware]: dragnet-ransomware-2022-1485 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 235accf5-a292-5e4e-a2fe-e5c020bad44b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
