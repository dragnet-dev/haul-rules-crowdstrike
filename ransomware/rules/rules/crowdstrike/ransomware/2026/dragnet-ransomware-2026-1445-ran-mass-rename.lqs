// Dragnet [Ransomware]: dragnet-ransomware-2026-1445 — Mass File Rename (blackshrantac)
// Status: test | Level: high | ID: b279c581-4c3b-59fb-920a-ec3bbcda338d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
