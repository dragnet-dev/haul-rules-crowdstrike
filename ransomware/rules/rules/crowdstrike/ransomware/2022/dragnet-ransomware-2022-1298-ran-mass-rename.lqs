// Dragnet [Ransomware]: dragnet-ransomware-2022-1298 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 95feb121-d5c1-5537-9c94-d25609b2d447

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
