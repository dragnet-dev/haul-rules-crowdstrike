// Dragnet [Ransomware]: dragnet-ransomware-2022-2904 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: 3011586a-32ec-5865-b590-4062ed0d96c5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
