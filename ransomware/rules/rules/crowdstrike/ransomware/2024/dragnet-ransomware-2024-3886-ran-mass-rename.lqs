// Dragnet [Ransomware]: dragnet-ransomware-2024-3886 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 83844c94-6d04-5b7c-99b7-39c35d7d97a4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
