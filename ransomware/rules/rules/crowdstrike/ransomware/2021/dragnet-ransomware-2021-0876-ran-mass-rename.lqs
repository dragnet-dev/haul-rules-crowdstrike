// Dragnet [Ransomware]: dragnet-ransomware-2021-0876 — Mass File Rename (rook)
// Status: deprecated | Level: high | ID: 3812cd4d-6b2a-51a4-b473-ee3acc84f6f2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
