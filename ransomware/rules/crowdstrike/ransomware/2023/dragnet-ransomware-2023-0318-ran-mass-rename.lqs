// Dragnet [Ransomware]: dragnet-ransomware-2023-0318 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: bca03bb9-7ea0-5ce5-ad0f-560ea6f5801c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
