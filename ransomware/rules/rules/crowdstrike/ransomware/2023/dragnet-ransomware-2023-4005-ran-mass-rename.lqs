// Dragnet [Ransomware]: dragnet-ransomware-2023-4005 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 19d30c07-ac59-5555-b623-92898616e70e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
