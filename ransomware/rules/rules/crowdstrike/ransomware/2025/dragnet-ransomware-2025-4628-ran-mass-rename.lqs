// Dragnet [Ransomware]: dragnet-ransomware-2025-4628 — Mass File Rename (monti)
// Status: experimental | Level: high | ID: 0aafdf4e-e72d-5853-bc29-fe1f23831177

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
