// Dragnet [Ransomware]: dragnet-ransomware-2025-5450 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 0ae4287b-b7b8-5341-ae1a-ac216f51f711

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
