// Dragnet [Ransomware]: dragnet-ransomware-2022-3158 — Mass File Rename (play)
// Status: deprecated | Level: high | ID: 38be7dda-75d9-59c1-81f6-df53c8cfac9c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
