// Dragnet [Ransomware]: dragnet-ransomware-2023-5352 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 08d8e282-0428-521d-8134-0df0d15bf5cd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
