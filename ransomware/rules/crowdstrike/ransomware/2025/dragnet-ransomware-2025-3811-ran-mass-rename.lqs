// Dragnet [Ransomware]: dragnet-ransomware-2025-3811 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: 988f641f-73b8-5a3a-a5f6-7fc5cb7e04d5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
