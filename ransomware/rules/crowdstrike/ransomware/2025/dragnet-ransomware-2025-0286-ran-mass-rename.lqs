// Dragnet [Ransomware]: dragnet-ransomware-2025-0286 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 005a975d-bde6-50ca-ab88-bf1f0c73c078

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
