// Dragnet [Ransomware]: dragnet-ransomware-2021-1559 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 40077e2a-1f87-5cd7-8aee-fb9953f7ec99

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
