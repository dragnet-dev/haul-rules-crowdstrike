// Dragnet [Ransomware]: dragnet-ransomware-2023-4547 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: fee72693-f8f6-5cae-98e3-cc3a35098e7e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
