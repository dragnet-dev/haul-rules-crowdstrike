// Dragnet [Ransomware]: dragnet-ransomware-2025-3390 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: d464b00a-182e-57cc-a116-ea98b3d2816e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
