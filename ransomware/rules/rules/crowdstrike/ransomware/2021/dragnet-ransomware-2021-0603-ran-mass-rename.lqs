// Dragnet [Ransomware]: dragnet-ransomware-2021-0603 — Mass File Rename (suncrypt)
// Status: deprecated | Level: high | ID: d5b626ec-753d-5ef7-a8ca-5c964617f798

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
