// Dragnet [Ransomware]: dragnet-ransomware-2025-3438 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: b7895042-3493-5be2-9982-024cdf6e3a0a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
