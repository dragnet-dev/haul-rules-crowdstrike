// Dragnet [Ransomware]: dragnet-ransomware-2025-4811 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: ea4d93f2-d7fb-5012-91f4-c63ca6fe1805

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
