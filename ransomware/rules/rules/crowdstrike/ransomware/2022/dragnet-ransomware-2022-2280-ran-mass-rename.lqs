// Dragnet [Ransomware]: dragnet-ransomware-2022-2280 — Mass File Rename (cuba)
// Status: deprecated | Level: high | ID: 20feb1f4-e0bf-5097-aee0-be0fe5e36056

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
