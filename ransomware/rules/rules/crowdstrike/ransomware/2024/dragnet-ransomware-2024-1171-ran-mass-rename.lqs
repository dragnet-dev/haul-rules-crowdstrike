// Dragnet [Ransomware]: dragnet-ransomware-2024-1171 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 0b32885e-597a-5b4a-8058-176fcb6e8f85

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
