// Dragnet [Ransomware]: dragnet-ransomware-2025-3610 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: 0b6c053d-0dcd-547e-854c-b68719f37e08

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
