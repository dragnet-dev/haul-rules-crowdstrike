// Dragnet [Ransomware]: dragnet-ransomware-2024-4185 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: 7302d988-d9d5-5d54-aa7e-aea0dd878c3c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
