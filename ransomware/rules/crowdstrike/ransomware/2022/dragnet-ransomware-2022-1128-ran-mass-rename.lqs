// Dragnet [Ransomware]: dragnet-ransomware-2022-1128 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: c83702bd-09f5-5747-820d-579d522ee1e0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
