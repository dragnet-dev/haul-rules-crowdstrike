// Dragnet [Ransomware]: dragnet-ransomware-2021-0849 — Mass File Rename (blackmatter)
// Status: deprecated | Level: high | ID: 52767713-6da8-5eda-8a19-50908bbdbec5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
