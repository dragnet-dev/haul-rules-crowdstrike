// Dragnet [Ransomware]: dragnet-ransomware-2025-4791 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 0e255b1a-7808-5c02-8121-91d0a3f26056

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
