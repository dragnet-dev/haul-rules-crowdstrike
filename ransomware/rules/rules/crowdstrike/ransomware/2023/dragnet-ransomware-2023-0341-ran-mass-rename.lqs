// Dragnet [Ransomware]: dragnet-ransomware-2023-0341 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: f11973a1-def8-536d-a2d1-98ee82c8c1a4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
