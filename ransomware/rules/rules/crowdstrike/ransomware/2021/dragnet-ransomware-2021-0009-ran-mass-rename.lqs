// Dragnet [Ransomware]: dragnet-ransomware-2021-0009 — Mass File Rename (marketo)
// Status: deprecated | Level: high | ID: 7466cbc6-721f-5100-aff4-5b07305ce19c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
