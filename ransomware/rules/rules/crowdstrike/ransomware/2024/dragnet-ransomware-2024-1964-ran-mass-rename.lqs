// Dragnet [Ransomware]: dragnet-ransomware-2024-1964 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 7a05a363-ee70-50ba-9127-90c7c32697e9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
