// Dragnet [Ransomware]: dragnet-ransomware-2024-1372 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 94dd1b2e-77e5-5d0a-b38b-e07e99a878da

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
