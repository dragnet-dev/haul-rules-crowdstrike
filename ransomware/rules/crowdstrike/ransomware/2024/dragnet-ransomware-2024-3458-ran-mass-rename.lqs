// Dragnet [Ransomware]: dragnet-ransomware-2024-3458 — Mass File Rename (madliberator)
// Status: experimental | Level: high | ID: a9abf114-9e65-5aee-a97e-577472005e5e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
