// Dragnet [Ransomware]: dragnet-ransomware-2023-5019 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 21fd9177-149e-5e47-9119-69e46d861359

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
