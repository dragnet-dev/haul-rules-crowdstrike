// Dragnet [Ransomware]: dragnet-ransomware-2025-7869 — Mass File Rename (J)
// Status: experimental | Level: high | ID: fe26af70-97a5-551e-adac-9861353f2ca9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
