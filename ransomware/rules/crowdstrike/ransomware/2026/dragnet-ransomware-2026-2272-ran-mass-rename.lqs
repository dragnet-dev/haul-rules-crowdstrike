// Dragnet [Ransomware]: dragnet-ransomware-2026-2272 — Mass File Rename (lockbit5)
// Status: stable | Level: high | ID: 2190af1f-ea58-52a0-822a-2e5d435ad87b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
