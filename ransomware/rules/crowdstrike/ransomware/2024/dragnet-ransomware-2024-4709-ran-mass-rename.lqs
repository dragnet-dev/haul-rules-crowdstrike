// Dragnet [Ransomware]: dragnet-ransomware-2024-4709 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: e6f3474d-3af3-536b-9666-3cf0735e4fe9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
