// Dragnet [Ransomware]: dragnet-ransomware-2022-2637 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: f27d55ab-8da7-562f-9991-77de4b6063c8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
