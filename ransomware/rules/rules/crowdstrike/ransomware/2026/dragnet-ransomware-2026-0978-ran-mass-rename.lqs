// Dragnet [Ransomware]: dragnet-ransomware-2026-0978 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 767206df-9bcc-536e-89de-89e438a91ef7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
