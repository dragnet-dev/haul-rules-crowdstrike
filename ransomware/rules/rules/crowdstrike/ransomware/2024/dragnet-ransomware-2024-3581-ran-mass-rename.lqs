// Dragnet [Ransomware]: dragnet-ransomware-2024-3581 — Mass File Rename (play)
// Status: experimental | Level: high | ID: fc5e6e9c-1c08-5be7-9b80-375a0d2b12c9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
