// Dragnet [Ransomware]: dragnet-ransomware-2023-1271 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: d85e5c68-696f-5b10-8c3a-3e0d88469358

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
