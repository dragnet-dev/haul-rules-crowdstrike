// Dragnet [Ransomware]: dragnet-ransomware-2024-1483 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 391262fe-5fa7-5a73-a30e-c5a6e33034cc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
