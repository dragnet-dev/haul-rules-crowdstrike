// Dragnet [Ransomware]: dragnet-ransomware-2024-0250 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 349982bd-3096-5b6d-b208-7472c8455a78

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
