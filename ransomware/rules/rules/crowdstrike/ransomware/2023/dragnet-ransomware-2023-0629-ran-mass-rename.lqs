// Dragnet [Ransomware]: dragnet-ransomware-2023-0629 — Mass File Rename (siegedsec)
// Status: experimental | Level: high | ID: 3e8c004a-f717-51f7-a653-8799452244e8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
