// Dragnet [Ransomware]: dragnet-ransomware-2025-4773 — Mass File Rename (killsec)
// Status: deprecated | Level: high | ID: c2499fe9-1ea7-5cb5-8a6f-154dbbe6ea63

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
