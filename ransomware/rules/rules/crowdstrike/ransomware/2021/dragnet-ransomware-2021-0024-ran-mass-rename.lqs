// Dragnet [Ransomware]: dragnet-ransomware-2021-0024 — Mass File Rename (spook)
// Status: deprecated | Level: high | ID: 29c175f9-789b-5d7b-b454-f05f68a997c7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
