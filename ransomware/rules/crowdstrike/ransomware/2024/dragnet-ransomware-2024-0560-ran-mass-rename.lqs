// Dragnet [Ransomware]: dragnet-ransomware-2024-0560 — Mass File Rename (snatch)
// Status: experimental | Level: high | ID: fa6aefc4-e89e-51d0-95ac-644234f8b277

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
