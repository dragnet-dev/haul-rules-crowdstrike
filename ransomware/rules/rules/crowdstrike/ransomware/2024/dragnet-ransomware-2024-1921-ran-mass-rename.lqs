// Dragnet [Ransomware]: dragnet-ransomware-2024-1921 — Mass File Rename (stormous)
// Status: deprecated | Level: high | ID: 2ad050b3-e29f-5266-9ebe-195b17335a88

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
