// Dragnet [Ransomware]: dragnet-ransomware-2021-0964 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: b10d4610-8439-5fe6-996c-d190c97fd759

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
