// Dragnet [Ransomware]: dragnet-ransomware-2023-3491 — Mass File Rename (coinbasecartel)
// Status: experimental | Level: high | ID: d34fb317-2317-5b4b-8606-f71efd7f4ed1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
