// Dragnet [Ransomware]: dragnet-ransomware-2025-6781 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: c1c77303-805b-54ce-a620-32d4a6ebd770

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
