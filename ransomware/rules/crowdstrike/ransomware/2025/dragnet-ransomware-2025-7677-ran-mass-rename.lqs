// Dragnet [Ransomware]: dragnet-ransomware-2025-7677 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 62e0bfe0-718d-565c-bc58-f277c84415c0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
