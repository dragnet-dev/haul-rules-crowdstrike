// Dragnet [Ransomware]: dragnet-ransomware-2021-1456 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: cc5add9a-991a-5ac9-9268-9b44d5efd645

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
