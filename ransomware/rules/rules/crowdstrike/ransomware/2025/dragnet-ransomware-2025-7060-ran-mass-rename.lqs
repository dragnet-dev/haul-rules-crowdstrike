// Dragnet [Ransomware]: dragnet-ransomware-2025-7060 — Mass File Rename (beast)
// Status: experimental | Level: high | ID: db5da5fb-84a9-5e76-b51c-4ee426ea8672

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
