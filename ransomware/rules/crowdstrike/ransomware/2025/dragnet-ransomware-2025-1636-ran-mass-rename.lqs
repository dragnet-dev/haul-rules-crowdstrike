// Dragnet [Ransomware]: dragnet-ransomware-2025-1636 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 57ad427d-de52-511d-99a7-ff5d1726d5c7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
