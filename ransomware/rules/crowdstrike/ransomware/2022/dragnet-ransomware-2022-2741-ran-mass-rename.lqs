// Dragnet [Ransomware]: dragnet-ransomware-2022-2741 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 33bb182b-e0b2-5e22-a5fa-caf554fd73e6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
