// Dragnet [Ransomware]: dragnet-ransomware-2023-2916 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 8b13b65c-b614-553c-ae9c-089b308ba343

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
