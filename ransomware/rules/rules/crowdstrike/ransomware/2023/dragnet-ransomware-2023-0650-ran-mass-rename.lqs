// Dragnet [Ransomware]: dragnet-ransomware-2023-0650 — Mass File Rename (noescape)
// Status: experimental | Level: high | ID: 0128a0a7-29e7-5e2d-8ddc-32c6c1fd0c16

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
