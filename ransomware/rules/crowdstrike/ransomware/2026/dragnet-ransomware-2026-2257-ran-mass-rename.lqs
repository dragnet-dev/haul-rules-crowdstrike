// Dragnet [Ransomware]: dragnet-ransomware-2026-2257 — Mass File Rename (dragonforce)
// Status: stable | Level: high | ID: 45eb8046-46f3-5f0c-a54b-3c7f8b35cbc7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
