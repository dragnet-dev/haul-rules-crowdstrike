// Dragnet [Ransomware]: dragnet-ransomware-2023-4481 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 5fc1c5db-5cf8-5bdd-af5b-d147900f8643

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
