// Dragnet [Ransomware]: dragnet-ransomware-2024-0155 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: d86149bf-27ba-5e43-9e30-5d514d73c363

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
