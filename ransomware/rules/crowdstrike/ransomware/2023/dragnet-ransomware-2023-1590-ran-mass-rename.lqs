// Dragnet [Ransomware]: dragnet-ransomware-2023-1590 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 18d8b796-8941-5ab6-b8cd-484548c68887

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
