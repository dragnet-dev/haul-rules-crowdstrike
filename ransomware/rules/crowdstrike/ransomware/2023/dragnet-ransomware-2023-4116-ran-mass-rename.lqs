// Dragnet [Ransomware]: dragnet-ransomware-2023-4116 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 63f2af08-23f2-5a27-9308-da7ef609b69b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
