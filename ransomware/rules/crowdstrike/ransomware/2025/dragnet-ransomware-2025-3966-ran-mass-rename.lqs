// Dragnet [Ransomware]: dragnet-ransomware-2025-3966 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: ce2b76fb-9b55-5705-b9e7-470e57a070a3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
