// Dragnet [Ransomware]: dragnet-ransomware-2024-0353 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 7a589057-6400-54a3-ab04-e8f091cce873

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
