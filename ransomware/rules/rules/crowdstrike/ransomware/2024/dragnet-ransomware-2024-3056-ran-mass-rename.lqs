// Dragnet [Ransomware]: dragnet-ransomware-2024-3056 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 3c45abfb-1399-5b91-89b4-6a4bfad63c4c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
