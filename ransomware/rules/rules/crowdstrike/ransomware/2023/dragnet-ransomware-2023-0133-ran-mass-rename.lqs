// Dragnet [Ransomware]: dragnet-ransomware-2023-0133 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 43cae44a-2660-5d1d-8113-8e1f88e345bb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
