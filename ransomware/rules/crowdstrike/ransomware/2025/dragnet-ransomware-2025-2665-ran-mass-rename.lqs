// Dragnet [Ransomware]: dragnet-ransomware-2025-2665 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 836b10c3-0e41-5990-8289-af81531a5df4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
