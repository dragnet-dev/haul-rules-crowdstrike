// Dragnet [Ransomware]: dragnet-ransomware-2025-5332 — Mass File Rename (lockbit5)
// Status: experimental | Level: high | ID: 11b2e97b-3b06-51fd-a6d0-7c7fe0574c60

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
