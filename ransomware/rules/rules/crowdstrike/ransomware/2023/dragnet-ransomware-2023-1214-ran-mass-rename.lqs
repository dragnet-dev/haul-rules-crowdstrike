// Dragnet [Ransomware]: dragnet-ransomware-2023-1214 — Mass File Rename (noescape)
// Status: experimental | Level: high | ID: b1294f94-689f-5f72-8334-9dc1da873da3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
