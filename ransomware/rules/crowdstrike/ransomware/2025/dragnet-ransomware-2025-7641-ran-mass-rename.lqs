// Dragnet [Ransomware]: dragnet-ransomware-2025-7641 — Mass File Rename (cloak)
// Status: deprecated | Level: high | ID: b5cfd9e3-1e58-581c-bd23-9c974505b4d7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
