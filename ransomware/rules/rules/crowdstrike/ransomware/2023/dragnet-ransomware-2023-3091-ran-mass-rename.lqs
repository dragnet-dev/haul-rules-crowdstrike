// Dragnet [Ransomware]: dragnet-ransomware-2023-3091 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 327e6588-58f8-55e9-8b14-53db9705fb9f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
