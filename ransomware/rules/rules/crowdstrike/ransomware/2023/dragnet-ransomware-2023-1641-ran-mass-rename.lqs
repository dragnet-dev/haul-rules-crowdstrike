// Dragnet [Ransomware]: dragnet-ransomware-2023-1641 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: cd934065-793f-5d14-b463-1fa9304ee92b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
