// Dragnet [Container]: dragnet-container-2026-2369 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: e2d27960-1947-5f35-a4ea-86afed74d3df

#event_simpleName=*
| (ImageFileName = *amazonlinux:1* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6*)
| table([timestamp, ComputerName])
| limit(1000)
