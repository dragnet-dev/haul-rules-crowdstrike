// Dragnet [Ransomware]: dragnet-ransomware-2022-2664 — Mass File Rename (alphv)
// Status: deprecated | Level: high | ID: 0bb1c5f7-8eba-5806-8835-764d0de4b015

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
