// Dragnet [Ransomware]: dragnet-ransomware-2021-1390 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 1dc7f33e-79aa-55b0-89db-a7826a366566

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
