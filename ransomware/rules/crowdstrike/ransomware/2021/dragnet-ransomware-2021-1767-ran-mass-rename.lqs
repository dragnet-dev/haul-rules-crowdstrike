// Dragnet [Ransomware]: dragnet-ransomware-2021-1767 — Mass File Rename (darkleakmarket)
// Status: deprecated | Level: high | ID: caa0d15f-6ca2-5a9b-8310-0273c173d1ef

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
