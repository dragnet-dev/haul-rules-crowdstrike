// Dragnet [Ransomware]: dragnet-ransomware-2024-2104 — Mass File Rename (play)
// Status: experimental | Level: high | ID: c22fc156-7071-50be-8707-06169511703b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
