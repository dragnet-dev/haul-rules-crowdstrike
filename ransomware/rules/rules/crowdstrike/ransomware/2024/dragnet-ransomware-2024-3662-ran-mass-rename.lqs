// Dragnet [Ransomware]: dragnet-ransomware-2024-3662 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: f48bb704-cc36-5598-a0af-7ac23726d624

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
