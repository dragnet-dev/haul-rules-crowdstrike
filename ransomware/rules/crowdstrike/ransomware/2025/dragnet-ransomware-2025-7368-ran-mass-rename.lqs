// Dragnet [Ransomware]: dragnet-ransomware-2025-7368 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: f595c0be-0ad6-5e3d-bf57-e0b6c6c76caa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
