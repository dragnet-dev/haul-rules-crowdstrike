// Dragnet [Ransomware]: dragnet-ransomware-2024-1666 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: ba3d55ed-d9e9-5fea-a0a6-33e56ed7dfd6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
