// Dragnet [Ransomware]: dragnet-ransomware-2023-4956 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 3b033524-4da7-5940-bc7d-95d5b9f7e896

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
