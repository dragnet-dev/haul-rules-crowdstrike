// Dragnet [Ransomware]: dragnet-ransomware-2025-7366 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 1aad8d38-086c-5f3e-b06b-63d65f2abb53

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
