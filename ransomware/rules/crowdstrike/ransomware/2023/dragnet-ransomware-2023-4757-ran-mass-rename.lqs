// Dragnet [Ransomware]: dragnet-ransomware-2023-4757 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 7cfc63d6-c4cf-5e9f-a601-31358d2e4d0f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
