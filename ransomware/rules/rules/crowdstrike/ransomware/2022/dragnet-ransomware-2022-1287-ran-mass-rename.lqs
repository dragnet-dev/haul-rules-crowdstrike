// Dragnet [Ransomware]: dragnet-ransomware-2022-1287 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: bbebfee4-9886-50de-a452-4e38833eb7c7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
