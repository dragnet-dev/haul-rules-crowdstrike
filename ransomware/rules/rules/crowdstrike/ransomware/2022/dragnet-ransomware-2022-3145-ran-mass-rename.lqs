// Dragnet [Ransomware]: dragnet-ransomware-2022-3145 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: ddf5d5f0-98e6-5880-8819-33f791d7aa8d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
