// Dragnet [Ransomware]: dragnet-ransomware-2022-2666 — Mass File Rename (royal)
// Status: deprecated | Level: high | ID: 01029ab3-14a0-5196-8c23-ee29ac47e971

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
