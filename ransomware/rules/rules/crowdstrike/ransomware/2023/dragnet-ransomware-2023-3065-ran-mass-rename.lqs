// Dragnet [Ransomware]: dragnet-ransomware-2023-3065 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 44d55378-3e3f-585d-bb0f-62c2f453c933

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
