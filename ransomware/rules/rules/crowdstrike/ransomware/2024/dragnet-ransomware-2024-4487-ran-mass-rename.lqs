// Dragnet [Ransomware]: dragnet-ransomware-2024-4487 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: cc70f537-ad05-50d4-a3c2-415932837980

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
