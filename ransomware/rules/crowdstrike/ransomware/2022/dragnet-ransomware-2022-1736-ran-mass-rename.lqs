// Dragnet [Ransomware]: dragnet-ransomware-2022-1736 — Mass File Rename (blackbasta)
// Status: deprecated | Level: high | ID: 12e0b2b9-f1f8-566a-a6b1-0cb53cd51c73

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
