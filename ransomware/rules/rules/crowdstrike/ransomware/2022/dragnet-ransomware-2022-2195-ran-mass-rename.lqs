// Dragnet [Ransomware]: dragnet-ransomware-2022-2195 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 6661b4d2-9050-588d-a564-836a2f954a22

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
