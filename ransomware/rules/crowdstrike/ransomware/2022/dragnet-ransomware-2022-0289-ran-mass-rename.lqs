// Dragnet [Ransomware]: dragnet-ransomware-2022-0289 — Mass File Rename (play)
// Status: deprecated | Level: high | ID: 05bf811f-b87e-5186-9a0f-f7bc748e39e2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
