// Dragnet [Ransomware]: dragnet-ransomware-2025-0478 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 749fb35a-6505-54d6-8c6c-64337aab29bc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
