// Dragnet [Ransomware]: dragnet-ransomware-2025-1687 — Mass File Rename (teamxxx)
// Status: experimental | Level: high | ID: 837034e2-f50f-5a80-92de-38fd559ff9c9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
