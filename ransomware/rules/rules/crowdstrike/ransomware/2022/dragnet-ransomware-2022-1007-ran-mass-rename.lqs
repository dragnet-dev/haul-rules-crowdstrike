// Dragnet [Ransomware]: dragnet-ransomware-2022-1007 — Mass File Rename (lv)
// Status: deprecated | Level: high | ID: 371b76b1-1520-5ad7-853f-a56116697779

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
