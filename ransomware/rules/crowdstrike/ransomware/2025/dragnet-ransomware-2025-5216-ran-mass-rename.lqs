// Dragnet [Ransomware]: dragnet-ransomware-2025-5216 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: d80382e9-933e-53ce-974b-229ba37ebe0e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
