// Dragnet [Ransomware]: dragnet-ransomware-2026-2983 — Mass File Rename (incransom)
// Status: test | Level: high | ID: fe73e625-43e1-5405-8a76-7986b79540a5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
