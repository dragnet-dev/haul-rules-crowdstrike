// Dragnet [Ransomware]: dragnet-ransomware-2024-3038 — Mass File Rename (interlock)
// Status: experimental | Level: high | ID: 7714ea00-e5dd-5974-bfdd-7e82121daf6b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
