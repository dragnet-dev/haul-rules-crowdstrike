// Dragnet [Ransomware]: dragnet-ransomware-2025-2065 — Mass File Rename (lockbit5)
// Status: experimental | Level: high | ID: 216a5a43-904d-5049-9de1-12bcc59fc23a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
