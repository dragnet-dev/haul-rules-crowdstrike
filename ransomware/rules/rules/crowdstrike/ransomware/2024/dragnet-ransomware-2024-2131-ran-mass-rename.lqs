// Dragnet [Ransomware]: dragnet-ransomware-2024-2131 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: eba7ed0d-7ff0-5073-9af8-08b1de9f9fd4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
