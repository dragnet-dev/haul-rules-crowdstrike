// Dragnet [Ransomware]: dragnet-ransomware-2024-1198 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 82f0e1f1-d808-5308-8929-efdee2e9d66f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
