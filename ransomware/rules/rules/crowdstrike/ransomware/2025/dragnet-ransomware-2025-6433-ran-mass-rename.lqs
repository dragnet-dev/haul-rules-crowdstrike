// Dragnet [Ransomware]: dragnet-ransomware-2025-6433 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 58a67074-d1c9-5d0e-9758-110b8ecdb5c5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
