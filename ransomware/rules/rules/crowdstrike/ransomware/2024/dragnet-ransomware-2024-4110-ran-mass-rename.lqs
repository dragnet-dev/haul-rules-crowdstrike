// Dragnet [Ransomware]: dragnet-ransomware-2024-4110 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 279e3634-1930-5e92-88c5-43adcdac4d66

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
