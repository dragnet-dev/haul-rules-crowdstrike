// Dragnet [Ransomware]: dragnet-ransomware-2025-3155 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: 64782db1-cf24-5214-a11b-3cb955b5e2eb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
