// Dragnet [Ransomware]: dragnet-ransomware-2025-2863 — Mass File Rename (GDLockerSec)
// Status: experimental | Level: high | ID: 5200015e-dba3-59b7-93cb-fc227c2b102f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
