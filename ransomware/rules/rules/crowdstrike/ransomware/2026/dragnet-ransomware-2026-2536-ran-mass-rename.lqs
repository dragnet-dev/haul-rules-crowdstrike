// Dragnet [Ransomware]: dragnet-ransomware-2026-2536 — Mass File Rename (krybit)
// Status: stable | Level: high | ID: 7c1ed38a-7cac-5dbb-97b3-5d9ad764fa20

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
