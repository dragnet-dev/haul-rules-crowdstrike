// Dragnet [Ransomware]: dragnet-ransomware-2021-0083 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 969bda77-019e-5668-8213-9b393c88e367

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
