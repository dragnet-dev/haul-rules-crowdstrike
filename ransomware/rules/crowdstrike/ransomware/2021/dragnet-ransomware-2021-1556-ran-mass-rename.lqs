// Dragnet [Ransomware]: dragnet-ransomware-2021-1556 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 0f2f6ccc-cfac-5d7e-ba47-c189de8b9e2f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
