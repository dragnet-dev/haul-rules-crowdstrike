// Dragnet [Ransomware]: dragnet-ransomware-2023-0873 — Mass File Rename (ragnarlocker)
// Status: deprecated | Level: high | ID: 9bc5aef9-b5ec-5335-8b11-b232cc605fa9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
