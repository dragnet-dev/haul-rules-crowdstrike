// Dragnet [Ransomware]: dragnet-ransomware-2023-3781 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 91bf4c5b-728f-5850-bd55-417df2c80e89

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
