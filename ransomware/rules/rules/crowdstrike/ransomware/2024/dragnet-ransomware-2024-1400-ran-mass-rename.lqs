// Dragnet [Ransomware]: dragnet-ransomware-2024-1400 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 8390ced8-365a-526c-8ce3-4bcb7ae7d3ec

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
