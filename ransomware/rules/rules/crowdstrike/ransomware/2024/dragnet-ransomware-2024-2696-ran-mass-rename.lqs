// Dragnet [Ransomware]: dragnet-ransomware-2024-2696 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 74b24c0c-40d1-53ba-b0f6-d86fbda53349

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
