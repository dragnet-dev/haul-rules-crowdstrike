// Dragnet [Ransomware]: dragnet-ransomware-2025-0729 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: ca3663dc-292f-50dd-a82a-9a1dfb96a808

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
