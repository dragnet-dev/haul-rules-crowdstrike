// Dragnet [Ransomware]: dragnet-ransomware-2021-0619 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 1f7cc732-8e60-52f9-b584-4223a2e89b0b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
