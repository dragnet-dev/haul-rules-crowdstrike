// Dragnet [Ransomware]: dragnet-ransomware-2021-0793 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: 8d2247c7-39a8-56df-b4b9-0d49fd041453

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
