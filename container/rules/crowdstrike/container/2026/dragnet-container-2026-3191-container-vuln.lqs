// Dragnet [Container]: dragnet-container-2026-3191 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 5348b7a5-0c61-5523-8a30-5532c0111c38

#event_simpleName=*
| (ImageFileName = *chainguard:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
