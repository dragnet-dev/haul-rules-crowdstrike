// Dragnet [Ransomware]: dragnet-ransomware-2022-1612 — Mass File Rename (icefire)
// Status: deprecated | Level: high | ID: 5aaf4e22-8b9d-53c2-a2a1-b7ff89803e55

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
