// Dragnet [Ransomware]: dragnet-ransomware-2022-2381 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 2797d884-efe2-597d-9167-016527397e83

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
