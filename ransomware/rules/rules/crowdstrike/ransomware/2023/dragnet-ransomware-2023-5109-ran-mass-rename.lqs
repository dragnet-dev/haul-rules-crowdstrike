// Dragnet [Ransomware]: dragnet-ransomware-2023-5109 — Mass File Rename (raworld)
// Status: experimental | Level: high | ID: 47ab7373-e8fc-5b4e-8ab7-2484cc2d8702

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
