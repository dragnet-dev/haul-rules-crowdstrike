// Dragnet [Ransomware]: dragnet-ransomware-2025-7444 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 615c88bb-1c18-51ea-8cdf-f3dad06bfdc5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
