// Dragnet [Ransomware]: dragnet-ransomware-2023-1982 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 0c83aa78-a8ac-5395-9f49-165ea4781489

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
