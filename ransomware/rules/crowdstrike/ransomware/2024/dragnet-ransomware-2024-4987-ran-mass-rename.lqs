// Dragnet [Ransomware]: dragnet-ransomware-2024-4987 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 31a6d7e2-ecf8-519e-8f79-7ce0a316ea57

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
