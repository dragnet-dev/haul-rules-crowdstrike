// Dragnet [Ransomware]: dragnet-ransomware-2025-2609 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 09174115-5d6f-5900-88a3-03b58f5f9623

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
