// Dragnet [Ransomware]: dragnet-ransomware-2024-3021 — Mass File Rename (qilin)
// Status: deprecated | Level: high | ID: 462efe62-4c7a-5355-8f1b-f6eeb6190c8f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
