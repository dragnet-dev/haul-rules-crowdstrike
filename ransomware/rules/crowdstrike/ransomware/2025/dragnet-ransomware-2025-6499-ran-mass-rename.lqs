// Dragnet [Ransomware]: dragnet-ransomware-2025-6499 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 6cf4ac3e-05cc-5307-922c-eccc0e98d76e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
