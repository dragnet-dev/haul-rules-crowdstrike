// Dragnet [Ransomware]: dragnet-ransomware-2023-0320 — Mass File Rename (royal)
// Status: experimental | Level: high | ID: 705b0d1e-fcc2-5aca-b5b9-be205d36f189

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
