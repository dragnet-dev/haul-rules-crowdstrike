// Dragnet [Ransomware]: dragnet-ransomware-2025-1952 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: ba2315ce-550f-5774-874b-bac3de069fd1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
