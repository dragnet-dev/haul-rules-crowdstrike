// Dragnet [Ransomware]: dragnet-ransomware-2022-0579 — Mass File Rename (avoslocker)
// Status: deprecated | Level: high | ID: e71ce72e-065a-51b5-85a6-e17ee468baa6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
