// Dragnet [Ransomware]: dragnet-ransomware-2024-3687 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 3296072f-5f88-50bc-88bc-c143d107a154

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
