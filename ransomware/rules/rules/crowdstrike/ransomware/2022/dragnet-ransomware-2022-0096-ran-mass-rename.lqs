// Dragnet [Ransomware]: dragnet-ransomware-2022-0096 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 254d7302-a455-5dfb-84bf-5b97580f2b6d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
