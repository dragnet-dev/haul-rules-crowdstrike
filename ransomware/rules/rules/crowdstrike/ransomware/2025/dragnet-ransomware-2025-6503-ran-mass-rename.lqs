// Dragnet [Ransomware]: dragnet-ransomware-2025-6503 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: d260c5a5-44dd-549b-a1fe-d9eedcb797da

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
