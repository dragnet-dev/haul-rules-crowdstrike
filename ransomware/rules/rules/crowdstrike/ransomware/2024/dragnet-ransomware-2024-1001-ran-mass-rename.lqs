// Dragnet [Ransomware]: dragnet-ransomware-2024-1001 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 371ac87b-7951-56b4-9bd2-177cf8f9c94a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
