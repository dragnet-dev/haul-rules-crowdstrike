// Dragnet [Ransomware]: dragnet-ransomware-2024-5458 — Mass File Rename (qiulong)
// Status: experimental | Level: high | ID: 9be089de-a113-5c48-b8f4-4d99192d1ba4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
