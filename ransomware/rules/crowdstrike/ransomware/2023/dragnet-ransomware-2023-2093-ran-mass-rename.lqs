// Dragnet [Ransomware]: dragnet-ransomware-2023-2093 — Mass File Rename (ransomhouse)
// Status: experimental | Level: high | ID: a1bc3b34-c505-551b-9855-8d5a495ea53f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
