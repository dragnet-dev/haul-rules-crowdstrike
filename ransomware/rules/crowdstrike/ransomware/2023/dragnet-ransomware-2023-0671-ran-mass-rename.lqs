// Dragnet [Ransomware]: dragnet-ransomware-2023-0671 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: c0531ab1-294e-5ca8-8b8e-d83e95e327e2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
