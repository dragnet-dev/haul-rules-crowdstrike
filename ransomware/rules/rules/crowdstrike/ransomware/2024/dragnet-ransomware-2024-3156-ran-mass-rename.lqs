// Dragnet [Ransomware]: dragnet-ransomware-2024-3156 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: 59075acf-ea25-5f14-be0d-29f3b7cfab96

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
