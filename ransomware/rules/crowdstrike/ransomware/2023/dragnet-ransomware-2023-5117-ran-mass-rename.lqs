// Dragnet [Ransomware]: dragnet-ransomware-2023-5117 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: c60bd3e8-1bdc-5fc8-b6cc-ad0dd93f4de3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
