// Dragnet [Ransomware]: dragnet-ransomware-2023-4645 — Mass File Rename (cactus)
// Status: deprecated | Level: high | ID: 0e669021-b6d6-5017-bf70-8f84babcfe80

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
