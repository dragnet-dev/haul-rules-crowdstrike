// Dragnet [Ransomware]: dragnet-ransomware-2025-3755 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: fd78bb87-d3fa-56ff-add6-791e7fa9dc01

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
