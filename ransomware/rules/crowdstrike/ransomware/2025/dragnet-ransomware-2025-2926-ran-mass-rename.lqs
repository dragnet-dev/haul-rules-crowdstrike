// Dragnet [Ransomware]: dragnet-ransomware-2025-2926 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 17d4a917-5f25-5d87-8940-9101219876a0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
