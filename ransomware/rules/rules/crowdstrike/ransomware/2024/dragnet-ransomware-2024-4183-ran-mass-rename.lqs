// Dragnet [Ransomware]: dragnet-ransomware-2024-4183 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 56bd9f62-9940-5057-b456-edfe9a8e2b2a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
