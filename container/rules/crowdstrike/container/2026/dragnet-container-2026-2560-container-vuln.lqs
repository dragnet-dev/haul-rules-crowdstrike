// Dragnet [Container]: dragnet-container-2026-2560 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: d8dd22a0-95ff-5e71-bf51-b5f1795b2bbb

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
