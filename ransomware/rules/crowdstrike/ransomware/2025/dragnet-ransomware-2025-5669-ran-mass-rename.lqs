// Dragnet [Ransomware]: dragnet-ransomware-2025-5669 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: effa792c-0f31-58a8-8c6c-5d8be3602b8b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
