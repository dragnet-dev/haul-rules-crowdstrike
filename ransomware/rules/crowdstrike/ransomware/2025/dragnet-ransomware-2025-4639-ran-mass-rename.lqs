// Dragnet [Ransomware]: dragnet-ransomware-2025-4639 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 5c89cc2b-8d0f-5646-94b8-c7564856b405

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
