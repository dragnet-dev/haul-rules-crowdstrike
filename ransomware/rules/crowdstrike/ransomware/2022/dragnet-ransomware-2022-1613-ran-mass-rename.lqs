// Dragnet [Ransomware]: dragnet-ransomware-2022-1613 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 7c353bdd-b879-50f2-b7c3-16cd3735e1f3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
