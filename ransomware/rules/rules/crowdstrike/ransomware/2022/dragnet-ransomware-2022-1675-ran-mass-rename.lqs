// Dragnet [Ransomware]: dragnet-ransomware-2022-1675 — Mass File Rename (snatch)
// Status: deprecated | Level: high | ID: d75a640a-9f8e-56f7-8dc9-3ea871c00476

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
