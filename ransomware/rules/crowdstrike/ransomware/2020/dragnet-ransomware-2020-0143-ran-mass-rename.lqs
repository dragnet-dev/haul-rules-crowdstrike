// Dragnet [Ransomware]: dragnet-ransomware-2020-0143 — Mass File Rename (netwalker)
// Status: deprecated | Level: high | ID: 74abc088-d8e5-5127-910f-4d0dd2630cf9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
