// Dragnet [Ransomware]: dragnet-ransomware-2023-2278 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 66d0815c-77e2-5c43-8fd5-4bdde15b5782

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
