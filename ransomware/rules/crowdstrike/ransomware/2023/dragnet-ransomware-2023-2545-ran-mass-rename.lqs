// Dragnet [Ransomware]: dragnet-ransomware-2023-2545 — Mass File Rename (ransomed)
// Status: experimental | Level: high | ID: a6e07db0-31f2-5dc8-9238-2ae2cacf371d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
