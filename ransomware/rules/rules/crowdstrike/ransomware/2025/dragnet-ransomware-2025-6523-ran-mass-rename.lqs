// Dragnet [Ransomware]: dragnet-ransomware-2025-6523 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 7b30772e-72ce-56f0-8b0f-7e0f69853441

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
