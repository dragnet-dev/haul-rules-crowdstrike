// Dragnet [Ransomware]: dragnet-ransomware-2023-5263 — Mass File Rename (noescape)
// Status: experimental | Level: high | ID: 4e0cda19-1e95-5c3b-a4ad-34a16d2a6124

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
