// Dragnet [Ransomware]: dragnet-ransomware-2023-4167 — Mass File Rename (noescape)
// Status: experimental | Level: high | ID: 8af5dd50-4f22-50d3-bf90-193171f5b503

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
