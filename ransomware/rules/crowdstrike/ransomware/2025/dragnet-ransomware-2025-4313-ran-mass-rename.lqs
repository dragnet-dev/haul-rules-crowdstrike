// Dragnet [Ransomware]: dragnet-ransomware-2025-4313 — Mass File Rename (teamxxx)
// Status: experimental | Level: high | ID: b9e3e943-d99d-54c3-8a14-ebcfdc620f5a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
