// Dragnet [Container]: dragnet-container-2026-0186 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: c54ca2a8-cfa3-5ed2-81b9-941b4b2311d1

#event_simpleName=*
| (ImageFileName = *amazonlinux:1* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:16.04* OR ImageFileName = *ubuntu:16.04-ESM* OR ImageFileName = *ubuntu:16.10*)
| table([timestamp, ComputerName])
| limit(1000)
