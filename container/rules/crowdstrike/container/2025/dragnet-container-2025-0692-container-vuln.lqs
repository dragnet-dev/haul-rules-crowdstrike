// Dragnet [Container]: dragnet-container-2025-0692 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: ac11ee18-59e2-5eb5-8af9-a3c378b986bf

#event_simpleName=*
| (ImageFileName = *amazonlinux:1* OR ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *ubuntu:18.04-ESM* OR ImageFileName = *ubuntu:20.04-ESM* OR ImageFileName = *ubuntu:22.04*)
| table([timestamp, ComputerName])
| limit(1000)
