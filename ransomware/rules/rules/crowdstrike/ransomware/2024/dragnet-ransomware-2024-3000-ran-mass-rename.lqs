// Dragnet [Ransomware]: dragnet-ransomware-2024-3000 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 4aa772e6-9a15-5fa9-aca4-1d2d1badddcc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
