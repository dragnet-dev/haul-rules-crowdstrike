// Dragnet [Ransomware]: dragnet-ransomware-2023-2359 — Mass File Rename (cactus)
// Status: deprecated | Level: high | ID: dfd25622-21d4-5b20-9a25-b498734b55c3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
