// Dragnet [Ransomware]: dragnet-ransomware-2025-6860 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 0e41d925-c19c-5718-a661-ed23d0b754ac

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
