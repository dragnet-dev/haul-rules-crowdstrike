// Dragnet [Ransomware]: dragnet-ransomware-2025-7623 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 00fbd948-614a-51e2-89dd-c2c474710c34

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
