// Dragnet [Ransomware]: dragnet-ransomware-2025-5449 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 15bcdfef-0486-563b-9ce8-cf5186ec6b41

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
