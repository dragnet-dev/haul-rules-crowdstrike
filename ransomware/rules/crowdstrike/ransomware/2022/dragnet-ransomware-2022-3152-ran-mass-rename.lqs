// Dragnet [Ransomware]: dragnet-ransomware-2022-3152 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 34680ac0-573e-5486-a70b-b05c30a5ada8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
