// Dragnet [Ransomware]: dragnet-ransomware-2025-2898 — Mass File Rename (devman)
// Status: deprecated | Level: high | ID: 439663f7-71b2-5a44-ab8b-3d0ed995c11b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
