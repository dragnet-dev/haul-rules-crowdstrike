// Dragnet [Ransomware]: dragnet-ransomware-2025-3039 — Mass File Rename (warlock)
// Status: deprecated | Level: high | ID: 329543da-d738-506c-a514-a4681744df4b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
