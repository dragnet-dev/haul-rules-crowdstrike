// Dragnet [Container]: dragnet-container-2024-0592 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: c91e7a2b-c099-5f71-98cd-106fd5201b9f

#event_simpleName=*
| (ImageFileName = *chainguard:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *photon os:4.0* OR ImageFileName = *ubuntu:20.04-ESM* OR ImageFileName = *ubuntu:22.04* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
