// Dragnet [Ransomware]: dragnet-ransomware-2022-0880 — Mass File Rename (everest)
// Status: deprecated | Level: high | ID: 5749abc5-674d-541e-aaf6-cde9b2798ab3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
