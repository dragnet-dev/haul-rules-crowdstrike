// Dragnet [Ransomware]: dragnet-ransomware-2023-3609 — Mass File Rename (ragnarlocker)
// Status: experimental | Level: high | ID: f095d4ce-1655-5e9b-8c93-4cbbc7eab4f5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
