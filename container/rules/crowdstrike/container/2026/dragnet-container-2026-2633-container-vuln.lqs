// Dragnet [Container]: dragnet-container-2026-2633 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: d2e19645-6003-5353-8d29-ac4296ae843d

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:5*)
| table([timestamp, ComputerName])
| limit(1000)
