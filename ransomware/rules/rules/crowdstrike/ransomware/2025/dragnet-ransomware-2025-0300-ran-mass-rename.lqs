// Dragnet [Ransomware]: dragnet-ransomware-2025-0300 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 43e1b8e3-d390-594f-8b6d-7e2d13b64bbc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
