// Dragnet [Ransomware]: dragnet-ransomware-2024-5968 — Mass File Rename (cicada3301)
// Status: experimental | Level: high | ID: 163e10ed-6400-5d02-b065-1acc29e95dd2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
