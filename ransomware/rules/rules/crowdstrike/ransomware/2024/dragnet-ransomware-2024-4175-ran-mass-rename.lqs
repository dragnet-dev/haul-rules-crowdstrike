// Dragnet [Ransomware]: dragnet-ransomware-2024-4175 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 1db2fa30-c031-577d-8118-bc9ad9a081c3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
