// Dragnet [Ransomware]: dragnet-ransomware-2026-1625 — Mass File Rename (everest)
// Status: stable | Level: high | ID: f6f6a435-25d4-5322-89ed-8bba10f7cb44

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
