// Dragnet [Ransomware]: dragnet-ransomware-2022-2965 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 7701c2c2-0cc4-544a-b987-24f6f2785bb8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
