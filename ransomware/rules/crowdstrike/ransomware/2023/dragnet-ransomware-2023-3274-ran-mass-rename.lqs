// Dragnet [Ransomware]: dragnet-ransomware-2023-3274 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 6868ce46-992e-5f84-9179-e1695a6cea9c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
