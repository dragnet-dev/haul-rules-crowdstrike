// Dragnet [Ransomware]: dragnet-ransomware-2023-4690 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: c391d36e-122f-5a3f-b1df-6068dffed074

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
