// Dragnet [Container]: dragnet-container-2026-1261 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 04ac4a5c-e816-5026-965e-dca9de2489a3

#event_simpleName=*
| (ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10* OR ImageFileName = *ubuntu:13.04* OR ImageFileName = *ubuntu:13.10*)
| table([timestamp, ComputerName])
| limit(1000)
