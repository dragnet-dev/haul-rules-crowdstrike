// Dragnet [Ransomware]: dragnet-ransomware-2021-0837 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: e054f321-687c-5812-ae00-0edcf94e4146

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
