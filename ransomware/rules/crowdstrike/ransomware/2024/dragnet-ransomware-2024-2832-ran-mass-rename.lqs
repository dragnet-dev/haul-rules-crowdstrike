// Dragnet [Ransomware]: dragnet-ransomware-2024-2832 — Mass File Rename (rhysida)
// Status: deprecated | Level: high | ID: 6aa317bd-ce42-5ed6-b0fa-8a171a5fee1e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
