// Dragnet [Ransomware]: dragnet-ransomware-2025-3815 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: c570d022-8759-5684-be19-b0701b3f4288

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
