// Dragnet [Ransomware]: dragnet-ransomware-2024-5954 — Mass File Rename (apt73)
// Status: experimental | Level: high | ID: 0bd2f003-3629-51f4-806a-3457faa337f1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
