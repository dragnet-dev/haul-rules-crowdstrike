// Dragnet [Ransomware]: dragnet-ransomware-2024-3896 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 3598a695-f00f-5bac-a889-1c2c31996011

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
