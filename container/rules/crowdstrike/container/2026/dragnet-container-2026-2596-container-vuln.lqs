// Dragnet [Container]: dragnet-container-2026-2596 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: d743314a-ec6c-5fea-b1c3-d357ecb5db62

#event_simpleName=*
| (ImageFileName = *chainguard:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
