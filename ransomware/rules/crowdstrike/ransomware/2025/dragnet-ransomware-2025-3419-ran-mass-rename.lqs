// Dragnet [Ransomware]: dragnet-ransomware-2025-3419 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 1d02328b-4cc4-5050-ba98-82463d7fe61f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
