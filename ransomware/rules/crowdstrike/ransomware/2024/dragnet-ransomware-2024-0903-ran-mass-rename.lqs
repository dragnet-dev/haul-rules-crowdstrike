// Dragnet [Ransomware]: dragnet-ransomware-2024-0903 — Mass File Rename (cicada3301)
// Status: experimental | Level: high | ID: 4e683b1b-7bc9-51df-9c70-c16247c0c21f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
