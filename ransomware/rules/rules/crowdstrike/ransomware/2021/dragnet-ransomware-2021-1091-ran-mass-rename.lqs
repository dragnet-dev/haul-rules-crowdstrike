// Dragnet [Ransomware]: dragnet-ransomware-2021-1091 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: cb2cf6c9-eadd-5921-9e1d-5befbbf333bc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
