// Dragnet [Ransomware]: dragnet-ransomware-2025-5912 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 00821e46-01c2-5ff7-94e3-9096091ca862

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
