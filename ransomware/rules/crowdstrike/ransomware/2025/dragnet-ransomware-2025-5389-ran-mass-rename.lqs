// Dragnet [Ransomware]: dragnet-ransomware-2025-5389 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: 40ed4cef-9b99-5770-9709-8be666187cec

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
