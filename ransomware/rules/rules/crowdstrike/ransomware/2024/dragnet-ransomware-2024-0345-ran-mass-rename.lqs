// Dragnet [Ransomware]: dragnet-ransomware-2024-0345 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 24fe4148-609b-52da-800a-cc64b6d343b4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
