// Dragnet [Ransomware]: dragnet-ransomware-2023-1768 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: dfecfc1e-b919-5007-bb31-e74ece5fbbc5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
