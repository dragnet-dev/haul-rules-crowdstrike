// Dragnet [Ransomware]: dragnet-ransomware-2023-0573 — Mass File Rename (royal)
// Status: experimental | Level: high | ID: 7d874b66-0104-5db2-a968-c4963fb46012

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
