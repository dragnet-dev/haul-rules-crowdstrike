// Dragnet [Ransomware]: dragnet-ransomware-2023-4991 — Mass File Rename (dunghill)
// Status: experimental | Level: high | ID: 4862b2c8-b930-55ae-b292-16743e8dbe92

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
