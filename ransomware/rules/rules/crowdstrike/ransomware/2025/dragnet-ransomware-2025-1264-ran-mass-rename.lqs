// Dragnet [Ransomware]: dragnet-ransomware-2025-1264 — Mass File Rename (warlock)
// Status: deprecated | Level: high | ID: 4004468e-9f5e-5e12-b44f-22af27b4cb1d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
