// Dragnet [Ransomware]: dragnet-ransomware-2021-0283 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: b9a3e2bd-0a5a-5038-b4a7-f7c045adc597

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
