// Dragnet [Ransomware]: dragnet-ransomware-2024-0791 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 470349cb-5587-5cb3-9a5c-3ae3fdf6186a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
