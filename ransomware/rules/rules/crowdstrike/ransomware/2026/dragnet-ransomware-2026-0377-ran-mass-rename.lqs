// Dragnet [Ransomware]: dragnet-ransomware-2026-0377 — Mass File Rename (nightspire)
// Status: deprecated | Level: high | ID: 5608725d-60ea-5416-89eb-874b3c187389

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
