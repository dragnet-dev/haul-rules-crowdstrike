// Dragnet [Ransomware]: dragnet-ransomware-2024-0797 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: e1460448-d4de-5949-9769-24a836b8de5a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
