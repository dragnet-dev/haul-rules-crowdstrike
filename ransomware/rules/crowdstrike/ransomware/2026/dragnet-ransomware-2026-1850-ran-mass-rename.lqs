// Dragnet [Ransomware]: dragnet-ransomware-2026-1850 — Mass File Rename (lockbit5)
// Status: test | Level: high | ID: 05f923ff-ea15-5151-a70f-4521c436d36d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
