// Dragnet [Ransomware]: dragnet-ransomware-2023-0488 — Mass File Rename (ElDorado)
// Status: deprecated | Level: high | ID: 02144767-9478-5c8e-ace5-c3b67d20d56b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
