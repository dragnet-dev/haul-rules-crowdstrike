// Dragnet [Ransomware]: dragnet-ransomware-2024-4747 — Mass File Rename (arcusmedia)
// Status: experimental | Level: high | ID: 12f05373-fb57-5064-b8bb-fb87830faaf2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
