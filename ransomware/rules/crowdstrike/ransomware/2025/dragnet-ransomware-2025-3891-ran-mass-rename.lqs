// Dragnet [Ransomware]: dragnet-ransomware-2025-3891 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 21301db6-82b7-5b0d-8db2-42b66ec16a30

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
