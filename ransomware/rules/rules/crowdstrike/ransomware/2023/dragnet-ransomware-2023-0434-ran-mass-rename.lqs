// Dragnet [Ransomware]: dragnet-ransomware-2023-0434 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: ff771d09-a06e-5407-ab90-dadfdcaa449b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
