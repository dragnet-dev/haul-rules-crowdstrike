// Dragnet [Container]: dragnet-container-2024-1104 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 2efdac89-0e05-5aed-b011-45c11d23806f

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
