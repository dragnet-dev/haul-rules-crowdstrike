// Dragnet [Ransomware]: dragnet-ransomware-2021-1202 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 7bf2e1fe-5bdf-52f6-a11b-13fa8c3cda39

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
