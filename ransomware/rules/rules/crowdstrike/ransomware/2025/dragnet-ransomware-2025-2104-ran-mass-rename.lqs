// Dragnet [Ransomware]: dragnet-ransomware-2025-2104 — Mass File Rename (arcusmedia)
// Status: experimental | Level: high | ID: 0d471fb2-0fe2-55ba-8635-aa865fd5c74b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
