// Dragnet [Ransomware]: dragnet-ransomware-2021-1287 — Mass File Rename (ragnarlocker)
// Status: deprecated | Level: high | ID: f60f3851-bb00-59a5-bee7-ed5f130aa7df

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
