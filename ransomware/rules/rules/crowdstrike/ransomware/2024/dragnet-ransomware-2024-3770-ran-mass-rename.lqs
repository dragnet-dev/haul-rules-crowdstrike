// Dragnet [Ransomware]: dragnet-ransomware-2024-3770 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 95f2feda-1d1c-5294-b37b-65071f17b02d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
