// Dragnet [Container]: dragnet-container-2024-0217 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 646f23e6-e640-5bd2-99d1-de2b11e499f8

#event_simpleName=*
| (ImageFileName = *debian:8* OR ImageFileName = *debian:9* OR ImageFileName = *ubuntu:16.04* OR ImageFileName = *ubuntu:18.04* OR ImageFileName = *ubuntu:18.10*)
| table([timestamp, ComputerName])
| limit(1000)
