// Dragnet [Ransomware]: dragnet-ransomware-2024-5062 — Mass File Rename (monti)
// Status: experimental | Level: high | ID: 90660670-e413-5ffb-b89d-211cd64e6b32

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
