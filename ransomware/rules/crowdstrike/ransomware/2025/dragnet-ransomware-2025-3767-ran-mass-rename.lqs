// Dragnet [Ransomware]: dragnet-ransomware-2025-3767 — Mass File Rename (metaencryptor)
// Status: experimental | Level: high | ID: 027d3718-53bc-53de-91c2-18577463e3b0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
