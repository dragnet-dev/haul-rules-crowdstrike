// Dragnet [Ransomware]: dragnet-ransomware-2025-5129 — Mass File Rename (weyhro)
// Status: experimental | Level: high | ID: 7b597d9e-da54-576b-842c-38e76248dc89

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
