// Dragnet [Ransomware]: dragnet-ransomware-2024-2775 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 88c5b3ae-fda5-5f1d-bc16-9b9d2694499d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
