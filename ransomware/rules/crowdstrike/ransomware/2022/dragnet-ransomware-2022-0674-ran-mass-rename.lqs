// Dragnet [Ransomware]: dragnet-ransomware-2022-0674 — Mass File Rename (revil)
// Status: deprecated | Level: high | ID: 812d4ae1-5331-5649-90cd-4a966623e37a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
