// Dragnet [Ransomware]: dragnet-ransomware-2024-4982 — Mass File Rename (dAn0n)
// Status: experimental | Level: high | ID: 5383e5ef-65e3-52b8-8a2f-3ef014cbb0f1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
