// Dragnet [Ransomware]: dragnet-ransomware-2025-2172 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 8d4bdd7d-6cbf-5569-8da2-5b706d7664f4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
