// Dragnet [Ransomware]: dragnet-ransomware-2024-5112 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: db1c27e8-be69-5059-9bc6-6e564ff0ec48

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
