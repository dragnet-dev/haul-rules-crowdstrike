// Dragnet [Ransomware]: dragnet-ransomware-2025-0548 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: cdffe90f-cdba-53da-9de4-42e9ee6c741f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
