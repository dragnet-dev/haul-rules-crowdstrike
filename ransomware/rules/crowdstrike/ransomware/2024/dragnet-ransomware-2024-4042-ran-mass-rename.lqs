// Dragnet [Ransomware]: dragnet-ransomware-2024-4042 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: fe511eb8-870f-51a3-8501-3a00381553f4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
