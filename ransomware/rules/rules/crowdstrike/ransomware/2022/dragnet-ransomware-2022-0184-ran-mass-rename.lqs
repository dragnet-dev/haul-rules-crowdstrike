// Dragnet [Ransomware]: dragnet-ransomware-2022-0184 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 2937d9aa-e18b-518a-9ae4-c52f5700705e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
