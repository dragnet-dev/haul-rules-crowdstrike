// Dragnet [Ransomware]: dragnet-ransomware-2024-1459 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 9011b07e-f8e2-5e5b-ae68-46fffade3045

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
