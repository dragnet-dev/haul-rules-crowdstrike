// Dragnet [Ransomware]: dragnet-ransomware-2026-1100 — Mass File Rename (thegentlemen)
// Status: test | Level: high | ID: 1ca5df18-7f30-54ab-825e-48e8826daceb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
