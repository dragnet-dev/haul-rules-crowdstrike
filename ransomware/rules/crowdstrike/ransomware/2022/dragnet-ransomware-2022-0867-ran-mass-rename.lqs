// Dragnet [Ransomware]: dragnet-ransomware-2022-0867 — Mass File Rename (blackbasta)
// Status: deprecated | Level: high | ID: 81bf8e16-2f17-5622-b53d-e7be1b804d7a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
