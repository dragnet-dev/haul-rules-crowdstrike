// Dragnet [Container]: dragnet-container-2026-2498 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: ee82ab50-dc78-5782-951a-03cd38ec215f

#event_simpleName=*
| (ImageFileName = *amazonlinux:1* OR ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10*)
| table([timestamp, ComputerName])
| limit(1000)
