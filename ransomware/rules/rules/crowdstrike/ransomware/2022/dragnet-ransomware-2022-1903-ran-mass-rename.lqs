// Dragnet [Ransomware]: dragnet-ransomware-2022-1903 — Mass File Rename (avoslocker)
// Status: deprecated | Level: high | ID: aa8724a6-5d0a-560b-8862-97059cb408aa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
