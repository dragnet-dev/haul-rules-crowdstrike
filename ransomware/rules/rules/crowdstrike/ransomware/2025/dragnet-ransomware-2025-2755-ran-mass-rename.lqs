// Dragnet [Ransomware]: dragnet-ransomware-2025-2755 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: da782ca9-3fe5-5898-90c4-aad34378c392

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
