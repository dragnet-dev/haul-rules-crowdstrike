// Dragnet [Ransomware]: dragnet-ransomware-2023-4329 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 26da75e4-f795-5c9a-825c-50564a39279f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
