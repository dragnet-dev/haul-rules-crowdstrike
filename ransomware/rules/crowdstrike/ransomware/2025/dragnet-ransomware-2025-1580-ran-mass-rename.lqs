// Dragnet [Ransomware]: dragnet-ransomware-2025-1580 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: 93496dcd-b466-56f7-b092-a2313767a9f6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
