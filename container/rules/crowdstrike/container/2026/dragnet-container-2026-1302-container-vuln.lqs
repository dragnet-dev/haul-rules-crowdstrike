// Dragnet [Container]: dragnet-container-2026-1302 — Vulnerable Base Image Pull
// Status: deprecated | Level: low | ID: a0b417a4-52bc-5ee5-a4d9-cc8758230de3

#event_simpleName=*
| (ImageFileName = *chainguard:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
