// Dragnet [Ransomware]: dragnet-ransomware-2025-2498 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: c18c23cf-07dd-53b7-a8d6-223084abc80a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
