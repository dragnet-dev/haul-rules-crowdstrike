// Dragnet [Ransomware]: dragnet-ransomware-2024-4352 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: cc5e3b2c-d7af-5674-8242-1bc84439360d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
