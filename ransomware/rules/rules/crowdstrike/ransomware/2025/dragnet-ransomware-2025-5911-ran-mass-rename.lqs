// Dragnet [Ransomware]: dragnet-ransomware-2025-5911 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: 4b6046cc-6ccb-59dc-9f70-b93ed3f009fb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
