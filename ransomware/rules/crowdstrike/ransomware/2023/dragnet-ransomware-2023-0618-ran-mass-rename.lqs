// Dragnet [Ransomware]: dragnet-ransomware-2023-0618 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 600082d8-e9a8-574d-8c7a-2eb926e5e97d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
