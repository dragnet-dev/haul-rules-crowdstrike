// Dragnet [Ransomware]: dragnet-ransomware-2023-2162 — Mass File Rename (ElDorado)
// Status: experimental | Level: high | ID: 7a7db1d0-ff84-5975-a0ca-0849a2d9313c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
