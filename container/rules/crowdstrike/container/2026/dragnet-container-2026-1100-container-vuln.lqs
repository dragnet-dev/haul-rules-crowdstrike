// Dragnet [Container]: dragnet-container-2026-1100 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: fbd6562a-54c9-57eb-880f-9f81eba7b482

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:7* OR ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *oraclelinux:7* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.04-ESM* OR ImageFileName = *ubuntu:14.04* OR ImageFileName = *ubuntu:14.04-ESM* OR ImageFileName = *ubuntu:14.10*)
| table([timestamp, ComputerName])
| limit(1000)
