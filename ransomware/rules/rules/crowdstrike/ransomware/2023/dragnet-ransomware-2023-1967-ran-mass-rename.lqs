// Dragnet [Ransomware]: dragnet-ransomware-2023-1967 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: df12cf24-cdef-536b-9b46-db9f556c5bf4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
