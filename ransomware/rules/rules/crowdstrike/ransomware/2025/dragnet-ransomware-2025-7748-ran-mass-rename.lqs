// Dragnet [Ransomware]: dragnet-ransomware-2025-7748 — Mass File Rename (play)
// Status: experimental | Level: high | ID: d1c7209b-7a40-5451-a2fa-69d3acfc8a19

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
