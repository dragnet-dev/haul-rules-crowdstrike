// Dragnet [Ransomware]: dragnet-ransomware-2021-1455 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 201f20db-a113-5e03-9b9e-991e5c9e5b6e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
