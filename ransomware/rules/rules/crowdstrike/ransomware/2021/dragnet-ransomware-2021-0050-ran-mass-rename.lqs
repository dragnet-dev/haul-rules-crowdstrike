// Dragnet [Ransomware]: dragnet-ransomware-2021-0050 — Mass File Rename (midas)
// Status: deprecated | Level: high | ID: f18808a5-4ace-5b9e-81b5-78a5253806a8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
