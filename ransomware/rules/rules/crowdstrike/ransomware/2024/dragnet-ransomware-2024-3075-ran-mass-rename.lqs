// Dragnet [Ransomware]: dragnet-ransomware-2024-3075 — Mass File Rename (play)
// Status: experimental | Level: high | ID: fcd16d3c-3023-5a60-bf08-49b91bd6cc0e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
