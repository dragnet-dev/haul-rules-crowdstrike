// Dragnet [Ransomware]: dragnet-ransomware-2025-1791 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 839de878-9653-5aaf-833e-fbc1b2689a06

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
