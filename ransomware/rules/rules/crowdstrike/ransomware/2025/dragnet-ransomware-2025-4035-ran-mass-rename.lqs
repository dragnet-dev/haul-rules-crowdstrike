// Dragnet [Ransomware]: dragnet-ransomware-2025-4035 — Mass File Rename (BrainCipher)
// Status: experimental | Level: high | ID: 01d8afb0-cfa2-5709-aa42-13824dff3187

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
