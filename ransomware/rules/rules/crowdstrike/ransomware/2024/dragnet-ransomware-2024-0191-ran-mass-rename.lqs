// Dragnet [Ransomware]: dragnet-ransomware-2024-0191 — Mass File Rename (knight)
// Status: experimental | Level: high | ID: a40e06ae-742d-5657-8b4c-7562b2a38552

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
