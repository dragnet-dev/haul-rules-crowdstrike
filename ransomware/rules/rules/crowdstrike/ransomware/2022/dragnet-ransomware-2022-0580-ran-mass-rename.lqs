// Dragnet [Ransomware]: dragnet-ransomware-2022-0580 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 371c7e6d-e462-5d7d-911c-474b676a11f7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
