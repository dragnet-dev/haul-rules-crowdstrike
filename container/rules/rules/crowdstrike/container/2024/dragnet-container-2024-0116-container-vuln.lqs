// Dragnet [Container]: dragnet-container-2024-0116 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 78bcd8f5-3ecc-514f-8c76-4db8b83d7180

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:13* OR ImageFileName = *debian:9* OR ImageFileName = *ubuntu:18.04* OR ImageFileName = *ubuntu:18.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
