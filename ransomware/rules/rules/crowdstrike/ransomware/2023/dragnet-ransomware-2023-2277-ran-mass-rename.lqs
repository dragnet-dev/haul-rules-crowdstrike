// Dragnet [Ransomware]: dragnet-ransomware-2023-2277 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: e8e91277-beff-5d91-9eff-98948f0d10ae

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
