// Dragnet [Ransomware]: dragnet-ransomware-2023-1580 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 35a33eb5-6176-58bd-b913-070f7d43f0e8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
