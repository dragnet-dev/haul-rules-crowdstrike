// Dragnet [Ransomware]: dragnet-ransomware-2023-0768 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 0c943500-86c7-5ba5-81c4-173dfa7a68c6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
