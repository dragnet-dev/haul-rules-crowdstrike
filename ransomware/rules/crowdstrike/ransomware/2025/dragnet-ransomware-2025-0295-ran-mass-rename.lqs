// Dragnet [Ransomware]: dragnet-ransomware-2025-0295 — Mass File Rename (flocker)
// Status: experimental | Level: high | ID: d4fd9c80-1621-53e0-8afa-77cc2152c7e9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
