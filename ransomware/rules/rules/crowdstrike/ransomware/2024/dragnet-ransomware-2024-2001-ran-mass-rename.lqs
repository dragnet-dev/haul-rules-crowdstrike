// Dragnet [Ransomware]: dragnet-ransomware-2024-2001 — Mass File Rename (play)
// Status: experimental | Level: high | ID: ac61660b-906c-5be5-9fae-fd5e7ef6f131

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
