// Dragnet [Ransomware]: dragnet-ransomware-2025-2459 — Mass File Rename (thegentlemen)
// Status: experimental | Level: high | ID: 5c1f5163-7862-5bf5-9fda-5f4999d67390

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
