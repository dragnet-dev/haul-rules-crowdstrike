// Dragnet [Ransomware]: dragnet-ransomware-2024-1018 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 8ba2abb3-7987-577e-8a9d-69905eb01c96

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
