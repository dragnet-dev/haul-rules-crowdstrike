// Dragnet [Ransomware]: dragnet-ransomware-2024-3956 — Mass File Rename (meow)
// Status: experimental | Level: high | ID: 21fcb9fe-a4d8-510e-8bdd-d50e00aa3cd3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
