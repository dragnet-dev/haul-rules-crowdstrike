// Dragnet [Container]: dragnet-container-2026-1018 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: acc1b2f2-cfc8-5023-a778-525d3c9cc2a6

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:5*)
| table([timestamp, ComputerName])
| limit(1000)
