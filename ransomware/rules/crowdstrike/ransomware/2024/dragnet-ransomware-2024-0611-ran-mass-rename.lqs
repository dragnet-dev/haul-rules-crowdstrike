// Dragnet [Ransomware]: dragnet-ransomware-2024-0611 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 00609cf0-d33c-5c1e-9bc7-6212abf3aece

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
