// Dragnet [Ransomware]: dragnet-ransomware-2023-3696 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: c9dc19d9-b55f-5729-938a-27e347b26020

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
