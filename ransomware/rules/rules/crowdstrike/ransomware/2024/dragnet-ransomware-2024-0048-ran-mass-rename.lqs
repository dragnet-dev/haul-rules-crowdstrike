// Dragnet [Ransomware]: dragnet-ransomware-2024-0048 — Mass File Rename (play)
// Status: experimental | Level: high | ID: adb47374-ad9e-54b4-99c5-ee94646cc256

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
