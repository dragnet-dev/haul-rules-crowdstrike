// Dragnet [Ransomware]: dragnet-ransomware-2026-1257 — Mass File Rename (lockbit5)
// Status: stable | Level: high | ID: 0eb59f47-4ff3-5563-91f4-93c747bb0f5f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
