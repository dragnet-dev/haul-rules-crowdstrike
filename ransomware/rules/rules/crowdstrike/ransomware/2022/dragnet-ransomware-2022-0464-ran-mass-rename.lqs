// Dragnet [Ransomware]: dragnet-ransomware-2022-0464 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 49423172-83c9-5efb-9b27-78d9b31b6d85

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
