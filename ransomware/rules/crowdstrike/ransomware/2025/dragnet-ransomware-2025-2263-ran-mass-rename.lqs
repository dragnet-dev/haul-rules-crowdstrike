// Dragnet [Ransomware]: dragnet-ransomware-2025-2263 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: 47eb1fbc-d933-566f-a5bb-75f651b33d05

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
