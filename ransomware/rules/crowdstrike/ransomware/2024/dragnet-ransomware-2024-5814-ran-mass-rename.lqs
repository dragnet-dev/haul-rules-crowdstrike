// Dragnet [Ransomware]: dragnet-ransomware-2024-5814 — Mass File Rename (radar)
// Status: deprecated | Level: high | ID: 1fe4cae8-fea5-5d93-9a3f-bac50a9bc9fa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
