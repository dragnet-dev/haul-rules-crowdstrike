// Dragnet [Ransomware]: dragnet-ransomware-2025-5732 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 5dfbdbdd-299a-551a-b7b6-52d489ce111f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
