// Dragnet [Ransomware]: dragnet-ransomware-2023-0239 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 06127422-077b-5788-b0d2-5b943eb504d1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
