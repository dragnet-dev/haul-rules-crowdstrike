// Dragnet [Ransomware]: dragnet-ransomware-2022-0413 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: e911c035-a2a2-5c98-9f4e-4aa86ed47388

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
