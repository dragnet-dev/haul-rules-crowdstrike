// Dragnet [Ransomware]: dragnet-ransomware-2020-0074 — Mass File Rename (maze)
// Status: deprecated | Level: high | ID: c6d3d038-a7cd-5fbd-a0cc-9b620fd338e3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
