// Dragnet [Ransomware]: dragnet-ransomware-2022-2553 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: dcb509c1-f036-56e5-9d4b-8cb9b089fd79

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
