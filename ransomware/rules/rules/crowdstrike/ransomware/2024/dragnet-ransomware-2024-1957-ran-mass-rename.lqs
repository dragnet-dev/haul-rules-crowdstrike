// Dragnet [Ransomware]: dragnet-ransomware-2024-1957 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: bc9a4dad-edea-50c6-a7e3-28c24bf53c2c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
