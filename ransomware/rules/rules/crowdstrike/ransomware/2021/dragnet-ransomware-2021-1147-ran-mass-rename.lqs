// Dragnet [Ransomware]: dragnet-ransomware-2021-1147 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 68b0dae0-9511-5b1a-8fe4-3f30c9bf51e6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
