// Dragnet [Ransomware]: dragnet-ransomware-2024-1833 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 9237d864-a0a7-5b7e-8019-a46b6f203de3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
