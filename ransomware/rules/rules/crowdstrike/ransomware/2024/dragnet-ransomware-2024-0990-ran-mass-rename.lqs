// Dragnet [Ransomware]: dragnet-ransomware-2024-0990 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 58068e51-2179-5054-b584-aeda0ba0c347

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
