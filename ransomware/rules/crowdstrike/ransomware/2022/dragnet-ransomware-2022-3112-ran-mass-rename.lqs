// Dragnet [Ransomware]: dragnet-ransomware-2022-3112 — Mass File Rename (play)
// Status: deprecated | Level: high | ID: 0e1d3b7e-aa95-5bd6-b37f-05ac905beeed

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
