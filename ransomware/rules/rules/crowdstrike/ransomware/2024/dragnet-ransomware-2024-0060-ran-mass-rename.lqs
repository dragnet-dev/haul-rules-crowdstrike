// Dragnet [Ransomware]: dragnet-ransomware-2024-0060 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: ac776183-6e03-5bcc-8630-3a3c958a356b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
