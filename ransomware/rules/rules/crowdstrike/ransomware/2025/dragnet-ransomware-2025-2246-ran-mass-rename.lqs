// Dragnet [Ransomware]: dragnet-ransomware-2025-2246 — Mass File Rename (hellcat)
// Status: deprecated | Level: high | ID: 10ed2b31-7ff9-532c-aabc-06f7e741aa34

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
