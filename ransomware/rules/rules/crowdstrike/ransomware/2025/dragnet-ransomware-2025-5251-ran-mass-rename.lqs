// Dragnet [Ransomware]: dragnet-ransomware-2025-5251 — Mass File Rename (direwolf)
// Status: experimental | Level: high | ID: 711c5bbf-e5b8-525b-bfad-8ef392fcb255

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
