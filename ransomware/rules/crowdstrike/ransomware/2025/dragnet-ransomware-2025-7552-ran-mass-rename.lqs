// Dragnet [Ransomware]: dragnet-ransomware-2025-7552 — Mass File Rename (worldleaks)
// Status: test | Level: high | ID: b5b05491-76aa-540c-b327-30834fae77b9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
