// Dragnet [Ransomware]: dragnet-ransomware-2025-2618 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: ee3c5e76-8ccb-5b02-ba95-bd4a7624caed

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
