// Dragnet [Ransomware]: dragnet-ransomware-2025-4091 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 86838b08-198b-58f7-8b93-3ad7d23a6bf0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
