// Dragnet [Ransomware]: dragnet-ransomware-2025-2013 — Mass File Rename (spacebears)
// Status: test | Level: high | ID: 8f2d4f01-a667-5b40-806f-28cc3457f501

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
