// Dragnet [Ransomware]: dragnet-ransomware-2025-3129 — Mass File Rename (shinyhunters)
// Status: experimental | Level: high | ID: 201b2fbe-2a19-5be3-ae06-a6ba07cd5b31

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
