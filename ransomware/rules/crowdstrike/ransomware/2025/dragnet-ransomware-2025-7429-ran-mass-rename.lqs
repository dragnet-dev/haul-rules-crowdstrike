// Dragnet [Ransomware]: dragnet-ransomware-2025-7429 — Mass File Rename (sinobi)
// Status: experimental | Level: high | ID: dbe0c997-b193-5544-ae3c-f5cf4a6e6266

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
