// Dragnet [Ransomware]: dragnet-ransomware-2025-2258 — Mass File Rename (blacklock)
// Status: experimental | Level: high | ID: 5372a292-2ab4-5559-afea-14904ee86657

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
