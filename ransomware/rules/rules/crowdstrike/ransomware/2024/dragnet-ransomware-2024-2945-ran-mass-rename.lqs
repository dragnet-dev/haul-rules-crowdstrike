// Dragnet [Ransomware]: dragnet-ransomware-2024-2945 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 723819dd-a46f-5a6f-8a00-deb97e9e97aa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
