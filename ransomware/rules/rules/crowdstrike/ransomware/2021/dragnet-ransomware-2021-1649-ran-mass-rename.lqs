// Dragnet [Ransomware]: dragnet-ransomware-2021-1649 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 58533409-9724-5095-80be-a371f37bd864

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
