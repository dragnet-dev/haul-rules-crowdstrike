// Dragnet [Ransomware]: dragnet-ransomware-2024-1351 — Mass File Rename (BrainCipher)
// Status: experimental | Level: high | ID: 1d90fb2b-9976-5bdd-b1ea-6779b632b3fd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
