// Dragnet [Ransomware]: dragnet-ransomware-2025-6211 — Mass File Rename (shinyhunters)
// Status: experimental | Level: high | ID: 096ebac6-0edb-5a2e-8f20-c7f787e2c751

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
