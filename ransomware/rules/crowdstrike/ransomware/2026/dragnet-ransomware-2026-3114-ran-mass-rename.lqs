// Dragnet [Ransomware]: dragnet-ransomware-2026-3114 — Mass File Rename (vect)
// Status: deprecated | Level: high | ID: 98797269-feaa-5d83-a7bb-30afc4e101cb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
