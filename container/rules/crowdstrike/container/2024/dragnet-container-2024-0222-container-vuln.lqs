// Status: deprecated | Level: critical | ID: 81ea1415-3d97-5f89-8fd5-ae15f8af51a0

#event_simpleName=*
| (ImageFileName = *alpine:3.17* OR ImageFileName = *alpine:3.18* OR ImageFileName = *alpine:3.19* OR ImageFileName = *alpine:3.20* OR ImageFileName = *alpine:3.21* OR ImageFileName = *alpine:3.22* OR ImageFileName = *alpine:3.23* OR ImageFileName = *alpine edge:* OR ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *ubuntu:18.04-ESM* OR ImageFileName = *ubuntu:20.04-ESM* OR ImageFileName = *ubuntu:22.04*)
| table([timestamp, ComputerName])
| limit(1000)
