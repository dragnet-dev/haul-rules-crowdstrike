// Dragnet [Ransomware]: dragnet-ransomware-2024-0128 — Mass File Rename (cloak)
// Status: experimental | Level: high | ID: 0d54906d-08fd-5923-ae8a-3525e6438dba

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
