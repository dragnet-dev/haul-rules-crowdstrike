// Dragnet [Ransomware]: dragnet-ransomware-2023-3438 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 3058fdfd-1fdd-5f70-8c52-42e990572df5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
