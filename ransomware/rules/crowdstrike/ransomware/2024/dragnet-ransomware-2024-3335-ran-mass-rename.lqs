// Dragnet [Ransomware]: dragnet-ransomware-2024-3335 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: 6937acfb-4723-5fe7-bf5d-ae57b1a8d064

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
