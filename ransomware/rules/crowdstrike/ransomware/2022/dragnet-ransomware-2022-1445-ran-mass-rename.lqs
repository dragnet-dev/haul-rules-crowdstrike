// Dragnet [Ransomware]: dragnet-ransomware-2022-1445 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 12ad237c-f9a4-5864-a4ea-48189816d8d6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
