// Dragnet [Ransomware]: dragnet-ransomware-2024-3998 — Mass File Rename (spacebears)
// Status: experimental | Level: high | ID: c1233e55-40fa-5b12-bfcd-d2e07e962a05

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
