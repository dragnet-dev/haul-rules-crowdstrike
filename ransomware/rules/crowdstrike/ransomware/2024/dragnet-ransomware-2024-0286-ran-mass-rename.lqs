// Dragnet [Ransomware]: dragnet-ransomware-2024-0286 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 5d2b0ede-f37a-533c-9d31-7a421ccc5f16

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
