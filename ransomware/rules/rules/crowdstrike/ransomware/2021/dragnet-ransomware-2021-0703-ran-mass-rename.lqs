// Dragnet [Ransomware]: dragnet-ransomware-2021-0703 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: c4f616f6-e5f4-525a-b398-d9f90f30fb11

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
