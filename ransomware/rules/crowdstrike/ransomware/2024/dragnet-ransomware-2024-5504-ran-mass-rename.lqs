// Dragnet [Ransomware]: dragnet-ransomware-2024-5504 — Mass File Rename (shinyhunters)
// Status: experimental | Level: high | ID: 33ba552d-6f6a-59c4-aa80-b029bbf99c0c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
