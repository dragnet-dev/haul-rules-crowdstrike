// Dragnet [Ransomware]: dragnet-ransomware-2024-5465 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: b387201b-0c80-545b-89f1-02a1f224b453

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
