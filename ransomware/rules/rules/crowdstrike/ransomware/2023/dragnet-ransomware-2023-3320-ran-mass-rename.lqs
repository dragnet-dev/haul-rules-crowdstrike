// Dragnet [Ransomware]: dragnet-ransomware-2023-3320 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 89f96c75-444b-5cfc-a5a3-205d7f297460

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
