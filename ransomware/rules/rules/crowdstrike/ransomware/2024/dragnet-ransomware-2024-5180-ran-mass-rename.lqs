// Dragnet [Ransomware]: dragnet-ransomware-2024-5180 — Mass File Rename (arcusmedia)
// Status: experimental | Level: high | ID: 4264b3eb-87e4-56a1-9012-6563790ff8c9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
