// Dragnet [Container]: dragnet-container-2024-0405 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 00dd93b3-1082-576a-9c99-2277494236d8

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:8* OR ImageFileName = *debian:9*)
| table([timestamp, ComputerName])
| limit(1000)
