// Dragnet [Ransomware]: dragnet-ransomware-2025-0362 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 16ab0b69-54be-5008-9239-a3a018d00c53

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
