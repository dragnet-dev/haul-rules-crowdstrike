// Dragnet [Ransomware]: dragnet-ransomware-2024-0366 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 0f627a9c-072b-5d75-9221-77d8fdff922b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
