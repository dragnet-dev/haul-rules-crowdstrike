// Dragnet [Ransomware]: dragnet-ransomware-2024-5011 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 4eec8d2b-825a-5bfd-862d-9b04274b3ba0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
