// Dragnet [Ransomware]: dragnet-ransomware-2023-3305 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 5b6f1d66-0ec7-5fc7-85b3-ea62af33a7db

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
