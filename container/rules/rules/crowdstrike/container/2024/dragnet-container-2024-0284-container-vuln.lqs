// Dragnet [Container]: dragnet-container-2024-0284 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: c27349d7-ea82-504a-a802-ddbddcb40f35

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:7* OR ImageFileName = *debian:8* OR ImageFileName = *debian:9* OR ImageFileName = *ubuntu:14.04-ESM* OR ImageFileName = *ubuntu:16.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
