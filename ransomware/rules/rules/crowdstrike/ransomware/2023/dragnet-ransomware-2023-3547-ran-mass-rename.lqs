// Dragnet [Ransomware]: dragnet-ransomware-2023-3547 — Mass File Rename (dunghill)
// Status: experimental | Level: high | ID: 15f3e028-d616-531f-959d-54344a7f8a65

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
