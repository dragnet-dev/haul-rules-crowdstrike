// Dragnet [Ransomware]: dragnet-ransomware-2025-2008 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 41b6486c-affb-535d-aea1-32fdfa3c15b9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
