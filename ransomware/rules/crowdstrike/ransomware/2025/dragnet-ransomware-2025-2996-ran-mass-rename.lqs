// Dragnet [Ransomware]: dragnet-ransomware-2025-2996 — Mass File Rename (monti)
// Status: experimental | Level: high | ID: f570e1ff-ec45-54e0-b517-3e987bf3c048

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
