// Dragnet [Ransomware]: dragnet-ransomware-2025-4589 — Mass File Rename (BrainCipher)
// Status: experimental | Level: high | ID: b9430996-ad80-5804-b130-5ba7fb714ee1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
