// Dragnet [Ransomware]: dragnet-ransomware-2022-0901 — Mass File Rename (midas)
// Status: deprecated | Level: high | ID: 4cf50fea-11ee-5a20-97de-c4683fbe009d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
