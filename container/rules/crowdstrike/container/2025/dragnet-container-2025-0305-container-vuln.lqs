// Dragnet [Container]: dragnet-container-2025-0305 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 114d9586-0c6d-503d-bcc1-44d35d769fd9

#event_simpleName=*
| (ImageFileName = *ubuntu:14.04* OR ImageFileName = *ubuntu:16.04* OR ImageFileName = *ubuntu:17.10* OR ImageFileName = *ubuntu:18.04*)
| table([timestamp, ComputerName])
| limit(1000)
