// Dragnet [Ransomware]: dragnet-ransomware-2024-4018 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: c793057b-7b67-5f4b-9f38-e67c23753d28

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
