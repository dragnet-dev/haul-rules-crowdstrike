// Dragnet [Container]: dragnet-container-2026-0760 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 5841bb58-acfb-56e0-a371-09356798472e

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *ubuntu:13.10* OR ImageFileName = *ubuntu:14.04*)
| table([timestamp, ComputerName])
| limit(1000)
