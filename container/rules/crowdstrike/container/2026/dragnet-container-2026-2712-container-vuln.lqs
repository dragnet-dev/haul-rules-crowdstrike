// Dragnet [Container]: dragnet-container-2026-2712 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 747f9c70-f904-5501-b610-ad7ab953ca53

#event_simpleName=*
| (ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10* OR ImageFileName = *ubuntu:13.04* OR ImageFileName = *ubuntu:13.10*)
| table([timestamp, ComputerName])
| limit(1000)
