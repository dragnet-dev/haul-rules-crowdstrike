// Dragnet [Ransomware]: dragnet-ransomware-2024-4408 — Mass File Rename (raworld)
// Status: experimental | Level: high | ID: a8a1191f-72e2-53c3-bf54-96408d8839ef

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
