// Dragnet [Ransomware]: dragnet-ransomware-2024-1937 — Mass File Rename (play)
// Status: experimental | Level: high | ID: a2269511-510e-50ad-acd2-9e2da0588ae1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
