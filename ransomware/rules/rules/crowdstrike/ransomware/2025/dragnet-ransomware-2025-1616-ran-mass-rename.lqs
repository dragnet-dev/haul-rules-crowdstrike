// Dragnet [Ransomware]: dragnet-ransomware-2025-1616 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 3ebd85be-0ba9-54f6-a3d9-29f1b756311b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
