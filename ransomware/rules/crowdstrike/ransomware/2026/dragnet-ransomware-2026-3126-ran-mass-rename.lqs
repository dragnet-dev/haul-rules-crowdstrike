// Dragnet [Ransomware]: dragnet-ransomware-2026-3126 — Mass File Rename (incransom)
// Status: test | Level: high | ID: 16f8bede-96f9-5439-84f4-b9bc4238a60c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
