// Dragnet [Ransomware]: dragnet-ransomware-2023-4011 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 3df52db6-2081-53b2-bf92-270687c741c4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
