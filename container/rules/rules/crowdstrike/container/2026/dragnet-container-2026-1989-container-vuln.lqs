// Dragnet [Container]: dragnet-container-2026-1989 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 8843da5e-ae6b-533e-bc98-11063e5a72e4

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:5*)
| table([timestamp, ComputerName])
| limit(1000)
