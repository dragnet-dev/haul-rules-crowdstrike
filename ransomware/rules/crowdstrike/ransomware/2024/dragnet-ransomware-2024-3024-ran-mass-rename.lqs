// Dragnet [Ransomware]: dragnet-ransomware-2024-3024 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 7b1188d7-5d0c-548d-828c-642df96b48a3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
