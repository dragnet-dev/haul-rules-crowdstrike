// Dragnet [Ransomware]: dragnet-ransomware-2025-3270 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: bf9e7b17-fa2c-52cd-ada6-fcdb813462c5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
