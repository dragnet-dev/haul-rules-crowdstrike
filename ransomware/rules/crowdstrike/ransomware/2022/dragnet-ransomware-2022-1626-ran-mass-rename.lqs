// Dragnet [Ransomware]: dragnet-ransomware-2022-1626 — Mass File Rename (cuba)
// Status: deprecated | Level: high | ID: edcf958e-89ec-54d2-9d10-38b45b833c34

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
