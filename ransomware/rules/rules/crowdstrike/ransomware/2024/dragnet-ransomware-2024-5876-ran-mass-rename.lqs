// Dragnet [Ransomware]: dragnet-ransomware-2024-5876 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: b59a5601-19e1-5515-b978-d402baa833c9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
