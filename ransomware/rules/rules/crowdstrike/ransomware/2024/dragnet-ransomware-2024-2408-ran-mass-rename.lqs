// Dragnet [Ransomware]: dragnet-ransomware-2024-2408 — Mass File Rename (helldown)
// Status: experimental | Level: high | ID: cff27af5-ed5f-5141-affd-5217c19a10cb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
