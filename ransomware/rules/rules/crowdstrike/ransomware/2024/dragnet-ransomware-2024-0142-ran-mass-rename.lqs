// Dragnet [Ransomware]: dragnet-ransomware-2024-0142 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 06faeadd-417e-5c0c-9ba4-5ddf9a38ee14

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
