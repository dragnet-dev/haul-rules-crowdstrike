// Dragnet [Ransomware]: dragnet-ransomware-2024-3119 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 74e92041-4d14-5ca1-8926-60bab0799e3b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
