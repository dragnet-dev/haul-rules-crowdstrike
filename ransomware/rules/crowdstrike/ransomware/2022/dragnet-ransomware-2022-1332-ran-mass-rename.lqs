// Dragnet [Ransomware]: dragnet-ransomware-2022-1332 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 29ebf053-0709-5c3c-a49d-c86b029767a0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
