// Dragnet [Ransomware]: dragnet-ransomware-2024-4809 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 1118048e-0447-534d-91a3-dcdf38842022

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
