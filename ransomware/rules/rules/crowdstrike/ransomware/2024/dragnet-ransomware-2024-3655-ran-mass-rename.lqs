// Dragnet [Ransomware]: dragnet-ransomware-2024-3655 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 5ce847a0-17f4-5339-8c41-19eadc2875e4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
