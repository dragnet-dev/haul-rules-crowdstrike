// Dragnet [Container]: dragnet-container-2026-1326 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 55936d7e-af07-546b-a781-f8a7503d3a4b

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
