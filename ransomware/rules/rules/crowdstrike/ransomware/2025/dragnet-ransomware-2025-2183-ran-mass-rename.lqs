// Dragnet [Ransomware]: dragnet-ransomware-2025-2183 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 386fc9fa-758a-524e-8311-a8b8cd524b67

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
