// Dragnet [Ransomware]: dragnet-ransomware-2024-4881 — Mass File Rename (embargo)
// Status: experimental | Level: high | ID: ffa10c66-5795-5396-bfb7-747d52d97e20

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
