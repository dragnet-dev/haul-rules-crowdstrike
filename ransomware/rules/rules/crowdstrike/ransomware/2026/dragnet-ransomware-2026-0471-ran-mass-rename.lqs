// Dragnet [Ransomware]: dragnet-ransomware-2026-0471 — Mass File Rename (lockbit5)
// Status: stable | Level: high | ID: b974c403-dbbe-5474-99cc-8786b851e9fa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
