// Dragnet [Ransomware]: dragnet-ransomware-2024-4429 — Mass File Rename (raworld)
// Status: experimental | Level: high | ID: da382d99-aa41-598e-b019-7350ac4daf22

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
