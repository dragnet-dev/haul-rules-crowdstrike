// Dragnet [Container]: dragnet-container-2026-2313 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 14d37ee0-6705-5dd8-8776-8fa14188857d

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:5*)
| table([timestamp, ComputerName])
| limit(1000)
