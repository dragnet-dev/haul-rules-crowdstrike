// Dragnet [Ransomware]: dragnet-ransomware-2025-7162 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: fa52c3e4-2b0f-528f-ab89-f01bf341122d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
