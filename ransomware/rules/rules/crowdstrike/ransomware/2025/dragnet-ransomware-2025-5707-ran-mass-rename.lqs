// Dragnet [Ransomware]: dragnet-ransomware-2025-5707 — Mass File Rename (stormous)
// Status: experimental | Level: high | ID: 4aceadf5-a941-5d8c-aa34-64f2eb32cde4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
