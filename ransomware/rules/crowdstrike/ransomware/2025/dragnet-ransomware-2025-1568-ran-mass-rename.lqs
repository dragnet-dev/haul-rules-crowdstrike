// Dragnet [Ransomware]: dragnet-ransomware-2025-1568 — Mass File Rename (obscura)
// Status: deprecated | Level: high | ID: 13a4de60-5927-5077-8bc4-90faefc2a414

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
