// Dragnet [Ransomware]: dragnet-ransomware-2024-0862 — Mass File Rename (dAn0n)
// Status: experimental | Level: high | ID: 6ed4406d-6b00-54a4-a03b-f724b3225649

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
