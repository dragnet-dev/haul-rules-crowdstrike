// Dragnet [Ransomware]: dragnet-ransomware-2025-1032 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 8a4372cb-ccc4-5b68-9b75-40194d2c36d7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
