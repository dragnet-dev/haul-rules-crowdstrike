// Dragnet [Ransomware]: dragnet-ransomware-2023-0152 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 47fc023e-8414-5434-94df-bd5acc87b7b0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
