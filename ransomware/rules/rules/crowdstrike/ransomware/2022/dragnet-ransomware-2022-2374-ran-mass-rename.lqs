// Dragnet [Ransomware]: dragnet-ransomware-2022-2374 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: ce75a980-b98a-59f6-98d7-b2c91ce2ccc8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
