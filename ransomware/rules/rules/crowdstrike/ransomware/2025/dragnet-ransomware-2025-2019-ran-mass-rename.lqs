// Dragnet [Ransomware]: dragnet-ransomware-2025-2019 — Mass File Rename (coinbasecartel)
// Status: experimental | Level: high | ID: 98e57489-bf7a-5e79-a0a6-4c4ceb1be8f1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
