// Dragnet [Ransomware]: dragnet-ransomware-2021-0122 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: b91c406e-947b-56bd-a7e4-99464e867754

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
