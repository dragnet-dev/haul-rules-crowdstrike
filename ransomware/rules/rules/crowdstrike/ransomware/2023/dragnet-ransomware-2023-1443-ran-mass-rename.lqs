// Dragnet [Ransomware]: dragnet-ransomware-2023-1443 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 8b1ceed8-9e35-578f-9c8f-c1b656cb7f7a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
