// Dragnet [Ransomware]: dragnet-ransomware-2025-3883 — Mass File Rename (devman)
// Status: deprecated | Level: high | ID: b145785c-a648-5c56-b5ab-027ea0492439

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
