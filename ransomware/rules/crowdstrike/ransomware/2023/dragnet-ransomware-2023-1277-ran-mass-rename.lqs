// Dragnet [Ransomware]: dragnet-ransomware-2023-1277 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 2194f683-6555-569e-b6e3-7a5ac9a4cd6b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
