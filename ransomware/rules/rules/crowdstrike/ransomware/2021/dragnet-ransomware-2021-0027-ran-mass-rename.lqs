// Dragnet [Ransomware]: dragnet-ransomware-2021-0027 — Mass File Rename (marketo)
// Status: deprecated | Level: high | ID: 2d8de212-ea01-5d02-ac8c-57fe49dde170

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
