// Dragnet [Ransomware]: dragnet-ransomware-2025-7831 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 7c48049c-b94f-5c45-bb9b-b2f0b8fc8913

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
