// Dragnet [Ransomware]: dragnet-ransomware-2022-0375 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 2b6951d6-974f-59f6-b1eb-a12dfa0f6ed8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
