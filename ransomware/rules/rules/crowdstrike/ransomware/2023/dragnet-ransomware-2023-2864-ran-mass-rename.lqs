// Dragnet [Ransomware]: dragnet-ransomware-2023-2864 — Mass File Rename (malas)
// Status: experimental | Level: high | ID: 3a6944f7-a2b3-5f4e-b077-b5352de1922a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
