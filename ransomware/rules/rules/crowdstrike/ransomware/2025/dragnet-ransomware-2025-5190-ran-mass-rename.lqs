// Dragnet [Ransomware]: dragnet-ransomware-2025-5190 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 2c1e1352-255d-5c37-9b6e-f84120b23782

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
