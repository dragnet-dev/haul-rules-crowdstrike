// Dragnet [Ransomware]: dragnet-ransomware-2022-0266 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 8fd5aaa7-b272-508a-a657-da72df69165c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
