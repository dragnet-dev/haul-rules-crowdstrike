// Dragnet [Ransomware]: dragnet-ransomware-2024-4880 — Mass File Rename (embargo)
// Status: experimental | Level: high | ID: e63de1f8-9d34-5a67-9628-7024a67687e1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
