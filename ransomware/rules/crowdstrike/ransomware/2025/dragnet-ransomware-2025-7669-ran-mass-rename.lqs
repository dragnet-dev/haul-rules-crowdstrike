// Dragnet [Ransomware]: dragnet-ransomware-2025-7669 — Mass File Rename (rhysida)
// Status: experimental | Level: high | ID: e2ba8aeb-0b16-51ac-8548-dde4955ee7ac

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
