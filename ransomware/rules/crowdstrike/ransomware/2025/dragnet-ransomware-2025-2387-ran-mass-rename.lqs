// Dragnet [Ransomware]: dragnet-ransomware-2025-2387 — Mass File Rename (pear)
// Status: experimental | Level: high | ID: 5279238c-cfa7-5cad-a432-b8ee67d02372

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
