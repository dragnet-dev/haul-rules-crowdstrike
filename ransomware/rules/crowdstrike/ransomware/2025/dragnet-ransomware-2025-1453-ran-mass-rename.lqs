// Dragnet [Ransomware]: dragnet-ransomware-2025-1453 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: b18dc99f-8f60-50d7-ab50-9a2913be7e32

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
