// Dragnet [Ransomware]: dragnet-ransomware-2025-4967 — Mass File Rename (worldleaks)
// Status: experimental | Level: high | ID: 53d449b7-60a5-525b-989e-66860d9b836e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
