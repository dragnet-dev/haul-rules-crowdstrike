// Dragnet [Ransomware]: dragnet-ransomware-2026-3245 — Mass File Rename (lockbit5)
// Status: stable | Level: high | ID: c8e14a64-846d-594e-8dca-aaf74dbf17dc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
