// Dragnet [Ransomware]: dragnet-ransomware-2025-6069 — Mass File Rename (interlock)
// Status: experimental | Level: high | ID: f4334010-61c9-5c44-b58f-3be1f2c406cd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
