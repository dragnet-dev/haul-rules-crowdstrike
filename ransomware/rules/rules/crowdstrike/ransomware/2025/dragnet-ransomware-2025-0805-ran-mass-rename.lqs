// Dragnet [Ransomware]: dragnet-ransomware-2025-0805 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: 4c9402f4-e0ba-5955-8443-01510c01cd12

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
