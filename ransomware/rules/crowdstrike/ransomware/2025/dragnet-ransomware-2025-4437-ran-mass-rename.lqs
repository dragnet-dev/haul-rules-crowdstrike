// Dragnet [Ransomware]: dragnet-ransomware-2025-4437 — Mass File Rename (incransom)
// Status: test | Level: high | ID: 67aae793-2dd6-5186-b06c-dc07cecd5797

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
