// Dragnet [Ransomware]: dragnet-ransomware-2024-0535 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 4c92f0d0-e571-528d-88ba-45f9635c1017

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
