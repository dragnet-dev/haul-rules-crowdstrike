// Dragnet [Ransomware]: dragnet-ransomware-2025-5627 — Mass File Rename (worldleaks)
// Status: experimental | Level: high | ID: c2819c38-db08-5782-a95e-296f3481ff1e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
