// Dragnet [Ransomware]: dragnet-ransomware-2025-4679 — Mass File Rename (devman)
// Status: experimental | Level: high | ID: 41305980-e53f-5d6b-a0b4-f2a6d67ac6b7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
