// Dragnet [Ransomware]: dragnet-ransomware-2024-4248 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 834ad02e-710b-5748-a0fe-74e9edbd7574

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
