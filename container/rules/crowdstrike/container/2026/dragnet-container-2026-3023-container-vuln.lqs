// Dragnet [Container]: dragnet-container-2026-3023 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 342e11c6-c61c-58ae-9578-b8d30dc94176

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:5*)
| table([timestamp, ComputerName])
| limit(1000)
