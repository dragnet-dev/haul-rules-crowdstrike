// Dragnet [Ransomware]: dragnet-ransomware-2022-2774 — Mass File Rename (karakurt)
// Status: deprecated | Level: high | ID: 870f8069-4345-5676-90c0-ee2aca544751

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
