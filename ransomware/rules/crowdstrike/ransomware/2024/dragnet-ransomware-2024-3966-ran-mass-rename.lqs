// Dragnet [Ransomware]: dragnet-ransomware-2024-3966 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: cbd12588-702f-547f-a297-5e0fc9a7acc4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
