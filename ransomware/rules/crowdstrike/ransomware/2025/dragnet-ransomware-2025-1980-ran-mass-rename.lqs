// Dragnet [Ransomware]: dragnet-ransomware-2025-1980 — Mass File Rename (monti)
// Status: experimental | Level: high | ID: 82e8845f-51df-5e8c-bed7-99395ce9e138

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
