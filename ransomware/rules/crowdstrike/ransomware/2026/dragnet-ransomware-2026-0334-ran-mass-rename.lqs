// Dragnet [Ransomware]: dragnet-ransomware-2026-0334 — Mass File Rename (genesis)
// Status: stable | Level: high | ID: 9500a28d-43fc-5a82-b8a5-6d03d37dad65

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
