// Dragnet [Container]: dragnet-container-2026-1121 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 6540449c-f4f4-514c-8fae-a6f700fbf05d

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:7* OR ImageFileName = *debian:8* OR ImageFileName = *ubuntu:15.04*)
| table([timestamp, ComputerName])
| limit(1000)
