// Dragnet [Ransomware]: dragnet-ransomware-2022-2816 — Mass File Rename (royal)
// Status: deprecated | Level: high | ID: 679714b2-0a63-59aa-836f-bdf5edbbe6db

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
