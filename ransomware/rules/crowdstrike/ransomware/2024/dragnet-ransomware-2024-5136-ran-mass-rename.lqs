// Dragnet [Ransomware]: dragnet-ransomware-2024-5136 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 7fb87b00-d857-506b-b990-33141422aaad

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
