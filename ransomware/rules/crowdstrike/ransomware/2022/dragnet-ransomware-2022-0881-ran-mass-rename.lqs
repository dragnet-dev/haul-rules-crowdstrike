// Dragnet [Ransomware]: dragnet-ransomware-2022-0881 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: ce6d8917-9e5a-5a5d-8110-2df5674235cf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
