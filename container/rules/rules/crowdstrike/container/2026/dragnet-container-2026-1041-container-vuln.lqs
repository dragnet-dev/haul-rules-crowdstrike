// Dragnet [Container]: dragnet-container-2026-1041 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: af2c97c1-4b45-54c0-a123-58ee1bd5aa6c

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6*)
| table([timestamp, ComputerName])
| limit(1000)
