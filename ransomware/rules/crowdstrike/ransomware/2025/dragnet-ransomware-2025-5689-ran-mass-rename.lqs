// Dragnet [Ransomware]: dragnet-ransomware-2025-5689 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 8154f638-509c-5df8-bdd8-04b1fc40ab8d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
