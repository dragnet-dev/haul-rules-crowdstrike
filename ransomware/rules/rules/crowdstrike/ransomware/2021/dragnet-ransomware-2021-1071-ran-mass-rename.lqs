// Dragnet [Ransomware]: dragnet-ransomware-2021-1071 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: d062cb49-89c2-5109-829c-2b97a4389dba

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
