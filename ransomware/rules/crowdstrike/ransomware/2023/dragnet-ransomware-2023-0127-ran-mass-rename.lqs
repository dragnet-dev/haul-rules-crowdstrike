// Dragnet [Ransomware]: dragnet-ransomware-2023-0127 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: cc61b671-d5a2-5e51-8aeb-9b813a2bd19b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
