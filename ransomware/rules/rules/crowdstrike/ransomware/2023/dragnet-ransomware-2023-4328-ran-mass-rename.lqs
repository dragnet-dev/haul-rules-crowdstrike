// Dragnet [Ransomware]: dragnet-ransomware-2023-4328 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 1847b4af-b193-59a1-894b-f3a808fa99cc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
