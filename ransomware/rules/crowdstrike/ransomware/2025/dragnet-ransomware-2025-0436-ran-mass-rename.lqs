// Dragnet [Ransomware]: dragnet-ransomware-2025-0436 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: 376c86e6-d147-5054-b811-c3438bba5d4e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
