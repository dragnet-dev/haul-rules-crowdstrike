// Dragnet [Ransomware]: dragnet-ransomware-2025-3141 — Mass File Rename (anubis)
// Status: experimental | Level: high | ID: 327871f5-904f-54a9-b55a-95da9e7343c0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
