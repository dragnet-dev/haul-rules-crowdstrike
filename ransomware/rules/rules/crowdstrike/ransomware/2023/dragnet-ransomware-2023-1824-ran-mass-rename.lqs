// Dragnet [Ransomware]: dragnet-ransomware-2023-1824 — Mass File Rename (karakurt)
// Status: experimental | Level: high | ID: 4c763c54-71ce-5735-8ac1-9fd17fe2702a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
