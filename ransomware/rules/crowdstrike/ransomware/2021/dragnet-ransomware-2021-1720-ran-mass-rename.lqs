// Dragnet [Ransomware]: dragnet-ransomware-2021-1720 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 8c21ea3b-24b8-555a-ac89-a9d8c4ec214f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
