// Dragnet [Ransomware]: dragnet-ransomware-2021-1551 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 18d2d25c-4d76-51cc-a618-8771cbea4b6c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
