// Dragnet [Ransomware]: dragnet-ransomware-2025-1676 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 551a3e20-7d23-5702-aba0-61b38d781094

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
