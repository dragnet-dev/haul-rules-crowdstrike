// Dragnet [Ransomware]: dragnet-ransomware-2025-1962 — Mass File Rename (warlock)
// Status: deprecated | Level: high | ID: 6cb46794-b710-5a58-93a5-cf5508d6d5bb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
