// Dragnet [Ransomware]: dragnet-ransomware-2024-5292 — Mass File Rename (everest)
// Status: experimental | Level: high | ID: 6b2e2c7c-56af-5a82-97e7-0f3f76f2f6bb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
