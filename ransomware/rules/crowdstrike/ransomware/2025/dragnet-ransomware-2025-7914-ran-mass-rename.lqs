// Dragnet [Ransomware]: dragnet-ransomware-2025-7914 — Mass File Rename (lockbit5)
// Status: test | Level: high | ID: ce555848-52c5-51fa-88ba-cee69577eebf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
