// Dragnet [Ransomware]: dragnet-ransomware-2022-2989 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 100fc41e-0ebd-5597-b079-f7dc654ff0d0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
