// Dragnet [Ransomware]: dragnet-ransomware-2022-3137 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 9f9d729b-22d1-50d6-bda9-2029adaf1139

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
