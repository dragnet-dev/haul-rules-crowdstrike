// Dragnet [Ransomware]: dragnet-ransomware-2022-0724 — Mass File Rename (everest)
// Status: deprecated | Level: high | ID: 5877736f-7631-56e6-be00-29ee7358b12b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
