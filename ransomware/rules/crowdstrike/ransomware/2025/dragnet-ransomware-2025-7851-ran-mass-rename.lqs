// Dragnet [Ransomware]: dragnet-ransomware-2025-7851 — Mass File Rename (alphalocker)
// Status: experimental | Level: high | ID: 93634e18-0f8d-57d7-b8d8-70eeffcda793

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
