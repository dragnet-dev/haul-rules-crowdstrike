// Dragnet [Ransomware]: dragnet-ransomware-2024-3082 — Mass File Rename (play)
// Status: experimental | Level: high | ID: de57db8e-e106-5032-adda-c8aa11960199

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
