// Dragnet [Ransomware]: dragnet-ransomware-2022-2603 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 9bec4974-2e8b-54ee-8736-bce6077cd920

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
