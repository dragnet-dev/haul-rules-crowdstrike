// Dragnet [Ransomware]: dragnet-ransomware-2024-3086 — Mass File Rename (moneymessage)
// Status: experimental | Level: high | ID: fbcd1782-252b-5b08-9245-eaa3d8e543b1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
