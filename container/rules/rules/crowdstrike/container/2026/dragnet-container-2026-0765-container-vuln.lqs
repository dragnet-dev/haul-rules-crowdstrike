// Dragnet [Container]: dragnet-container-2026-0765 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: a46ce76c-ebd6-547c-af5e-937568317381

#event_simpleName=*
| (ImageFileName = *chainguard:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
