// Dragnet [Ransomware]: dragnet-ransomware-2023-1731 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: e75d3f15-eab3-5675-8989-021110ca1f35

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
