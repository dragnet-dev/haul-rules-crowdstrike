// Dragnet [Ransomware]: dragnet-ransomware-2025-0661 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 94de84f6-ddbd-5c48-b255-4b09e4d89c8c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
