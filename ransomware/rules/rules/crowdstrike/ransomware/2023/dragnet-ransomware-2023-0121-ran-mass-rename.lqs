// Dragnet [Ransomware]: dragnet-ransomware-2023-0121 — Mass File Rename (knight)
// Status: experimental | Level: high | ID: a92c8bb1-4eaf-5449-8609-6737b263207c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
