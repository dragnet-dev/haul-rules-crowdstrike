// Dragnet [Ransomware]: dragnet-ransomware-2023-4931 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: ab07d321-97b5-5512-86ed-569d533b627f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
