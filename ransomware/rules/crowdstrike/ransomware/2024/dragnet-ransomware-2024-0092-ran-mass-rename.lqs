// Dragnet [Ransomware]: dragnet-ransomware-2024-0092 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: e83effa4-1f7b-5906-822c-c9de661b4aee

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
