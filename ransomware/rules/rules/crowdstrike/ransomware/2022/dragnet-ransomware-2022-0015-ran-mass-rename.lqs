// Dragnet [Ransomware]: dragnet-ransomware-2022-0015 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 12834334-c33b-5bad-b6b2-c97997b9cffe

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
