// Dragnet [Ransomware]: dragnet-ransomware-2022-1679 — Mass File Rename (kelvinsecurity)
// Status: deprecated | Level: high | ID: 9117e72a-2d8b-5ed0-84cd-13fee5d12964

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
