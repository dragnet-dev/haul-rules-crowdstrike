// Dragnet [Ransomware]: dragnet-ransomware-2023-4739 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 4fdcf663-8317-5cff-b9d2-744373e0a067

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
