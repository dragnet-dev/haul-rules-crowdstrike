// Dragnet [Ransomware]: dragnet-ransomware-2020-0102 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: c27ef251-446b-54f9-8bc7-7ccb1d850b36

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
