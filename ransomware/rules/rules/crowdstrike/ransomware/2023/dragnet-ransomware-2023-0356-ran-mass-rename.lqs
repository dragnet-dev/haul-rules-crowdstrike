// Dragnet [Ransomware]: dragnet-ransomware-2023-0356 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: edc886a8-0e70-5de4-ac18-f8bbff5d6f1e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
