// Dragnet [Ransomware]: dragnet-ransomware-2024-0106 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: aad66ce9-c7f0-5e20-bc92-299b0a911375

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
