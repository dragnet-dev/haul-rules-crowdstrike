// Dragnet [Ransomware]: dragnet-ransomware-2025-3753 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: caa64fcc-64d2-502c-b9f5-8cad22405155

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
