// Dragnet [Ransomware]: dragnet-ransomware-2025-6522 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: 12c7afc8-0c32-5406-8a57-073d9257fd28

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
