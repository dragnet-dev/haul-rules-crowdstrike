// Dragnet [Ransomware]: dragnet-ransomware-2023-3824 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: cc5305a9-74b5-52fe-821c-94df664507f0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
