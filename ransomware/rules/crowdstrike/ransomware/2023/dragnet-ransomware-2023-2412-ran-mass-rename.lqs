// Dragnet [Ransomware]: dragnet-ransomware-2023-2412 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: c8f3ac8c-95b2-5365-90d3-0e9984b6e074

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
