// Dragnet [Ransomware]: dragnet-ransomware-2025-5057 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 4e3eb930-1068-541b-8252-64788f9fc6ae

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
