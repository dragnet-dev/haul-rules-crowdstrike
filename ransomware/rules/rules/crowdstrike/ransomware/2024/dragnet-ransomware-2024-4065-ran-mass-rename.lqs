// Dragnet [Ransomware]: dragnet-ransomware-2024-4065 — Mass File Rename (blacklock)
// Status: experimental | Level: high | ID: 40242e39-dfb2-50fd-a57e-a5e7c743aff7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
