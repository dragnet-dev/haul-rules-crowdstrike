// Dragnet [Ransomware]: dragnet-ransomware-2026-3417 — Mass File Rename (anubis)
// Status: stable | Level: high | ID: 075cd27c-a5fb-53fb-b030-58e521516d18

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
