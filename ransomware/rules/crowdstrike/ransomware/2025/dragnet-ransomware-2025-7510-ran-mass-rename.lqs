// Dragnet [Ransomware]: dragnet-ransomware-2025-7510 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: b8b9fe16-1cef-53c6-af23-ed8821001006

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
