// Dragnet [Ransomware]: dragnet-ransomware-2025-7197 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 24b80658-0909-58a0-94d9-ca616086ad73

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
