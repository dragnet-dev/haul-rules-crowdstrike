// Dragnet [Ransomware]: dragnet-ransomware-2025-2248 — Mass File Rename (ransomhouse)
// Status: experimental | Level: high | ID: fdca7fa9-d752-5e58-90dc-9b253d80890f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
