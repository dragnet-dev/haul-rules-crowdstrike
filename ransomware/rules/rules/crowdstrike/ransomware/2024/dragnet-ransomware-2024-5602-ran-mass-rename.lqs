// Dragnet [Ransomware]: dragnet-ransomware-2024-5602 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: e4c93436-6868-51fd-8c23-72f7601cf8ac

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
