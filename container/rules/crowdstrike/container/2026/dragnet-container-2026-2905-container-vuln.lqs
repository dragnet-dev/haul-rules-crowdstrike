// Dragnet [Container]: dragnet-container-2026-2905 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 22dfc91f-538b-5343-b62a-63c7a42bf2bf

#event_simpleName=*
| (ImageFileName = *amazonlinux:1* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:7* OR ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10* OR ImageFileName = *ubuntu:13.04* OR ImageFileName = *ubuntu:13.10* OR ImageFileName = *ubuntu:14.04* OR ImageFileName = *ubuntu:14.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
