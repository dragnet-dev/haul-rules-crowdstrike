// Dragnet [Ransomware]: dragnet-ransomware-2025-2187 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 985d34c1-2f10-58d6-827d-4c2c2e335507

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
