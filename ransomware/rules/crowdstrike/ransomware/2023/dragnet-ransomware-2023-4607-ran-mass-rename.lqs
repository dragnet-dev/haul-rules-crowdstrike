// Dragnet [Ransomware]: dragnet-ransomware-2023-4607 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 06ea70fc-43df-5c33-98a9-331abf47c39c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
