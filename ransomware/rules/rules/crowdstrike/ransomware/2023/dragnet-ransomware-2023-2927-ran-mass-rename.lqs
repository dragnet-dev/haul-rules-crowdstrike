// Dragnet [Ransomware]: dragnet-ransomware-2023-2927 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: f335c1d7-890e-5d9f-aa0a-4690ba884b3e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
