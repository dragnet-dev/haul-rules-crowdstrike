// Dragnet [Ransomware]: dragnet-ransomware-2025-7187 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: 7f94669c-7aca-5940-b4c3-5ec8e2345786

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
