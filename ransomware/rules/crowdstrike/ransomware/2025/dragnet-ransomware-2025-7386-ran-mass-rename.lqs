// Dragnet [Ransomware]: dragnet-ransomware-2025-7386 — Mass File Rename (ransomhouse)
// Status: experimental | Level: high | ID: 1c9b9ab0-c48c-5da6-b091-7b52d72dc860

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
