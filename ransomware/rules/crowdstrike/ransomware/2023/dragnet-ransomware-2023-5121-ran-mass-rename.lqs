// Dragnet [Ransomware]: dragnet-ransomware-2023-5121 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: facfe2e3-1835-5e84-b296-aa6f03482136

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
