// Dragnet [Ransomware]: dragnet-ransomware-2023-4505 — Mass File Rename (worldleaks)
// Status: experimental | Level: high | ID: fe60af43-cbdc-5eb0-a931-d46f2504eba6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
