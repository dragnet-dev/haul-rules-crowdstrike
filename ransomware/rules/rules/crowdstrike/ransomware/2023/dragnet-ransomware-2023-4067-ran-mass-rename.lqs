// Dragnet [Ransomware]: dragnet-ransomware-2023-4067 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: eeb2e6f0-cb63-5f4a-acb5-d1b868bc5909

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
