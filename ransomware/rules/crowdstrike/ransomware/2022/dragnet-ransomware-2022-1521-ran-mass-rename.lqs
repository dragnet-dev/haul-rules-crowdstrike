// Dragnet [Ransomware]: dragnet-ransomware-2022-1521 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 1ef58d43-e29e-5545-a13f-e98ee0dbb6e4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
