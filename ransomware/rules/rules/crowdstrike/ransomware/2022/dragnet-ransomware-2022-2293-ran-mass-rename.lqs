// Dragnet [Ransomware]: dragnet-ransomware-2022-2293 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: fa1967ae-de0c-56e0-948b-d06faf5779ed

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
