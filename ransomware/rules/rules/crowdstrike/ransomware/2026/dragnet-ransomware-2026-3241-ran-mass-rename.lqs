// Dragnet [Ransomware]: dragnet-ransomware-2026-3241 — Mass File Rename (lockbit5)
// Status: test | Level: high | ID: cd0b711c-3eb8-59c2-9573-e77a7a24ac33

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
