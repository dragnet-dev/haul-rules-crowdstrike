// Dragnet [Ransomware]: dragnet-ransomware-2025-3483 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: c501b2c5-ce78-5e87-9aef-305c3fa095a9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
