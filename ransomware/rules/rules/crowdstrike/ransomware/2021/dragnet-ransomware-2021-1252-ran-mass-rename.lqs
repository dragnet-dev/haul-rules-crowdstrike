// Dragnet [Ransomware]: dragnet-ransomware-2021-1252 — Mass File Rename (synack)
// Status: deprecated | Level: high | ID: 73016816-368e-5ea2-9889-1731347068b3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
