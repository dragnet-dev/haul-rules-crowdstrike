// Dragnet [Ransomware]: dragnet-ransomware-2022-0993 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 0dd300c7-a088-59c3-a1f6-1a4de048cf10

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
