// Dragnet [Ransomware]: dragnet-ransomware-2024-5838 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 6254d61b-1539-50a8-8071-913cfd481ef8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
