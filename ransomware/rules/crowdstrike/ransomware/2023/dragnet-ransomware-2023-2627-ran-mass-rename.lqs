// Dragnet [Ransomware]: dragnet-ransomware-2023-2627 — Mass File Rename (raworld)
// Status: experimental | Level: high | ID: 310104f2-1a84-5096-b599-09f936a8a41b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
