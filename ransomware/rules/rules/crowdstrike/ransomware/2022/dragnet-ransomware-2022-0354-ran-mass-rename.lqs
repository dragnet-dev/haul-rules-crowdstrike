// Dragnet [Ransomware]: dragnet-ransomware-2022-0354 — Mass File Rename (blackbasta)
// Status: deprecated | Level: high | ID: 60b9bff0-bacf-5351-9096-9d2a984ce0d7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
