// Dragnet [Ransomware]: dragnet-ransomware-2024-3102 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: f3887744-b070-5721-948b-872b5cad6481

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
