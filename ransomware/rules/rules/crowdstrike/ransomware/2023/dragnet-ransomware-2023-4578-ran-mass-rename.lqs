// Dragnet [Ransomware]: dragnet-ransomware-2023-4578 — Mass File Rename (donutleaks)
// Status: experimental | Level: high | ID: 24cb9090-194c-5e21-94e6-f97e1d3cca57

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
