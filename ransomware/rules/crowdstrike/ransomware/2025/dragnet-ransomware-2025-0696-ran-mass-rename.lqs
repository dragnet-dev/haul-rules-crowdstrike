// Dragnet [Ransomware]: dragnet-ransomware-2025-0696 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: d246b969-f6ff-5455-8eab-fcb8582aeaf8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
