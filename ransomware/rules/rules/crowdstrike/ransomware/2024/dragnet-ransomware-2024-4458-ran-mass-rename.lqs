// Dragnet [Ransomware]: dragnet-ransomware-2024-4458 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: 82947af3-e438-5273-9adc-611f74a804bc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
