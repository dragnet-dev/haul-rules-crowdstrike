// Dragnet [Ransomware]: dragnet-ransomware-2024-1433 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 1cb7cf4f-56f8-5f59-ac1c-c38be1a5b79d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
