// Dragnet [Ransomware]: dragnet-ransomware-2024-2960 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: be646524-aff8-5959-b67e-fcdd5a5f5e42

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
