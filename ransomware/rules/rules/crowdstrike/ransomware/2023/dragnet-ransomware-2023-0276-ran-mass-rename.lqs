// Dragnet [Ransomware]: dragnet-ransomware-2023-0276 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: b5c78efb-442b-5433-be6a-b33a36a5d2b9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
