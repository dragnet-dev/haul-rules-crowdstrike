// Dragnet [Ransomware]: dragnet-ransomware-2023-2062 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: c83e2a84-7697-5f85-99ff-69a749c55bdb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
