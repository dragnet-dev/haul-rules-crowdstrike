// Dragnet [Ransomware]: dragnet-ransomware-2021-1511 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 78ba34d1-c6a1-5860-a6f3-8e77d6aa820e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
