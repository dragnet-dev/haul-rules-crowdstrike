// Dragnet [Ransomware]: dragnet-ransomware-2024-5183 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 0769fce9-4395-5258-8b6f-8b88bf2c7e24

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
