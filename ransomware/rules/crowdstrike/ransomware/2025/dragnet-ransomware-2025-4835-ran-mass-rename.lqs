// Dragnet [Ransomware]: dragnet-ransomware-2025-4835 — Mass File Rename (devman)
// Status: experimental | Level: high | ID: 6db55058-8dec-5e08-a15d-8c23959ea0d5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
