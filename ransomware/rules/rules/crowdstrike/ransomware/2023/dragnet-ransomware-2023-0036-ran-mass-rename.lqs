// Dragnet [Ransomware]: dragnet-ransomware-2023-0036 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: fd3bbdee-71e8-5f2e-a9a6-009d67efb0ec

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
