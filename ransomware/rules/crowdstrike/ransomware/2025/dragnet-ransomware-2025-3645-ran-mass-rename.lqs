// Dragnet [Ransomware]: dragnet-ransomware-2025-3645 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 9dbf85fb-4b56-556f-aa0f-2cf72f9b7fd8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
