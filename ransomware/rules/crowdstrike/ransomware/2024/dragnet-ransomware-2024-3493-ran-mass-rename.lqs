// Dragnet [Ransomware]: dragnet-ransomware-2024-3493 — Mass File Rename (handala)
// Status: experimental | Level: high | ID: 6e8d9763-2a03-5379-a4ab-59a5d8e9c8ba

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
