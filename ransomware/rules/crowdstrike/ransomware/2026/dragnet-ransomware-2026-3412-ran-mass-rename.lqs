// Dragnet [Ransomware]: dragnet-ransomware-2026-3412 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 15d7ad01-8d1a-5691-9d6c-18c08b1892d6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
