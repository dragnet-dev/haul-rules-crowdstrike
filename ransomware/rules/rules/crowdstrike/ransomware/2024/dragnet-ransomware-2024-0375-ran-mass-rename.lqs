// Dragnet [Ransomware]: dragnet-ransomware-2024-0375 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: b106c752-c29f-573b-be28-71bda0e9d099

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
