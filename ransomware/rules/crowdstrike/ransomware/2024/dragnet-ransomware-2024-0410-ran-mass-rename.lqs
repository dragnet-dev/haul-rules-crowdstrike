// Dragnet [Ransomware]: dragnet-ransomware-2024-0410 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 5172a722-de24-5ad2-9587-6bc73b51ac33

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
