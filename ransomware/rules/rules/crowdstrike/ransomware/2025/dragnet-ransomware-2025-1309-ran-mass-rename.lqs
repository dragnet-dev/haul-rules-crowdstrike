// Dragnet [Ransomware]: dragnet-ransomware-2025-1309 — Mass File Rename (warlock)
// Status: deprecated | Level: high | ID: 55d6b5b8-a529-58ff-bee2-358cbc32a857

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
