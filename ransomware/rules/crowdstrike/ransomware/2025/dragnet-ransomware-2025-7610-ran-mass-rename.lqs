// Dragnet [Ransomware]: dragnet-ransomware-2025-7610 — Mass File Rename (J)
// Status: experimental | Level: high | ID: 0e1daa75-b6be-5896-8eec-7826951955c6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
