// Dragnet [Ransomware]: dragnet-ransomware-2026-3477 — Mass File Rename (killsec)
// Status: deprecated | Level: high | ID: c4c36626-24de-5454-b502-1cd94c6afc89

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
