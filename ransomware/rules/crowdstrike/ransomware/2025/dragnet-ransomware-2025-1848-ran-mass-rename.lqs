// Dragnet [Ransomware]: dragnet-ransomware-2025-1848 — Mass File Rename (brotherhood)
// Status: experimental | Level: high | ID: 192cc75b-5609-5361-9161-78f163a6454b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
