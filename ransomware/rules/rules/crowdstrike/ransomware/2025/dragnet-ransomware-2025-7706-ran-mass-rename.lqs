// Dragnet [Ransomware]: dragnet-ransomware-2025-7706 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 2a919698-b74a-557c-8c36-9adaf4fa7031

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
