// Dragnet [Ransomware]: dragnet-ransomware-2026-2956 — Mass File Rename (payoutsking)
// Status: stable | Level: high | ID: 475ccfdd-62c5-58f6-8067-f24bcef6b285

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
