// Dragnet [Ransomware]: dragnet-ransomware-2023-5174 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: d212f510-3c30-5e3e-946c-7b8b61c6811c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
