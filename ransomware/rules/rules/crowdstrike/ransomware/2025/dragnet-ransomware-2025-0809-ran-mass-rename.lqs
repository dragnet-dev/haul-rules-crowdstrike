// Dragnet [Ransomware]: dragnet-ransomware-2025-0809 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: 7a609481-048a-551e-ba9c-19d16bf5097c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
