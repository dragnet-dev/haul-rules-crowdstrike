// Dragnet [Ransomware]: dragnet-ransomware-2024-2739 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 3d765774-72c5-5f96-bf45-35f97d0a1301

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
