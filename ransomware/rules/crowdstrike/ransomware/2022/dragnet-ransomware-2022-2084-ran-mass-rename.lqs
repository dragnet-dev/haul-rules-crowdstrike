// Dragnet [Ransomware]: dragnet-ransomware-2022-2084 — Mass File Rename (medusalocker)
// Status: deprecated | Level: high | ID: b7e28b9b-1aab-599d-93a5-df46cae647c7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
