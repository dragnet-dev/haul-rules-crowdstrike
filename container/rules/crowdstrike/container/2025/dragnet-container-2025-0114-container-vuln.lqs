// Dragnet [Container]: dragnet-container-2025-0114 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: ef9e5e49-bbf9-5988-9611-787f4e2a8bf6

#event_simpleName=*
| (ImageFileName = *chainguard:* OR ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:9* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:20.04* OR ImageFileName = *ubuntu:20.04-ESM* OR ImageFileName = *ubuntu:22.04* OR ImageFileName = *ubuntu:23.10* OR ImageFileName = *ubuntu:24.04* OR ImageFileName = *ubuntu:24.10* OR ImageFileName = *ubuntu:25.04* OR ImageFileName = *ubuntu:25.10* OR ImageFileName = *ubuntu:26.04* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
