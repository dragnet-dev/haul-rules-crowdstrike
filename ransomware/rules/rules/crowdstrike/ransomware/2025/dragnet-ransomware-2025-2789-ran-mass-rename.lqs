// Dragnet [Ransomware]: dragnet-ransomware-2025-2789 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: 41530a76-ea8c-5810-81af-743ea9e43b47

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
