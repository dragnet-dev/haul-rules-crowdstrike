// Dragnet [Ransomware]: dragnet-ransomware-2020-0112 — Mass File Rename (ragnarlocker)
// Status: deprecated | Level: high | ID: 1da42c25-37b3-5dfd-a50c-3e1cfc9a7f95

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
