// Dragnet [Ransomware]: dragnet-ransomware-2025-4972 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 17f58f2d-0915-59e8-afb4-20598787bf66

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
