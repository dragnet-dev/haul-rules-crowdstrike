// Dragnet [Ransomware]: dragnet-ransomware-2023-5020 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 15c028f6-f5f1-562f-958d-1666363f2798

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
