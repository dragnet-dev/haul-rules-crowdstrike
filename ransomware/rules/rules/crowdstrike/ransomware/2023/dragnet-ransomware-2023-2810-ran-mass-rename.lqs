// Dragnet [Ransomware]: dragnet-ransomware-2023-2810 — Mass File Rename (malas)
// Status: experimental | Level: high | ID: b3050467-42db-55de-8fea-82040197f5b5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
