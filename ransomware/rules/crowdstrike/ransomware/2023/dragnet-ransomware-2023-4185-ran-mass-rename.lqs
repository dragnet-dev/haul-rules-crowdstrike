// Dragnet [Ransomware]: dragnet-ransomware-2023-4185 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 0a4e491a-e573-5864-9c28-c9e61cf725e4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
