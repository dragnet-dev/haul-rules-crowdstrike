// Dragnet [Ransomware]: dragnet-ransomware-2024-1352 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: 6e4091f8-a1fd-5f4c-9dfd-b0fed02a63bb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
