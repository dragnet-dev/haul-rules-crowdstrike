// Dragnet [Ransomware]: dragnet-ransomware-2024-0649 — Mass File Rename (dAn0n)
// Status: experimental | Level: high | ID: 0827c3ad-a5b1-5ecb-b291-6b10047ba4fd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
