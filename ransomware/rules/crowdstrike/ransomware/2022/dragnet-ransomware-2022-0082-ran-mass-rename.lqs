// Dragnet [Ransomware]: dragnet-ransomware-2022-0082 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 868cbfe3-f232-5fd0-91f9-6c61b6502cce

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
