// Dragnet [Ransomware]: dragnet-ransomware-2022-2312 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 4681f30d-aaeb-5fd2-8687-04fec1c3e738

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
