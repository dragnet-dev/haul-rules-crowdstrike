// Dragnet [Ransomware]: dragnet-ransomware-2023-5338 — Mass File Rename (toufan)
// Status: deprecated | Level: high | ID: bca4b578-7dea-551e-afc4-b21cc0f2d4a9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
