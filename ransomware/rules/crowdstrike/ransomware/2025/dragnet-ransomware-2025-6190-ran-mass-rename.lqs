// Dragnet [Ransomware]: dragnet-ransomware-2025-6190 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: c2b46e9a-fc3d-5582-bf46-f96268585518

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
