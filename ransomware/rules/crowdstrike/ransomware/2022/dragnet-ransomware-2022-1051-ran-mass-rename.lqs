// Dragnet [Ransomware]: dragnet-ransomware-2022-1051 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: cc1942a2-0e82-577d-965e-0e412d6a7d11

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
