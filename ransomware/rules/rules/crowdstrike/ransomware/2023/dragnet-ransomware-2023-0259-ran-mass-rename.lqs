// Dragnet [Ransomware]: dragnet-ransomware-2023-0259 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: e59bb464-5d39-5a08-9486-bdea79334336

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
