// Dragnet [Ransomware]: dragnet-ransomware-2023-3687 — Mass File Rename (dragonforce)
// Status: deprecated | Level: high | ID: ec007000-4b4a-5c2d-9e7e-0bfbdec5c624

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
