// Dragnet [Ransomware]: dragnet-ransomware-2023-5314 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 11ece50e-a9e1-5c83-a362-169f324f16ac

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
