// Dragnet [Ransomware]: dragnet-ransomware-2023-0512 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: f785043b-1a3c-5c36-8e58-b56104fa9195

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
