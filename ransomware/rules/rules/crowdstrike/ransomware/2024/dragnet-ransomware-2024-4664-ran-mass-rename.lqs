// Dragnet [Ransomware]: dragnet-ransomware-2024-4664 — Mass File Rename (ransomcortex)
// Status: experimental | Level: high | ID: 4f427ba1-9aea-5ed3-8c7b-9a6babe784f1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
