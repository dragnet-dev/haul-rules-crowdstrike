// Dragnet [Ransomware]: dragnet-ransomware-2025-6151 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: 77779b68-6032-53f2-b6aa-1c689e80e244

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
