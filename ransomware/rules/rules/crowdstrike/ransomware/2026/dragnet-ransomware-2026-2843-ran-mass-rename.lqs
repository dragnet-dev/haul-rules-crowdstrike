// Dragnet [Ransomware]: dragnet-ransomware-2026-2843 — Mass File Rename (safepay)
// Status: stable | Level: high | ID: 384b85ca-3371-52bb-ba7d-31e56b33313c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
