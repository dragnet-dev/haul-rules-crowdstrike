// Dragnet [Ransomware]: dragnet-ransomware-2025-7109 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 494fa129-9866-51ad-8e3e-af05551458bf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
