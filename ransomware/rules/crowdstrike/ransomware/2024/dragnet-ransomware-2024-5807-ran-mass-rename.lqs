// Dragnet [Ransomware]: dragnet-ransomware-2024-5807 — Mass File Rename (play)
// Status: experimental | Level: high | ID: f4fe6480-f20b-58f7-b37a-5b0d0f51f600

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
