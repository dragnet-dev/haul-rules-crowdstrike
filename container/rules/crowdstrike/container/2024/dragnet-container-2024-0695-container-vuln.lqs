// Dragnet [Container]: dragnet-container-2024-0695 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 14f5ecb8-59a8-5f70-a580-be26d362dec8

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *redhat/ubi9:*)
| table([timestamp, ComputerName])
| limit(1000)
