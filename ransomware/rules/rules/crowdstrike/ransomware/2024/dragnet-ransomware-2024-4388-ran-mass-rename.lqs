// Dragnet [Ransomware]: dragnet-ransomware-2024-4388 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 76e99d87-11d1-54b4-96f6-c84d8720684b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
