// Dragnet [Ransomware]: dragnet-ransomware-2023-3916 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 49f29b72-afcc-5fd0-b04c-ad82c42d4053

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
