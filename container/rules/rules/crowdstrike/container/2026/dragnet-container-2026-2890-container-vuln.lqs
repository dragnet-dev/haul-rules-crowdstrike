// Dragnet [Container]: dragnet-container-2026-2890 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 418e0034-3fd5-5c08-bc36-b4b571258677

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:7* OR ImageFileName = *debian:8* OR ImageFileName = *redhat/ubi9:*)
| table([timestamp, ComputerName])
| limit(1000)
