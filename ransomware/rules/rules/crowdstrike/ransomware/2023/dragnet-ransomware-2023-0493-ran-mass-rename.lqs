// Dragnet [Ransomware]: dragnet-ransomware-2023-0493 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 2efc639a-701b-550d-8d24-8cfe85630b44

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
