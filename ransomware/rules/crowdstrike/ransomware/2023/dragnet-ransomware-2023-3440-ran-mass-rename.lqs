// Dragnet [Ransomware]: dragnet-ransomware-2023-3440 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 83ffbe0a-d8ca-5d2a-89c9-fd63443261ff

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
