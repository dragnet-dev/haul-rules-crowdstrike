// Dragnet [Ransomware]: dragnet-ransomware-2025-1375 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: edfd7f13-82a3-59e5-807d-d6acafff1172

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
