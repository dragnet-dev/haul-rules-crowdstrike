// Dragnet [Ransomware]: dragnet-ransomware-2023-3726 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 59426bc3-05e7-596f-b141-df88c8139649

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
