// Dragnet [Ransomware]: dragnet-ransomware-2023-5147 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 2bef4c38-6851-52f5-b7ac-6ade168eb9da

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
