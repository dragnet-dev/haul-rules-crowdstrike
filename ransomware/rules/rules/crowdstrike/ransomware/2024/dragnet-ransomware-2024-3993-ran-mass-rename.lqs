// Dragnet [Ransomware]: dragnet-ransomware-2024-3993 — Mass File Rename (BrainCipher)
// Status: experimental | Level: high | ID: 2fddd9cc-8c2c-5800-9f0e-d3b601443fc2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
