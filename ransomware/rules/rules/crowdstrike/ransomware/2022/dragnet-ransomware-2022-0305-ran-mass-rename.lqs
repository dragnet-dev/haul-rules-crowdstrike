// Dragnet [Ransomware]: dragnet-ransomware-2022-0305 — Mass File Rename (play)
// Status: deprecated | Level: high | ID: 223a5d24-9f4e-5669-9230-af8be42b2f45

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
