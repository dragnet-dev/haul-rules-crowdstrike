// Dragnet [Ransomware]: dragnet-ransomware-2024-1745 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: d1919c9b-f3a1-5190-b122-1c1b38c1c4b6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
