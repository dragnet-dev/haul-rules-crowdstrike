// Dragnet [Ransomware]: dragnet-ransomware-2024-0202 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: f3bc40f6-66a7-5c6f-b3da-da73bfe8c4e2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
