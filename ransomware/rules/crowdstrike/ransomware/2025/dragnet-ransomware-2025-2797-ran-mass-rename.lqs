// Dragnet [Ransomware]: dragnet-ransomware-2025-2797 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 2036a350-8238-5895-903b-7cd6a635d91b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
