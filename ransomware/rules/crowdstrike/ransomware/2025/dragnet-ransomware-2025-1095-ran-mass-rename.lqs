// Dragnet [Ransomware]: dragnet-ransomware-2025-1095 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 81719ad2-7fae-58a9-a2e5-18ed91a16993

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
