// Dragnet [Ransomware]: dragnet-ransomware-2025-2726 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: a563103f-f8b3-5efc-95c5-1e59cfef8958

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
