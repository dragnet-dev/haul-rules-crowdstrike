// Dragnet [Ransomware]: dragnet-ransomware-2024-4260 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 1cabe711-53f6-50a4-a818-7de8b90bbbb5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
