// Dragnet [Ransomware]: dragnet-ransomware-2025-3149 — Mass File Rename (coinbasecartel)
// Status: experimental | Level: high | ID: d55903a4-f41c-5af0-85f2-6cf2fa90ff6c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
