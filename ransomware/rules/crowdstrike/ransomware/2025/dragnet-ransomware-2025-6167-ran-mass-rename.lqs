// Dragnet [Ransomware]: dragnet-ransomware-2025-6167 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 17def243-d889-5388-9c82-a4156911528c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
