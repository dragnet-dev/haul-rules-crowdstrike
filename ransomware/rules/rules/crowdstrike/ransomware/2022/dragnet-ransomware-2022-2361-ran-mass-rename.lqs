// Dragnet [Ransomware]: dragnet-ransomware-2022-2361 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 295874b4-7f63-5983-b371-d11559cf1a95

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
