// Dragnet [Ransomware]: dragnet-ransomware-2024-1968 — Mass File Rename (rhysida)
// Status: deprecated | Level: high | ID: f653bed7-089f-57e5-8584-c4217125dd5e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
