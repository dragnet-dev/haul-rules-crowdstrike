// Dragnet [Ransomware]: dragnet-ransomware-2024-0401 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 32260113-c71d-54bb-ba84-e66d2001c58c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
