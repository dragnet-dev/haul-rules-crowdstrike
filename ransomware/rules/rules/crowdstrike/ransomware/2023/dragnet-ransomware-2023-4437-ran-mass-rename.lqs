// Dragnet [Ransomware]: dragnet-ransomware-2023-4437 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 42a8babb-2fd0-593a-9915-bbdf88021890

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
