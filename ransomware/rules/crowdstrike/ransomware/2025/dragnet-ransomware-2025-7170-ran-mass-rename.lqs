// Dragnet [Ransomware]: dragnet-ransomware-2025-7170 — Mass File Rename (anubis)
// Status: experimental | Level: high | ID: 90705ffb-bd04-5647-9ef0-033a47156d01

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
