// Dragnet [Ransomware]: dragnet-ransomware-2024-0524 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 393475e8-baed-5327-9989-61fba0fd43d4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
