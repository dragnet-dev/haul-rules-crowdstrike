// Dragnet [Ransomware]: dragnet-ransomware-2021-1405 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: cca4d980-9934-531f-9d03-1af53f32e6d1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
