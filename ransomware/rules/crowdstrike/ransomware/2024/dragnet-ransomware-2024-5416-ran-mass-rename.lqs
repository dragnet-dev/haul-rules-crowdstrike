// Dragnet [Ransomware]: dragnet-ransomware-2024-5416 — Mass File Rename (play)
// Status: experimental | Level: high | ID: d19820f2-4171-58e9-aba9-a59594e5c81b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
