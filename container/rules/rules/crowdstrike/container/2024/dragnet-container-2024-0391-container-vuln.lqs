// Dragnet [Container]: dragnet-container-2024-0391 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: be2d2d09-ecd5-5aba-9414-d2263c131e16

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:8* OR ImageFileName = *debian:9*)
| table([timestamp, ComputerName])
| limit(1000)
