// Dragnet [Ransomware]: dragnet-ransomware-2022-3094 — Mass File Rename (cuba)
// Status: deprecated | Level: high | ID: b509c684-90d1-533f-8c66-6692fa870d2a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
