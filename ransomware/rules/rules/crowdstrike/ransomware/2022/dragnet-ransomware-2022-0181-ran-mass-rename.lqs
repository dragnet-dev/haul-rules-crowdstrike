// Dragnet [Ransomware]: dragnet-ransomware-2022-0181 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: b84540c2-681b-5693-a987-6c3ff34e4878

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
