// Dragnet [Ransomware]: dragnet-ransomware-2025-0743 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 6a318cfb-e82f-50ae-ab20-6509ab5021ab

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
