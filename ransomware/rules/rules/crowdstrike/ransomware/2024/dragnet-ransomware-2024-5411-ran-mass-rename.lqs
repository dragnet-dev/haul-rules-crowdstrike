// Dragnet [Ransomware]: dragnet-ransomware-2024-5411 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: a5d3d323-33bb-5f76-a89a-87ac86cb0e31

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
