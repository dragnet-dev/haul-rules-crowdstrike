// Dragnet [Ransomware]: dragnet-ransomware-2025-5859 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 33fba309-281f-573b-b142-d08a876f7954

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
