// Dragnet [Ransomware]: dragnet-ransomware-2021-1188 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 3964087c-229e-56d3-98ed-c784187c3ded

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
