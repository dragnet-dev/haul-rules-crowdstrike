// Dragnet [Container]: dragnet-container-2026-0587 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 7afe39d3-5c01-521e-b8b3-7703241f4e39

#event_simpleName=*
| (ImageFileName = *azure linux:3.0* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
