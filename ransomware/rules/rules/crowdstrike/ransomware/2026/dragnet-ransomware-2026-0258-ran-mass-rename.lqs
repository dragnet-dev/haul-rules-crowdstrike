// Dragnet [Ransomware]: dragnet-ransomware-2026-0258 — Mass File Rename (insomnia)
// Status: stable | Level: high | ID: 5a0f6248-fb2b-5d6e-81b2-9f1e1763dbd2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
