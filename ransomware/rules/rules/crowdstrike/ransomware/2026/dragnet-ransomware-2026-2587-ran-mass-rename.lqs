// Dragnet [Ransomware]: dragnet-ransomware-2026-2587 — Mass File Rename (interlock)
// Status: stable | Level: high | ID: d80ea85f-c7ae-539c-a5f9-d60fa902fea2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
