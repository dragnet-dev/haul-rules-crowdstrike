// Dragnet [Ransomware]: dragnet-ransomware-2021-1574 — Mass File Rename (avaddon)
// Status: deprecated | Level: high | ID: 480ddfce-b941-599d-803d-c69194085766

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
