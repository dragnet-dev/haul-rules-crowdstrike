// Dragnet [Container]: dragnet-container-2024-0191 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 0bf35708-7035-5926-ae6e-0218878f2c46

#event_simpleName=*
| (ImageFileName = *chainguard:* OR ImageFileName = *debian:10* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
