// Dragnet [Ransomware]: dragnet-ransomware-2023-2490 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 174e2d0e-1d6b-5337-840e-4db8c6b92a1d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
