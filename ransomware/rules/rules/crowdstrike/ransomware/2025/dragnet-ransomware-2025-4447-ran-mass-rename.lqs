// Dragnet [Ransomware]: dragnet-ransomware-2025-4447 — Mass File Rename (SilentRansomGroup)
// Status: deprecated | Level: high | ID: fcc8ef1e-4c47-5e0e-a3fe-0d68f28dd82a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
