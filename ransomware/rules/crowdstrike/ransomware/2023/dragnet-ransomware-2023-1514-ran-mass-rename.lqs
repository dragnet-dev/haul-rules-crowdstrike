// Dragnet [Ransomware]: dragnet-ransomware-2023-1514 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: 23a7e805-ddbf-524e-98b3-81ff24b39999

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
