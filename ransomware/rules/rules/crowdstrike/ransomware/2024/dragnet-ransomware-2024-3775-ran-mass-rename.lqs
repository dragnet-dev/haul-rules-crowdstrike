// Dragnet [Ransomware]: dragnet-ransomware-2024-3775 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 80b9be06-fd54-52ff-adc2-d2c13b9fd0b3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
