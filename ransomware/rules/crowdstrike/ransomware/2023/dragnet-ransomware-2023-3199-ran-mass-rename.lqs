// Dragnet [Ransomware]: dragnet-ransomware-2023-3199 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: e9281c63-f99b-5318-b5d9-dc5fb0e3d8a1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
