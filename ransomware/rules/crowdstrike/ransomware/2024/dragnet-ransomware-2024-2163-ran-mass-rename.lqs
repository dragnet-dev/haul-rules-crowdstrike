// Dragnet [Ransomware]: dragnet-ransomware-2024-2163 — Mass File Rename (cloak)
// Status: deprecated | Level: high | ID: 6ea3f57d-0b68-57d6-bdab-66b17a25dc94

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
