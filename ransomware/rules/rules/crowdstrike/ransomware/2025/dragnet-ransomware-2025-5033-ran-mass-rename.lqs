// Dragnet [Ransomware]: dragnet-ransomware-2025-5033 — Mass File Rename (trinity)
// Status: experimental | Level: high | ID: c0df52d3-300d-5f7e-b193-4f7ce959694e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
