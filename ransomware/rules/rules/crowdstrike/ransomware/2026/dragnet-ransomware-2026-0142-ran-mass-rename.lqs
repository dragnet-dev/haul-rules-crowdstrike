// Dragnet [Ransomware]: dragnet-ransomware-2026-0142 — Mass File Rename (stormous)
// Status: deprecated | Level: high | ID: 4bf42952-c3d0-552c-b892-b2a50061223b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
