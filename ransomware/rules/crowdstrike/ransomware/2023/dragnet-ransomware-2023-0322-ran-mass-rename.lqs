// Dragnet [Ransomware]: dragnet-ransomware-2023-0322 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: c65626c5-8257-53b6-8fe7-bb5049dc4f81

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
