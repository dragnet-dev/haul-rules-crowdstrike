// Dragnet [Container]: dragnet-container-2024-0839 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 347fbc8a-a576-5848-9f62-9b4a22fcce6f

#event_simpleName=*
| (ImageFileName = *amazonlinux:2* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:9* OR ImageFileName = *oraclelinux:8* OR ImageFileName = *photon os:1.0* OR ImageFileName = *photon os:2.0* OR ImageFileName = *photon os:3.0* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:18.04* OR ImageFileName = *ubuntu:18.04-ESM* OR ImageFileName = *ubuntu:20.04* OR ImageFileName = *ubuntu:20.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
