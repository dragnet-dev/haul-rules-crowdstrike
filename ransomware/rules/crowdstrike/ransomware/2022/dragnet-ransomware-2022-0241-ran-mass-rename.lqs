// Dragnet [Ransomware]: dragnet-ransomware-2022-0241 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 3503bd5e-5a73-5692-bf07-09dbce5c326e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
