// Dragnet [Ransomware]: dragnet-ransomware-2025-7179 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: e7319127-85f0-5fa8-bb8c-0e7b20fc41de

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
