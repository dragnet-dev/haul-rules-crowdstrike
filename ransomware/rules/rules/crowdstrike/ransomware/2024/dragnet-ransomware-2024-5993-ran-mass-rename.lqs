// Dragnet [Ransomware]: dragnet-ransomware-2024-5993 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: 2008ac7e-1a3d-5ee5-8f30-3371aab3ff4a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
