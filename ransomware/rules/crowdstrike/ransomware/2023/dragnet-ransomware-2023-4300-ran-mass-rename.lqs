// Dragnet [Ransomware]: dragnet-ransomware-2023-4300 — Mass File Rename (play)
// Status: experimental | Level: high | ID: b94783fa-4fd0-53c3-8e6f-5d2e4c9815d5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
