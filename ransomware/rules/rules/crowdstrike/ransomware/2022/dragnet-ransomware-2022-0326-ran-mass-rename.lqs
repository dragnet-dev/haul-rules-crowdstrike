// Dragnet [Ransomware]: dragnet-ransomware-2022-0326 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 97b8b626-dd1f-578a-8a74-d12c70bfe7e5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
