// Dragnet [Container]: dragnet-container-2024-0307 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 9d5950b4-bfb0-5aa3-a565-38b6c1ff8248

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
