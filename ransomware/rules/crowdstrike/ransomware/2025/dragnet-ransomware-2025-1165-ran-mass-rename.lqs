// Dragnet [Ransomware]: dragnet-ransomware-2025-1165 — Mass File Rename (SilentRansomGroup)
// Status: deprecated | Level: high | ID: 1a33ba11-5e6c-5289-8a27-123f680ef609

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
