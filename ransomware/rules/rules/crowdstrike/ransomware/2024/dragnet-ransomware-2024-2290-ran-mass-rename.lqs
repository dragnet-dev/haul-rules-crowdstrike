// Dragnet [Ransomware]: dragnet-ransomware-2024-2290 — Mass File Rename (rhysida)
// Status: deprecated | Level: high | ID: 40b9dc03-4f43-5b8e-9294-2e19cdc1400f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
