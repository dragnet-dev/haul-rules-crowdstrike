// Dragnet [Ransomware]: dragnet-ransomware-2022-0087 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 84bc13c6-fbb9-519c-a9e8-a783437eef9b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
