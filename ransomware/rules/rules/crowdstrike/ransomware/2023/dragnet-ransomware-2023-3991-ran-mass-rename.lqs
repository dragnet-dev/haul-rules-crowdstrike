// Dragnet [Ransomware]: dragnet-ransomware-2023-3991 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 524cd837-c3bf-56fe-a467-46f233c72f50

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
