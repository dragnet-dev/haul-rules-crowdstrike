// Dragnet [Ransomware]: dragnet-ransomware-2025-7186 — Mass File Rename (insomnia)
// Status: test | Level: high | ID: ac0998e8-126f-541e-966f-360946d501dc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
