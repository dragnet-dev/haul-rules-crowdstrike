// Dragnet [Ransomware]: dragnet-ransomware-2024-5335 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 57a5e44a-1322-5282-86ed-11654f367a61

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
