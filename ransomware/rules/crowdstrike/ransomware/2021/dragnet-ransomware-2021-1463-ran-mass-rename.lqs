// Dragnet [Ransomware]: dragnet-ransomware-2021-1463 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 4868537f-4336-5b6e-8802-bc14b5da9f2d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
