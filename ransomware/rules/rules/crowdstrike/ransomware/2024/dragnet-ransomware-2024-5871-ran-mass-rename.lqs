// Dragnet [Ransomware]: dragnet-ransomware-2024-5871 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 190e01c5-8f7d-594c-9f7d-b6d58654418c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
