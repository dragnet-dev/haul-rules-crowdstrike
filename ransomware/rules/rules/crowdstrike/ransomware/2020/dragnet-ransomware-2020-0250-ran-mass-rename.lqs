// Dragnet [Ransomware]: dragnet-ransomware-2020-0250 — Mass File Rename (doppelpaymer)
// Status: deprecated | Level: high | ID: 2348bde0-7a34-5dae-b211-ce079a306cbc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
