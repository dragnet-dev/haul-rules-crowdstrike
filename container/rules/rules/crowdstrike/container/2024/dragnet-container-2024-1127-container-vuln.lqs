// Dragnet [Container]: dragnet-container-2024-1127 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 624c6e7f-14f7-57f9-a299-a5488ee3450f

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:20.04-ESM* OR ImageFileName = *ubuntu:22.04*)
| table([timestamp, ComputerName])
| limit(1000)
