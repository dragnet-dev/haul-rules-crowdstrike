// Dragnet [Ransomware]: dragnet-ransomware-2022-2346 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 3f176b94-2f97-5b14-964f-d99087b8a2c8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
