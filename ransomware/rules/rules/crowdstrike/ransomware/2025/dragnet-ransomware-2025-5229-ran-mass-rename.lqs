// Dragnet [Ransomware]: dragnet-ransomware-2025-5229 — Mass File Rename (lockbit5)
// Status: test | Level: high | ID: fb510793-b916-588e-aa2c-b27189534b44

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
