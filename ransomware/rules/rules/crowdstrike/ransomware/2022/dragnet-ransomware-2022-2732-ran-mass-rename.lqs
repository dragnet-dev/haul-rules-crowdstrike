// Dragnet [Ransomware]: dragnet-ransomware-2022-2732 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 5c45c1e0-d831-5e75-ac22-845ea69ecd62

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
