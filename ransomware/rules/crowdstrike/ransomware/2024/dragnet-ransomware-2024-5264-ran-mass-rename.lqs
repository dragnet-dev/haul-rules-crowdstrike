// Dragnet [Ransomware]: dragnet-ransomware-2024-5264 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 6b9d0c0b-1c8d-5fde-9103-36028a7c673b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
