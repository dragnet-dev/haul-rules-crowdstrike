// Dragnet [Container]: dragnet-container-2026-3045 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: af217bba-bdfb-5c6f-b4b8-1de99895e50c

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6*)
| table([timestamp, ComputerName])
| limit(1000)
