// Dragnet [Ransomware]: dragnet-ransomware-2023-4371 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: 45c61158-b86c-526d-af0d-a67c9e5c80cf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
