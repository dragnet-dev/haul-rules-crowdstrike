// Dragnet [Container]: dragnet-container-2026-2521 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: c6273e30-17d6-5abc-9fbe-8c7f31aa1f06

#event_simpleName=*
| (ImageFileName = *chainguard:* OR ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *ubuntu:12.04*)
| table([timestamp, ComputerName])
| limit(1000)
