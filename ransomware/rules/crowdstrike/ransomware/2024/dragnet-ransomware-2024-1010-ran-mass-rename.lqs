// Dragnet [Ransomware]: dragnet-ransomware-2024-1010 — Mass File Rename (shinyhunters)
// Status: experimental | Level: high | ID: f0f44875-4200-523d-94f7-5af9834e94d1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
