// Dragnet [Ransomware]: dragnet-ransomware-2025-1554 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: d55a6232-93f9-5b26-96ef-92d6222ff080

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
