// Dragnet [Ransomware]: dragnet-ransomware-2025-0337 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 412aa47e-746a-5d74-acb8-0e6d0077fa81

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
