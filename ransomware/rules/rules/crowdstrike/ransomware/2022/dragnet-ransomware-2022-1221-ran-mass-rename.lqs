// Dragnet [Ransomware]: dragnet-ransomware-2022-1221 — Mass File Rename (karakurt)
// Status: experimental | Level: high | ID: 43b82e71-ab94-5afb-b7e9-00d6ccdb22cc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
