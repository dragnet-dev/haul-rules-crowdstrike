// Dragnet [Ransomware]: dragnet-ransomware-2025-4948 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 05a170a3-9372-5ddb-b2d5-59b008510304

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
