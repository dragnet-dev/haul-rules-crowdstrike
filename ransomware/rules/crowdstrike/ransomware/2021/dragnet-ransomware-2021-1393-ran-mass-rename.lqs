// Dragnet [Ransomware]: dragnet-ransomware-2021-1393 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: a8949ab9-d4cf-5e6b-9a8a-4a370c56ac3c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
