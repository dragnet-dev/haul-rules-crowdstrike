// Dragnet [Ransomware]: dragnet-ransomware-2025-0400 — Mass File Rename (obscura)
// Status: experimental | Level: high | ID: eefffdbd-d722-5691-a6af-8eac16e97463

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
