// Dragnet [Container]: dragnet-container-2024-0910 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 67f208d6-eba3-51f0-95e4-7fe6a276dd60

#event_simpleName=*
| (ImageFileName = *chainguard:* OR ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
