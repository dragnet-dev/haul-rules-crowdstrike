// Dragnet [Ransomware]: dragnet-ransomware-2023-1369 — Mass File Rename (mallox)
// Status: deprecated | Level: high | ID: 95325995-79ea-592f-a5c2-0c994811c3d5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
