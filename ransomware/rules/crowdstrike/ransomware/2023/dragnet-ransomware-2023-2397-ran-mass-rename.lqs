// Dragnet [Ransomware]: dragnet-ransomware-2023-2397 — Mass File Rename (royal)
// Status: experimental | Level: high | ID: 9d488b7e-51c3-505a-83a9-c173010526ea

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
