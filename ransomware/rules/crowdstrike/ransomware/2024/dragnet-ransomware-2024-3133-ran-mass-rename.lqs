// Dragnet [Ransomware]: dragnet-ransomware-2024-3133 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: ddb0834b-cb21-5ea9-b656-33d0daaa6696

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
