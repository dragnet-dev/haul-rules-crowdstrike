// Dragnet [Ransomware]: dragnet-ransomware-2026-2279 — Mass File Rename (nightspire)
// Status: deprecated | Level: high | ID: 8c84d58e-4321-5c78-afc2-4fb3f5c8b420

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
