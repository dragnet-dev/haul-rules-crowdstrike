// Dragnet [Ransomware]: dragnet-ransomware-2025-2669 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 4bc1e8fd-f5d4-51f9-99d1-16ff169da15d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
