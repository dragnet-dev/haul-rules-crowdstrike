// Dragnet [Ransomware]: dragnet-ransomware-2025-7585 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 7859c0f0-d6f3-5222-93d5-3783f8178ff5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
