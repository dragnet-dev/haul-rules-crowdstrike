// Dragnet [Ransomware]: dragnet-ransomware-2021-1688 — Mass File Rename (ransomexx)
// Status: deprecated | Level: high | ID: 1a5c6e87-0e6e-50fc-b22b-0d5eab542bda

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
