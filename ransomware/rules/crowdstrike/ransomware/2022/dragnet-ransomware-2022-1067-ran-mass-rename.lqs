// Dragnet [Ransomware]: dragnet-ransomware-2022-1067 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 82cd954e-3a7e-570e-9900-e39b625a3e67

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
