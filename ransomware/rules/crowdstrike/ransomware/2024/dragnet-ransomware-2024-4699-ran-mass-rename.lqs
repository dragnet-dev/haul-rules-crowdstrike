// Dragnet [Ransomware]: dragnet-ransomware-2024-4699 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: b727510e-fa34-58a1-b74c-20e42436f7fa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
