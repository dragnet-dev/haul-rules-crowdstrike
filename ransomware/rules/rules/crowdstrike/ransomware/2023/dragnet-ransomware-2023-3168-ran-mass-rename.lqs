// Dragnet [Ransomware]: dragnet-ransomware-2023-3168 — Mass File Rename (toufan)
// Status: deprecated | Level: high | ID: a855cf74-6320-55ea-9012-7d18d00990de

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
