// Dragnet [Ransomware]: dragnet-ransomware-2022-3005 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: a1207599-6d77-54a4-b0d7-fe44597311e1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
