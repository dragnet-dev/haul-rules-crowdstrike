// Dragnet [Ransomware]: dragnet-ransomware-2024-3138 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 5742654b-bde9-50d4-9a3b-445b8224fc18

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
