// Dragnet [Ransomware]: dragnet-ransomware-2022-2395 — Mass File Rename (bianlian)
// Status: deprecated | Level: high | ID: ef96b32a-4ec5-5de8-92ec-a0e32201885b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
