// Dragnet [Ransomware]: dragnet-ransomware-2024-4866 — Mass File Rename (ElDorado)
// Status: experimental | Level: high | ID: d51cad5d-ea71-5f5c-87f9-275dab49de8a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
