// Dragnet [Ransomware]: dragnet-ransomware-2023-5216 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: 212f8d34-f8cf-524e-88b0-07b0ce58973a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
