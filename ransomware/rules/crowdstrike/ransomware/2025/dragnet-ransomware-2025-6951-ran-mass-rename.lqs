// Dragnet [Ransomware]: dragnet-ransomware-2025-6951 — Mass File Rename (nightspire)
// Status: deprecated | Level: high | ID: 3a29240c-51e2-5c29-b2e8-6d489ed0cee6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
