// Dragnet [Ransomware]: dragnet-ransomware-2022-2808 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 4518d33f-d079-5c72-b0e3-d3cb9805c023

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
