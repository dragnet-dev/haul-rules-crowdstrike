// Dragnet [Ransomware]: dragnet-ransomware-2024-5076 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: ca3c70a3-d2b8-5d59-9b42-6085ee826365

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
