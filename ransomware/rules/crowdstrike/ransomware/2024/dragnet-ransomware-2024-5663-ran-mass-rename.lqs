// Dragnet [Ransomware]: dragnet-ransomware-2024-5663 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 31dee058-9d1a-5d00-9738-050ac1b1759f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
