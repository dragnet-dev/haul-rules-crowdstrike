// Dragnet [Ransomware]: dragnet-ransomware-2024-0264 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 790aa814-6a22-5214-b3d5-06ef1c949137

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
