// Dragnet [Ransomware]: dragnet-ransomware-2025-2956 — Mass File Rename (embargo)
// Status: experimental | Level: high | ID: 533ba863-fdb0-50d5-96ac-481c942f03a8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
