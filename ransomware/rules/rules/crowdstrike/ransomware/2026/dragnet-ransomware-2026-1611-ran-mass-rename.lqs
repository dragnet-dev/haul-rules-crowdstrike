// Dragnet [Ransomware]: dragnet-ransomware-2026-1611 — Mass File Rename (incransom)
// Status: stable | Level: high | ID: 9631ef56-c44d-52ee-8679-b383886905f5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
