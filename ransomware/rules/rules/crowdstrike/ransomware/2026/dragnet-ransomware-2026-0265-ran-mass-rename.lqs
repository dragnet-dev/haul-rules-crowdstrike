// Dragnet [Ransomware]: dragnet-ransomware-2026-0265 — Mass File Rename (dragonforce)
// Status: stable | Level: high | ID: 539d73a0-7e2b-57a4-b019-2a64b24ae051

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
