// Dragnet [Ransomware]: dragnet-ransomware-2026-3094 — Mass File Rename (securotrop)
// Status: test | Level: high | ID: 55a797b8-ce4e-5678-a354-7a6a94ffb992

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
