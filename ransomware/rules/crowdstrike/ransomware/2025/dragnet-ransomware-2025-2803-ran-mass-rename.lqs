// Dragnet [Ransomware]: dragnet-ransomware-2025-2803 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 3c385a2d-7986-598d-a674-534ac61467bd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
