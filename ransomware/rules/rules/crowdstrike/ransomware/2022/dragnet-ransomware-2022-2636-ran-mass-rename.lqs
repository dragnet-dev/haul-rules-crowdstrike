// Dragnet [Ransomware]: dragnet-ransomware-2022-2636 — Mass File Rename (play)
// Status: deprecated | Level: high | ID: 69f30e3c-7baa-5f26-a9f3-302aef993812

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
