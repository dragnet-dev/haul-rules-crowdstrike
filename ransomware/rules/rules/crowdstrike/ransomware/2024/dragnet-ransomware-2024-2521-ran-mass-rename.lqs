// Dragnet [Ransomware]: dragnet-ransomware-2024-2521 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 8a7af7f2-6b49-5b44-bed2-0e95c37b566a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
