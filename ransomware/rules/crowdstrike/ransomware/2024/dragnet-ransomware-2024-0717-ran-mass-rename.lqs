// Dragnet [Ransomware]: dragnet-ransomware-2024-0717 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: 6c38afad-cdb0-53af-a301-2a18bf43ca08

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
