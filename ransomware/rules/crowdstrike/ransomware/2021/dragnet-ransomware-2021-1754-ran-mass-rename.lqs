// Dragnet [Ransomware]: dragnet-ransomware-2021-1754 — Mass File Rename (alphv)
// Status: deprecated | Level: high | ID: dd2e3a19-cbf5-596c-ab2b-75547c0d57b1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
