// Dragnet [Ransomware]: dragnet-ransomware-2025-2739 — Mass File Rename (warlock)
// Status: deprecated | Level: high | ID: ef87f0dc-3bd7-556b-96c1-484484e9762d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
