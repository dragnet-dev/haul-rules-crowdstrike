// Dragnet [Ransomware]: dragnet-ransomware-2025-7153 — Mass File Rename (shinyhunters)
// Status: experimental | Level: high | ID: 9c472049-6d53-5519-be48-f59901565081

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
