// Dragnet [Ransomware]: dragnet-ransomware-2023-3068 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 65c7719a-9971-5a71-a4ed-ca403464d51c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
