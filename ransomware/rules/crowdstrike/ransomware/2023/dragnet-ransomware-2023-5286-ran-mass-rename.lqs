// Dragnet [Ransomware]: dragnet-ransomware-2023-5286 — Mass File Rename (ransomhouse)
// Status: deprecated | Level: high | ID: 80da10d9-00f6-5354-afd4-3673cb06cb0e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
