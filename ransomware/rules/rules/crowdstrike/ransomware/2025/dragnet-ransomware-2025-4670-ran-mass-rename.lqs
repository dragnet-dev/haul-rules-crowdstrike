// Dragnet [Ransomware]: dragnet-ransomware-2025-4670 — Mass File Rename (flocker)
// Status: experimental | Level: high | ID: 4adb7a0b-6e93-5bf4-bc88-75b542cf2beb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
