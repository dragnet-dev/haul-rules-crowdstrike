// Dragnet [Ransomware]: dragnet-ransomware-2026-3349 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: e52d8c4d-dbc3-5484-8e3e-02054ba4774e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
