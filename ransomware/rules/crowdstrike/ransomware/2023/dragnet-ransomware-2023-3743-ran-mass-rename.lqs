// Dragnet [Ransomware]: dragnet-ransomware-2023-3743 — Mass File Rename (siegedsec)
// Status: experimental | Level: high | ID: f58b8897-57dc-5a12-89a0-9aa0a459b22c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
