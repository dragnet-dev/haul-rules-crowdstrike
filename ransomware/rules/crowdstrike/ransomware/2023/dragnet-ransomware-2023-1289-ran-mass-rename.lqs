// Dragnet [Ransomware]: dragnet-ransomware-2023-1289 — Mass File Rename (noescape)
// Status: experimental | Level: high | ID: 02311040-ffa8-525b-bee0-9b60dd300e55

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
