// Dragnet [Ransomware]: dragnet-ransomware-2023-4432 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 99b960c6-bb99-5077-a20d-d168ddca9075

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
