// Dragnet [Ransomware]: dragnet-ransomware-2024-3907 — Mass File Rename (trisec)
// Status: experimental | Level: high | ID: 703e9489-0acc-55ac-bca2-2b4390bc40fc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
