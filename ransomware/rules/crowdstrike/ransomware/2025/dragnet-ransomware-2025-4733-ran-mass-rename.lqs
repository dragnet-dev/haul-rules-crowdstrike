// Dragnet [Ransomware]: dragnet-ransomware-2025-4733 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: e9971e2d-16b8-5329-8716-782734bc6ad8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
