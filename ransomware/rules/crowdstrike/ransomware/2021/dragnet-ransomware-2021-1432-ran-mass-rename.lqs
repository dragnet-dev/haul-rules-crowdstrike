// Dragnet [Ransomware]: dragnet-ransomware-2021-1432 — Mass File Rename (ryuk)
// Status: deprecated | Level: high | ID: 3457946b-b155-596b-8a15-2a9bc7e7d35a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
