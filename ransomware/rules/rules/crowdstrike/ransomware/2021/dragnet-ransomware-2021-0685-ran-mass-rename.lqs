// Dragnet [Ransomware]: dragnet-ransomware-2021-0685 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 6f8654e4-6293-501e-950e-4386de118527

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
