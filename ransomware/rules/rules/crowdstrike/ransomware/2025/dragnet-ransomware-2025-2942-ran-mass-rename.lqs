// Dragnet [Ransomware]: dragnet-ransomware-2025-2942 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: f60127ff-07c4-5ddf-9c1e-f0277ef4a676

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
