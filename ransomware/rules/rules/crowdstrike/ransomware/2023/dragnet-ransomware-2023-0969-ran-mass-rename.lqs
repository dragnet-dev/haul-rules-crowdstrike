// Dragnet [Ransomware]: dragnet-ransomware-2023-0969 — Mass File Rename (donutleaks)
// Status: experimental | Level: high | ID: 7267163e-25ad-58bd-a614-816ce4a51b4d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
