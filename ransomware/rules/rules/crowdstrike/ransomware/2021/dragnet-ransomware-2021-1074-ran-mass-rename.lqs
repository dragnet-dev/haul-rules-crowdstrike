// Dragnet [Ransomware]: dragnet-ransomware-2021-1074 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 0916f368-aabf-5bb3-93fc-236c9d503858

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
