// Dragnet [Ransomware]: dragnet-ransomware-2026-2682 — Mass File Rename (incransom)
// Status: test | Level: high | ID: 93d31acd-55ff-55e3-b47e-eb09ed1027fe

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
