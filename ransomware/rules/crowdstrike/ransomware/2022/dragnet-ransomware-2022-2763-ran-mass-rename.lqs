// Dragnet [Ransomware]: dragnet-ransomware-2022-2763 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 2671de84-4abd-5b08-96a4-b0bc02db456d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
