// Dragnet [Ransomware]: dragnet-ransomware-2023-1497 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 7fa5caf3-5576-5cb9-bf38-272090312ebe

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
