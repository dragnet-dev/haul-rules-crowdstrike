// Dragnet [Ransomware]: dragnet-ransomware-2022-1228 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: e2f41cd6-3c18-5c9f-9e28-ef5a15ff705b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
