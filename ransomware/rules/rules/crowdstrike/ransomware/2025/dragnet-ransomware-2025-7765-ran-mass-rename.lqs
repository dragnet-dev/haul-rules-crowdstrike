// Dragnet [Ransomware]: dragnet-ransomware-2025-7765 — Mass File Rename (kairos)
// Status: experimental | Level: high | ID: f1ce9e5c-cbd9-5461-8259-9c17f7435c85

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
