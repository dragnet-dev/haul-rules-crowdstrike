// Dragnet [Ransomware]: dragnet-ransomware-2024-5399 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: feee36b9-75fe-5698-8dcf-92e9434e3c63

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
