// Dragnet [Ransomware]: dragnet-ransomware-2024-1915 — Mass File Rename (BrainCipher)
// Status: experimental | Level: high | ID: 8b3c5cdf-06ea-5820-8387-375e20f75b42

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
