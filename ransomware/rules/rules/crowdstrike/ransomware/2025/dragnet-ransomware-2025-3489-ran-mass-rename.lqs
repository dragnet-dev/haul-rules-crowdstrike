// Dragnet [Ransomware]: dragnet-ransomware-2025-3489 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 7a0df762-9d40-5973-9e97-465e0ba361e4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
