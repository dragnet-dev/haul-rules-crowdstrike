// Dragnet [Ransomware]: dragnet-ransomware-2025-4208 — Mass File Rename (warlock)
// Status: deprecated | Level: high | ID: 254cca06-7f42-5b77-9668-d2c0b534c68a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
