// Dragnet [Ransomware]: dragnet-ransomware-2023-0459 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 4610181a-56f6-5c22-a5d6-51fb7f94ec12

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
