// Dragnet [Ransomware]: dragnet-ransomware-2025-3813 — Mass File Rename (obscura)
// Status: experimental | Level: high | ID: d5f2a2c0-e9b4-5c2e-9dcf-2b6186a30879

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
