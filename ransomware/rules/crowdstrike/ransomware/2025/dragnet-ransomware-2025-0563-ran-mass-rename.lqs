// Dragnet [Ransomware]: dragnet-ransomware-2025-0563 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 15e0009d-e648-5987-894a-efce9b7ae544

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
