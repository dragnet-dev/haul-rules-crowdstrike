// Dragnet [Ransomware]: dragnet-ransomware-2024-0950 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 5bc3c2ca-5a34-57bd-9dab-a6346a45312a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
