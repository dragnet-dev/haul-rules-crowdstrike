// Dragnet [Ransomware]: dragnet-ransomware-2023-2103 — Mass File Rename (avoslocker)
// Status: deprecated | Level: high | ID: b36714dc-5088-5c7a-ab5a-60ba0608fc1c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
