// Dragnet [Ransomware]: dragnet-ransomware-2022-2954 — Mass File Rename (everest)
// Status: deprecated | Level: high | ID: 41bc7404-cede-547d-afd6-adf99f26702f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
