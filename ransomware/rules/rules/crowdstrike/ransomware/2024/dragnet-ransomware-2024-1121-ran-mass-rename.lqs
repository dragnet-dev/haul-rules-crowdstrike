// Dragnet [Ransomware]: dragnet-ransomware-2024-1121 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: f15ac808-eb45-5075-8016-c5f857f6e669

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
