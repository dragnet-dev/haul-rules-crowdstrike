// Dragnet [Ransomware]: dragnet-ransomware-2026-0372 — Mass File Rename (kittykatkrew)
// Status: stable | Level: high | ID: 53d5795e-1cd7-59fd-87ce-ddf23be37c85

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
