// Dragnet [Ransomware]: dragnet-ransomware-2024-2027 — Mass File Rename (BrainCipher)
// Status: experimental | Level: high | ID: a21be41f-d225-52e9-a4fd-e8588a0a6638

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
