// Dragnet [Ransomware]: dragnet-ransomware-2024-3192 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: b98980bc-2bde-5bbe-84fa-896b49b93ac1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
