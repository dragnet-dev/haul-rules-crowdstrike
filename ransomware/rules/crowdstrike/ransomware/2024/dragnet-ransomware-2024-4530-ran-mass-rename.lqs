// Dragnet [Ransomware]: dragnet-ransomware-2024-4530 — Mass File Rename (safepay)
// Status: deprecated | Level: high | ID: e1f4b736-99c5-51af-9d69-a28ddc408388

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
