// Dragnet [Ransomware]: dragnet-ransomware-2023-3800 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 06b5cf7d-868b-5b23-a638-b681a373b95a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
