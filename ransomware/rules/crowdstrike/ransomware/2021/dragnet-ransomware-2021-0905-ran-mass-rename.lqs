// Dragnet [Ransomware]: dragnet-ransomware-2021-0905 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 3132889f-0d46-5680-93a0-557dfe7aa3bf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
