// Dragnet [Ransomware]: dragnet-ransomware-2023-4726 — Mass File Rename (knight)
// Status: experimental | Level: high | ID: 21738ebf-ca03-5b00-82b0-b4da1a1b5578

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
