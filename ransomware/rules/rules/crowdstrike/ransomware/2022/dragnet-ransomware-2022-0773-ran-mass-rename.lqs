// Dragnet [Ransomware]: dragnet-ransomware-2022-0773 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 24b88723-0644-5499-8db7-8cd63042f750

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
