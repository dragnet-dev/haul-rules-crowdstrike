// Dragnet [Ransomware]: dragnet-ransomware-2021-0474 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: fa41f5a9-a83f-5b28-bcc9-0351aa838129

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
