// Dragnet [Ransomware]: dragnet-ransomware-2025-0374 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 35f06820-165e-527b-a3f3-80786b9e4061

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
