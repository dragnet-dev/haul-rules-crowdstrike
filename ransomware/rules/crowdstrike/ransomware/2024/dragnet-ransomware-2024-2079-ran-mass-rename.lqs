// Dragnet [Ransomware]: dragnet-ransomware-2024-2079 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: b3a4964a-118d-5591-8d72-292d9e513801

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
