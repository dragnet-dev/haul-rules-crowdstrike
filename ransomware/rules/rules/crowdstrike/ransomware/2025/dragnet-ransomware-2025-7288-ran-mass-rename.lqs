// Dragnet [Ransomware]: dragnet-ransomware-2025-7288 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 7f374d44-0ba5-541d-99ac-5f8f1e474a1d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
