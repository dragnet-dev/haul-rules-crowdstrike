// Dragnet [Ransomware]: dragnet-ransomware-2024-3769 — Mass File Rename (knight)
// Status: experimental | Level: high | ID: 753ab6bb-f304-548c-a46e-43f45327b0f6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
