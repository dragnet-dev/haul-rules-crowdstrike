// Dragnet [Ransomware]: dragnet-ransomware-2024-1510 — Mass File Rename (abyss)
// Status: deprecated | Level: high | ID: 990df3c2-c7db-55c3-ad79-9f93d3cf8f97

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
