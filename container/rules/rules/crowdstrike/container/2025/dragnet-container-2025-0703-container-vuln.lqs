// Dragnet [Container]: dragnet-container-2025-0703 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: bab3d8a5-c36b-574f-b7a0-9ee05ac496f7

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:9* OR ImageFileName = *ubuntu:16.04* OR ImageFileName = *ubuntu:18.04*)
| table([timestamp, ComputerName])
| limit(1000)
