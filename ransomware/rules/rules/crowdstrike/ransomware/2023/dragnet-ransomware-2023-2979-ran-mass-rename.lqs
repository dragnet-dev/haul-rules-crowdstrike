// Dragnet [Ransomware]: dragnet-ransomware-2023-2979 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 3be289d1-ce92-5492-83c0-08cbfcb6efba

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
