// Dragnet [Ransomware]: dragnet-ransomware-2024-4003 — Mass File Rename (meow)
// Status: experimental | Level: high | ID: 6d76bb94-8887-578a-8734-e6cd28043705

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
