// Dragnet [Ransomware]: dragnet-ransomware-2023-4184 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: c33bc273-dda0-5e3e-930d-74fe5164c002

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
