// Dragnet [Container]: dragnet-container-2026-2253 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 9b03a433-a878-512b-8a0f-6b78f0666254

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:5*)
| table([timestamp, ComputerName])
| limit(1000)
