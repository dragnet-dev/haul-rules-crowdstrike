// Dragnet [Ransomware]: dragnet-ransomware-2024-5874 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 1ab08cc0-f7a9-594e-95fa-ab719d150dc3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
