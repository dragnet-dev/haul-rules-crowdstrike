// Dragnet [Ransomware]: dragnet-ransomware-2026-2583 — Mass File Rename (dragonforce)
// Status: stable | Level: high | ID: cd21aaa5-c280-5895-b183-8111c0cc2125

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
