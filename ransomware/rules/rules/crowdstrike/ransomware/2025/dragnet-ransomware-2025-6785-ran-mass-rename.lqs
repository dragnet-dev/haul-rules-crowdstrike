// Dragnet [Ransomware]: dragnet-ransomware-2025-6785 — Mass File Rename (play)
// Status: experimental | Level: high | ID: ae7f94d3-2420-56a5-a9da-ded289f6fc9b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
