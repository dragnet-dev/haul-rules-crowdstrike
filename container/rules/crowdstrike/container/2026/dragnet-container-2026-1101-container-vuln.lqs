// Dragnet [Container]: dragnet-container-2026-1101 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 4c7f6747-1af3-5440-bc7b-8dfedfd9c17f

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:5*)
| table([timestamp, ComputerName])
| limit(1000)
