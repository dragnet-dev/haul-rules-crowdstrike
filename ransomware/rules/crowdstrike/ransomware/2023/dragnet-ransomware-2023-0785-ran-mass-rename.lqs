// Dragnet [Ransomware]: dragnet-ransomware-2023-0785 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: dccb8b4c-dff9-5498-8a4e-093c049df135

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
