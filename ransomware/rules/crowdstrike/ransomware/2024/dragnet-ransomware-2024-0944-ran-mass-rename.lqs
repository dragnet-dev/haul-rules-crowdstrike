// Dragnet [Ransomware]: dragnet-ransomware-2024-0944 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: 0939645e-2c33-552b-a853-2b3fe0f29560

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
