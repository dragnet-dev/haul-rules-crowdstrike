// Dragnet [Ransomware]: dragnet-ransomware-2023-3251 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 936f665e-7881-5725-8e49-be990330b395

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
