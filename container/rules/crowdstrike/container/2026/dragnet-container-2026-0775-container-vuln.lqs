// Dragnet [Container]: dragnet-container-2026-0775 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: a14a392f-290c-59ef-907c-2d92d8eea2ad

#event_simpleName=*
| (ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10* OR ImageFileName = *ubuntu:13.04* OR ImageFileName = *ubuntu:13.10*)
| table([timestamp, ComputerName])
| limit(1000)
