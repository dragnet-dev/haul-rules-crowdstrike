// Dragnet [Ransomware]: dragnet-ransomware-2023-0571 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: e03600c2-f5c7-5c83-9391-0da6bf0a097d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
