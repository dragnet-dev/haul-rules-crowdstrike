// Dragnet [Ransomware]: dragnet-ransomware-2025-4141 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: 26c878d5-a6e9-572b-b8a5-2cff7965efe9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
