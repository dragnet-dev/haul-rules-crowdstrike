// Dragnet [Ransomware]: dragnet-ransomware-2025-6144 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 0512ca5d-72f8-528b-97d9-9efe2ba00c65

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
