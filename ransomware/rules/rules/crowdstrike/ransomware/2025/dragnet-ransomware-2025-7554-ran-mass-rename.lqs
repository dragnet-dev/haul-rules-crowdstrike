// Dragnet [Ransomware]: dragnet-ransomware-2025-7554 — Mass File Rename (AiLock)
// Status: deprecated | Level: high | ID: 16468614-0bce-5bf4-b115-c03778497fa2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
