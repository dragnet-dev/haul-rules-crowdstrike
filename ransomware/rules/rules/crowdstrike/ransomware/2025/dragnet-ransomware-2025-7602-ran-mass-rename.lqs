// Dragnet [Ransomware]: dragnet-ransomware-2025-7602 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 9c236dcc-12b3-5757-8268-22491cccb642

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
