// Dragnet [Ransomware]: dragnet-ransomware-2023-0386 — Mass File Rename (ransomhouse)
// Status: experimental | Level: high | ID: 5f2763ed-2a86-55b1-9c34-3871e2e5ecb6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
