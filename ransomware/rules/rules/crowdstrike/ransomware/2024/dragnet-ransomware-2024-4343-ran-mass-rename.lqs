// Dragnet [Ransomware]: dragnet-ransomware-2024-4343 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: d3165034-199f-53a9-8735-4ff18ef509c8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
