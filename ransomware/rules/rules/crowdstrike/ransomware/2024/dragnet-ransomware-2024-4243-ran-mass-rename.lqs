// Dragnet [Ransomware]: dragnet-ransomware-2024-4243 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 8ae2eeab-08d7-55f6-b4d2-e5007c7da612

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
