// Dragnet [Container]: dragnet-container-2025-0528 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 6bdd1e60-4c47-5a18-a3ec-680eb256c270

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:7* OR ImageFileName = *debian:8* OR ImageFileName = *debian:9*)
| table([timestamp, ComputerName])
| limit(1000)
