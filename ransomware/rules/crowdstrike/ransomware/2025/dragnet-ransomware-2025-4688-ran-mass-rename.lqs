// Dragnet [Ransomware]: dragnet-ransomware-2025-4688 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: ac4f0500-29e8-56e6-88b3-a9a7fdaf7696

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
