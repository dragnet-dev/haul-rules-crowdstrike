// Dragnet [Ransomware]: dragnet-ransomware-2025-7141 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 0dcb5129-e5d1-57d1-ae65-a62ad2af31a4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
