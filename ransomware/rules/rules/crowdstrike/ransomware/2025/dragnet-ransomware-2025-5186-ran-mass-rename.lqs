// Dragnet [Ransomware]: dragnet-ransomware-2025-5186 — Mass File Rename (warlock)
// Status: deprecated | Level: high | ID: 0822fa98-2d3b-50c8-ac2d-54c3971596a0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
