// Dragnet [Ransomware]: dragnet-ransomware-2025-3416 — Mass File Rename (play)
// Status: experimental | Level: high | ID: c137cf91-e9b4-5e46-8d70-e2e2939a9749

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
