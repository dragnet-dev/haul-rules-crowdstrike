// Dragnet [Ransomware]: dragnet-ransomware-2023-0770 — Mass File Rename (royal)
// Status: experimental | Level: high | ID: 90425c9d-21ef-535e-9e91-d416796e02b2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
