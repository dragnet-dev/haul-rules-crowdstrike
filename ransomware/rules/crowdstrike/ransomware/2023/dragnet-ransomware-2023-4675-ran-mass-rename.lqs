// Dragnet [Ransomware]: dragnet-ransomware-2023-4675 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 12a18e92-140d-55d5-a33d-de30f8491b71

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
