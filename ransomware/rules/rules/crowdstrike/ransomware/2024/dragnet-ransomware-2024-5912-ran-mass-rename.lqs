// Dragnet [Ransomware]: dragnet-ransomware-2024-5912 — Mass File Rename (monti)
// Status: experimental | Level: high | ID: 461a2530-266c-5e7f-be99-c50534b5840e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
