// Dragnet [Ransomware]: dragnet-ransomware-2023-5208 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 3309734c-069b-50ce-b73c-6316fcf1eaef

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
