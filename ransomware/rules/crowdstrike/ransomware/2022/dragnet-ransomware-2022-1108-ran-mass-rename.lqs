// Dragnet [Ransomware]: dragnet-ransomware-2022-1108 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 6fc1d38e-8530-5122-b29e-6221cf111f7d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
