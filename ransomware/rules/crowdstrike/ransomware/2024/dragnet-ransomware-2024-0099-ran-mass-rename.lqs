// Dragnet [Ransomware]: dragnet-ransomware-2024-0099 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 2e096010-2051-5a5a-b7da-8b45a8da2e31

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
