// Dragnet [Ransomware]: dragnet-ransomware-2025-7522 — Mass File Rename (sarcoma)
// Status: deprecated | Level: high | ID: 2058747b-b8f1-580e-82d8-91d43a6a4e9e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
