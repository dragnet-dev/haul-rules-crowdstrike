// Dragnet [Ransomware]: dragnet-ransomware-2021-1373 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: fa8a5a78-fa17-5d70-a4a8-c02d6e94903a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
