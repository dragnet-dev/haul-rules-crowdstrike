// Dragnet [Ransomware]: dragnet-ransomware-2026-1677 — Mass File Rename (killsec)
// Status: deprecated | Level: high | ID: fc9016ff-449f-5e6b-a225-7faed4c6fd1d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
