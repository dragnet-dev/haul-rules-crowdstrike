// Dragnet [Ransomware]: dragnet-ransomware-2022-2548 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 21c8a740-b959-56ef-9db2-b430149cfd2c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
