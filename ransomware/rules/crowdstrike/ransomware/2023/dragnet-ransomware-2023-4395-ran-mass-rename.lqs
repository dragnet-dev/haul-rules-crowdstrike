// Dragnet [Ransomware]: dragnet-ransomware-2023-4395 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 27b131a1-e358-5999-a500-ca51e42c5413

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
