// Dragnet [Container]: dragnet-container-2026-1213 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 34e035d0-a632-5ba5-9dcf-7723981d4814

#event_simpleName=*
| (ImageFileName = *chainguard:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
