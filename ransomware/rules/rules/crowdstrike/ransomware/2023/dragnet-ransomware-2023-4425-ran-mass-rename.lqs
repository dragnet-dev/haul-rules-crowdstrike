// Dragnet [Ransomware]: dragnet-ransomware-2023-4425 — Mass File Rename (play)
// Status: deprecated | Level: high | ID: 1430b0b4-024f-5b30-b9eb-74512ec0fa3e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
