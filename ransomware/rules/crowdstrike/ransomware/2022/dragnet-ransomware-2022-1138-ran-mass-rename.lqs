// Dragnet [Ransomware]: dragnet-ransomware-2022-1138 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 5cc0bec1-ddc5-5fac-ba16-f022ec7aa1a7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
