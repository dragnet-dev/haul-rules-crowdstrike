// Dragnet [Ransomware]: dragnet-ransomware-2022-2292 — Mass File Rename (cuba)
// Status: deprecated | Level: high | ID: a6afe3f6-0d4c-51f2-a152-4d3eee389713

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
