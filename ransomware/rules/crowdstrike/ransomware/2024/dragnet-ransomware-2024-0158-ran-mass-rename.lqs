// Dragnet [Ransomware]: dragnet-ransomware-2024-0158 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: f0423ad5-4d56-5093-8087-e4dab54cf90a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
