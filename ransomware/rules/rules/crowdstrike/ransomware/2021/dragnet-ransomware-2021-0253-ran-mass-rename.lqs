// Dragnet [Ransomware]: dragnet-ransomware-2021-0253 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 056ff446-b963-5567-9686-6016efd683d8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
