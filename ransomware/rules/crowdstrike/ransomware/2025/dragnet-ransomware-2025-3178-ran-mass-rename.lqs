// Dragnet [Ransomware]: dragnet-ransomware-2025-3178 — Mass File Rename (worldleaks)
// Status: experimental | Level: high | ID: d4d75725-9af9-5905-8c3f-4b16deb6c028

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
