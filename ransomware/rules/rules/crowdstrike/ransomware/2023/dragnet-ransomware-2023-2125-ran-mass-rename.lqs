// Dragnet [Ransomware]: dragnet-ransomware-2023-2125 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 11767b98-4a5c-516c-b2d0-cfa1eca9a848

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
