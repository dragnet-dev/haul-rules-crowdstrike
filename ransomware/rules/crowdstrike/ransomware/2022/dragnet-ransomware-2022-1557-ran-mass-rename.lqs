// Dragnet [Ransomware]: dragnet-ransomware-2022-1557 — Mass File Rename (bianlian)
// Status: deprecated | Level: high | ID: 3451c9cd-47c3-54eb-8d5e-7e8fbaf0ce3d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
