// Dragnet [Ransomware]: dragnet-ransomware-2026-2674 — Mass File Rename (nightspire)
// Status: deprecated | Level: high | ID: bf64b67f-c9ac-5a89-9ff0-d04399b11498

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
