// Dragnet [Ransomware]: dragnet-ransomware-2025-5856 — Mass File Rename (stormous)
// Status: deprecated | Level: high | ID: f64ec037-cd02-58ed-8c4c-220a6fc0fcc4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
