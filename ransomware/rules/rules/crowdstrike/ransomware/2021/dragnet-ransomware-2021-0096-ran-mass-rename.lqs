// Dragnet [Ransomware]: dragnet-ransomware-2021-0096 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: f95947ce-ed1d-5ad0-b936-43dc1f5b6704

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
