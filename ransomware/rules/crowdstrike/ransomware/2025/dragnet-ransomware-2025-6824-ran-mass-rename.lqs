// Dragnet [Ransomware]: dragnet-ransomware-2025-6824 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: cbb7b0e0-b890-5268-9549-0f64ceca6c64

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
