// Dragnet [Ransomware]: dragnet-ransomware-2025-5908 — Mass File Rename (direwolf)
// Status: experimental | Level: high | ID: c83cf376-ff11-5ca7-ac0d-fbf9400a6315

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
