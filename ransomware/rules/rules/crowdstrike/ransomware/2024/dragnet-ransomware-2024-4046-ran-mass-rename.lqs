// Dragnet [Ransomware]: dragnet-ransomware-2024-4046 — Mass File Rename (knight)
// Status: experimental | Level: high | ID: dca11cdf-5d2e-5253-8d2f-1f2129a5ef88

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
