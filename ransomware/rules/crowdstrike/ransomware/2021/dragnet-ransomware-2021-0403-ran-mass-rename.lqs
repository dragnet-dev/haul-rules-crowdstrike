// Dragnet [Ransomware]: dragnet-ransomware-2021-0403 — Mass File Rename (everest)
// Status: deprecated | Level: high | ID: 1233dd22-dc9a-5389-98ff-441473f717f5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
