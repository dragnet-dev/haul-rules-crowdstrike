// Dragnet [Ransomware]: dragnet-ransomware-2022-2993 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: fd38f500-361f-5c67-a764-68aedb99e749

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
