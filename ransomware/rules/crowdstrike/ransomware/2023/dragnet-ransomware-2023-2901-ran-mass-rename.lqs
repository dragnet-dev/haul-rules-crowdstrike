// Dragnet [Ransomware]: dragnet-ransomware-2023-2901 — Mass File Rename (akira)
// Status: experimental | Level: high | ID: 0e8f672b-4192-5a50-97b5-83c75f919c91

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
