// Dragnet [Ransomware]: dragnet-ransomware-2025-2341 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 127c8387-770b-5016-a603-810e9d6b74bf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
