// Dragnet [Ransomware]: dragnet-ransomware-2022-1697 — Mass File Rename (cuba)
// Status: deprecated | Level: high | ID: 201083d0-46e9-5453-b3d1-f13933cbc186

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
