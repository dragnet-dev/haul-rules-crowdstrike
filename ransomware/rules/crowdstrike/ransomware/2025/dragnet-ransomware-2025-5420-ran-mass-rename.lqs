// Dragnet [Ransomware]: dragnet-ransomware-2025-5420 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 7b670376-4ab1-5850-8e47-a13e2f723b08

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
