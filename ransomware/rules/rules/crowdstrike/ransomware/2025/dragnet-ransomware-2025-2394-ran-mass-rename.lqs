// Dragnet [Ransomware]: dragnet-ransomware-2025-2394 — Mass File Rename (thegentlemen)
// Status: experimental | Level: high | ID: fed2690e-510f-5d08-b12f-9f19cbd226e7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
