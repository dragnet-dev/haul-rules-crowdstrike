// Dragnet [Ransomware]: dragnet-ransomware-2024-4621 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: d07f6725-4e13-55c2-904e-2762aed7b349

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
