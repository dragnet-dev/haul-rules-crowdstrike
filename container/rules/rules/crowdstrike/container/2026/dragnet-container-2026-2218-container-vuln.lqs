// Dragnet [Container]: dragnet-container-2026-2218 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 87911afd-1c47-5330-9dce-717c06405ce9

#event_simpleName=*
| (ImageFileName = *chainguard:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:9* OR ImageFileName = *photon os:4.0*)
| table([timestamp, ComputerName])
| limit(1000)
