// Dragnet [Ransomware]: dragnet-ransomware-2025-2399 — Mass File Rename (thegentlemen)
// Status: experimental | Level: high | ID: 894544de-68f9-5a93-91ae-299c870cc90e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
