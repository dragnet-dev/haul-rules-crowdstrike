// Dragnet [Ransomware]: dragnet-ransomware-2025-6122 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: 1d77675e-8e3d-5482-847d-c1a3e8c66d8d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
