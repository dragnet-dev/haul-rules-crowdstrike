// Dragnet [Ransomware]: dragnet-ransomware-2025-2514 — Mass File Rename (ransomhouse)
// Status: experimental | Level: high | ID: bd8d7f9f-d4c9-5e6c-b25d-54c8c418c423

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
