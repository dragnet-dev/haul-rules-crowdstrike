// Dragnet [Ransomware]: dragnet-ransomware-2022-0555 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 493bc3be-530c-5f74-8329-aa1a905343a5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
