// Dragnet [Ransomware]: dragnet-ransomware-2024-4787 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 14283e21-5fd4-5976-b406-02f4741223aa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
