// Dragnet [Container]: dragnet-container-2026-0441 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: a502f5ae-8df4-5f34-93bb-376322dbca3d

#event_simpleName=*
| (ImageFileName = *amazonlinux:1* OR ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10*)
| table([timestamp, ComputerName])
| limit(1000)
