// Dragnet [Ransomware]: dragnet-ransomware-2023-4129 — Mass File Rename (ragnarlocker)
// Status: experimental | Level: high | ID: 9c4b49aa-8774-5cb9-97be-d6d9f6221b6f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
