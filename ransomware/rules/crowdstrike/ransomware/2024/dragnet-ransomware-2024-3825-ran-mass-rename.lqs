// Dragnet [Ransomware]: dragnet-ransomware-2024-3825 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 4a8ab63b-166d-5217-9cc2-aa22523f7fcb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
