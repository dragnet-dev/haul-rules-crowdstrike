// Dragnet [Ransomware]: dragnet-ransomware-2025-7330 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 99e2e027-d84d-5e08-b0f5-7f5f462a461f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
