// Dragnet [Ransomware]: dragnet-ransomware-2022-0683 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 236e4d63-8d32-5d03-9f92-a31d6070f58a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
