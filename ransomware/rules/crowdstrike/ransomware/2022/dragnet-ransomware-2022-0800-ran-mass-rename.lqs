// Dragnet [Ransomware]: dragnet-ransomware-2022-0800 — Mass File Rename (cuba)
// Status: deprecated | Level: high | ID: 651e8ce4-d064-5c7d-a6e1-e030e6683a8b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
