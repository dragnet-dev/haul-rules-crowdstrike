// Dragnet [Ransomware]: dragnet-ransomware-2022-0562 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: a01d1d2b-3853-5971-9781-f9b42017ab80

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
