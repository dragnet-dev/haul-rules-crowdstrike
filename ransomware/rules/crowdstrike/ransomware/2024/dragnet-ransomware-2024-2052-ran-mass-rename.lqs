// Dragnet [Ransomware]: dragnet-ransomware-2024-2052 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: 28db5150-65ea-520a-b961-9f780ab99520

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
