// Dragnet [Ransomware]: dragnet-ransomware-2024-0157 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: e1e271f6-c57f-5f41-a357-43d1e3616363

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
