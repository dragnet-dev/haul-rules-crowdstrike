// Dragnet [Ransomware]: dragnet-ransomware-2024-0768 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 53ca2476-b907-5558-bce0-2f778272aa01

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
