// Dragnet [Ransomware]: dragnet-ransomware-2023-4667 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: c8fe8931-b593-5a4e-9a0c-ccd7928f0927

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
