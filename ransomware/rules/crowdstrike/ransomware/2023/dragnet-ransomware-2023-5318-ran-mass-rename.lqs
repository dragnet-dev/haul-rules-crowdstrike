// Dragnet [Ransomware]: dragnet-ransomware-2023-5318 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: 1b934f7f-60aa-52b5-96a3-afb07b4d919a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
