// Dragnet [Ransomware]: dragnet-ransomware-2023-5114 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 75030fd9-d51d-59ce-9571-a3f0ed6da183

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
