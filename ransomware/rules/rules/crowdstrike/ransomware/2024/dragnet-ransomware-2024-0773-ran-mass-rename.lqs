// Dragnet [Ransomware]: dragnet-ransomware-2024-0773 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: bdda68eb-9b7e-5042-8005-953a910dfa5a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
