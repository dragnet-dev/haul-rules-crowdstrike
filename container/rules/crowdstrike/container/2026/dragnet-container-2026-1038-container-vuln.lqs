// Dragnet [Container]: dragnet-container-2026-1038 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: d1178573-fc17-5a87-8407-b20deda62c6a

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
