// Dragnet [Ransomware]: dragnet-ransomware-2024-5140 — Mass File Rename (blacklock)
// Status: experimental | Level: high | ID: d63d227d-4143-5189-ae0f-17f19500f7a3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
