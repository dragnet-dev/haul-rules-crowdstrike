// Dragnet [Ransomware]: dragnet-ransomware-2025-6872 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: 559bd9f7-2a53-54be-86b0-3f2d4536bd9f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
