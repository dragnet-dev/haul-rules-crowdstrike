// Dragnet [Ransomware]: dragnet-ransomware-2023-0640 — Mass File Rename (trigona)
// Status: deprecated | Level: high | ID: 932a15c5-816c-5a46-a2b3-490d0eb6ad13

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
