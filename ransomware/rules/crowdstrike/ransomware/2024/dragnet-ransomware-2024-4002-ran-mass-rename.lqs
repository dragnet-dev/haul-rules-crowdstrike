// Dragnet [Ransomware]: dragnet-ransomware-2024-4002 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 0547294f-0161-5168-a8be-1a5749362c74

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
