// Dragnet [Ransomware]: dragnet-ransomware-2025-1852 — Mass File Rename (brotherhood)
// Status: experimental | Level: high | ID: 50428444-a448-5241-96c9-38e08a92e8e2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
