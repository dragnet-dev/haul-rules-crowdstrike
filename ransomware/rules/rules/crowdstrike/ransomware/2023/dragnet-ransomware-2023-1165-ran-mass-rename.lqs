// Dragnet [Ransomware]: dragnet-ransomware-2023-1165 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: e42835c3-6a43-504d-98d3-033531a40118

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
