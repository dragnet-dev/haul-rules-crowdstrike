// Dragnet [Ransomware]: dragnet-ransomware-2024-5878 — Mass File Rename (play)
// Status: experimental | Level: high | ID: d3b404e5-0e97-5a34-90ab-098c9f85da34

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
