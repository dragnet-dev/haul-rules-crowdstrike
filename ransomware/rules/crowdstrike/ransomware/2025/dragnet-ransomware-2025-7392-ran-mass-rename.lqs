// Dragnet [Ransomware]: dragnet-ransomware-2025-7392 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: 29156791-f603-5911-ab05-f8a051bc7017

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
