// Dragnet [Ransomware]: dragnet-ransomware-2024-0327 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: dc95460f-3cb6-509a-998b-028579dc86fc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
