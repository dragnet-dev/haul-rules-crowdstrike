// Dragnet [Ransomware]: dragnet-ransomware-2022-3040 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 457130be-600e-5a86-bdef-25a15e335131

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
