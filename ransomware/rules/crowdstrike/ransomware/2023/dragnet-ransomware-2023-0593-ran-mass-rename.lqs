// Dragnet [Ransomware]: dragnet-ransomware-2023-0593 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 5c11f8b0-286b-5b2a-af6e-e00cd1f6e68b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
