// Dragnet [Ransomware]: dragnet-ransomware-2022-0163 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 54b5c93f-89dd-51e5-a151-ca541ba79f07

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
