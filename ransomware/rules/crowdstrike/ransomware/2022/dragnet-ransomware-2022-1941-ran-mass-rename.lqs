// Dragnet [Ransomware]: dragnet-ransomware-2022-1941 — Mass File Rename (quantum)
// Status: deprecated | Level: high | ID: 38296f3d-4e31-53fb-b1a6-28db303a93f7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
