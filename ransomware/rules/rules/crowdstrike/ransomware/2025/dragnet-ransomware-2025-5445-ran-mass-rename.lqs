// Dragnet [Ransomware]: dragnet-ransomware-2025-5445 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 623e41ff-9af3-54cd-abf6-fb35fdf0acae

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
