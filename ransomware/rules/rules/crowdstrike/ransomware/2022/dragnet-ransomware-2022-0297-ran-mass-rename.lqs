// Dragnet [Ransomware]: dragnet-ransomware-2022-0297 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: be8a635a-ec90-58a5-8723-aebc20aad72f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
