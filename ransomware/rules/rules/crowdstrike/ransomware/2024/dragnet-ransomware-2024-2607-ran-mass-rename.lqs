// Dragnet [Ransomware]: dragnet-ransomware-2024-2607 — Mass File Rename (meow)
// Status: experimental | Level: high | ID: adc41f01-bea5-5042-8ae5-3477b1d393b4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
