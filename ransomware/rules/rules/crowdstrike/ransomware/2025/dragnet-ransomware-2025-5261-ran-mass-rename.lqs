// Dragnet [Ransomware]: dragnet-ransomware-2025-5261 — Mass File Rename (beast)
// Status: experimental | Level: high | ID: 2f8836c7-8b41-567b-a708-0c5b35c1d210

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
