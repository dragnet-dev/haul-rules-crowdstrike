// Dragnet [Ransomware]: dragnet-ransomware-2021-1561 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 47e717ac-c775-5f68-8c25-f4b122768113

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
