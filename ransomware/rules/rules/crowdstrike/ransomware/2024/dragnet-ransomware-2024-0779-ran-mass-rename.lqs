// Dragnet [Ransomware]: dragnet-ransomware-2024-0779 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: bc1cc719-2366-58ad-90a3-9434ac1b9807

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
