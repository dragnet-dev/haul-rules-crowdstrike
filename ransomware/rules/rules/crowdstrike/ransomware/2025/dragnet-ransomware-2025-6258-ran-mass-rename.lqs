// Dragnet [Ransomware]: dragnet-ransomware-2025-6258 — Mass File Rename (genesis)
// Status: experimental | Level: high | ID: 43850bc3-2fed-51e7-9015-e0dc1083b291

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
