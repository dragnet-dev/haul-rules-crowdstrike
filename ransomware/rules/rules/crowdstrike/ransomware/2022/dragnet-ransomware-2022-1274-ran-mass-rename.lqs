// Dragnet [Ransomware]: dragnet-ransomware-2022-1274 — Mass File Rename (play)
// Status: deprecated | Level: high | ID: a7d09edc-9416-5cc6-bb2e-bca4cab9c67d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
