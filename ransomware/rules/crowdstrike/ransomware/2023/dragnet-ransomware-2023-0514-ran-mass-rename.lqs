// Dragnet [Ransomware]: dragnet-ransomware-2023-0514 — Mass File Rename (trigona)
// Status: experimental | Level: high | ID: d1919e0d-7a69-511d-b37d-434fa5db7825

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
