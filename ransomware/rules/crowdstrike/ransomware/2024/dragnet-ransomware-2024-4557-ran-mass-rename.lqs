// Dragnet [Ransomware]: dragnet-ransomware-2024-4557 — Mass File Rename (darkvault)
// Status: experimental | Level: high | ID: 50f14e04-7e50-5fad-aa0d-e6a3b6accbc6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
