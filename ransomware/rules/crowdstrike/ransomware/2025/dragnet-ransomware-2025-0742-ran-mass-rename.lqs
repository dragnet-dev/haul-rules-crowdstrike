// Dragnet [Ransomware]: dragnet-ransomware-2025-0742 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 67120bc4-021f-52c2-aa41-a82d295d17c0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
