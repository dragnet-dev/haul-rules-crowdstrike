// Dragnet [Ransomware]: dragnet-ransomware-2024-1848 — Mass File Rename (underground)
// Status: experimental | Level: high | ID: 8900f8f6-5398-5eaa-9a24-69d7857d4952

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
