// Dragnet [Ransomware]: dragnet-ransomware-2025-1513 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 95b58b4e-9691-512b-8ad7-2ff56591d8b1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
