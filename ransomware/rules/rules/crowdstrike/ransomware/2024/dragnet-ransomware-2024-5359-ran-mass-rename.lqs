// Dragnet [Ransomware]: dragnet-ransomware-2024-5359 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: d2dbfc56-9517-5719-9edd-51286e001465

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
