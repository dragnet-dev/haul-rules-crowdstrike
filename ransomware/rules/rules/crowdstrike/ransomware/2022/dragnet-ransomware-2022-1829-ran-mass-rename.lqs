// Dragnet [Ransomware]: dragnet-ransomware-2022-1829 — Mass File Rename (cuba)
// Status: deprecated | Level: high | ID: 6c743f92-d378-596d-a951-cb0875d5f5aa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
