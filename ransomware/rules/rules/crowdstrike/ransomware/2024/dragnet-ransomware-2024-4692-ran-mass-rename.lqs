// Dragnet [Ransomware]: dragnet-ransomware-2024-4692 — Mass File Rename (meow)
// Status: experimental | Level: high | ID: 3da77f67-4fc1-5b7a-a38e-02572739a034

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
