// Dragnet [Ransomware]: dragnet-ransomware-2022-0483 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 7c3e5874-a64b-522d-87dd-f5459aa43de0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
