// Dragnet [Ransomware]: dragnet-ransomware-2021-1412 — Mass File Rename (lv)
// Status: deprecated | Level: high | ID: e6d55cd7-9746-5e1c-904c-d6be0f2a8d61

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
