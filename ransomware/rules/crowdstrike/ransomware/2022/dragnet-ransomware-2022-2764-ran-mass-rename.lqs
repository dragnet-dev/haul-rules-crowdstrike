// Dragnet [Ransomware]: dragnet-ransomware-2022-2764 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: c7d88fa6-897f-55ee-9955-eeb686d6659f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
