// Dragnet [Ransomware]: dragnet-ransomware-2023-2530 — Mass File Rename (royal)
// Status: deprecated | Level: high | ID: 29acb3fc-d183-562c-abcc-21305d60e95f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
