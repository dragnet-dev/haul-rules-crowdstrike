// Dragnet [Ransomware]: dragnet-ransomware-2025-0656 — Mass File Rename (blacklock)
// Status: experimental | Level: high | ID: 26c229e8-0b52-51e9-9f8f-5f93b7ed0364

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
