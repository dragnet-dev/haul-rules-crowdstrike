// Dragnet [Ransomware]: dragnet-ransomware-2023-4213 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: b210007f-d8d5-56d5-9881-09c7bb92ac75

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
