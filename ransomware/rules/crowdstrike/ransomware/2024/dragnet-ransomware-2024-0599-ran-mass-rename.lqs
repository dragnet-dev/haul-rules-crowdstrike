// Dragnet [Ransomware]: dragnet-ransomware-2024-0599 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 8e6d03bb-8750-598d-b4b6-4ecf404c108b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
