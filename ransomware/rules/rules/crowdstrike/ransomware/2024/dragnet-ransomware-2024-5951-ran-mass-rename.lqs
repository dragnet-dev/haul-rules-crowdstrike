// Dragnet [Ransomware]: dragnet-ransomware-2024-5951 — Mass File Rename (ransomhouse)
// Status: experimental | Level: high | ID: 14d00a0b-9f9d-58ba-931b-12dda30f776e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
