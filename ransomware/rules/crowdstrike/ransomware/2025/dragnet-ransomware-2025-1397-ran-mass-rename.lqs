// Dragnet [Ransomware]: dragnet-ransomware-2025-1397 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 52211b18-e5e5-5123-8cd9-abc8f55b997d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
