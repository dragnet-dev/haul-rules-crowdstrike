// Dragnet [Ransomware]: dragnet-ransomware-2023-4104 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 1f7bc259-b155-50f4-a691-2d3f7b92a1f3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
