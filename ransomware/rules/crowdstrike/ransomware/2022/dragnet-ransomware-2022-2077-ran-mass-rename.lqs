// Dragnet [Ransomware]: dragnet-ransomware-2022-2077 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 5b8c8ed2-b091-58ac-802d-ed4725d9fd77

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
