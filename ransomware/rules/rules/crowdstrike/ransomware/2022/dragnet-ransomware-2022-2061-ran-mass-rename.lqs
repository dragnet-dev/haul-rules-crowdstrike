// Dragnet [Ransomware]: dragnet-ransomware-2022-2061 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: d7d37a14-76f8-50ff-8542-55c8bac9a55e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
