// Dragnet [Ransomware]: dragnet-ransomware-2022-0905 — Mass File Rename (blackbasta)
// Status: deprecated | Level: high | ID: b6799a8c-c207-5c92-a33c-fe38b4c3392b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
