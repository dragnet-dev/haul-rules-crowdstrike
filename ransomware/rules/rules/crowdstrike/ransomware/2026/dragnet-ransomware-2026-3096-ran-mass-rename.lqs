// Dragnet [Ransomware]: dragnet-ransomware-2026-3096 — Mass File Rename (securotrop)
// Status: stable | Level: high | ID: 3cffc1e3-cf20-5b52-b27e-1196db64886a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
