// Dragnet [Container]: dragnet-container-2024-0547 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: df83e9df-9e37-59f2-bc2d-b06beeebc1e5

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:7* OR ImageFileName = *ubuntu:14.10* OR ImageFileName = *ubuntu:15.04* OR ImageFileName = *ubuntu:15.10* OR ImageFileName = *ubuntu:16.04* OR ImageFileName = *ubuntu:16.04-ESM* OR ImageFileName = *ubuntu:16.10* OR ImageFileName = *ubuntu:17.04*)
| table([timestamp, ComputerName])
| limit(1000)
