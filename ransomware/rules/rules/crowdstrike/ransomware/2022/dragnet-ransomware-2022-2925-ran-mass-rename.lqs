// Dragnet [Ransomware]: dragnet-ransomware-2022-2925 — Mass File Rename (ragnarlocker)
// Status: deprecated | Level: high | ID: acbbed09-cd02-5906-8779-e2fbc6a01f88

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
