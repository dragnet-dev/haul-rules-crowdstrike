// Dragnet [Ransomware]: dragnet-ransomware-2026-0295 — Mass File Rename (nightspire)
// Status: deprecated | Level: high | ID: 1aa9285d-a96e-52e4-8177-dcb31235b3a5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
