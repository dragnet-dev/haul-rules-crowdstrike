// Dragnet [Container]: dragnet-container-2026-1972 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 1aa3588f-e330-5a5f-b276-efc50ab3b54b

#event_simpleName=*
| (ImageFileName = *debian:7* OR ImageFileName = *debian:8* OR ImageFileName = *ubuntu:14.04* OR ImageFileName = *ubuntu:15.10* OR ImageFileName = *ubuntu:16.04*)
| table([timestamp, ComputerName])
| limit(1000)
