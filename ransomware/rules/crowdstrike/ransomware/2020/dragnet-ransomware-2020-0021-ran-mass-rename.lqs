// Dragnet [Ransomware]: dragnet-ransomware-2020-0021 — Mass File Rename (maze)
// Status: deprecated | Level: high | ID: 85e846c7-8d43-508f-b9be-a8538c04d138

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
