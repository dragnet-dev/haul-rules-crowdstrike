// Dragnet [Ransomware]: dragnet-ransomware-2024-0996 — Mass File Rename (darkvault)
// Status: experimental | Level: high | ID: 82e2a47a-b54b-5c47-8b4c-4c095e2ebd3f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
