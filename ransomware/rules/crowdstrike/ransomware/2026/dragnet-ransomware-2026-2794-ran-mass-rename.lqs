// Dragnet [Ransomware]: dragnet-ransomware-2026-2794 — Mass File Rename (coinbasecartel)
// Status: stable | Level: high | ID: 6591e119-f11f-555e-b0f5-d388a7b97c8c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
