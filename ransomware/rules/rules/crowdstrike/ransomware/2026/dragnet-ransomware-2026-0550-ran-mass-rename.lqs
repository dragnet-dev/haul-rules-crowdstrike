// Dragnet [Ransomware]: dragnet-ransomware-2026-0550 — Mass File Rename (nightspire)
// Status: deprecated | Level: high | ID: e17bf256-ddf6-585f-8336-d1965100ff27

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
