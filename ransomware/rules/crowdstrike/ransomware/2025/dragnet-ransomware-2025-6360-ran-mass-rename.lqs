// Dragnet [Ransomware]: dragnet-ransomware-2025-6360 — Mass File Rename (rhysida)
// Status: experimental | Level: high | ID: fb8b167e-d6b0-5ff1-b072-de933b2cff73

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
