// Dragnet [Ransomware]: dragnet-ransomware-2023-5078 — Mass File Rename (noescape)
// Status: experimental | Level: high | ID: 95143377-72e7-5194-978d-a795ac23d2a8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
