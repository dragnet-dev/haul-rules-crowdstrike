// Dragnet [Ransomware]: dragnet-ransomware-2024-2605 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 4e59d30c-50ca-5d4b-8d7b-c83d7783707d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
