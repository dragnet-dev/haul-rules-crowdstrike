// Dragnet [Ransomware]: dragnet-ransomware-2024-0523 — Mass File Rename (chort)
// Status: experimental | Level: high | ID: 8a2e1abf-5218-546f-8d1b-387f65456355

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
