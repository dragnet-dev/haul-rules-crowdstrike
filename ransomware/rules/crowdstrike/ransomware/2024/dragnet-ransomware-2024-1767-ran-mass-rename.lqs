// Dragnet [Ransomware]: dragnet-ransomware-2024-1767 — Mass File Rename (SilentRansomGroup)
// Status: deprecated | Level: high | ID: f70ce617-dd56-536d-ad8f-fdf43626baf5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
