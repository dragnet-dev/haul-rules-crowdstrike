// Dragnet [Container]: dragnet-container-2024-0916 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 0780dab2-8652-5c65-b366-8484b3054f35

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:9*)
| table([timestamp, ComputerName])
| limit(1000)
