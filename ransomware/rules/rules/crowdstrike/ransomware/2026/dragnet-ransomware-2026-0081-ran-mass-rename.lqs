// Dragnet [Ransomware]: dragnet-ransomware-2026-0081 — Mass File Rename (shinyhunters)
// Status: deprecated | Level: high | ID: 055f8480-931a-57b4-bc56-15d3e213d63b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
