// Dragnet [Ransomware]: dragnet-ransomware-2021-1498 — Mass File Rename (revil)
// Status: deprecated | Level: high | ID: 43cddb09-5dbe-52f9-8d4c-38371b050dca

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
