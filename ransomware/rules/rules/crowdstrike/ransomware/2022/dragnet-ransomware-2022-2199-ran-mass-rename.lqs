// Dragnet [Ransomware]: dragnet-ransomware-2022-2199 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 2b69343e-ff2e-50bf-b1a1-58a41849c7cd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
