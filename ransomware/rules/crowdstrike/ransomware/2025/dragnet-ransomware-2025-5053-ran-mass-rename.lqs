// Dragnet [Ransomware]: dragnet-ransomware-2025-5053 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: e8ef2e72-3859-552c-9c0d-639dc7f5dd28

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
