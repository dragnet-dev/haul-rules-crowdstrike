// Dragnet [Ransomware]: dragnet-ransomware-2025-0702 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 1429a2b0-ad80-591b-ab20-ff26375bb94a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
