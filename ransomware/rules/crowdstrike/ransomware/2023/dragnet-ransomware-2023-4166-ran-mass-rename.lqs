// Dragnet [Ransomware]: dragnet-ransomware-2023-4166 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: c08ad55e-cec7-5149-adbd-97d8058abab2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
