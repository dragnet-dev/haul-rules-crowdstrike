| (ImageFileName = *alpine:3.3* OR ImageFileName = *alpine:3.4* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *ubuntu:16.04* OR ImageFileName = *ubuntu:16.04-ESM* OR ImageFileName = *ubuntu:16.10*)
| table([timestamp, ComputerName])
| limit(1000)
