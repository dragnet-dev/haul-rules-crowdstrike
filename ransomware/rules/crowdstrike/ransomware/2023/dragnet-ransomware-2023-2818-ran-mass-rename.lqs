// Dragnet [Ransomware]: dragnet-ransomware-2023-2818 — Mass File Rename (malas)
// Status: experimental | Level: high | ID: 6f172508-1edf-5084-b9eb-fac40daba855

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
