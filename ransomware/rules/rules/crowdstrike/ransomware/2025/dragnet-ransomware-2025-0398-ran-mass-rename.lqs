// Dragnet [Ransomware]: dragnet-ransomware-2025-0398 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 6e2ed793-34f3-551b-8261-93140763fffa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
