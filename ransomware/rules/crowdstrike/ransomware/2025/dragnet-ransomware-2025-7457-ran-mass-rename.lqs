// Dragnet [Ransomware]: dragnet-ransomware-2025-7457 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: afb48ab4-965c-5cde-b195-3310784fd8c6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
