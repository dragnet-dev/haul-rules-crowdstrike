// Dragnet [Ransomware]: dragnet-ransomware-2025-3328 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 82d6c67e-5af3-51d4-a1fa-9edc399efa86

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
