// Dragnet [Ransomware]: dragnet-ransomware-2024-0399 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 9d398a40-68bd-52cf-81b2-b2993c1e49d9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
