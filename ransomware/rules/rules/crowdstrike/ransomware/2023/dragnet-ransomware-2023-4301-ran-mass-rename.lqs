// Dragnet [Ransomware]: dragnet-ransomware-2023-4301 — Mass File Rename (metaencryptor)
// Status: experimental | Level: high | ID: 791a7d9a-e334-589f-adc9-8fda45500052

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
