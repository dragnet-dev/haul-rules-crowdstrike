// Dragnet [Ransomware]: dragnet-ransomware-2024-1022 — Mass File Rename (kraken)
// Status: experimental | Level: high | ID: e537983d-340a-5931-81bf-a67b89431960

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
