// Dragnet [Ransomware]: dragnet-ransomware-2025-6044 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 8b8c6ebc-219a-5cc3-aaf0-9f42e37bac48

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
