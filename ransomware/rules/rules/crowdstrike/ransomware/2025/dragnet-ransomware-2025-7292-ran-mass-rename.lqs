// Dragnet [Ransomware]: dragnet-ransomware-2025-7292 — Mass File Rename (frag)
// Status: deprecated | Level: high | ID: 4df2e29a-933c-511d-af6e-bf73abb643ba

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
