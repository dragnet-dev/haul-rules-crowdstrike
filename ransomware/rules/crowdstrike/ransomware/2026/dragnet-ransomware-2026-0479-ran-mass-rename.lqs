// Dragnet [Ransomware]: dragnet-ransomware-2026-0479 — Mass File Rename (stormous)
// Status: deprecated | Level: high | ID: 6f78dc22-5513-570a-8f9b-eb6bf75216ae

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
