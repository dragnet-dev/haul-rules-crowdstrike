// Dragnet [Ransomware]: dragnet-ransomware-2025-4031 — Mass File Rename (crypto24)
// Status: deprecated | Level: high | ID: 188b5946-14d0-5743-bc66-69267b62b33d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
