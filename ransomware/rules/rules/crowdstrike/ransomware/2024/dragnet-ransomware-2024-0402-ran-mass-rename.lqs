// Dragnet [Ransomware]: dragnet-ransomware-2024-0402 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 9126152b-9a4f-503b-b4d0-549894089407

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
