// Dragnet [Ransomware]: dragnet-ransomware-2021-0483 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: 78d2b813-19c9-5435-98e2-af9c7736b669

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
