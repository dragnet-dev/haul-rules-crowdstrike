// Dragnet [Ransomware]: dragnet-ransomware-2022-2153 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: a86d4b76-6b75-5378-b9b1-1ed4136f99f8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
