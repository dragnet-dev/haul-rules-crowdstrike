// Dragnet [Ransomware]: dragnet-ransomware-2026-3410 — Mass File Rename (shinyhunters)
// Status: deprecated | Level: high | ID: dca655e3-d7e5-5fa0-ad08-7bf85e2d9014

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
