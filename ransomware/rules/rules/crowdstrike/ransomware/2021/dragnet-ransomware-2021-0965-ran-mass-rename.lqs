// Dragnet [Ransomware]: dragnet-ransomware-2021-0965 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: d80a50d8-4a1a-57d2-9d10-d7f17d3fcbff

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
