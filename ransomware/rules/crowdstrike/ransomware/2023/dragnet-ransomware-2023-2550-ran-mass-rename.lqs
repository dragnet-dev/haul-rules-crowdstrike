// Dragnet [Ransomware]: dragnet-ransomware-2023-2550 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: af2cedbf-a248-5726-aa79-c1b318a366de

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
