// Dragnet [Ransomware]: dragnet-ransomware-2024-2235 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 08fd7d31-1553-5e81-9e32-1936ef85e1db

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
