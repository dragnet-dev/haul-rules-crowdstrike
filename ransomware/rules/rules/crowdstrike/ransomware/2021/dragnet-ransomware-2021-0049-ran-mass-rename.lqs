// Dragnet [Ransomware]: dragnet-ransomware-2021-0049 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 1e416f44-2f9d-52f4-8053-4ff2fcbbee30

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
