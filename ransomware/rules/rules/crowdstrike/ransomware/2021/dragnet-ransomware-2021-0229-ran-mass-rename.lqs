// Dragnet [Ransomware]: dragnet-ransomware-2021-0229 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: ad31222c-7beb-510e-94f1-c12e8362820d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
