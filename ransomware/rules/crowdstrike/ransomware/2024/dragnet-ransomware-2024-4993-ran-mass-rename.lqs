// Dragnet [Ransomware]: dragnet-ransomware-2024-4993 — Mass File Rename (blackbyte)
// Status: deprecated | Level: high | ID: 22c8efa5-f360-5b64-8548-a9a0c32591a1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
