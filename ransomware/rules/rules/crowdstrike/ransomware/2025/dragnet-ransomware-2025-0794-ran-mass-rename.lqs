// Dragnet [Ransomware]: dragnet-ransomware-2025-0794 — Mass File Rename (morpheus)
// Status: deprecated | Level: high | ID: 8413101d-c965-5736-8ae5-805a846a483e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
