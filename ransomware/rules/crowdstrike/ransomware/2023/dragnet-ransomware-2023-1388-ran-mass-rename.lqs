// Dragnet [Ransomware]: dragnet-ransomware-2023-1388 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 4975685d-8d0a-5e52-a6fb-9831262fb94e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
