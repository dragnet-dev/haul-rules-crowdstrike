// Dragnet [Ransomware]: dragnet-ransomware-2022-2974 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 59b91a22-3834-53da-a902-c48ab778f467

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
