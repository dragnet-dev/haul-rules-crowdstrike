// Dragnet [Ransomware]: dragnet-ransomware-2024-4667 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 3459df08-e1de-58d3-a0fe-7e00aca54739

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
