// Dragnet [Container]: dragnet-container-2024-1149 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: b68d6272-d10e-56f9-82ad-dd3e3d3a07ae

#event_simpleName=*
| (ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:8* OR ImageFileName = *debian:9*)
| table([timestamp, ComputerName])
| limit(1000)
