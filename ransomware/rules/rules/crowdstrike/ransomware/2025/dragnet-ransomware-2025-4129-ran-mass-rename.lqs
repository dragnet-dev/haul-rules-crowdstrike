// Dragnet [Ransomware]: dragnet-ransomware-2025-4129 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 58570bf4-441b-556d-a7ad-bb4ce91b4765

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
