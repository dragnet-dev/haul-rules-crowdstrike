// Dragnet [Ransomware]: dragnet-ransomware-2024-3048 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 757d560e-0f51-5f4d-8379-7ec93ba8005d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
