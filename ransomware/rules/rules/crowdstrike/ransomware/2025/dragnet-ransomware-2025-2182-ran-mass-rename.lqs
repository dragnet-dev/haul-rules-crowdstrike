// Dragnet [Ransomware]: dragnet-ransomware-2025-2182 — Mass File Rename (abyss)
// Status: deprecated | Level: high | ID: 83a4f580-d328-5902-b64d-dfa31a755609

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
