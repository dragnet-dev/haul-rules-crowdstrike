// Dragnet [Ransomware]: dragnet-ransomware-2026-2071 — Mass File Rename (incransom)
// Status: stable | Level: high | ID: 0396da0b-ee38-5e40-bb30-b4b271a4f0f9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
