// Dragnet [Ransomware]: dragnet-ransomware-2022-1121 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 9d1b7ebd-d938-55dc-8e74-9de0a5fcc9c6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
