// Dragnet [Ransomware]: dragnet-ransomware-2023-1621 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 16e07f9c-49bb-5522-9b34-814b4934214e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
