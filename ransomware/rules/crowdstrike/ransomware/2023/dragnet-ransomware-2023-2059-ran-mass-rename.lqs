// Dragnet [Ransomware]: dragnet-ransomware-2023-2059 — Mass File Rename (knight)
// Status: experimental | Level: high | ID: c44ef3b9-813d-5d53-b672-5aff6e6925df

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
