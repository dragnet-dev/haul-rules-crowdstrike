// Dragnet [Ransomware]: dragnet-ransomware-2025-7835 — Mass File Rename (killsec)
// Status: deprecated | Level: high | ID: 39808b43-fa63-5652-a2c3-173893b193fb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
