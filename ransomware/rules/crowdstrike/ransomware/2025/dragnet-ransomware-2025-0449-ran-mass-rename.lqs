// Dragnet [Ransomware]: dragnet-ransomware-2025-0449 — Mass File Rename (pear)
// Status: experimental | Level: high | ID: 829314c9-d945-52b6-91a7-6fac84a04082

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
