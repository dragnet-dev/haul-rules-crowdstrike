// Dragnet [Ransomware]: dragnet-ransomware-2021-1095 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: e92fa58a-9e20-5392-8859-614261bbde90

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
