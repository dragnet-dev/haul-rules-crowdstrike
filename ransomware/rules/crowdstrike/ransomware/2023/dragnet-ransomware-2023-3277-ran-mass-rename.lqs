// Dragnet [Ransomware]: dragnet-ransomware-2023-3277 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 39799ab4-6461-5bd0-a3d1-b0c57aaadb25

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
