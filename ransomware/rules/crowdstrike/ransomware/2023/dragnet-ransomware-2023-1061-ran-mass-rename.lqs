// Dragnet [Ransomware]: dragnet-ransomware-2023-1061 — Mass File Rename (royal)
// Status: deprecated | Level: high | ID: 2d59a5f2-42fb-5100-a2ab-a9f829c8b322

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
