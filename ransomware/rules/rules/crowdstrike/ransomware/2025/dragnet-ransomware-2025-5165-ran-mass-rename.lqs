// Dragnet [Ransomware]: dragnet-ransomware-2025-5165 — Mass File Rename (sinobi)
// Status: experimental | Level: high | ID: 23f357b6-d530-586c-bf10-2ccad4762c9d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
