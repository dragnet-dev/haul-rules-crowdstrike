// Dragnet [Container]: dragnet-container-2024-1410 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: d5605f2f-c7fc-56c2-a862-1e90281f0f29

#event_simpleName=*
| (ImageFileName = *chainguard:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:8* OR ImageFileName = *debian:9* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:16.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
