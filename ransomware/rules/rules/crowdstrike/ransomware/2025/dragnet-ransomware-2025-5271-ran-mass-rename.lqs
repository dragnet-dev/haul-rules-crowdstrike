// Dragnet [Ransomware]: dragnet-ransomware-2025-5271 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 096c28fa-226d-5965-a19a-5b00059e519e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
