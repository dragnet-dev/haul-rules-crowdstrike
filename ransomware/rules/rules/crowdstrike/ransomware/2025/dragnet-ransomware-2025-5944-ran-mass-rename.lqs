// Dragnet [Ransomware]: dragnet-ransomware-2025-5944 — Mass File Rename (blacknevas)
// Status: experimental | Level: high | ID: 25252c5f-82b3-5b10-8dde-fa11e35a0bb8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
