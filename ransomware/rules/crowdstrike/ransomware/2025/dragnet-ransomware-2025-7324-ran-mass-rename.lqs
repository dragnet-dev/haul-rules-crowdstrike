// Dragnet [Ransomware]: dragnet-ransomware-2025-7324 — Mass File Rename (stormous)
// Status: deprecated | Level: high | ID: 030602d7-521a-5fa7-b6e0-9c2e07d07b33

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
