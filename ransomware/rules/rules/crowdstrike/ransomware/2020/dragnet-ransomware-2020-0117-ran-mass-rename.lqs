// Dragnet [Ransomware]: dragnet-ransomware-2020-0117 — Mass File Rename (maze)
// Status: deprecated | Level: high | ID: d3eeede6-3112-5cfb-95c2-b9864f9cb443

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
