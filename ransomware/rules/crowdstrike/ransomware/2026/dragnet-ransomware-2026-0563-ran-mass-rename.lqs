// Dragnet [Ransomware]: dragnet-ransomware-2026-0563 — Mass File Rename (spacebears)
// Status: test | Level: high | ID: 767961df-4d82-5fdc-8a6f-9fb7d3357ce8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
