// Dragnet [Ransomware]: dragnet-ransomware-2025-1767 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: 1536167b-ab01-5a28-b7ab-0bdc245a253c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
