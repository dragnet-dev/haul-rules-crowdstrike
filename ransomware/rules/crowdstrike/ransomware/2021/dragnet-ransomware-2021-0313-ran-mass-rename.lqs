// Dragnet [Ransomware]: dragnet-ransomware-2021-0313 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 6f5402bc-258f-5373-9482-41bd0e73d6ff

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
