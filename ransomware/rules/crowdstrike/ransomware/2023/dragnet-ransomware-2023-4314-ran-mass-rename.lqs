// Dragnet [Ransomware]: dragnet-ransomware-2023-4314 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 8a7ee76e-4a1b-57bf-83b1-fe29152b4bc6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
