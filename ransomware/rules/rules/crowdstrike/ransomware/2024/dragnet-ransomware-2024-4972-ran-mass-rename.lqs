// Dragnet [Ransomware]: dragnet-ransomware-2024-4972 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: 212fc994-e4d1-5caf-90b0-5a324de40f7e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
