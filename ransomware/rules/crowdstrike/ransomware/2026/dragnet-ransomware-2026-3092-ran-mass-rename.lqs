// Dragnet [Ransomware]: dragnet-ransomware-2026-3092 — Mass File Rename (securotrop)
// Status: test | Level: high | ID: 8bc4815b-77c5-573f-ac67-3a7b654a1d1d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
