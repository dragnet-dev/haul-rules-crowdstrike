// Dragnet [Ransomware]: dragnet-ransomware-2024-4598 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: ccb96529-c368-5b9f-ae1f-48e39ee4d0cc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
