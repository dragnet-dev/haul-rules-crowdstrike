// Dragnet [Ransomware]: dragnet-ransomware-2023-1290 — Mass File Rename (noescape)
// Status: experimental | Level: high | ID: 5ffda5e4-1e6a-5053-b2d6-116879084b74

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
