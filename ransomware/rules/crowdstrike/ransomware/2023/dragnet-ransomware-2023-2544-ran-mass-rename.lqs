// Dragnet [Ransomware]: dragnet-ransomware-2023-2544 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: b2d96d8b-fce9-5584-9573-affbea78938a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
