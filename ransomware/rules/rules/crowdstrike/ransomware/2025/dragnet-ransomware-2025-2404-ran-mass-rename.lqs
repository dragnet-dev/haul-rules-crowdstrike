// Dragnet [Ransomware]: dragnet-ransomware-2025-2404 — Mass File Rename (thegentlemen)
// Status: experimental | Level: high | ID: b72867e0-e7f5-54be-a968-b0e5893edb59

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
