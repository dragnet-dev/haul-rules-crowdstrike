// Dragnet [Ransomware]: dragnet-ransomware-2024-2022 — Mass File Rename (blacksuit)
// Status: experimental | Level: high | ID: 50019613-ccbb-54c4-ab34-b29b343a05e2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
