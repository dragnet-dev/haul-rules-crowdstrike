// Dragnet [Ransomware]: dragnet-ransomware-2025-7652 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: a9cdf21a-2d35-5209-b972-cbf008b28900

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
