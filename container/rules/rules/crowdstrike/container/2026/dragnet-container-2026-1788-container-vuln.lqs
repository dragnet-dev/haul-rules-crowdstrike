// Dragnet [Container]: dragnet-container-2026-1788 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 6cd9564a-68bd-5769-99ba-999175ecc412

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
