// Dragnet [Ransomware]: dragnet-ransomware-2025-2185 — Mass File Rename (warlock)
// Status: deprecated | Level: high | ID: aeedc964-cf9b-5334-a2a5-a4ded058ab66

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
