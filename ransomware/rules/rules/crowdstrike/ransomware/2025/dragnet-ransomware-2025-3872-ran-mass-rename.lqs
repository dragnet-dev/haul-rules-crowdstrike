// Dragnet [Ransomware]: dragnet-ransomware-2025-3872 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 5a2e2872-43b3-5b1f-9ae7-851b8d0c5726

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
