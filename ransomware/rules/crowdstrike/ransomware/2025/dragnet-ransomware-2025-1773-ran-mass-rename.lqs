// Dragnet [Ransomware]: dragnet-ransomware-2025-1773 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 54ec74f2-602b-5a03-8895-177465875a30

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
