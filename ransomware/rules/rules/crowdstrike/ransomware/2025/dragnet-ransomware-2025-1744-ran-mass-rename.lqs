// Dragnet [Ransomware]: dragnet-ransomware-2025-1744 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: aeff909b-9a4e-57e2-9dbb-f9f7a26bde27

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
