// Dragnet [Ransomware]: dragnet-ransomware-2023-1543 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 777bc9af-423f-587a-8147-01af146c293f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
