// Dragnet [Ransomware]: dragnet-ransomware-2023-3399 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: fb13133b-3124-59b5-bc2b-9ad903f8bdcd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
