// Dragnet [Ransomware]: dragnet-ransomware-2025-5822 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 451f82aa-3c73-58e0-9bc9-8060e12ddf1a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
