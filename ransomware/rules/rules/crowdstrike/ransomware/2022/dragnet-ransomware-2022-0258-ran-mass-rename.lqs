// Dragnet [Ransomware]: dragnet-ransomware-2022-0258 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 6c178862-5d2f-5389-ab27-71bd810946b5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
