// Dragnet [Ransomware]: dragnet-ransomware-2023-4324 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: b6692868-d433-50a3-a710-d1529ca12e7c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
