// Dragnet [Ransomware]: dragnet-ransomware-2025-5534 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: 15c29a63-e945-526b-9d90-8f890cd7ca11

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
