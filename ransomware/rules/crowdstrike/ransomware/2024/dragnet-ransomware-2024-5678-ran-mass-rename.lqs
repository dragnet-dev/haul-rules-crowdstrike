// Dragnet [Ransomware]: dragnet-ransomware-2024-5678 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: dcbd8b46-990d-588f-8552-e7821798e53a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
