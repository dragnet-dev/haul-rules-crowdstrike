// Dragnet [Ransomware]: dragnet-ransomware-2024-5702 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 000f311f-a8a6-5109-860a-ba24acf0c65b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
