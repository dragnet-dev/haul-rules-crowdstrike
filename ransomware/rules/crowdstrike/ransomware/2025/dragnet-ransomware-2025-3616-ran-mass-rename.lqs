// Dragnet [Ransomware]: dragnet-ransomware-2025-3616 — Mass File Rename (devman)
// Status: experimental | Level: high | ID: 4875b528-b7ab-578a-bfe6-cd881cf85e3c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
