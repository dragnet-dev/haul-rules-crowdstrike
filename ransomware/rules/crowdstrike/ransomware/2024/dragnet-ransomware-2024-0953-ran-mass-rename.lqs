// Dragnet [Ransomware]: dragnet-ransomware-2024-0953 — Mass File Rename (meow)
// Status: experimental | Level: high | ID: 7e06b367-f02b-569a-bbe3-9254940fd0fd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
