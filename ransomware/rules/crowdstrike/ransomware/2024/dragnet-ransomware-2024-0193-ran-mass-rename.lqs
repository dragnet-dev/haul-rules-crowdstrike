// Dragnet [Ransomware]: dragnet-ransomware-2024-0193 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: a00d7f1d-6e06-57fe-ac74-bf73ca87d1f5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
