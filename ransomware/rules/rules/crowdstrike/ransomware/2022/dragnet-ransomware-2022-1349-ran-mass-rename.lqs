// Dragnet [Ransomware]: dragnet-ransomware-2022-1349 — Mass File Rename (royal)
// Status: deprecated | Level: high | ID: d4fefdb6-57b2-5b95-92a4-528cc40e3a64

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
