// Dragnet [Ransomware]: dragnet-ransomware-2024-4885 — Mass File Rename (meow)
// Status: experimental | Level: high | ID: 0a6012e5-d365-5541-b28c-be58ea0ab456

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
