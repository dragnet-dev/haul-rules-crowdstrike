// Dragnet [Ransomware]: dragnet-ransomware-2026-2008 — Mass File Rename (lockbit5)
// Status: test | Level: high | ID: 089415db-7a21-5c35-b25d-a505349e3785

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
