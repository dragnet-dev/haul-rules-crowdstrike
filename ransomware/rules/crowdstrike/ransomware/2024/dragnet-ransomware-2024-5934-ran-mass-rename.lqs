// Dragnet [Ransomware]: dragnet-ransomware-2024-5934 — Mass File Rename (raworld)
// Status: experimental | Level: high | ID: be808f74-7481-5de6-af11-c1e43790ee8e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
