// Dragnet [Ransomware]: dragnet-ransomware-2024-4643 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 7834506c-b24b-57bd-a9cd-10c330fc2f6d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
