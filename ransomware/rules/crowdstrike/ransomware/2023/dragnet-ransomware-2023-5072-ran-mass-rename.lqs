// Dragnet [Ransomware]: dragnet-ransomware-2023-5072 — Mass File Rename (werewolves)
// Status: experimental | Level: high | ID: 7e989018-1c52-5704-855a-598818aa4122

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
