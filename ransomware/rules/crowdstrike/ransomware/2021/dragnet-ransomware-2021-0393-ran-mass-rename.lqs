// Dragnet [Ransomware]: dragnet-ransomware-2021-0393 — Mass File Rename (revil)
// Status: deprecated | Level: high | ID: 42db80ff-b3e9-5bad-8c09-a3cb29726154

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
