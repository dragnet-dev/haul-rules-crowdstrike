// Dragnet [Ransomware]: dragnet-ransomware-2025-2064 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: aef4428c-12cd-552c-b803-ce1986d8958b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
