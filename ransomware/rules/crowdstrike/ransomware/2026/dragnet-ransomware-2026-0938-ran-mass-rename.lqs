// Dragnet [Ransomware]: dragnet-ransomware-2026-0938 — Mass File Rename (payload)
// Status: stable | Level: high | ID: 873374b9-68d6-54b6-8425-68c553404d4a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
