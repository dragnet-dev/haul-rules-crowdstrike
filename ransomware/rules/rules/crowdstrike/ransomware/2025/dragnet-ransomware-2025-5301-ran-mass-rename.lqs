// Dragnet [Ransomware]: dragnet-ransomware-2025-5301 — Mass File Rename (flocker)
// Status: experimental | Level: high | ID: 9964ad89-969e-5395-b1c8-d220281f3362

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
