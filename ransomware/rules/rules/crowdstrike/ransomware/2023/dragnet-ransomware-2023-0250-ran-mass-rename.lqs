// Dragnet [Ransomware]: dragnet-ransomware-2023-0250 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: d15de631-684e-5ca6-8611-d27904343ed0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
