// Dragnet [Ransomware]: dragnet-ransomware-2025-2877 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: d8daf21f-75e4-5dad-9899-8a9faa7b94d7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
