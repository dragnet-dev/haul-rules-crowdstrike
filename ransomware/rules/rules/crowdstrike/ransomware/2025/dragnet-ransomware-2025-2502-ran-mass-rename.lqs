// Dragnet [Ransomware]: dragnet-ransomware-2025-2502 — Mass File Rename (lockbit5)
// Status: experimental | Level: high | ID: e7253951-4732-5050-b3ab-6d3baf7a8371

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
