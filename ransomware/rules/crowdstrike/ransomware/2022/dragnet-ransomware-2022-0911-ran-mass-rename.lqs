// Dragnet [Ransomware]: dragnet-ransomware-2022-0911 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 1a54d9de-2050-587b-bfbb-bef51e510e21

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
