// Dragnet [Ransomware]: dragnet-ransomware-2026-0747 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 8f5e84b1-abf2-5e56-8ce2-9734cdba6432

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
