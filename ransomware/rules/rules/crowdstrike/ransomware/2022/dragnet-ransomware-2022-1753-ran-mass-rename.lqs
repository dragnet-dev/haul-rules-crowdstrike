// Dragnet [Ransomware]: dragnet-ransomware-2022-1753 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: ba324b8a-e4c0-5b3e-b4ba-6e5fb8cbcece

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
