// Dragnet [Ransomware]: dragnet-ransomware-2025-7862 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: e051fd3e-408e-5a49-ad23-d02f21f9cd1a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
