// Dragnet [Ransomware]: dragnet-ransomware-2025-7275 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 4db74dd6-bf6c-5f9a-96f1-b38b5de156a6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
