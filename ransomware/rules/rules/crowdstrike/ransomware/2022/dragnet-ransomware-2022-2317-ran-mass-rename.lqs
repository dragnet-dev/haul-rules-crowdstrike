// Dragnet [Ransomware]: dragnet-ransomware-2022-2317 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 06734a57-1a46-583c-b69b-ebaf43ff46a5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
