// Dragnet [Ransomware]: dragnet-ransomware-2022-0985 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 87be92f8-a71c-5e37-94e6-326d7883a830

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
