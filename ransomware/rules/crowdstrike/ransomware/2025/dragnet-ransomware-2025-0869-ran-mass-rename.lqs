// Dragnet [Ransomware]: dragnet-ransomware-2025-0869 — Mass File Rename (SilentRansomGroup)
// Status: deprecated | Level: high | ID: ac53380e-f4aa-5b0f-85dc-809dbb5272b4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
