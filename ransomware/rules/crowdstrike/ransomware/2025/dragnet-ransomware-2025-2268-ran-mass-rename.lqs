// Dragnet [Ransomware]: dragnet-ransomware-2025-2268 — Mass File Rename (arcusmedia)
// Status: experimental | Level: high | ID: 6a2f524a-abeb-5158-99bc-8724b0b01fe7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
