// Dragnet [Ransomware]: dragnet-ransomware-2023-4245 — Mass File Rename (abyss)
// Status: deprecated | Level: high | ID: 91df2411-497f-55f5-880a-d2d4e279159d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
