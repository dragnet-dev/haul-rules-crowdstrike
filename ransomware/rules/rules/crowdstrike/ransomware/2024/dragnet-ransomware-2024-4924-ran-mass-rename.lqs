// Dragnet [Ransomware]: dragnet-ransomware-2024-4924 — Mass File Rename (arcusmedia)
// Status: experimental | Level: high | ID: 1a7aae65-10cf-581e-a101-9d425f252695

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
