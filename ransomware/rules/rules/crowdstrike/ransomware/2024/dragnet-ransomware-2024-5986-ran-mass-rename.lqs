// Dragnet [Ransomware]: dragnet-ransomware-2024-5986 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: f78fdc0e-43d6-543b-8a62-ed140030dad7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
