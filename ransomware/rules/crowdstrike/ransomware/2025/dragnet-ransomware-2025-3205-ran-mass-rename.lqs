// Dragnet [Ransomware]: dragnet-ransomware-2025-3205 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 747d1dbe-2fe3-5e8a-a75c-627c6b37913f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
