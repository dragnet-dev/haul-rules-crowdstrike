// Dragnet [Ransomware]: dragnet-ransomware-2023-1006 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 3a6de578-ac89-555b-a485-9896ae49a194

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
