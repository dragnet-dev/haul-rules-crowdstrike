// Dragnet [Ransomware]: dragnet-ransomware-2024-2283 — Mass File Rename (blacklock)
// Status: experimental | Level: high | ID: 7c2af9ae-c1db-50d5-8996-17b6e289ae5c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
