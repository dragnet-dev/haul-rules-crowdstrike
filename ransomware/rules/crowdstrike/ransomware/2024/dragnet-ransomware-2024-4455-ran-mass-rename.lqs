// Dragnet [Ransomware]: dragnet-ransomware-2024-4455 — Mass File Rename (play)
// Status: experimental | Level: high | ID: b4c920c9-5317-52a2-8ec9-c2b41432e9ab

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
