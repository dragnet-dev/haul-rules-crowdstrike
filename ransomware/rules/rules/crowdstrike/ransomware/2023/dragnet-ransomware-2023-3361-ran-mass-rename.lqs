// Dragnet [Ransomware]: dragnet-ransomware-2023-3361 — Mass File Rename (raworld)
// Status: experimental | Level: high | ID: 0ff64e75-ee0e-5258-86a3-5cf49f0e0083

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
