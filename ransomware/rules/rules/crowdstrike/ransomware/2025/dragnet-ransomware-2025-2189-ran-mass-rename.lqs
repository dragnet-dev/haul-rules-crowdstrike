// Dragnet [Ransomware]: dragnet-ransomware-2025-2189 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 3dc2c506-36ba-5535-83a1-e23a8abcfe59

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
