// Dragnet [Ransomware]: dragnet-ransomware-2024-1996 — Mass File Rename (rhysida)
// Status: experimental | Level: high | ID: b10b3f5f-7022-5559-885e-d93809d37141

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
