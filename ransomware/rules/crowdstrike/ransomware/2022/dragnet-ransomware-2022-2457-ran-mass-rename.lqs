// Dragnet [Ransomware]: dragnet-ransomware-2022-2457 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: b2d6d469-7a1b-5740-844f-6507bc3595c6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
