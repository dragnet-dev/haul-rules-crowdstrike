// Dragnet [Ransomware]: dragnet-ransomware-2023-4390 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 5470fb7a-6340-5f15-87cb-e0e94f97f9f6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
