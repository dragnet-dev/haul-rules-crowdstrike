// Dragnet [Ransomware]: dragnet-ransomware-2024-1990 — Mass File Rename (spacebears)
// Status: experimental | Level: high | ID: 1ceda761-2327-5215-bc67-6f437f7d8ab5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
