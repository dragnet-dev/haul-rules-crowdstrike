// Dragnet [Ransomware]: dragnet-ransomware-2023-4153 — Mass File Rename (raworld)
// Status: experimental | Level: high | ID: 1406b80a-2521-5727-9d62-1ec97fd34c34

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
