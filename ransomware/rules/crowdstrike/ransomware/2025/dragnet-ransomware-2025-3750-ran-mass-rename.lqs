// Dragnet [Ransomware]: dragnet-ransomware-2025-3750 — Mass File Rename (crypto24)
// Status: deprecated | Level: high | ID: 6d7aa2a6-dedf-5190-89b1-8b3a5fee66b0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
