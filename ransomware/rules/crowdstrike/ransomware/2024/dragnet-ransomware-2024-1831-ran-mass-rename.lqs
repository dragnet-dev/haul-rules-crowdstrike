// Dragnet [Ransomware]: dragnet-ransomware-2024-1831 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 41f20c3f-18c2-5e4d-81e8-e4fe97da3b8a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
