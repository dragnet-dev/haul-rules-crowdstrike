// Dragnet [Ransomware]: dragnet-ransomware-2024-4474 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: f7c96dab-3b70-5adc-a5d3-248cc0260299

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
