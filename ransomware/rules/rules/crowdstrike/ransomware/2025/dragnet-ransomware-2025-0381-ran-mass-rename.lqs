// Dragnet [Ransomware]: dragnet-ransomware-2025-0381 — Mass File Rename (worldleaks)
// Status: experimental | Level: high | ID: 61932cfb-65bc-5669-97d7-85da3a2d016d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
