// Dragnet [Ransomware]: dragnet-ransomware-2023-2245 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: a474bcc1-9f82-5f92-b0ae-3e0ba54d29dd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
