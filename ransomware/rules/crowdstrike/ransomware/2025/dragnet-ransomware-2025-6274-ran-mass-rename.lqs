// Dragnet [Ransomware]: dragnet-ransomware-2025-6274 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 3dfed493-cc75-50c7-a131-31a396128e36

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
