// Dragnet [Ransomware]: dragnet-ransomware-2025-2850 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 1354e6c4-5f23-5132-b363-8961f135bdce

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
