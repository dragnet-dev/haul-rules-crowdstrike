// Dragnet [Ransomware]: dragnet-ransomware-2025-2029 — Mass File Rename (ransomhouse)
// Status: experimental | Level: high | ID: 86b7d457-332c-5ef2-86dc-d8e66ee7d344

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
