// Dragnet [Ransomware]: dragnet-ransomware-2023-0050 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 3c9ebad0-dcd6-511d-81aa-b23fb304fae3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
