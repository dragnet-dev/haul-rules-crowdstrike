// Dragnet [Ransomware]: dragnet-ransomware-2025-2851 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 60ec0a7c-f55d-542b-9695-dfdb9be43049

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
