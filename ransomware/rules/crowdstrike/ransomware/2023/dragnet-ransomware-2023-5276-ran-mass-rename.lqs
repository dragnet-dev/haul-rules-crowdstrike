// Dragnet [Ransomware]: dragnet-ransomware-2023-5276 — Mass File Rename (underground)
// Status: experimental | Level: high | ID: ddf76f43-637c-5f1d-84b0-34dfc34f9fac

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
