// Dragnet [Ransomware]: dragnet-ransomware-2021-0895 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: c18f3da8-90f4-56e5-8f9e-3a9d022aaf92

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
