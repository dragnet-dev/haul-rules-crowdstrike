// Dragnet [Container]: dragnet-container-2026-2396 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 0ac0ce8f-290c-5965-8479-beda1c3adda8

#event_simpleName=*
| (ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6*)
| table([timestamp, ComputerName])
| limit(1000)
