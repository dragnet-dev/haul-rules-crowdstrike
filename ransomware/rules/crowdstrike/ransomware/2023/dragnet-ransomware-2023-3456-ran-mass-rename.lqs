// Dragnet [Ransomware]: dragnet-ransomware-2023-3456 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 9ee26d03-9078-5059-a5f7-107ee608f284

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
