// Dragnet [Ransomware]: dragnet-ransomware-2024-5294 — Mass File Rename (dragonforce)
// Status: deprecated | Level: high | ID: 9c0d25ae-c7d8-5949-b20e-7768aad2fc68

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
