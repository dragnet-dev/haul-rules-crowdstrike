// Dragnet [Ransomware]: dragnet-ransomware-2020-0084 — Mass File Rename (netwalker)
// Status: deprecated | Level: high | ID: aca2b0c2-bc23-5548-beb6-cf19978981bd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
