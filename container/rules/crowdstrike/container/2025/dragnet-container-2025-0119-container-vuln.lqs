// Dragnet [Container]: dragnet-container-2025-0119 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 493f46d5-40b0-5bdd-8317-fea41968d940

#event_simpleName=*
| (ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *ubuntu:22.04*)
| table([timestamp, ComputerName])
| limit(1000)
