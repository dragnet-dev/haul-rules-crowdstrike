// Dragnet [Ransomware]: dragnet-ransomware-2022-1710 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 12c4a447-7a8a-51eb-8821-a223d6e3ee93

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
