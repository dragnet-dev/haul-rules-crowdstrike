// Dragnet [Ransomware]: dragnet-ransomware-2021-1159 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: bcb80e72-1042-5033-9179-8e837d17d5a4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
