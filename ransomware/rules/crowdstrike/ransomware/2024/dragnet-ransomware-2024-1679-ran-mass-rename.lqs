// Dragnet [Ransomware]: dragnet-ransomware-2024-1679 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 0769651c-eda1-53bc-b11c-cb1dcc5dedfe

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
