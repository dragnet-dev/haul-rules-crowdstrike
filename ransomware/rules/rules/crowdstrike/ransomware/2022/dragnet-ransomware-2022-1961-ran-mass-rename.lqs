// Dragnet [Ransomware]: dragnet-ransomware-2022-1961 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 01c998fd-fbfa-5a62-9d95-01adb5bb2869

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
