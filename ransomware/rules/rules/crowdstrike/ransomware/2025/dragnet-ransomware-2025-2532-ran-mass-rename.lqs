// Dragnet [Ransomware]: dragnet-ransomware-2025-2532 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 9393a5af-74da-53da-be07-0ed45d9a8aef

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
