// Dragnet [Ransomware]: dragnet-ransomware-2024-4015 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: f456f0b5-25a9-5fa6-93a7-0ac36557d1cd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
