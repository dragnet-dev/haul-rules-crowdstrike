// Dragnet [Container]: dragnet-container-2025-0534 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: ab7f0122-a322-5a83-a79a-6db81e6e494e

#event_simpleName=*
| (ImageFileName = *ubuntu:14.04* OR ImageFileName = *ubuntu:16.04* OR ImageFileName = *ubuntu:16.04-ESM* OR ImageFileName = *ubuntu:17.04* OR ImageFileName = *ubuntu:17.10*)
| table([timestamp, ComputerName])
| limit(1000)
