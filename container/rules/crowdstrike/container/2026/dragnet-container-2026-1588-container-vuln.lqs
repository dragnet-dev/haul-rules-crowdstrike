// Dragnet [Container]: dragnet-container-2026-1588 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: ce59cce2-02cf-54d7-bcae-b8691c425412

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:5*)
| table([timestamp, ComputerName])
| limit(1000)
