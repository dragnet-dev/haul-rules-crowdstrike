// Dragnet [Ransomware]: dragnet-ransomware-2023-3071 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 37eb9d88-2919-5d03-a8c5-ff05500c6bd0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
