// Dragnet [Ransomware]: dragnet-ransomware-2021-1666 — Mass File Rename (everest)
// Status: deprecated | Level: high | ID: 844ae9be-aa5d-5391-bae5-b58e0672cc8c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
