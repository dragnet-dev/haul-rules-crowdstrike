// Dragnet [Ransomware]: dragnet-ransomware-2021-1197 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 41a65355-e5ad-51e3-8fb2-1838d102b1f5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
