// Dragnet [Ransomware]: dragnet-ransomware-2023-1042 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 68eb2551-1291-5b94-a5b0-70996a8cc459

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
