// Dragnet [Ransomware]: dragnet-ransomware-2025-2195 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 8d4854e7-60ea-5da6-ab4d-a912b06ad24c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
