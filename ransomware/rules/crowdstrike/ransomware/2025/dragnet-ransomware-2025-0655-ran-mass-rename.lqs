// Dragnet [Ransomware]: dragnet-ransomware-2025-0655 — Mass File Rename (blacklock)
// Status: experimental | Level: high | ID: 83cdf780-d921-5e45-803e-73c156f0ac57

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
