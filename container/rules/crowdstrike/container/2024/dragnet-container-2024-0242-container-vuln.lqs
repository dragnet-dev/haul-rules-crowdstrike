// Dragnet [Container]: dragnet-container-2024-0242 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 946fe707-771d-5d29-b210-f7f538d55e27

#event_simpleName=*
| (ImageFileName = *debian:12* OR ImageFileName = *debian:14* OR ImageFileName = *ubuntu:18.04-ESM* OR ImageFileName = *ubuntu:20.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
