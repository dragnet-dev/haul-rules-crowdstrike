// Dragnet [Ransomware]: dragnet-ransomware-2025-1691 — Mass File Rename (sinobi)
// Status: experimental | Level: high | ID: 277cbec1-bbc8-5046-b0fd-327e993646b1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
