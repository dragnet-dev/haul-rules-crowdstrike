// Dragnet [Ransomware]: dragnet-ransomware-2023-2318 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 1a42cc6a-c6d9-52e3-b1e2-8d3abd5cecba

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
