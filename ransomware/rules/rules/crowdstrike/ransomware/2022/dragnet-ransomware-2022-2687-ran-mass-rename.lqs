// Dragnet [Ransomware]: dragnet-ransomware-2022-2687 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 56186772-abd8-5775-9353-06ddbf027b65

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
