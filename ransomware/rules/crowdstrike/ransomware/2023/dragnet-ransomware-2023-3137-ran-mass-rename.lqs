// Dragnet [Ransomware]: dragnet-ransomware-2023-3137 — Mass File Rename (siegedsec)
// Status: deprecated | Level: high | ID: 1d55c3ad-4c57-53b2-9341-b3fcc2571a94

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
