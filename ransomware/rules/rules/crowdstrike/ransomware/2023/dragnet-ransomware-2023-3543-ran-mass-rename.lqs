// Dragnet [Ransomware]: dragnet-ransomware-2023-3543 — Mass File Rename (cloak)
// Status: deprecated | Level: high | ID: b49cec1e-64fa-5c5c-bb8f-3493d9b387d9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
