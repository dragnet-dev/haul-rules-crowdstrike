// Dragnet [Ransomware]: dragnet-ransomware-2026-0956 — Mass File Rename (nightspire)
// Status: deprecated | Level: high | ID: 459ffe9a-557e-55c0-b62b-9a9e8c7d3f85

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
