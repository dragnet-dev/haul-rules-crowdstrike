// Dragnet [Ransomware]: dragnet-ransomware-2026-1686 — Mass File Rename (incransom)
// Status: stable | Level: high | ID: 9f2919f8-7ccc-5e75-82a1-7c8ccc966f32

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
