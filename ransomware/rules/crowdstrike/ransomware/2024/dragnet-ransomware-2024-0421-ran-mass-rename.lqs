// Dragnet [Ransomware]: dragnet-ransomware-2024-0421 — Mass File Rename (monti)
// Status: experimental | Level: high | ID: 8c21bdca-b091-560e-b872-ad1725d326e7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
