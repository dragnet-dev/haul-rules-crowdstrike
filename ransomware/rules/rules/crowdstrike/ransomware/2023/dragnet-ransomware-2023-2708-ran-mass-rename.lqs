// Dragnet [Ransomware]: dragnet-ransomware-2023-2708 — Mass File Rename (monti)
// Status: experimental | Level: high | ID: 7951ba87-568e-594e-b4e2-b59d1d974789

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
