// Dragnet [Ransomware]: dragnet-ransomware-2025-3070 — Mass File Rename (handala)
// Status: experimental | Level: high | ID: 0f5a21c1-d661-5ed5-95de-d91e192b4d36

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
