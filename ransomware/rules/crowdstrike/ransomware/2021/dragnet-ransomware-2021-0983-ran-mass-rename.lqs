// Dragnet [Ransomware]: dragnet-ransomware-2021-0983 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: b4993978-f4ea-513b-bb31-1cd2755d4643

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
