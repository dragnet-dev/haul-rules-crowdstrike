// Dragnet [Ransomware]: dragnet-ransomware-2023-3052 — Mass File Rename (meow)
// Status: experimental | Level: high | ID: d96f29ae-0ff2-5b36-9ece-b90025cc91dd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
