// Dragnet [Ransomware]: dragnet-ransomware-2024-1808 — Mass File Rename (nitrogen)
// Status: experimental | Level: high | ID: 77e5908e-eadd-5bff-aca6-d6c878d6da40

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
