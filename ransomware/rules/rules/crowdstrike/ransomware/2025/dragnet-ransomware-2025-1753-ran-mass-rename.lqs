// Dragnet [Ransomware]: dragnet-ransomware-2025-1753 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: a12ebc50-f4b3-51a1-be2f-16d57e489a5c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
