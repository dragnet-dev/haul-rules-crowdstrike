// Dragnet [Ransomware]: dragnet-ransomware-2026-0152 — Mass File Rename (handala)
// Status: stable | Level: high | ID: 2fa89ebf-534f-5503-99cd-d1867d2ce3c0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
