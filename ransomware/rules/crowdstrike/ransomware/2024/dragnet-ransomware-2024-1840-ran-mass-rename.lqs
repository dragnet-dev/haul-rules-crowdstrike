// Dragnet [Ransomware]: dragnet-ransomware-2024-1840 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 84e65cbe-9034-59d7-b537-736738dda2f2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
