// Dragnet [Container]: dragnet-container-2026-2857 — Vulnerable Base Image Pull
// Status: deprecated | Level: medium | ID: 166fff76-06d9-513e-bd41-ee1e539ed68c

#event_simpleName=*
| (ImageFileName = *alpine edge:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
