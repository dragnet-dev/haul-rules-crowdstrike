// Dragnet [Ransomware]: dragnet-ransomware-2023-3258 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: fadd02c9-fb72-5f1a-a0d4-91ba991da928

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
