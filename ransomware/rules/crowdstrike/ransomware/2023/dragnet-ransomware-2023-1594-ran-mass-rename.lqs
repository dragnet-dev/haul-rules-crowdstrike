// Dragnet [Ransomware]: dragnet-ransomware-2023-1594 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 92b2d180-d849-5788-9f8e-b889a1693be1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
