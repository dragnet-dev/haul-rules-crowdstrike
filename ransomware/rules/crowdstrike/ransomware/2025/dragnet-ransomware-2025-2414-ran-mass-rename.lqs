// Dragnet [Ransomware]: dragnet-ransomware-2025-2414 — Mass File Rename (thegentlemen)
// Status: experimental | Level: high | ID: cb8c7abd-06dc-5d4e-a8ff-02665787d647

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
