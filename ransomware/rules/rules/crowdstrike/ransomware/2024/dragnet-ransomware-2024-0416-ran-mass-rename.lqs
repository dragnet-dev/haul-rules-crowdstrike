// Dragnet [Ransomware]: dragnet-ransomware-2024-0416 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 262ee00e-3742-54b6-a4ec-a0299e6bc0c5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
