// Dragnet [Ransomware]: dragnet-ransomware-2023-5249 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: bb688dff-5b18-530c-a043-2386ec9aec80

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
