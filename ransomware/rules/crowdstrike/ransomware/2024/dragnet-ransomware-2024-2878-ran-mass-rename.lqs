// Dragnet [Ransomware]: dragnet-ransomware-2024-2878 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 0497cace-06b0-532b-8144-c00f30b28174

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
