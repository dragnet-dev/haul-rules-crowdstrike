// Dragnet [Ransomware]: dragnet-ransomware-2021-1374 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 8dc4ba6e-766f-51b8-856d-b2658b19e0aa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
