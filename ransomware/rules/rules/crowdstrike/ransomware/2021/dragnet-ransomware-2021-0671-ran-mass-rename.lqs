// Dragnet [Ransomware]: dragnet-ransomware-2021-0671 — Mass File Rename (everest)
// Status: deprecated | Level: high | ID: 62c27fbc-e869-5b08-8d4f-5af1aa387a26

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
