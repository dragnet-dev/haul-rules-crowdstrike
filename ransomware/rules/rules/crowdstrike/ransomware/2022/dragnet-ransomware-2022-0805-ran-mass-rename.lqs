// Dragnet [Ransomware]: dragnet-ransomware-2022-0805 — Mass File Rename (cuba)
// Status: deprecated | Level: high | ID: 16910ecd-4159-5b84-bdc6-71c5bbd2ef98

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
