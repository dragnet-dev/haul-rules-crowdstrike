// Dragnet [Ransomware]: dragnet-ransomware-2024-5128 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 53fa2c22-7c0c-54c4-9d91-ba364aa8a5f9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
