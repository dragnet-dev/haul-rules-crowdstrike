// Dragnet [Ransomware]: dragnet-ransomware-2023-4375 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 7addd80d-a1da-5080-9188-9099796b0e36

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
