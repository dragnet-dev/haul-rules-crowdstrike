// Dragnet [Ransomware]: dragnet-ransomware-2025-7758 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 7f9cd925-77c3-59cb-acd8-04aaf104f165

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
