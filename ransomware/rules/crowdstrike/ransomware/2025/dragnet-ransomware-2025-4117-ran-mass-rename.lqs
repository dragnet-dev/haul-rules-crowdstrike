// Dragnet [Ransomware]: dragnet-ransomware-2025-4117 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 0f2cee05-4f98-5de9-b950-9a58a0143d45

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
