// Dragnet [Ransomware]: dragnet-ransomware-2025-6658 — Mass File Rename (medusalocker)
// Status: experimental | Level: high | ID: 621bc62e-91eb-53f4-bed9-477777c6c7db

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
