// Dragnet [Ransomware]: dragnet-ransomware-2023-2353 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 85e5a6ae-12bf-5cd4-b236-822e11eed0d9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
