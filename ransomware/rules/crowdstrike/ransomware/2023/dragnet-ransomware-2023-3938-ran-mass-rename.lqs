// Dragnet [Ransomware]: dragnet-ransomware-2023-3938 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 572e90a1-4dd3-5e36-bc1a-474748785819

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
