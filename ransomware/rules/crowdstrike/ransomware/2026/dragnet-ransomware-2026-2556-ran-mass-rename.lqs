// Dragnet [Ransomware]: dragnet-ransomware-2026-2556 — Mass File Rename (lockbit5)
// Status: test | Level: high | ID: eadcf202-a250-5f09-971b-ff78e82ae92f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
