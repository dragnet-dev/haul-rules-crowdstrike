// Dragnet [Ransomware]: dragnet-ransomware-2025-2583 — Mass File Rename (play)
// Status: experimental | Level: high | ID: a31760e1-6a51-5e74-adbd-a1fc0d47c12c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
