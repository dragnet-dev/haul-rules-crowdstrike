// Dragnet [Ransomware]: dragnet-ransomware-2024-0003 — Mass File Rename (meow)
// Status: experimental | Level: high | ID: 21bc02de-5967-577e-bdb4-be3a9622fcda

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
