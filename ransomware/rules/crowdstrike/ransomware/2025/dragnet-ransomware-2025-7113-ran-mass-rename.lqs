// Dragnet [Ransomware]: dragnet-ransomware-2025-7113 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 6207021d-38b9-5ec2-8d87-eae06c2f4c1d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
