// Dragnet [Ransomware]: dragnet-ransomware-2024-1995 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 61b9325b-a961-5cec-9beb-3bf1b56f937e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
