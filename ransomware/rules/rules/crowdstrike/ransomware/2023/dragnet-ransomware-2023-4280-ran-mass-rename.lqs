// Dragnet [Ransomware]: dragnet-ransomware-2023-4280 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: abd0ea94-c5c9-5688-883a-4a8316a347bf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
