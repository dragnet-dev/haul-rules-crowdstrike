// Dragnet [Ransomware]: dragnet-ransomware-2023-2268 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 99b4be5a-e924-5129-bc88-f57f0d75c91b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
