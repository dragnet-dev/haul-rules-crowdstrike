// Dragnet [Ransomware]: dragnet-ransomware-2025-4800 — Mass File Rename (blacknevas)
// Status: experimental | Level: high | ID: 8b0cf702-9d72-57af-89a6-4358ce0517fd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
