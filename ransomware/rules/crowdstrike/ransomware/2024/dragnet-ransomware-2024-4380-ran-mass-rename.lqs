// Dragnet [Ransomware]: dragnet-ransomware-2024-4380 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: d9125e70-d350-55c3-b021-72b4af7afcef

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
