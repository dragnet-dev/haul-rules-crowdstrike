// Dragnet [Ransomware]: dragnet-ransomware-2023-1135 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 09ec7b8f-7164-5ce4-b272-18c9f5498ae0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
