// Dragnet [Ransomware]: dragnet-ransomware-2025-1421 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 57d1c8e7-5831-5c2b-af26-0fe0ea204af7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
