// Dragnet [Ransomware]: dragnet-ransomware-2024-3473 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 02f1b39b-496f-5480-ade5-a1074f5da24d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
