// Dragnet [Ransomware]: dragnet-ransomware-2024-3200 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: 9e94a703-2dba-5331-afbb-34d5e119415b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
