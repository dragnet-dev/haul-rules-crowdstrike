// Dragnet [Ransomware]: dragnet-ransomware-2025-3648 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 63208d9d-d9ae-5bd0-8b99-67f0f7e4a8b0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
