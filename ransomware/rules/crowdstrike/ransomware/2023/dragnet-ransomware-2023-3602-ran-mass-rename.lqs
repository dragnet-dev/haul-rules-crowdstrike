// Dragnet [Ransomware]: dragnet-ransomware-2023-3602 — Mass File Rename (royal)
// Status: experimental | Level: high | ID: 6476b4a2-c4d3-5ecd-84a0-696e05b87319

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
