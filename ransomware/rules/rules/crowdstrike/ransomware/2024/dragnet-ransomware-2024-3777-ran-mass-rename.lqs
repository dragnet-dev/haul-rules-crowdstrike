// Dragnet [Ransomware]: dragnet-ransomware-2024-3777 — Mass File Rename (dragonransomware)
// Status: experimental | Level: high | ID: 582f0f4d-19fd-5298-a05c-adffb8409bfb

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
