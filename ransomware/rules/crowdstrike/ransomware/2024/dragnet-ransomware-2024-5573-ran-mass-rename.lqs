// Dragnet [Ransomware]: dragnet-ransomware-2024-5573 — Mass File Rename (rhysida)
// Status: deprecated | Level: high | ID: e46e8c36-234e-53c8-aae3-c4336409daef

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
