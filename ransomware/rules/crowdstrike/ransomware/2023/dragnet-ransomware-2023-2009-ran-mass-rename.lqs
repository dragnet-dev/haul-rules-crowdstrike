// Dragnet [Ransomware]: dragnet-ransomware-2023-2009 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 1c2547f3-4b77-51f0-8892-22655ddbeab6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
