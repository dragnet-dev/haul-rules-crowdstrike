// Dragnet [Ransomware]: dragnet-ransomware-2025-0637 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: f794b259-cbeb-59ce-9c0a-f69da7ddf87f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
