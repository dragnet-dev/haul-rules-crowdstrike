// Dragnet [Ransomware]: dragnet-ransomware-2022-0105 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 7007ee0b-79f2-53ac-8568-ddb481e5bd46

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
