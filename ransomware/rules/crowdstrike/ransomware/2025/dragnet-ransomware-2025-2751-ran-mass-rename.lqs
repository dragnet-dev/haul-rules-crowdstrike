// Dragnet [Ransomware]: dragnet-ransomware-2025-2751 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 0619a378-02fa-513c-9caa-3b1e59daa54c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
