// Dragnet [Ransomware]: dragnet-ransomware-2022-0074 — Mass File Rename (lv)
// Status: deprecated | Level: high | ID: edbf766f-a912-5d75-9ae6-b0c0c938181d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
