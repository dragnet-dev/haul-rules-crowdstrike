// Dragnet [Container]: dragnet-container-2026-2196 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 951fd7b5-bd16-529f-8679-06ea455a6ac0

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6*)
| table([timestamp, ComputerName])
| limit(1000)
