// Dragnet [Ransomware]: dragnet-ransomware-2025-0078 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 250cbc69-84eb-5297-afcf-3ac36633d826

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
