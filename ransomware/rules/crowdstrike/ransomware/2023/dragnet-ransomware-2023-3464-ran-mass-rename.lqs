// Dragnet [Ransomware]: dragnet-ransomware-2023-3464 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 14acf6f4-dfee-5239-a961-e8aa2a63fde0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
