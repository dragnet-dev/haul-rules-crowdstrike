// Dragnet [Container]: dragnet-container-2026-0244 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: fcf4afaa-3ca9-5073-b66f-9321a5166636

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:5*)
| table([timestamp, ComputerName])
| limit(1000)
