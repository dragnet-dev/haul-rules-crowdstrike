// Dragnet [Ransomware]: dragnet-ransomware-2022-0613 — Mass File Rename (royal)
// Status: deprecated | Level: high | ID: fe245f42-53ce-589a-b5cc-0e62182ce554

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
