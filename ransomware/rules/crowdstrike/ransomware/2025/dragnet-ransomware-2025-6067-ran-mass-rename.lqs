// Dragnet [Ransomware]: dragnet-ransomware-2025-6067 — Mass File Rename (blackshrantac)
// Status: test | Level: high | ID: 89077eb4-8298-5b01-a559-b7b36d8a6b18

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
