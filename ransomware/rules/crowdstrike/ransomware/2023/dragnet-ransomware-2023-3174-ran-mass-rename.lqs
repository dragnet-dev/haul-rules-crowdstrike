// Dragnet [Ransomware]: dragnet-ransomware-2023-3174 — Mass File Rename (cactus)
// Status: deprecated | Level: high | ID: 2feb2466-4950-520d-b400-92aee41b7400

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
