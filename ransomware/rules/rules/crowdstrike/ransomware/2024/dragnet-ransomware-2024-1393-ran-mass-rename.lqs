// Dragnet [Ransomware]: dragnet-ransomware-2024-1393 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 84406c03-60d3-5be4-92ba-a2e1d4e3d760

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
