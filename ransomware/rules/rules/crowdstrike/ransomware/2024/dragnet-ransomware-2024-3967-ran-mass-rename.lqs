// Dragnet [Ransomware]: dragnet-ransomware-2024-3967 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: be7f33cc-cd71-555f-8191-e14cfacbf1aa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
