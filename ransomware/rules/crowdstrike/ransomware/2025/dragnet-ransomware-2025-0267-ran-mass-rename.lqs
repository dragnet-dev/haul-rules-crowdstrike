// Dragnet [Ransomware]: dragnet-ransomware-2025-0267 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: ad6475fd-286e-5a7d-a48e-5fcfeebd16fc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
