// Dragnet [Ransomware]: dragnet-ransomware-2023-3181 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 50e416c8-2163-5c53-a9fd-696105be7d9e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
