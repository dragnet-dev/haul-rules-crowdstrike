// Dragnet [Ransomware]: dragnet-ransomware-2025-4241 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 60b69dcd-8b45-51c2-b4fc-790236073db7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
