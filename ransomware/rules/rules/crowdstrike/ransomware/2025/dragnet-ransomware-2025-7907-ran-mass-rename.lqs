// Dragnet [Ransomware]: dragnet-ransomware-2025-7907 — Mass File Rename (blackshrantac)
// Status: experimental | Level: high | ID: df7dd058-9377-5d9e-adee-f1ec62ad94f1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
