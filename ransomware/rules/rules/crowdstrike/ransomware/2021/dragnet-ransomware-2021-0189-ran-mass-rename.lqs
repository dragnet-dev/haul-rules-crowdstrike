// Dragnet [Ransomware]: dragnet-ransomware-2021-0189 — Mass File Rename (azroteam)
// Status: deprecated | Level: high | ID: 678e08a4-9f21-530d-be80-78c80ac5c8a2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
