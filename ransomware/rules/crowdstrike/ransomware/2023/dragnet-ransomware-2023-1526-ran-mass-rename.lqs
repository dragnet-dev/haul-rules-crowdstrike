// Dragnet [Ransomware]: dragnet-ransomware-2023-1526 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: e15a8f47-f1b4-5730-8b11-e5cd14a96d25

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
