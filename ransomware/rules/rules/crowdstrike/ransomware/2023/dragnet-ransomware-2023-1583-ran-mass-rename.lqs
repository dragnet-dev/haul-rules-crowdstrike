// Dragnet [Ransomware]: dragnet-ransomware-2023-1583 — Mass File Rename (raworld)
// Status: experimental | Level: high | ID: 80645f04-baf6-51cd-bbf8-489c6c3a0c17

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
