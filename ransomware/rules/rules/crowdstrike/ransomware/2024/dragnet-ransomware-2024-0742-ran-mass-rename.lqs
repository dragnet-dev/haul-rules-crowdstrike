// Dragnet [Ransomware]: dragnet-ransomware-2024-0742 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 28a2f3d5-465b-5dd9-a9cb-55340ad14cd6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
