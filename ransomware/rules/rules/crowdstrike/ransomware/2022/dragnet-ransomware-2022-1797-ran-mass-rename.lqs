// Dragnet [Ransomware]: dragnet-ransomware-2022-1797 — Mass File Rename (lv)
// Status: deprecated | Level: high | ID: d6e141a1-d07c-5131-9ba9-6c872d33d740

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
