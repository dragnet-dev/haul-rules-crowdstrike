// Dragnet [Ransomware]: dragnet-ransomware-2024-3779 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: 63f8e08b-50df-597d-844f-d3eefcd32953

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
