// Dragnet [Ransomware]: dragnet-ransomware-2020-0062 — Mass File Rename (maze)
// Status: deprecated | Level: high | ID: 01442bee-d77f-57b3-ab30-780f24e47e00

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
