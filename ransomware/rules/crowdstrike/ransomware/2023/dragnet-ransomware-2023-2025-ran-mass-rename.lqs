// Dragnet [Ransomware]: dragnet-ransomware-2023-2025 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 7cf99876-5892-586d-b0a7-4e9d78bfdced

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
