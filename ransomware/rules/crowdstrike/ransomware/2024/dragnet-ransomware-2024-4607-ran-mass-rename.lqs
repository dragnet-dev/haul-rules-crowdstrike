// Dragnet [Ransomware]: dragnet-ransomware-2024-4607 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: bcd11bab-6b5d-5ec2-bb77-55b6be458add

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
