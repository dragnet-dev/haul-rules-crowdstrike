// Dragnet [Ransomware]: dragnet-ransomware-2024-5401 — Mass File Rename (dragonforce)
// Status: deprecated | Level: high | ID: 1d88b1a8-d679-564d-bc47-705cbf7d0aee

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
