// Dragnet [Ransomware]: dragnet-ransomware-2025-2992 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 7f279551-d671-5bfc-9089-7fbc5f8ce7ee

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
