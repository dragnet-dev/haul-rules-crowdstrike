// Dragnet [Ransomware]: dragnet-ransomware-2025-7586 — Mass File Rename (killsec)
// Status: experimental | Level: high | ID: 4db87c32-5272-50f7-936b-edf9b0da54c6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
