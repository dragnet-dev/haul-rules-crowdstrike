// Dragnet [Ransomware]: dragnet-ransomware-2025-1781 — Mass File Rename (bqtlock)
// Status: experimental | Level: high | ID: 1997d317-fd0a-5085-99ed-3711313ec352

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
