// Dragnet [Ransomware]: dragnet-ransomware-2024-3254 — Mass File Rename (dragonransomware)
// Status: experimental | Level: high | ID: 797f2947-d132-59c4-97f3-254afb0896f7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
