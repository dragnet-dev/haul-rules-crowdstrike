// Dragnet [Ransomware]: dragnet-ransomware-2024-2322 — Mass File Rename (apt73)
// Status: experimental | Level: high | ID: 24326329-719b-5ede-b9d6-aeda46130442

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
