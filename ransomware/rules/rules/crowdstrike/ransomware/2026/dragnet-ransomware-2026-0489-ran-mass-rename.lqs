// Dragnet [Ransomware]: dragnet-ransomware-2026-0489 — Mass File Rename (vect)
// Status: deprecated | Level: high | ID: f4b88395-23d6-5ce3-9705-64f7f57c4c21

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
