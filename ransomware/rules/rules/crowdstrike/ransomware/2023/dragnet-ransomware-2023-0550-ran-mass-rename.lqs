// Dragnet [Ransomware]: dragnet-ransomware-2023-0550 — Mass File Rename (play)
// Status: deprecated | Level: high | ID: 9544235b-3d95-5429-82c4-60475a3d14e9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
