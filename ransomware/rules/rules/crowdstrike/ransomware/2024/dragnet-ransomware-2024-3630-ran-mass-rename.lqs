// Dragnet [Ransomware]: dragnet-ransomware-2024-3630 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: f836df88-3606-55ca-8050-5528b2a5ea6a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
