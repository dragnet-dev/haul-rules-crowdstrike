// Dragnet [Ransomware]: dragnet-ransomware-2022-0151 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 141c759d-3fea-5f5a-8f91-3046a68bae44

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
