// Dragnet [Ransomware]: dragnet-ransomware-2023-0092 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 2371d8e3-e6ec-5b3f-a0aa-5d5b5a7423be

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
