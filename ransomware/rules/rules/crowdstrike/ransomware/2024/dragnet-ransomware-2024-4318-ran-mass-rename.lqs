// Dragnet [Ransomware]: dragnet-ransomware-2024-4318 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: 83f8ea4f-3a8e-5732-b7ff-834ba980141c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
