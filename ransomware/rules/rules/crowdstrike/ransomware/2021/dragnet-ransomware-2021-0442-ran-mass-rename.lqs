// Dragnet [Ransomware]: dragnet-ransomware-2021-0442 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: ad063977-a746-5fcf-98f7-0f8521a110d1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
