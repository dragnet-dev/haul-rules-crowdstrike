// Dragnet [Ransomware]: dragnet-ransomware-2024-3580 — Mass File Rename (cloak)
// Status: deprecated | Level: high | ID: 2e62b713-2b1d-5d6e-b742-17466c123d7a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
