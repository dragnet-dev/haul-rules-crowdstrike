// Dragnet [Ransomware]: dragnet-ransomware-2025-4016 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 2a6d9181-59d5-580b-9177-25294994afe4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
