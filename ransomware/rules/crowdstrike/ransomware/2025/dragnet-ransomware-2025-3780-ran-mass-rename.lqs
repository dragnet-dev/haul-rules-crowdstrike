// Dragnet [Ransomware]: dragnet-ransomware-2025-3780 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 5ff3b1ab-63cd-5a95-bef9-628ba6010788

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
