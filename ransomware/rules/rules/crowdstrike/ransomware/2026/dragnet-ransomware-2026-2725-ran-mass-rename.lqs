// Dragnet [Ransomware]: dragnet-ransomware-2026-2725 — Mass File Rename (incransom)
// Status: stable | Level: high | ID: d9334600-58cf-5733-89c4-68cb7b4190a5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
