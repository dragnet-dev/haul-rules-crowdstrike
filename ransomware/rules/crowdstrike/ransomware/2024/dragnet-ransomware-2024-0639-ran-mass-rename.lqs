// Dragnet [Ransomware]: dragnet-ransomware-2024-0639 — Mass File Rename (helldown)
// Status: experimental | Level: high | ID: a1a0b4f5-b842-5767-9565-326287108469

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
