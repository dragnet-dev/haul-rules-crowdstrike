// Dragnet [Ransomware]: dragnet-ransomware-2024-0782 — Mass File Rename (ransomhouse)
// Status: experimental | Level: high | ID: e56be8fd-6c3c-578f-95ed-03a0e558cb7b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
