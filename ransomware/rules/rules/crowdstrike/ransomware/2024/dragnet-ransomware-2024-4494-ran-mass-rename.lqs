// Dragnet [Ransomware]: dragnet-ransomware-2024-4494 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 068fbfe7-f115-5ec1-902f-7a1c3b2a3aef

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
