// Dragnet [Ransomware]: dragnet-ransomware-2025-1892 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 7592d5df-6d3e-5054-a792-12c260a679bf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
