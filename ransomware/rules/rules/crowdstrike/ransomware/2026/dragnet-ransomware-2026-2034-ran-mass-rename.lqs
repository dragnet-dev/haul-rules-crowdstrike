// Dragnet [Ransomware]: dragnet-ransomware-2026-2034 — Mass File Rename (payload)
// Status: stable | Level: high | ID: 71212803-272c-52fb-9365-a2cd058aaba8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
