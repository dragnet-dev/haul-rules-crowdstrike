// Dragnet [Ransomware]: dragnet-ransomware-2025-7902 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: 5fd383df-5c23-5a1c-8752-1e014b5f3cd9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
