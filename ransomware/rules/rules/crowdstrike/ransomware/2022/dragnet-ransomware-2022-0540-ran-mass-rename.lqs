// Dragnet [Ransomware]: dragnet-ransomware-2022-0540 — Mass File Rename (suncrypt)
// Status: deprecated | Level: high | ID: 9333dbf4-9248-55bd-9dbf-c300f0a581f0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
