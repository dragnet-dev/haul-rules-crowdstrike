// Dragnet [Ransomware]: dragnet-ransomware-2025-5836 — Mass File Rename (chaos)
// Status: experimental | Level: high | ID: 3fb544c5-a181-5454-a1b8-a2d20a4d609d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
