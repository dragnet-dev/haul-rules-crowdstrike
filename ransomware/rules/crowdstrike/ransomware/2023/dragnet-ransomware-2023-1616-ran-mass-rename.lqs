// Dragnet [Ransomware]: dragnet-ransomware-2023-1616 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 201842f8-3683-5e5d-96b4-828e912b0cab

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
