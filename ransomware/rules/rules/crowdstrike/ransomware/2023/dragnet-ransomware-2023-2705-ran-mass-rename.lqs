// Dragnet [Ransomware]: dragnet-ransomware-2023-2705 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 7009122b-6fca-58f4-8ea9-0e8537a75668

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
