// Dragnet [Container]: dragnet-container-2024-1195 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 9ad3683e-5cd6-54bf-b190-2d5e57daa5b1

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
