// Dragnet [Ransomware]: dragnet-ransomware-2024-1688 — Mass File Rename (fog)
// Status: experimental | Level: high | ID: 77a1086e-005c-5fbb-909c-16f69c84aca5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
