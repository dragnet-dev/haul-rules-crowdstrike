// Dragnet [Ransomware]: dragnet-ransomware-2025-6514 — Mass File Rename (lockbit5)
// Status: test | Level: high | ID: 55996474-7af3-564a-a342-ffa9caa72bb1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
