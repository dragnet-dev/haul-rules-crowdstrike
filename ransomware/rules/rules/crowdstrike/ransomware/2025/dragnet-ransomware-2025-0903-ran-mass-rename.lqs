// Dragnet [Ransomware]: dragnet-ransomware-2025-0903 — Mass File Rename (coinbasecartel)
// Status: experimental | Level: high | ID: ac20b591-1c7f-53cb-b9b2-e2b45677a483

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
