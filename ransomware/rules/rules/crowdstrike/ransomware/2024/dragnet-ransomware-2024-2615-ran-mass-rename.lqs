// Dragnet [Ransomware]: dragnet-ransomware-2024-2615 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 892c78bb-4067-5f77-89e0-08fe75d1e350

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
