// Dragnet [Ransomware]: dragnet-ransomware-2023-1246 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 348c3572-e62e-53de-a351-fbbe0a98969c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
