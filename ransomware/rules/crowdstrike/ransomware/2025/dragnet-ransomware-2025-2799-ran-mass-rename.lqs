// Dragnet [Ransomware]: dragnet-ransomware-2025-2799 — Mass File Rename (crazyhunter)
// Status: experimental | Level: high | ID: 93621160-e397-5575-8a9d-516318ee2c2f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
