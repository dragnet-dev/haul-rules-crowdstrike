// Dragnet [Ransomware]: dragnet-ransomware-2024-3486 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 907de25d-246e-5632-abc3-ddb236c48146

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
