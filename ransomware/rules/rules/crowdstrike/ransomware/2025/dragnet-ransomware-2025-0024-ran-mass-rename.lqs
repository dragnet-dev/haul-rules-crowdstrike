// Dragnet [Ransomware]: dragnet-ransomware-2025-0024 — Mass File Rename (gunra)
// Status: experimental | Level: high | ID: 5aa52d3e-1da4-5633-bee6-3264af9df353

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
