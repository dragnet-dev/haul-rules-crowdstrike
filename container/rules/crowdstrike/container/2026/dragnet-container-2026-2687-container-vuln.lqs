// Dragnet [Container]: dragnet-container-2026-2687 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 2a327f21-9815-5e08-b722-1a43ebf3e675

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:7* OR ImageFileName = *debian:8* OR ImageFileName = *ubuntu:12.04*)
| table([timestamp, ComputerName])
| limit(1000)
