// Dragnet [Ransomware]: dragnet-ransomware-2024-0167 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: ee478388-f22f-5ea9-85fb-beb3b815d8ca

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
