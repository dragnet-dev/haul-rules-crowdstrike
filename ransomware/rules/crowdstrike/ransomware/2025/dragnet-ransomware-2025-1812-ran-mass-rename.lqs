// Dragnet [Ransomware]: dragnet-ransomware-2025-1812 — Mass File Rename (sarcoma)
// Status: deprecated | Level: high | ID: 2fa6b49a-b2ba-5ad8-943e-f1f21f2c2b10

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
