// Dragnet [Ransomware]: dragnet-ransomware-2022-2253 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: dcf70927-2b8e-5548-886c-9ae6dd617600

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
