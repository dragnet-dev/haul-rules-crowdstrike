// Dragnet [Ransomware]: dragnet-ransomware-2024-2931 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 6e9c762f-7645-566e-b2f4-2ca67697e2e0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
