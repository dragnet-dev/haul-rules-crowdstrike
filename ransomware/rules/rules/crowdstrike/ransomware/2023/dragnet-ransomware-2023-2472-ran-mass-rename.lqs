// Dragnet [Ransomware]: dragnet-ransomware-2023-2472 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 3d005704-849d-5151-bae6-179d96a01350

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
