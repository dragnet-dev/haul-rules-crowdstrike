// Dragnet [Container]: dragnet-container-2026-0856 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 86db6bd4-60b6-5580-b2ac-24ac06e0d2d4

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:5*)
| table([timestamp, ComputerName])
| limit(1000)
