// Dragnet [Ransomware]: dragnet-ransomware-2025-3288 — Mass File Rename (dragonforce)
// Status: experimental | Level: high | ID: dc72ebbf-a53f-5823-8163-2f32d04f178a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
