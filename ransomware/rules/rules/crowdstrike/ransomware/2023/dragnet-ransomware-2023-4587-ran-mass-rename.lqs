// Dragnet [Ransomware]: dragnet-ransomware-2023-4587 — Mass File Rename (nokoyawa)
// Status: experimental | Level: high | ID: dde672ff-65c8-567b-8c56-74427a4f0ad7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
