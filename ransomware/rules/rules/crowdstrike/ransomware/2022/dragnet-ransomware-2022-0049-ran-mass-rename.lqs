// Dragnet [Ransomware]: dragnet-ransomware-2022-0049 — Mass File Rename (karakurt)
// Status: deprecated | Level: high | ID: ac407856-5b89-5823-b674-32ae847f7664

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
