// Dragnet [Ransomware]: dragnet-ransomware-2023-3450 — Mass File Rename (cloak)
// Status: deprecated | Level: high | ID: f8ac0b95-ecf4-50fb-a33d-ab170102b268

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
