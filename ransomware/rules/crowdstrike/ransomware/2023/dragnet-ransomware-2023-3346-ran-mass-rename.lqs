// Dragnet [Ransomware]: dragnet-ransomware-2023-3346 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: 73c128ad-7e9f-571e-a536-e137cf38cc9d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
