// Dragnet [Ransomware]: dragnet-ransomware-2022-0641 — Mass File Rename (blackbasta)
// Status: deprecated | Level: high | ID: 979324a4-bdf0-5b41-9a79-345a829aecf5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
