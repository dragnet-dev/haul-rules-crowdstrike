// Dragnet [Ransomware]: dragnet-ransomware-2024-5413 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 654952e4-fe5c-5138-89bf-e9294d44b385

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
