// Dragnet [Ransomware]: dragnet-ransomware-2024-4247 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 99dd1e6f-6474-564b-b204-0518154e973a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
