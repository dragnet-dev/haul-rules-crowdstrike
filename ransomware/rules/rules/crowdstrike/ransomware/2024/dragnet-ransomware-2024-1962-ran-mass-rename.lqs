// Dragnet [Ransomware]: dragnet-ransomware-2024-1962 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 3b26eee3-0b38-53ea-aa8f-9495dad888c7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
