// Dragnet [Ransomware]: dragnet-ransomware-2025-1951 — Mass File Rename (warlock)
// Status: deprecated | Level: high | ID: 20e793ce-8ae9-5abc-88af-cb9d710de1a2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
