// Dragnet [Ransomware]: dragnet-ransomware-2025-4896 — Mass File Rename (embargo)
// Status: experimental | Level: high | ID: 5b3ca987-5651-542f-b708-6bd3588d138c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
