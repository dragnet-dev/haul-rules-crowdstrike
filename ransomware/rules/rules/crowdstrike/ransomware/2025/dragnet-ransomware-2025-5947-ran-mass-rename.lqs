// Dragnet [Ransomware]: dragnet-ransomware-2025-5947 — Mass File Rename (bert)
// Status: experimental | Level: high | ID: 2e0adef7-b8f2-5ae3-827e-1e6e74d3a28a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
