// Dragnet [Ransomware]: dragnet-ransomware-2022-2407 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 646b2f2a-a29a-510b-acc9-ea38ffc30810

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
