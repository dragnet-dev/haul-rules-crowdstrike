// Dragnet [Ransomware]: dragnet-ransomware-2025-4873 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: b94b03b5-7aa6-5bcd-9e0f-b4c31c60e5d4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
