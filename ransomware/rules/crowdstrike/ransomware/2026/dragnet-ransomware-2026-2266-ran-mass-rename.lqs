// Dragnet [Ransomware]: dragnet-ransomware-2026-2266 — Mass File Rename (nightspire)
// Status: deprecated | Level: high | ID: 8f58596d-81ae-5b7a-aa73-73b791e472e7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
