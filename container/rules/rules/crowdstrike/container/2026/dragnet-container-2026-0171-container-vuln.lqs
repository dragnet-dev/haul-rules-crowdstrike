// Dragnet [Container]: dragnet-container-2026-0171 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 1834b224-c863-57aa-86a0-cfaa5669a2bc

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:7*)
| table([timestamp, ComputerName])
| limit(1000)
