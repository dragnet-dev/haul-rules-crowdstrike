// Dragnet [Ransomware]: dragnet-ransomware-2023-5370 — Mass File Rename (cryptbb)
// Status: experimental | Level: high | ID: ef85b4c0-736d-5ccd-b94f-5627226caf26

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
