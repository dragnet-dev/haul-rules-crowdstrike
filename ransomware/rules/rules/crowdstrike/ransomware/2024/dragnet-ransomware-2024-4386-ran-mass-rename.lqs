// Dragnet [Ransomware]: dragnet-ransomware-2024-4386 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 9c9ec7ab-cada-59de-a435-9fd15f8a0b6d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
