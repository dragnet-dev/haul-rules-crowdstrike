// Dragnet [Ransomware]: dragnet-ransomware-2025-5230 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 9820be0c-428d-531d-9e48-d1cb703512d2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
