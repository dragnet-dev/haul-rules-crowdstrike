// Dragnet [Ransomware]: dragnet-ransomware-2022-1887 — Mass File Rename (alphv)
// Status: deprecated | Level: high | ID: 227a0ede-99ed-5005-8672-11eba883d753

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
