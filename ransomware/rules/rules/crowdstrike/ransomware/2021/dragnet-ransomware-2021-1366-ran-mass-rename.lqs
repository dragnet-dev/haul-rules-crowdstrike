// Dragnet [Ransomware]: dragnet-ransomware-2021-1366 — Mass File Rename (ragnarlocker)
// Status: deprecated | Level: high | ID: 6ad6273a-ed33-53c2-ba00-1e051178f993

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
