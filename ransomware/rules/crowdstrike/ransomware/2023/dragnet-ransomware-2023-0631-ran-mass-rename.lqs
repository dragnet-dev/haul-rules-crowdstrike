// Dragnet [Ransomware]: dragnet-ransomware-2023-0631 — Mass File Rename (snatch)
// Status: experimental | Level: high | ID: 2a0cfd8b-0dce-5782-a938-01072f87bac3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
