// Dragnet [Container]: dragnet-container-2025-0063 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 318c94bb-f5a8-53c8-ab30-0ff61d272691

#event_simpleName=*
| (ImageFileName = *amazonlinux:2* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:16.04-ESM* OR ImageFileName = *ubuntu:18.04-ESM* OR ImageFileName = *ubuntu:20.04* OR ImageFileName = *ubuntu:20.04-ESM* OR ImageFileName = *ubuntu:22.04* OR ImageFileName = *ubuntu:24.04* OR ImageFileName = *ubuntu:24.10* OR ImageFileName = *ubuntu:25.04*)
| table([timestamp, ComputerName])
| limit(1000)
