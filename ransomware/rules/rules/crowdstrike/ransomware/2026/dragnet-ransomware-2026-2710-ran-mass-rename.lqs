// Dragnet [Ransomware]: dragnet-ransomware-2026-2710 — Mass File Rename (incransom)
// Status: test | Level: high | ID: 65006d37-018c-5159-b7cb-c634a994cc82

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
