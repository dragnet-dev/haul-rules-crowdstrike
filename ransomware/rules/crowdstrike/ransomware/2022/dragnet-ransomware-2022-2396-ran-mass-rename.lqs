// Dragnet [Ransomware]: dragnet-ransomware-2022-2396 — Mass File Rename (karakurt)
// Status: experimental | Level: high | ID: 4257fe23-3272-5b41-b420-4050e2fb5c97

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
