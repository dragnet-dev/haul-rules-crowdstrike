// Dragnet [Ransomware]: dragnet-ransomware-2023-3253 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 02dac16e-c67b-5936-8e0d-efa8b16e76a4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
