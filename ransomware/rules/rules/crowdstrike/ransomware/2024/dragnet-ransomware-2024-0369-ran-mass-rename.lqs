// Dragnet [Ransomware]: dragnet-ransomware-2024-0369 — Mass File Rename (funksec)
// Status: experimental | Level: high | ID: 2ad47a67-1029-5122-b62a-e7996d1e1204

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
