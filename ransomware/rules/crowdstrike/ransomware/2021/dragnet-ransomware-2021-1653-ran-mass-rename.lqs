// Dragnet [Ransomware]: dragnet-ransomware-2021-1653 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 83556b65-4b00-532e-a5e2-209ebc896d92

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
