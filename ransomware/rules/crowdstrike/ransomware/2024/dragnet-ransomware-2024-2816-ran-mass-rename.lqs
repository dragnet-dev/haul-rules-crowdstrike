// Dragnet [Ransomware]: dragnet-ransomware-2024-2816 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 4efd3874-e7bc-5e7b-8058-cab54d211c6f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
