// Dragnet [Ransomware]: dragnet-ransomware-2024-2239 — Mass File Rename (meow)
// Status: experimental | Level: high | ID: 31c43609-bbc9-560e-b6f0-ef2eb7ab374b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
