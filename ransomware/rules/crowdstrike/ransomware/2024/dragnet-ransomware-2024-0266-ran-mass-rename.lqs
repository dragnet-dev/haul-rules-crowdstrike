// Dragnet [Ransomware]: dragnet-ransomware-2024-0266 — Mass File Rename (meow)
// Status: experimental | Level: high | ID: fb9a3ee4-8db1-5235-a800-f7ee0e911331

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
