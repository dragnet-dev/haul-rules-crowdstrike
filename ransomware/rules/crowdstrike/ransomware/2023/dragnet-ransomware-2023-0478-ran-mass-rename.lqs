// Dragnet [Ransomware]: dragnet-ransomware-2023-0478 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 866725ff-528b-5bde-8e7f-62b8f64aa83d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
