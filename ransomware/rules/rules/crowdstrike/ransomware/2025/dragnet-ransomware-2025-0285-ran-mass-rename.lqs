// Dragnet [Ransomware]: dragnet-ransomware-2025-0285 — Mass File Rename (arcusmedia)
// Status: experimental | Level: high | ID: 3b40dc4b-ff60-5efe-9df0-c4bce0ca4469

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
