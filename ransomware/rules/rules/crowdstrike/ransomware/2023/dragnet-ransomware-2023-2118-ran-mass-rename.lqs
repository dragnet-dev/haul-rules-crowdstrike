// Dragnet [Ransomware]: dragnet-ransomware-2023-2118 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 14cce780-20e7-5bf4-bfae-1ec6f07a2518

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
