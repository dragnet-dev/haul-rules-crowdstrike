// Dragnet [Ransomware]: dragnet-ransomware-2024-1557 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: 81552d03-6a4b-56bd-af84-ebc9415fb275

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
