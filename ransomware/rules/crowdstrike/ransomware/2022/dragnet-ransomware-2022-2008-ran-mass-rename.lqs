// Dragnet [Ransomware]: dragnet-ransomware-2022-2008 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 8ea86733-b7f3-576c-bd02-ca4e7ca31240

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
