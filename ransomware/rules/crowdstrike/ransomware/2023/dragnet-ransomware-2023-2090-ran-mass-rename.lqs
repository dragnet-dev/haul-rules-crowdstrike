// Dragnet [Ransomware]: dragnet-ransomware-2023-2090 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 171206e0-de44-510d-8b32-8c168111f644

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
