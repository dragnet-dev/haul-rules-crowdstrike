// Dragnet [Ransomware]: dragnet-ransomware-2022-1873 — Mass File Rename (cuba)
// Status: deprecated | Level: high | ID: 7a8f4bc5-8112-5f70-b22b-d87c9bc52f29

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
