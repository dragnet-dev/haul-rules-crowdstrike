// Dragnet [Ransomware]: dragnet-ransomware-2022-2932 — Mass File Rename (vicesociety)
// Status: deprecated | Level: high | ID: 4b921b89-c12c-54e1-8ae2-c2a352846363

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
