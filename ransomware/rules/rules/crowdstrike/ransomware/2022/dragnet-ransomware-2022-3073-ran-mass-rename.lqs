// Dragnet [Ransomware]: dragnet-ransomware-2022-3073 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 9852a083-d186-53d9-a479-2590b63f3ec4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
