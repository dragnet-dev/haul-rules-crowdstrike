// Dragnet [Ransomware]: dragnet-ransomware-2023-1611 — Mass File Rename (ransomed)
// Status: deprecated | Level: high | ID: 867b8fb2-97df-5e49-ab2e-5098efd33dd5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
