// Dragnet [Ransomware]: dragnet-ransomware-2026-1381 — Mass File Rename (worldleaks)
// Status: stable | Level: high | ID: e7d9292c-f0a4-5230-8823-0c0951be4797

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
