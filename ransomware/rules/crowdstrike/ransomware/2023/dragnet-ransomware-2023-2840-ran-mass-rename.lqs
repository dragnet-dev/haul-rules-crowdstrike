// Dragnet [Ransomware]: dragnet-ransomware-2023-2840 — Mass File Rename (malas)
// Status: experimental | Level: high | ID: 50732a43-4b07-58f6-bd5a-aec58b889c05

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
