// Dragnet [Ransomware]: dragnet-ransomware-2025-1053 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: fe514618-dcbd-599c-81ce-8b3f5b2800f3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
