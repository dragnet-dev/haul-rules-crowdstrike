// Dragnet [Ransomware]: dragnet-ransomware-2023-1209 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: 4a449ec5-1fdb-583a-95eb-807ee8995861

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
