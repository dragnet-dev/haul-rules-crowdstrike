// Dragnet [Ransomware]: dragnet-ransomware-2024-5063 — Mass File Rename (threeam)
// Status: experimental | Level: high | ID: cca1729c-c969-5644-8f0f-65f96fd1781e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
