// Dragnet [Ransomware]: dragnet-ransomware-2024-0067 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 1dc226d3-e4d4-5122-a648-66602b2599b4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
