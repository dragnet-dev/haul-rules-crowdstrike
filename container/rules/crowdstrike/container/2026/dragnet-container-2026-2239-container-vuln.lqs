// Dragnet [Container]: dragnet-container-2026-2239 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 33782f8b-382e-587e-a09e-08b10c06fb52

#event_simpleName=*
| (ImageFileName = *oraclelinux:5* OR ImageFileName = *oraclelinux:6* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10* OR ImageFileName = *ubuntu:13.04* OR ImageFileName = *ubuntu:13.10*)
| table([timestamp, ComputerName])
| limit(1000)
