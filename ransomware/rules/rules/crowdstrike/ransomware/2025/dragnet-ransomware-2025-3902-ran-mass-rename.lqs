// Dragnet [Ransomware]: dragnet-ransomware-2025-3902 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 6574ccf5-4d73-564f-a3f4-4c223936d87a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
