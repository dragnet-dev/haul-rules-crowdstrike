// Dragnet [Ransomware]: dragnet-ransomware-2025-2999 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: a425e681-df80-529b-8b89-565eef3e991a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
