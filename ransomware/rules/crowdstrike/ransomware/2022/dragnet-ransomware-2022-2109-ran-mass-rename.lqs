// Dragnet [Ransomware]: dragnet-ransomware-2022-2109 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: e5f88e0a-0bb5-52dc-8b48-912eae02fe89

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
