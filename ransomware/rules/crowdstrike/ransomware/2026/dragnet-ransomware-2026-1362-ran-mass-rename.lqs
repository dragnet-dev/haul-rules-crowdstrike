// Dragnet [Ransomware]: dragnet-ransomware-2026-1362 — Mass File Rename (aurora)
// Status: stable | Level: high | ID: ac589ec7-817e-5955-a816-c46e664c243f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
