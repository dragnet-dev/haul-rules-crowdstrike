// Dragnet [Ransomware]: dragnet-ransomware-2025-7871 — Mass File Rename (sarcoma)
// Status: deprecated | Level: high | ID: 1795a71e-cd88-5999-84ce-10d13139450c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
