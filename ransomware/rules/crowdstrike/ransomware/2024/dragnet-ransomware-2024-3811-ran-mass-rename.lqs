// Dragnet [Ransomware]: dragnet-ransomware-2024-3811 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 4fdcc669-08e1-58be-9fb6-713e3bff3e6f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
