// Dragnet [Ransomware]: dragnet-ransomware-2021-1073 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 59e84359-a302-5a41-b7c7-3dbcd0e665e6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
