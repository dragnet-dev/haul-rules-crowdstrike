// Dragnet [Ransomware]: dragnet-ransomware-2024-3952 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 1e231c36-8948-5817-beea-e06e4a56fecd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
