// Dragnet [Ransomware]: dragnet-ransomware-2021-1668 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 62e9e72c-7a14-56fd-a9aa-86cd22f80c9d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
