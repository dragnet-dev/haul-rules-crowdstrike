// Dragnet [Ransomware]: dragnet-ransomware-2023-3887 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: a3c2c06a-436f-5295-867b-6aadb4e74b68

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
