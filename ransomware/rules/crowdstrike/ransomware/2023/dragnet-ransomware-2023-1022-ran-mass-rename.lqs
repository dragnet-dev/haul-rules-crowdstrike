// Dragnet [Ransomware]: dragnet-ransomware-2023-1022 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 8ea279d2-a503-5853-b4fe-30f5a841496f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
