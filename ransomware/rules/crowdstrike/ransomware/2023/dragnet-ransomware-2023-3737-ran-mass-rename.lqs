// Dragnet [Ransomware]: dragnet-ransomware-2023-3737 — Mass File Rename (raworld)
// Status: experimental | Level: high | ID: 57a241d5-1e9f-55bb-a1b4-a890064c92fc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
