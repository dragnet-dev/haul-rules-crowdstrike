// Dragnet [Ransomware]: dragnet-ransomware-2025-0495 — Mass File Rename (devman)
// Status: deprecated | Level: high | ID: c6e25d1d-4b5b-52d7-b691-18bbd332de57

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
