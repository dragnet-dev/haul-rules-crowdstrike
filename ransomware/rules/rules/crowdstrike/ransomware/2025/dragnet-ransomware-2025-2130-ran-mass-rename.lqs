// Dragnet [Ransomware]: dragnet-ransomware-2025-2130 — Mass File Rename (shinyhunters)
// Status: deprecated | Level: high | ID: a21a2ddc-b67b-53e5-bb8b-dec99f0378b2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
