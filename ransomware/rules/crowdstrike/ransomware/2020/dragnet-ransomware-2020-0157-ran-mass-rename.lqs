// Dragnet [Ransomware]: dragnet-ransomware-2020-0157 — Mass File Rename (revil)
// Status: deprecated | Level: high | ID: 1e94e553-faac-56a0-80b5-06b5a0c40ba2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
