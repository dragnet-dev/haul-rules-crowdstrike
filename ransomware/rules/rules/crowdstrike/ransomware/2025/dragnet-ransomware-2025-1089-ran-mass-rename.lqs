// Dragnet [Ransomware]: dragnet-ransomware-2025-1089 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 3fef94ea-ac8a-5139-917a-1e38552cb441

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
