// Dragnet [Ransomware]: dragnet-ransomware-2022-0546 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 0bf4a3c6-f709-597a-90b3-772e675e4c59

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
