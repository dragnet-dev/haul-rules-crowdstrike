// Dragnet [Ransomware]: dragnet-ransomware-2025-7854 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: c86a9a4d-66bc-543b-8369-777592c04832

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
