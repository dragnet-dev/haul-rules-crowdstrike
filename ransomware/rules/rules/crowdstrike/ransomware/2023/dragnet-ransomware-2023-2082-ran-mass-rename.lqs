// Dragnet [Ransomware]: dragnet-ransomware-2023-2082 — Mass File Rename (ransomhouse)
// Status: experimental | Level: high | ID: 8b4ade3f-506b-5a7b-be26-3f27ae5892d9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
