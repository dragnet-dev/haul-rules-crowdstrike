// Dragnet [Ransomware]: dragnet-ransomware-2024-4354 — Mass File Rename (BrainCipher)
// Status: experimental | Level: high | ID: b24a9423-4869-5c5d-8eb4-4fbea401f403

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
