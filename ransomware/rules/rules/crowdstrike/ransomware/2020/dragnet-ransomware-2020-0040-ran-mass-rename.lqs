// Dragnet [Ransomware]: dragnet-ransomware-2020-0040 — Mass File Rename (egregor)
// Status: deprecated | Level: high | ID: f648a1e2-ef6e-5956-9191-b3c55943da4f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
