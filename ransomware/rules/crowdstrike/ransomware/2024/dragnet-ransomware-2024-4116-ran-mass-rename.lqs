// Dragnet [Ransomware]: dragnet-ransomware-2024-4116 — Mass File Rename (meow)
// Status: experimental | Level: high | ID: e6e36920-0e76-53e1-a1bf-c611ee64c436

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
