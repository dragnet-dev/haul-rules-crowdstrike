// Dragnet [Ransomware]: dragnet-ransomware-2023-4200 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 42fb01b2-ad0a-5b79-8aea-0d9380b64f17

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
