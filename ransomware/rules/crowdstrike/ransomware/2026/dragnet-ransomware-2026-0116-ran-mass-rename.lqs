// Dragnet [Ransomware]: dragnet-ransomware-2026-0116 — Mass File Rename (incransom)
// Status: stable | Level: high | ID: 9a5620ab-b298-5ff6-873d-c39965bc9812

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
