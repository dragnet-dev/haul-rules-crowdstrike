// Dragnet [Ransomware]: dragnet-ransomware-2024-3852 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 1c024546-d0ae-56b4-b140-c2b762067eb6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
