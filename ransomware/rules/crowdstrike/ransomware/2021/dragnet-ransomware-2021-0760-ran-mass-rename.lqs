// Dragnet [Ransomware]: dragnet-ransomware-2021-0760 — Mass File Rename (xinglocker)
// Status: deprecated | Level: high | ID: 8c0f487b-a7ae-56aa-9f2f-5d9bfa52d556

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
