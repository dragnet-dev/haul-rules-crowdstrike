// Dragnet [Ransomware]: dragnet-ransomware-2026-0517 — Mass File Rename (lockbit5)
// Status: test | Level: high | ID: 7c0c9f59-0b44-5f1d-b52d-755b7ec81896

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
