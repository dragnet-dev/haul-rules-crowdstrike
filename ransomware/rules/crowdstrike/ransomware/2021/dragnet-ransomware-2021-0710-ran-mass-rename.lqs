// Dragnet [Ransomware]: dragnet-ransomware-2021-0710 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 1586448d-3db0-5e9f-9aa7-2f7b1c1a4a89

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
