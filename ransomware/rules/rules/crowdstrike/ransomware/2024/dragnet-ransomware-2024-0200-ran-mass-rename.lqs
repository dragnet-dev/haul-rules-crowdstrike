// Dragnet [Ransomware]: dragnet-ransomware-2024-0200 — Mass File Rename (safepay)
// Status: deprecated | Level: high | ID: 915fa680-19d4-57ca-b453-90ed906a8760

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
