// Dragnet [Ransomware]: dragnet-ransomware-2023-1765 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: a58b6504-944e-54ae-863e-57344a44d270

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
