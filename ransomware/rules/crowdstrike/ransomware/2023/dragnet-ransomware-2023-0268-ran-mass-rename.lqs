// Dragnet [Ransomware]: dragnet-ransomware-2023-0268 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 17e0a05a-51be-50d1-817a-f2ea67f67eae

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
