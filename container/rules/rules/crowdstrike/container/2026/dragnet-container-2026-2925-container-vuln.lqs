// Dragnet [Container]: dragnet-container-2026-2925 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: a7b37493-1841-5817-abe3-69d0aabe76d9

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *ubuntu:12.04* OR ImageFileName = *ubuntu:12.10*)
| table([timestamp, ComputerName])
| limit(1000)
