// Dragnet [Ransomware]: dragnet-ransomware-2024-1411 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: cd20d821-06cd-5bd0-b2b4-c82223755048

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
