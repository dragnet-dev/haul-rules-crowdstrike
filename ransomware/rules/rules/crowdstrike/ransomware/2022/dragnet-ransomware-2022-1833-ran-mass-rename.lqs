// Dragnet [Ransomware]: dragnet-ransomware-2022-1833 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: cf724876-c96f-52cf-b073-a6944bce567e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
