// Dragnet [Ransomware]: dragnet-ransomware-2023-2177 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: 1234c4a0-e448-55a4-886f-3df19729efe7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
