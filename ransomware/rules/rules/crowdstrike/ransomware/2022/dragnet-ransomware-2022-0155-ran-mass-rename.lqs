// Dragnet [Ransomware]: dragnet-ransomware-2022-0155 — Mass File Rename (vicesociety)
// Status: deprecated | Level: high | ID: 2c00891c-82c8-5a16-a2fa-b0c4fa2e774c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
