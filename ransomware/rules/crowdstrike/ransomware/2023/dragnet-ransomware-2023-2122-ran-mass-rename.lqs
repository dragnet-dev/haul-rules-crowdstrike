// Dragnet [Ransomware]: dragnet-ransomware-2023-2122 — Mass File Rename (play)
// Status: experimental | Level: high | ID: a563744a-46e0-5319-8f97-c3db9834f96f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
