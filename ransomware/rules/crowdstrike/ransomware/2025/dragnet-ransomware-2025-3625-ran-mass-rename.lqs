// Dragnet [Ransomware]: dragnet-ransomware-2025-3625 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 0986db64-bc10-5753-bf81-3dd91637800b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
