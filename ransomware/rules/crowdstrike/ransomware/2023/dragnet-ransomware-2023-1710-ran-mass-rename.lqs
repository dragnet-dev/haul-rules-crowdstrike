// Dragnet [Ransomware]: dragnet-ransomware-2023-1710 — Mass File Rename (dispossessor)
// Status: experimental | Level: high | ID: 53214c72-6734-5143-9286-df8abb758c0d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
