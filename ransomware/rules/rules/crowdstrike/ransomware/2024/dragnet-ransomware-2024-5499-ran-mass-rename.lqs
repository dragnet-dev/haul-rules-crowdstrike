// Dragnet [Ransomware]: dragnet-ransomware-2024-5499 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: d558da93-3a56-5179-9794-dc4e09b3c043

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
