// Dragnet [Ransomware]: dragnet-ransomware-2025-1499 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 82cd7566-dbc9-581b-bd59-c8fcc5f6b2c4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
