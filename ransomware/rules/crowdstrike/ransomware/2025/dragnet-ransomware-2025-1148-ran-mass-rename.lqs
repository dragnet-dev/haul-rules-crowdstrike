// Dragnet [Ransomware]: dragnet-ransomware-2025-1148 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 838a9d41-9f27-5cda-ac01-9a521836c617

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
