// Dragnet [Ransomware]: dragnet-ransomware-2024-1967 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: cbbf0a61-ea67-5bad-a113-8d5b62ac196b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
