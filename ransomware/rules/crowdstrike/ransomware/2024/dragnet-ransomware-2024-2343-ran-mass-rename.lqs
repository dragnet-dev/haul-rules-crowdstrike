// Dragnet [Ransomware]: dragnet-ransomware-2024-2343 — Mass File Rename (genesis)
// Status: experimental | Level: high | ID: 952c6565-7826-5192-b2e0-398fd5dbac84

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
