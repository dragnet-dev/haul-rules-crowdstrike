// Dragnet [Ransomware]: dragnet-ransomware-2025-2149 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: f956920d-844f-51c8-8004-6314faf3f84e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
