// Dragnet [Container]: dragnet-container-2026-2264 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: d193a5a4-b21e-5260-b1a4-dfc808eb2c91

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
