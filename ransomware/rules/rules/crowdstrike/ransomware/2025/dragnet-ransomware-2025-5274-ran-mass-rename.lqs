// Dragnet [Ransomware]: dragnet-ransomware-2025-5274 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: add5394a-6315-58ef-99d4-af867e822cd5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
