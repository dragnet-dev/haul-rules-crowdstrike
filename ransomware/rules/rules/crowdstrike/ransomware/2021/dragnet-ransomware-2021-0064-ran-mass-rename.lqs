// Dragnet [Ransomware]: dragnet-ransomware-2021-0064 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: fdb72cdb-3698-5830-9da3-2fb3b97a0593

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
