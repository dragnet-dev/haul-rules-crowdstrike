// Dragnet [Ransomware]: dragnet-ransomware-2021-1310 — Mass File Rename (ransomexx)
// Status: deprecated | Level: high | ID: 5ca8d8fc-99a2-5aad-8ed3-43a6bdfc0988

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
