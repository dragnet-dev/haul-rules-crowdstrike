// Dragnet [Ransomware]: dragnet-ransomware-2022-2958 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 0b9f945d-5953-56c1-b301-bca20f851b5d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
