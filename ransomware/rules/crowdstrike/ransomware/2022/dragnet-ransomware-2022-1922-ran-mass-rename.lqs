// Dragnet [Ransomware]: dragnet-ransomware-2022-1922 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: caadf484-9364-5107-8744-989d56c0a3bf

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
