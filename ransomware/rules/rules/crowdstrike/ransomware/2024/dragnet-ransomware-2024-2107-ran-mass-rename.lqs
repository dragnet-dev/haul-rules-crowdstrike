// Dragnet [Ransomware]: dragnet-ransomware-2024-2107 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 2e9c935b-d69d-54a7-b276-99743d9595be

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
