// Dragnet [Ransomware]: dragnet-ransomware-2024-0428 — Mass File Rename (meow)
// Status: experimental | Level: high | ID: 6d490ddf-5db8-5a86-8098-9bd4c8ed462a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
