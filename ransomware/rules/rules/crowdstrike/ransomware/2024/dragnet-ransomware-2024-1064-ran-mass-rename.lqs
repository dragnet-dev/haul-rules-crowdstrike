// Dragnet [Ransomware]: dragnet-ransomware-2024-1064 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 031069c7-c164-5507-bb91-3ec13155a71f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
