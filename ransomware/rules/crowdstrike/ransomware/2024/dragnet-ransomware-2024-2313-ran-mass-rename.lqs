// Dragnet [Ransomware]: dragnet-ransomware-2024-2313 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 28fd13d9-293d-5d86-8f31-3ec710157bc1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
