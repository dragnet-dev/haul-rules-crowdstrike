// Dragnet [Ransomware]: dragnet-ransomware-2024-2704 — Mass File Rename (dragonransomware)
// Status: experimental | Level: high | ID: ee66fe0a-1e3f-5990-bbf0-a1486a6de6ba

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
