// Dragnet [Ransomware]: dragnet-ransomware-2022-2326 — Mass File Rename (hive)
// Status: deprecated | Level: high | ID: 15fbeccc-14b4-536f-9249-f90fff694695

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
