// Dragnet [Container]: dragnet-container-2026-0098 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 4bb8ce71-1695-514b-80c7-5699c1f728cc

#event_simpleName=*
| (ImageFileName = *amazonlinux:1* OR ImageFileName = *amazonlinux:2* OR ImageFileName = *amazonlinux:2022* OR ImageFileName = *debian:10* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *debian:9* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:16.04-ESM* OR ImageFileName = *ubuntu:18.04* OR ImageFileName = *ubuntu:18.04-ESM* OR ImageFileName = *ubuntu:20.04* OR ImageFileName = *ubuntu:20.04-ESM* OR ImageFileName = *ubuntu:21.04* OR ImageFileName = *ubuntu:21.10*)
| table([timestamp, ComputerName])
| limit(1000)
