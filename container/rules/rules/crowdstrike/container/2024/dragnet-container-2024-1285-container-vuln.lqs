// Dragnet [Container]: dragnet-container-2024-1285 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: b7f1b8ae-0cc8-5628-83e5-ecae606168a8

#event_simpleName=*
| (ImageFileName = *amazonlinux:1* OR ImageFileName = *debian:11* OR ImageFileName = *debian:7* OR ImageFileName = *debian:8* OR ImageFileName = *debian:9* OR ImageFileName = *photon os:1.0* OR ImageFileName = *ubuntu:14.04* OR ImageFileName = *ubuntu:14.04-ESM* OR ImageFileName = *ubuntu:16.04* OR ImageFileName = *ubuntu:16.04-ESM* OR ImageFileName = *ubuntu:17.10* OR ImageFileName = *ubuntu:18.04* OR ImageFileName = *ubuntu:18.04-ESM* OR ImageFileName = *ubuntu:18.10*)
| table([timestamp, ComputerName])
| limit(1000)
