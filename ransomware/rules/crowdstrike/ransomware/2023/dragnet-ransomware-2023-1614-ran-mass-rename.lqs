// Dragnet [Ransomware]: dragnet-ransomware-2023-1614 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: 9f0eddac-ec70-50e4-a288-e1e650e2f235

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
