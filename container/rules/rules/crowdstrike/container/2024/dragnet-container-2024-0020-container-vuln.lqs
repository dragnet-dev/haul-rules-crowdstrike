// Dragnet [Container]: dragnet-container-2024-0020 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 9186de0f-3014-55f0-9fcc-3eadb7311acd

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13*)
| table([timestamp, ComputerName])
| limit(1000)
