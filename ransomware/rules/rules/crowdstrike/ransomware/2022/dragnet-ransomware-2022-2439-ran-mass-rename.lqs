// Dragnet [Ransomware]: dragnet-ransomware-2022-2439 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 295431dd-ec24-50c6-93cc-a38abfef8b06

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
