// Dragnet [Ransomware]: dragnet-ransomware-2024-4518 — Mass File Rename (hunters)
// Status: experimental | Level: high | ID: ef7c5c24-90ec-5514-84ca-a8a1b0d11420

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
