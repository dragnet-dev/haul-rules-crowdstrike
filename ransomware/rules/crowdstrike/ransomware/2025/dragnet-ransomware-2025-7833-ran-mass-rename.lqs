// Dragnet [Ransomware]: dragnet-ransomware-2025-7833 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: b0dcbc41-b402-58ac-ae3e-72105c34c948

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
