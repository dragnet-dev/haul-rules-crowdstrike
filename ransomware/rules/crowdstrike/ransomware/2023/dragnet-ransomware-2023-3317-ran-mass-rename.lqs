// Dragnet [Ransomware]: dragnet-ransomware-2023-3317 — Mass File Rename (bianlian)
// Status: experimental | Level: high | ID: 6cde7d14-420c-5193-a118-c264dbc699ef

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
