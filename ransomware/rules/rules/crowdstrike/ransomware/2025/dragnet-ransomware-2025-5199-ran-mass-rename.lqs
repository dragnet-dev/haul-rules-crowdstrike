// Dragnet [Ransomware]: dragnet-ransomware-2025-5199 — Mass File Rename (sinobi)
// Status: experimental | Level: high | ID: c5cca418-a7c2-58bf-a255-ee986a941a08

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
