// Dragnet [Ransomware]: dragnet-ransomware-2024-3980 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: bd15f8a1-4ad2-5ac8-aec2-3e44f7b2d808

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
