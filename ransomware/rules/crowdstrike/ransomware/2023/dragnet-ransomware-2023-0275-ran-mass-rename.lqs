// Dragnet [Ransomware]: dragnet-ransomware-2023-0275 — Mass File Rename (toufan)
// Status: deprecated | Level: high | ID: de3db9a0-0286-5314-b6a5-c7775b33a9f2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
