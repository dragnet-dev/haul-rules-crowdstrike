// Dragnet [Ransomware]: dragnet-ransomware-2026-0297 — Mass File Rename (dragonforce)
// Status: test | Level: high | ID: 468587f6-d484-5557-9159-8dcafbea9afd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
