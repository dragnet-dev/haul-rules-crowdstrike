// Dragnet [Ransomware]: dragnet-ransomware-2021-1586 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 8558d385-07d9-585b-bdca-ebce190442c7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
