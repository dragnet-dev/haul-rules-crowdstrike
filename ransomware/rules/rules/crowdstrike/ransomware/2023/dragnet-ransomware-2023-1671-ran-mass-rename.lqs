// Dragnet [Ransomware]: dragnet-ransomware-2023-1671 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 99b22d40-b856-5b95-a625-790c01af79b7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
