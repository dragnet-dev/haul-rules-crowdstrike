// Dragnet [Ransomware]: dragnet-ransomware-2025-6411 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: a4852394-3806-59c4-9681-fb0a5aeffcac

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
