// Dragnet [Ransomware]: dragnet-ransomware-2025-1041 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 956d29b8-b36a-5b0d-ad0d-92cddb1a52ff

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
