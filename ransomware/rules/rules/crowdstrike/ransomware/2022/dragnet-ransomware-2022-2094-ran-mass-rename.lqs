// Dragnet [Ransomware]: dragnet-ransomware-2022-2094 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: f1e7a791-c841-5af1-a69b-03f15edeb2ed

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
