// Dragnet [Ransomware]: dragnet-ransomware-2022-0858 — Mass File Rename (ragnarlocker)
// Status: deprecated | Level: high | ID: 28d0202c-2df4-533f-ba37-1ad867ff5432

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
