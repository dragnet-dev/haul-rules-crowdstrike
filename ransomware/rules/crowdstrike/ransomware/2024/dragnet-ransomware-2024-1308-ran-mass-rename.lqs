// Dragnet [Ransomware]: dragnet-ransomware-2024-1308 — Mass File Rename (metaencryptor)
// Status: experimental | Level: high | ID: be5b824c-6b3a-5451-9d4f-abd5acfa5d06

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
