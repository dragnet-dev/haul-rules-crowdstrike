// Dragnet [Ransomware]: dragnet-ransomware-2023-1495 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 990e6b01-3454-548c-8064-5b9a10afe1ad

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
