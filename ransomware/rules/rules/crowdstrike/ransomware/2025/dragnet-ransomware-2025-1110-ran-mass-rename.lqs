// Dragnet [Ransomware]: dragnet-ransomware-2025-1110 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 1fef3140-cadf-5549-928e-c75a8ea1be7a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
