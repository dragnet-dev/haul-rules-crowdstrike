// Dragnet [Ransomware]: dragnet-ransomware-2026-1192 — Mass File Rename (AiLock)
// Status: deprecated | Level: high | ID: ad953219-7010-5c48-81d8-a325dcc8726f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
