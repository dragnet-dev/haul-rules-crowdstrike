// Dragnet [Ransomware]: dragnet-ransomware-2025-4178 — Mass File Rename (global)
// Status: deprecated | Level: high | ID: e49a7767-aa7a-51e2-b9d2-a70d12333d23

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
