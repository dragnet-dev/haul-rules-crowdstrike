// Dragnet [Ransomware]: dragnet-ransomware-2025-1425 — Mass File Rename (gunra)
// Status: experimental | Level: high | ID: 31ad93db-a7f0-5d04-b83f-b9d272cb14b6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
