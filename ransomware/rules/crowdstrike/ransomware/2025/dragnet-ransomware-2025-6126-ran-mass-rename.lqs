// Dragnet [Ransomware]: dragnet-ransomware-2025-6126 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: 1f5f059b-dda8-5fa3-8ecf-8ec25aba28e9

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
