// Dragnet [Ransomware]: dragnet-ransomware-2021-0183 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 5267c877-e296-51fa-a555-962ad582eb6b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
