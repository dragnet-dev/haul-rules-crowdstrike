// Dragnet [Ransomware]: dragnet-ransomware-2023-4178 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: bb02c08e-d223-5a70-909b-064fceb01bbc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
