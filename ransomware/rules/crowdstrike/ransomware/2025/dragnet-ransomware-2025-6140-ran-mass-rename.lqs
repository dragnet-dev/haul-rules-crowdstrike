// Dragnet [Ransomware]: dragnet-ransomware-2025-6140 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: a406f5d0-a60a-5e12-98dd-9541e1184a57

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
