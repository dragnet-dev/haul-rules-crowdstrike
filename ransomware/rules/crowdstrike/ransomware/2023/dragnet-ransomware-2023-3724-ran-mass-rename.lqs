// Dragnet [Ransomware]: dragnet-ransomware-2023-3724 — Mass File Rename (cryptbb)
// Status: experimental | Level: high | ID: a8fcae2f-b0f9-57a5-a4d7-9805830da6dc

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
