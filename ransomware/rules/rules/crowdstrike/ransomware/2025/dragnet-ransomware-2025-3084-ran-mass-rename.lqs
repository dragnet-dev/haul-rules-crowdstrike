// Dragnet [Ransomware]: dragnet-ransomware-2025-3084 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: aeb328f5-6084-52bd-9c2b-c21e26fb27d7

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
