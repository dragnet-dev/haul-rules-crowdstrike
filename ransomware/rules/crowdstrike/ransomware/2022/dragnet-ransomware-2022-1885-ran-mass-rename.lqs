// Dragnet [Ransomware]: dragnet-ransomware-2022-1885 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: 65ee836f-d2d1-5e8c-a05a-7309b37a7b99

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
