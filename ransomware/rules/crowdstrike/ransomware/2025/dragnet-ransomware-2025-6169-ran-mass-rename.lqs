// Dragnet [Ransomware]: dragnet-ransomware-2025-6169 — Mass File Rename (direwolf)
// Status: experimental | Level: high | ID: eca7a6cb-cb86-5e6b-8c87-ad31888aee2c

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
