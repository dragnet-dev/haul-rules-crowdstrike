// Dragnet [Ransomware]: dragnet-ransomware-2024-5882 — Mass File Rename (blackbasta)
// Status: experimental | Level: high | ID: 73f23415-8251-5ffd-85d8-418d43fa0279

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
