// Dragnet [Ransomware]: dragnet-ransomware-2022-0331 — Mass File Rename (lockbit2)
// Status: deprecated | Level: high | ID: 90a100a6-06e6-5555-a173-8c41034ccc79

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
