// Dragnet [Ransomware]: dragnet-ransomware-2024-5002 — Mass File Rename (cactus)
// Status: experimental | Level: high | ID: f6b5cd23-a3e3-5486-896c-2e95a03dcde6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
