// Dragnet [Ransomware]: dragnet-ransomware-2024-3537 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: f021014e-e24d-53eb-a333-2c7219370408

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
