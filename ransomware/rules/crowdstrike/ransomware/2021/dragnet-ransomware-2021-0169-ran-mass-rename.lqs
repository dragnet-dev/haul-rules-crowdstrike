// Dragnet [Ransomware]: dragnet-ransomware-2021-0169 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: ad735b08-277c-57bf-8909-b8c2ecbff8d6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
