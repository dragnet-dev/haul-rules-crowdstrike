// Dragnet [Ransomware]: dragnet-ransomware-2023-0627 — Mass File Rename (losttrust)
// Status: deprecated | Level: high | ID: ff269b24-c338-5fda-bd16-ae482c0928a0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
