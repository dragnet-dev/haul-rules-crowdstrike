// Dragnet [Ransomware]: dragnet-ransomware-2024-1460 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: ad803c25-48bb-58a2-99c8-67f6fb0c4aa6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
