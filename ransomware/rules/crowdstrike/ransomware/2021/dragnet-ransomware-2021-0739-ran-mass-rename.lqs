// Dragnet [Ransomware]: dragnet-ransomware-2021-0739 — Mass File Rename (conti)
// Status: deprecated | Level: high | ID: 9d59f1e1-08f9-5839-8c51-f926e5bde160

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
