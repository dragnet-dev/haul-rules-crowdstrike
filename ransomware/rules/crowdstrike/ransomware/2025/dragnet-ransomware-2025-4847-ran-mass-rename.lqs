// Dragnet [Ransomware]: dragnet-ransomware-2025-4847 — Mass File Rename (anubis)
// Status: experimental | Level: high | ID: 88be3e98-57a5-59e1-8287-5e5e0c0cc890

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
