// Dragnet [Ransomware]: dragnet-ransomware-2023-0806 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: d3bf0240-b19e-5a2a-a271-35e8c5e9cf1e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
