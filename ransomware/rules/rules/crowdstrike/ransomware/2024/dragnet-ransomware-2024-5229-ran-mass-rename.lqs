// Dragnet [Ransomware]: dragnet-ransomware-2024-5229 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 0ec13e45-fe1e-55be-bb00-157bb82d3335

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
