// Dragnet [Ransomware]: dragnet-ransomware-2025-6238 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: d629f36f-db7f-5c8f-8628-43de1ef598e1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
