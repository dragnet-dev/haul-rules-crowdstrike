// Dragnet [Ransomware]: dragnet-ransomware-2024-2995 — Mass File Rename (SilentRansomGroup)
// Status: deprecated | Level: high | ID: 824bb615-737c-53af-a712-06df292363c2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
