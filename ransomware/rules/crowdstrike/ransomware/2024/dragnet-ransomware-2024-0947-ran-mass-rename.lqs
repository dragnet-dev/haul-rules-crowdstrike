// Dragnet [Ransomware]: dragnet-ransomware-2024-0947 — Mass File Rename (unsafe)
// Status: deprecated | Level: high | ID: 2edf179c-d7b9-5664-80c0-c36c205bdc01

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
