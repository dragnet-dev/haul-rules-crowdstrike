// Dragnet [Ransomware]: dragnet-ransomware-2025-7645 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 1dc20195-274e-5217-ad73-2845916819a0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
