// Dragnet [Ransomware]: dragnet-ransomware-2025-1680 — Mass File Rename (play)
// Status: experimental | Level: high | ID: fd5c889b-58cb-54c7-ada6-d6985d67ace4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
