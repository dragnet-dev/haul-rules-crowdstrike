// Dragnet [Ransomware]: dragnet-ransomware-2024-1714 — Mass File Rename (monti)
// Status: experimental | Level: high | ID: 5ae0cf9f-6976-5af5-b515-281a19568eb6

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
