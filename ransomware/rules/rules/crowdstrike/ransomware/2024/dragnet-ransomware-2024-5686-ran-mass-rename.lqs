// Dragnet [Ransomware]: dragnet-ransomware-2024-5686 — Mass File Rename (arcusmedia)
// Status: experimental | Level: high | ID: fa4ac90f-7c40-5d28-be2c-dd0b62181f2e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
