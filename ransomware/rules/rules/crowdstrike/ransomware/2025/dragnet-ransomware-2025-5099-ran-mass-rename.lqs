// Dragnet [Ransomware]: dragnet-ransomware-2025-5099 — Mass File Rename (incransom)
// Status: experimental | Level: high | ID: e0833815-7b2e-5cab-8c40-5bea123a7354

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
