// Dragnet [Ransomware]: dragnet-ransomware-2024-4770 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: dc9b2f80-ada8-591a-953f-a1d1c47c1cda

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
