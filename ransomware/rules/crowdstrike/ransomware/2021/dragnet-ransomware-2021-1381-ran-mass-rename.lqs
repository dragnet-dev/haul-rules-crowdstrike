// Dragnet [Ransomware]: dragnet-ransomware-2021-1381 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 26f91911-c8f6-5d4b-9b53-30a3480e1ee0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
