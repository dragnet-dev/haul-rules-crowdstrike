// Dragnet [Ransomware]: dragnet-ransomware-2025-7929 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: 20bb6ebe-0a2c-5bb0-8510-8b38b0d966e2

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
