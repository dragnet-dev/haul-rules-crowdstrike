// Dragnet [Container]: dragnet-container-2026-0670 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 385f2f5f-ff43-5c6f-a4bb-adc37e368904

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
