// Dragnet [Ransomware]: dragnet-ransomware-2023-5256 — Mass File Rename (lockbit3)
// Status: deprecated | Level: high | ID: b19a00df-0645-5398-8431-002360de85a3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
