// Dragnet [Ransomware]: dragnet-ransomware-2023-1312 — Mass File Rename (play)
// Status: experimental | Level: high | ID: 9322dd22-ece9-55d5-9a69-68006821cff1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
