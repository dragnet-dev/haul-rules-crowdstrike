// Dragnet [Ransomware]: dragnet-ransomware-2025-3299 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: deadc462-3810-5b8f-88e2-1514368ae3e4

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
