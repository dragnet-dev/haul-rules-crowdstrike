// Dragnet [Ransomware]: dragnet-ransomware-2025-4740 — Mass File Rename (clop)
// Status: deprecated | Level: high | ID: a4cfc3d9-ceea-5a25-80b4-6ff2fa679732

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
