// Dragnet [Ransomware]: dragnet-ransomware-2025-6251 — Mass File Rename (ralord)
// Status: experimental | Level: high | ID: 3853f113-9e1a-5efa-9641-48093c6e18aa

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
