// Dragnet [Ransomware]: dragnet-ransomware-2024-4445 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: b289807b-6af9-52fa-9ac6-b5f043d80e97

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
