// Dragnet [Ransomware]: dragnet-ransomware-2024-5072 — Mass File Rename (frag)
// Status: deprecated | Level: high | ID: ed2f5c50-c51e-5963-9e80-a8a3e0c2b15f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
