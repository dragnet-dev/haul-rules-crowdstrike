// Dragnet [Ransomware]: dragnet-ransomware-2022-1068 — Mass File Rename (lv)
// Status: deprecated | Level: high | ID: 44954a4e-c275-592a-af0d-80b9be80ca68

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
