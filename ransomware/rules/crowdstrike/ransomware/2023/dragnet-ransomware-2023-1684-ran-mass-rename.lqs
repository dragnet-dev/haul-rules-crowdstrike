// Dragnet [Ransomware]: dragnet-ransomware-2023-1684 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: f7c4fba1-4cc7-5043-abb8-b3383d1b4265

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
