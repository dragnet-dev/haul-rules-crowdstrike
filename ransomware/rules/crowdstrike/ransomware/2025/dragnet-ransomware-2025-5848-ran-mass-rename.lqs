// Dragnet [Ransomware]: dragnet-ransomware-2025-5848 — Mass File Rename (gunra)
// Status: experimental | Level: high | ID: d7494247-c2fd-5b8e-a8a0-58c0d5a5213d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
