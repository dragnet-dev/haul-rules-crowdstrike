// Dragnet [Ransomware]: dragnet-ransomware-2024-5039 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 6277acd3-9ca1-593c-a850-16ebc206d693

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
