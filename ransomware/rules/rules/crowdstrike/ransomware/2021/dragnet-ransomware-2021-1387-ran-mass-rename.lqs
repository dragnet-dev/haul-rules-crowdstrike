// Dragnet [Ransomware]: dragnet-ransomware-2021-1387 — Mass File Rename (suncrypt)
// Status: deprecated | Level: high | ID: eb6319b2-6691-5c91-84e9-9df475677980

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
