// Dragnet [Ransomware]: dragnet-ransomware-2025-3409 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 0003b0a2-f8e5-51ce-8cf7-b48bb801b822

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
