// Dragnet [Ransomware]: dragnet-ransomware-2025-4863 — Mass File Rename (sarcoma)
// Status: deprecated | Level: high | ID: d40b1ed8-1eb1-5402-b62b-ac3027787a4d

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
