// Dragnet [Ransomware]: dragnet-ransomware-2024-3240 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 11a4c78b-b09e-5d3c-8169-ff0921a39b92

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
