// Dragnet [Ransomware]: dragnet-ransomware-2024-1652 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: 9499bc2c-4922-59ec-b24b-4f88b33f47a0

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
