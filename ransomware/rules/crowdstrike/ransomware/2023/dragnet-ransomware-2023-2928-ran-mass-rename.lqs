// Dragnet [Ransomware]: dragnet-ransomware-2023-2928 — Mass File Rename (snatch)
// Status: experimental | Level: high | ID: 4ed2d0cc-3aaa-5866-a5d3-c5e5c224afba

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
