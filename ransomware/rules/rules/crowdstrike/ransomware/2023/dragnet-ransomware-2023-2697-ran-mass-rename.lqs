// Dragnet [Ransomware]: dragnet-ransomware-2023-2697 — Mass File Rename (alphv)
// Status: experimental | Level: high | ID: a55b12b2-8462-5c42-b094-4ba97bce7d7b

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
