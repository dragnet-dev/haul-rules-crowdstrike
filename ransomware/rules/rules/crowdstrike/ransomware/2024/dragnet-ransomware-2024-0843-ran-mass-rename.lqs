// Dragnet [Ransomware]: dragnet-ransomware-2024-0843 — Mass File Rename (medusa)
// Status: experimental | Level: high | ID: b89c2ba0-8c4b-5c67-b28e-943f156ec01f

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
