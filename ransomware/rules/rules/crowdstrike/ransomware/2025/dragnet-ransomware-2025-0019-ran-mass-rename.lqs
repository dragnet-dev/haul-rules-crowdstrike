// Dragnet [Ransomware]: dragnet-ransomware-2025-0019 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 39fcca1e-9ef3-590d-8d0e-a92d25e9ac6e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
