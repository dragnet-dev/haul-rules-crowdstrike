// Dragnet [Ransomware]: dragnet-ransomware-2024-4542 — Mass File Rename (sarcoma)
// Status: deprecated | Level: high | ID: ea59241f-9cd7-5394-a2c2-2aa8a3ffa65e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
