// Dragnet [Ransomware]: dragnet-ransomware-2026-0053 — Mass File Rename (payoutsking)
// Status: deprecated | Level: high | ID: b2251409-ae42-548e-a66f-984d66b082e8

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
