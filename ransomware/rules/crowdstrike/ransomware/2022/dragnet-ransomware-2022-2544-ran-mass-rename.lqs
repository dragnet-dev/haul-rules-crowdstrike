// Dragnet [Ransomware]: dragnet-ransomware-2022-2544 — Mass File Rename (royal)
// Status: deprecated | Level: high | ID: 1ca1dc5a-868f-5556-b747-6789dd45a39a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
