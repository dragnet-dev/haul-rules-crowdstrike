// Dragnet [Container]: dragnet-container-2026-0450 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 34c0afba-0ddb-5310-b0dc-dfb9bf460382

#event_simpleName=*
| (ImageFileName = *alpine edge:* OR ImageFileName = *chainguard:* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *wolfi:*)
| table([timestamp, ComputerName])
| limit(1000)
