// Dragnet [Container]: dragnet-container-2024-1161 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 42c18923-dbd4-5cf5-a75c-d318c90bfb82

#event_simpleName=*
| (ImageFileName = *almalinux:8* OR ImageFileName = *amazonlinux:2* OR ImageFileName = *cbl-mariner:1.0* OR ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14* OR ImageFileName = *oraclelinux:8* OR ImageFileName = *photon os:1.0* OR ImageFileName = *photon os:2.0* OR ImageFileName = *photon os:3.0* OR ImageFileName = *redhat/ubi9:* OR ImageFileName = *ubuntu:16.04* OR ImageFileName = *ubuntu:16.04-ESM* OR ImageFileName = *ubuntu:18.04* OR ImageFileName = *ubuntu:18.04-ESM*)
| table([timestamp, ComputerName])
| limit(1000)
