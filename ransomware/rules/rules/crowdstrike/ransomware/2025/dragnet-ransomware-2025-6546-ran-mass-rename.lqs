// Dragnet [Ransomware]: dragnet-ransomware-2025-6546 — Mass File Rename (sinobi)
// Status: experimental | Level: high | ID: 70fcc94c-946b-5d3d-a980-0a4de7852cc5

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
