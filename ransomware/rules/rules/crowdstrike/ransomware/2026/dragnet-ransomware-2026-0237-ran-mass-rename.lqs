// Dragnet [Ransomware]: dragnet-ransomware-2026-0237 — Mass File Rename (akira)
// Status: deprecated | Level: high | ID: f45e4ce3-a87e-5c96-bd0f-12833911b138

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
