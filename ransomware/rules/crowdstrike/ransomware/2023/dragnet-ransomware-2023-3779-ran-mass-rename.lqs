// Dragnet [Ransomware]: dragnet-ransomware-2023-3779 — Mass File Rename (clop)
// Status: experimental | Level: high | ID: 124d4d4e-6023-5e15-b422-8f80bd8a4149

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
