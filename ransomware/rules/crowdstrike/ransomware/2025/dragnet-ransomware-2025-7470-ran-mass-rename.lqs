// Dragnet [Ransomware]: dragnet-ransomware-2025-7470 — Mass File Rename (rhysida)
// Status: experimental | Level: high | ID: 505872c1-5dc6-5289-8d47-ec9b19bcc0f1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
