// Dragnet [Ransomware]: dragnet-ransomware-2021-1097 — Mass File Rename (avaddon)
// Status: deprecated | Level: high | ID: acf2255c-04fa-5371-96ee-f354aaddd236

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
