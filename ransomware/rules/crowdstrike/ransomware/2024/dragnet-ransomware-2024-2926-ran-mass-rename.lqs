// Dragnet [Ransomware]: dragnet-ransomware-2024-2926 — Mass File Rename (ransomhub)
// Status: experimental | Level: high | ID: 0fc1b78d-3544-5b9f-9ed5-5454fcd66d86

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
