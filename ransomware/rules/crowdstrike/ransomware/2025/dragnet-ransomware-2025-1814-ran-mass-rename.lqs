// Dragnet [Ransomware]: dragnet-ransomware-2025-1814 — Mass File Rename (babuk2)
// Status: experimental | Level: high | ID: 970fa2dc-e9c0-5e9d-a209-2e4b07a77421

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
