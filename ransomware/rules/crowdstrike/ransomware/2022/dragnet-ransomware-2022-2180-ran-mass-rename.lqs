// Dragnet [Ransomware]: dragnet-ransomware-2022-2180 — Mass File Rename (8base)
// Status: experimental | Level: high | ID: d63c2194-67cb-59eb-a314-caf4d6604462

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
