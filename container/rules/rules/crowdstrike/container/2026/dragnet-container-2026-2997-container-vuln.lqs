// Dragnet [Container]: dragnet-container-2026-2997 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: ee77fb9f-9d31-57e1-850e-73fb4a3272ec

#event_simpleName=*
| (ImageFileName = *debian:11* OR ImageFileName = *debian:12* OR ImageFileName = *debian:13* OR ImageFileName = *debian:14*)
| table([timestamp, ComputerName])
| limit(1000)
