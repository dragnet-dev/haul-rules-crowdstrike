// Dragnet [Ransomware]: dragnet-ransomware-2024-3059 — Mass File Rename (mallox)
// Status: experimental | Level: high | ID: 1ce513ef-987b-563e-9eea-30ea1740c164

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
