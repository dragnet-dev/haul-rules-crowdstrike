// Dragnet [Ransomware]: dragnet-ransomware-2024-1870 — Mass File Rename (qilin)
// Status: experimental | Level: high | ID: 2fb7c368-dd88-54dd-9449-b6427fca39ff

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
