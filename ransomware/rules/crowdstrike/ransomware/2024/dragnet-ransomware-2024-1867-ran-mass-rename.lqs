// Dragnet [Ransomware]: dragnet-ransomware-2024-1867 — Mass File Rename (ransomexx)
// Status: experimental | Level: high | ID: f1316ef8-e557-57d5-89d3-aa45bf7f85fd

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
