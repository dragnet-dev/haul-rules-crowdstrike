// Dragnet [Ransomware]: dragnet-ransomware-2024-5528 — Mass File Rename (lockbit3)
// Status: experimental | Level: high | ID: 7affb1db-020f-5fa1-bf50-c39b3277ae24

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
