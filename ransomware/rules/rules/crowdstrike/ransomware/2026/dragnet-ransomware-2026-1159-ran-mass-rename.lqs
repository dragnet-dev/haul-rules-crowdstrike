// Dragnet [Ransomware]: dragnet-ransomware-2026-1159 — Mass File Rename (thegentlemen)
// Status: stable | Level: high | ID: 433530c7-165c-53b4-a8e3-f37ab55f29db

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
