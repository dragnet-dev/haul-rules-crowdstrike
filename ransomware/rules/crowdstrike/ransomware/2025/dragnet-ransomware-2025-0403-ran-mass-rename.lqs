// Dragnet [Ransomware]: dragnet-ransomware-2025-0403 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 3f849878-a7f5-5cdc-9719-f20aa895fa0e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
