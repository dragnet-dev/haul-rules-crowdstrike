// Dragnet [Ransomware]: dragnet-ransomware-2022-1709 — Mass File Rename (play)
// Status: deprecated | Level: high | ID: f735f170-3e06-575a-b2d7-17c9b980aa8e

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
