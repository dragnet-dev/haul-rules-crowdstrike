// Dragnet [Ransomware]: dragnet-ransomware-2025-1800 — Mass File Rename (safepay)
// Status: experimental | Level: high | ID: 8b45f888-9c08-5b0e-ba73-4fea7edd3db3

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
