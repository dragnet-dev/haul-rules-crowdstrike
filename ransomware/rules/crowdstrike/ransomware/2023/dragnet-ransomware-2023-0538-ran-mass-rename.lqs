// Dragnet [Ransomware]: dragnet-ransomware-2023-0538 — Mass File Rename (vicesociety)
// Status: experimental | Level: high | ID: 4fee274c-dca1-5ada-a551-ce033d776009

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
