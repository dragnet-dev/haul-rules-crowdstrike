// Dragnet [Ransomware]: dragnet-ransomware-2024-4814 — Mass File Rename (flocker)
// Status: experimental | Level: high | ID: 9e43dc7e-7158-549c-bec0-8db19afe19b1

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
