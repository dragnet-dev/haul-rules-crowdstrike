// Dragnet [Ransomware]: dragnet-ransomware-2025-6684 — Mass File Rename (lynx)
// Status: experimental | Level: high | ID: 9c17d846-de4b-5c53-bb07-bec37558877a

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
