// Dragnet [Ransomware]: dragnet-ransomware-2021-0436 — Mass File Rename (pysa)
// Status: deprecated | Level: high | ID: 9e2df603-5c1c-524e-b6c3-463ee5f62917

#event_simpleName=*
| (FilePath = *.encrypted OR FilePath = *.locked OR FilePath = *.ransom)
| table([timestamp, ComputerName])
| limit(1000)
